[{"id":1735129281000,"createdDate":"2024-12-25 12:21","name":"法国国际广播电台","title":"呼唤有精神的艺术， 与人性同呼吸共命运的艺术","content":"为什么会出现乱世，为什么痛不欲生，为什么会未来越来越不可预见，为什么生活从习以为常会走向既不确定，更不可捉摸？为什么自己的人生会从有常走向无常？艺术能给答案吗？不一定。但是能够在艺术里得到启发，从而有感悟，甚至顿悟的经验，那就说明：眼前的艺术是有精神的，有力量的艺术。期待在2025年能看到更多这样的艺术。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%96%87%E5%8C%96%E8%89%BA%E6%9C%AF/20241225-%E5%91%BC%E5%94%A4%E6%9C%89%E7%B2%BE%E7%A5%9E%E7%9A%84%E8%89%BA%E6%9C%AF%EF%BC%8C-%E4%B8%8E%E4%BA%BA%E6%80%A7%E5%90%8C%E5%91%BC%E5%90%B8%E5%85%B1%E5%91%BD%E8%BF%90%E7%9A%84%E8%89%BA%E6%9C%AF","thumbnail":"","detailImage":"news/detail/rfi/2024/12/25/1735129281000.webp","sourceId":"rfi"},{"id":1735127873000,"createdDate":"2024-12-25 11:57","name":"法国国际广播电台","title":"叙利亚基督徒首次参加圣诞夜弥撒 圣诞树被烧引发抗议","content":"路透社报道，叙利亚首都大马士革圣母教堂星期二（12月24日）举行圣诞夜礼拜。由于担心针对基督教场所的暴力行为，活动在严密的安保下举行。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20241225-%E5%8F%99%E5%88%A9%E4%BA%9A%E5%9F%BA%E7%9D%A3%E5%BE%92%E9%A6%96%E6%AC%A1%E5%8F%82%E5%8A%A0%E5%9C%A3%E8%AF%9E%E5%A4%9C%E5%BC%A5%E6%92%92-%E5%9C%A3%E8%AF%9E%E6%A0%91%E8%A2%AB%E7%83%A7%E5%BC%95%E5%8F%91%E6%8A%97%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2024/12/25/1735127873000.webp","sourceId":"rfi"},{"id":1735126884000,"createdDate":"2024-12-25 11:41","name":"法国国际广播电台","title":"阿塞拜疆航空一客机飞俄罗斯途中在哈萨克坠毁","content":"阿塞拜疆航空公司一架客机在哈萨克坠毁，在本文截稿前，据法新社消息称有32人生还，哈萨克当局表示正调查客机失事原因，包括是否涉及技术问题。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20241225-%E9%98%BF%E5%A1%9E%E6%8B%9C%E7%96%86%E8%88%AA%E7%A9%BA%E4%B8%80%E5%AE%A2%E6%9C%BA%E9%A3%9E%E4%BF%84%E7%BD%97%E6%96%AF%E9%80%94%E4%B8%AD%E5%9C%A8%E5%93%88%E8%90%A8%E5%85%8B%E5%9D%A0%E6%AF%81","thumbnail":"","detailImage":"news/detail/rfi/2024/12/25/1735126884000.webp","sourceId":"rfi"},{"id":1735125910000,"createdDate":"2024-12-25 11:25","name":"法国国际广播电台","title":"越南管制互联网新法生效 人权观察组织：对言论自由构成威胁","content":"越南管制互联网的法律在圣诞节当天生效。新法规定社交媒体用户须验证身份，社媒平台必须存储用户数据，按当局要求提供数据，以及把政府视为非法的内容在24小时内删除。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20241225-%E8%B6%8A%E5%8D%97%E7%AE%A1%E5%88%B6%E4%BA%92%E8%81%94%E7%BD%91%E6%96%B0%E6%B3%95%E7%94%9F%E6%95%88-%E4%BA%BA%E6%9D%83%E8%A7%82%E5%AF%9F%E7%BB%84%E7%BB%87-%E5%AF%B9%E8%A8%80%E8%AE%BA%E8%87%AA%E7%94%B1%E6%9E%84%E6%88%90%E5%A8%81%E8%83%81","thumbnail":"","detailImage":"news/detail/rfi/2024/12/25/1735125910000.webp","sourceId":"rfi"},{"id":1735125495000,"createdDate":"2024-12-25 11:18","name":"法国国际广播电台","title":"韩国在野党以弹劾代总统为压力要立法惩处尹锡悦夫妇，韩国外长打电话给中国外长希望持续发展战略伙伴关系","content":"韩国政治不确定因素明显。代行总统职权的国务总理韩悳洙有被弹劾的可能。韩国外长赵兑烈昨天打电话给中国外长王毅，介绍了韩国的形势，强调韩国政府在职权代行体制下仍将继续发展韩中战略合作伙伴关系。赵兑烈表示，两国应在亚太经合组织领导人非正式会议等多个平台保持合作。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241225-%E9%9F%A9%E5%9B%BD%E5%9C%A8%E9%87%8E%E5%85%9A%E4%BB%A5%E5%BC%B9%E5%8A%BE%E4%BB%A3%E6%80%BB%E7%BB%9F%E4%B8%BA%E5%8E%8B%E5%8A%9B%E8%A6%81%E7%AB%8B%E6%B3%95%E6%83%A9%E5%A4%84%E5%B0%B9%E9%94%A1%E6%82%A6%E5%A4%AB%E5%A6%87%EF%BC%8C%E9%9F%A9%E5%9B%BD%E5%A4%96%E9%95%BF%E6%89%93%E7%94%B5%E8%AF%9D%E7%BB%99%E4%B8%AD%E5%9B%BD%E5%A4%96%E9%95%BF%E5%B8%8C%E6%9C%9B%E6%8C%81%E7%BB%AD%E5%8F%91%E5%B1%95%E6%88%98%E7%95%A5%E4%BC%99%E4%BC%B4%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2024/12/25/1735125495000.webp","sourceId":"rfi"},{"id":1735119386000,"createdDate":"2024-12-25 09:36","name":"法国国际广播电台","title":"方济各主持圣诞夜弥撒 开启天主教圣年 鼓励人们让世界更美好","content":"教宗方济各主持圣诞夜弥撒，同时开启每25年一次的天主教圣年，呼吁人们鼓起勇气让世界变得更美好。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241225-%E6%96%B9%E6%B5%8E%E5%90%84%E4%B8%BB%E6%8C%81%E5%9C%A3%E8%AF%9E%E5%A4%9C%E5%BC%A5%E6%92%92-%E5%BC%80%E5%90%AF%E5%A4%A9%E4%B8%BB%E6%95%99%E5%9C%A3%E5%B9%B4-%E9%BC%93%E5%8A%B1%E4%BA%BA%E4%BB%AC%E8%AE%A9%E4%B8%96%E7%95%8C%E6%9B%B4%E7%BE%8E%E5%A5%BD","thumbnail":"","detailImage":"news/detail/rfi/2024/12/25/1735119386000.webp","sourceId":"rfi"},{"id":1735118086000,"createdDate":"2024-12-25 09:14","name":"法国国际广播电台","title":"圣诞节一早 俄罗斯导弹袭击乌克兰破坏能源设施","content":"无视圣诞节，俄罗斯仍然发动大规模袭击，破坏乌克兰各地的能源基础设施。据法新社报道，乌克兰星期三（12月25日）早上响起空袭警报，俄罗斯用巡航导弹和弹道导弹袭击乌克兰。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20241225-%E5%9C%A3%E8%AF%9E%E8%8A%82%E4%B8%80%E6%97%A9-%E4%BF%84%E7%BD%97%E6%96%AF%E5%AF%BC%E5%BC%B9%E8%A2%AD%E5%87%BB%E4%B9%8C%E5%85%8B%E5%85%B0%E7%A0%B4%E5%9D%8F%E8%83%BD%E6%BA%90%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2024/12/25/1735118086000.webp","sourceId":"rfi"},{"id":1735116749000,"createdDate":"2024-12-25 08:52","name":"法国国际广播电台","title":"快讯：中国对欧盟白兰地反倾销调查 延长至明年4月","content":"路透社北京消息指，中国决定对欧盟白兰地的反倾销调查延长至明年4月，并表示这是因为情况复杂。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241225-%E5%BF%AB%E8%AE%AF-%E4%B8%AD%E5%9B%BD%E5%AF%B9%E6%AC%A7%E7%9B%9F%E7%99%BD%E5%85%B0%E5%9C%B0%E5%8F%8D%E5%80%BE%E9%94%80%E8%B0%83%E6%9F%A5-%E5%BB%B6%E9%95%BF%E8%87%B3%E6%98%8E%E5%B9%B44%E6%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2024/12/25/1735116749000.webp","sourceId":"rfi"},{"id":1735116113000,"createdDate":"2024-12-25 08:41","name":"法国国际广播电台","title":"郑敬基被港府悬红通缉 评论斥干预加国选举 忧坏郑选情","content":"港府在平安夜公布的新悬红通缉名单中，社会学者锺剑华和原艺人郑敬基上榜最令人大惑不解，主要是二人都只是发表评论，不涉及中国口中的「反华组织」，熟悉中港事务的评论员程翔表示，难以理解港府的通缉标准，亦不知当局是否欲藉此把争取参选加国议会的郑敬基踢出局，但实际效果必然是会损害郑的人力和物力支持。港人在加组织「港加联」的声明则对郑被通缉表示「尤为愤慨」，认为是公然干预加国的民主选举。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241225-%E9%83%91%E6%95%AC%E5%9F%BA%E8%A2%AB%E6%B8%AF%E5%BA%9C%E6%82%AC%E7%BA%A2%E9%80%9A%E7%BC%89-%E8%AF%84%E8%AE%BA%E6%96%A5%E5%B9%B2%E9%A2%84%E5%8A%A0%E5%9B%BD%E9%80%89%E4%B8%BE-%E5%BF%A7%E5%9D%8F%E9%83%91%E9%80%89%E6%83%85","thumbnail":"","detailImage":"news/detail/rfi/2024/12/25/1735116113000.webp","sourceId":"rfi"},{"id":1735115953000,"createdDate":"2024-12-25 08:39","name":"法国国际广播电台","title":"港府悬红再通缉六人：美国谴责 联合国专员不安 国际组织猛批 VS 中国支持","content":"港府把艺人郑敬基和学者锺剑华等六名海外港人列入悬红百万港元的通缉名单，引起西方国家一片骂声，美国驻港总领事梅儒瑞出言谴责，联合国人权专员MaryLawlor直指事件是当局欲压制海内外批判中国人权的声音。相反，中国政府则支持港府的行动，强调任何人都没有法外特权。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241225-%E6%B8%AF%E5%BA%9C%E6%82%AC%E7%BA%A2%E5%86%8D%E9%80%9A%E7%BC%89%E5%85%AD%E4%BA%BA-%E7%BE%8E%E5%9B%BD%E8%B0%B4%E8%B4%A3-%E8%81%94%E5%90%88%E5%9B%BD%E4%B8%93%E5%91%98%E4%B8%8D%E5%AE%89-%E5%9B%BD%E9%99%85%E7%BB%84%E7%BB%87%E7%8C%9B%E6%89%B9-vs-%E4%B8%AD%E5%9B%BD%E6%94%AF%E6%8C%81","thumbnail":"","detailImage":"news/detail/rfi/2024/12/25/1735115953000.webp","sourceId":"rfi"},{"id":1735115845000,"createdDate":"2024-12-25 08:37","name":"法国国际广播电台","title":"赵薇夫婿再被入禀追债7.5亿","content":"中国影星赵薇的丈夫黄有龙日前被中国华融的关连公司入禀香港高等法院，追讨本利逾7.5亿港元(下同，折算约9280万欧元)。把之前三宗追债追租共约6亿元的入禀状计算在内，黄有龙被追讨的款项合计约13.6亿元。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241225-%E8%B5%B5%E8%96%87%E5%A4%AB%E5%A9%BF%E5%86%8D%E8%A2%AB%E5%85%A5%E7%A6%80%E8%BF%BD%E5%80%BA7-5%E4%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2024/12/25/1735115845000.webp","sourceId":"rfi"},{"id":1735115728000,"createdDate":"2024-12-25 08:35","name":"法国国际广播电台","title":"日本外务大臣到达北京 与李强及王毅会谈","content":"日本外相岩屋毅于日本时间12月25日凌晨到达北京，与中国国务院总理李强及外长王毅举行了会谈。双方强调加强两国间的合作与沟通，为解决悬而未决的问题奠定基础。中国方面在明年1月特朗普政府上台之前，力图推动日中关系的稳定。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20241225-%E6%97%A5%E6%9C%AC%E5%A4%96%E5%8A%A1%E5%A4%A7%E8%87%A3%E5%88%B0%E8%BE%BE%E5%8C%97%E4%BA%AC-%E4%B8%8E%E6%9D%8E%E5%BC%BA%E5%8F%8A%E7%8E%8B%E6%AF%85%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2024/12/25/1735115728000.webp","sourceId":"rfi"}]