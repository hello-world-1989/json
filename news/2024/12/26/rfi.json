[{"id":1735216220000,"createdDate":"2024-12-26 12:30","name":"法国国际广播电台","title":"与日本抢客 韩国考虑对中国团游试行免签措施","content":"为吸引中国游客，日本外相岩屋毅25日在北京表示，日方将于明年春季放宽对中国公民发放签证。翌日，观光业受早前戒严令冲击的韩国，据韩联社报道，也将研讨对中国团客试行免签入境措施。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20241226-%E4%B8%8E%E6%97%A5%E6%9C%AC%E6%8A%A2%E5%AE%A2-%E9%9F%A9%E5%9B%BD%E8%80%83%E8%99%91%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%9B%A2%E6%B8%B8%E8%AF%95%E8%A1%8C%E5%85%8D%E7%AD%BE%E6%8E%AA%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2024/12/26/1735216220000.webp","sourceId":"rfi"},{"id":1735214414000,"createdDate":"2024-12-26 12:00","name":"法国国际广播电台","title":"“停火这条路走不通” 俄罗斯拒绝特朗普的休战呼吁","content":"据彭博社报道，俄罗斯外交部长拉夫罗夫今天（12月26日）表示，“停火这条路走不通”，因为乌克兰会借机增强军事实力。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20241226-%E5%81%9C%E7%81%AB%E8%BF%99%E6%9D%A1%E8%B7%AF%E8%B5%B0%E4%B8%8D%E9%80%9A-%E4%BF%84%E7%BD%97%E6%96%AF%E6%8B%92%E7%BB%9D%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84%E4%BC%91%E6%88%98%E5%91%BC%E5%90%81","thumbnail":"","detailImage":"news/detail/rfi/2024/12/26/1735214414000.webp","sourceId":"rfi"},{"id":1735213767000,"createdDate":"2024-12-26 11:49","name":"法国国际广播电台","title":"以古讽今 中国经济学家任泽平微博再被禁言","content":"中国中原银行首席经济学家任泽平因在个人微博上以古喻今，被认为是在讽刺中国领导人习近平，遭到微博禁言。平安夜之后，若是查询任泽平的微博账号，会发现处于禁言状态，原因是“因违反相关法律法规”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241226-%E4%BB%A5%E5%8F%A4%E8%AE%BD%E4%BB%8A-%E4%B8%AD%E5%9B%BD%E7%BB%8F%E6%B5%8E%E5%AD%A6%E5%AE%B6%E4%BB%BB%E6%B3%BD%E5%B9%B3%E5%BE%AE%E5%8D%9A%E5%86%8D%E8%A2%AB%E7%A6%81%E8%A8%80","thumbnail":"","detailImage":"news/detail/rfi/2024/12/26/1735213767000.webp","sourceId":"rfi"},{"id":1735212345000,"createdDate":"2024-12-26 11:25","name":"法国国际广播电台","title":"韩国民主党发起弹劾代理总统案，明天在国会投票","content":"韩国代行总统职权的国务总理韩悳洙26日拒绝任命宪法裁判所（宪法法院）法官候选人。就此，最大在野党共同民主党立即发起韩悳洙弹劾案。法新社和法国世界报报道，民主党议员朴成俊在国会告诉记者：韩国共同民主党在全体会议之前提出了这项动议，明天投票。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20241226-%E9%9F%A9%E5%9B%BD%E6%B0%91%E4%B8%BB%E5%85%9A%E5%8F%91%E8%B5%B7%E5%BC%B9%E5%8A%BE%E4%BB%A3%E7%90%86%E6%80%BB%E7%BB%9F%E6%A1%88%EF%BC%8C%E6%98%8E%E5%A4%A9%E5%9C%A8%E5%9B%BD%E4%BC%9A%E6%8A%95%E7%A5%A8","thumbnail":"","detailImage":"news/detail/rfi/2024/12/26/1735212345000.webp","sourceId":"rfi"},{"id":1735205782000,"createdDate":"2024-12-26 09:36","name":"法国国际广播电台","title":"南亚大海啸20周年 印尼响起警报揭开追悼活动序幕","content":"今天12月26日是南亚大海啸20周年，预计受灾各国将举行纪念活动，悼念当年罹难者超过22万人，这场大海啸是人类史上最严重天灾之一。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20241226-%E5%8D%97%E4%BA%9A%E5%A4%A7%E6%B5%B7%E5%95%B820%E5%91%A8%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2024/12/26/1735205782000.webp","sourceId":"rfi"},{"id":1735203909000,"createdDate":"2024-12-26 09:05","name":"法国国际广播电台","title":"柯文哲涉贪及公益侵占罪遭检方求刑28年半 国际传媒关注此案影响","content":"台北地检署星期四（12月26日）决定以受贿、公益侵占等罪起诉民众党主席柯文哲，求刑合计28年半。多家国际传媒当天从不同角度分析此事件对台湾政坛的影响，显示出对台湾政情变化的高度关注。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20241226-%E6%9F%AF%E6%96%87%E5%93%B2%E6%B6%89%E8%B4%AA%E5%8F%8A%E5%85%AC%E7%9B%8A%E4%BE%B5%E5%8D%A0%E7%BD%AA%E9%81%AD%E6%A3%80%E6%96%B9%E6%B1%82%E5%88%9128%E5%B9%B4%E5%8D%8A-%E5%9B%BD%E9%99%85%E4%BC%A0%E5%AA%92%E5%85%B3%E6%B3%A8%E6%AD%A4%E6%A1%88%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2024/12/26/1735203909000.webp","sourceId":"rfi"},{"id":1735203221000,"createdDate":"2024-12-26 08:53","name":"法国国际广播电台","title":"假期来港旅客增15% 离港人更多 餐饮受惠升 8% 高档消费叹「旺丁不旺财」","content":"今年是深圳恢复一签多行赴港後第一个圣诞，出入境人次明显上升，由冬至到圣诞节的六天内，共有逾700万人次出入境，较去年同期大增三成二。不过，人流的增加刚可弥补人均消费力下降，以致餐饮业的营业额较去年只上升约8%，珠宝玉石等高消费，销售额只能与去年持平。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241226-%E5%81%87%E6%9C%9F%E6%9D%A5%E6%B8%AF%E6%97%85%E5%AE%A2%E5%A2%9E15-%E7%A6%BB%E6%B8%AF%E4%BA%BA%E6%9B%B4%E5%A4%9A-%E9%A4%90%E9%A5%AE%E5%8F%97%E6%83%A0%E5%8D%87-8-%E9%AB%98%E6%A1%A3%E6%B6%88%E8%B4%B9%E5%8F%B9-%E6%97%BA%E4%B8%81%E4%B8%8D%E6%97%BA%E8%B4%A2","thumbnail":"","detailImage":"news/detail/rfi/2024/12/26/1735203221000.webp","sourceId":"rfi"},{"id":1735202984000,"createdDate":"2024-12-26 08:49","name":"法国国际广播电台","title":"日本外务大臣在北京宣布：大幅放宽中国人赴日签证","content":"25日，在中国北京举行的促进日本与中国之间人员和文化交流的日中高级别人文交流磋商机制第二次会议（人文对话）上，日本外务大臣岩屋毅表示，将放宽对以旅游目的访日的中国人短期签证的发放条件。日本官房长林芳正在26日的记者会上，就此措施表示：“期待日中两国之间的交流更加顺畅，互相理解进一步加深。”","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20241226-%E6%97%A5%E6%9C%AC%E5%A4%96%E5%8A%A1%E5%A4%A7%E8%87%A3%E5%9C%A8%E5%8C%97%E4%BA%AC%E5%AE%A3%E5%B8%83-%E5%A4%A7%E5%B9%85%E6%94%BE%E5%AE%BD%E4%B8%AD%E5%9B%BD%E4%BA%BA%E8%B5%B4%E6%97%A5%E7%AD%BE%E8%AF%81","thumbnail":"","detailImage":"news/detail/rfi/2024/12/26/1735202984000.webp","sourceId":"rfi"},{"id":1735236004000,"createdDate":"2024-12-26 18:00","name":"法国国际广播电台","title":"初步调查显示阿塞拜疆航空公司航班被俄罗斯防空部队击落","content":"四位了解阿塞拜疆对灾难调查初步结果的消息人士周四（26日）告诉路透社称，俄罗斯防空部队击落了在哈萨克斯坦坠毁的阿塞拜疆航空公司客机，造成38人死亡。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241226-%E5%88%9D%E6%AD%A5%E8%B0%83%E6%9F%A5%E6%98%BE%E7%A4%BA%E9%98%BF%E5%A1%9E%E6%8B%9C%E7%96%86%E8%88%AA%E7%A9%BA%E5%85%AC%E5%8F%B8%E8%88%AA%E7%8F%AD%E8%A2%AB%E4%BF%84%E7%BD%97%E6%96%AF%E9%98%B2%E7%A9%BA%E9%83%A8%E9%98%9F%E5%87%BB%E8%90%BD","thumbnail":"","detailImage":"news/detail/rfi/2024/12/26/1735236004000.webp","sourceId":"rfi"},{"id":1735226994000,"createdDate":"2024-12-26 15:29","name":"法国国际广播电台","title":"解放军陆海军2名司令落马 中国国防部避答","content":"中央社报道，针对中国解放军前陆军副司令员尤海涛、南部战区海军司令李鹏程被解除人大代表职务，中国国防部发言人张晓刚周四回避作答，仅表示“我没有需要发布的讯息”。军方反腐行动看似仍未停歇。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241226-%E8%A7%A3%E6%94%BE%E5%86%9B%E9%99%86%E6%B5%B7%E5%86%9B2%E5%90%8D%E5%8F%B8%E4%BB%A4%E8%90%BD%E9%A9%AC-%E4%B8%AD%E5%9B%BD%E5%9B%BD%E9%98%B2%E9%83%A8%E9%81%BF%E7%AD%94","thumbnail":"","detailImage":"news/detail/rfi/2024/12/26/1735226994000.webp","sourceId":"rfi"},{"id":1735226040000,"createdDate":"2024-12-26 15:14","name":"法国国际广播电台","title":"面对中国军事“扩张” 台湾总统府首度举行桌上兵棋推演","content":"面对中国军事“扩张”，台湾总统府首度主办两岸军事冲突桌上兵棋推演。法新社今天（12月26日）引述多名台湾官员透露，数十个中央和地方政府机构，以及民间组织参与当天举行的三小时兵推。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20241226-%E9%9D%A2%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%86%9B%E4%BA%8B-%E6%89%A9%E5%BC%A0-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E5%BA%9C%E9%A6%96%E5%BA%A6%E4%B8%BE%E8%A1%8C%E6%A1%8C%E4%B8%8A%E5%85%B5%E6%A3%8B%E6%8E%A8%E6%BC%94","thumbnail":"","detailImage":"news/detail/rfi/2024/12/26/1735226040000.webp","sourceId":"rfi"},{"id":1735224852000,"createdDate":"2024-12-26 14:54","name":"法国国际广播电台","title":"行业预测报告：中国2025年电动车销售量将超传统汽车","content":"英国《金融时报》报道，中国明年电动车销售量预估可成长20%，这将成为一个历史性的转折点，一方面这是首次电动车销量超越传统汽车，更使得中国汽车市场得以领先西方竞争对手数年。不过，中国的电动车市场也非全盘乐观，制造商已从高峰期的超过百家，淘汰到如今的50家。中国一家名为极越的电动车品牌很大可能会成为下一个倒闭的厂家。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241226-%E8%A1%8C%E4%B8%9A%E9%A2%84%E6%B5%8B%E6%8A%A5%E5%91%8A-%E4%B8%AD%E5%9B%BD2025%E5%B9%B4%E7%94%B5%E5%8A%A8%E8%BD%A6%E9%94%80%E5%94%AE%E9%87%8F%E5%B0%86%E8%B6%85%E4%BC%A0%E7%BB%9F%E6%B1%BD%E8%BD%A6","thumbnail":"","detailImage":"news/detail/rfi/2024/12/26/1735224852000.webp","sourceId":"rfi"}]