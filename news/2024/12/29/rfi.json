[{"id":1735473542000,"createdDate":"2024-12-29 11:59","name":"法国国际广播电台","title":"教皇方济各为韩国空难死者和家人祈祷 罹难者增至177人","content":"教皇方济各周日为韩国空难的遇难者和家人祈祷。济州航空公司一架波音客机上的181名乘客几乎全部遇难。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241229-%E6%95%99%E7%9A%87%E6%96%B9%E6%B5%8E%E5%90%84%E4%B8%BA%E9%9F%A9%E5%9B%BD%E7%A9%BA%E9%9A%BE%E6%AD%BB%E8%80%85%E5%92%8C%E5%AE%B6%E4%BA%BA%E7%A5%88%E7%A5%B7-%E7%BD%B9%E9%9A%BE%E8%80%85%E5%A2%9E%E8%87%B3176%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735473542000.webp","sourceId":"rfi"},{"id":1735466985000,"createdDate":"2024-12-29 10:09","name":"法国国际广播电台","title":"克罗地亚总统选举投票开始 现任总统寻求连任","content":"克罗地亚周日举行选举总统投票，选民在8位候选人中将选出未来5年的总统，现任总统米拉诺维奇寻求连任并是热门候选人。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20241229-%E5%85%8B%E7%BD%97%E5%9C%B0%E4%BA%9A%E6%80%BB%E7%BB%9F%E9%80%89%E4%B8%BE%E6%8A%95%E7%A5%A8-%E7%8E%B0%E4%BB%BB%E6%80%BB%E7%BB%9F%E5%AF%BB%E6%B1%82%E8%BF%9E%E4%BB%BB","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735466985000.webp","sourceId":"rfi"},{"id":1735463494000,"createdDate":"2024-12-29 09:11","name":"法国国际广播电台","title":"美国电信AT&T、威瑞森遭中国相关黑客“盐台风”网络攻击","content":"与中国相关的盐台风（SaltTyphoon）网络间谍行动针对了美国电讯公司AT&T和威瑞森系统，这两家公司周六（12月28日）首次承认受到此次攻击，但表示，正在与执法部门和政府官员合作处理事件，其运营的美国网络目前是安全的。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241229-%E7%BE%8E%E5%9B%BD%E7%94%B5%E4%BF%A1at-t-%E5%A8%81%E7%91%9E%E6%A3%AE%E9%81%AD%E4%B8%AD%E5%9B%BD%E7%9B%B8%E5%85%B3%E9%BB%91%E5%AE%A2-%E7%9B%90%E5%8F%B0%E9%A3%8E-%E7%BD%91%E7%BB%9C%E6%94%BB%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735463494000.webp","sourceId":"rfi"},{"id":1735460300000,"createdDate":"2024-12-29 08:18","name":"法国国际广播电台","title":"韩国航班失事 至少167人遇难","content":"周日，韩国济州航空公司一架载有181人的飞机在韩国务安国际机场降落时坠毁并起火，可能是与鸟类相撞所致，事故造成至少167人死亡。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241229-%E9%9F%A9%E5%9B%BD%E8%88%AA%E7%8F%AD%E5%A4%B1%E4%BA%8B-%E8%87%B3%E5%B0%91124%E4%BA%BA%E9%81%87%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735460300000.webp","sourceId":"rfi"},{"id":1735460231000,"createdDate":"2024-12-29 08:17","name":"法国国际广播电台","title":"2024年中国海警船出没在钓鱼岛毗邻区天数创历史新高","content":"日本第11管区海上保安本部（那霸市）于29日宣布，确认有中国海警局的船只进入钓鱼岛（日本称为“尖阁诸岛”）附近的毗连区。今年以来，中国海警局船只在钓鱼岛毗连区出现天数达到353天，刷新了过去的最高纪录。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241229-2024%E5%B9%B4%E4%B8%AD%E5%9B%BD%E6%B5%B7%E8%AD%A6%E8%88%B9%E5%87%BA%E6%B2%A1%E5%9C%A8%E9%92%93%E9%B1%BC%E5%B2%9B%E6%AF%97%E9%82%BB%E5%8C%BA%E5%A4%A9%E6%95%B0%E5%88%9B%E5%8E%86%E5%8F%B2%E6%96%B0%E9%AB%98","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735460231000.webp","sourceId":"rfi"},{"id":1735493578000,"createdDate":"2024-12-29 17:32","name":"法国国际广播电台","title":"乍得十三年间的首次立法选举","content":"非洲内陆国乍得（Tchad）,中文也有译作查德共和国。该国在2024年最后一个周末的两天里（12月28日星期六和12月29日星期天），在全国范围组织立法、市镇和地方三项选举。本台法广（RFI）非洲组动员了在恩贾梅纳（N'Djamena）的两名法语通讯员自12月27日周五就已开始，对此进行实地报道。乍得上一次组织立法选举要追溯到十三年前的2011年2月。国际舆论把在本周末举行的这次选举投票视为乍得老总统伊德里斯·代比·伊特诺（PrésidentIdrisDébyItno）于2021年在战斗中阵亡后，该国为期三年过渡的结束。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20241229-rfi-%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E4%B9%8D%E5%BE%97%E5%8D%81%E4%B8%89%E5%B9%B4%E9%97%B4%E7%9A%84%E9%A6%96%E6%AC%A1%E7%AB%8B%E6%B3%95%E9%80%89%E4%B8%BE","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735493578000.webp","sourceId":"rfi"},{"id":1735490214000,"createdDate":"2024-12-29 16:36","name":"法国国际广播电台","title":"法国海军在塔希提岛一艘西班牙船上缉获半吨可卡因","content":"法新社12月29日从宪兵队获悉，近一周前，法属波利尼西亚塔希提岛（大溪地岛）附近一艘西班牙船上被缉获了500多公斤可卡因。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20241229-%E6%B3%95%E5%9B%BD%E6%B5%B7%E5%86%9B%E5%9C%A8%E5%A1%94%E5%B8%8C%E6%8F%90%E5%B2%9B%E4%B8%80%E8%89%98%E8%A5%BF%E7%8F%AD%E7%89%99%E8%88%B9%E4%B8%8A%E7%BC%89%E8%8E%B7%E5%8D%8A%E5%90%A8%E5%8F%AF%E5%8D%A1%E5%9B%A0","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735490214000.webp","sourceId":"rfi"},{"id":1735487550000,"createdDate":"2024-12-29 15:52","name":"法国国际广播电台","title":"格鲁吉亚前“国脚”宣誓就任总统，数千示威者举“红牌”抗议","content":"忠于执政党的格鲁吉亚新总统米哈伊尔-卡韦拉奇维利周日宣誓就职，接替即将离任的国家元首、亲欧反对派支持者萨洛梅-祖拉比什维利。这是该国已持续两个月的政治危机中的新插曲。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241229-%E6%A0%BC%E9%B2%81%E5%90%89%E4%BA%9A%E5%89%8D-%E5%9B%BD%E8%84%9A-%E5%AE%A3%E8%AA%93%E5%B0%B1%E4%BB%BB%E6%80%BB%E7%BB%9F%EF%BC%8C%E6%95%B0%E5%8D%83%E7%A4%BA%E5%A8%81%E8%80%85%E4%B8%BE-%E7%BA%A2%E7%89%8C-%E6%8A%97%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735487550000.webp","sourceId":"rfi"},{"id":1735479035000,"createdDate":"2024-12-29 13:30","name":"法国国际广播电台","title":"韩国空难179人罹难 政府宣布国丧7天","content":"韩国政府29日宣布全国举哀7天，为当天早晨空难事故的179名罹难者降半旗，设灵堂，佩丝带...。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241229-%E9%9F%A9%E5%9B%BD%E7%A9%BA%E9%9A%BE179%E4%BA%BA%E7%BD%B9%E9%9A%BE-%E6%94%BF%E5%BA%9C%E5%AE%A3%E5%B8%83%E5%9B%BD%E4%B8%A77%E5%A4%A9","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735479035000.webp","sourceId":"rfi"},{"id":1735476803000,"createdDate":"2024-12-29 12:53","name":"法国国际广播电台","title":"台积电在日本首座芯片厂开始量产，拟建第二厂第三厂","content":"据共同社12月27日引述熊本县知事木村敬透露，全球最大半导体代工企业台积电（TSMC）在菊阳町建设的第一座工厂已开始量产半导体。台积电当天发表评论称，“12月按计划已开始量产”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241229-%E5%8F%B0%E7%A7%AF%E7%94%B5%E5%9C%A8%E6%97%A5%E6%9C%AC%E9%A6%96%E5%BA%A7%E8%8A%AF%E7%89%87%E5%8E%82%E5%BC%80%E5%A7%8B%E9%87%8F%E4%BA%A7%EF%BC%8C%E6%8B%9F%E5%BB%BA%E7%AC%AC%E4%BA%8C%E5%8E%82%E7%AC%AC%E4%B8%89%E5%8E%82","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735476803000.webp","sourceId":"rfi"}]