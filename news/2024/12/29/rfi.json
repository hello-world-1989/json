[{"id":1735473542000,"createdDate":"2024-12-29 11:59","name":"法国国际广播电台","title":"教皇方济各为韩国空难死者和家人祈祷 罹难者增至177人","content":"教皇方济各周日为韩国空难的遇难者和家人祈祷。济州航空公司一架波音客机上的181名乘客几乎全部遇难。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241229-%E6%95%99%E7%9A%87%E6%96%B9%E6%B5%8E%E5%90%84%E4%B8%BA%E9%9F%A9%E5%9B%BD%E7%A9%BA%E9%9A%BE%E6%AD%BB%E8%80%85%E5%92%8C%E5%AE%B6%E4%BA%BA%E7%A5%88%E7%A5%B7-%E7%BD%B9%E9%9A%BE%E8%80%85%E5%A2%9E%E8%87%B3176%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735473542000.webp","sourceId":"rfi"},{"id":1735466985000,"createdDate":"2024-12-29 10:09","name":"法国国际广播电台","title":"克罗地亚总统选举投票开始 现任总统寻求连任","content":"克罗地亚周日举行选举总统投票，选民在8位候选人中将选出未来5年的总统，现任总统米拉诺维奇寻求连任并是热门候选人。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20241229-%E5%85%8B%E7%BD%97%E5%9C%B0%E4%BA%9A%E6%80%BB%E7%BB%9F%E9%80%89%E4%B8%BE%E6%8A%95%E7%A5%A8-%E7%8E%B0%E4%BB%BB%E6%80%BB%E7%BB%9F%E5%AF%BB%E6%B1%82%E8%BF%9E%E4%BB%BB","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735466985000.webp","sourceId":"rfi"},{"id":1735463494000,"createdDate":"2024-12-29 09:11","name":"法国国际广播电台","title":"美国电信AT&T、威瑞森遭中国相关黑客“盐台风”网络攻击","content":"与中国相关的盐台风（SaltTyphoon）网络间谍行动针对了美国电讯公司AT&T和威瑞森系统，这两家公司周六（12月28日）首次承认受到此次攻击，但表示，正在与执法部门和政府官员合作处理事件，其运营的美国网络目前是安全的。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241229-%E7%BE%8E%E5%9B%BD%E7%94%B5%E4%BF%A1at-t-%E5%A8%81%E7%91%9E%E6%A3%AE%E9%81%AD%E4%B8%AD%E5%9B%BD%E7%9B%B8%E5%85%B3%E9%BB%91%E5%AE%A2-%E7%9B%90%E5%8F%B0%E9%A3%8E-%E7%BD%91%E7%BB%9C%E6%94%BB%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735463494000.webp","sourceId":"rfi"},{"id":1735460300000,"createdDate":"2024-12-29 08:18","name":"法国国际广播电台","title":"韩国航班失事 至少167人遇难","content":"周日，韩国济州航空公司一架载有181人的飞机在韩国务安国际机场降落时坠毁并起火，可能是与鸟类相撞所致，事故造成至少167人死亡。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241229-%E9%9F%A9%E5%9B%BD%E8%88%AA%E7%8F%AD%E5%A4%B1%E4%BA%8B-%E8%87%B3%E5%B0%91124%E4%BA%BA%E9%81%87%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735460300000.webp","sourceId":"rfi"},{"id":1735460231000,"createdDate":"2024-12-29 08:17","name":"法国国际广播电台","title":"2024年中国海警船出没在钓鱼岛毗邻区天数创历史新高","content":"日本第11管区海上保安本部（那霸市）于29日宣布，确认有中国海警局的船只进入钓鱼岛（日本称为“尖阁诸岛”）附近的毗连区。今年以来，中国海警局船只在钓鱼岛毗连区出现天数达到353天，刷新了过去的最高纪录。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241229-2024%E5%B9%B4%E4%B8%AD%E5%9B%BD%E6%B5%B7%E8%AD%A6%E8%88%B9%E5%87%BA%E6%B2%A1%E5%9C%A8%E9%92%93%E9%B1%BC%E5%B2%9B%E6%AF%97%E9%82%BB%E5%8C%BA%E5%A4%A9%E6%95%B0%E5%88%9B%E5%8E%86%E5%8F%B2%E6%96%B0%E9%AB%98","thumbnail":"","detailImage":"news/detail/rfi/2024/12/29/1735460231000.webp","sourceId":"rfi"}]