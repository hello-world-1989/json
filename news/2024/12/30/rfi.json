[{"id":1735562260000,"createdDate":"2024-12-30 12:37","name":"法国国际广播电台","title":"阿萨德时代从俄进口粮食的叙利亚开始接收乌克兰粮援，叙乌展望战略伙伴关系","content":"综合路透社与自由欧洲等消息，12月30日，叙利亚新任外交部长当天对到访的乌克兰外长表示，叙利亚希望与乌克兰建立“战略伙伴关系”。在俄罗斯影响力或减弱的情况下，基辅正着手与大马士革的新统治者建立关系。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241230-%E9%98%BF%E8%90%A8%E5%BE%B7%E6%97%B6%E4%BB%A3%E4%BB%8E%E4%BF%84%E8%BF%9B%E5%8F%A3%E7%B2%AE%E9%A3%9F%E7%9A%84%E5%8F%99%E5%88%A9%E4%BA%9A%E5%BC%80%E5%A7%8B%E6%8E%A5%E6%94%B6%E4%B9%8C%E5%85%8B%E5%85%B0%E7%B2%AE%E6%8F%B4%EF%BC%8C%E5%8F%99%E4%B9%8C%E5%B1%95%E6%9C%9B%E6%88%98%E7%95%A5%E4%BC%99%E4%BC%B4%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2024/12/30/1735562260000.webp","sourceId":"rfi"},{"id":1735560797000,"createdDate":"2024-12-30 12:13","name":"法国国际广播电台","title":"韩国最严重空难后检查所有波音737-800型飞机","content":"韩国航空公司一架波音737-800飞机周日早晨在该国西南的务安国际机场失事，造成181名乘客中的179人死亡。韩国周一启动对所有波音737-800型飞机的检查。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241230-%E9%9F%A9%E5%9B%BD%E6%9C%80%E4%B8%A5%E9%87%8D%E7%A9%BA%E9%9A%BE%E5%90%8E%E6%A3%80%E6%9F%A5%E6%89%80%E6%9C%89%E6%B3%A2%E9%9F%B3737-800%E5%9E%8B%E9%A3%9E%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2024/12/30/1735560797000.webp","sourceId":"rfi"},{"id":1735560487000,"createdDate":"2024-12-30 12:08","name":"法国国际广播电台","title":"中国对吉米·卡特逝世表示“深切哀悼”","content":"周一中国对美国前总统吉米·卡特周日去世表示“深切哀悼”。卡特的任期标志着华盛顿对中华人民共和国的外交承认。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241230-%E4%B8%AD%E5%9B%BD%E5%AF%B9%E5%90%89%E7%B1%B3%C2%B7%E5%8D%A1%E7%89%B9%E9%80%9D%E4%B8%96%E8%A1%A8%E7%A4%BA-%E6%B7%B1%E5%88%87%E5%93%80%E6%82%BC","thumbnail":"","detailImage":"news/detail/rfi/2024/12/30/1735560487000.webp","sourceId":"rfi"},{"id":1735548862000,"createdDate":"2024-12-30 08:54","name":"法国国际广播电台","title":"石破茂首相发文沉痛悼念前美国总统卡特去世","content":"石破茂首相于12月30日发表悼文，对美国前总统吉米·卡特去世表示哀悼。石破茂首相在悼文中表示：得知美国第39任总统吉米·卡特阁下逝世的消息，深感悲痛。谨向其家属、美国政府及其国民致以诚挚的哀悼。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241230-%E7%9F%B3%E7%A0%B4%E8%8C%82%E9%A6%96%E7%9B%B8%E5%8F%91%E6%96%87%E6%B2%89%E7%97%9B%E6%82%BC%E5%BF%B5%E5%89%8D%E7%BE%8E%E5%9B%BD%E6%80%BB%E7%BB%9F%E5%8D%A1%E7%89%B9%E5%8E%BB%E4%B8%96","thumbnail":"","detailImage":"news/detail/rfi/2024/12/30/1735548862000.webp","sourceId":"rfi"},{"id":1735548272000,"createdDate":"2024-12-30 08:44","name":"法国国际广播电台","title":"河北邯郸初中生杀人案 2名被告宣判无期徒刑及12年","content":"中国河北省邯郸今年稍早发生初生中杀人案，3名未满14岁的学生涉嫌杀害同学后埋尸，事件震惊中国。邯郸市中级人民法院周一（12月30日）一审公开宣判，3名被告中2人分别判处无期徒刑及有期徒刑12年，另一人不予刑事处罚。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241230-%E6%B2%B3%E5%8C%97%E9%82%AF%E9%83%B8%E5%88%9D%E4%B8%AD%E7%94%9F%E6%9D%80%E4%BA%BA%E6%A1%88-2%E8%A2%AB%E5%91%8A%E5%88%A4%E6%97%A0%E5%88%91%E5%BE%92%E5%88%91%E5%8F%8A12%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2024/12/30/1735548272000.webp","sourceId":"rfi"},{"id":1735546823000,"createdDate":"2024-12-30 08:20","name":"法国国际广播电台","title":"出狱社工被停牌五年 社工组织批注册局淮则不透明丶太严苛","content":"民选成份大减的社会工作者注册局再次将一名因2019年社会运动服刑完毕的社工有年期停牌，成为至少第14名暂时被「钉牌」的出狱社工，但不同的是，被停牌的「前社工」刘家栋被停牌五年，是法例的最高停牌年期，且事前未有机会解释。有社工的民间组织认为，注册局的处理太严苛，且标淮不明，又忽视改过自新这社工价值，做法会影响社工声誉。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241230-%E5%87%BA%E7%8B%B1%E7%A4%BE%E5%B7%A5%E8%A2%AB%E5%81%9C%E7%89%8C%E4%BA%94%E5%B9%B4-%E7%A4%BE%E5%B7%A5%E7%BB%84%E7%BB%87%E6%89%B9%E6%B3%A8%E5%86%8C%E5%B1%80%E6%B7%AE%E5%88%99%E4%B8%8D%E9%80%8F%E6%98%8E%E4%B8%B6%E5%A4%AA%E4%B8%A5%E8%8B%9B","thumbnail":"","detailImage":"news/detail/rfi/2024/12/30/1735546823000.webp","sourceId":"rfi"},{"id":1735545596000,"createdDate":"2024-12-30 07:59","name":"法国国际广播电台","title":"大摩：中国减息出现反效果 专家料监管机构会重新考虑","content":"市场憧景中国减息降淮救经济，但摩根士丹利(俗称大摩)首席中国金融分析师徐然接受香港财经报章《信报》访问时指出，中国经过多番减息后，似乎正朝着相反效果的路上发展，既令居民收入受损，又导致中国产能自然筛选优胜劣败的过程减慢，不利消化风险，相信中国监管机构亦会逐渐考虑，减息是否有利于中国经济复苏。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241230-%E5%A4%A7%E6%91%A9-%E4%B8%AD%E5%9B%BD%E5%87%8F%E6%81%AF%E5%87%BA%E7%8E%B0%E5%8F%8D%E6%95%88%E6%9E%9C-%E4%B8%93%E5%AE%B6%E6%96%99%E7%9B%91%E7%AE%A1%E6%9C%BA%E6%9E%84%E4%BC%9A%E9%87%8D%E6%96%B0%E8%80%83%E8%99%91","thumbnail":"","detailImage":"news/detail/rfi/2024/12/30/1735545596000.webp","sourceId":"rfi"}]