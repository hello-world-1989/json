[{"id":1735647631000,"createdDate":"2024-12-31 12:20","name":"法国国际广播电台","title":"2024超级选举年：民主化进程的倒退与专制化的回潮","content":"刚刚结束的2024年被看作是超级选举年。全球60多个国家，理论上总计半数以上的全球适龄选民都要在这一年面对投票箱做出自己选择。如果说公开、自由的投票活动是民主体制的标志性要素之一的话，过去一年世界各地大大小小的的选举活动尤其暴露出民主化进程遭遇的挑战和所处的困境，无论是在传统民主国家，还是在新兴民主国家。瑞典哥德堡大学“多元民主中心”每年都对全球民主化形势做出评估。该中心”创办人及现任负责人史泰凡•林德伯格（StaffanLindberg）2024年年底接受法国«世界报»采访时认为，全球正经历第三波专制化浪潮，民主化形势处于自上个世纪30年代以来最糟糕的情况，而且看不到短期内好转的迹象。今天的公民论坛节目就来同大家一起简单梳理一下世界各地民主政体在过去一年遭遇的挫折与挑战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%85%AC%E6%B0%91%E8%AE%BA%E5%9D%9B/20241231-2024%E8%B6%85%E7%BA%A7%E9%80%89%E4%B8%BE%E5%B9%B4-%E6%B0%91%E4%B8%BB%E5%8C%96%E8%BF%9B%E7%A8%8B%E7%9A%84%E5%80%92%E9%80%80%E4%B8%8E%E4%B8%93%E5%88%B6%E5%8C%96%E7%9A%84%E5%9B%9E%E6%BD%AE","thumbnail":"","detailImage":"news/detail/rfi/2024/12/31/1735647631000.webp","sourceId":"rfi"},{"id":1735642543000,"createdDate":"2024-12-31 10:55","name":"法国国际广播电台","title":"关税战开打在即 美控中黑客入侵财政部网站 北京驳“毫无根据”","content":"即将迈入2025年美中新一轮贸易战开打之际，美国财政部声称中国的网络攻击绕过了其计算机安全系统并窃取了文件，中国周二对这一说法进行了反击，称这一指控“毫无根据”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20241231-%E5%85%B3%E7%A8%8E%E6%88%98%E5%BC%80%E6%89%93%E5%9C%A8%E5%8D%B3-%E7%BE%8E%E6%8E%A7%E4%B8%AD%E9%BB%91%E5%AE%A2%E5%85%A5%E4%BE%B5%E8%B4%A2%E6%94%BF%E9%83%A8%E7%BD%91%E7%AB%99-%E5%8C%97%E4%BA%AC%E9%A9%B3-%E6%AF%AB%E6%97%A0%E6%A0%B9%E6%8D%AE","thumbnail":"","detailImage":"news/detail/rfi/2024/12/31/1735642543000.webp","sourceId":"rfi"},{"id":1735635174000,"createdDate":"2024-12-31 08:52","name":"法国国际广播电台","title":"韩国宪政史上首例 法院批准对尹锡悦的逮捕令","content":"法新社首尔消息，韩国调查当局表示，法院在今年最后一天12月31日批准对总统尹锡悦的逮捕令。尹锡悦因本月3日实施戒严的决定遭弹劾且被停职。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20241231-%E9%9F%A9%E5%9B%BD%E5%AE%AA%E6%94%BF%E5%8F%B2%E4%B8%8A%E9%A6%96%E4%BE%8B-%E6%B3%95%E9%99%A2%E6%89%B9%E5%87%86%E5%AF%B9%E5%B0%B9%E9%94%A1%E6%82%A6%E7%9A%84%E9%80%AE%E6%8D%95%E4%BB%A4","thumbnail":"","detailImage":"news/detail/rfi/2024/12/31/1735635174000.webp","sourceId":"rfi"},{"id":1735634118000,"createdDate":"2024-12-31 08:35","name":"法国国际广播电台","title":"国际化褪色 港府只望旅游业在2029年回复2018年疫前水平","content":"香港旅游业受2019社会运动和随後而至的疫情困扰，港府的复苏预期多次落空，而最新的发展蓝图显示，当局在投入多项措施和名强邮轮旅游後，亦只能期望旅游业的增加值在五年後追上略低於六年前的疫情前水平。有报章社论指，蓝图描划的发展定位清晰，但成效有待观察；相反，有网上新闻节目主持则认为，报告没有新意，亦不能面对香港的国际色彩已然褪色的问题作出弥补，加强邮轮旅游恐成错配。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241231-%E5%9B%BD%E9%99%85%E5%8C%96%E8%A4%AA%E8%89%B2-%E6%B8%AF%E5%BA%9C%E5%8F%AA%E6%9C%9B%E6%97%85%E6%B8%B8%E4%B8%9A%E5%9C%A82029%E5%B9%B4%E5%9B%9E%E5%A4%8D2018%E5%B9%B4%E7%96%AB%E5%89%8D%E6%B0%B4%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2024/12/31/1735634118000.webp","sourceId":"rfi"},{"id":1735634043000,"createdDate":"2024-12-31 08:34","name":"法国国际广播电台","title":"中国驻曼城总领馆被涂抗议标语 记者采访受阻兼遭恐吓","content":"继时任总领事郑曦原带队围殴香港示威者後，中国驻英国曼彻斯特总领事馆再发生馆方人员阻挠记者采访事件。事缘有人在总领馆的围墙和馆外行人路上涂写抗议中共和声援香港的字句，当美资传媒自由亚洲电台(RFA)记者前往采访及拍摄时，被馆内人员引用外交特权和肖像权阻挠，又出言恐吓。警方其後将涂污事件循「仇恨犯罪」（HateCrime）方向调查，但记者被阻一事，则因馆方不合作而遭结案。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241231-%E4%B8%AD%E5%9B%BD%E9%A9%BB%E6%9B%BC%E5%9F%8E%E6%80%BB%E9%A2%86%E9%A6%86%E8%A2%AB%E6%B6%82%E6%8A%97%E8%AE%AE%E6%A0%87%E8%AF%AD-%E8%AE%B0%E8%80%85%E9%87%87%E8%AE%BF%E5%8F%97%E9%98%BB%E5%85%BC%E9%81%AD%E6%81%90%E5%90%93","thumbnail":"","detailImage":"news/detail/rfi/2024/12/31/1735634043000.webp","sourceId":"rfi"},{"id":1735633825000,"createdDate":"2024-12-31 08:30","name":"法国国际广播电台","title":"日本首相放弃特朗普就职前访美计划 言称访华极其重要","content":"关于石破首相与美国候任总统特朗普会谈一事，日本政府已明确方针，不会在1月特朗普就职前进行，而石破首相在电视节目中表示：“访问中国极其重要”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20241231-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E6%94%BE%E5%BC%83%E7%89%B9%E6%9C%97%E6%99%AE%E5%B0%B1%E8%81%8C%E5%89%8D%E8%AE%BF%E7%BE%8E%E8%AE%A1%E5%88%92-%E8%A8%80%E7%A7%B0%E8%AE%BF%E5%8D%8E%E6%9E%81%E5%85%B6%E9%87%8D%E8%A6%81","thumbnail":"","detailImage":"news/detail/rfi/2024/12/31/1735633825000.webp","sourceId":"rfi"},{"id":1735670189000,"createdDate":"2024-12-31 18:36","name":"法国国际广播电台","title":"叙利亚反抗军同意解散并加入叙利亚国防部","content":"叙利亚反抗军同意解散并加入叙利亚国防部，外籍战士成为军官。叙利亚新领导层上周公布，已与国内反抗军组织就解散并入国防部达成协议，目前已任命多名有潜力的军官。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241231-%E5%8F%99%E5%88%A9%E4%BA%9A%E5%8F%8D%E6%8A%97%E5%86%9B%E5%90%8C%E6%84%8F%E8%A7%A3%E6%95%A3%E5%B9%B6%E5%8A%A0%E5%85%A5%E5%8F%99%E5%88%A9%E4%BA%9A%E5%9B%BD%E9%98%B2%E9%83%A8","thumbnail":"","detailImage":"news/detail/rfi/2024/12/31/1735670189000.webp","sourceId":"rfi"},{"id":1735667979000,"createdDate":"2024-12-31 17:59","name":"法国国际广播电台","title":"3名少年死于致命挑战 委内瑞拉法院对TikTok罚款1000万美元","content":"委内瑞拉周一对TikTok处以1000万美元罚款，原因是3名委内瑞拉少年在接受了这个中国短视频平台流传的一项危险挑战后死亡，另有200人中毒。Tiktok被指管理“疏忽”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241231-3%E5%90%8D%E5%B0%91%E5%B9%B4%E6%AD%BB%E4%BA%8E%E8%87%B4%E5%91%BD%E6%8C%91%E6%88%98-%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E6%B3%95%E9%99%A2%E5%AF%B9tiktok%E7%BD%9A%E6%AC%BE1000%E4%B8%87%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2024/12/31/1735667979000.webp","sourceId":"rfi"},{"id":1735663663000,"createdDate":"2024-12-31 16:47","name":"法国国际广播电台","title":"习近平承诺 2025 年实施更积极的宏观经济政策","content":"据中国官媒报道，中国国家主席习近平周二承诺在2025年将采取更“积极主动”的宏观经济政策，中国政府将继续努力遏制增长放缓。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241231-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%89%BF%E8%AF%BA-2025-%E5%B9%B4%E5%AE%9E%E6%96%BD%E6%9B%B4%E7%A7%AF%E6%9E%81%E7%9A%84%E5%AE%8F%E8%A7%82%E7%BB%8F%E6%B5%8E%E6%94%BF%E7%AD%96","thumbnail":"","detailImage":"news/detail/rfi/2024/12/31/1735663663000.webp","sourceId":"rfi"},{"id":1735659692000,"createdDate":"2024-12-31 15:41","name":"法国国际广播电台","title":"中国称与世卫组织共享了新冠病毒信息“没有任何限制”","content":"在世界卫生组织（WHO）呼吁中国提供更多数据和访问权限以了解疫情起源后，中国外交部发言人周二表示，中国已“无任何限制地”共享了关于新冠病毒（Covid-19）的信息，并称，新冠病毒起源是全球性的。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241231-%E4%B8%AD%E5%9B%BD%E7%A7%B0%E4%B8%8E%E4%B8%96%E5%8D%AB%E7%BB%84%E7%BB%87%E5%85%B1%E4%BA%AB%E4%BA%86%E6%96%B0%E5%86%A0%E7%97%85%E6%AF%92%E4%BF%A1%E6%81%AF-%E6%B2%A1%E6%9C%89%E4%BB%BB%E4%BD%95%E9%99%90%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2024/12/31/1735659692000.webp","sourceId":"rfi"},{"id":1735651411000,"createdDate":"2024-12-31 13:23","name":"法国国际广播电台","title":"世界告别2024年 带着和平希望走向2025年","content":"2024年最后一天，人们点燃烟花准备进入2025年。法新社回望2024年说：巴黎奥运取得了成功，唐纳德-特朗普（DonaldTrump）雷鸣般地回归，中东和乌克兰发生了新的动荡巨变。人们希望和平到来。随着人工智能（AI）的进步和通货膨胀的放缓，经济界对2025年充满期待。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241231-%E4%B8%96%E7%95%8C%E5%91%8A%E5%88%AB2024%E5%B9%B4%EF%BC%8C%E5%B8%A6%E7%9D%80%E5%92%8C%E5%B9%B3%E5%B8%8C%E6%9C%9B%E8%B5%B0%E5%90%912025%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2024/12/31/1735651411000.webp","sourceId":"rfi"},{"id":1735649526000,"createdDate":"2024-12-31 12:52","name":"法国国际广播电台","title":"法国在叙利亚打击“伊斯兰国”军事目标","content":"法国空袭了叙利亚中部两个伊斯兰国军事目标。巴沙尔-阿萨德下台后，叙利亚全面重新洗牌，引发人们对伊斯兰国卷土重来的担忧。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241231-%E6%B3%95%E5%9B%BD%E5%9C%A8%E5%8F%99%E5%88%A9%E4%BA%9A%E6%89%93%E5%87%BB-%E4%BC%8A%E6%96%AF%E5%85%B0%E5%9B%BD-%E5%86%9B%E4%BA%8B%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2024/12/31/1735649526000.webp","sourceId":"rfi"}]