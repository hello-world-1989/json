[{"id":1735044278000,"createdDate":"2024-12-24 12:44","name":"法国国际广播电台","title":"土耳其采取措施，方便在土耳其的叙利亚难民回国：过去两周回国叙利亚难民超过25,000人","content":"土耳其内政部长阿里·耶利卡亚周二表示，过去两周已有25,000多名叙利亚难民越过土耳其边境返回祖国。土耳其当局希望大批难民返回叙利亚，以缓解民众强烈的反叙利亚情绪。土耳其内政部长说，土耳其与叙利亚接壤 900多公里的边界，仍然欢迎逃离战争的约292万叙利亚人。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241224-%E5%9C%9F%E8%80%B3%E5%85%B6%E9%87%87%E5%8F%96%E6%8E%AA%E6%96%BD%EF%BC%8C%E6%96%B9%E4%BE%BF%E5%9C%A8%E5%9C%9F%E8%80%B3%E5%85%B6%E7%9A%84%E5%8F%99%E5%88%A9%E4%BA%9A%E9%9A%BE%E6%B0%91%E5%9B%9E%E5%9B%BD-%E8%BF%87%E5%8E%BB%E4%B8%A4%E5%91%A8%E5%9B%9E%E5%9B%BD%E5%8F%99%E5%88%A9%E4%BA%9A%E9%9A%BE%E6%B0%91%E8%B6%85%E8%BF%8725-000%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2024/12/24/1735044278000.webp","sourceId":"rfi"},{"id":1735039100000,"createdDate":"2024-12-24 11:18","name":"法国国际广播电台","title":"买岛、并邻国、收回运河：特朗普开玩笑，抑或认真的？专家怎么说","content":"美国后任总统特朗普还没入主白宫，已扬言要收回巴拿马运河、重提买下格陵兰，还戏称要并吞加拿大，法新社指出，特朗普当下一个又一个挑衅性言论，让全世界都在怀疑是否应该认真对待他。但有专家认为，特朗普或许是向中国传信息。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20241224-%E4%B9%B0%E5%B2%9B-%E5%B9%B6%E9%82%BB%E5%9B%BD-%E6%94%B6%E5%9B%9E%E8%BF%90%E6%B2%B3-%E7%89%B9%E6%9C%97%E6%99%AE%E5%BC%80%E7%8E%A9%E7%AC%91%EF%BC%8C%E6%8A%91%E6%88%96%E8%AE%A4%E7%9C%9F%E7%9A%84-%E4%B8%93%E5%AE%B6%E6%80%8E%E4%B9%88%E8%AF%B4","thumbnail":"","detailImage":"news/detail/rfi/2024/12/24/1735039100000.webp","sourceId":"rfi"},{"id":1735030865000,"createdDate":"2024-12-24 09:01","name":"法国国际广播电台","title":"挽救经济 消息人士：中国明年拟发3万亿特别国债","content":"据路透引述消息人士透露，中国政府已同意明年发行价值3万亿元人民币（约合4110亿美元）的特别国债，这将是有记录以来最高的一次。由此可见，北京正在加大财政刺激力度，以重振摇摇欲坠的经济。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241224-%E6%8C%BD%E6%95%91%E7%BB%8F%E6%B5%8E-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB-%E4%B8%AD%E5%9B%BD%E6%98%8E%E5%B9%B4%E6%8B%9F%E5%8F%913%E4%B8%87%E4%BA%BF%E4%BA%BA%E5%B8%81%E7%89%B9%E5%88%AB%E5%9B%BD%E5%80%BA","thumbnail":"","detailImage":"news/detail/rfi/2024/12/24/1735030865000.webp","sourceId":"rfi"},{"id":1735030050000,"createdDate":"2024-12-24 08:47","name":"法国国际广播电台","title":"港府悬红百万通缉六人 前艺员郑敬基和学者锺剑华在列","content":"香港第三次每人悬红100万港元(折算约12.4万欧元)通缉六名被指涉嫌违反《港区国安法》的海外港人，他们均是因为离开香港後，发表包括「港独」或要求制裁中国或香港官员的言论而被指涉嫌违例，令因涉嫌违反国安法而被悬红百万元通缉的海外港人增至十九人。国际人权组织「人权观察」亚洲区副主任王松莲指，这是意图恐吓港人的懦夫行为，敦促尚未对华采取制裁行动的英国和加拿大政府，立即阻止港府的行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241224-%E6%B8%AF%E5%BA%9C%E6%82%AC%E7%BA%A2%E7%99%BE%E4%B8%87%E9%80%9A%E7%BC%89%E5%85%AD%E4%BA%BA-%E5%89%8D%E8%89%BA%E5%91%98%E9%83%91%E6%95%AC%E5%9F%BA%E5%92%8C%E5%AD%A6%E8%80%85%E9%94%BA%E5%89%91%E5%8D%8E%E5%9C%A8%E5%88%97","thumbnail":"","detailImage":"news/detail/rfi/2024/12/24/1735030050000.webp","sourceId":"rfi"},{"id":1735029607000,"createdDate":"2024-12-24 08:40","name":"法国国际广播电台","title":"美国会CECC促制裁按港府要求限制港人取回资产的金融机构 中国反对","content":"美国国会及行政当局中国委员会（简称CECC）的最新报告指出，中国人权及自由持续恶化，并违反「一国两制」原则，加大干涉港澳事务。报告建议国会制裁按港府要求去限制港人取回个人资产的金融机构，并继续制裁侵犯人权的港府官员。中国外交部对报告「强烈不满，坚决反对」；而港府则强烈谴责「所谓『制裁』」，但同时又说，对制裁嗤之以鼻。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241224-%E7%BE%8E%E5%9B%BD%E4%BC%9Acecc%E4%BF%83%E5%88%B6%E8%A3%81%E6%8C%89%E6%B8%AF%E5%BA%9C%E8%A6%81%E6%B1%82%E9%99%90%E5%88%B6%E6%B8%AF%E4%BA%BA%E5%8F%96%E5%9B%9E%E8%B5%84%E4%BA%A7%E7%9A%84%E9%87%91%E8%9E%8D%E6%9C%BA%E6%9E%84-%E4%B8%AD%E5%9B%BD%E5%8F%8D%E5%AF%B9","thumbnail":"","detailImage":"news/detail/rfi/2024/12/24/1735029607000.webp","sourceId":"rfi"},{"id":1735029472000,"createdDate":"2024-12-24 08:37","name":"法国国际广播电台","title":"港府列作潜逃者增至13人 前议员许智峯讽刺为「笑话一则」","content":"圣诞节假是西方政界休息的日子，中国过往不时会在此节日前後拘禁买异见人士，以减少面对即时的批评；而香港政府亦在平安夜的早上刊登宪报，把之前已经悬红100万港元通缉的七名流亡美国和澳洲的港人列为潜逃者，令他们的特区护照被取消，而名单中的许智峯共80万元资产亦被冻结。保安局长邓炳强强调，把悬红通缉者列作潜逃人士可切断其资金炼，方法十分有效；但港府并未因此拘捕任何人，而许智峯更表示，暴政的雕虫小技，毫不影响他在自袖国家生活，只是笑话一则。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241224-%E6%B8%AF%E5%BA%9C%E5%88%97%E4%BD%9C%E6%BD%9C%E9%80%83%E8%80%85%E5%A2%9E%E8%87%B313%E4%BA%BA-%E5%89%8D%E8%AE%AE%E5%91%98%E8%AE%B8%E6%99%BA%E5%B3%AF%E8%AE%BD%E5%88%BA%E4%B8%BA-%E7%AC%91%E8%AF%9D%E4%B8%80%E5%88%99","thumbnail":"","detailImage":"news/detail/rfi/2024/12/24/1735029472000.webp","sourceId":"rfi"},{"id":1735029249000,"createdDate":"2024-12-24 08:34","name":"法国国际广播电台","title":"日本外务大臣访华与王毅及李强会谈","content":"日本外务大臣岩屋毅在24日的记者会上宣布，他将于25日访问中国北京，与中共中央政治局委员兼外长王毅举行会谈。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20241224-%E6%97%A5%E6%9C%AC%E5%A4%96%E5%8A%A1%E5%A4%A7%E8%87%A3%E8%AE%BF%E5%8D%8E%E4%B8%8E%E7%8E%8B%E6%AF%85%E5%8F%8A%E6%9D%8E%E5%BC%BA%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2024/12/24/1735029249000.webp","sourceId":"rfi"},{"id":1735064500000,"createdDate":"2024-12-24 18:21","name":"法国国际广播电台","title":"继海康威视后 大华股份退出新疆5地方政府项目","content":"据路透社报导，中国视频监控设备制造商大华股份周一向深圳证券交易所提交的文件显示，该公司及其子公司已同意终止或退出与新疆地方政府签署的五个项目。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241224-%E7%BB%A7%E6%B5%B7%E5%BA%B7%E5%A8%81%E8%A7%86%E5%90%8E-%E5%A4%A7%E5%8D%8E%E8%82%A1%E4%BB%BD%E9%80%80%E5%87%BA%E6%96%B0%E7%96%865%E5%9C%B0%E6%96%B9%E6%94%BF%E5%BA%9C%E9%A1%B9%E7%9B%AE","thumbnail":"","detailImage":"news/detail/rfi/2024/12/24/1735064500000.webp","sourceId":"rfi"},{"id":1735063246000,"createdDate":"2024-12-24 18:00","name":"法国国际广播电台","title":"拜登考虑下台前对俄能源业实施重大制裁 给特朗普更多筹码","content":"据《华盛顿邮报》援引四位知情人士报导称，美国总统拜登（JoeBiden）正考虑在其任期的最后几周对俄罗斯能源行业实施新的重大制裁，拜登政府或将对俄总统普京的金融战中实施下台前的最后一击。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20241224-%E6%8B%9C%E7%99%BB%E8%80%83%E8%99%91%E4%B8%8B%E5%8F%B0%E5%89%8D%E5%AF%B9%E4%BF%84%E8%83%BD%E6%BA%90%E8%A1%8C%E4%B8%9A%E5%AE%9E%E6%96%BD%E9%87%8D%E5%A4%A7%E5%88%B6%E8%A3%81-%E7%BB%99%E7%89%B9%E6%9C%97%E6%99%AE%E6%9B%B4%E5%A4%9A%E7%AD%B9%E7%A0%81","thumbnail":"","detailImage":"news/detail/rfi/2024/12/24/1735063246000.webp","sourceId":"rfi"},{"id":1735060685000,"createdDate":"2024-12-24 17:18","name":"法国国际广播电台","title":"港警再悬红通缉6人 欧盟：损害香港作为国际商业中心的吸引力","content":"香港警方国安处12月24日公布新一轮通缉名单，涉及6名海外港人，包括艺人郑敬基、理大前助理教授锺剑华、前“学生动源”召集人锺翰林、黄大仙区议会前议员刘珈汶、新闻工作者何良懋及张晞晴。当局指，他们分别涉煽动分裂国家罪、颠覆国家政权罪、勾结外国或者境外势力危害国家安全罪；各悬红100万元。港警国安处指各人涉嫌出卖国家，罔顾港人利益。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241224-%E6%B8%AF%E8%AD%A6%E5%86%8D%E6%82%AC%E7%BA%A2%E9%80%9A%E7%BC%896%E4%BA%BA-%E6%AC%A7%E7%9B%9F-%E6%8D%9F%E5%AE%B3%E9%A6%99%E6%B8%AF%E4%BD%9C%E4%B8%BA%E5%9B%BD%E9%99%85%E5%95%86%E4%B8%9A%E4%B8%AD%E5%BF%83%E7%9A%84%E5%90%B8%E5%BC%95%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2024/12/24/1735060685000.webp","sourceId":"rfi"},{"id":1735046531000,"createdDate":"2024-12-24 13:22","name":"法国国际广播电台","title":"中国2025年预算政策为增加赤字开路，国际货币基金组织 预计中国 2025年的GDP增长将进一步放缓","content":"中国周二公布了“更加积极”的2025年预算政策，旨在支持依然脆弱的国内消费，稳定面临持续挑战的经济。根据12月23日至24日于北京召开的全国财政工作会议结束时的公告，这一新方向标志着公共支出的加速，并为预算赤字的增加开辟了道路。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241224-%E4%B8%AD%E5%9B%BD2025%E5%B9%B4%E9%A2%84%E7%AE%97%E6%94%BF%E7%AD%96%E4%B8%BA%E5%A2%9E%E5%8A%A0%E8%B5%A4%E5%AD%97%E5%BC%80%E8%B7%AF%EF%BC%8C%E5%9B%BD%E9%99%85%E8%B4%A7%E5%B8%81%E5%9F%BA%E9%87%91%E7%BB%84%E7%BB%87-%E9%A2%84%E8%AE%A1%E4%B8%AD%E5%9B%BD-2025%E5%B9%B4%E7%9A%84gdp%E5%A2%9E%E9%95%BF%E5%B0%86%E8%BF%9B%E4%B8%80%E6%AD%A5%E6%94%BE%E7%BC%93","thumbnail":"","detailImage":"news/detail/rfi/2024/12/24/1735046531000.webp","sourceId":"rfi"},{"id":1735045400000,"createdDate":"2024-12-24 13:03","name":"法国国际广播电台","title":"特朗普说要收回巴拿马运河、重提买下格陵兰： 政治学者解读这是警告丹麦不要对中国太友好","content":"美国总统当选人特朗普还没上任，已扬言要收回巴拿马运河、重提买下格陵兰，还戏称要并吞加拿大。美国智库兰德公司（RandCorporation）资深政治学者佩扎德（StephaniePezard）说，特朗普提收购格陵兰，「或许是向中国传达讯息」。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241224-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AF%B4%E8%A6%81%E6%94%B6%E5%9B%9E%E5%B7%B4%E6%8B%BF%E9%A9%AC%E8%BF%90%E6%B2%B3-%E9%87%8D%E6%8F%90%E4%B9%B0%E4%B8%8B%E6%A0%BC%E9%99%B5%E5%85%B0-%E6%94%BF%E6%B2%BB%E5%AD%A6%E8%80%85%E8%A7%A3%E8%AF%BB%E8%BF%99%E6%98%AF%E8%AD%A6%E5%91%8A%E4%B8%B9%E9%BA%A6%E4%B8%8D%E8%A6%81%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%A4%AA%E5%8F%8B%E5%A5%BD","thumbnail":"","detailImage":"news/detail/rfi/2024/12/24/1735045400000.webp","sourceId":"rfi"},{"id":1735044923000,"createdDate":"2024-12-24 12:55","name":"法国国际广播电台","title":"中国半导体产能巨大：美国展开调查，北京谴责保护主义","content":"美国12月23日表示，对中国的半导体产业政策展开调查，理由是担心北京正在采取「广泛的反竞争和非市场手段」来伤害其他经济体。北京谴责这项半导体产业政策调查是「保护主义」，发誓要捍卫自身利益，并敦促华府停止「错误举措」。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241224-%E4%B8%AD%E5%9B%BD%E5%8D%8A%E5%AF%BC%E4%BD%93%E4%BA%A7%E8%83%BD%E5%B7%A8%E5%A4%A7-%E7%BE%8E%E5%9B%BD%E5%B1%95%E5%BC%80%E8%B0%83%E6%9F%A5%EF%BC%8C%E5%8C%97%E4%BA%AC%E8%B0%B4%E8%B4%A3%E4%BF%9D%E6%8A%A4%E4%B8%BB%E4%B9%89","thumbnail":"","detailImage":"news/detail/rfi/2024/12/24/1735044923000.webp","sourceId":"rfi"}]