[{"id":1735389044000,"createdDate":"2024-12-28 12:30","name":"法国国际广播电台","title":"比亚迪遭贩卖人口指控 巴西取消临时工作签证","content":"据路透消息，巴西外交部周五表示，巴西已停止向比亚迪发放临时工作签证，此前有指控称，这家中国电动汽车制造商旗下工厂的部分工人是人口贩运的受害者。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241228-%E6%AF%94%E4%BA%9A%E8%BF%AA%E9%81%AD%E8%B4%A9%E5%8D%96%E4%BA%BA%E5%8F%A3%E6%8C%87%E6%8E%A7-%E5%B7%B4%E8%A5%BF%E5%8F%96%E6%B6%88%E4%B8%B4%E6%97%B6%E5%B7%A5%E4%BD%9C%E7%AD%BE%E8%AF%81","thumbnail":"","detailImage":"news/detail/rfi/2024/12/28/1735389044000.webp","sourceId":"rfi"},{"id":1735382968000,"createdDate":"2024-12-28 10:49","name":"法国国际广播电台","title":"中国将降低部分再生铜铝原料的进口关税","content":"中国财政部周六声明显示将从2025年1月1日起降低乙烷和部分再生铜铝原料等的进口关税，进一步推动绿色经济发展，促进高水平对外开放。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20241228-%E4%B8%AD%E5%9B%BD%E5%B0%86%E9%99%8D%E4%BD%8E%E9%83%A8%E5%88%86%E5%86%8D%E7%94%9F%E9%93%9C%E9%93%9D%E5%8E%9F%E6%96%99%E7%9A%84%E8%BF%9B%E5%8F%A3%E5%85%B3%E7%A8%8E","thumbnail":"","detailImage":"news/detail/rfi/2024/12/28/1735382968000.webp","sourceId":"rfi"},{"id":1735378429000,"createdDate":"2024-12-28 09:33","name":"法国国际广播电台","title":"韩国检察官报告：尹锡悦曾授权军队开枪进入国会","content":"法新社周六（12月28日）看到的一份韩国检察官报告称，韩国总统尹锡悦在12月3日企图实施戒严期间，曾授权军队在必要时开枪进入国会。在国会议员紧急否决戒严令后，他曾表示将“第二次、第三次”宣布戒严。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241228-%E9%9F%A9%E5%9B%BD%E6%A3%80%E5%AF%9F%E5%AE%98%E6%8A%A5%E5%91%8A-%E5%B0%B9%E9%94%A1%E6%82%A6%E6%9B%BE%E6%8E%88%E6%9D%83%E5%86%9B%E9%98%9F%E5%BC%80%E6%9E%AA%E8%BF%9B%E5%85%A5%E5%9B%BD%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2024/12/28/1735378429000.webp","sourceId":"rfi"},{"id":1735373342000,"createdDate":"2024-12-28 08:09","name":"法国国际广播电台","title":"日本外务大臣质疑中方发表的日中外长会谈内容","content":"关于12月25日举行的日中外长会谈，日本外务大臣岩屋毅在27日的记者会上指出：有关我在会谈中的发言，中国方面的报道不准确，已向中方提出了交涉。对此，中国方面称：“正确认识和对待日本军国主义侵略历史，是日本取信于国际社会特别是亚洲近邻的重要前提。”","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20241228-%E6%97%A5%E6%9C%AC%E5%A4%96%E5%8A%A1%E5%A4%A7%E8%87%A3%E8%B4%A8%E7%96%91%E4%B8%AD%E6%96%B9%E5%8F%91%E8%A1%A8%E7%9A%84%E6%97%A5%E4%B8%AD%E5%A4%96%E9%95%BF%E4%BC%9A%E8%B0%88%E5%86%85%E5%AE%B9","thumbnail":"","detailImage":"news/detail/rfi/2024/12/28/1735373342000.webp","sourceId":"rfi"}]