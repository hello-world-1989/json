[{"id":1772583091000,"createdDate":"2026-03-04 00:11","name":"法国国际广播电台","title":"伊朗战争：俄罗斯无能为力，无法援助受威胁的盟友","content":"法国世界报周二强调，在伊朗遭受美以联合打击之际，俄罗斯无能为力，没有力量援助受威胁的盟友。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260304-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89-%E4%BF%84%E7%BD%97%E6%96%AF%E6%97%A0%E8%83%BD%E4%B8%BA%E5%8A%9B%EF%BC%8C%E6%97%A0%E6%B3%95%E6%8F%B4%E5%8A%A9%E5%8F%97%E5%A8%81%E8%83%81%E7%9A%84%E7%9B%9F%E5%8F%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772583091000.webp","sourceId":"rfi"},{"id":1772582924000,"createdDate":"2026-03-04 00:08","name":"法国国际广播电台","title":"中东航班仍然稀少，各国政府的撤离行动也在持续进行中","content":"中东战争导致大规模航班取消，过去四天里，共有1.9万架次航班被取消。周二，商业航班开始少量恢复运行。各国政府和航空公司也正组织航班，接回因冲突滞留在中东的旅客。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260304-%E4%B8%AD%E4%B8%9C%E8%88%AA%E7%8F%AD%E4%BB%8D%E7%84%B6%E7%A8%80%E5%B0%91%EF%BC%8C%E5%90%84%E5%9B%BD%E6%94%BF%E5%BA%9C%E7%9A%84%E6%92%A4%E7%A6%BB%E8%A1%8C%E5%8A%A8%E4%B9%9F%E5%9C%A8%E6%8C%81%E7%BB%AD%E8%BF%9B%E8%A1%8C%E4%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772582924000.webp","sourceId":"rfi"},{"id":1772611914000,"createdDate":"2026-03-04 08:11","name":"法国国际广播电台","title":"中国人大明召开 将审议GDP和「十五五」发言人指惠港措施陆续有来","content":"中国人民代表大会明(5日)早在北京人民大会堂举行开幕礼，八天会期内，各人大会审议政府工作报告及国民经济和社会发展第十五个五年规划(简称十五五规划)纲要草案，全国人大新闻发言人娄勤俭表示，中央将在「十五五」规划中，进一步部署支持香港发挥独特优势和重要作用，并继续出台更多惠港政策措施。不过，他未有透露详情。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E4%B8%AD%E5%9B%BD%E4%BA%BA%E5%A4%A7%E6%98%8E%E5%8F%AC%E5%BC%80-%E5%B0%86%E5%AE%A1%E8%AE%AEgdp%E5%92%8C-%E5%8D%81%E4%BA%94%E4%BA%94-%E5%8F%91%E8%A8%80%E4%BA%BA%E6%8C%87%E6%83%A0%E6%B8%AF%E6%8E%AA%E6%96%BD%E9%99%86%E7%BB%AD%E6%9C%89%E6%9D%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772611914000.webp","sourceId":"rfi"},{"id":1772611692000,"createdDate":"2026-03-04 08:08","name":"法国国际广播电台","title":"人大：中愿与美沟通但有底线 更愿与欧洲加强合作","content":"中国「两会」将在美以两国攻击伊朗声中召开，中国人大会议新闻发言人娄勤俭呼吁各方停火，他虽没有直接点出中东局势会否影响中美关系，但就表明，中方愿与美方一道，加强各层级和管道的沟通，为双方合作开拓更广阔的空间，但同时强调，中方也有自己的原则和底线，将一如既往，坚决捍卫自身主权安全发展利益。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E4%BA%BA%E5%A4%A7-%E4%B8%AD%E6%84%BF%E4%B8%8E%E7%BE%8E%E6%B2%9F%E9%80%9A%E4%BD%86%E6%9C%89%E5%BA%95%E7%BA%BF-%E6%9B%B4%E6%84%BF%E4%B8%8E%E6%AC%A7%E6%B4%B2%E5%8A%A0%E5%BC%BA%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772611692000.webp","sourceId":"rfi"},{"id":1772611474000,"createdDate":"2026-03-04 08:04","name":"法国国际广播电台","title":"日本首相拒绝回答美以攻击伊朗是否违反国际法","content":"高市早苗首相在日本时间3日的众议院预算委员会上，就美以两军对伊朗发动攻击一事表示，在计划3月内的访美期间，在与特朗普总统会谈时，“将坦率地进行交流”。她还强调，将就中东局势深入讨论，深入探讨美方的想法,但她拒绝对美以两军的攻击是否违反国际法做出判断。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E6%8B%92%E7%BB%9D%E5%9B%9E%E7%AD%94%E7%BE%8E%E4%BB%A5%E6%94%BB%E5%87%BB%E4%BC%8A%E6%9C%97%E6%98%AF%E5%90%A6%E8%BF%9D%E5%8F%8D%E5%9B%BD%E9%99%85%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772611474000.webp","sourceId":"rfi"},{"id":1772611274000,"createdDate":"2026-03-04 08:01","name":"法国国际广播电台","title":"两会前夕 夏宝龙吁港澳成员把握「十五五」推发展 新华社罕嘱港拓欧美市场","content":"中国全国政协和人大会议分别于今(4日)明两天开幕，港澳办主任夏宝龙在「两会」召开前夕向与会的香港和澳门特区成员表示，希望他们倍加珍惜港澳来之不易的大好局面，心怀\"国之大者\"，认真履职，推动港澳高质量发展，更好融入和服务国家发展大局。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E4%B8%A4%E4%BC%9A%E5%89%8D%E5%A4%95-%E5%A4%8F%E5%AE%9D%E9%BE%99%E5%90%81%E6%B8%AF%E6%BE%B3%E6%88%90%E5%91%98%E6%8A%8A%E6%8F%A1-%E5%8D%81%E4%BA%94%E4%BA%94-%E6%8E%A8%E5%8F%91%E5%B1%95-%E6%96%B0%E5%8D%8E%E7%A4%BE%E7%BD%95%E5%98%B1%E6%B8%AF%E6%8B%93%E6%AC%A7%E7%BE%8E%E5%B8%82%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772611274000.webp","sourceId":"rfi"},{"id":1772611108000,"createdDate":"2026-03-04 07:58","name":"法国国际广播电台","title":"中国2026年“两会”拉开帷幕：军费预算与人口挑战下的经济压力备受关注","content":"法新社北京电稿称，中国周三（3月4日）正式拉开年度政治盛事“两会”的帷幕，届时将公布世界第二大经济体的增长目标及军费预算，而当前国内外形势复杂多变。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E4%B8%AD%E5%9B%BD2026%E5%B9%B4-%E4%B8%A4%E4%BC%9A-%E6%8B%89%E5%BC%80%E5%B8%B7%E5%B9%95-%E5%86%9B%E8%B4%B9%E9%A2%84%E7%AE%97%E4%B8%8E%E4%BA%BA%E5%8F%A3%E6%8C%91%E6%88%98%E4%B8%8B%E7%9A%84%E7%BB%8F%E6%B5%8E%E5%8E%8B%E5%8A%9B%E5%A4%87%E5%8F%97%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772611108000.webp","sourceId":"rfi"},{"id":1772610254000,"createdDate":"2026-03-04 07:44","name":"法国国际广播电台","title":"中国驻斯特拉斯堡领事馆要求取消台湾剧目，市长谴责：干预行为“极其严重”","content":"周二（3月3日），法国东部城市斯特拉斯堡市长向法新社透露，中国驻斯特拉斯堡领事馆此前要求该市取消一场关于台湾的舞台剧演出。斯堡市长对此表示强烈谴责，称这种干预行为“极其严重”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E4%B8%AD%E5%9B%BD%E9%A9%BB%E6%96%AF%E7%89%B9%E6%8B%89%E6%96%AF%E5%A0%A1%E9%A2%86%E4%BA%8B%E9%A6%86%E8%A6%81%E6%B1%82%E5%8F%96%E6%B6%88%E5%8F%B0%E6%B9%BE%E5%89%A7%E7%9B%AE%EF%BC%8C%E5%B8%82%E9%95%BF%E8%B0%B4%E8%B4%A3-%E5%B9%B2%E9%A2%84%E8%A1%8C%E4%B8%BA-%E6%9E%81%E5%85%B6%E4%B8%A5%E9%87%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772610254000.webp","sourceId":"rfi"}]