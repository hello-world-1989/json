[{"id":1772583091000,"createdDate":"2026-03-04 00:11","name":"法国国际广播电台","title":"伊朗战争：俄罗斯无能为力，无法援助受威胁的盟友","content":"法国世界报周二强调，在伊朗遭受美以联合打击之际，俄罗斯无能为力，没有力量援助受威胁的盟友。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260304-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89-%E4%BF%84%E7%BD%97%E6%96%AF%E6%97%A0%E8%83%BD%E4%B8%BA%E5%8A%9B%EF%BC%8C%E6%97%A0%E6%B3%95%E6%8F%B4%E5%8A%A9%E5%8F%97%E5%A8%81%E8%83%81%E7%9A%84%E7%9B%9F%E5%8F%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772583091000.webp","sourceId":"rfi"},{"id":1772582924000,"createdDate":"2026-03-04 00:08","name":"法国国际广播电台","title":"中东航班仍然稀少，各国政府的撤离行动也在持续进行中","content":"中东战争导致大规模航班取消，过去四天里，共有1.9万架次航班被取消。周二，商业航班开始少量恢复运行。各国政府和航空公司也正组织航班，接回因冲突滞留在中东的旅客。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260304-%E4%B8%AD%E4%B8%9C%E8%88%AA%E7%8F%AD%E4%BB%8D%E7%84%B6%E7%A8%80%E5%B0%91%EF%BC%8C%E5%90%84%E5%9B%BD%E6%94%BF%E5%BA%9C%E7%9A%84%E6%92%A4%E7%A6%BB%E8%A1%8C%E5%8A%A8%E4%B9%9F%E5%9C%A8%E6%8C%81%E7%BB%AD%E8%BF%9B%E8%A1%8C%E4%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772582924000.webp","sourceId":"rfi"},{"id":1772611914000,"createdDate":"2026-03-04 08:11","name":"法国国际广播电台","title":"中国人大明召开 将审议GDP和「十五五」发言人指惠港措施陆续有来","content":"中国人民代表大会明(5日)早在北京人民大会堂举行开幕礼，八天会期内，各人大会审议政府工作报告及国民经济和社会发展第十五个五年规划(简称十五五规划)纲要草案，全国人大新闻发言人娄勤俭表示，中央将在「十五五」规划中，进一步部署支持香港发挥独特优势和重要作用，并继续出台更多惠港政策措施。不过，他未有透露详情。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E4%B8%AD%E5%9B%BD%E4%BA%BA%E5%A4%A7%E6%98%8E%E5%8F%AC%E5%BC%80-%E5%B0%86%E5%AE%A1%E8%AE%AEgdp%E5%92%8C-%E5%8D%81%E4%BA%94%E4%BA%94-%E5%8F%91%E8%A8%80%E4%BA%BA%E6%8C%87%E6%83%A0%E6%B8%AF%E6%8E%AA%E6%96%BD%E9%99%86%E7%BB%AD%E6%9C%89%E6%9D%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772611914000.webp","sourceId":"rfi"},{"id":1772611692000,"createdDate":"2026-03-04 08:08","name":"法国国际广播电台","title":"人大：中愿与美沟通但有底线 更愿与欧洲加强合作","content":"中国「两会」将在美以两国攻击伊朗声中召开，中国人大会议新闻发言人娄勤俭呼吁各方停火，他虽没有直接点出中东局势会否影响中美关系，但就表明，中方愿与美方一道，加强各层级和管道的沟通，为双方合作开拓更广阔的空间，但同时强调，中方也有自己的原则和底线，将一如既往，坚决捍卫自身主权安全发展利益。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E4%BA%BA%E5%A4%A7-%E4%B8%AD%E6%84%BF%E4%B8%8E%E7%BE%8E%E6%B2%9F%E9%80%9A%E4%BD%86%E6%9C%89%E5%BA%95%E7%BA%BF-%E6%9B%B4%E6%84%BF%E4%B8%8E%E6%AC%A7%E6%B4%B2%E5%8A%A0%E5%BC%BA%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772611692000.webp","sourceId":"rfi"},{"id":1772611474000,"createdDate":"2026-03-04 08:04","name":"法国国际广播电台","title":"日本首相拒绝回答美以攻击伊朗是否违反国际法","content":"高市早苗首相在日本时间3日的众议院预算委员会上，就美以两军对伊朗发动攻击一事表示，在计划3月内的访美期间，在与特朗普总统会谈时，“将坦率地进行交流”。她还强调，将就中东局势深入讨论，深入探讨美方的想法,但她拒绝对美以两军的攻击是否违反国际法做出判断。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E6%8B%92%E7%BB%9D%E5%9B%9E%E7%AD%94%E7%BE%8E%E4%BB%A5%E6%94%BB%E5%87%BB%E4%BC%8A%E6%9C%97%E6%98%AF%E5%90%A6%E8%BF%9D%E5%8F%8D%E5%9B%BD%E9%99%85%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772611474000.webp","sourceId":"rfi"},{"id":1772611274000,"createdDate":"2026-03-04 08:01","name":"法国国际广播电台","title":"两会前夕 夏宝龙吁港澳成员把握「十五五」推发展 新华社罕嘱港拓欧美市场","content":"中国全国政协和人大会议分别于今(4日)明两天开幕，港澳办主任夏宝龙在「两会」召开前夕向与会的香港和澳门特区成员表示，希望他们倍加珍惜港澳来之不易的大好局面，心怀\"国之大者\"，认真履职，推动港澳高质量发展，更好融入和服务国家发展大局。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E4%B8%A4%E4%BC%9A%E5%89%8D%E5%A4%95-%E5%A4%8F%E5%AE%9D%E9%BE%99%E5%90%81%E6%B8%AF%E6%BE%B3%E6%88%90%E5%91%98%E6%8A%8A%E6%8F%A1-%E5%8D%81%E4%BA%94%E4%BA%94-%E6%8E%A8%E5%8F%91%E5%B1%95-%E6%96%B0%E5%8D%8E%E7%A4%BE%E7%BD%95%E5%98%B1%E6%B8%AF%E6%8B%93%E6%AC%A7%E7%BE%8E%E5%B8%82%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772611274000.webp","sourceId":"rfi"},{"id":1772611108000,"createdDate":"2026-03-04 07:58","name":"法国国际广播电台","title":"中国2026年“两会”拉开帷幕：军费预算与人口挑战下的经济压力备受关注","content":"法新社北京电稿称，中国周三（3月4日）正式拉开年度政治盛事“两会”的帷幕，届时将公布世界第二大经济体的增长目标及军费预算，而当前国内外形势复杂多变。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E4%B8%AD%E5%9B%BD2026%E5%B9%B4-%E4%B8%A4%E4%BC%9A-%E6%8B%89%E5%BC%80%E5%B8%B7%E5%B9%95-%E5%86%9B%E8%B4%B9%E9%A2%84%E7%AE%97%E4%B8%8E%E4%BA%BA%E5%8F%A3%E6%8C%91%E6%88%98%E4%B8%8B%E7%9A%84%E7%BB%8F%E6%B5%8E%E5%8E%8B%E5%8A%9B%E5%A4%87%E5%8F%97%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772611108000.webp","sourceId":"rfi"},{"id":1772610254000,"createdDate":"2026-03-04 07:44","name":"法国国际广播电台","title":"中国驻斯特拉斯堡领事馆要求取消台湾剧目，市长谴责：干预行为“极其严重”","content":"周二（3月3日），法国东部城市斯特拉斯堡市长向法新社透露，中国驻斯特拉斯堡领事馆此前要求该市取消一场关于台湾的舞台剧演出。斯堡市长对此表示强烈谴责，称这种干预行为“极其严重”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E4%B8%AD%E5%9B%BD%E9%A9%BB%E6%96%AF%E7%89%B9%E6%8B%89%E6%96%AF%E5%A0%A1%E9%A2%86%E4%BA%8B%E9%A6%86%E8%A6%81%E6%B1%82%E5%8F%96%E6%B6%88%E5%8F%B0%E6%B9%BE%E5%89%A7%E7%9B%AE%EF%BC%8C%E5%B8%82%E9%95%BF%E8%B0%B4%E8%B4%A3-%E5%B9%B2%E9%A2%84%E8%A1%8C%E4%B8%BA-%E6%9E%81%E5%85%B6%E4%B8%A5%E9%87%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772610254000.webp","sourceId":"rfi"},{"id":1772641739000,"createdDate":"2026-03-04 16:28","name":"法国国际广播电台","title":"2万美元廉价无人机与400万美元昂贵拦截弹，哪个先耗尽或决定中东战局","content":"伊朗正通过一波又一波的廉价无人机，对美国及其海湾盟友的防空系统持续施压。据彭博社援引专家指出，这场战局的走向，或将取决于哪一方先耗尽弹药。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260304-2%E4%B8%87%E7%BE%8E%E5%85%83%E5%BB%89%E4%BB%B7%E6%97%A0%E4%BA%BA%E6%9C%BA%E4%B8%8E400%E4%B8%87%E7%BE%8E%E5%85%83%E6%98%82%E8%B4%B5%E6%8B%A6%E6%88%AA%E5%BC%B9%EF%BC%8C%E5%93%AA%E4%B8%AA%E5%85%88%E8%80%97%E5%B0%BD%E6%88%96%E5%86%B3%E5%AE%9A%E4%B8%AD%E4%B8%9C%E6%88%98%E5%B1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772641739000.webp","sourceId":"rfi"},{"id":1772640008000,"createdDate":"2026-03-04 16:00","name":"法国国际广播电台","title":"英国警方逮捕涉北京间谍活动的三名男嫌","content":"据法新社报道，伦敦反恐警察周三（3月4日）逮捕了三名涉嫌为北京从事间谍活动的男子。英国政府一名部长表示，此举凸显了伦敦“打击外国国家干预”——特别是来自中国的干预——的坚定决心。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E8%8B%B1%E5%9B%BD%E8%AD%A6%E6%96%B9%E9%80%AE%E6%8D%95%E6%B6%89%E5%8C%97%E4%BA%AC%E9%97%B4%E8%B0%8D%E6%B4%BB%E5%8A%A8%E7%9A%84%E4%B8%89%E5%90%8D%E7%94%B7%E5%AB%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772640008000.webp","sourceId":"rfi"},{"id":1772637048000,"createdDate":"2026-03-04 15:10","name":"法国国际广播电台","title":"伊媒：哈梅内伊告别式因吊唁者过多推迟 已确定几名候选人接班 穆杰塔巴“最有可能”","content":"原定今晚3月4日开始举行的已故最高领袖哈梅内伊告别仪式被推迟，新的安排将随后发布。据伊朗媒体报道说，推迟原因是预计前来吊唁的民众数量空前庞大。此外，《纽约时报》日前引述伊朗官员说，高级神职人员考虑最早于今天宣布由已故的哈梅内伊次子穆杰塔巴（MojtabaKhamenei）接替父亲成为伊朗最高领导人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260304-%E4%BC%8A%E5%AA%92-%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E5%91%8A%E5%88%AB%E5%BC%8F%E5%9B%A0%E5%90%8A%E5%94%81%E8%80%85%E8%BF%87%E5%A4%9A%E6%8E%A8%E8%BF%9F-%E5%B7%B2%E7%A1%AE%E5%AE%9A%E5%87%A0%E5%90%8D%E5%80%99%E9%80%89%E4%BA%BA%E6%8E%A5%E7%8F%AD-%E7%A9%86%E6%9D%B0%E5%A1%94%E5%B7%B4%E6%9C%80%E6%9C%89%E5%8F%AF%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772637048000.webp","sourceId":"rfi"},{"id":1772636963000,"createdDate":"2026-03-04 15:09","name":"法国国际广播电台","title":"美国证实击沉一艘伊朗护卫舰  148人失踪","content":"美国防长赫格塞斯今天证实美军潜艇在印度洋击沉一艘伊朗军舰。斯里兰卡军方称该舰船上180名人员中有32人获救。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260304-%E7%BE%8E%E5%9B%BD%E8%AF%81%E5%AE%9E%E5%87%BB%E6%B2%89%E4%B8%80%E8%89%98%E4%BC%8A%E6%9C%97%E6%8A%A4%E5%8D%AB%E8%88%B0-148%E4%BA%BA%E5%A4%B1%E8%B8%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772636963000.webp","sourceId":"rfi"},{"id":1772636340000,"createdDate":"2026-03-04 14:59","name":"法国国际广播电台","title":"距离2026足球世界杯不足百日，伊朗国足去还是不去？","content":"美国和以色列启动军事打击行动几天后，伊朗神权政府可以说已经岌岌可危。不过，无论是近日曾为把持伊朗最高权柄的哈梅内伊之死欢呼的人，还是为美国和以色列的军事行动愤怒者，如今都面对一个两难的棘手选择：距离主场在美国的2026世界杯足球赛开始已经不足百日，伊朗国足去？还是不去？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260304-%E8%B7%9D%E7%A6%BB2026%E8%B6%B3%E7%90%83%E4%B8%96%E7%95%8C%E6%9D%AF%E4%B8%8D%E8%B6%B3%E7%99%BE%E6%97%A5%EF%BC%8C%E4%BC%8A%E6%9C%97%E5%9B%BD%E8%B6%B3%E5%8E%BB%E8%BF%98%E6%98%AF%E4%B8%8D%E5%8E%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772636340000.webp","sourceId":"rfi"},{"id":1772635313000,"createdDate":"2026-03-04 14:41","name":"法国国际广播电台","title":"中国“两会”开幕：应对内外挑战抑或强化习近平路线？","content":"在消费低迷、人口老龄化、向新技术转型、地缘政治危机等重大挑战的背景下，一年一度的中国“两会”如期登场。2026年版中国人民政治协商和全国人大分别于周三（3月4号）和周四拉开帷幕。“两会”被形容为“橡皮图章”但仍然引人瞩目，究其原因，这是中国乃至世界各国得以窥见北京每年优先事项的窗口。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260304-%E4%B8%AD%E5%9B%BD%E4%B8%A4%E4%BC%9A-%E5%BA%94%E5%AF%B9%E5%86%85%E5%A4%96%E6%8C%91%E6%88%98%E6%8A%91%E6%88%96%E5%BC%BA%E5%8C%96%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%B7%AF%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772635313000.webp","sourceId":"rfi"},{"id":1772635067000,"createdDate":"2026-03-04 14:37","name":"法国国际广播电台","title":"「胡锦涛的伯乐」中共元老宋平逝世 享寿109岁","content":"中央社引述新华社报道，曾任中共第13届政治局常委、中国国务委员等职的中共元老宋平今天4日下午在北京逝世，享寿109岁。宋平早年曾任已故国务院总理周恩来的政治秘书，并自1970年代末期任甘肃省委第一书记，一路拔擢当时任职甘肃的前中共总书记胡锦涛，奠定他日后在党内的地位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E8%83%A1%E9%94%A6%E6%B6%9B%E7%9A%84%E4%BC%AF%E4%B9%90-%E4%B8%AD%E5%85%B1%E5%85%83%E8%80%81%E5%AE%8B%E5%B9%B3%E9%80%9D%E4%B8%96-%E4%BA%AB%E5%AF%BF109%E5%B2%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772635067000.webp","sourceId":"rfi"},{"id":1772628401000,"createdDate":"2026-03-04 12:46","name":"法国国际广播电台","title":"尼泊尔迎来Z世代抗议后首次大选：街头怒火能否化为选票 全球拭目以待","content":"尼泊尔周四3月5日将迎来「Z世代抗议」后的首次全国性选举。这场由年轻人主导的历史性抗争能否转化为选票，为这个长期政治动荡的国家带来实质变革，备受外界关注。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260304-%E5%B0%BC%E6%B3%8A%E5%B0%94%E8%BF%8E%E6%9D%A5z%E4%B8%96%E4%BB%A3%E6%8A%97%E8%AE%AE%E5%90%8E%E9%A6%96%E6%AC%A1%E5%A4%A7%E9%80%89-%E8%A1%97%E5%A4%B4%E6%80%92%E7%81%AB%E8%83%BD%E5%90%A6%E5%8C%96%E4%B8%BA%E9%80%89%E7%A5%A8%E6%8B%AD%E7%9B%AE%E4%BB%A5%E5%BE%85","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772628401000.webp","sourceId":"rfi"},{"id":1772626847000,"createdDate":"2026-03-04 12:20","name":"法国国际广播电台","title":"法国航母启航地中海，希腊护卫舰抵达塞浦路斯加强防务","content":"在中东局势紧张、无人机袭击波及地中海东部之际，法国采取军事行动。马克龙总统宣布法国将派遣“戴高乐”号航空母舰及舰载机战斗群前往地中海，而希腊两艘护卫舰已抵达塞浦路斯，加强地区防御能力。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260304-%E6%B3%95%E5%9B%BD%E8%88%AA%E6%AF%8D%E5%90%AF%E8%88%AA%E5%9C%B0%E4%B8%AD%E6%B5%B7%EF%BC%8C%E5%B8%8C%E8%85%8A%E6%8A%A4%E5%8D%AB%E8%88%B0%E6%8A%B5%E8%BE%BE%E5%A1%9E%E6%B5%A6%E8%B7%AF%E6%96%AF%E5%8A%A0%E5%BC%BA%E9%98%B2%E5%8A%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772626847000.webp","sourceId":"rfi"},{"id":1772625089000,"createdDate":"2026-03-04 11:51","name":"法国国际广播电台","title":"中国航运巨头中远海运暂停往返海湾地区的服务","content":"法新社北京消息，中国航运巨头中远海运（Cosco）运营着全球规模最大的油轮船队之一。该公司周三3月4日宣布，将从即日起暂停往返阿联酋、巴林、沙特阿拉伯、伊拉克和科威特等海湾国家的航运服务。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E4%B8%AD%E5%9B%BD%E8%88%AA%E8%BF%90%E5%B7%A8%E5%A4%B4%E4%B8%AD%E8%BF%9C%E6%B5%B7%E8%BF%90%E6%9A%82%E5%81%9C%E5%BE%80%E8%BF%94%E6%B5%B7%E6%B9%BE%E5%9C%B0%E5%8C%BA%E7%9A%84%E6%9C%8D%E5%8A%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772625089000.webp","sourceId":"rfi"},{"id":1772617035000,"createdDate":"2026-03-04 09:37","name":"法国国际广播电台","title":"为安全起见，美国下令驻巴基斯坦两领馆非必要人员撤离","content":"美国和以色列对伊朗军事行动的战火虽然并未波及巴基斯坦，但伊朗精神领袖哈梅内伊之死在巴基斯坦多座城市引发反美抗议集会，并造成人员伤亡。美国国务院已下令其驻卡拉奇和拉合尔的两座领事馆非必要人员离开巴基斯坦。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260304-%E4%B8%BA%E5%AE%89%E5%85%A8%E8%B5%B7%E8%A7%81%EF%BC%8C%E7%BE%8E%E5%9B%BD%E4%B8%8B%E4%BB%A4%E9%A9%BB%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E4%B8%A4%E9%A2%86%E9%A6%86%E9%9D%9E%E5%BF%85%E8%A6%81%E4%BA%BA%E5%91%98%E6%92%A4%E7%A6%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772617035000.webp","sourceId":"rfi"},{"id":1772616502000,"createdDate":"2026-03-04 09:28","name":"法国国际广播电台","title":"政协开幕：落马传闻不断的马兴瑞又缺席，副主席陈武也未现身","content":"据路透社报道，中国全国政协会议今天（3月4日）北京时间下午三点开幕，出席开幕会的中央政治局委员合计有21位，而中央政治局委员马兴瑞未出席。马兴瑞去年7月卸任中共新疆党委书记后，自去年底以来，连续缺席重要场合，落马传闻不断。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E6%94%BF%E5%8D%8F%E5%BC%80%E5%B9%95-%E8%90%BD%E9%A9%AC%E4%BC%A0%E9%97%BB%E4%B8%8D%E6%96%AD%E7%9A%84%E9%A9%AC%E5%85%B4%E7%91%9E%E5%8F%88%E7%BC%BA%E5%B8%AD%EF%BC%8C%E5%89%AF%E4%B8%BB%E5%B8%AD%E9%99%88%E6%AD%A6%E4%B9%9F%E6%9C%AA%E7%8E%B0%E8%BA%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772616502000.webp","sourceId":"rfi"},{"id":1772616291000,"createdDate":"2026-03-04 09:24","name":"法国国际广播电台","title":"美战争次长：美对台军售立场不变，并反对用暴力或胁迫手段改变台海现状","content":"美国战争部负责政策的次长柯伯吉表示，在中东局势升级之际，对于任何可能以为这会是对台湾动手时机的国家，美国总统特朗普并不畏惧动用美国军队。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E7%BE%8E%E6%88%98%E4%BA%89%E6%AC%A1%E9%95%BF-%E7%BE%8E%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E7%AB%8B%E5%9C%BA%E4%B8%8D%E5%8F%98%EF%BC%8C%E5%B9%B6%E5%8F%8D%E5%AF%B9%E7%94%A8%E6%9A%B4%E5%8A%9B%E6%88%96%E8%83%81%E8%BF%AB%E6%89%8B%E6%AE%B5%E6%94%B9%E5%8F%98%E5%8F%B0%E6%B5%B7%E7%8E%B0%E7%8A%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772616291000.webp","sourceId":"rfi"},{"id":1772615499000,"createdDate":"2026-03-04 09:11","name":"法国国际广播电台","title":"布鲁塞尔将公布“欧洲制造”计划    专家：重大且必要的转折点","content":"布鲁塞尔周三将公布期待已久的“欧洲制造”提案，旨在重振欧洲大陆工业并应对中国竞争 。这项法律草案的公布时间最初预计本应在2025年底，但由于成员国之间甚至欧盟委员会内部对该措施的有效性、范围和局限性存在分歧，已被多次推迟。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260304-%E5%B8%83%E9%B2%81%E5%A1%9E%E5%B0%94%E5%B0%86%E5%85%AC%E5%B8%83-%E6%AC%A7%E6%B4%B2%E5%88%B6%E9%80%A0-%E8%AE%A1%E5%88%92-%E4%B8%93%E5%AE%B6-%E9%87%8D%E5%A4%A7%E4%B8%94%E5%BF%85%E8%A6%81%E7%9A%84%E8%BD%AC%E6%8A%98%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772615499000.webp","sourceId":"rfi"},{"id":1772615004000,"createdDate":"2026-03-04 09:03","name":"法国国际广播电台","title":"西班牙拒绝美军使用基地攻伊 特朗普威胁贸易禁运 桑切斯反击“不要战争”","content":"由于西班牙拒绝允许美国军方使用它的基地执行打击伊朗的军事任务，美国总统特朗普威胁对西班牙实施全面贸易禁运。据路透社报道，特朗普是在与到访的德国总理默茨会面时提到，“西班牙的表现非常糟糕”，已指示财长贝森特“切断与西班牙的一切贸易往来”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260304-%E8%A5%BF%E7%8F%AD%E7%89%99%E6%8B%92%E7%BB%9D%E7%BE%8E%E5%86%9B%E4%BD%BF%E7%94%A8%E5%9F%BA%E5%9C%B0%E6%94%BB%E4%BC%8A-%E7%89%B9%E6%9C%97%E6%99%AE%E5%A8%81%E8%83%81%E8%B4%B8%E6%98%93%E7%A6%81%E8%BF%90-%E4%B8%AD%E5%9B%BD%E5%91%BC%E5%90%81%E8%B4%B8%E6%98%93%E4%B8%8D%E5%BA%94%E8%A2%AB%E6%AD%A6%E5%99%A8%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/04/1772615004000.webp","sourceId":"rfi"}]