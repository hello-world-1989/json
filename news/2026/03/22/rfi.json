[{"id":1774137722000,"createdDate":"2026-03-22 00:02","name":"法国国际广播电台","title":"突破拦截 伊朗袭击以色列南部至少一百多人受伤","content":"周六晚间，伊朗对以色列南部实施两轮轰炸，多枚导弹突破以色列拦截，在以色列南方造成至少100多人受伤，并给该国造成开战三周以来最重大的物质损失。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260322-%E7%AA%81%E7%A0%B4%E6%8B%A6%E6%88%AA-%E4%BC%8A%E6%9C%97%E8%A2%AD%E5%87%BB%E4%BB%A5%E8%89%B2%E5%88%97%E5%8D%97%E9%83%A8%E8%87%B3%E5%B0%91%E4%B8%80%E7%99%BE%E5%A4%9A%E4%BA%BA%E5%8F%97%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774137722000.webp","sourceId":"rfi"},{"id":1774169029000,"createdDate":"2026-03-22 08:43","name":"法国国际广播电台","title":"被伊朗关押的两名日本人：其中一人获释回国  健康状况没有问题  日本外相称曾对伊朗强力施压","content":"日本外相茂木敏充周日（3月22日）宣布，伊朗已释放两名被关押的日本公民中的其中一人。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260322-%E8%A2%AB%E4%BC%8A%E6%9C%97%E5%85%B3%E6%8A%BC%E7%9A%84%E4%B8%A4%E5%90%8D%E6%97%A5%E6%9C%AC%E4%BA%BA-%E5%85%B6%E4%B8%AD%E4%B8%80%E4%BA%BA%E8%8E%B7%E9%87%8A%E5%9B%9E%E5%9B%BD-%E5%81%A5%E5%BA%B7%E7%8A%B6%E5%86%B5%E6%B2%A1%E6%9C%89%E9%97%AE%E9%A2%98-%E6%97%A5%E6%9C%AC%E5%A4%96%E7%9B%B8%E7%A7%B0%E6%9B%BE%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%BC%BA%E5%8A%9B%E6%96%BD%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774169029000.webp","sourceId":"rfi"},{"id":1774167739000,"createdDate":"2026-03-22 08:22","name":"法国国际广播电台","title":"回应特朗普最后通牒：伊朗放话打击中东关键基础设施","content":"法新社德黑兰消息，伊朗周日22日威胁将打击中东地区的关键基础设施，以回应美国总统特朗普发出的最后通牒：要求伊朗在48小时内重新开放霍尔木兹海峡。此前，伊朗对以色列南部发动了特别具有破坏性的袭击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260322-%E5%9B%9E%E5%BA%94%E7%89%B9%E6%9C%97%E6%99%AE%E6%9C%80%E5%90%8E%E9%80%9A%E7%89%92-%E4%BC%8A%E6%9C%97%E6%94%BE%E8%AF%9D%E6%89%93%E5%87%BB%E4%B8%AD%E4%B8%9C%E5%85%B3%E9%94%AE%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774167739000.webp","sourceId":"rfi"},{"id":1774166564000,"createdDate":"2026-03-22 08:02","name":"法国国际广播电台","title":"特朗普向伊朗下达最后通牒：开放霍尔木兹海峡 否则炸毁发电设施","content":"法新社耶路撒冷消息，美国总统特朗普周六21日晚向伊朗下达48小时最后通牒，要求其无条件重新开放霍尔木兹海峡，否则将面临其能源基础设施被摧毁的威胁。此前，德黑兰对以色列发动了迄今为止最具破坏性的袭击，造成百余人受伤。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260322-%E7%89%B9%E6%9C%97%E6%99%AE%E5%90%91%E4%BC%8A%E6%9C%97%E4%B8%8B%E8%BE%BE%E6%9C%80%E5%90%8E%E9%80%9A%E7%89%92%EF%BC%8C%E8%A6%81%E6%B1%82%E9%87%8D%E5%BC%80%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774166564000.webp","sourceId":"rfi"},{"id":1774196334000,"createdDate":"2026-03-22 16:18","name":"法国国际广播电台","title":"台国防部：延迟达产的F-16新型战机将于今年开始交付","content":"路透社台北消息，台湾国防部表示，在高级防务官员访问美国后，延迟交付的F-16V战机将于今年开始交付，且生产已“全面达产”。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260322-%E5%8F%B0%E5%9B%BD%E9%98%B2%E9%83%A8-%E9%A6%96%E6%9E%B6f-16-blk70%E5%9C%A8%E7%BE%8E%E5%AE%8C%E6%88%90%E9%AA%8C%E6%94%B6%E9%A3%9E%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774196334000.webp","sourceId":"rfi"},{"id":1774193459000,"createdDate":"2026-03-22 15:30","name":"法国国际广播电台","title":"欧盟将增加在非洲大陆科技投资","content":"刚果民主共和国（laRDCongo）和欧洲联盟（UE）签署伙伴协议,以加强刚果（金）的矿务治理。这是本台法广非洲组（RFIAfrique）近日的一则法文消息。为了支持非洲大陆的科技和地理科学或地球科学（géosciences），布鲁塞尔（Bruxelles）打算在2026年至2029年间投入4500万欧元。金沙萨（Kinshasa）是这一欧洲计划的重要受益方。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260322-%E6%B3%95%E5%B9%BFrfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E6%AC%A7%E7%9B%9F%E5%B0%86%E5%A2%9E%E5%8A%A0%E5%9C%A8%E9%9D%9E%E6%B4%B2%E5%A4%A7%E9%99%86%E7%A7%91%E6%8A%80%E6%8A%95%E8%B5%84","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774193459000.webp","sourceId":"rfi"},{"id":1774193072000,"createdDate":"2026-03-22 15:24","name":"法国国际广播电台","title":"法新解析：经历关税战后 美中拟建新机制 规范双边贸易关系","content":"法新社星期天22日发自华盛顿的电稿指出，在经历了一系列关税争端和脆弱的缓和谈判后，华盛顿和北京正在考虑建立新机制，以规范双边贸易往来。一些观察人士担心这可能会扭曲自由竞争，而另一些人则认为这是两大经济体走向更和平共处的一种方式。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260322-%E6%B3%95%E6%96%B0%E8%A7%A3%E6%9E%90-%E7%BB%8F%E5%8E%86%E5%85%B3%E7%A8%8E%E6%88%98%E5%90%8E-%E7%BE%8E%E4%B8%AD%E6%8B%9F%E5%BB%BA%E6%96%B0%E6%9C%BA%E5%88%B6-%E8%A7%84%E8%8C%83%E5%8F%8C%E8%BE%B9%E8%B4%B8%E6%98%93%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774193072000.webp","sourceId":"rfi"},{"id":1774191853000,"createdDate":"2026-03-22 15:04","name":"法国国际广播电台","title":"法国市政决选：中午投票率20.33%，较首轮略有上升","content":"法国地方选举第二轮的投票率是否会高于第一轮？据本台法语部报道，在巴黎、里昂、马赛、波尔多、图卢兹等几乎所有大城市，选举结果仍然悬而未决。自清晨4点起，近1600个城镇的居民被召集前往投票站。据法国内政部数据，截至中午，法国本土的投票率为20.33%，较第一轮略有上升。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260322-%E6%B3%95%E5%9B%BD%E5%B8%82%E6%94%BF%E5%86%B3%E9%80%89-%E4%B8%AD%E5%8D%88%E6%8A%95%E7%A5%A8%E7%8E%8720-33-%EF%BC%8C%E8%BE%83%E9%A6%96%E8%BD%AE%E7%95%A5%E6%9C%89%E4%B8%8A%E5%8D%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774191853000.webp","sourceId":"rfi"},{"id":1774189860000,"createdDate":"2026-03-22 14:31","name":"法国国际广播电台","title":"伊朗匿名官员：德黑兰告知斡旋方 想停战先满足六条件","content":"伊朗多家媒体报道，一名匿名伊朗官员在接受黎巴嫩“广场”电视台采访时说，中东地区一些斡旋方已向伊朗提出停战建议，但伊朗提出必须满足六项条件。另据土耳其外交界消息说，土耳其外长菲丹与伊朗和埃及外长、美国官员以及欧盟官员讨论了结束伊朗、美国和以色列之间战争的措施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260322-%E4%BC%8A%E6%9C%97%E5%8C%BF%E5%90%8D%E5%AE%98%E5%91%98-%E5%BE%B7%E9%BB%91%E5%85%B0%E5%91%8A%E7%9F%A5%E6%96%A1%E6%97%8B%E6%96%B9-%E6%83%B3%E5%81%9C%E6%88%98%E5%85%88%E6%BB%A1%E8%B6%B3%E5%85%AD%E6%9D%A1%E4%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774189860000.webp","sourceId":"rfi"},{"id":1774187674000,"createdDate":"2026-03-22 13:54","name":"法国国际广播电台","title":"中国或将在两年内成为全球最大公共科研资助国？","content":"加州大学“科学与创新政策前沿”项目近日为《自然指数》提供的一份独家分析显示，随着美国政府投资增长停滞，中国政府对研发的持续投入已让两者处于交汇点的边缘。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%BE%AE%E8%A8%80%E5%BE%AE%E8%AF%AD/20260322-%E4%B8%AD%E5%9B%BD%E6%88%96%E5%B0%86%E5%9C%A8%E4%B8%A4%E5%B9%B4%E5%86%85%E6%88%90%E4%B8%BA%E5%85%A8%E7%90%83%E6%9C%80%E5%A4%A7%E5%85%AC%E5%85%B1%E7%A7%91%E7%A0%94%E8%B5%84%E5%8A%A9%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774187674000.webp","sourceId":"rfi"},{"id":1774187365000,"createdDate":"2026-03-22 13:49","name":"法国国际广播电台","title":"针对伊朗空袭逐渐演变成海湾战争 后果严重","content":"法国各报周日头版报道2026年法国市政选举第二轮投票，有1500多个投票站开门。另外各报国际版继续关注不断升级的海湾战争，分析其地缘政治和经济等后果。回声报认为空袭伊朗军事行动正在演变成一场新的海湾战争，费加罗报指出针对伊朗战争不可避免影响欧洲。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260322-%E9%92%88%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%A9%BA%E8%A2%AD%E9%80%90%E6%B8%90%E6%BC%94%E5%8F%98%E6%88%90%E6%B5%B7%E6%B9%BE%E6%88%98%E4%BA%89-%E5%90%8E%E6%9E%9C%E4%B8%A5%E9%87%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774187365000.webp","sourceId":"rfi"},{"id":1774183644000,"createdDate":"2026-03-22 12:47","name":"法国国际广播电台","title":"Axios：特朗普抛出和谈“底牌” 要伊朗做出六保证","content":"美伊战争进入第四周，国际油价已飙升50%。美国国内质疑声日益高涨，认为特朗普政府未能预见开战后的经济冲击，且战争目标模糊。美国新闻网站Axios于21日引述两名知情人士的消息称，特朗普政府现已开始研拟与伊朗的和谈策略，希望伊朗能做出六项核心承诺。然而，其中部分要求，已被伊朗多次拒绝，另外，美方目前似乎仍无法确定伊朗真正的决策者究竟是谁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260322-axios-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8A%9B%E5%87%BA%E5%92%8C%E8%B0%88-%E5%BA%95%E7%89%8C-%E8%A6%81%E4%BC%8A%E6%9C%97%E5%81%9A%E5%87%BA%E5%85%AD%E9%A1%B9%E4%BF%9D%E8%AF%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774183644000.webp","sourceId":"rfi"},{"id":1774182435000,"createdDate":"2026-03-22 12:27","name":"法国国际广播电台","title":"重庆市长胡衡华落马主因：应与家族腐败有关","content":"据中央社周日22日报道称，重庆市长胡衡华20日遭到调查，中国媒体引述知情人士表示，胡衡华是17日上午被中央纪委国家监委从重庆带走，而他有至少4名近亲属也被纪检人员从湖南等地带走调查。有消息指，胡衡华的主要问题和易炼红差不多，均涉及家族式腐败。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260322-%E9%87%8D%E5%BA%86%E5%B8%82%E9%95%BF%E8%83%A1%E8%A1%A1%E5%8D%8E%E8%90%BD%E9%A9%AC%E4%B8%BB%E5%9B%A0-%E5%BA%94%E4%B8%8E%E5%AE%B6%E6%97%8F%E8%85%90%E8%B4%A5%E6%9C%89%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774182435000.webp","sourceId":"rfi"},{"id":1774174447000,"createdDate":"2026-03-22 10:14","name":"法国国际广播电台","title":"亲伊朗的伊拉克武装昨晚8次袭击巴格达机场附近一个美军中心","content":"在伊拉克巴格达机场附近的一个美军中心周六晚间到周日清晨遭到8次袭击。亲伊朗的伊拉克武装派别声称支持伊朗，对这些袭击事件负责。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260322-%E4%BA%B2%E4%BC%8A%E6%9C%97%E7%9A%84%E4%BC%8A%E6%8B%89%E5%85%8B%E6%AD%A6%E8%A3%85%E6%98%A8%E6%99%9A8%E6%AC%A1%E8%A2%AD%E5%87%BB%E5%B7%B4%E6%A0%BC%E8%BE%BE%E6%9C%BA%E5%9C%BA%E9%99%84%E8%BF%91%E4%B8%80%E4%B8%AA%E7%BE%8E%E5%86%9B%E4%B8%AD%E5%BF%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774174447000.webp","sourceId":"rfi"},{"id":1774171846000,"createdDate":"2026-03-22 09:30","name":"法国国际广播电台","title":"日本外相表示：高市向特朗普解释日本不出兵原因  特朗普首肯","content":"刚刚结束参与日美首脑会谈回国的日本外相茂木敏充，22日出演富士电视台《星期日报道THEPRIME》节目并透露，在日美首脑会谈中围绕向霍尔木兹海峡派遣自卫队的讨论中，高市首相已向特朗普说明了日本受到宪法第9条的限制，无法在战时派兵。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260322-%E6%97%A5%E6%9C%AC%E5%A4%96%E7%9B%B8%E8%A1%A8%E7%A4%BA-%E9%AB%98%E5%B8%82%E5%90%91%E7%89%B9%E6%9C%97%E6%99%AE%E8%A7%A3%E9%87%8A%E6%97%A5%E6%9C%AC%E4%B8%8D%E5%87%BA%E5%85%B5%E5%8E%9F%E5%9B%A0-%E7%89%B9%E6%9C%97%E6%99%AE%E9%A6%96%E8%82%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774171846000.webp","sourceId":"rfi"},{"id":1774171386000,"createdDate":"2026-03-22 09:23","name":"法国国际广播电台","title":"中国官媒：总理李强承诺做大全球贸易“蛋糕”","content":"法新社北京消息，据中国官方媒体新华社报道，中国国务院总理李强周日22日表示，中国愿意为扩展国际贸易的“蛋糕”做出贡献，并进一步开放市场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260322-%E4%B8%AD%E5%9B%BD%E5%AE%98%E5%AA%92-%E6%80%BB%E7%90%86%E6%9D%8E%E5%BC%BA%E6%89%BF%E8%AF%BA%E5%81%9A%E5%A4%A7%E5%85%A8%E7%90%83%E8%B4%B8%E6%98%93-%E8%9B%8B%E7%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774171386000.webp","sourceId":"rfi"},{"id":1774169794000,"createdDate":"2026-03-22 08:56","name":"法国国际广播电台","title":"Politico：伊战没打完前不会安排“特习会” 遭到白宫否认 中方“无可奉告”","content":"美国政治媒体网站《Politico》周六21日引述2名消息人士说法报道，美国政府已告诉外国官员和相关人士，美伊战争没打完前，不会重新安排特习会。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260322-politico-%E4%BC%8A%E6%88%98%E6%B2%A1%E6%89%93%E5%AE%8C%E5%89%8D%E4%B8%8D%E4%BC%9A%E5%AE%89%E6%8E%92-%E7%89%B9%E4%B9%A0%E4%BC%9A-%E9%81%AD%E5%88%B0%E7%99%BD%E5%AE%AB%E5%90%A6%E8%AE%A4-%E4%B8%AD%E6%96%B9-%E6%97%A0%E5%8F%AF%E5%A5%89%E5%91%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774169794000.webp","sourceId":"rfi"},{"id":1774222619000,"createdDate":"2026-03-22 23:36","name":"法国国际广播电台","title":"中东战争:马达加斯加陷燃油匮乏","content":"在海湾地区，美以两国对伊朗发起的军事打击现已超过三周之久。中东战乱持续对全球的负面影响开始在世界各地显现。就位于印度洋中的非洲大岛马达加斯加（Madagascar）而言，当前的最大困难就是燃油供应紧张。这是本台法广非洲组（RFIAfrique）今天（2026年03月22号星期日）的最新法文消息之一。在马达加斯加首都安塔那那利佛（Antananarivo），燃油匮乏已致该城陷入瘫痪。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%B9%BFrfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89-%E9%A9%AC%E8%BE%BE%E5%8A%A0%E6%96%AF%E5%8A%A0%E9%99%B7%E7%87%83%E6%B2%B9%E5%8C%AE%E4%B9%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774222619000.webp","sourceId":"rfi"},{"id":1774219019000,"createdDate":"2026-03-22 22:36","name":"法国国际广播电台","title":"巴斯夫总裁为在中国的数十亿投资进行辩护","content":"据德国《明镜》周刊报道，尽管面临强烈批评，德国化工巨头巴斯夫（BASF）仍在中国湛江新建了一处生产基地。如今，集团总裁MarkusKamieth承认，这项投资实现回报的时间将比原计划晚得多。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260322-%E5%B7%B4%E6%96%AF%E5%A4%AB%E6%80%BB%E8%A3%81%E4%B8%BA%E5%9C%A8%E4%B8%AD%E5%9B%BD%E7%9A%84%E6%95%B0%E5%8D%81%E4%BA%BF%E6%8A%95%E8%B5%84%E8%BF%9B%E8%A1%8C%E8%BE%A9%E6%8A%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774219019000.webp","sourceId":"rfi"},{"id":1774218819000,"createdDate":"2026-03-22 22:33","name":"法国国际广播电台","title":"华尔街对华关门 英媒曝中国企业赴美上市几近停摆","content":"从美国国会调查承销商、纳斯达克提高门槛，到证券监管机构打击股票操纵，华尔街对中国企业的大门正越关越窄，今年初至今仅有两家中国公司在纽约完成首次公开募股（IPO），较去年同期的19家大幅萎缩。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260322-%E5%8D%8E%E5%B0%94%E8%A1%97%E5%AF%B9%E5%8D%8E%E5%85%B3%E9%97%A8-%E8%8B%B1%E5%AA%92%E6%9B%9D%E4%B8%AD%E5%9B%BD%E4%BC%81%E4%B8%9A%E8%B5%B4%E7%BE%8E%E4%B8%8A%E5%B8%82%E5%87%A0%E8%BF%91%E5%81%9C%E6%91%86","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774218819000.webp","sourceId":"rfi"},{"id":1774218615000,"createdDate":"2026-03-22 22:30","name":"法国国际广播电台","title":"泽连斯基希望美国能够继续努力结束俄罗斯对乌克兰的入侵","content":"乌克兰总统泽连斯基周日表示，尽管美国目前将重点放在打击伊朗上，但他仍希望美国能够继续努力结束俄罗斯对乌克兰的入侵。此前，双方特使在佛罗里达州举行了会晤。这次会谈是在美国放松对俄罗斯石油的制裁之后举行的。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260322-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%B8%8C%E6%9C%9B%E7%BE%8E%E5%9B%BD%E8%83%BD%E5%A4%9F%E7%BB%A7%E7%BB%AD%E5%8A%AA%E5%8A%9B%E7%BB%93%E6%9D%9F%E4%BF%84%E7%BD%97%E6%96%AF%E5%AF%B9%E4%B9%8C%E5%85%8B%E5%85%B0%E7%9A%84%E5%85%A5%E4%BE%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774218615000.webp","sourceId":"rfi"},{"id":1774218387000,"createdDate":"2026-03-22 22:26","name":"法国国际广播电台","title":"伊朗威胁要袭击海水淡化厂在内的中东关键基础设施","content":"特朗普威胁称，除非霍尔木兹海峡迅速重开，否则将摧毁伊朗的发电厂。伊朗周日发誓，如果美国总统特朗普兑现其威胁，将“不可逆转地”摧毁中东地区的关键基础设施。伊朗还誓言，如果特朗普真的执行最后通牒，伊朗将完全封锁霍尔木兹海峡，切断这条对石油和天然气至关重要的航道上仅存的少量通行。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260322-%E4%BC%8A%E6%9C%97%E5%A8%81%E8%83%81%E8%A6%81%E8%A2%AD%E5%87%BB%E6%B5%B7%E6%B0%B4%E6%B7%A1%E5%8C%96%E5%8E%82%E5%9C%A8%E5%86%85%E7%9A%84%E4%B8%AD%E4%B8%9C%E5%85%B3%E9%94%AE%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774218387000.webp","sourceId":"rfi"},{"id":1774218277000,"createdDate":"2026-03-22 22:24","name":"法国国际广播电台","title":"比利时首相呼吁欧盟反击 “正在摧毁我们经济”的中国","content":"比利时首相德韦弗致信欧盟委员会主席冯德莱恩，呼吁对华采取强硬立场，他指中国“正在摧毁我们的经济”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260322-%E6%AF%94%E5%88%A9%E6%97%B6%E9%A6%96%E7%9B%B8%E5%91%BC%E5%90%81%E6%AC%A7%E7%9B%9F%E5%8F%8D%E5%87%BB-%E6%AD%A3%E5%9C%A8%E6%91%A7%E6%AF%81%E6%88%91%E4%BB%AC%E7%BB%8F%E6%B5%8E-%E7%9A%84%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774218277000.webp","sourceId":"rfi"},{"id":1774217866000,"createdDate":"2026-03-22 22:17","name":"法国国际广播电台","title":"左翼成功守住巴黎里昂马赛 与极左翼结盟却遭重挫","content":"法国第二轮市镇选举周日晚结束，截至22点，已知左翼阵营成功守住了巴黎、里昂和马赛。但左翼与极左翼法兰西不屈服结成的左翼大联盟遭遇挫败，在图卢兹、克莱蒙费朗和利摩日均告失利，后者则在首轮赢得巴黎大区第一大城圣德尼后，第二轮夺取了北方重镇鲁贝。而极右翼“国民联盟”的表现喜忧参半，虽在土伦和尼姆落败，但在多个中等规模城市获胜。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260322-%E5%B7%A6%E7%BF%BC%E6%88%90%E5%8A%9F%E5%AE%88%E4%BD%8F%E5%B7%B4%E9%BB%8E%E9%87%8C%E6%98%82%E9%A9%AC%E8%B5%9B-%E4%B8%8E%E6%9E%81%E5%B7%A6%E7%BF%BC%E7%BB%93%E7%9B%9F%E5%8D%B4%E9%81%AD%E9%87%8D%E6%8C%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774217866000.webp","sourceId":"rfi"}]