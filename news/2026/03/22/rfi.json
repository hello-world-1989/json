[{"id":1774137722000,"createdDate":"2026-03-22 00:02","name":"法国国际广播电台","title":"突破拦截 伊朗袭击以色列南部至少一百多人受伤","content":"周六晚间，伊朗对以色列南部实施两轮轰炸，多枚导弹突破以色列拦截，在以色列南方造成至少100多人受伤，并给该国造成开战三周以来最重大的物质损失。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260322-%E7%AA%81%E7%A0%B4%E6%8B%A6%E6%88%AA-%E4%BC%8A%E6%9C%97%E8%A2%AD%E5%87%BB%E4%BB%A5%E8%89%B2%E5%88%97%E5%8D%97%E9%83%A8%E8%87%B3%E5%B0%91%E4%B8%80%E7%99%BE%E5%A4%9A%E4%BA%BA%E5%8F%97%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774137722000.webp","sourceId":"rfi"},{"id":1774169029000,"createdDate":"2026-03-22 08:43","name":"法国国际广播电台","title":"被伊朗关押的两名日本人：其中一人获释回国  健康状况没有问题  日本外相称曾对伊朗强力施压","content":"日本外相茂木敏充周日（3月22日）宣布，伊朗已释放两名被关押的日本公民中的其中一人。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260322-%E8%A2%AB%E4%BC%8A%E6%9C%97%E5%85%B3%E6%8A%BC%E7%9A%84%E4%B8%A4%E5%90%8D%E6%97%A5%E6%9C%AC%E4%BA%BA-%E5%85%B6%E4%B8%AD%E4%B8%80%E4%BA%BA%E8%8E%B7%E9%87%8A%E5%9B%9E%E5%9B%BD-%E5%81%A5%E5%BA%B7%E7%8A%B6%E5%86%B5%E6%B2%A1%E6%9C%89%E9%97%AE%E9%A2%98-%E6%97%A5%E6%9C%AC%E5%A4%96%E7%9B%B8%E7%A7%B0%E6%9B%BE%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%BC%BA%E5%8A%9B%E6%96%BD%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774169029000.webp","sourceId":"rfi"},{"id":1774167739000,"createdDate":"2026-03-22 08:22","name":"法国国际广播电台","title":"回应特朗普最后通牒：伊朗放话打击中东关键基础设施","content":"法新社德黑兰消息，伊朗周日22日威胁将打击中东地区的关键基础设施，以回应美国总统特朗普发出的最后通牒：要求伊朗在48小时内重新开放霍尔木兹海峡。此前，伊朗对以色列南部发动了特别具有破坏性的袭击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260322-%E5%9B%9E%E5%BA%94%E7%89%B9%E6%9C%97%E6%99%AE%E6%9C%80%E5%90%8E%E9%80%9A%E7%89%92-%E4%BC%8A%E6%9C%97%E6%94%BE%E8%AF%9D%E6%89%93%E5%87%BB%E4%B8%AD%E4%B8%9C%E5%85%B3%E9%94%AE%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774167739000.webp","sourceId":"rfi"},{"id":1774166564000,"createdDate":"2026-03-22 08:02","name":"法国国际广播电台","title":"特朗普向伊朗下达最后通牒：开放霍尔木兹海峡 否则炸毁发电设施","content":"法新社耶路撒冷消息，美国总统特朗普周六21日晚向伊朗下达48小时最后通牒，要求其无条件重新开放霍尔木兹海峡，否则将面临其能源基础设施被摧毁的威胁。此前，德黑兰对以色列发动了迄今为止最具破坏性的袭击，造成百余人受伤。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260322-%E7%89%B9%E6%9C%97%E6%99%AE%E5%90%91%E4%BC%8A%E6%9C%97%E4%B8%8B%E8%BE%BE%E6%9C%80%E5%90%8E%E9%80%9A%E7%89%92%EF%BC%8C%E8%A6%81%E6%B1%82%E9%87%8D%E5%BC%80%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/22/1774166564000.webp","sourceId":"rfi"}]