[{"id":1773474282000,"createdDate":"2026-03-14 07:44","name":"法国国际广播电台","title":"面对中俄高超音速武器威胁 日本考虑加入美国“金穹”防御系统","content":"据《读卖日相新闻》获悉，日相高市准备向特朗普表示，东京愿意加入华盛顿提出的“金穹”（GoldenDome）下一代导弹防御系统。此举旨在应对中国与俄罗斯近年来研发高超音速滑翔飞行器所带来的威胁，并进一步深化美日军事同盟。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260314-%E9%9D%A2%E5%AF%B9%E4%B8%AD%E4%BF%84%E9%AB%98%E8%B6%85%E9%9F%B3%E9%80%9F%E6%AD%A6%E5%99%A8%E5%A8%81%E8%83%81-%E6%97%A5%E6%9C%AC%E8%80%83%E8%99%91%E5%8A%A0%E5%85%A5%E7%BE%8E%E5%9B%BD-%E9%87%91%E7%A9%B9-%E9%98%B2%E5%BE%A1%E7%B3%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773474282000.webp","sourceId":"rfi"},{"id":1773448728000,"createdDate":"2026-03-14 00:38","name":"法国国际广播电台","title":"美国正将亚太军力调动到中东 引发区域盟友安全焦虑","content":"鉴于伊朗加大了对霍尔木兹海峡的袭击力度，美国约2500名海军陆战队员和多达三艘军舰正从印太地区前往中东。眼看白宫持续把军事资源投向中东的伊朗战争中，美国的亚洲盟友越来越感到焦虑，担心区域防御力量会因此被削弱。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260314-%E7%BE%8E%E5%9B%BD%E6%AD%A3%E5%B0%86%E4%BA%9A%E5%A4%AA%E5%86%9B%E5%8A%9B%E8%B0%83%E5%8A%A8%E5%88%B0%E4%B8%AD%E4%B8%9C-%E5%BC%95%E5%8F%91%E5%8C%BA%E5%9F%9F%E7%9B%9F%E5%8F%8B%E5%AE%89%E5%85%A8%E7%84%A6%E8%99%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773448728000.webp","sourceId":"rfi"}]