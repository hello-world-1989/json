[{"id":1773474282000,"createdDate":"2026-03-14 07:44","name":"法国国际广播电台","title":"面对中俄高超音速武器威胁 日本考虑加入美国“金穹”防御系统","content":"据《读卖日相新闻》获悉，日相高市准备向特朗普表示，东京愿意加入华盛顿提出的“金穹”（GoldenDome）下一代导弹防御系统。此举旨在应对中国与俄罗斯近年来研发高超音速滑翔飞行器所带来的威胁，并进一步深化美日军事同盟。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260314-%E9%9D%A2%E5%AF%B9%E4%B8%AD%E4%BF%84%E9%AB%98%E8%B6%85%E9%9F%B3%E9%80%9F%E6%AD%A6%E5%99%A8%E5%A8%81%E8%83%81-%E6%97%A5%E6%9C%AC%E8%80%83%E8%99%91%E5%8A%A0%E5%85%A5%E7%BE%8E%E5%9B%BD-%E9%87%91%E7%A9%B9-%E9%98%B2%E5%BE%A1%E7%B3%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773474282000.webp","sourceId":"rfi"},{"id":1773448728000,"createdDate":"2026-03-14 00:38","name":"法国国际广播电台","title":"美国正将亚太军力调动到中东 引发区域盟友安全焦虑","content":"鉴于伊朗加大了对霍尔木兹海峡的袭击力度，美国约2500名海军陆战队员和多达三艘军舰正从印太地区前往中东。眼看白宫持续把军事资源投向中东的伊朗战争中，美国的亚洲盟友越来越感到焦虑，担心区域防御力量会因此被削弱。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260314-%E7%BE%8E%E5%9B%BD%E6%AD%A3%E5%B0%86%E4%BA%9A%E5%A4%AA%E5%86%9B%E5%8A%9B%E8%B0%83%E5%8A%A8%E5%88%B0%E4%B8%AD%E4%B8%9C-%E5%BC%95%E5%8F%91%E5%8C%BA%E5%9F%9F%E7%9B%9F%E5%8F%8B%E5%AE%89%E5%85%A8%E7%84%A6%E8%99%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773448728000.webp","sourceId":"rfi"},{"id":1773501929000,"createdDate":"2026-03-14 15:25","name":"法国国际广播电台","title":"中东战争：以色列防长指进入“决定性阶段” 伊朗革命卫队称“止战有两个条件”","content":"法新社报道，周六进入第三周的中东战争据以色列称已进入“决定性阶段”，以色列决心与其美国盟友一道，消灭伊朗政权。另一方面，伊朗则继续通过袭击海湾地区的基础设施进行反击，据革命卫队高级指挥官表示，在两个条件下考虑结束战争，一是伊朗收回所有损失，二是美国离开波斯湾。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260314-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89-%E4%BB%A5%E8%89%B2%E5%88%97%E5%A4%96%E9%95%BF%E6%8C%87%E8%BF%9B%E5%85%A5-%E5%86%B3%E5%AE%9A%E6%80%A7%E9%98%B6%E6%AE%B5-%E4%BC%8A%E6%9C%97%E9%9D%A9%E5%91%BD%E5%8D%AB%E9%98%9F%E7%A7%B0-%E6%AD%A2%E6%88%98%E6%9C%89%E4%B8%A4%E4%B8%AA%E6%9D%A1%E4%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773501929000.webp","sourceId":"rfi"},{"id":1773499741000,"createdDate":"2026-03-14 14:49","name":"法国国际广播电台","title":"马克龙呼吁以色列与黎巴嫩“直接对话”，并提议在巴黎举办会谈","content":"法新社巴黎消息，法国总统马克龙周六（3月14日）呼吁以色列接受与黎巴嫩政府（真主党也应在内）进行“直接对话”，并表示愿意为这些对话提供便利，并在巴黎举办相关会谈。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260314-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%91%BC%E5%90%81%E4%BB%A5%E8%89%B2%E5%88%97%E4%B8%8E%E9%BB%8E%E5%B7%B4%E5%AB%A9-%E7%9B%B4%E6%8E%A5%E5%AF%B9%E8%AF%9D-%EF%BC%8C%E5%B9%B6%E6%8F%90%E8%AE%AE%E5%9C%A8%E5%B7%B4%E9%BB%8E%E4%B8%BE%E5%8A%9E%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773499741000.webp","sourceId":"rfi"},{"id":1773499444000,"createdDate":"2026-03-14 14:44","name":"法国国际广播电台","title":"朝鲜导弹试射与美韩军演：看伊朗战争背景下的朝鲜半岛困局","content":"美国抽调兵力增援中东对伊朗的战争引发美国在亚太地区的安全保护伞效力减弱忧虑之际，韩国和日本国防部门消息都证实，朝鲜当局14日向日本海方向发射十枚疑似弹道导弹。而就在几小时前，正在华盛顿访问的韩国总理金民锡刚刚透露，美国总统特朗普乐见与朝鲜领导人金正恩再次会面。从目前韩国总理透露的内容来看，特朗普的相关表述其实语焉不详。而相较于特朗普第一个总统任期，金正恩政权扩充军备的努力已经取得长足发展，围绕朝鲜半岛的大国角力也正呈现出不一样的版图。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260314-%E6%9C%9D%E9%B2%9C%E5%AF%BC%E5%BC%B9%E8%AF%95%E5%B0%84%E4%B8%8E%E7%BE%8E%E9%9F%A9%E5%86%9B%E6%BC%94-%E7%9C%8B%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E8%83%8C%E6%99%AF%E4%B8%8B%E7%9A%84%E6%9C%9D%E9%B2%9C%E5%8D%8A%E5%B2%9B%E5%9B%B0%E5%B1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773499444000.webp","sourceId":"rfi"},{"id":1773492243000,"createdDate":"2026-03-14 12:44","name":"法国国际广播电台","title":"伊朗战争如何脱身？路透揭露：特朗普身边三大阵营争抢“退场剧本”内幕","content":"据路透社专稿指出，白宫内部一场复杂的角力正在影响美国总统特朗普对伊朗战争走向不断变化的公开表态。在战事蔓延整个中东地区的同时，他的幕僚们却正在争论应当在何时以及如何宣布“胜利”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260314-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E5%A6%82%E4%BD%95%E8%84%B1%E8%BA%AB-%E8%B7%AF%E9%80%8F%E6%8F%AD%E9%9C%B2-%E7%89%B9%E6%9C%97%E6%99%AE%E8%BA%AB%E8%BE%B9%E4%B8%89%E5%A4%A7%E9%98%B5%E8%90%A5%E7%81%AB%E7%83%AD%E7%AB%9E%E4%BA%89-%E9%80%80%E5%9C%BA%E5%89%A7%E6%9C%AC-%E5%86%85%E5%B9%95","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773492243000.webp","sourceId":"rfi"},{"id":1773488448000,"createdDate":"2026-03-14 11:40","name":"法国国际广播电台","title":"古巴国家主席确认正与美国对话，并释放51名在押政治犯","content":"古巴最高领导人13日确认，古巴近期与美国代表就双边分歧展开对话，以求让两国关系“远离对抗”。同一天，古巴当局也按照此前与梵蒂冈教廷达成的一项协议，宣布释放了51名在押政治犯","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260314-%E5%8F%A4%E5%B7%B4%E5%9B%BD%E5%AE%B6%E4%B8%BB%E5%B8%AD%E7%A1%AE%E8%AE%A4%E6%AD%A3%E4%B8%8E%E7%BE%8E%E5%9B%BD%E5%AF%B9%E8%AF%9D%EF%BC%8C%E5%B9%B6%E9%87%8A%E6%94%BE51%E5%90%8D%E5%9C%A8%E6%8A%BC%E6%94%BF%E6%B2%BB%E7%8A%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773488448000.webp","sourceId":"rfi"},{"id":1773484387000,"createdDate":"2026-03-14 10:33","name":"法国国际广播电台","title":"“特习会”在即 具体目标不明！ 有学者指：若伊朗战争持续那将成主要议题","content":"据法新社发自华盛顿的专稿称，距离特朗普与习近平原定在北京举行的会晤仅剩两周，美国总统的访问目标以及对伊战争对这次备受瞩目的行程所产生的影响，依然充满不确定性。不过，据新加坡学者认为，如果伊朗战争持续到4月，那将成为特习会的主要议题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260314-%E7%89%B9%E4%B9%A0%E4%BC%9A-%E4%B8%BE%E8%A1%8C%E5%9C%A8%E5%8D%B3-%E5%85%B7%E4%BD%93%E7%9B%AE%E6%A0%87%E4%BB%8D%E4%B8%8D%E6%98%8E%E6%9C%97-%E6%9C%89%E5%AD%A6%E8%80%85%E6%8C%87-%E8%8B%A5%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%8C%81%E7%BB%AD%E9%82%A3%E5%B0%86%E6%88%90%E4%B8%BB%E8%A6%81%E8%AE%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773484387000.webp","sourceId":"rfi"},{"id":1773480297000,"createdDate":"2026-03-14 09:24","name":"法国国际广播电台","title":"美韩军演，朝鲜发射十余枚弹道导弹","content":"3月14日，朝鲜向海上发射了十多枚弹道导弹。韩国军方表示，导弹是在当天下午约13时20分从首都平壤附近地区发射，飞向朝鲜东海岸外海方向。韩国联合参谋本部称，军方探测到约十枚“来源未确认的弹道导弹”，发射地点位于朝鲜顺安一带，目标方向为东海。韩国所称的“东海”，即日本海。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260314-%E7%BE%8E%E9%9F%A9%E5%86%9B%E6%BC%94%EF%BC%8C%E6%9C%9D%E9%B2%9C%E5%8F%91%E5%B0%84%E5%8D%81%E4%BD%99%E6%9E%9A%E5%BC%B9%E9%81%93%E5%AF%BC%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773480297000.webp","sourceId":"rfi"},{"id":1773478604000,"createdDate":"2026-03-14 08:56","name":"法国国际广播电台","title":"日美等召开能源主管部长会议 探讨能源供应多元化","content":"在中东局势恶化的背景下，日本时间3月14日起，为期两天的“印太能源安全部长级会议暨商业论坛”在东京举行。日美以及亚洲等地区的能源主管部长等参加，就石油等能源稳定供应进行磋商。此次会议由日美两国政府首次共同主办，日本方面由经济产业大臣赤泽亮正出席，除美国外，来自印度洋—太平洋地区各国的能源主管部长等也参加了会议和论坛。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260314-%E6%97%A5%E7%BE%8E%E7%AD%89%E5%8F%AC%E5%BC%80%E8%83%BD%E6%BA%90%E4%B8%BB%E7%AE%A1%E9%83%A8%E9%95%BF%E4%BC%9A%E8%AE%AE-%E6%8E%A2%E8%AE%A8%E8%83%BD%E6%BA%90%E4%BE%9B%E5%BA%94%E5%A4%9A%E5%85%83%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773478604000.webp","sourceId":"rfi"},{"id":1773477785000,"createdDate":"2026-03-14 08:43","name":"法国国际广播电台","title":"特朗普：“彻底摧毁”了伊朗石油枢纽哈尔克岛的军事目标，石油基础设施暂除外","content":"中东战争届满两周，美国总统特朗普周五13日晚间宣布，美军已“彻底摧毁”了伊朗石油枢纽——哈尔克岛（KhargIsland）上的军事目标，岛上的石油基础设施先不含在内，但接着威胁称，伊朗若阻碍霍尔木兹海峡的航行自由，他将打击岛上的石油基础设施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260314-%E7%89%B9%E6%9C%97%E6%99%AE-%E5%BD%BB%E5%BA%95%E6%91%A7%E6%AF%81-%E4%BC%8A%E6%9C%97%E7%9F%B3%E6%B2%B9%E6%9E%A2%E7%BA%BD%E5%93%88%E5%B0%94%E5%85%8B%E5%B2%9B%E7%9A%84%E5%86%9B%E4%BA%8B%E7%9B%AE%E6%A0%87%EF%BC%8C%E7%9F%B3%E6%B2%B9%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD%E6%9A%82%E9%99%A4%E5%A4%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773477785000.webp","sourceId":"rfi"},{"id":1773528049000,"createdDate":"2026-03-14 22:40","name":"法国国际广播电台","title":"伊朗：基辅“打‘伊朗牌’是为了从西方获取更多资源","content":"基辅一直试图用反无人机技术和专业知识与美国换取乌克兰急需的常规防空导弹， 大力宣传其在摧毁俄罗斯发射的伊朗设计的无人机方面的技术。星期六，伊朗驻乌克兰外交代表沙赫里亚尔·阿穆泽加尔驳斥了基辅对美国及其海湾盟友的支持。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260314-%E4%BC%8A%E6%9C%97-%E5%9F%BA%E8%BE%85-%E6%89%93-%E4%BC%8A%E6%9C%97%E7%89%8C-%E6%98%AF%E4%B8%BA%E4%BA%86%E4%BB%8E%E8%A5%BF%E6%96%B9%E8%8E%B7%E5%8F%96%E6%9B%B4%E5%A4%9A%E8%B5%84%E6%BA%90","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773528049000.webp","sourceId":"rfi"},{"id":1773527757000,"createdDate":"2026-03-14 22:35","name":"法国国际广播电台","title":"黎巴嫩正准备组建一个代表团与以色列谈判","content":"法国政府已起草了一份结束黎巴嫩战争的计划，这个方案要求贝鲁特政府正式承认以色列。法新社报道，一位官员透露，黎巴嫩正准备组建一个代表团与以色列谈判，以期结束与伊朗支持的真主党之间的战争。以色列还没有对这个倡议做出承诺。他说：“谈判已经提上日程，组建代表团的准备工作也在进行中，但是……时间和地点都尚未确定，巴黎和塞浦路斯都在考虑之列。”","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260314-%E9%BB%8E%E5%B7%B4%E5%AB%A9%E6%AD%A3%E5%87%86%E5%A4%87%E7%BB%84%E5%BB%BA%E4%B8%80%E4%B8%AA%E4%BB%A3%E8%A1%A8%E5%9B%A2%E4%B8%8E%E4%BB%A5%E8%89%B2%E5%88%97%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773527757000.webp","sourceId":"rfi"},{"id":1773527483000,"createdDate":"2026-03-14 22:31","name":"法国国际广播电台","title":"伊朗：如果伊朗的石油和能源基础设施遭到攻击，将报复美国公司的能源基础设施","content":"美军周五袭击了哈尔克岛，伊朗几乎所有石油都从哈尔克岛出口。美国总统特朗普称，所有军事目标都被“摧毁”，但能源设施幸免于难。伊朗外长阿拉格奇说：我们的武装部队已经表明，如果我们的石油和能源基础设施遭到攻击，他们将进行报复。他还补充说，伊朗将攻击这个地区任何属于美国公司或美国公司是股东的能源基础设施。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260314-%E4%BC%8A%E6%9C%97-%E5%A6%82%E6%9E%9C%E4%BC%8A%E6%9C%97%E7%9A%84%E7%9F%B3%E6%B2%B9%E5%92%8C%E8%83%BD%E6%BA%90%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD%E9%81%AD%E5%88%B0%E6%94%BB%E5%87%BB%EF%BC%8C%E5%B0%86%E6%8A%A5%E5%A4%8D%E7%BE%8E%E5%9B%BD%E5%85%AC%E5%8F%B8%E7%9A%84%E8%83%BD%E6%BA%90%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773527483000.webp","sourceId":"rfi"},{"id":1773527166000,"createdDate":"2026-03-14 22:26","name":"法国国际广播电台","title":"瑞士拒绝美国与中东战争相关的飞越领空的两项请求","content":"瑞士周六表示，已拒绝美国与当前中东战争相关的飞越他们领空的两项请求，理由是瑞士在国际法下保持中立。瑞士周六表示，已拒绝美国与当前中东战争相关的飞越他们领空的两项请求，理由是瑞士在国际法下保持中立。这次拒绝的两架飞机均是为了作侦察飞行。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260314-%E7%91%9E%E5%A3%AB%E6%8B%92%E7%BB%9D%E7%BE%8E%E5%9B%BD%E4%B8%8E%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E7%9B%B8%E5%85%B3%E7%9A%84%E9%A3%9E%E8%B6%8A%E9%A2%86%E7%A9%BA%E7%9A%84%E4%B8%A4%E9%A1%B9%E8%AF%B7%E6%B1%82","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773527166000.webp","sourceId":"rfi"},{"id":1773526863000,"createdDate":"2026-03-14 22:21","name":"法国国际广播电台","title":"特朗普为何寻求中国等国派遣战舰护航霍尔木兹海峡","content":"这件事出乎很多人的预料，美国总统特朗普周六呼吁中国、法国等国派遣战舰与美国一道去霍尔木兹海峡护航，以确保这条全球关键能源航道保持畅通。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260314-%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%BA%E4%BD%95%E5%AF%BB%E6%B1%82%E4%B8%AD%E5%9B%BD%E7%AD%89%E5%9B%BD%E6%B4%BE%E9%81%A3%E6%88%98%E8%88%B0%E6%8A%A4%E8%88%AA%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773526863000.webp","sourceId":"rfi"},{"id":1773523003000,"createdDate":"2026-03-14 21:16","name":"法国国际广播电台","title":"特朗普呼吁中国法国等派军舰护航霍尔木兹海峡","content":"在中东冲突持续升级、全球能源供应面临冲击之际，美国总统特朗普（DonaldTrump）14日表示，美国正推动多国派遣军舰前往霍尔木兹海峡，以确保这条全球关键能源航道保持畅通。他呼吁包括中国、法国等受影响国家加入行动，强化国际海军存在，以避免伊朗持续威胁全球航运。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260314-%E7%89%B9%E6%9C%97%E6%99%AE%E5%91%BC%E5%90%81%E4%B8%AD%E5%9B%BD%E6%B3%95%E5%9B%BD%E7%AD%89%E6%B4%BE%E5%86%9B%E8%88%B0%E6%8A%A4%E8%88%AA%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773523003000.webp","sourceId":"rfi"},{"id":1773515024000,"createdDate":"2026-03-14 19:03","name":"法国国际广播电台","title":"当代思想大师 德国哲学家哈贝马斯逝世","content":"当代最具影响力的思想家之一——德国哲学家于尔根·哈贝马斯周六去世，享年96岁。他的辞世引发广泛悼念，德国总理默茨将他的思想比作“狂暴大海中的一盏灯塔”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260314-%E5%BD%93%E4%BB%A3%E6%80%9D%E6%83%B3%E5%A4%A7%E5%B8%88-%E5%BE%B7%E5%9B%BD%E5%93%B2%E5%AD%A6%E5%AE%B6%E5%93%88%E8%B4%9D%E9%A9%AC%E6%96%AF%E9%80%9D%E4%B8%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773515024000.webp","sourceId":"rfi"},{"id":1773506886000,"createdDate":"2026-03-14 16:48","name":"法国国际广播电台","title":"照片曝光后 北约合作伙伴塞尔维亚承认采购中国超音速导弹","content":"据路透社周五13日报道，塞尔维亚总统亚历山大尔·武契奇（AleksandarVucic）周四晚间在塞尔维亚国家电视台RTS的直播节目中证实，塞尔维亚近期为空军采购了中国研制的CM-400AKG空对地弹道导弹，成为该武器在欧洲的首个使用国。但同时也引来巴尔干地区国家的高度警惕。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260314-%E7%85%A7%E7%89%87%E6%9B%9D%E5%85%89%E5%90%8E-%E5%8C%97%E7%BA%A6%E5%90%88%E4%BD%9C%E4%BC%99%E4%BC%B4%E5%A1%9E%E5%B0%94%E7%BB%B4%E4%BA%9A%E6%89%BF%E8%AE%A4%E9%87%87%E8%B4%AD%E4%B8%AD%E5%9B%BD%E8%B6%85%E9%9F%B3%E9%80%9F%E5%AF%BC%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/14/1773506886000.webp","sourceId":"rfi"}]