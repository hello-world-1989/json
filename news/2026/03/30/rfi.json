[{"id":1774859774000,"createdDate":"2026-03-30 08:36","name":"法国国际广播电台","title":"国台办主任宋涛：习近平邀国民党主席郑丽文四月访中","content":"据中国官媒表示，国台办主任宋涛指称，习近平邀访国民党主席郑丽文于4月7日到12日访中。对于郑习会的确立，台湾内部有许多不同的看法。民进党认为，此举将分化台湾内部。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260330-%E5%9B%BD%E5%8F%B0%E5%8A%9E%E4%B8%BB%E4%BB%BB%E5%AE%8B%E6%B6%9B-%E4%B9%A0%E8%BF%91%E5%B9%B3%E9%82%80%E5%9B%BD%E6%B0%91%E5%85%9A%E4%B8%BB%E5%B8%AD%E9%83%91%E4%B8%BD%E6%96%87%E5%9B%9B%E6%9C%88%E8%AE%BF%E4%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774859774000.webp","sourceId":"rfi"},{"id":1774859621000,"createdDate":"2026-03-30 08:33","name":"法国国际广播电台","title":"退休公务员谢小华「翻阉」当政制局长 惟过往未有相关经验","content":"香港政府内专责政制及中国事务的问责局长职位，在由副局长兼任两个月后，由之前从未参与政制事务和中国内地事务的已退休官员谢小华补上。她辩称，在过往不同岗位上，有与内地联络，对内地事务并不陌生；上任後的首要工作，是编制配合中国「十五五」的香港首份五年规划。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260330-%E9%80%80%E4%BC%91%E5%85%AC%E5%8A%A1%E5%91%98%E8%B0%A2%E5%B0%8F%E5%8D%8E-%E7%BF%BB%E9%98%89-%E5%BD%93%E6%94%BF%E5%88%B6%E5%B1%80%E9%95%BF-%E6%83%9F%E8%BF%87%E5%BE%80%E6%9C%AA%E6%9C%89%E7%9B%B8%E5%85%B3%E7%BB%8F%E9%AA%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774859621000.webp","sourceId":"rfi"},{"id":1774859356000,"createdDate":"2026-03-30 08:29","name":"法国国际广播电台","title":"中国制裁日本众院宪法审议会会长古屋圭司","content":"中国外交部3月30日发布《中华人民共和国外交部令第20号公布关于对日本国会众议员古屋圭司采取反制措施的决定》，对日本众议院议员，日本众议院宪法审议会会长，与台湾进行交流的日本跨党派国会议员组成的“日华议员恳谈会”会长古屋圭司实行制裁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260330-%E4%B8%AD%E5%9B%BD%E5%88%B6%E8%A3%81%E6%97%A5%E6%9C%AC%E4%BC%97%E9%99%A2%E5%AE%AA%E6%B3%95%E5%AE%A1%E8%AE%AE%E4%BC%9A%E4%BC%9A%E9%95%BF%E5%8F%A4%E5%B1%8B%E5%9C%AD%E5%8F%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774859356000.webp","sourceId":"rfi"},{"id":1774858204000,"createdDate":"2026-03-30 08:10","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第24：浪漫主义群星之三：荷尔德林 ：第五节 狄奥提玛 ：荷尔德林的生命之光","content":"在荷尔德林不断改写《许佩里翁》时，他的生活中发生了一件大事，他恋爱了。这是一段刻骨铭心之爱，但终以悲剧结束。于是，在《许佩里翁》一书中有了一位女性的名字：狄奥提玛，成了他倾诉的对象，讨论的伴侣。这位绝世女子既是荷尔德林生活中的真实恋人又是希腊精神的象征。她的内涵极其丰富，集神性、自然、诗与哲学于一身。荷尔德林称她为”天国的生灵“。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260330-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%89-%E8%8D%B7%E5%B0%94%E5%BE%B7%E6%9E%97-%E7%AC%AC%E4%BA%94%E8%8A%82-%E7%8B%84%E5%A5%A5%E6%8F%90%E7%8E%9B-%E8%8D%B7%E5%B0%94%E5%BE%B7%E6%9E%97%E7%9A%84%E7%94%9F%E5%91%BD%E4%B9%8B%E5%85%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774858204000.webp","sourceId":"rfi"},{"id":1774858017000,"createdDate":"2026-03-30 08:06","name":"法国国际广播电台","title":"突尼斯总工会新领袖出自教育界","content":"在北非国家突尼斯，67岁的教育界工会代表SlaheddineSelmi于2026年03月28日周六当选该国总工会(Centralesyndicale/UGTT-Uniongénéraletunisiennedutravail)的新领袖。这是本台法广非洲组（RFIAfrique)03月29日星期天上网的法文消息之一。突尼斯总工会是2015年诺贝尔和平奖（ leprixNobeldelaPaix）得主之一。突尼斯总工会的新领袖承诺要重启社会对话。","newsLink":"https://www.rfi.fr/cn/rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E7%AA%81%E5%B0%BC%E6%96%AF%E6%80%BB%E5%B7%A5%E4%BC%9A%E6%96%B0%E9%A2%86%E8%A2%96%E5%87%BA%E8%87%AA%E6%95%99%E8%82%B2%E7%95%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774858017000.webp","sourceId":"rfi"},{"id":1774857799000,"createdDate":"2026-03-30 08:03","name":"法国国际广播电台","title":"古巴挑战美国禁运令 ：一艘受制裁的俄罗斯油轮为古巴运送至少65万桶原油   特朗普回应：没有任何问题","content":"美国总统特朗普周日（3月29日）晚间似乎放松了对古巴实施的石油禁运政策。他表示，不反对任何国家向这个加勒比海岛国运送原油。此前，根据船舶追踪数据，一艘属于俄罗斯“影子船队”的油轮周日已出现在古巴东部海域附近。据古巴官方媒体报道，该油轮预计将于周一抵达马坦萨斯港。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260330-%E5%8F%A4%E5%B7%B4%E6%8C%91%E6%88%98%E7%BE%8E%E5%9B%BD%E7%A6%81%E8%BF%90%E4%BB%A4-%E4%B8%80%E8%89%98%E5%8F%97%E5%88%B6%E8%A3%81%E7%9A%84%E4%BF%84%E7%BD%97%E6%96%AF%E6%B2%B9%E8%BD%AE%E4%B8%BA%E5%8F%A4%E5%B7%B4%E8%BF%90%E9%80%81%E8%87%B3%E5%B0%9165%E4%B8%87%E6%A1%B6%E5%8E%9F%E6%B2%B9-%E7%89%B9%E6%9C%97%E6%99%AE%E5%9B%9E%E5%BA%94-%E6%B2%A1%E6%9C%89%E4%BB%BB%E4%BD%95%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774857799000.webp","sourceId":"rfi"},{"id":1774855493000,"createdDate":"2026-03-30 07:24","name":"法国国际广播电台","title":"星总理黄循财：香港是中国的金融中心 与新不同 两地合作与竞争共存","content":"曾以国际金融中心自居丶在区内与新加坡互相竞争的香港，在新加坡(又称星加坡或星洲)总理黄循财口中，已由国际金融中心变成以中国大陆为腹地，而星洲则是背靠东南亚的金融中心，双方应聚焦合作，而不是竞争。他在首次官式访港后又说，会研究如何参与北部都会区。时事评论员衍锐绍向本台指出，黄循财是因为重视对华关系才爱屋及乌地访港，虽有合作意向，但不会以中国为马首是瞻，而是亲身了解再行接触及计划。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260330-%E6%98%9F%E6%80%BB%E7%90%86%E9%BB%84%E5%BE%AA%E8%B4%A2-%E9%A6%99%E6%B8%AF%E6%98%AF%E4%B8%AD%E5%9B%BD%E7%9A%84%E9%87%91%E8%9E%8D%E4%B8%AD%E5%BF%83-%E4%B8%8E%E6%96%B0%E4%B8%8D%E5%90%8C-%E4%B8%A4%E5%9C%B0%E5%90%88%E4%BD%9C%E4%B8%8E%E7%AB%9E%E4%BA%89%E5%85%B1%E5%AD%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774855493000.webp","sourceId":"rfi"},{"id":1774886735000,"createdDate":"2026-03-30 16:05","name":"法国国际广播电台","title":"伊朗革命卫队证实负责封锁霍尔木兹海峡的海军司令坦格西里去世","content":"伊朗革命卫队官方网站SepahNews周一30日证实了其海军司令阿里礼萨·坦格西里（AlirezaTangsiri）去世的消息，称这位在伊朗武装部队中最​​具知名度的人物之一，“因伤势过重而去世”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260330-%E4%BC%8A%E6%9C%97%E9%9D%A9%E5%91%BD%E5%8D%AB%E9%98%9F%E8%AF%81%E5%AE%9E%E8%B4%9F%E8%B4%A3%E5%B0%81%E9%94%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%9A%84%E6%B5%B7%E5%86%9B%E5%8F%B8%E4%BB%A4%E5%9D%A6%E6%A0%BC%E8%A5%BF%E9%87%8C%E5%8E%BB%E4%B8%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774886735000.webp","sourceId":"rfi"},{"id":1774880396000,"createdDate":"2026-03-30 14:19","name":"法国国际广播电台","title":"泽连斯基访问海湾国家赞扬双方达成“历史性”安全合作协议","content":"乌克兰总统泽连斯基周一在访问海湾期间，赞扬海湾国家与乌克兰签署的“历史性”安全和防空合作协议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260330-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E8%AE%BF%E9%97%AE%E6%B5%B7%E6%B9%BE%E5%9B%BD%E5%AE%B6%E8%BE%BE%E6%88%90-%E5%8E%86%E5%8F%B2%E6%80%A7-%E5%AE%89%E5%85%A8%E5%90%88%E4%BD%9C%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774880396000.webp","sourceId":"rfi"},{"id":1774878375000,"createdDate":"2026-03-30 13:46","name":"法国国际广播电台","title":"海湾战事持续或将导致如铝、化肥等出现短缺","content":"伊朗3月28日空袭海湾国家的两家铝冶炼厂，危及了全球铝的供应，持续的战火和对霍尔木兹海峡的封锁也影响海湾国家输出其他的工业产品，引发生产芯片，塑料，化肥和药品等原料供应危机。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E7%BB%8F%E6%B5%8E/20260330-%E6%B5%B7%E6%B9%BE%E6%88%98%E4%BA%8B%E6%8C%81%E7%BB%AD%E6%88%96%E5%B0%86%E5%AF%BC%E8%87%B4%E5%A6%82%E9%93%9D-%E5%8C%96%E8%82%A5%E7%AD%89%E5%87%BA%E7%8E%B0%E7%9F%AD%E7%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774878375000.webp","sourceId":"rfi"},{"id":1774878111000,"createdDate":"2026-03-30 13:41","name":"法国国际广播电台","title":"面对中东石油危机 泽连斯基向俄罗斯提议能源休战","content":"乌克兰总统泽连斯基今天周一向莫斯科提议暂停对俄罗斯石油设施的袭击，以应对中东战争引发的能源危机。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260330-%E9%9D%A2%E5%AF%B9%E4%B8%AD%E4%B8%9C%E7%9F%B3%E6%B2%B9%E5%8D%B1%E6%9C%BA-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%90%91%E4%BF%84%E7%BD%97%E6%96%AF%E6%8F%90%E8%AE%AE%E8%83%BD%E6%BA%90%E4%BC%91%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774878111000.webp","sourceId":"rfi"},{"id":1774877396000,"createdDate":"2026-03-30 13:29","name":"法国国际广播电台","title":"温家宝罕见公开露面","content":"中国前总理温家宝2026年3月27日现身北京中科院地理所，视频曝光后引发关注，间接回应了外界对其「失联」与健康状况的揣测。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260330-%E6%B8%A9%E5%AE%B6%E5%AE%9D%E7%BD%95%E8%A7%81%E5%85%AC%E5%BC%80%E9%9C%B2%E9%9D%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774877396000.webp","sourceId":"rfi"},{"id":1774874331000,"createdDate":"2026-03-30 12:38","name":"法国国际广播电台","title":"断航六年后，中国国航首次恢复北京-平壤直飞航班","content":"中国国际航空（AirChina）周一恢复北京至平壤的直飞航班，这是该航线中断六年后的首次复航，也是朝鲜逐步开放的又一迹象。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260330-%E6%96%AD%E8%88%AA%E5%85%AD%E5%B9%B4%E5%90%8E%EF%BC%8C%E4%B8%AD%E5%9B%BD%E5%9B%BD%E8%88%AA%E9%A6%96%E6%AC%A1%E6%81%A2%E5%A4%8D%E5%8C%97%E4%BA%AC-%E5%B9%B3%E5%A3%A4%E7%9B%B4%E9%A3%9E%E8%88%AA%E7%8F%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774874331000.webp","sourceId":"rfi"},{"id":1774871943000,"createdDate":"2026-03-30 11:59","name":"法国国际广播电台","title":"特朗普认为美以发起的战争已导致伊朗政权更迭 预告20搜油轮将通过霍尔木兹海峡","content":"唐纳德-特朗普认为对伊朗伊斯兰共和国最高领导层的袭击实际上相当于该国的政权更迭，并预告美国与伊朗新领导人达成“协议”的可能性，尽管德黑兰周一仍在继续对海湾国家发动袭击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260330-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%A4%E4%B8%BA%E7%BE%8E%E4%BB%A5%E5%8F%91%E8%B5%B7%E7%9A%84%E6%88%98%E4%BA%89%E5%B7%B2%E5%AF%BC%E8%87%B4%E4%BC%8A%E6%9C%97%E6%94%BF%E6%9D%83%E6%9B%B4%E8%BF%AD-%E9%A2%84%E5%91%8A20%E6%90%9C%E6%B2%B9%E8%BD%AE%E5%B0%86%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774871943000.webp","sourceId":"rfi"},{"id":1774871375000,"createdDate":"2026-03-30 11:49","name":"法国国际广播电台","title":"习近平邀请郑丽文访中，释放了什么信号？","content":"周一，中国官方媒体新华社称，习近平邀请郑丽文于4月率团访问中国。随后，国民党发布的声明证实了这一报道，国民党主席郑丽文表示，她“希望双方共同努力，推动两岸关系和平发展，促进交流与合作，并为台湾海峡的和平以及两岸民众更大的福祉而努力”。此次到访是否为“习郑会”？又为随后的特朗普的访中释放了什么信号？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260330-%E4%B9%A0%E8%BF%91%E5%B9%B3%E9%82%80%E8%AF%B7%E9%83%91%E4%B8%BD%E6%96%87%E8%AE%BF%E4%B8%AD%EF%BC%8C%E9%87%8A%E6%94%BE%E4%BA%86%E4%BB%80%E4%B9%88%E4%BF%A1%E5%8F%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774871375000.webp","sourceId":"rfi"},{"id":1774869313000,"createdDate":"2026-03-30 11:15","name":"法国国际广播电台","title":"中东战争：七国集团召开财政、能源会议讨论经济影响","content":"担任轮值主席的法国周一召集七国集团举行财政能源峰会。各国财长、能源部长和央行行长将在视频中齐聚一堂，讨论中东战争带来的经济影响。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260330-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89-%E4%B8%83%E5%9B%BD%E9%9B%86%E5%9B%A2%E5%8F%AC%E5%BC%80%E8%B4%A2%E6%94%BF-%E8%83%BD%E6%BA%90%E4%BC%9A%E8%AE%AE%E8%AE%A8%E8%AE%BA%E7%BB%8F%E6%B5%8E%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/30/1774869313000.webp","sourceId":"rfi"}]