[{"id":1773556619000,"createdDate":"2026-03-15 06:36","name":"法国国际广播电台","title":"台湾：中国大规模军机绕台活动在异常“消失”后恢复","content":"路透社台北消息，台湾周日（3月15日）报告称，中国空军在岛屿周边的活跃程度已恢复至大规模水平。此前，此类活动经历了长达两周多原因不明的“消失”，引发了台北方面对北京意图的各种猜测。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260315-%E5%8F%B0%E6%B9%BE-%E4%B8%AD%E5%9B%BD%E5%A4%A7%E8%A7%84%E6%A8%A1%E5%86%9B%E6%9C%BA%E7%BB%95%E5%8F%B0%E6%B4%BB%E5%8A%A8%E5%9C%A8%E5%BC%82%E5%B8%B8-%E6%B6%88%E5%A4%B1-%E5%90%8E%E6%81%A2%E5%A4%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/15/1773556619000.webp","sourceId":"rfi"},{"id":1773554640000,"createdDate":"2026-03-15 06:04","name":"法国国际广播电台","title":"越南大选登场：共产党料将续以压倒性掌控国会","content":"法新社河内消息，越南今天举行5年一度大选，近7350万选民将投票选出500席国会议员，以及地方议会代表。参选国会议员的候选人有93%为共产党籍；预料共产党将继续压倒性掌控国会。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260315-%E8%B6%8A%E5%8D%97%E5%9B%BD%E4%BC%9A%E9%80%89%E4%B8%BE%E7%99%BB%E5%9C%BA-%E5%85%B1%E4%BA%A7%E5%85%9A%E5%8F%AF%E6%9C%9B%E7%BB%AD%E4%BB%A5%E5%8E%8B%E5%80%92%E6%80%A7%E6%8E%8C%E6%8E%A7%E5%9B%BD%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/15/1773554640000.webp","sourceId":"rfi"},{"id":1773553143000,"createdDate":"2026-03-15 05:39","name":"法国国际广播电台","title":"路透洞察：中国如何争取巴拉圭政界人士远离长期盟友台湾","content":"路透社亚松森专稿报道，去年底，巴拉圭反对党议员莱迪·加莱亚诺（LeidyGaleano）参加了中国六座城市的全程赞助之旅后，她深信巴拉圭若继续与长期盟友台湾保持关系，而非转向北京，将错失重大经济机遇。路透社注意到，在她访问期间这一信息被中国官员反复强调。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260315-%E8%B7%AF%E9%80%8F%E6%B4%9E%E5%AF%9F-%E4%B8%AD%E5%9B%BD%E5%A6%82%E4%BD%95%E4%BA%89%E5%8F%96%E5%B7%B4%E6%8B%89%E5%9C%AD%E6%94%BF%E7%95%8C%E4%BA%BA%E5%A3%AB%E8%BF%9C%E7%A6%BB%E9%95%BF%E6%9C%9F%E7%9B%9F%E5%8F%8B%E5%8F%B0%E6%B9%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/15/1773553143000.webp","sourceId":"rfi"}]