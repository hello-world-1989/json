[{"id":1774513931000,"createdDate":"2026-03-26 08:32","name":"法国国际广播电台","title":"柯文哲判17年、褫夺公权6年 求解除电子脚环降保 柯妈：政治迫害","content":"台北地院审理京华城容积奖励案、民众党政治献金案等4大案，在当地时间周四下午一审宣判。前台北市长柯文哲被判应执行17年有期徒刑，褫夺公权6年。可上诉。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260326-%E4%BA%AC%E5%8D%8E%E5%9F%8E%E6%A1%88%E4%B8%80%E5%AE%A1%E5%AE%A3%E5%88%A4-%E6%9F%AF%E6%96%87%E5%93%B2%E5%88%A417%E5%B9%B4-%E8%A4%AB%E5%A4%BA%E5%85%AC%E6%9D%836%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774513931000.webp","sourceId":"rfi"},{"id":1774513614000,"createdDate":"2026-03-26 08:26","name":"法国国际广播电台","title":"民众党前主席柯文哲涉京华城贪渎案 一审判刑17年并褫夺公权6年","content":"民众党前主席柯文哲涉京华城容积奖励案、民众党政治献金案等4大案，在26日一审判决，被处17年有期徒刑，褫夺公权6年。柯文哲、民众党主席黄国昌及律师团将召开「柯文哲司法记者会」回应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260326-%E6%B0%91%E4%BC%97%E5%85%9A%E5%89%8D%E4%B8%BB%E5%B8%AD%E6%9F%AF%E6%96%87%E5%93%B2%E6%B6%89%E4%BA%AC%E5%8D%8E%E5%9F%8E%E8%B4%AA%E6%B8%8E%E6%A1%88-%E4%B8%80%E5%AE%A1%E5%88%A4%E5%88%9117%E5%B9%B4%E5%B9%B6%E8%A4%AB%E5%A4%BA%E5%85%AC%E6%9D%836%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774513614000.webp","sourceId":"rfi"},{"id":1774509685000,"createdDate":"2026-03-26 07:21","name":"法国国际广播电台","title":"妇联副主席章冬梅任港澳办副主任 料将在港建立共青团等党化社会治理架构","content":"主管港澳事务的中央港澳办有新任命，曾任全国妇联副主席的章冬梅，新增为港澳办副主任。分析认为，在宏福苑大火后，港府治理能力不足问题突出，派有基层组织经验的官员加入港澳办，料会按中国社会组织架构，重建香港的社会网络，把共青团和少先队等组织引进香港。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260326-%E5%A6%87%E8%81%94%E5%89%AF%E4%B8%BB%E5%B8%AD%E7%AB%A0%E5%86%AC%E6%A2%85%E4%BB%BB%E6%B8%AF%E6%BE%B3%E5%8A%9E%E5%89%AF%E4%B8%BB%E4%BB%BB-%E6%96%99%E5%B0%86%E5%9C%A8%E6%B8%AF%E5%BB%BA%E7%AB%8B%E5%85%B1%E9%9D%92%E5%9B%A2%E7%AD%89%E5%85%9A%E5%8C%96%E7%A4%BE%E4%BC%9A%E6%B2%BB%E7%90%86%E6%9E%B6%E6%9E%84","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774509685000.webp","sourceId":"rfi"},{"id":1774509424000,"createdDate":"2026-03-26 07:17","name":"法国国际广播电台","title":"针对日本审定合格的高中教课书 中韩表示严正交涉和强烈抗议","content":"针对多本涉及历史问题和领土问题的日本高中教