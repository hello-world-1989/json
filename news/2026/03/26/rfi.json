[{"id":1774513931000,"createdDate":"2026-03-26 08:32","name":"法国国际广播电台","title":"柯文哲判17年、褫夺公权6年 求解除电子脚环降保 柯妈：政治迫害","content":"台北地院审理京华城容积奖励案、民众党政治献金案等4大案，在当地时间周四下午一审宣判。前台北市长柯文哲被判应执行17年有期徒刑，褫夺公权6年。可上诉。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260326-%E4%BA%AC%E5%8D%8E%E5%9F%8E%E6%A1%88%E4%B8%80%E5%AE%A1%E5%AE%A3%E5%88%A4-%E6%9F%AF%E6%96%87%E5%93%B2%E5%88%A417%E5%B9%B4-%E8%A4%AB%E5%A4%BA%E5%85%AC%E6%9D%836%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774513931000.webp","sourceId":"rfi"},{"id":1774513614000,"createdDate":"2026-03-26 08:26","name":"法国国际广播电台","title":"民众党前主席柯文哲涉京华城贪渎案 一审判刑17年并褫夺公权6年","content":"民众党前主席柯文哲涉京华城容积奖励案、民众党政治献金案等4大案，在26日一审判决，被处17年有期徒刑，褫夺公权6年。柯文哲、民众党主席黄国昌及律师团将召开「柯文哲司法记者会」回应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260326-%E6%B0%91%E4%BC%97%E5%85%9A%E5%89%8D%E4%B8%BB%E5%B8%AD%E6%9F%AF%E6%96%87%E5%93%B2%E6%B6%89%E4%BA%AC%E5%8D%8E%E5%9F%8E%E8%B4%AA%E6%B8%8E%E6%A1%88-%E4%B8%80%E5%AE%A1%E5%88%A4%E5%88%9117%E5%B9%B4%E5%B9%B6%E8%A4%AB%E5%A4%BA%E5%85%AC%E6%9D%836%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774513614000.webp","sourceId":"rfi"},{"id":1774509685000,"createdDate":"2026-03-26 07:21","name":"法国国际广播电台","title":"妇联副主席章冬梅任港澳办副主任 料将在港建立共青团等党化社会治理架构","content":"主管港澳事务的中央港澳办有新任命，曾任全国妇联副主席的章冬梅，新增为港澳办副主任。分析认为，在宏福苑大火后，港府治理能力不足问题突出，派有基层组织经验的官员加入港澳办，料会按中国社会组织架构，重建香港的社会网络，把共青团和少先队等组织引进香港。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260326-%E5%A6%87%E8%81%94%E5%89%AF%E4%B8%BB%E5%B8%AD%E7%AB%A0%E5%86%AC%E6%A2%85%E4%BB%BB%E6%B8%AF%E6%BE%B3%E5%8A%9E%E5%89%AF%E4%B8%BB%E4%BB%BB-%E6%96%99%E5%B0%86%E5%9C%A8%E6%B8%AF%E5%BB%BA%E7%AB%8B%E5%85%B1%E9%9D%92%E5%9B%A2%E7%AD%89%E5%85%9A%E5%8C%96%E7%A4%BE%E4%BC%9A%E6%B2%BB%E7%90%86%E6%9E%B6%E6%9E%84","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774509685000.webp","sourceId":"rfi"},{"id":1774509424000,"createdDate":"2026-03-26 07:17","name":"法国国际广播电台","title":"针对日本审定合格的高中教课书 中韩表示严正交涉和强烈抗议","content":"针对多本涉及历史问题和领土问题的日本高中教科书于24日通过日本政府审定，韩国外交部与中国外交部分别提出强烈抗议与严正交涉。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260326-%E9%92%88%E5%AF%B9%E6%97%A5%E6%9C%AC%E5%AE%A1%E5%AE%9A%E5%90%88%E6%A0%BC%E7%9A%84%E9%AB%98%E4%B8%AD%E6%95%99%E8%AF%BE%E4%B9%A6-%E4%B8%AD%E9%9F%A9%E8%A1%A8%E7%A4%BA%E4%B8%A5%E6%AD%A3%E4%BA%A4%E6%B6%89%E5%92%8C%E5%BC%BA%E7%83%88%E6%8A%97%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774509424000.webp","sourceId":"rfi"},{"id":1774541920000,"createdDate":"2026-03-26 16:18","name":"法国国际广播电台","title":"苹果公司在监管机构压力之下 正在中国展开魅力攻势","content":"各位听众，在监管机构的压力之下，苹果公司正在中国展开魅力攻势。“我们将共同植树造林。”苹果公司总裁蒂姆·库克在北京之行中并未提及苹果与中国之间的“共生关系”，而三年前他还对此赞不绝口。这位科技巨头的掌门人引用了一句中国谚语，称赞中国拥有“极具才华的开发者群体”，并表示与他们拥有共同的“发展愿景”。除了这些惯常的说辞之外，此次访问对苹果而言意义重大，因为该集团正面临着来自中国监管机构日益增长的压力。尤其值得一提的是，此次访华，库克会见了中国商务部长。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260326-%E8%8B%B9%E6%9E%9C%E5%85%AC%E5%8F%B8%E5%9C%A8%E7%9B%91%E7%AE%A1%E6%9C%BA%E6%9E%84%E5%8E%8B%E5%8A%9B%E4%B9%8B%E4%B8%8B-%E6%AD%A3%E5%9C%A8%E4%B8%AD%E5%9B%BD%E5%B1%95%E5%BC%80%E9%AD%85%E5%8A%9B%E6%94%BB%E5%8A%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774541920000.webp","sourceId":"rfi"},{"id":1774541362000,"createdDate":"2026-03-26 16:09","name":"法国国际广播电台","title":"卡拉斯指俄罗斯正向伊朗提供情报，以杀美国人 泽连斯基出访沙特寻求交换支持","content":"欧盟外交与安全政策高级代表卡拉斯（KajaKallas）周四指控俄罗斯向伊朗提供情报支持，意图在这场中东战争中“杀美国人”，并呼吁美方加大对俄施压力度。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260326-%E5%8D%A1%E6%8B%89%E6%96%AF%E6%8C%87%E4%BF%84%E7%BD%97%E6%96%AF%E6%AD%A3%E5%90%91%E4%BC%8A%E6%9C%97%E6%8F%90%E4%BE%9B%E6%83%85%E6%8A%A5%EF%BC%8C%E4%BB%A5%E6%9D%80%E7%BE%8E%E5%9B%BD%E4%BA%BA-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%87%BA%E8%AE%BF%E6%B2%99%E7%89%B9%E5%AF%BB%E6%B1%82%E4%BA%A4%E6%8D%A2%E6%94%AF%E6%8C%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774541362000.webp","sourceId":"rfi"},{"id":1774538179000,"createdDate":"2026-03-26 15:16","name":"法国国际广播电台","title":"德总理称未来可预见欧中达成贸易协议 受中方制裁荷兰新外贸相拟率团访华","content":"德国总理默茨（FriedrichMerz）周三表示，可以预见欧盟在与澳大利亚达成最新协议后，还将达成更多贸易协议，其中包括与中国，这标志着欧洲国家首都对北京的立场有所软化。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260326-%E5%BE%B7%E6%80%BB%E7%90%86%E7%A7%B0%E6%9C%AA%E6%9D%A5%E5%8F%AF%E9%A2%84%E8%A7%81%E6%AC%A7%E4%B8%AD%E8%BE%BE%E6%88%90%E8%B4%B8%E6%98%93%E5%8D%8F%E8%AE%AE-%E5%8F%97%E4%B8%AD%E6%96%B9%E5%88%B6%E8%A3%81%E8%8D%B7%E5%85%B0%E6%96%B0%E5%A4%96%E8%B4%B8%E7%9B%B8%E5%B0%86%E7%8E%87%E5%9B%A2%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774538179000.webp","sourceId":"rfi"},{"id":1774535266000,"createdDate":"2026-03-26 14:27","name":"法国国际广播电台","title":"联合国中非稳定团澄清撤出传闻","content":"联合国[中非稳定团]（MINUSCA）在周三（2026年03月25日）的新闻发布会上，澄清计划永久撤离中非共和国（RCA）的传闻。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260326-%E6%B3%95%E5%B9%BFrfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E8%81%94%E5%90%88%E5%9B%BD%E4%B8%AD%E9%9D%9E%E7%A8%B3%E5%AE%9A%E5%9B%A2%E6%BE%84%E6%B8%85%E6%92%A4%E5%87%BA%E4%BC%A0%E9%97%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774535266000.webp","sourceId":"rfi"},{"id":1774533296000,"createdDate":"2026-03-26 13:54","name":"法国国际广播电台","title":"被指“结交政治骗子，匿名诬告他人” 原正部级刘慧，被开除党籍","content":"中央纪委国家监委网站周四发布通报宣布，十三届全国政协教科卫体委员会副主任刘慧被开除党籍。值得一提的是，通报指刘慧“丧失理想信念，背弃初心使命，贯彻落实党中央重大决策部署打折扣、搞变通，结交政治骗子”等，更是罕见地指这名原正部级官员“匿名诬告他人”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260326-%E8%A2%AB%E6%8C%87-%E7%BB%93%E4%BA%A4%E6%94%BF%E6%B2%BB%E9%AA%97%E5%AD%90%EF%BC%8C%E5%8C%BF%E5%90%8D%E8%AF%AC%E5%91%8A%E4%BB%96%E4%BA%BA-%E5%8E%9F%E6%AD%A3%E9%83%A8%E7%BA%A7%E5%88%98%E6%85%A7%EF%BC%8C%E8%A2%AB%E5%BC%80%E9%99%A4%E5%85%9A%E7%B1%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774533296000.webp","sourceId":"rfi"},{"id":1774531495000,"createdDate":"2026-03-26 13:24","name":"法国国际广播电台","title":"法国镉污染为何比其他欧洲国家高数倍？","content":"法国国家食品安全、环境及劳动署. （ANSES）昨天就法国的镉污染发表全面的调查报告，报告揭露了法国镉污染的严重程度极其原因，并且提出了相应应对措施。镉是一种有毒的金属，它在自然界，在土壤中自然存在，会从土壤迁移到食物中，随着工业化的发展，镉被广泛运用于塑胶，电池，涂料等多种工业，镉污染所导致的公共卫生事件也因此不断涌现，上个世纪六十年代的日本，八十年代的台湾，以及十多年前的中国湖南与江西都发生过因食用被高浓度的镉污水污染的大米而引发的痛痛病等健康事件。不过，上述污染均与工业开发有关，而在今天化工厂寥寥无几的法国，镉污染为何依然如此严重？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260326-%E6%B3%95%E5%9B%BD%E9%95%89%E6%B1%A1%E6%9F%93%E4%B8%BA%E4%BD%95%E6%AF%94%E5%85%B6%E4%BB%96%E6%AC%A7%E6%B4%B2%E5%9B%BD%E5%AE%B6%E9%AB%98%E6%95%B0%E5%80%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774531495000.webp","sourceId":"rfi"},{"id":1774529531000,"createdDate":"2026-03-26 12:52","name":"法国国际广播电台","title":"美司法部公布两起中国公民被控走私AI芯片及贩毒大案","content":"周三，美国司法当局在两起不同的案件中指控中国公民犯有多项罪行，包括串谋对华走私先进的人工智能芯片、贩毒和洗钱。同日，美国总统特朗普（DonaldTrump）宣布了备受瞩目的美中峰会的新日期，定于五月中旬举行。与此同时，两国在人工智能领域的全球领导地位竞争仍在继续，华盛顿方面也持续指责北京在全球芬太尼供应链中扮演着关键角色。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260326-%E7%BE%8E%E5%8F%B8%E6%B3%95%E9%83%A8%E5%85%AC%E5%B8%83%E4%B8%A4%E8%B5%B7%E4%B8%AD%E5%9B%BD%E5%85%AC%E6%B0%91%E8%A2%AB%E6%8E%A7%E8%B5%B0%E7%A7%81ai%E8%8A%AF%E7%89%87%E5%8F%8A%E8%B4%A9%E6%AF%92%E5%A4%A7%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774529531000.webp","sourceId":"rfi"},{"id":1774526963000,"createdDate":"2026-03-26 12:09","name":"法国国际广播电台","title":"尼泊尔一调查委员会建议追究前总理镇压民间抗议的刑事责任","content":"尼泊尔3月初立法选举产生的新议会26日即将宣誓就职之际，当地媒体披露一份关于2025年前任政府垮台前镇压民间抗议行为的调查报告。报告建议追究前政府总理夏尔马-奥利的刑事责任。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260326-%E5%B0%BC%E6%B3%8A%E5%B0%94%E4%B8%80%E8%B0%83%E6%9F%A5%E5%A7%94%E5%91%98%E4%BC%9A%E5%BB%BA%E8%AE%AE%E8%BF%BD%E7%A9%B6%E5%89%8D%E6%80%BB%E7%90%86%E9%95%87%E5%8E%8B%E6%B0%91%E9%97%B4%E6%8A%97%E8%AE%AE%E7%9A%84%E5%88%91%E4%BA%8B%E8%B4%A3%E4%BB%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774526963000.webp","sourceId":"rfi"},{"id":1774525454000,"createdDate":"2026-03-26 11:44","name":"法国国际广播电台","title":"以防长称击杀伊朗革命卫队海军司令 特朗普警告当局：最好尽快认真，否则就太迟了","content":"以色列国防部长卡茨（IsraelKatz）表示，伊朗伊斯兰革命卫队海军司令坦格西里（AlirezaTangsiri）在以军的一次空袭中丧生。卡茨周四上午在与军方官员举行的评估会议上说：“以色列国防军消灭了伊朗伊斯兰革命卫队海军司令，此人直接负责在霍尔木兹海峡布雷并封锁海上交通的恐怖行动”。华盛顿方面，美国总统特朗普通过社媒警告伊朗当局“最好尽快认真起来，否则就太迟了”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260326-%E4%BB%A5%E9%98%B2%E9%95%BF%E7%A7%B0%E5%87%BB%E6%9D%80%E4%BC%8A%E6%9C%97%E9%9D%A9%E5%91%BD%E5%8D%AB%E9%98%9F%E6%B5%B7%E5%86%9B%E5%8F%B8%E4%BB%A4-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AD%A6%E5%91%8A%E5%BD%93%E5%B1%80-%E6%9C%80%E5%A5%BD%E5%B0%BD%E5%BF%AB%E8%AE%A4%E7%9C%9F%EF%BC%8C%E5%90%A6%E5%88%99%E5%B0%B1%E5%A4%AA%E8%BF%9F%E4%BA%86","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774525454000.webp","sourceId":"rfi"},{"id":1774521367000,"createdDate":"2026-03-26 10:36","name":"法国国际广播电台","title":"联合国提紧急人道援助古巴计划 以避免局势“迅速恶化”","content":"联合国于周三晚间公布紧急援助古巴的人道救援计划包括运送燃料和食品，这对于维持古巴的基本服务至关重要，古巴目前仍被美国禁运。与此同时，世界卫生组织认为古巴的卫生状况令人担忧。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260326-%E8%81%94%E5%90%88%E5%9B%BD%E6%8F%90%E7%B4%A7%E6%80%A5%E4%BA%BA%E9%81%93%E6%8F%B4%E5%8A%A9%E5%8F%A4%E5%B7%B4%E8%AE%A1%E5%88%92-%E4%BB%A5%E9%81%BF%E5%85%8D%E5%B1%80%E5%8A%BF-%E8%BF%85%E9%80%9F%E6%81%B6%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774521367000.webp","sourceId":"rfi"},{"id":1774521321000,"createdDate":"2026-03-26 10:35","name":"法国国际广播电台","title":"五角大楼拟定对伊朗“最后一击”四大军事方案 考虑将部分对乌军援转至中东","content":"据Axios新闻网援引两名美国官员和两名知情人士报导称，五角大楼正在制定对伊朗进行“最后一击”的军事方案，其中可能包括使用地面部队和大规模轰炸行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260326-%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC%E6%8B%9F%E5%AE%9A%E5%AF%B9%E4%BC%8A%E6%9C%97-%E6%9C%80%E5%90%8E%E4%B8%80%E5%87%BB-%E5%9B%9B%E5%A4%A7%E5%86%9B%E4%BA%8B%E6%96%B9%E6%A1%88-%E8%80%83%E8%99%91%E5%B0%86%E9%83%A8%E5%88%86%E5%AF%B9%E4%B9%8C%E5%86%9B%E6%8F%B4%E8%BD%AC%E8%87%B3%E4%B8%AD%E4%B8%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774521321000.webp","sourceId":"rfi"},{"id":1774519338000,"createdDate":"2026-03-26 10:02","name":"法国国际广播电台","title":"美议员将提出法案禁止联邦政府购买或使用中制人形机器人","content":"周四，两位美国联邦参议员计划提出一项法案，禁止政府购买或运营中国公司制造的人形机器人。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260326-%E7%BE%8E%E8%AE%AE%E5%91%98%E5%B0%86%E6%8F%90%E5%87%BA%E6%B3%95%E6%A1%88%E7%A6%81%E6%AD%A2%E8%81%94%E9%82%A6%E6%94%BF%E5%BA%9C%E8%B4%AD%E4%B9%B0%E6%88%96%E4%BD%BF%E7%94%A8%E4%B8%AD%E5%88%B6%E4%BA%BA%E5%BD%A2%E6%9C%BA%E5%99%A8%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774519338000.webp","sourceId":"rfi"},{"id":1774567109000,"createdDate":"2026-03-26 23:18","name":"法国国际广播电台","title":"欧盟宣布对进口小额包裹收费，最迟将于11月1日实施，2024年91%的小额包裹来自中国","content":"欧盟27个成员国及欧洲议会议员周四（3月26日）批准，对进口至欧盟的低价值包裹征收处理费，具体金额尚未确定，但最迟将于11月1日实施。这些费用将在每种商品征收3欧元税费的基础上额外收取，该税费将自7月起适用于同样的“低价值包裹”（价值低于150欧元），而这些包裹主要来自中国。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260326-%E7%BB%A7%E6%B3%95%E5%9B%BD%E5%90%8E%EF%BC%8C%E6%AC%A7%E7%9B%9F%E5%AE%A3%E5%B8%83%E5%AF%B9%E8%BF%9B%E5%8F%A3%E5%B0%8F%E9%A2%9D%E5%8C%85%E8%A3%B9%E6%94%B6%E8%B4%B9%EF%BC%8C%E6%9C%80%E8%BF%9F%E5%B0%86%E4%BA%8E11%E6%9C%881%E6%97%A5%E5%AE%9E%E6%96%BD-2024%E5%B9%B4%E7%BA%A6%E6%9C%8946%E4%BA%BF%E4%B8%AA%E5%B0%8F%E9%A2%9D%E5%8C%85%E8%A3%B9%E8%BF%9B%E5%85%A5%E6%AC%A7%E7%9B%9F%EF%BC%8C%E5%85%B6%E4%B8%AD91-%E6%9D%A5%E8%87%AA%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774567109000.webp","sourceId":"rfi"},{"id":1774565127000,"createdDate":"2026-03-26 22:45","name":"法国国际广播电台","title":"特朗普又将对伊朗的最后通牒延期至4月6日，称这是“伊朗政府的要求”","content":"特朗普周四（3月26日）宣布，将对伊朗的最后通牒延长至4月6日，以便在可能对伊朗电力设施进行打击前继续谈判，他还称与德黑兰的讨论“非常顺利”。同时他声称这是“伊朗政府的要求”，不过他并未说明在此之前需要满足哪些具体条件。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260326-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%88%E5%B0%86%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%9A%84%E6%9C%80%E5%90%8E%E9%80%9A%E7%89%92%E5%BB%B6%E9%95%BF%E8%87%B34%E6%9C%886%E6%97%A5%EF%BC%8C%E7%A7%B0%E8%BF%99%E6%98%AF-%E4%BC%8A%E6%9C%97%E6%94%BF%E5%BA%9C%E7%9A%84%E8%A6%81%E6%B1%82","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774565127000.webp","sourceId":"rfi"},{"id":1774557986000,"createdDate":"2026-03-26 20:46","name":"法国国际广播电台","title":"鲁比奥缺席G7外长首日会议，但表示帮助重新开放霍尔木兹海峡符合G7国家利益，同时重申美国对盟友的失望","content":"G7外长周四（3月26日）在巴黎附近举行会议，美国国务卿鲁比奥缺席首日会议，目前正在赶往法国的途中。此次会议的主要意图是推动美国在中东采取降级行动，同时强调继续关注乌克兰。虽然没有到场，但鲁比奥仍表示，G7国家有“利益”帮助重新开放霍尔木兹海峡，同时他重申了美国对盟友的失望。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260326-%E9%B2%81%E6%AF%94%E5%A5%A5%E7%BC%BA%E5%B8%ADg7%E5%A4%96%E9%95%BF%E9%A6%96%E6%97%A5%E4%BC%9A%E8%AE%AE%EF%BC%8C%E4%BD%86%E8%A1%A8%E7%A4%BA%E5%B8%AE%E5%8A%A9%E9%87%8D%E6%96%B0%E5%BC%80%E6%94%BE%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%AC%A6%E5%90%88g7%E5%9B%BD%E5%AE%B6%E5%88%A9%E7%9B%8A%EF%BC%8C%E5%90%8C%E6%97%B6%E9%87%8D%E7%94%B3%E7%BE%8E%E5%9B%BD%E5%AF%B9%E7%9B%9F%E5%8F%8B%E7%9A%84%E5%A4%B1%E6%9C%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774557986000.webp","sourceId":"rfi"},{"id":1774557276000,"createdDate":"2026-03-26 20:34","name":"法国国际广播电台","title":"国会预算僵局难解　国土安全部关门危机升温","content":"美国国土安全部关门危机已进入第41天，国会两党谈判陷入僵局，不仅未见突破迹象，甚至出现倒退。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260326-%E5%9B%BD%E4%BC%9A%E9%A2%84%E7%AE%97%E5%83%B5%E5%B1%80%E9%9A%BE%E8%A7%A3-%E5%9B%BD%E5%9C%9F%E5%AE%89%E5%85%A8%E9%83%A8%E5%85%B3%E9%97%A8%E5%8D%B1%E6%9C%BA%E5%8D%87%E6%B8%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774557276000.webp","sourceId":"rfi"},{"id":1774557121000,"createdDate":"2026-03-26 20:32","name":"法国国际广播电台","title":"巴基斯坦恢复对阿富汗军事行动，开斋节短暂停火结束","content":"3月26日，巴基斯坦外交部表示，巴基斯坦军方在短暂停火后，恢复了针对阿富汗的军事行动。这一声明打破了对双方持续停火的希望。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260326-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E6%81%A2%E5%A4%8D%E5%AF%B9%E9%98%BF%E5%AF%8C%E6%B1%97%E5%86%9B%E4%BA%8B%E8%A1%8C%E5%8A%A8%EF%BC%8C%E5%BC%80%E6%96%8B%E8%8A%82%E7%9F%AD%E6%9A%82%E5%81%9C%E7%81%AB%E7%BB%93%E6%9D%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774557121000.webp","sourceId":"rfi"},{"id":1774555661000,"createdDate":"2026-03-26 20:07","name":"法国国际广播电台","title":"泽连斯基突访沙特谈无人机，乌远程打击俄罗斯能源出口","content":"3月26日，乌克兰总统弗拉基米尔·泽连斯基表示，在国际对俄罗斯石油制裁放松后，乌克兰通过远程打击能源基础设施持续向俄罗斯施压。泽连斯基指出：“世界对俄罗斯的压力正在减弱。因此，与世界上大多数国家不同，乌克兰有自己的制裁：其远程（打击）能力”。他补充道，如果乌克兰不回应俄罗斯的攻击，后者将继续战争，不会考虑暂停。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260326-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E6%B2%99%E7%89%B9%E7%AA%81%E8%AE%BF%E8%B0%88%E6%97%A0%E4%BA%BA%E6%9C%BA%EF%BC%8C%E4%B9%8C%E8%BF%9C%E7%A8%8B%E6%89%93%E5%87%BB%E6%89%93%E5%87%BB%E4%BF%84%E7%BD%97%E6%96%AF%E8%83%BD%E6%BA%90%E5%87%BA%E5%8F%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774555661000.webp","sourceId":"rfi"},{"id":1774555580000,"createdDate":"2026-03-26 20:06","name":"法国国际广播电台","title":"被捕3个月后，马杜罗在纽约法庭短暂露面   法新社称面带微笑神情轻松，但没有发言","content":"被废黜的委内瑞拉总统尼古拉斯·马杜罗（NicolasMaduro）周四（3月26日）面带微笑出现在纽约的一家法庭上，庭审大约持续了一个小时，但他没有发言。自从被美国抓捕后，这是他第二次公开露面。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260326-%E8%A2%AB%E6%8D%953%E4%B8%AA%E6%9C%88%E5%90%8E%EF%BC%8C%E9%A9%AC%E6%9D%9C%E7%BD%97%E5%9C%A8%E7%BA%BD%E7%BA%A6%E6%B3%95%E5%BA%AD%E7%9F%AD%E6%9A%82%E9%9C%B2%E9%9D%A2-%E6%B3%95%E6%96%B0%E7%A4%BE%E7%A7%B0%E9%9D%A2%E5%B8%A6%E5%BE%AE%E7%AC%91%E7%A5%9E%E6%83%85%E8%BD%BB%E6%9D%BE%EF%BC%8C%E4%BD%86%E6%B2%A1%E6%9C%89%E5%8F%91%E8%A8%80","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774555580000.webp","sourceId":"rfi"},{"id":1774555553000,"createdDate":"2026-03-26 20:05","name":"法国国际广播电台","title":"欧洲进一步收紧移民政策：计划将非法移民送往欧洲以外的“遣返中心”，并可能进行拘留","content":"欧洲议会周四（3月26日）批准了一项大幅收紧欧洲移民政策的法案，并通过了“遣返中心”这一概念，也就是在欧盟外设立移民中心，将申请被拒的寻求庇护者，以及面临离境义务的人送往这些中心，并可能在那里进行拘留。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260326-%E6%AC%A7%E6%B4%B2%E8%BF%9B%E4%B8%80%E6%AD%A5%E6%94%B6%E7%B4%A7%E7%A7%BB%E6%B0%91%E6%94%BF%E7%AD%96-%E8%AE%A1%E5%88%92%E5%B0%86%E9%9D%9E%E6%B3%95%E7%A7%BB%E6%B0%91%E9%80%81%E5%BE%80%E6%AC%A7%E6%B4%B2%E4%BB%A5%E5%A4%96%E7%9A%84-%E9%81%A3%E8%BF%94%E4%B8%AD%E5%BF%83-%EF%BC%8C%E5%B9%B6%E5%8F%AF%E8%83%BD%E8%BF%9B%E8%A1%8C%E6%8B%98%E7%95%99","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774555553000.webp","sourceId":"rfi"},{"id":1774552410000,"createdDate":"2026-03-26 19:13","name":"法国国际广播电台","title":"英国考虑或将对外国游客收取博物馆门票费  数据显示：外国游客约占总参观人数的43%","content":"英国政府周四（3月26日）宣布，计划进一步探讨对国家博物馆的外国游客收取门票这一想法，目的是增加这些文化机构的资金来源。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260326-%E8%8B%B1%E5%9B%BD%E8%80%83%E8%99%91%E6%88%96%E5%B0%86%E5%AF%B9%E5%A4%96%E5%9B%BD%E6%B8%B8%E5%AE%A2%E6%94%B6%E5%8F%96%E5%8D%9A%E7%89%A9%E9%A6%86%E9%97%A8%E7%A5%A8%E8%B4%B9-%E6%95%B0%E6%8D%AE%E6%98%BE%E7%A4%BA-%E5%A4%96%E5%9B%BD%E6%B8%B8%E5%AE%A2%E7%BA%A6%E5%8D%A0%E6%80%BB%E5%8F%82%E8%A7%82%E4%BA%BA%E6%95%B0%E7%9A%8443","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774552410000.webp","sourceId":"rfi"},{"id":1774550701000,"createdDate":"2026-03-26 18:45","name":"法国国际广播电台","title":"乌克兰驻北约大使：暂无迹象表明美国将原本打算分配给乌克兰的武器资源转向中东","content":"乌克兰驻北约大使阿廖娜·格特曼丘克周四（3月26日）向法新社表示，尽管中东战争正在进行，乌克兰仍持续接收对防御至关重要的美国装备，且未收到任何来自华盛顿的信号表明这些资源将被重新分配。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260326-%E4%B9%8C%E5%85%8B%E5%85%B0%E9%A9%BB%E5%8C%97%E7%BA%A6%E5%A4%A7%E4%BD%BF-%E6%9A%82%E6%97%A0%E8%BF%B9%E8%B1%A1%E8%A1%A8%E6%98%8E%E7%BE%8E%E5%9B%BD%E5%B0%86%E5%8E%9F%E6%9C%AC%E6%89%93%E7%AE%97%E5%88%86%E9%85%8D%E7%BB%99%E4%B9%8C%E5%85%8B%E5%85%B0%E7%9A%84%E6%AD%A6%E5%99%A8%E8%B5%84%E6%BA%90%E8%BD%AC%E5%90%91%E4%B8%AD%E4%B8%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774550701000.webp","sourceId":"rfi"},{"id":1774549994000,"createdDate":"2026-03-26 18:33","name":"法国国际广播电台","title":"法国教育部长向司法机关提交报告 指控TikTok“煽动自杀”和推送非法视频内容","content":"法国教育部长爱德华·格夫雷于周四（3月26日）宣布，已向司法机关提交针对TikTok的报告，指控该平台涉及“煽动自杀”和“非法数据传输”，并批评TikTok将用户“困入致命螺旋”。这位部长透露，他与办公室人员共同创建了一个账户，并设置年龄为14岁。“不到20分钟，我们就被推送到抑郁视频……陷入了致命螺旋”，包括“割腕教程”和“煽动自杀的视频”，他警告说。“这不是意外。算法的运作机制就是为了将人困在这种螺旋中。”","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260326-%E6%B3%95%E5%9B%BD%E6%95%99%E8%82%B2%E9%83%A8%E9%95%BF%E5%90%91%E5%8F%B8%E6%B3%95%E6%9C%BA%E5%85%B3%E6%8F%90%E4%BA%A4%E6%8A%A5%E5%91%8A-%E6%8C%87%E6%8E%A7tiktok-%E7%85%BD%E5%8A%A8%E8%87%AA%E6%9D%80-%E5%92%8C%E6%8E%A8%E9%80%81%E9%9D%9E%E6%B3%95%E8%A7%86%E9%A2%91%E5%86%85%E5%AE%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774549994000.webp","sourceId":"rfi"},{"id":1774548112000,"createdDate":"2026-03-26 18:01","name":"法国国际广播电台","title":"法新社：伊朗认为在面对急于谈判的特朗普时掌握主动权","content":"法新社采访的分析人士指出，在回应美国提出的15点停火方案时，伊朗提出了自己的条件，这表明在近四周的战争之后，德黑兰认为自己在谈判中处于有利位置。但也有分析人士提醒，不要只看表象，实际上，目前的伊朗可能已经非常虚弱。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260326-%E6%B3%95%E6%96%B0%E7%A4%BE-%E4%BC%8A%E6%9C%97%E8%AE%A4%E4%B8%BA%E5%9C%A8%E9%9D%A2%E5%AF%B9%E6%80%A5%E4%BA%8E%E8%B0%88%E5%88%A4%E7%9A%84%E7%89%B9%E6%9C%97%E6%99%AE%E6%97%B6%E6%8E%8C%E6%8F%A1%E4%B8%BB%E5%8A%A8%E6%9D%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774548112000.webp","sourceId":"rfi"},{"id":1774539577000,"createdDate":"2026-03-26 15:39","name":"法国国际广播电台","title":"被中东危机边缘化的乌克兰战争面对多重新挑战","content":"七大工业国集团26日-27日在法国举行外长会议。导致全球能源价格上涨并对各国经济产生影响的伊朗战争无疑将是会议重点。尽管七国集团在印度、巴西、日本、韩国和沙特阿拉伯等国外长之外，还邀请了乌克兰外长与会，但乌克兰战争是否能避免被中东主题边缘化、重新吸引与会各国的注意力却很难说。而乌克兰进入第五个年头的抗俄战争如今正面对不只是来自俄罗斯的多重挑战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260326-%E8%A2%AB%E4%B8%AD%E4%B8%9C%E5%8D%B1%E6%9C%BA%E8%BE%B9%E7%BC%98%E5%8C%96%E7%9A%84%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E4%BA%89%E9%9D%A2%E5%AF%B9%E5%A4%9A%E9%87%8D%E6%96%B0%E6%8C%91%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/26/1774539577000.webp","sourceId":"rfi"}]