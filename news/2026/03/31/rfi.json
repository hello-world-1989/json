[{"id":1774946089000,"createdDate":"2026-03-31 08:34","name":"法国国际广播电台","title":"日本首在熊本和静冈两处基地部署远程导弹 威慑中国与朝鲜","content":"综合法新社与日媒报道，日本防卫省周二31日宣布在西南部熊本县的健军驻地（CampKengun）以及中部静冈县的富士驻地（CampFuji），开始配备射程约1千公里、涵盖中国沿岸与朝的长程导弹。这也代表过去着重防卫的日本安全保障政策，出现重大转变。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260331-%E6%97%A5%E6%9C%AC%E9%A6%96%E5%9C%A8%E7%86%8A%E6%9C%AC%E5%92%8C%E9%9D%99%E5%86%88%E4%B8%A4%E5%A4%84%E5%9F%BA%E5%9C%B0%E9%83%A8%E7%BD%B2%E8%BF%9C%E7%A8%8B%E5%AF%BC%E5%BC%B9-%E5%A8%81%E6%85%91%E4%B8%AD%E5%9B%BD%E4%B8%8E%E6%9C%9D%E9%B2%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774946089000.webp","sourceId":"rfi"},{"id":1774942966000,"createdDate":"2026-03-31 07:42","name":"法国国际广播电台","title":"法国总统马克龙携夫人3月31日到访日本","content":"3月31日至4月2日，法国总统马克龙及夫人布丽吉特·马克龙以正式工作访问宾客身份访问日本，于31日乘坐政府专机“空中客车A330”到达日本。马克龙总统4月1日将与高市早苗首相举行会谈。法国是今年七国集团（G7）主席国，能否在应对中东危机方面推动日欧协作打开局面成为这次访问的焦点。双方还将就太空防御及下一代核电站开发的双边合作进行讨论。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260331-%E6%B3%95%E5%9B%BD%E6%80%BB%E7%BB%9F%E9%A9%AC%E5%85%8B%E9%BE%99%E6%90%BA%E5%A4%AB%E4%BA%BA3%E6%9C%8831%E6%97%A5%E5%88%B0%E8%AE%BF%E6%97%A5%E6%9C%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774942966000.webp","sourceId":"rfi"},{"id":1774942905000,"createdDate":"2026-03-31 07:41","name":"法国国际广播电台","title":"支联会案：官禁当年留守天安门至最后记者谈见证和展示六四照片","content":"前支联会及要员被控煽动颠覆案续审，前副主席邹幸彤传召三名辩方证人作证，但法官多次禁止1989年6月4日凌晨与天安门广场学生一起撤离的时任记者展示六四现场照片和录音，亦不许证人发表对「4.26社论」的意见，强调法庭不会考虑相关证据和就当年事件的是非作判断。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260331-%E6%94%AF%E8%81%94%E4%BC%9A%E6%A1%88-%E5%AE%98%E7%A6%81%E5%BD%93%E5%B9%B4%E7%95%99%E5%AE%88%E5%A4%A9%E5%AE%89%E9%97%A8%E8%87%B3%E6%9C%80%E5%90%8E%E8%AE%B0%E8%80%85%E8%B0%88%E8%A7%81%E8%AF%81%E5%92%8C%E5%B1%95%E7%A4%BA%E5%85%AD%E5%9B%9B%E7%85%A7%E7%89%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774942905000.webp","sourceId":"rfi"},{"id":1774942838000,"createdDate":"2026-03-31 07:40","name":"法国国际广播电台","title":"中国艺术家高兟因旧作讽刺毛泽东 羁押一年半後被闭门审讯 惟未判刑","content":"已移居美国的中国艺术家高兟，因其作品被指批评已故中共领导人毛泽东，涉嫌侵害英烈名誉，遭中国当局关押逾580天后，案件于周一(30日)早上在河北省三河市人民法院进行闭门审讯，家人亦不得旁听。同样遭到拒绝的，还有欧盟驻华代表团。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260331-%E4%B8%AD%E5%9B%BD%E8%89%BA%E6%9C%AF%E5%AE%B6%E9%AB%98%E5%85%9F%E5%9B%A0%E6%97%A7%E4%BD%9C%E8%AE%BD%E5%88%BA%E6%AF%9B%E6%B3%BD%E4%B8%9C-%E7%BE%81%E6%8A%BC%E4%B8%80%E5%B9%B4%E5%8D%8A%E5%BE%8C%E8%A2%AB%E9%97%AD%E9%97%A8%E5%AE%A1%E8%AE%AF-%E6%83%9F%E6%9C%AA%E5%88%A4%E5%88%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774942838000.webp","sourceId":"rfi"},{"id":1774924160000,"createdDate":"2026-03-31 02:29","name":"法国国际广播电台","title":"法国等23个国家发现一种突变数量创纪录的新变种新冠病毒","content":"专家警告，一种突变程度创纪录的新变种新冠病毒正在全球蔓延。这种名为BA.3.2的新变种新冠病毒已在多个国家被发现，它具有更强的逃避抗体的能力，但尚未引起流行浪潮。这种病毒现今在欧洲传播最为迅速。此外，在美国五十个州中的一半州也都发现了。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260331-%E6%B3%95%E5%9B%BD%E7%AD%8923%E4%B8%AA%E5%9B%BD%E5%AE%B6%E5%8F%91%E7%8E%B0%E4%B8%80%E7%A7%8D%E7%AA%81%E5%8F%98%E6%95%B0%E9%87%8F%E5%88%9B%E7%BA%AA%E5%BD%95%E7%9A%84%E6%96%B0%E5%8F%98%E7%A7%8D%E6%96%B0%E5%86%A0%E7%97%85%E6%AF%92","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774924160000.webp","sourceId":"rfi"}]