[{"id":1774946089000,"createdDate":"2026-03-31 08:34","name":"法国国际广播电台","title":"日本首在熊本和静冈两处基地部署远程导弹 威慑中国与朝鲜","content":"综合法新社与日媒报道，日本防卫省周二31日宣布在西南部熊本县的健军驻地（CampKengun）以及中部静冈县的富士驻地（CampFuji），开始配备射程约1千公里、涵盖中国沿岸与朝的长程导弹。这也代表过去着重防卫的日本安全保障政策，出现重大转变。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260331-%E6%97%A5%E6%9C%AC%E9%A6%96%E5%9C%A8%E7%86%8A%E6%9C%AC%E5%92%8C%E9%9D%99%E5%86%88%E4%B8%A4%E5%A4%84%E5%9F%BA%E5%9C%B0%E9%83%A8%E7%BD%B2%E8%BF%9C%E7%A8%8B%E5%AF%BC%E5%BC%B9-%E5%A8%81%E6%85%91%E4%B8%AD%E5%9B%BD%E4%B8%8E%E6%9C%9D%E9%B2%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774946089000.webp","sourceId":"rfi"},{"id":1774942966000,"createdDate":"2026-03-31 07:42","name":"法国国际广播电台","title":"法国总统马克龙携夫人3月31日到访日本","content":"3月31日至4月2日，法国总统马克龙及夫人布丽吉特·马克龙以正式工作访问宾客身份访问日本，于31日乘坐政府专机“空中客车A330”到达日本。马克龙总统4月1日将与高市早苗首相举行会谈。法国是今年七国集团（G7）主席国，能否在应对中东危机方面推动日欧协作打开局面成为这次访问的焦点。双方还将就太空防御及下一代核电站开发的双边合作进行讨论。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260331-%E6%B3%95%E5%9B%BD%E6%80%BB%E7%BB%9F%E9%A9%AC%E5%85%8B%E9%BE%99%E6%90%BA%E5%A4%AB%E4%BA%BA3%E6%9C%8831%E6%97%A5%E5%88%B0%E8%AE%BF%E6%97%A5%E6%9C%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774942966000.webp","sourceId":"rfi"},{"id":1774942905000,"createdDate":"2026-03-31 07:41","name":"法国国际广播电台","title":"支联会案：官禁当年留守天安门至最后记者谈见证和展示六四照片","content":"前支联会及要员被控煽动颠覆案续审，前副主席邹幸彤传召三名辩方证人作证，但法官多次禁止1989年6月4日凌晨与天安门广场学生一起撤离的时任记者展示六四现场照片和录音，亦不许证人发表对「4.26社论」的意见，强调法庭不会考虑相关证据和就当年事件的是非作判断。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260331-%E6%94%AF%E8%81%94%E4%BC%9A%E6%A1%88-%E5%AE%98%E7%A6%81%E5%BD%93%E5%B9%B4%E7%95%99%E5%AE%88%E5%A4%A9%E5%AE%89%E9%97%A8%E8%87%B3%E6%9C%80%E5%90%8E%E8%AE%B0%E8%80%85%E8%B0%88%E8%A7%81%E8%AF%81%E5%92%8C%E5%B1%95%E7%A4%BA%E5%85%AD%E5%9B%9B%E7%85%A7%E7%89%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774942905000.webp","sourceId":"rfi"},{"id":1774942838000,"createdDate":"2026-03-31 07:40","name":"法国国际广播电台","title":"中国艺术家高兟因旧作讽刺毛泽东 羁押一年半後被闭门审讯 惟未判刑","content":"已移居美国的中国艺术家高兟，因其作品被指批评已故中共领导人毛泽东，涉嫌侵害英烈名誉，遭中国当局关押逾580天后，案件于周一(30日)早上在河北省三河市人民法院进行闭门审讯，家人亦不得旁听。同样遭到拒绝的，还有欧盟驻华代表团。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260331-%E4%B8%AD%E5%9B%BD%E8%89%BA%E6%9C%AF%E5%AE%B6%E9%AB%98%E5%85%9F%E5%9B%A0%E6%97%A7%E4%BD%9C%E8%AE%BD%E5%88%BA%E6%AF%9B%E6%B3%BD%E4%B8%9C-%E7%BE%81%E6%8A%BC%E4%B8%80%E5%B9%B4%E5%8D%8A%E5%BE%8C%E8%A2%AB%E9%97%AD%E9%97%A8%E5%AE%A1%E8%AE%AF-%E6%83%9F%E6%9C%AA%E5%88%A4%E5%88%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774942838000.webp","sourceId":"rfi"},{"id":1774924160000,"createdDate":"2026-03-31 02:29","name":"法国国际广播电台","title":"法国等23个国家发现一种突变数量创纪录的新变种新冠病毒","content":"专家警告，一种突变程度创纪录的新变种新冠病毒正在全球蔓延。这种名为BA.3.2的新变种新冠病毒已在多个国家被发现，它具有更强的逃避抗体的能力，但尚未引起流行浪潮。这种病毒现今在欧洲传播最为迅速。此外，在美国五十个州中的一半州也都发现了。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260331-%E6%B3%95%E5%9B%BD%E7%AD%8923%E4%B8%AA%E5%9B%BD%E5%AE%B6%E5%8F%91%E7%8E%B0%E4%B8%80%E7%A7%8D%E7%AA%81%E5%8F%98%E6%95%B0%E9%87%8F%E5%88%9B%E7%BA%AA%E5%BD%95%E7%9A%84%E6%96%B0%E5%8F%98%E7%A7%8D%E6%96%B0%E5%86%A0%E7%97%85%E6%AF%92","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774924160000.webp","sourceId":"rfi"},{"id":1774972696000,"createdDate":"2026-03-31 15:58","name":"法国国际广播电台","title":"高兟案：欧盟驻华代表团要求旁听遭拒  法广网站对该案报道被黑","content":"中国艺术家高兟因旧作讽刺毛泽东被囚禁一年半后3月30日在河北省三河市一间法院闭门庭审，受到关注。欧盟驻华代表团未被允许进入法庭。法广网站30日有关的报道遭黑客攻击...","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260331-%E9%AB%98%E5%85%9F%E6%A1%88-%E6%AC%A7%E7%9B%9F%E9%A9%BB%E5%8D%8E%E4%BB%A3%E8%A1%A8%E5%9B%A2%E8%A6%81%E6%B1%82%E6%97%81%E5%90%AC%E9%81%AD%E6%8B%92-%E6%B3%95%E5%B9%BF%E7%BD%91%E7%AB%99%E5%AF%B9%E8%AF%A5%E6%A1%88%E6%8A%A5%E9%81%93%E8%A2%AB%E9%BB%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774972696000.webp","sourceId":"rfi"},{"id":1774965913000,"createdDate":"2026-03-31 14:05","name":"法国国际广播电台","title":"《法兰克福评论报》：特朗普的伊朗战争催生反西方联盟","content":"伊朗战争背景下的中美关系继续是德语媒体关注的话题。多份媒体认为，特朗普的伊朗战争让中国受益。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9F%8F%E6%9E%97%E9%A3%9E%E9%B8%BF/20260331-%E6%B3%95%E5%85%B0%E5%85%8B%E7%A6%8F%E8%AF%84%E8%AE%BA%E6%8A%A5-%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E5%82%AC%E7%94%9F%E5%8F%8D%E8%A5%BF%E6%96%B9%E8%81%94%E7%9B%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774965913000.webp","sourceId":"rfi"},{"id":1774965778000,"createdDate":"2026-03-31 14:02","name":"法国国际广播电台","title":"伊朗继续打击海湾国家 袭击并纵火焚烧一艘科威特油轮","content":"伊朗革命卫队继续对海湾国家发动袭击：周二袭击并焚烧一艘停泊在迪拜海岸附近的科威特油轮，迪拜则再传爆炸声，沙特宣布已拦截八枚弹道导弹，以色列特拉维夫地区8人在伊朗袭击中受伤。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260331-%E4%BC%8A%E6%9C%97%E7%BB%A7%E7%BB%AD%E6%89%93%E5%87%BB%E6%B5%B7%E6%B9%BE%E5%9B%BD%E5%AE%B6-%E8%A2%AD%E5%87%BB%E5%B9%B6%E7%BA%B5%E7%81%AB%E7%84%9A%E7%83%A7%E4%B8%80%E8%89%98%E7%A7%91%E5%A8%81%E7%89%B9%E6%B2%B9%E8%BD%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774965778000.webp","sourceId":"rfi"},{"id":1774965735000,"createdDate":"2026-03-31 14:02","name":"法国国际广播电台","title":"太空竞赛：中国的对手更像是时间，而不是美国","content":"各位好，今天是2026年3月31日星期二。今日出刊的法国主流日刊刊出了多篇与中国相关的分析报道。本期法国报纸摘要，带您纵览这些话题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260331-%E5%A4%AA%E7%A9%BA%E7%AB%9E%E8%B5%9B-%E4%B8%AD%E5%9B%BD%E7%9A%84%E5%AF%B9%E6%89%8B%E6%9B%B4%E5%83%8F%E6%98%AF%E6%97%B6%E9%97%B4%EF%BC%8C%E8%80%8C%E4%B8%8D%E6%98%AF%E7%BE%8E%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774965735000.webp","sourceId":"rfi"},{"id":1774960393000,"createdDate":"2026-03-31 12:33","name":"法国国际广播电台","title":"WSJ：特朗普准备在未完全重开霍尔木兹海峡的情况下结束战争","content":"据《华尔街日报》报道，特朗普认为强行重开霍尔木兹海峡将使冲突“超出其预定的四-六周时间表”。但以色列总理表示他不想设置时间表。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260331-wsj-%E7%89%B9%E6%9C%97%E6%99%AE%E5%87%86%E5%A4%87%E5%9C%A8%E6%9C%AA%E5%AE%8C%E5%85%A8%E9%87%8D%E5%BC%80%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%9A%84%E6%83%85%E5%86%B5%E4%B8%8B%E7%BB%93%E6%9D%9F%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774960393000.webp","sourceId":"rfi"},{"id":1774959077000,"createdDate":"2026-03-31 12:11","name":"法国国际广播电台","title":"PFAS : 欧洲化学品管理局建议\"广泛限制\"","content":"总部位于赫尔辛基的欧洲化学品管理局（ECHA）3月26日公布了经过数年的研究之后做出的有关永久污染物PFAS的结论，结论明确指出，永久污染物对人体“有害”，并对人口和环境构成“日益增长的风险”。建议欧盟对这类的化学物质进行“广泛的限制”。欧盟应该在今年年底之前就是否禁止在日常消费品中使用PFAS立法。不过，布鲁塞尔的立法文本关键取决于欧洲化学品管理局的两份意见：一份是刚刚发布的科学报告，另一份是预计在年底前完成的关于PFAS减量措施的社会经济影响研究。这就是为什么新发表的报告受到环保组织以及业内人士的广泛关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260331-pfas-%E6%AC%A7%E6%B4%B2%E5%8C%96%E5%AD%A6%E5%93%81%E7%AE%A1%E7%90%86%E5%B1%80%E5%BB%BA%E8%AE%AE-%E5%B9%BF%E6%B3%9B%E9%99%90%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774959077000.webp","sourceId":"rfi"},{"id":1774958774000,"createdDate":"2026-03-31 12:06","name":"法国国际广播电台","title":"伊朗首都德黑兰和中部军事设施遭袭击发生巨大爆炸","content":"伊朗首都德黑兰及中部地区周一至周二发生多起巨大爆炸，美以的袭击目标为“军事设施”，并导致停电。此前，唐纳德·特朗普曾再次威胁称，如果华盛顿与德黑兰之间的谈判不能“迅速”取得成果，他将采取进一步行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260331-%E4%BC%8A%E6%9C%97%E9%A6%96%E9%83%BD%E5%BE%B7%E9%BB%91%E5%85%B0%E5%92%8C%E4%B8%AD%E9%83%A8%E5%86%9B%E4%BA%8B%E8%AE%BE%E6%96%BD%E9%81%AD%E8%A2%AD%E5%87%BB%E5%8F%91%E7%94%9F%E5%B7%A8%E5%A4%A7%E7%88%86%E7%82%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774958774000.webp","sourceId":"rfi"},{"id":1774954054000,"createdDate":"2026-03-31 10:47","name":"法国国际广播电台","title":"马克龙访日韩：中东危机、G7筹备与亚太战略的新机遇","content":"本台法语部报道说，在4月2日前往韩国访问之前，法国总统马克龙周二（3月31日）抵达东京，开始对日本为期三天的正式访问。此次访问正值国际局势因中东战争而动荡不安，马克龙的行程也将围绕这一话题展开。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260331-%E9%A9%AC%E5%85%8B%E9%BE%99%E8%AE%BF%E6%97%A5%E9%9F%A9-%E4%B8%AD%E4%B8%9C%E5%8D%B1%E6%9C%BA-g7%E7%AD%B9%E5%A4%87%E4%B8%8E%E4%BA%9A%E5%A4%AA%E6%88%98%E7%95%A5%E7%9A%84%E6%96%B0%E6%9C%BA%E9%81%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/31/1774954054000.webp","sourceId":"rfi"}]