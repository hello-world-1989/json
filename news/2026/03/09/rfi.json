[{"id":1773045610000,"createdDate":"2026-03-09 08:40","name":"法国国际广播电台","title":"中国抗议台湾行政院长访日 日方称没接触政府人士","content":"日本政府相关人士8日证实，中国外交部副部长孙卫东已于7日深夜就台湾行政院院长卓荣泰访日一事打电话给日本驻华大使金杉宪治，表达强烈不满与抗议。日本官房长官木原稔9日在记者会上表示，为了观看世界棒球经典赛（WBC）而来到日本的卓荣泰并未与日本政府相关人士会面。木原表示：“据我所知，台湾方面称这是私人行程。日本政府没有发表评论的立场，他没有与日本政府相关人士接触。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260309-%E4%B8%AD%E5%9B%BD%E6%8A%97%E8%AE%AE%E5%8F%B0%E6%B9%BE%E8%A1%8C%E6%94%BF%E9%99%A2%E9%95%BF%E8%AE%BF%E6%97%A5-%E6%97%A5%E6%96%B9%E7%A7%B0%E6%B2%A1%E6%8E%A5%E8%A7%A6%E6%94%BF%E5%BA%9C%E4%BA%BA%E5%A3%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773045610000.webp","sourceId":"rfi"},{"id":1773043410000,"createdDate":"2026-03-09 08:03","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第24：浪漫主义群星之三：荷尔德林第二节：从康德到斯宾诺莎","content":"在图宾根神学院，荷尔德林遇到了谢林和黑格尔，三人同居一个宿舍。在五年求学期间，荷尔德林受同室的两位哲学天才影响，深入研究哲学，康德无疑是首要功课。但斯宾诺莎，这位隐居海牙，每天磨制眼镜片的荷兰哲人给了他建立诗的王国的理念基础。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260309-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%89-%E8%8D%B7%E5%B0%94%E5%BE%B7%E6%9E%97%E7%AC%AC%E4%BA%8C%E8%8A%82-%E4%BB%8E%E5%BA%B7%E5%BE%B7%E5%88%B0%E6%96%AF%E5%AE%BE%E8%AF%BA%E8%8E%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773043410000.webp","sourceId":"rfi"},{"id":1773043146000,"createdDate":"2026-03-09 07:59","name":"法国国际广播电台","title":"美以攻击伊朗 日本失去以往谴责以色列的勇气","content":"日本时间2月28日，美国和以色列宣布已对伊朗实施攻击,伊朗最高领袖阿里·哈梅内伊在袭击中身亡，而从最近的日本的反应看，日本已不像近些年来，在以色列袭击伊朗的问题上，敢于谴责以色列，而是转为一味批判伊朗，逢迎美国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260309-%E7%BE%8E%E4%BB%A5%E6%94%BB%E5%87%BB%E4%BC%8A%E6%9C%97-%E6%97%A5%E6%9C%AC%E5%A4%B1%E5%8E%BB%E4%BB%A5%E5%BE%80%E8%B0%B4%E8%B4%A3%E4%BB%A5%E8%89%B2%E5%88%97%E7%9A%84%E5%8B%87%E6%B0%94","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773043146000.webp","sourceId":"rfi"},{"id":1773041932000,"createdDate":"2026-03-09 07:38","name":"法国国际广播电台","title":"记协主席郑嘉如告《华尔街》非法解雇 资方提中止聆讯遭驳回","content":"记协主席郑嘉如在2024年当选后不足一个月遭雇主《华尔街日报》(WSJ)以「架构重组」为由解雇，她为此控告WSJ母公司「阻止雇员参与工会」；辩方早前提出中止聆讯申请，被法庭今(9日)早驳回，法官稍后会颁布裁决理由，案件审讯继续。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260309-%E8%AE%B0%E5%8D%8F%E4%B8%BB%E5%B8%AD%E9%83%91%E5%98%89%E5%A6%82%E5%91%8A-%E5%8D%8E%E5%B0%94%E8%A1%97-%E9%9D%9E%E6%B3%95%E8%A7%A3%E9%9B%87-%E8%B5%84%E6%96%B9%E6%8F%90%E4%B8%AD%E6%AD%A2%E8%81%86%E8%AE%AF%E9%81%AD%E9%A9%B3%E5%9B%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773041932000.webp","sourceId":"rfi"},{"id":1773041571000,"createdDate":"2026-03-09 07:32","name":"法国国际广播电台","title":"宏福苑灾场遭盗窃引灾民不满 港府治理能力再受质疑","content":"大埔宏福苑大火发生逾百天，灾民仍未能回家点算损失，却爆出工人藉政府工程盗窃灾场财物事件。警方拘捕三名负责加固工程的工人，指他们涉嫌潜入单位偷走约值九万港元(下同，折算约9995欧元)财物。数百灾民为此联署去信特首李家超表达不满，有灾民指责政府失职，让宏福苑沦为「无掩鸡笼」(门户洞开的意思)。评论指，警方事前未有做好安保工作，事后才亡羊补牢地加强检查，更突显港府治理能力的问题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260309-%E5%AE%8F%E7%A6%8F%E8%8B%91%E7%81%BE%E5%9C%BA%E9%81%AD%E7%9B%97%E7%AA%83%E5%BC%95%E7%81%BE%E6%B0%91%E4%B8%8D%E6%BB%A1-%E6%B8%AF%E5%BA%9C%E6%B2%BB%E7%90%86%E8%83%BD%E5%8A%9B%E5%86%8D%E5%8F%97%E8%B4%A8%E7%96%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773041571000.webp","sourceId":"rfi"},{"id":1773072061000,"createdDate":"2026-03-09 16:01","name":"法国国际广播电台","title":"伊朗/中东战争第十天：最新进展一览","content":"周一（3月9号）是伊朗/中东战争爆发第十天，法新社下午总结了当天部分最新重要进展。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260309-%E4%BC%8A%E6%9C%97-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E7%AC%AC%E5%8D%81%E5%A4%A9-%E6%9C%80%E6%96%B0%E8%BF%9B%E5%B1%95%E4%B8%80%E8%A7%88","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773072061000.webp","sourceId":"rfi"},{"id":1773070161000,"createdDate":"2026-03-09 15:29","name":"法国国际广播电台","title":"SIPRI报告：印度已成亚洲最大武器进口国  法国是全球第二大武器供应国","content":"根据斯德哥尔摩国际和平研究所（SIPRI）最新报告，过去5年全球武器交易量增加近10%，在与中国和巴基斯坦关系紧张的背景下，印度成为亚洲最大武器进口国。在地区地缘局势紧张的背景下，巴基斯坦，日本与台湾的武器进口量同期也大增。同时，由于欧洲需求飙升，全球武器流通量增长近10%。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260309-sipri%E6%8A%A5%E5%91%8A-%E5%8D%B0%E5%BA%A6%E5%B7%B2%E6%88%90%E4%BA%9A%E6%B4%B2%E6%9C%80%E5%A4%A7%E6%AD%A6%E5%99%A8%E8%BF%9B%E5%8F%A3%E5%9B%BD-%E6%B3%95%E5%9B%BD%E6%98%AF%E5%85%A8%E7%90%83%E7%AC%AC%E4%BA%8C%E5%A4%A7%E6%AD%A6%E5%99%A8%E4%BE%9B%E5%BA%94%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773070161000.webp","sourceId":"rfi"},{"id":1773068574000,"createdDate":"2026-03-09 15:02","name":"法国国际广播电台","title":"3.8 妇女节：金正恩称朝鲜女性为“革命坚实支柱”   “心爱的女儿”地位倍受关注","content":"据朝鲜官方媒体周一报道，朝鲜最高领导人金正恩在3.8国际妇女节之际向朝鲜女性致敬，称她们“意志坚强”，是“革命的坚实支柱”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260309-3-8-%E5%A6%87%E5%A5%B3%E8%8A%82-%E9%87%91%E6%AD%A3%E6%81%A9%E7%A7%B0%E6%9C%9D%E9%B2%9C%E5%A5%B3%E6%80%A7%E4%B8%BA-%E9%9D%A9%E5%91%BD%E5%9D%9A%E5%AE%9E%E6%94%AF%E6%9F%B1-%E5%BF%83%E7%88%B1%E7%9A%84%E5%A5%B3%E5%84%BF-%E5%9C%B0%E4%BD%8D%E5%80%8D%E5%8F%97%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773068574000.webp","sourceId":"rfi"},{"id":1773067115000,"createdDate":"2026-03-09 14:38","name":"法国国际广播电台","title":"北约在土耳其拦截第二枚伊朗导弹","content":"土耳其国防部周一发表声明称，北约在土耳其领空摧毁了伊朗发射的第二枚导弹，并在塞浦路斯北部署6架F16战机。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260309-%E5%8C%97%E7%BA%A6%E5%9C%A8%E5%9C%9F%E8%80%B3%E5%85%B6%E6%8B%A6%E6%88%AA%E7%AC%AC%E4%BA%8C%E6%9E%9A%E4%BC%8A%E6%9C%97%E5%AF%BC%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773067115000.webp","sourceId":"rfi"},{"id":1773067086000,"createdDate":"2026-03-09 14:38","name":"法国国际广播电台","title":"MH370失联已12年  搜寻暂停  中国遇难者家属要求马来西亚“透明”处理","content":"MH370航班失踪十二年后，成为民航史上最大的谜团之一。在马来西亚取消新一轮搜寻行动后，中国乘客家属周一要求马来西亚方面“透明”并给出答案，“说出真相！”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260309-mh370%E5%A4%B1%E8%81%94%E5%B7%B212%E5%B9%B4-%E6%90%9C%E5%AF%BB%E6%9A%82%E5%81%9C-%E4%B8%AD%E5%9B%BD%E9%81%87%E9%9A%BE%E8%80%85%E5%AE%B6%E5%B1%9E%E8%A6%81%E6%B1%82%E9%A9%AC%E6%9D%A5%E8%A5%BF%E4%BA%9A-%E9%80%8F%E6%98%8E-%E5%A4%84%E7%90%86","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773067086000.webp","sourceId":"rfi"},{"id":1773066465000,"createdDate":"2026-03-09 14:27","name":"法国国际广播电台","title":"接任伊朗最高领袖 穆杰塔巴·哈梅内伊为何人？","content":"伊朗官方周日晚（3月8日）宣布，已故最高领袖阿里哈梅内伊之子、56岁的宗教人士穆杰塔巴·哈梅内伊接任最高领袖。在美伊持续军事打击伊朗进入第十天之际，这一任命被视为伊朗强硬派继续牢牢掌控政权，释出继续强硬对抗信号。任命宣布翌日，欧亚股市周一大跌，国际油价飙涨突破每桶100美元大关。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260309-%E6%8E%A5%E4%BB%BB%E4%BC%8A%E6%9C%97%E6%9C%80%E9%AB%98%E9%A2%86%E8%A2%96-%E7%A9%86%E6%9D%B0%E5%A1%94%E5%B7%B4-%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E5%85%B6%E4%B8%BA%E4%BD%95%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773066465000.webp","sourceId":"rfi"},{"id":1773061989000,"createdDate":"2026-03-09 13:13","name":"法国国际广播电台","title":"中东战争：马克龙到访塞浦路斯 聚焦讨论地区安全问题","content":"法国总统马克龙周一（3月9号）抵达塞浦路斯，与塞浦路斯和希腊领导人讨论加强地区安全问题。据爱丽舍宫消息，马克龙将于当天下午登上停泊在克里特岛海岸的“戴高乐”号航空母舰。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260309-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%88%B0%E8%AE%BF%E5%A1%9E%E6%B5%A6%E8%B7%AF%E6%96%AF-%E8%81%9A%E7%84%A6%E8%AE%A8%E8%AE%BA%E5%9C%B0%E5%8C%BA%E5%AE%89%E5%85%A8%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773061989000.webp","sourceId":"rfi"},{"id":1773059959000,"createdDate":"2026-03-09 12:39","name":"法国国际广播电台","title":"七国集团财长会议  讨论考虑动用战略石油储备 但“尚未达到那个阶段”","content":"七国集团（G7）财长周一（3月9号）在法国担任轮值主席国期间举行会议，可能会决定动用战略石油储备，以缓解中东战争导致的油价飙升。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260309-%E4%B8%83%E5%9B%BD%E9%9B%86%E5%9B%A2%E8%B4%A2%E9%95%BF%E4%BC%9A%E8%AE%AE-%E8%80%83%E8%99%91%E5%8A%A8%E7%94%A8%E6%88%98%E7%95%A5%E7%9F%B3%E6%B2%B9%E5%82%A8%E5%A4%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773059959000.webp","sourceId":"rfi"},{"id":1773058837000,"createdDate":"2026-03-09 12:20","name":"法国国际广播电台","title":"伊朗推出“敌人憎恨的对象”担任最高领袖发出“坚定信号” ？ 油价飙升 市场动荡","content":"3月9号周一，伊朗与以色列之间的战争已持续十天之际，伊朗正式任命穆杰塔巴·哈梅内伊为最高领袖，接替被以美斩首的父亲阿里·哈梅内伊职位，开启伊朗“新时代”。这场战争已经引发市场恐慌，并导致油价飙升。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260309-%E4%BC%8A%E6%9C%97%E6%8E%A8%E5%87%BA-%E6%95%8C%E4%BA%BA%E6%86%8E%E6%81%A8%E7%9A%84%E5%AF%B9%E8%B1%A1-%E6%8B%85%E4%BB%BB%E6%9C%80%E9%AB%98%E9%A2%86%E8%A2%96%E5%8F%91%E5%87%BA-%E5%9D%9A%E5%AE%9A%E4%BF%A1%E5%8F%B7-%E6%B2%B9%E4%BB%B7%E9%A3%99%E5%8D%87-%E5%B8%82%E5%9C%BA%E5%8A%A8%E8%8D%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773058837000.webp","sourceId":"rfi"},{"id":1773057847000,"createdDate":"2026-03-09 12:04","name":"法国国际广播电台","title":"中国：通胀率创三年来新高","content":"中国国家统计局周一公布的数据显示，2月份中国消费者物价指数（CPI）同比上涨1.3%。消费者物价指数是衡量通胀的关键指标。周一宣布的指数涨幅自2023年1月（2.1%）以来最大的，也是三年多来的最高涨幅。2月份正值农历新年假期，政府原本希望春节假期能提振消费。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260309-%E4%B8%AD%E5%9B%BD-%E9%80%9A%E8%83%80%E7%8E%87%E5%88%9B%E4%B8%89%E5%B9%B4%E6%9D%A5%E6%96%B0%E9%AB%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773057847000.webp","sourceId":"rfi"},{"id":1773056732000,"createdDate":"2026-03-09 11:45","name":"法国国际广播电台","title":"法国呼吁伊朗做出“重大让步” “ 将人民的未来交还给他们”","content":"法国外长让-诺埃尔·巴罗周一强调，伊朗当局必须“做出重大让步，并彻底改变立场”。前一天，伊朗宣布了新任最高领袖。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260309-%E6%B3%95%E5%9B%BD%E5%91%BC%E5%90%81%E4%BC%8A%E6%9C%97%E5%81%9A%E5%87%BA-%E9%87%8D%E5%A4%A7%E8%AE%A9%E6%AD%A5-%E5%B0%86%E4%BA%BA%E6%B0%91%E7%9A%84%E6%9C%AA%E6%9D%A5%E4%BA%A4%E8%BF%98%E7%BB%99%E4%BB%96%E4%BB%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773056732000.webp","sourceId":"rfi"},{"id":1773055661000,"createdDate":"2026-03-09 11:27","name":"法国国际广播电台","title":"路透： 特朗普访华 “国事访问规模不断缩减”  可能不会取得突破  旨在维持稳定","content":"路透社周一（3月9号）引述五位了解筹备情况的人士表示，美国总统唐纳德·特朗普和中国国家主席习近平本月底举行的峰会不太可能为哪怕是有限地重启经贸和投资关系创造空间。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260309-%E8%B7%AF%E9%80%8F-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E-%E5%9B%BD%E4%BA%8B%E8%AE%BF%E9%97%AE%E8%A7%84%E6%A8%A1%E4%B8%8D%E6%96%AD%E7%BC%A9%E5%87%8F-%E5%8F%AF%E8%83%BD%E4%B8%8D%E4%BC%9A%E5%8F%96%E5%BE%97%E7%AA%81%E7%A0%B4-%E6%97%A8%E5%9C%A8%E7%BB%B4%E6%8C%81%E7%A8%B3%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773055661000.webp","sourceId":"rfi"},{"id":1773046906000,"createdDate":"2026-03-09 09:01","name":"法国国际广播电台","title":"伊朗：穆杰塔巴继任父位  革命卫队宣誓效忠  美以警告  中国反对外国干预","content":"56岁的阿亚图拉·穆杰塔巴·哈梅内伊（MojtabaKhamenei）周日（3月8号）被由88名什叶派神职人员组成的“专家会议”推选为最高领袖，接替于2月28日美以发动战争第一天就遇害的父亲阿里·哈梅内伊的职位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260309-%E4%BC%8A%E6%9C%97-%E7%A9%86%E6%9D%B0%E5%A1%94%E5%B7%B4%E4%BB%BB%E7%BB%A7%E4%BB%BB%E7%88%B6%E4%BD%8D-%E9%9D%A9%E5%91%BD%E5%8D%AB%E9%98%9F%E5%AE%A3%E8%AA%93%E6%95%88%E5%BF%A0-%E7%BE%8E%E4%BB%A5%E8%AD%A6%E5%91%8A-%E4%B8%AD%E5%9B%BD%E5%8F%8D%E5%AF%B9%E5%A4%96%E5%9B%BD%E5%B9%B2%E9%A2%84","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773046906000.webp","sourceId":"rfi"},{"id":1773046259000,"createdDate":"2026-03-09 08:50","name":"法国国际广播电台","title":"中国军机绕台活动近期明显减少 专家分析多种可能原因","content":"台湾在过去十天中有九天未侦测到中国军机在岛屿周边活动，这一近年来罕见出现的下降情况引发关注，专家提出多种可能原因的分析。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260309-%E4%B8%AD%E5%9B%BD%E5%86%9B%E6%9C%BA%E7%BB%95%E5%8F%B0%E6%B4%BB%E5%8A%A8%E8%BF%91%E6%9C%9F%E6%98%8E%E6%98%BE%E5%87%8F%E5%B0%91-%E4%B8%93%E5%AE%B6%E6%8F%90%E5%87%BA%E5%A4%9A%E7%A7%8D%E5%8F%AF%E8%83%BD%E5%8E%9F%E5%9B%A0%E5%88%86%E6%9E%90","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773046259000.webp","sourceId":"rfi"},{"id":1773099440000,"createdDate":"2026-03-09 23:37","name":"法国国际广播电台","title":"尽管伊朗战争在持续，但中国仍然准备接待特朗普本月底访华","content":"法国世界报周一表示，尽管伊朗战争在持续，但中国仍然准备在本月底接待特朗普访华。该报表示，中国外交部长王毅在全国人大记者会上的发言让人明白，中国倾向于维持特朗普访华。3月8日，在年度记者会上，中国外长王毅一方面谴责伊朗战争，另一方面避免直接批评美国，同时，王毅还强调今年对中美关系十分关键。这为美国总统特朗普可能在3月底访问中国留下了外交空间。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260309-%E5%B0%BD%E7%AE%A1%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E5%9C%A8%E6%8C%81%E7%BB%AD%EF%BC%8C%E4%BD%86%E4%B8%AD%E5%9B%BD%E4%BB%8D%E7%84%B6%E5%87%86%E5%A4%87%E6%8E%A5%E5%BE%85%E7%89%B9%E6%9C%97%E6%99%AE%E6%9C%AC%E6%9C%88%E5%BA%95%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773099440000.webp","sourceId":"rfi"},{"id":1773099253000,"createdDate":"2026-03-09 23:34","name":"法国国际广播电台","title":"严重依赖海湾石油和天然气，巴基斯坦宣布一系列紧缩措施","content":"由于原油价格飙升，巴基斯坦总理谢里夫周一公布了一系列旨在降低燃油消耗的紧缩措施：政府每周实施4天工作制、提倡远程办公，学校也延长假期，减少公务旅行等等。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260309-%E4%B8%A5%E9%87%8D%E4%BE%9D%E8%B5%96%E6%B5%B7%E6%B9%BE%E7%9F%B3%E6%B2%B9%E5%92%8C%E5%A4%A9%E7%84%B6%E6%B0%94%EF%BC%8C%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%AE%A3%E5%B8%83%E4%B8%80%E7%B3%BB%E5%88%97%E7%B4%A7%E7%BC%A9%E6%8E%AA%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773099253000.webp","sourceId":"rfi"},{"id":1773091190000,"createdDate":"2026-03-09 21:19","name":"法国国际广播电台","title":"马克龙：“仅仅通过轰炸”无法实现政权更迭","content":"法国总统马克龙9日访问塞浦路斯，并与塞浦路斯总统、希腊总理会晤，以彰显欧盟的“团结”。马克龙是乘坐直升机降落在航空母舰上的。法国已将戴高乐号核动力航母从北大西洋调往地中海东部，目前在克里特岛（Crète）附近，向东行进，目的是应对中东冲突升级、保护盟友（如塞浦路斯）和海上航线安全。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260309-%E9%A9%AC%E5%85%8B%E9%BE%99-%E4%BB%85%E4%BB%85%E9%80%9A%E8%BF%87%E8%BD%B0%E7%82%B8-%E6%97%A0%E6%B3%95%E5%AE%9E%E7%8E%B0%E6%94%BF%E6%9D%83%E6%9B%B4%E8%BF%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773091190000.webp","sourceId":"rfi"},{"id":1773090971000,"createdDate":"2026-03-09 21:16","name":"法国国际广播电台","title":"霍尔木兹海峡：装成中国船未成攻击目标","content":"美国和以色列对伊朗发动军事打击后，连接波斯湾和阿曼湾的霍尔木兹海峡通行非常困难。伊方程仅仅禁止美国、以色列、欧洲船只通行，由此船舶在海湾地区航行或停泊时伪装，或说的好听一些，改为“中国船东”“全员中国船员”或“船上有中国船员”，以免遭受攻击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260309-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E8%A3%85%E6%88%90%E4%B8%AD%E5%9B%BD%E8%88%B9%E6%9C%AA%E6%88%90%E6%94%BB%E5%87%BB%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773090971000.webp","sourceId":"rfi"},{"id":1773090618000,"createdDate":"2026-03-09 21:10","name":"法国国际广播电台","title":"英警告中东局势将带来通货膨胀","content":"英国财政大臣蕾切尔·里夫斯（RachelReeves）周一警告称，中东战争有可能再次引发通货膨胀，飙升的油气价格加剧了人们对重大经济危机的担忧。她还表示：“中东局势的经济影响当然取决于其严重程度和持续时间”。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260309-%E8%8B%B1%E8%AD%A6%E5%91%8A%E4%B8%AD%E4%B8%9C%E5%B1%80%E5%8A%BF%E5%B0%86%E5%B8%A6%E6%9D%A5%E9%80%9A%E8%B4%A7%E8%86%A8%E8%83%80","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773090618000.webp","sourceId":"rfi"},{"id":1773090434000,"createdDate":"2026-03-09 21:07","name":"法国国际广播电台","title":"佐格比民调公司：“特朗普面临失去一切的风险”","content":"距离美国中期选举不到八个月的时间，旷日持久的战争前景很可能会对竞选产生重大影响。美国国会共和党议员周一在佛罗里达州举行重要战略会议。佐格比（JohnZogby）民调公司表示，特朗普有可能在11月失去参众两院的多数席位，他“面临失去一切的风险”！","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260309-%E4%BD%90%E6%A0%BC%E6%AF%94%E6%B0%91%E8%B0%83%E5%85%AC%E5%8F%B8-%E7%89%B9%E6%9C%97%E6%99%AE%E9%9D%A2%E4%B8%B4%E5%A4%B1%E5%8E%BB%E4%B8%80%E5%88%87%E7%9A%84%E9%A3%8E%E9%99%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773090434000.webp","sourceId":"rfi"},{"id":1773090270000,"createdDate":"2026-03-09 21:04","name":"法国国际广播电台","title":"油价飙升    特朗普没有很多备选方案","content":"伊朗战争持续十日且外溢超预期，引发全球资产价格剧烈震荡：原油价格暴涨超50%，日韩股市因依赖中东能源且前期涨幅过大而大幅下跌。中东冲突导致的油价飙升会对11月份的美国中期选举产生负面影响。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260309-%E6%B2%B9%E4%BB%B7%E9%A3%99%E5%8D%87-%E7%89%B9%E6%9C%97%E6%99%AE%E6%B2%A1%E6%9C%89%E5%BE%88%E5%A4%9A%E5%A4%87%E9%80%89%E6%96%B9%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773090270000.webp","sourceId":"rfi"},{"id":1773089987000,"createdDate":"2026-03-09 20:59","name":"法国国际广播电台","title":"黎巴嫩总统指责真主党      提议与以色列谈判","content":"黎巴嫩总统约瑟夫·奥恩（JosephAoun）周一指责亲伊朗的真主党企图“让黎巴嫩崩溃”，并提议与以色列进行“直接谈判”。以色列已对黎巴嫩进行了一周的轰炸。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260309-%E9%BB%8E%E5%B7%B4%E5%AB%A9%E6%80%BB%E7%BB%9F%E6%8C%87%E8%B4%A3%E7%9C%9F%E4%B8%BB%E5%85%9A-%E6%8F%90%E8%AE%AE%E4%B8%8E%E4%BB%A5%E8%89%B2%E5%88%97%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773089987000.webp","sourceId":"rfi"},{"id":1773089877000,"createdDate":"2026-03-09 20:57","name":"法国国际广播电台","title":"联合国：战争污染环境      危及饮用水","content":"联合国秘书长发言人周一警告称，中东地区持续不断的石油设施袭击事件将造成“严重的环境后果”，并可能对饮用水和空气质量产生影响。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260309-%E8%81%94%E5%90%88%E5%9B%BD-%E6%88%98%E4%BA%89%E6%B1%A1%E6%9F%93%E7%8E%AF%E5%A2%83-%E5%8D%B1%E5%8F%8A%E9%A5%AE%E7%94%A8%E6%B0%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773089877000.webp","sourceId":"rfi"},{"id":1773089637000,"createdDate":"2026-03-09 20:53","name":"法国国际广播电台","title":"纽约时报反战文章：特朗普也许会后悔对伊朗开战","content":"美国纽约时报题为“特朗普也许会后悔对伊朗开战”的文章写道：“我们不能对反复非法使用美国军队的行为麻木不仁。我们也不应低估特朗普将永久战争扩大化对我们造成的影响。”","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260309-%E7%BA%BD%E7%BA%A6%E6%97%B6%E6%8A%A5%E5%8F%8D%E6%88%98%E6%96%87%E7%AB%A0-%E7%89%B9%E6%9C%97%E6%99%AE%E4%B9%9F%E8%AE%B8%E4%BC%9A%E5%90%8E%E6%82%94%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%BC%80%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773089637000.webp","sourceId":"rfi"},{"id":1773086609000,"createdDate":"2026-03-09 20:03","name":"法国国际广播电台","title":"美以伊空战十天 导弹无人机说了算","content":"周一（3月9日），中东局势持续紧张，海湾国家持续遭到伊朗无人机和导弹袭击。还发生伊朗导弹携带一枚集束弹头袭击以色列中部，其中造成两名中国籍建筑工人一死一重伤。这是自周日到周一夜间以来伊朗对以色列和海湾国家发动的第七次空中攻击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260309-%E7%BE%8E%E4%BB%A5%E4%BC%8A%E7%A9%BA%E6%88%98%E5%8D%81%E5%A4%A9-%E5%AF%BC%E5%BC%B9%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%AF%B4%E4%BA%86%E7%AE%97","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773086609000.webp","sourceId":"rfi"},{"id":1773085745000,"createdDate":"2026-03-09 19:49","name":"法国国际广播电台","title":"南非要面向中国加大锰矿石出口","content":"南非作为全球最大的锰矿（lemanganèse）出口国，准备加大其出口力度。为此，该国准备新建一座每年具有1600万吨锰矿出口能力的大码头。招标预计将于一个月后（2026年04月份）开始。这是本台法广（RFI）法语[原材料]专栏（laChroniquedesMatièresPremières）今天（2026年03月09日）周一的最新法文消息之一。在全球锰矿出口中，南非的比重接近40%。南非锰矿的主要出口地是中国。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260309-%E6%B3%95%E5%B9%BFrfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%8D%97%E9%9D%9E%E8%A6%81%E9%9D%A2%E5%90%91%E4%B8%AD%E5%9B%BD%E5%8A%A0%E5%A4%A7%E9%94%B0%E7%9F%BF%E7%9F%B3%E5%87%BA%E5%8F%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773085745000.webp","sourceId":"rfi"},{"id":1773078855000,"createdDate":"2026-03-09 17:54","name":"法国国际广播电台","title":"民调显示特朗普施政支持率下滑　民主党在国会选情暂领先","content":"最新全国民调显示，美国总统特朗普（DonaldTrump）的施政支持率出现下滑，同时两大政党的整体形象均面临严峻挑战。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260309-%E6%B0%91%E8%B0%83%E6%98%BE%E7%A4%BA%E7%89%B9%E6%9C%97%E6%99%AE%E6%96%BD%E6%94%BF%E6%94%AF%E6%8C%81%E7%8E%87%E4%B8%8B%E6%BB%91-%E6%B0%91%E4%B8%BB%E5%85%9A%E5%9C%A8%E5%9B%BD%E4%BC%9A%E9%80%89%E6%83%85%E6%9A%82%E9%A2%86%E5%85%88","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773078855000.webp","sourceId":"rfi"}]