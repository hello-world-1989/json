[{"id":1773045610000,"createdDate":"2026-03-09 08:40","name":"法国国际广播电台","title":"中国抗议台湾行政院长访日 日方称没接触政府人士","content":"日本政府相关人士8日证实，中国外交部副部长孙卫东已于7日深夜就台湾行政院院长卓荣泰访日一事打电话给日本驻华大使金杉宪治，表达强烈不满与抗议。日本官房长官木原稔9日在记者会上表示，为了观看世界棒球经典赛（WBC）而来到日本的卓荣泰并未与日本政府相关人士会面。木原表示：“据我所知，台湾方面称这是私人行程。日本政府没有发表评论的立场，他没有与日本政府相关人士接触。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260309-%E4%B8%AD%E5%9B%BD%E6%8A%97%E8%AE%AE%E5%8F%B0%E6%B9%BE%E8%A1%8C%E6%94%BF%E9%99%A2%E9%95%BF%E8%AE%BF%E6%97%A5-%E6%97%A5%E6%96%B9%E7%A7%B0%E6%B2%A1%E6%8E%A5%E8%A7%A6%E6%94%BF%E5%BA%9C%E4%BA%BA%E5%A3%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773045610000.webp","sourceId":"rfi"},{"id":1773043410000,"createdDate":"2026-03-09 08:03","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第24：浪漫主义群星之三：荷尔德林第二节：从康德到斯宾诺莎","content":"在图宾根神学院，荷尔德林遇到了谢林和黑格尔，三人同居一个宿舍。在五年求学期间，荷尔德林受同室的两位哲学天才影响，深入研究哲学，康德无疑是首要功课。但斯宾诺莎，这位隐居海牙，每天磨制眼镜片的荷兰哲人给了他建立诗的王国的理念基础。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260309-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%89-%E8%8D%B7%E5%B0%94%E5%BE%B7%E6%9E%97%E7%AC%AC%E4%BA%8C%E8%8A%82-%E4%BB%8E%E5%BA%B7%E5%BE%B7%E5%88%B0%E6%96%AF%E5%AE%BE%E8%AF%BA%E8%8E%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773043410000.webp","sourceId":"rfi"},{"id":1773043146000,"createdDate":"2026-03-09 07:59","name":"法国国际广播电台","title":"美以攻击伊朗 日本失去以往谴责以色列的勇气","content":"日本时间2月28日，美国和以色列宣布已对伊朗实施攻击,伊朗最高领袖阿里·哈梅内伊在袭击中身亡，而从最近的日本的反应看，日本已不像近些年来，在以色列袭击伊朗的问题上，敢于谴责以色列，而是转为一味批判伊朗，逢迎美国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260309-%E7%BE%8E%E4%BB%A5%E6%94%BB%E5%87%BB%E4%BC%8A%E6%9C%97-%E6%97%A5%E6%9C%AC%E5%A4%B1%E5%8E%BB%E4%BB%A5%E5%BE%80%E8%B0%B4%E8%B4%A3%E4%BB%A5%E8%89%B2%E5%88%97%E7%9A%84%E5%8B%87%E6%B0%94","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773043146000.webp","sourceId":"rfi"},{"id":1773041932000,"createdDate":"2026-03-09 07:38","name":"法国国际广播电台","title":"记协主席郑嘉如告《华尔街》非法解雇 资方提中止聆讯遭驳回","content":"记协主席郑嘉如在2024年当选后不足一个月遭雇主《华尔街日报》(WSJ)以「架构重组」为由解雇，她为此控告WSJ母公司「阻止雇员参与工会」；辩方早前提出中止聆讯申请，被法庭今(9日)早驳回，法官稍后会颁布裁决理由，案件审讯继续。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260309-%E8%AE%B0%E5%8D%8F%E4%B8%BB%E5%B8%AD%E9%83%91%E5%98%89%E5%A6%82%E5%91%8A-%E5%8D%8E%E5%B0%94%E8%A1%97-%E9%9D%9E%E6%B3%95%E8%A7%A3%E9%9B%87-%E8%B5%84%E6%96%B9%E6%8F%90%E4%B8%AD%E6%AD%A2%E8%81%86%E8%AE%AF%E9%81%AD%E9%A9%B3%E5%9B%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773041932000.webp","sourceId":"rfi"},{"id":1773041571000,"createdDate":"2026-03-09 07:32","name":"法国国际广播电台","title":"宏福苑灾场遭盗窃引灾民不满 港府治理能力再受质疑","content":"大埔宏福苑大火发生逾百天，灾民仍未能回家点算损失，却爆出工人藉政府工程盗窃灾场财物事件。警方拘捕三名负责加固工程的工人，指他们涉嫌潜入单位偷走约值九万港元(下同，折算约9995欧元)财物。数百灾民为此联署去信特首李家超表达不满，有灾民指责政府失职，让宏福苑沦为「无掩鸡笼」(门户洞开的意思)。评论指，警方事前未有做好安保工作，事后才亡羊补牢地加强检查，更突显港府治理能力的问题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260309-%E5%AE%8F%E7%A6%8F%E8%8B%91%E7%81%BE%E5%9C%BA%E9%81%AD%E7%9B%97%E7%AA%83%E5%BC%95%E7%81%BE%E6%B0%91%E4%B8%8D%E6%BB%A1-%E6%B8%AF%E5%BA%9C%E6%B2%BB%E7%90%86%E8%83%BD%E5%8A%9B%E5%86%8D%E5%8F%97%E8%B4%A8%E7%96%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/09/1773041571000.webp","sourceId":"rfi"}]