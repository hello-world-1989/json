[{"id":1772526820000,"createdDate":"2026-03-03 08:33","name":"法国国际广播电台","title":"北京撤销韩卫国等三名将军的政协委员资格","content":"法新社北京消息，在两会即将召开之前，据中国官方媒体报道，中国最高政协机构投票撤销了韩卫国、刘雷和高津三名将军的职务。另外就在一周前，已有九名军方官员被撤销了全国人大的代表资格。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260303-%E5%8C%97%E4%BA%AC%E6%92%A4%E9%94%80%E4%B8%89%E5%90%8D%E5%B0%86%E5%86%9B%E7%9A%84%E6%94%BF%E5%8D%8F%E5%A7%94%E5%91%98%E8%B5%84%E6%A0%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772526820000.webp","sourceId":"rfi"},{"id":1772522777000,"createdDate":"2026-03-03 07:26","name":"法国国际广播电台","title":"伊朗战事料令香港空运成本加三成 学者忧战火持续致全球滞胀","content":"中东战火持续，海空货运均大受影响而令成本和价格上升，两名香港经济学者预料，情况会带动香港通胀，甚至会导致环球滞涨，即经济倒退但通胀上升。其严重程度须视乎战事持续的时间，越久则影响越深远。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260303-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%8B%E6%96%99%E4%BB%A4%E9%A6%99%E6%B8%AF%E7%A9%BA%E8%BF%90%E6%88%90%E6%9C%AC%E5%8A%A0%E4%B8%89%E6%88%90-%E5%AD%A6%E8%80%85%E5%BF%A7%E6%88%98%E7%81%AB%E6%8C%81%E7%BB%AD%E8%87%B4%E5%85%A8%E7%90%83%E6%BB%9E%E8%83%80","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772522777000.webp","sourceId":"rfi"},{"id":1772522411000,"createdDate":"2026-03-03 07:20","name":"法国国际广播电台","title":"民调：港人重视推动中国民主人权丶轻经济 与港府政策相悖 学者叹港人已不懂不满","content":"一项涵盖海内外港人的民意调查结果显示，较多受访者认为，港人有责任推动中国的民主和人权发展，比率远高于认为港人有责任推动中国经济发展的比例；受访者亦较多不同意「先发展经济，之后再推动民主发展及人权改善」的说法。相关结果，与香港政府现时强调要与中国「十五五」规划对接丶不谈人权民主的政策相反。民调负责人锺剑华指出，这可能是因为不少港人认为，若中国人权不改善，香港现时受压的情况难有突破；至于港府政策与民意相违会否引发不满，锺坦言，现在更大的问题是，港人不懂得不满。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260303-%E6%B0%91%E8%B0%83-%E6%B8%AF%E4%BA%BA%E9%87%8D%E8%A7%86%E6%8E%A8%E5%8A%A8%E4%B8%AD%E5%9B%BD%E6%B0%91%E4%B8%BB%E4%BA%BA%E6%9D%83%E4%B8%B6%E8%BD%BB%E7%BB%8F%E6%B5%8E-%E4%B8%8E%E6%B8%AF%E5%BA%9C%E6%94%BF%E7%AD%96%E7%9B%B8%E6%82%96-%E5%AD%A6%E8%80%85%E5%8F%B9%E6%B8%AF%E4%BA%BA%E5%B7%B2%E4%B8%8D%E6%87%82%E4%B8%8D%E6%BB%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772522411000.webp","sourceId":"rfi"},{"id":1772556050000,"createdDate":"2026-03-03 16:40","name":"法国国际广播电台","title":"卫星捕捉伊朗控制霍尔木兹海峡的阿巴斯军港惨状：四舰齐燃，昼夜不停！","content":"在中东战争进入第四天之际，据《纽约时报》对卫星影像的深入分析显示，位于伊朗南部的阿巴斯港（BandarAbbas）海军基地在近期袭击中遭受重创。根据最新公布的照片，该基地至少有四艘军舰正冒出浓烟，且火势已持续燃烧超过24小时。影像画面显示，现场目前并未出现明显的抢救行动迹象，情势显得十分严峻。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260303-%E5%8D%AB%E6%98%9F%E6%8D%95%E6%8D%89%E4%BC%8A%E6%9C%97%E6%8E%A7%E5%88%B6%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%9A%84%E9%98%BF%E5%B7%B4%E6%96%AF%E5%86%9B%E6%B8%AF%E6%83%A8%E7%8A%B6-%E5%9B%9B%E8%88%B0%E9%BD%90%E7%87%83%EF%BC%8C%E6%98%BC%E5%A4%9C%E4%B8%8D%E5%81%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772556050000.webp","sourceId":"rfi"},{"id":1772552565000,"createdDate":"2026-03-03 15:42","name":"法国国际广播电台","title":"美媒：全球伊朗人疯传“特朗普舞” 以表反哈梅内伊神权统治心情","content":"近日，全球各地的伊朗人在社交媒体上掀起了一场模仿热潮，通过跳起美国总统特朗普造势大会上标志性的舞步，以此庆祝美国主导的空袭行动击毙了伊朗最高领袖哈梅内伊。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260303-%E7%BE%8E%E5%AA%92-%E5%85%A8%E7%90%83%E4%BC%8A%E6%9C%97%E4%BA%BA%E7%96%AF%E4%BC%A0-%E7%89%B9%E6%9C%97%E6%99%AE%E8%88%9E-%E5%8F%8D%E6%8A%97%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E7%A5%9E%E6%9D%83%E7%BB%9F%E6%B2%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772552565000.webp","sourceId":"rfi"},{"id":1772552314000,"createdDate":"2026-03-03 15:38","name":"法国国际广播电台","title":"中东战事第四天：以伊发动新一轮攻击 以军扩占黎巴嫩新据点","content":"以色列与美国对伊朗发动军事打击进入第四天，战火进一步蔓延至黎巴嫩、海湾国家以及更多中东地区。各方军事打击仍在升级，德黑兰周二（3月3日）袭击海湾国家与美国相关的设施。以色列则继续“同时”轰炸伊朗和黎巴嫩，并宣布向黎巴嫩增派部队扩大占领新的据点。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260303-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%8B%E7%AC%AC%E5%9B%9B%E5%A4%A9-%E4%BB%A5%E4%BC%8A%E5%8F%91%E5%8A%A8%E6%96%B0%E4%B8%80%E8%BD%AE%E6%94%BB%E5%87%BB-%E4%BB%A5%E5%86%9B%E6%89%A9%E5%8D%A0%E9%BB%8E%E5%B7%B4%E5%AB%A9%E6%96%B0%E6%8D%AE%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772552314000.webp","sourceId":"rfi"},{"id":1772551959000,"createdDate":"2026-03-03 15:32","name":"法国国际广播电台","title":"【视频】以色列：空袭德黑兰 伊朗国家电视台总部被炸","content":"美国和以色列对伊朗发动战争进入第四天，德黑兰和其他伊朗主要城市继续遭到轰炸。伊朗也持续进行反击，目标锁定以色列及中东的军事基地。伊朗国家电视台总部也遭到空袭。当局敦促伊朗民众留在家中。和法广同属法国世界媒体集团的法国电视24台的记者西蒙·莫里茨和艾蒂安·帕波诺对此进行了报道","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260303-%E8%A7%86%E9%A2%91-%E4%BB%A5%E8%89%B2%E5%88%97-%E7%A9%BA%E8%A2%AD%E5%BE%B7%E9%BB%91%E5%85%B0-%E4%BC%8A%E6%9C%97%E5%9B%BD%E5%AE%B6%E7%94%B5%E8%A7%86%E5%8F%B0%E6%80%BB%E9%83%A8%E8%A2%AB%E7%82%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772551959000.webp","sourceId":"rfi"},{"id":1772551697000,"createdDate":"2026-03-03 15:28","name":"法国国际广播电台","title":"俄罗斯外长担忧美以空袭伊朗后会出现核军备扩散","content":"俄罗斯外长拉夫罗夫今天周二警告称，美国和以色列联合对德黑兰发动的战争可能会适得其反，促使伊朗及阿拉伯邻国寻求发展核武器。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260303-%E4%BF%84%E7%BD%97%E6%96%AF%E5%A4%96%E9%95%BF%E6%8B%85%E5%BF%A7%E7%BE%8E%E4%BB%A5%E7%A9%BA%E8%A2%AD%E4%BC%8A%E6%9C%97%E5%90%8E%E4%BC%9A%E5%87%BA%E7%8E%B0%E6%A0%B8%E5%86%9B%E5%A4%87%E6%89%A9%E6%95%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772551697000.webp","sourceId":"rfi"},{"id":1772550664000,"createdDate":"2026-03-03 15:11","name":"法国国际广播电台","title":"互联网热传“公职躺平地图”，官媒厉批“用心不良”引来嘲讽","content":"据中央社报道，中国经济走下坡，民众报考公职变得热门，不料在中国年轻人中盛行的“躺平”风，竟也刮向竞争最激烈的“考公”领域。近来网上热传的“考公最闲岗位排名”，折射出民众考公心态的转变，也引发《人民日报》等官媒发文批判。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260303-%E4%BA%92%E8%81%94%E7%BD%91%E7%83%AD%E4%BC%A0-%E5%85%AC%E8%81%8C%E8%BA%BA%E5%B9%B3%E5%9C%B0%E5%9B%BE-%EF%BC%8C%E5%AE%98%E5%AA%92%E5%8E%89%E6%89%B9-%E7%94%A8%E5%BF%83%E4%B8%8D%E8%89%AF-%E5%BC%95%E6%9D%A5%E5%98%B2%E8%AE%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772550664000.webp","sourceId":"rfi"},{"id":1772547167000,"createdDate":"2026-03-03 14:12","name":"法国国际广播电台","title":"上诉法院驳回特朗普政府返还已缴关税的延期请求，退款金额达1750亿美元","content":"继美国最高法院2月20日裁决特朗普政府大规模关税违宪后，美国总统特朗普再逢法庭败绩。联邦上诉法院驳回了政府推迟关税退税之争后续步骤的请求，下令立即采取行动重启相关法律程序，将案件发回国际贸易法院。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260303-%E4%B8%8A%E8%AF%89%E6%B3%95%E9%99%A2%E9%A9%B3%E5%9B%9E%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E8%BF%94%E8%BF%98%E5%B7%B2%E7%BC%B4%E5%85%B3%E7%A8%8E%E7%9A%84%E5%BB%B6%E6%9C%9F%E8%AF%B7%E6%B1%82%EF%BC%8C%E9%87%91%E9%A2%9D%E8%BE%BE1750%E4%BA%BF%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772547167000.webp","sourceId":"rfi"},{"id":1772543223000,"createdDate":"2026-03-03 13:07","name":"法国国际广播电台","title":"冰川专家呼吁关注冰川消融问题","content":"冰川融化将导致水资源短缺和海平面上升等问题，影响人们的未来，冰川学家海蒂·塞维斯特通过拍摄亲身科技探险经历的《冰川消失调查》纪录片强调进行科普和唤醒人们保护自然意识的重要性，特别是在全球地缘政治关系复杂的背景下，揭示了冰川消融与各国当前治理措施息息相关。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260303-%E5%86%B0%E5%B7%9D%E4%B8%93%E5%AE%B6%E5%91%BC%E5%90%81%E5%85%B3%E6%B3%A8%E5%86%B0%E5%B7%9D%E6%B6%88%E8%9E%8D%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772543223000.webp","sourceId":"rfi"},{"id":1772538559000,"createdDate":"2026-03-03 11:49","name":"法国国际广播电台","title":"伊朗称封锁霍尔木兹海峡后，中国敦促各方维护海峡安全","content":"法新社北京消息称，中国呼吁中东战争各方维护霍尔木兹海峡这一石油和天然气关键航线的安全，并誓言将采取措施确保自身的能源安全。另外，美国国务卿卢比奥昨天2日对记者说，美国将采取行动应对美伊冲突造成能源价格飙涨的局面，并透露美国财长贝森特和能源部长赖特将于今天3日公布相关计划。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260303-%E4%BC%8A%E6%9C%97%E7%A7%B0%E5%B0%81%E9%94%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%90%8E%EF%BC%8C%E4%B8%AD%E5%9B%BD%E6%95%A6%E4%BF%83%E5%90%84%E6%96%B9%E7%BB%B4%E6%8A%A4%E6%B5%B7%E5%B3%A1%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772538559000.webp","sourceId":"rfi"},{"id":1772534398000,"createdDate":"2026-03-03 10:39","name":"法国国际广播电台","title":"特朗普: 英美关系已经今非昔比, 斯塔默一直不配合","content":"美国总统特朗普暗示，为了迎合穆斯林选民，英国首相斯塔默不支持他对伊朗的战争，并警告说，英国“已经不再是以前那个熟悉的国家了”。特朗普在接受《太阳报》采访时表示：“阻止那些仇恨你们的外国公民入境。”","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260303-%E7%89%B9%E6%9C%97%E6%99%AE-%E8%8B%B1%E7%BE%8E%E5%85%B3%E7%B3%BB%E5%B7%B2%E7%BB%8F%E4%BB%8A%E9%9D%9E%E6%98%94%E6%AF%94-%E6%96%AF%E5%A1%94%E9%BB%98%E4%B8%80%E7%9B%B4%E4%B8%8D%E9%85%8D%E5%90%88","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772534398000.webp","sourceId":"rfi"},{"id":1772531349000,"createdDate":"2026-03-03 09:49","name":"法国国际广播电台","title":"交战第四天：利雅得美国大使馆成目标，黎巴嫩和伊朗再遭袭","content":"法新社利雅得电稿称，由以色列和美国对伊朗发动的袭击引发的中东战争周二（3月3日）进入第四天，战事仍无缓和迹象，沙特阿拉伯首都利雅得的美国大使馆遭无人机袭击，以色列对德黑兰和黎巴嫩的空袭也在持续升级。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260303-%E4%BA%A4%E6%88%98%E7%AC%AC%E5%9B%9B%E5%A4%A9-%E5%88%A9%E9%9B%85%E5%BE%97%E7%BE%8E%E5%9B%BD%E5%A4%A7%E4%BD%BF%E9%A6%86%E9%81%87%E8%A2%AD%EF%BC%8C%E9%BB%8E%E5%B7%B4%E5%AB%A9%E5%92%8C%E4%BC%8A%E6%9C%97%E9%81%AD%E7%A9%BA%E8%A2%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772531349000.webp","sourceId":"rfi"},{"id":1772530606000,"createdDate":"2026-03-03 09:36","name":"法国国际广播电台","title":"伊朗轰炸巴林美军基地 科威特美国大使馆遇袭后关闭","content":"法新社德黑兰华盛顿消息，伊朗伊斯兰革命卫队（IRGC）周二通过官方媒体发布声明说，已对位于巴林的一座美国空军基地发动攻击。与此同时，美国驻科威特大使馆在社媒X平台上发声明说：“鉴于区域局势持续紧张，美国驻科威特大使馆将关闭至另行通知。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260303-%E4%BC%8A%E6%9C%97%E8%BD%B0%E7%82%B8%E5%B7%B4%E6%9E%97%E7%BE%8E%E5%86%9B%E5%9F%BA%E5%9C%B0-%E7%A7%91%E5%A8%81%E7%89%B9%E7%BE%8E%E5%9B%BD%E5%A4%A7%E4%BD%BF%E9%A6%86%E9%81%87%E8%A2%AD%E5%90%8E%E5%85%B3%E9%97%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772530606000.webp","sourceId":"rfi"},{"id":1772530181000,"createdDate":"2026-03-03 09:29","name":"法国国际广播电台","title":"默茨访华：德中关系回暖","content":"德国总理默茨于2月24-26日访问了中国。他在北京强调“战略伙伴关系”，在中国没有使用“竞争对手”这个词，这被媒体普遍认为是德中关系缓和的信号。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9F%8F%E6%9E%97%E9%A3%9E%E9%B8%BF/20260303-%E9%BB%98%E8%8C%A8%E8%AE%BF%E5%8D%8E-%E5%BE%B7%E4%B8%AD%E5%85%B3%E7%B3%BB%E5%9B%9E%E6%9A%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772530181000.webp","sourceId":"rfi"},{"id":1772529513000,"createdDate":"2026-03-03 09:18","name":"法国国际广播电台","title":"日本外务大臣分别会见以色列与伊朗大使 对中东局势表示严重关切","content":"日本时间3月2日，日本外务大臣茂木敏充在当前中东局势背景下，会见了中东各国驻日大使或代理大使。茂木大臣还分别与以色列驻日大使和伊朗驻日大使单独会谈。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260303-%E6%97%A5%E6%9C%AC%E5%A4%96%E5%8A%A1%E5%A4%A7%E8%87%A3%E5%88%86%E5%88%AB%E4%BC%9A%E8%A7%81%E4%BB%A5%E8%89%B2%E5%88%97%E4%B8%8E%E4%BC%8A%E6%9C%97%E5%A4%A7%E4%BD%BF-%E5%AF%B9%E4%B8%AD%E4%B8%9C%E5%B1%80%E5%8A%BF%E8%A1%A8%E7%A4%BA%E4%B8%A5%E9%87%8D%E5%85%B3%E5%88%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772529513000.webp","sourceId":"rfi"},{"id":1772528992000,"createdDate":"2026-03-03 09:09","name":"法国国际广播电台","title":"彭博社：“特习会”前，中美贸易代表三月中在巴黎会晤","content":"彭博社报道，中美首席贸易谈判代表预计三月中旬将在巴黎会晤，这一安排显示尽管美国对伊朗发动空袭，但特朗普三月底访问中国与习近平的峰会仍按计划推进。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260303-%E5%BD%AD%E5%8D%9A%E7%A4%BE-%E7%89%B9%E4%B9%A0%E4%BC%9A-%E5%89%8D%EF%BC%8C%E4%B8%AD%E7%BE%8E%E8%B4%B8%E6%98%93%E4%BB%A3%E8%A1%A8%E4%B8%89%E6%9C%88%E4%B8%AD%E5%9C%A8%E5%B7%B4%E9%BB%8E%E4%BC%9A%E6%99%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772528992000.webp","sourceId":"rfi"},{"id":1772528138000,"createdDate":"2026-03-03 08:55","name":"法国国际广播电台","title":"以色列宣布：以军将“控制”黎巴嫩境内的多个新据点","content":"法新社耶路撒冷消息，以色列国防部长于周二（3月3日）宣布，已授权军队“控制”黎巴嫩境内的多个新据点。目前，以色列在对伊朗作战的同时，正针对黎巴嫩亲伊朗武装组织真主党发动一系列猛烈空袭。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260303-%E4%BB%A5%E8%89%B2%E5%88%97%E5%AE%A3%E5%B8%83%E5%85%B6%E5%86%9B%E9%98%9F%E5%B0%86-%E6%8E%A7%E5%88%B6-%E9%BB%8E%E5%B7%B4%E5%AB%A9%E5%A2%83%E5%86%85%E7%9A%84%E5%A4%9A%E4%B8%AA%E6%96%B0%E6%8D%AE%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/03/1772528138000.webp","sourceId":"rfi"}]