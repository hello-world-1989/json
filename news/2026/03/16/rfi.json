[{"id":1773649593000,"createdDate":"2026-03-16 08:26","name":"法国国际广播电台","title":"因中东战争影响，韩国将取消煤炭发电上限，同时增加核能发电","content":"韩国周一宣布，将取消此前对燃煤发电能力设定的80%上限，并将核能发电的利用率提高到接近同一水平。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260316-%E5%9B%A0%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E5%BD%B1%E5%93%8D%EF%BC%8C%E9%9F%A9%E5%9B%BD%E5%B0%86%E5%8F%96%E6%B6%88%E7%85%A4%E7%82%AD%E5%8F%91%E7%94%B5%E4%B8%8A%E9%99%90%EF%BC%8C%E5%90%8C%E6%97%B6%E5%A2%9E%E5%8A%A0%E6%A0%B8%E8%83%BD%E5%8F%91%E7%94%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773649593000.webp","sourceId":"rfi"},{"id":1773647511000,"createdDate":"2026-03-16 07:51","name":"法国国际广播电台","title":"美国民调：中国民众对台湾抱持相对友善情感，并倾向不对台动武","content":"美国民调结果显示，中国民众对台湾抱持相对友善的情感，多数受访者倾向以非军事手段改善两岸关系美国学界对中国民众进行民调，由非营利组织卡特中心（TheCarterCenter）与艾莫瑞大学（EmoryUniversity）发起并于近日公布。根据中央社报导，民调显示中国民众对台湾抱持相对友善的情感，调查访问中国民众对台湾的感受评分，0到49的评分表示感受到不友好和冷漠，51到100之间表示感到友好和温暖，而中国受访者平均给出62分。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260316-%E7%BE%8E%E5%9B%BD%E6%B0%91%E8%B0%83-%E4%B8%AD%E5%9B%BD%E6%B0%91%E4%BC%97%E5%AF%B9%E5%8F%B0%E6%B9%BE%E6%8A%B1%E6%8C%81%E7%9B%B8%E5%AF%B9%E5%8F%8B%E5%96%84%E6%83%85%E6%84%9F%EF%BC%8C%E5%B9%B6%E5%80%BE%E5%90%91%E4%B8%8D%E5%AF%B9%E5%8F%B0%E5%8A%A8%E6%AD%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773647511000.webp","sourceId":"rfi"},{"id":1773647308000,"createdDate":"2026-03-16 07:48","name":"法国国际广播电台","title":"港警又要求删文 促境外网站删除女督察自杀报道被拒","content":"香港警队一名见习女督察上月在警署内开枪自杀身亡一事，警方仍在调查，但在未有结果前，便致函一个相信是澳洲的网站，以可能违反私隐条例为由，要求删除有关报道，但遭网站拒绝，称事涉公众知情权，质疑警方是欲盖弥彰。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260316-%E6%B8%AF%E8%AD%A6%E5%8F%88%E8%A6%81%E6%B1%82%E5%88%A0%E6%96%87-%E4%BF%83%E5%A2%83%E5%A4%96%E7%BD%91%E7%AB%99%E5%88%A0%E9%99%A4%E5%A5%B3%E7%9D%A3%E5%AF%9F%E8%87%AA%E6%9D%80%E6%8A%A5%E9%81%93%E8%A2%AB%E6%8B%92","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773647308000.webp","sourceId":"rfi"},{"id":1773623567000,"createdDate":"2026-03-16 01:12","name":"法国国际广播电台","title":"特朗普称中国如不参与护航霍尔木兹海峡 或推迟特习会","content":"美国总统特朗普表示，如果中国不采取确保霍尔木兹海峡安全的行动，他可能推迟即将在北京与中国国家主席习近平举行的峰会。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260316-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E4%B8%AD%E5%9B%BD%E5%A6%82%E4%B8%8D%E5%8F%82%E4%B8%8E%E6%8A%A4%E8%88%AA%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E6%88%96%E6%8E%A8%E8%BF%9F%E7%89%B9%E4%B9%A0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773623567000.webp","sourceId":"rfi"},{"id":1773677817000,"createdDate":"2026-03-16 16:16","name":"法国国际广播电台","title":"古巴将允许海外侨民在本国投资并拥有企业 特朗普：会先伊朗再古巴","content":"古巴副总理兼外贸外资部长佩雷斯-奥利瓦（OscarPérez-OlivaFraga）在接受美国全国广播公司（NBC）新闻专访时表示，居住在迈阿密等地的古巴国民将被允许在古巴的私营部门投资并拥有自己的企业。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260316-%E5%8F%A4%E5%B7%B4%E5%B0%86%E5%85%81%E8%AE%B8%E6%B5%B7%E5%A4%96%E4%BE%A8%E6%B0%91%E5%9C%A8%E6%9C%AC%E5%9B%BD%E6%8A%95%E8%B5%84%E5%B9%B6%E6%8B%A5%E6%9C%89%E4%BC%81%E4%B8%9A-%E7%89%B9%E6%9C%97%E6%99%AE-%E4%BC%9A%E5%85%88%E4%BC%8A%E6%9C%97%E5%86%8D%E5%8F%A4%E5%B7%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773677817000.webp","sourceId":"rfi"},{"id":1773674762000,"createdDate":"2026-03-16 15:26","name":"法国国际广播电台","title":"美中巴黎磋商“格外稳定富有建设性” 拟议的贸易、投资委员会受关注","content":"据路透社援引两位知情人士报导称，美中两国高级经济官员周日在巴黎举行了“格外稳定”的会谈，双方就农业、关键矿产以及贸易管理等可能达成共识的领域进行了探讨，供美国总统特朗普和中国国家主席习近平在北京会晤时参考。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260316-%E7%BE%8E%E4%B8%AD%E5%B7%B4%E9%BB%8E%E7%A3%8B%E5%95%86-%E6%A0%BC%E5%A4%96%E7%A8%B3%E5%AE%9A%E5%AF%8C%E6%9C%89%E5%BB%BA%E8%AE%BE%E6%80%A7-%E6%8B%9F%E8%AE%AE%E7%9A%84%E8%B4%B8%E6%98%93-%E6%8A%95%E8%B5%84%E5%A7%94%E5%91%98%E4%BC%9A%E5%8F%97%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773674762000.webp","sourceId":"rfi"},{"id":1773672837000,"createdDate":"2026-03-16 14:53","name":"法国国际广播电台","title":"受网络黑客攻击 欧盟制裁中国和伊朗个人和实体","content":"欧盟理事会今天周一宣布对两家中国公司和一家伊朗公司实施制裁，理由是它们对欧盟成员国发动了网络黑客攻击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260316-%E5%9B%A0%E5%8F%97%E4%B8%AD%E5%9B%BD%E5%92%8C%E4%BC%8A%E6%9C%97%E7%BD%91%E7%BB%9C%E6%94%BB%E5%87%BB-%E6%AC%A7%E7%9B%9F%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773672837000.webp","sourceId":"rfi"},{"id":1773670970000,"createdDate":"2026-03-16 14:22","name":"法国国际广播电台","title":"曾二度受中方制裁是否影响鲁比奥访华 北京：针对的是其担任参议员期间的言行","content":"中国外交部发言人林剑在周一的例行记者会上就美国国务卿鲁比奥（中国大陆旧译“卢比奥”）受中方制裁是否会影响其随特朗普总统访华一事回答说，“中方制裁措施针对的是鲁比奥先生担任联邦参议员期间的涉华言行”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260316-%E6%9B%BE%E4%BA%8C%E5%BA%A6%E5%8F%97%E4%B8%AD%E6%96%B9%E5%88%B6%E8%A3%81%E6%98%AF%E5%90%A6%E5%BD%B1%E5%93%8D%E9%B2%81%E6%AF%94%E5%A5%A5%E8%AE%BF%E5%8D%8E-%E5%8C%97%E4%BA%AC-%E9%92%88%E5%AF%B9%E7%9A%84%E6%98%AF%E5%85%B6%E6%8B%85%E4%BB%BB%E5%8F%82%E8%AE%AE%E5%91%98%E6%9C%9F%E9%97%B4%E7%9A%84%E8%A8%80%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773670970000.webp","sourceId":"rfi"},{"id":1773669396000,"createdDate":"2026-03-16 13:56","name":"法国国际广播电台","title":"王维洛 | 为什么雅鲁藏布江下游水电工程的开工仪式不在自己的工地上举行？","content":"根据新华社报道，2025年7月19日雅鲁藏布江下游水电工程正式开工。雅鲁藏布江下游水电工程是世界上投资最大的水电工程，据称年发电量为三千亿千瓦时，是三峡工程的三倍。世界媒体对这个巨型工程给予高度的关注，但是没有注意到，雅鲁藏布江下游水电工程的开工仪式并没有在自己的工地上举行，而是在林芝市的另一个水库大坝工程——米林水电站的坝址处举行的。为什么？","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260316-%E7%8E%8B%E7%BB%B4%E6%B4%9B-%E4%B8%BA%E4%BB%80%E4%B9%88%E9%9B%85%E9%B2%81%E8%97%8F%E5%B8%83%E6%B1%9F%E4%B8%8B%E6%B8%B8%E6%B0%B4%E7%94%B5%E5%B7%A5%E7%A8%8B%E7%9A%84%E5%BC%80%E5%B7%A5%E4%BB%AA%E5%BC%8F%E4%B8%8D%E5%9C%A8%E8%87%AA%E5%B7%B1%E7%9A%84%E5%B7%A5%E5%9C%B0%E4%B8%8A%E4%B8%BE%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773669396000.webp","sourceId":"rfi"},{"id":1773668243000,"createdDate":"2026-03-16 13:37","name":"法国国际广播电台","title":"白宫：特习会很可能会推迟， 总统目前首要职责是确保对伊行动持续成功","content":"白宫新闻秘书莱维特（KarolineLeavitt）周一向媒体表示，美国总统特朗普拟与中国国家主席习近平举行的峰会并未面临风险，但可能会推迟，特朗普目前仍将注意力集中在对伊朗的军事行动上。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260316-%E7%99%BD%E5%AE%AB-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%BE%88%E5%8F%AF%E8%83%BD%E4%BC%9A%E6%8E%A8%E8%BF%9F%EF%BC%8C-%E6%80%BB%E7%BB%9F%E7%9B%AE%E5%89%8D%E9%A6%96%E8%A6%81%E8%81%8C%E8%B4%A3%E6%98%AF%E7%A1%AE%E4%BF%9D%E5%8F%B2%E8%AF%97%E7%8B%82%E6%80%92%E8%A1%8C%E5%8A%A8%E6%8C%81%E7%BB%AD%E6%88%90%E5%8A%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773668243000.webp","sourceId":"rfi"},{"id":1773665843000,"createdDate":"2026-03-16 12:57","name":"法国国际广播电台","title":"伊朗战争沉重打击亚洲经济","content":"全球经济受到伊朗战争的负面影响，而亚洲成为本次中东战争导致石油供应危机的中心，特别是日本和韩国正因严重依赖从海湾地区进口石油和天然气，影响其经济发展，而中国有庞大的石油储备目前情况相对稍好。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260316-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%B2%89%E9%87%8D%E6%89%93%E5%87%BB%E4%BA%9A%E6%B4%B2%E7%BB%8F%E6%B5%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773665843000.webp","sourceId":"rfi"},{"id":1773665620000,"createdDate":"2026-03-16 12:53","name":"法国国际广播电台","title":"贝森特：若特习会改期将是出于后勤安排，与霍尔木兹海峡无关","content":"美国财政部长贝森特（ScottBessent）周一在巴黎结束了与中方举行的新一轮经贸磋商后表示，特朗普总统与习近平主席的会晤能否如期举行仍有待观察，但任何变动都将是伊朗战争背景下的后勤问题所致。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260316-%E8%B4%9D%E6%A3%AE%E7%89%B9-%E8%8B%A5%E7%89%B9%E4%B9%A0%E4%BC%9A%E6%94%B9%E6%9C%9F%E5%B0%86%E6%98%AF%E5%87%BA%E4%BA%8E%E5%90%8E%E5%8B%A4%E5%AE%89%E6%8E%92%EF%BC%8C%E4%B8%8E%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%97%A0%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773665620000.webp","sourceId":"rfi"},{"id":1773662586000,"createdDate":"2026-03-16 12:03","name":"法国国际广播电台","title":"中国工程院3院士被官网除名 均为军工专家","content":"综合消息显示，中国工程院官网“全体院士名单”更新显示，三名曾任职军工集团的中国工程院院士，姓名和简历被撤下。其中吴曼青、赵宪庚曾担任中国工程院副院长。2025年7月，吴曼青被免去中国工程院副院长职务。截至3月16日，中国工程院官网显示院士人数为989人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260316-%E4%B8%AD%E5%9B%BD%E5%B7%A5%E7%A8%8B%E9%99%A23%E9%99%A2%E5%A3%AB%E9%81%AD%E9%99%A4%E5%90%8D-%E5%9D%87%E4%B8%BA%E5%86%9B%E5%B7%A5%E4%B8%93%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773662586000.webp","sourceId":"rfi"},{"id":1773661650000,"createdDate":"2026-03-16 11:47","name":"法国国际广播电台","title":"《一战再战》力压《罪人》荣获奥斯卡最佳影片","content":"周日晚间，在洛杉矶举行的第98届奥斯卡颁奖礼上，美国片《一战再战》力压其他影片，荣获6座小金人，成为本届典礼的大赢家。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260316-%E4%B8%80%E6%88%98%E5%86%8D%E6%88%98-%E5%8A%9B%E5%8E%8B-%E7%BD%AA%E4%BA%BA-%E8%8D%A3%E8%8E%B7%E5%A5%A5%E6%96%AF%E5%8D%A1%E6%9C%80%E4%BD%B3%E5%BD%B1%E7%89%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773661650000.webp","sourceId":"rfi"},{"id":1773659609000,"createdDate":"2026-03-16 11:13","name":"法国国际广播电台","title":"特朗普连续多天持续向多国施压，希望促成霍尔木兹海峡通航，真的有效吗？","content":"目前中东战争已进入第17天，以色列周一继续轰炸黎巴嫩和伊朗首都德黑兰，而伊朗仍宣称控制着霍尔木兹海峡这一位于波斯湾的战略通道。全球约五分之一的石油和液化天然气运输都要经过这条航道，亚洲和欧洲经济体对此高度依赖。比如，日本约95%的原油进口来自中东地区，在冲突爆发前，其中70%需要通过霍尔木兹海峡。国际能源署甚至称这是全球石油市场历史上最严重的供应中断。而自战争爆发以来，油价几乎一直维持在每桶约100美元左右徘徊，这对世界经济，以及特朗普本人都造成了巨大的压力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260316-%E7%89%B9%E6%9C%97%E6%99%AE%E8%BF%9E%E7%BB%AD%E5%A4%9A%E5%A4%A9%E6%8C%81%E7%BB%AD%E5%90%91%E5%A4%9A%E5%9B%BD%E6%96%BD%E5%8E%8B%EF%BC%8C%E5%B8%8C%E6%9C%9B%E4%BF%83%E6%88%90%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%80%9A%E8%88%AA%EF%BC%8C%E7%9C%9F%E7%9A%84%E6%9C%89%E6%95%88%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773659609000.webp","sourceId":"rfi"},{"id":1773656810000,"createdDate":"2026-03-16 10:26","name":"法国国际广播电台","title":"卡拉斯提黑海倡议模式以疏通霍尔木兹海峡：海峡关闭对亚洲能源供应来说非常危险","content":"欧盟外交与安全政策高级代表卡拉斯（KajaKallas）周一表示，她已与联合国秘书长古特雷斯讨论了通过霍尔木兹海峡疏导石油和天然气运输的方案，该方案将借鉴战时乌克兰粮食海运运输的模式，即“黑海谷物倡议”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260316-%E5%8D%A1%E6%8B%89%E6%96%AF%E6%8F%90%E9%BB%91%E6%B5%B7%E5%80%A1%E8%AE%AE%E6%A8%A1%E5%BC%8F%E4%BB%A5%E7%96%8F%E9%80%9A%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E6%B5%B7%E5%B3%A1%E5%85%B3%E9%97%AD%E5%AF%B9%E4%BA%9A%E6%B4%B2%E8%83%BD%E6%BA%90%E4%BE%9B%E5%BA%94%E6%9D%A5%E8%AF%B4%E9%9D%9E%E5%B8%B8%E5%8D%B1%E9%99%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773656810000.webp","sourceId":"rfi"},{"id":1773654474000,"createdDate":"2026-03-16 09:47","name":"法国国际广播电台","title":"特朗普指或就霍尔木兹海峡问题推迟访华 中方：就当前局势同各方保持沟通","content":"美国总统特朗普（DonaldTrump）警告称，如果美国盟友不协助打通霍尔木兹海峡，北约将面临“非常坏”的未来，这无疑是在向欧洲盟国发出明确信号，要求它们加入其对伊朗的战争努力。特朗普周日在接受英国《金融时报》采访时还表示，可能会推迟本月晚些时候与中国国家主席习近平的峰会，特朗普正敦促中方帮助疏通这条至关重要的水道。北京方面，中国外交部发言人林剑在周一的例行记者会上应询时则回应称，“我们也就当前的局势同各方保持沟通，致力于推动局势缓和降温”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260316-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8C%87%E6%88%96%E5%B0%B1%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%97%AE%E9%A2%98%E6%8E%A8%E8%BF%9F%E8%AE%BF%E5%8D%8E-%E4%B8%AD%E6%96%B9-%E5%B0%B1%E5%BD%93%E5%89%8D%E5%B1%80%E5%8A%BF%E5%90%8C%E5%90%84%E6%96%B9%E4%BF%9D%E6%8C%81%E6%B2%9F%E9%80%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773654474000.webp","sourceId":"rfi"},{"id":1773651522000,"createdDate":"2026-03-16 08:58","name":"法国国际广播电台","title":"18国能源主管在东京发表联合声明","content":"日美两国政府共同主办的就印度—太平洋地区能源安全进行讨论的会议与论坛于15日在东京都内结束，为期两天的日程落下帷幕。来自日本、美国等18个国家的部长级官员参加了会议。在为期两天的会议中，各方汇总了一份联合声明，提出通过基础设施投资等合作，促进地区内能源的稳定供应。配合会议举行的日美主管部长会议还就建立应对重要矿产供应中断的快速反应框架达成一致，而日本新年度预算案16日开始在参议院审议，针对伊朗封锁霍尔木兹海峡带来的能源危机及美国总统特朗普表示期待日本向中东派遣舰船一事，高市首相表示：“正在研究应对措施。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260316-18%E5%9B%BD%E8%83%BD%E6%BA%90%E4%B8%BB%E7%AE%A1%E5%9C%A8%E4%B8%9C%E4%BA%AC%E5%8F%91%E8%A1%A8%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773651522000.webp","sourceId":"rfi"},{"id":1773651265000,"createdDate":"2026-03-16 08:54","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第24：浪漫主义群星之三：荷尔德林第三节：基督与希腊群神","content":"浪漫派运动产生在宗教改革之后，那时人们已从全新的视角看待基督教。那些给予浪漫派以思想武器的哲学家，尽管学说各异，观点分歧，但都有一个共同的基督教背景，都面对现实世界与超验世界的纠缠。哲学中谈及的自我与非我，理性与感性，当下与永恒都会在宗教中找到另一种表达，个人与上帝，神与世俗，原罪与救赎。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260316-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%89-%E8%8D%B7%E5%B0%94%E5%BE%B7%E6%9E%97%E7%AC%AC%E4%B8%89%E8%8A%82-%E5%9F%BA%E7%9D%A3%E4%B8%8E%E5%B8%8C%E8%85%8A%E7%BE%A4%E7%A5%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773651265000.webp","sourceId":"rfi"}]