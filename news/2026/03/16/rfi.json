[{"id":1773649593000,"createdDate":"2026-03-16 08:26","name":"法国国际广播电台","title":"因中东战争影响，韩国将取消煤炭发电上限，同时增加核能发电","content":"韩国周一宣布，将取消此前对燃煤发电能力设定的80%上限，并将核能发电的利用率提高到接近同一水平。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260316-%E5%9B%A0%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E5%BD%B1%E5%93%8D%EF%BC%8C%E9%9F%A9%E5%9B%BD%E5%B0%86%E5%8F%96%E6%B6%88%E7%85%A4%E7%82%AD%E5%8F%91%E7%94%B5%E4%B8%8A%E9%99%90%EF%BC%8C%E5%90%8C%E6%97%B6%E5%A2%9E%E5%8A%A0%E6%A0%B8%E8%83%BD%E5%8F%91%E7%94%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773649593000.webp","sourceId":"rfi"},{"id":1773647511000,"createdDate":"2026-03-16 07:51","name":"法国国际广播电台","title":"美国民调：中国民众对台湾抱持相对友善情感，并倾向不对台动武","content":"美国民调结果显示，中国民众对台湾抱持相对友善的情感，多数受访者倾向以非军事手段改善两岸关系美国学界对中国民众进行民调，由非营利组织卡特中心（TheCarterCenter）与艾莫瑞大学（EmoryUniversity）发起并于近日公布。根据中央社报导，民调显示中国民众对台湾抱持相对友善的情感，调查访问中国民众对台湾的感受评分，0到49的评分表示感受到不友好和冷漠，51到100之间表示感到友好和温暖，而中国受访者平均给出62分。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260316-%E7%BE%8E%E5%9B%BD%E6%B0%91%E8%B0%83-%E4%B8%AD%E5%9B%BD%E6%B0%91%E4%BC%97%E5%AF%B9%E5%8F%B0%E6%B9%BE%E6%8A%B1%E6%8C%81%E7%9B%B8%E5%AF%B9%E5%8F%8B%E5%96%84%E6%83%85%E6%84%9F%EF%BC%8C%E5%B9%B6%E5%80%BE%E5%90%91%E4%B8%8D%E5%AF%B9%E5%8F%B0%E5%8A%A8%E6%AD%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773647511000.webp","sourceId":"rfi"},{"id":1773647308000,"createdDate":"2026-03-16 07:48","name":"法国国际广播电台","title":"港警又要求删文 促境外网站删除女督察自杀报道被拒","content":"香港警队一名见习女督察上月在警署内开枪自杀身亡一事，警方仍在调查，但在未有结果前，便致函一个相信是澳洲的网站，以可能违反私隐条例为由，要求删除有关报道，但遭网站拒绝，称事涉公众知情权，质疑警方是欲盖弥彰。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260316-%E6%B8%AF%E8%AD%A6%E5%8F%88%E8%A6%81%E6%B1%82%E5%88%A0%E6%96%87-%E4%BF%83%E5%A2%83%E5%A4%96%E7%BD%91%E7%AB%99%E5%88%A0%E9%99%A4%E5%A5%B3%E7%9D%A3%E5%AF%9F%E8%87%AA%E6%9D%80%E6%8A%A5%E9%81%93%E8%A2%AB%E6%8B%92","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773647308000.webp","sourceId":"rfi"},{"id":1773623567000,"createdDate":"2026-03-16 01:12","name":"法国国际广播电台","title":"特朗普称中国如不参与护航霍尔木兹海峡 或推迟特习会","content":"美国总统特朗普表示，如果中国不采取确保霍尔木兹海峡安全的行动，他可能推迟即将在北京与中国国家主席习近平举行的峰会。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260316-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E4%B8%AD%E5%9B%BD%E5%A6%82%E4%B8%8D%E5%8F%82%E4%B8%8E%E6%8A%A4%E8%88%AA%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E6%88%96%E6%8E%A8%E8%BF%9F%E7%89%B9%E4%B9%A0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/16/1773623567000.webp","sourceId":"rfi"}]