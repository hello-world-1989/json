[{"id":1774596876000,"createdDate":"2026-03-27 07:34","name":"法国国际广播电台","title":"继财经官员访港 英官方报告称会就保障国家安全加强与港合作","content":"一度因北京在香港实施《港区国安法》而冷下来的港英关系有解冻迹象，继英国投资事务部长和伦敦金融城市长在过去半年内访港后，英国外相顾绮慧(YvetteCooper)在一份政府报告中表明，会在保障英国安全方面加强与香港的合作，包括打击严重的有组织罪行。但她没有指明，会否考虑重新启动已中断近六年的移交逃犯协定。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260327-%E7%BB%A7%E8%B4%A2%E7%BB%8F%E5%AE%98%E5%91%98%E8%AE%BF%E6%B8%AF-%E8%8B%B1%E5%AE%98%E6%96%B9%E6%8A%A5%E5%91%8A%E7%A7%B0%E4%BC%9A%E5%B0%B1%E4%BF%9D%E9%9A%9C%E5%9B%BD%E5%AE%B6%E5%AE%89%E5%85%A8%E5%8A%A0%E5%BC%BA%E4%B8%8E%E6%B8%AF%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774596876000.webp","sourceId":"rfi"},{"id":1774574488000,"createdDate":"2026-03-27 01:21","name":"法国国际广播电台","title":"乌克兰的麦田正被战争变成化学定时炸弹","content":"乌克兰素有“欧洲粮仓”之称，然而俄乌战争正在把乌克兰的麦田变成化学定时炸弹。在满目疮痍的土地背后，真正的危险是看不见的：铅、镉和镍渗入土壤，直接威胁农业生产。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260327-%E4%B9%8C%E5%85%8B%E5%85%B0%E7%9A%84%E9%BA%A6%E7%94%B0%E6%AD%A3%E8%A2%AB%E6%88%98%E4%BA%89%E5%8F%98%E6%88%90%E5%8C%96%E5%AD%A6%E5%AE%9A%E6%97%B6%E7%82%B8%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774574488000.webp","sourceId":"rfi"},{"id":1774627791000,"createdDate":"2026-03-27 16:09","name":"法国国际广播电台","title":"印度批准价值250亿美元的军购计划 包括购买俄S-400防空系统等","content":"印度周五批准了价值250亿美元的军购提案，用于购买运输机、俄罗斯S-400防空导弹系统和遥控攻击机等装备。此举旨在推进印度军事现代化，并在与巴基斯坦的冲突后补充装备。此前，印度上月还批准了另一项价值400亿美元的重大采购计划，用于为空军购买更多法制“阵风”战斗机，并为海军购买波音P-8I海上侦察机。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260327-%E5%8D%B0%E5%BA%A6%E6%89%B9%E5%87%86%E4%BB%B7%E5%80%BC250%E4%BA%BF%E7%BE%8E%E5%85%83%E7%9A%84%E5%86%9B%E8%B4%AD%E8%AE%A1%E5%88%92-%E5%8C%85%E6%8B%AC%E8%B4%AD%E4%B9%B0%E4%BF%84s-400%E9%98%B2%E7%A9%BA%E7%B3%BB%E7%BB%9F%E7%AD%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774627791000.webp","sourceId":"rfi"},{"id":1774626851000,"createdDate":"2026-03-27 15:54","name":"法国国际广播电台","title":"台湾半导体氮需求热 法国液化空气在台搭人工智能双热潮大获利","content":"各位听众，如果氮气供应中断，一切都将停滞不前。在台湾，法国工业气体集团《液化空气集团》（AirLiquide）正从半导体热潮和人工智能热潮中获利。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260327-%E5%8F%B0%E6%B9%BE%E5%8D%8A%E5%AF%BC%E4%BD%93%E9%AB%98%E9%9C%80%E6%B1%82%E6%B0%AE-%E6%B3%95%E5%9B%BD%E6%B6%B2%E5%8C%96%E7%A9%BA%E6%B0%94%E6%90%AD%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E5%8F%8C%E9%AB%98%E7%83%AD%E6%BD%AE%E5%A4%A7%E8%8E%B7%E5%88%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774626851000.webp","sourceId":"rfi"},{"id":1774626511000,"createdDate":"2026-03-27 15:48","name":"法国国际广播电台","title":"不断被削弱的世贸组织在大国竞争中寻找改革自救路径","content":"世界贸易组织自26日起，在喀麦隆首都雅温得召开第14届部长级会议。如果说此时正值随伊朗战争而来的能源危机令国际贸易秩序再受冲击的话，这次世贸组织高级别会议尤其需要在特朗普第二个总统任期下的关税措施对国际贸易格局的冲击背景下，推动成员国就作用不断被削弱的世贸组织改革问题达成某种共识。世贸组织总干事伊维拉在会议首日就明确表示，国际贸易体系正面对80年来最糟糕的困扰。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260327-%E4%B8%8D%E6%96%AD%E8%A2%AB%E5%89%8A%E5%BC%B1%E7%9A%84%E4%B8%96%E8%B4%B8%E7%BB%84%E7%BB%87%E5%9C%A8%E5%A4%A7%E5%9B%BD%E7%AB%9E%E4%BA%89%E4%B8%AD%E5%AF%BB%E6%89%BE%E6%94%B9%E9%9D%A9%E8%87%AA%E6%95%91%E8%B7%AF%E5%BE%84","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774626511000.webp","sourceId":"rfi"},{"id":1774625989000,"createdDate":"2026-03-27 15:39","name":"法国国际广播电台","title":"美能确信伊朗约三分之一的导弹库存被摧毁 美军据报已发射850多枚战斧导弹","content":"据路透社援引五位熟悉美国情报的人士报导称，随着美以两国对伊朗的战争接近一个月，美国目前只能确信摧毁了伊朗庞大导弹库存的约三分之一。另有约三分之一的导弹下落尚不明朗，但四位消息人士称，轰炸很可能对这些导弹造成了损坏、摧毁或掩埋在了地下隧道和掩体中。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260327-%E7%BE%8E%E8%83%BD%E7%A1%AE%E4%BF%A1%E4%BC%8A%E6%9C%97%E7%BA%A6%E4%B8%89%E5%88%86%E4%B9%8B%E4%B8%80%E7%9A%84%E5%AF%BC%E5%BC%B9%E5%BA%93%E5%AD%98%E8%A2%AB%E6%91%A7%E6%AF%81-%E7%BE%8E%E5%86%9B%E6%8D%AE%E6%8A%A5%E5%B7%B2%E5%8F%91%E5%B0%84%E9%80%BE850%E6%9E%9A%E6%88%98%E6%96%A7%E5%AF%BC%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774625989000.webp","sourceId":"rfi"},{"id":1774624519000,"createdDate":"2026-03-27 15:15","name":"法国国际广播电台","title":"特朗普访华行程定局 伊朗战争阴影笼罩峰会","content":"美国总统特朗普（DonaldTrump）将于5月14至15日赴北京与中国国家主席习近平会面，白宫周三正式确认日期。这将是近十年来美国总统首度踏足中国，也是两国关系的重大外交事件。然而，伊朗战事未息、霍尔木兹海峡封锁危机持续，令这场峰会的走向充满变数。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260327-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E8%A1%8C%E7%A8%8B%E5%AE%9A%E5%B1%80-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E9%98%B4%E5%BD%B1%E7%AC%BC%E7%BD%A9%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774624519000.webp","sourceId":"rfi"},{"id":1774623749000,"createdDate":"2026-03-27 15:02","name":"法国国际广播电台","title":"两艘中远海运集装箱船试图穿越霍尔木兹海峡后折返","content":"船舶追踪数据显示，尽管伊朗方面保证中方船只可以通行，但两艘中国集装箱船周五试图经霍尔木兹海峡离开波斯湾时掉头返航。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260327-%E4%B8%A4%E8%89%98%E4%B8%AD%E8%BF%9C%E6%B5%B7%E8%BF%90%E9%9B%86%E8%A3%85%E7%AE%B1%E8%88%B9%E8%AF%95%E5%9B%BE%E7%A9%BF%E8%B6%8A%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%90%8E%E6%8A%98%E8%BF%94","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774623749000.webp","sourceId":"rfi"},{"id":1774620640000,"createdDate":"2026-03-27 14:10","name":"法国国际广播电台","title":"事发中业岛附近海域 菲军方称中国军舰“故意”举动让两国军舰险些相撞","content":"菲律宾军方周五将一艘菲律宾海军军舰与中国军舰在西菲律宾海（菲方对其专属经济区内南中国海海域的称呼）帕加萨岛（中方称中业岛）附近发生的险些相撞事件描述为局势升级。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260327-%E4%BA%8B%E5%8F%91%E4%B8%AD%E4%B8%9A%E5%B2%9B%E9%99%84%E8%BF%91%E6%B5%B7%E5%9F%9F-%E8%8F%B2%E5%86%9B%E6%96%B9%E7%A7%B0%E4%B8%AD%E5%9B%BD%E5%86%9B%E8%88%B0-%E6%95%85%E6%84%8F-%E4%B8%BE%E5%8A%A8%E8%AE%A9%E4%B8%A4%E5%9B%BD%E5%86%9B%E8%88%B0%E9%99%A9%E4%BA%9B%E7%9B%B8%E6%92%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774620640000.webp","sourceId":"rfi"},{"id":1774619503000,"createdDate":"2026-03-27 13:51","name":"法国国际广播电台","title":"乌克兰和沙特签署防空合作协议","content":"乌克兰和沙特阿拉伯在泽连斯基总统3月26日访问期间签署了一项防控合作协议，该协议将允许基辅分享其在打击“沙赫德”无人机袭击的经验。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260327-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%92%8C%E6%B2%99%E7%89%B9%E9%98%BF%E6%8B%89%E4%BC%AF%E7%AD%BE%E7%BD%B2%E4%BA%86%E9%98%B2%E7%A9%BA%E5%90%88%E4%BD%9C%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774619503000.webp","sourceId":"rfi"},{"id":1774615066000,"createdDate":"2026-03-27 12:37","name":"法国国际广播电台","title":"普京据报首次召集寡头亲口要求捐款以支持财政 誓言夺下整个顿巴斯","content":"据英国《金融时报》援引三位知情人士报导称，俄罗斯总统普京已要求寡头们向俄财政捐款，以期在继续入侵乌克兰的同时稳定国家财政。普京周四对一大群知名商人发表的讲话表明，尽管克里姆林宫的财政状况日益紧张，但他仍决心将这场战争进行到底，直至取得胜利。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260327-%E6%99%AE%E4%BA%AC%E6%8D%AE%E6%8A%A5%E9%A6%96%E6%AC%A1%E5%8F%AC%E9%9B%86%E5%AF%A1%E5%A4%B4%E4%BA%B2%E5%8F%A3%E8%A6%81%E6%B1%82%E6%8D%90%E6%AC%BE%E6%94%AF%E6%8C%81%E8%B4%A2%E6%94%BF-%E8%AA%93%E8%A8%80%E5%A4%BA%E4%B8%8B%E6%95%B4%E4%B8%AA%E9%A1%BF%E5%B7%B4%E6%96%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774615066000.webp","sourceId":"rfi"},{"id":1774613708000,"createdDate":"2026-03-27 12:15","name":"法国国际广播电台","title":"尼泊尔青年世代运动催生的政治团队走马上任","content":"尼泊尔3月初立法选举产生的新议会26日宣誓就职的次日，新政府总理、35岁的前首都加德满都市长沙阿27日走马上任，呼吁国家团结。73岁的临时政府总理苏希拉-卡尔基功成身退，重返退休生活。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260327-%E5%B0%BC%E6%B3%8A%E5%B0%94%E9%9D%92%E5%B9%B4%E4%B8%96%E4%BB%A3%E8%BF%90%E5%8A%A8%E5%82%AC%E7%94%9F%E7%9A%84%E6%94%BF%E6%B2%BB%E5%9B%A2%E9%98%9F%E8%B5%B0%E9%A9%AC%E4%B8%8A%E4%BB%BB%EF%BC%8C%E6%96%B0%E6%80%BB%E7%90%86%E5%91%BC%E5%90%81%E5%9B%BD%E6%B0%91%E5%9B%A2%E7%BB%93%E4%B8%80%E8%87%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774613708000.webp","sourceId":"rfi"},{"id":1774612533000,"createdDate":"2026-03-27 11:55","name":"法国国际广播电台","title":"美官员指中国扣押巴拿马籍船舶激增远超以往惯例 北京批美暴露霸占运河","content":"美国联邦海事委员会（FMC）周四表示，正密切关注中国境内巴拿马籍船舶被扣押数量激增的现象，这似乎与巴拿马法院对总部位于香港的长江和记实业有限公司（以下简称长和）的裁决有关。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260327-%E7%BE%8E%E5%AE%98%E5%91%98%E6%8C%87%E4%B8%AD%E5%9B%BD%E6%89%A3%E6%8A%BC%E5%B7%B4%E6%8B%BF%E9%A9%AC%E7%B1%8D%E8%88%B9%E8%88%B6%E6%BF%80%E5%A2%9E%E8%BF%9C%E8%B6%85%E4%BB%A5%E5%BE%80%E6%83%AF%E4%BE%8B-%E5%8C%97%E4%BA%AC%E6%89%B9%E7%BE%8E%E6%9A%B4%E9%9C%B2%E9%9C%B8%E5%8D%A0%E8%BF%90%E6%B2%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774612533000.webp","sourceId":"rfi"},{"id":1774607925000,"createdDate":"2026-03-27 10:38","name":"法国国际广播电台","title":"法菲防长签署《访问部队地位协定》强化军事合作","content":"菲律宾和法国正式签署了两国之间的《访问部队地位协定》（SOVFA）。菲律宾国防部长特奥多罗（GilbertTeodoro）和法国国防部长沃特兰（CatherineVautrin）于周四在巴黎举行的双边会晤中签署了该协定。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260327-%E6%B3%95%E8%8F%B2%E9%98%B2%E9%95%BF%E7%AD%BE%E7%BD%B2-%E8%AE%BF%E9%97%AE%E9%83%A8%E9%98%9F%E5%9C%B0%E4%BD%8D%E5%8D%8F%E5%AE%9A-%E5%BC%BA%E5%8C%96%E5%86%9B%E4%BA%8B%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774607925000.webp","sourceId":"rfi"},{"id":1774605472000,"createdDate":"2026-03-27 09:57","name":"法国国际广播电台","title":"中资钴矿污染引发公共卫生危机 刚果(金)政府勒令展开调查","content":"中国河南洛阳栾川钼业集团在短短二十多年的时间内发展成为在上海以及香港上市，在非洲与南美都拥有重大矿产的世界级的资源公司，据公司网站的介绍，洛阳钼业集团今天是全球领先的铜、钴、钼、钨、铌生产商，亦是巴西领先的磷肥生产商，2024全球矿企市值前50强第19位。不过，该集团的发展史也伴随着大大小小的国内国外的污染事件，今天洛阳钼业在非洲刚果金的一家分公司，TFM也因污染问题而受到当地民众以及非政府组织的谴责，并将遭受当地政府的调查。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E5%A2%83%E4%B8%8E%E5%8F%91%E5%B1%95/20260327-%E4%B8%AD%E8%B5%84%E9%92%B4%E7%9F%BF%E6%B1%A1%E6%9F%93%E5%BC%95%E5%8F%91%E5%85%AC%E5%85%B1%E5%8D%AB%E7%94%9F%E5%8D%B1%E6%9C%BA-%E5%88%9A%E6%9E%9C-%E9%87%91-%E6%94%BF%E5%BA%9C%E5%8B%92%E4%BB%A4%E5%B1%95%E5%BC%80%E8%B0%83%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774605472000.webp","sourceId":"rfi"},{"id":1774605368000,"createdDate":"2026-03-27 09:56","name":"法国国际广播电台","title":"美官员称中芯国际向伊朗军方提供芯片制造工具 北京：不了解情况","content":"据路透社报导，两名美国特朗普政府高级官员周四表示，中国最大的芯片制造商中芯国际（SMIC）已向伊朗军方提供了芯片制造工具，这引发了人们对中方在持续一个月的美以和伊朗的冲突中立场的质疑。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260327-%E7%BE%8E%E5%AE%98%E5%91%98%E7%A7%B0%E4%B8%AD%E8%8A%AF%E5%9B%BD%E9%99%85%E5%90%91%E4%BC%8A%E6%9C%97%E5%86%9B%E6%96%B9%E6%8F%90%E4%BE%9B%E8%8A%AF%E7%89%87%E5%88%B6%E9%80%A0%E5%B7%A5%E5%85%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774605368000.webp","sourceId":"rfi"},{"id":1774603628000,"createdDate":"2026-03-27 09:27","name":"法国国际广播电台","title":"日本欢迎美伊停战协商  日本伊朗友好议员联盟召开总会","content":"针对美国总统特朗普宣布将原本预告对伊朗发电站实施攻击的期限延长至下月6日，美伊正在进行停战协商一事，日本内阁官房长官木原稔在27日上午的记者会上表示，他“期待（美国与）伊朗之间的磋商能够朝着良好的方向发展。”而在3月26日，针对伊朗局势，在日本国会内召开了日本与伊朗友好议员联盟总会，该会会长、前首相岸田文雄提到，在以日美同盟为基轴的同时，有必要兼顾与伊朗的传统友好关系，并表示：“必须动用一切外交渠道开展对话，为解决问题付出努力。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260327-%E6%97%A5%E6%9C%AC%E6%AC%A2%E8%BF%8E%E7%BE%8E%E4%BC%8A%E5%81%9C%E6%88%98%E5%8D%8F%E5%95%86-%E6%97%A5%E6%9C%AC%E4%BC%8A%E6%9C%97%E5%8F%8B%E5%A5%BD%E8%AE%AE%E5%91%98%E8%81%94%E7%9B%9F%E5%8F%AC%E5%BC%80%E6%80%BB%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774603628000.webp","sourceId":"rfi"},{"id":1774602626000,"createdDate":"2026-03-27 09:10","name":"法国国际广播电台","title":"哈工大等“国防七子”大学采购搭载受限英伟达芯片的超微服务器","content":"据路透社报导，采购数据显示，过去一年里，包括两所与解放军有关联的大学在内的四所中国高校，购买了搭载受限人工智能芯片的超微电脑（Supermicro）服务器。这一发现正值美国限制向中国出售部分先进处理器。目前尚不清楚这些服务器的来源。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260327-%E5%93%88%E5%B7%A5%E5%A4%A7%E7%AD%89-%E5%9B%BD%E9%98%B2%E4%B8%83%E5%AD%90-%E5%A4%A7%E5%AD%A6%E8%B4%AD%E4%B9%B0%E6%90%AD%E8%BD%BD%E5%8F%97%E9%99%90%E8%8B%B1%E4%BC%9F%E8%BE%BE%E8%8A%AF%E7%89%87%E7%9A%84%E8%B6%85%E5%BE%AE%E6%9C%8D%E5%8A%A1%E5%99%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774602626000.webp","sourceId":"rfi"},{"id":1774653423000,"createdDate":"2026-03-27 23:17","name":"法国国际广播电台","title":"媒体：俄罗斯正在向伊朗运送更先进的无人机","content":"美联社援引匿名的美国和欧洲官员报道，俄罗斯正在向伊朗运送一批无人机，其中包括对伊朗以前提供给莫斯科、用于乌克兰战争的无人机进行升级后的无人机。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260327-%E5%AA%92%E4%BD%93-%E4%BF%84%E7%BD%97%E6%96%AF%E6%AD%A3%E5%9C%A8%E5%90%91%E4%BC%8A%E6%9C%97%E8%BF%90%E9%80%81%E6%9B%B4%E5%85%88%E8%BF%9B%E7%9A%84%E6%97%A0%E4%BA%BA%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774653423000.webp","sourceId":"rfi"},{"id":1774653225000,"createdDate":"2026-03-27 23:13","name":"法国国际广播电台","title":"伊朗战争验证了北京当局的战略方向是对的","content":"法国世界报周五就伊朗战争写道，这场战争使中国受到冲击，但是，也让中国的战略获得确认。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260327-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E9%AA%8C%E8%AF%81%E4%BA%86%E5%8C%97%E4%BA%AC%E5%BD%93%E5%B1%80%E7%9A%84%E6%88%98%E7%95%A5%E6%96%B9%E5%90%91%E6%98%AF%E5%AF%B9%E7%9A%84","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774653225000.webp","sourceId":"rfi"},{"id":1774653073000,"createdDate":"2026-03-27 23:11","name":"法国国际广播电台","title":"伊朗盟友也门胡塞武装威胁或将加入战争，打击红海航运","content":"也门胡塞武装在伊朗支持下周五（3月27日）表示，如果针对伊朗的攻击继续、更多国家加入美以攻势，或红海成为攻击发起地，他们将参与战争。此前，美国媒体透露，白宫和国防部正考虑在未来几天向中东增派至少1万名作战士兵。目前霍尔木兹海峡通航依旧遥遥无期，如果中东的冲突真的发展到这一步，那么红海航运也将受到打击，对全球经济来说无疑是雪上加霜。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260327-%E4%BC%8A%E6%9C%97%E7%9B%9F%E5%8F%8B%E4%B9%9F%E9%97%A8%E8%83%A1%E5%A1%9E%E6%AD%A6%E8%A3%85%E5%A8%81%E8%83%81%E6%88%96%E5%B0%86%E5%8A%A0%E5%85%A5%E6%88%98%E4%BA%89%EF%BC%8C%E6%89%93%E5%87%BB%E7%BA%A2%E6%B5%B7%E8%88%AA%E8%BF%90","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774653073000.webp","sourceId":"rfi"},{"id":1774651216000,"createdDate":"2026-03-27 22:40","name":"法国国际广播电台","title":"[法语世界]第149集：[法语观察站]和2026年[世界法语报告]","content":"法国国际广播电台（RadioFranceInternationale）中文[法语世界]（Chroniquefrancophonie）2026年03月27日第149集介绍在2026年03月17日至03月20日第31届法语周（Semainedelalanguefrançaiseetdelafrancophonie）期间，[法语国家及地区国际组织]（OIF）旗下[法语观察站]（l'Observatoiredelalanguefrançaise）负责人接受本台法语[午间非洲嘉宾]（InvitéAfriqueMidi）专栏记者采访的录音片段，内容围绕四年一度的[世界法语报告]（Rapportdelalanguefrançaisedanslemonde2026），由尼古拉编译。Pr.MohamedEmbarki,responsabledel'ObservatoiredelaFrancophonie,estl'invitéd'AfriqueMidiaumicrodeRFIMatthieuVendrely.","newsLink":"https://www.rfi.fr/cn/%E8%A7%86%E9%A2%91/20260327-rfi-%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C%E7%AC%AC149%E9%9B%86-%E6%B3%95%E8%AF%AD%E8%A7%82%E5%AF%9F%E7%AB%99-%E5%92%8C2026%E5%B9%B4-%E4%B8%96%E7%95%8C%E6%B3%95%E8%AF%AD%E6%8A%A5%E5%91%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774651216000.webp","sourceId":"rfi"},{"id":1774645081000,"createdDate":"2026-03-27 20:58","name":"法国国际广播电台","title":"法国电视台采访俄外长被指助俄“大外宣”，乌克兰抗议，法外交部表关切","content":"2026年3月26日，法国电视台二台晚间20点新闻播出了对俄罗斯外交部长谢尔盖·拉夫罗夫的采访。这次采访通过远程连线进行，当时拉夫罗夫身处莫斯科。该电视台播出了约10分钟的内容，观看人数为340万。这一采访引发的争议正在持续发酵。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260327-%E6%B3%95%E5%9B%BD%E7%94%B5%E8%A7%86%E5%8F%B0%E9%87%87%E8%AE%BF%E4%BF%84%E5%A4%96%E9%95%BF%E5%BC%95%E4%BA%89%E8%AE%AE%EF%BC%8C%E4%B9%8C%E5%85%8B%E5%85%B0%E6%8A%97%E8%AE%AE%EF%BC%8C%E6%B3%95%E5%A4%96%E4%BA%A4%E9%83%A8%E8%A1%A8%E5%85%B3%E5%88%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774645081000.webp","sourceId":"rfi"},{"id":1774644986000,"createdDate":"2026-03-27 20:56","name":"法国国际广播电台","title":"法语已发展成为一种多中心语言","content":"2026年版[世界法语报告]已于一周前对外发布。负责这一报告的[法语观察站]（l'Observatoiredelalanguefrançaise）负责人接受了本台法广（RFI）[午间非洲嘉宾]（InvitéAfriqueMidi）法语记者的采访。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260327-%E6%B3%95%E8%AF%AD%E5%B7%B2%E5%8F%91%E5%B1%95%E6%88%90%E4%B8%BA%E4%B8%80%E7%A7%8D%E5%A4%9A%E4%B8%AD%E5%BF%83%E8%AF%AD%E8%A8%80","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774644986000.webp","sourceId":"rfi"},{"id":1774643035000,"createdDate":"2026-03-27 20:23","name":"法国国际广播电台","title":"燃料价格飙升，法国政府宣布近7000万欧元“定向援助”计划","content":"法国政府周五（3月27日）宣布了一项近7000万欧元的援助计划，定向援助部分行业并且仅限四月份，主要用于帮助受燃料价格飙升影响最严重的行业：渔业、农业和交通运输业。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260327-%E7%87%83%E6%96%99%E4%BB%B7%E6%A0%BC%E9%A3%99%E5%8D%87%EF%BC%8C%E6%B3%95%E5%9B%BD%E6%94%BF%E5%BA%9C%E5%AE%A3%E5%B8%83%E8%BF%917000%E4%B8%87%E6%AC%A7%E5%85%83-%E5%AE%9A%E5%90%91%E6%8F%B4%E5%8A%A9-%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774643035000.webp","sourceId":"rfi"},{"id":1774641910000,"createdDate":"2026-03-27 20:05","name":"法国国际广播电台","title":"鲁比奥指责泽连斯基“撒谎”，称没说过乌克兰需要在领土问题上让步才能获得美国的安全保障，还透露美国可能将部分军援调配给中东","content":"美国国务卿鲁比奥周五（3月27日）指责乌克兰总统泽连斯基“撒谎”，因为泽连斯基声称美国将向乌克兰提供安全保障的条件，是乌克兰在领土问题上向俄罗斯作出让步。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260327-%E9%B2%81%E6%AF%94%E5%A5%A5%E6%8C%87%E8%B4%A3%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E6%92%92%E8%B0%8E-%EF%BC%8C%E7%A7%B0%E6%B2%A1%E8%AF%B4%E8%BF%87%E4%B9%8C%E5%85%8B%E5%85%B0%E9%9C%80%E8%A6%81%E5%9C%A8%E9%A2%86%E5%9C%9F%E9%97%AE%E9%A2%98%E4%B8%8A%E8%AE%A9%E6%AD%A5%E6%89%8D%E8%83%BD%E8%8E%B7%E5%BE%97%E7%BE%8E%E5%9B%BD%E7%9A%84%E5%AE%89%E5%85%A8%E4%BF%9D%E9%9A%9C%EF%BC%8C%E8%BF%98%E9%80%8F%E9%9C%B2%E7%BE%8E%E5%9B%BD%E5%8F%AF%E8%83%BD%E5%B0%86%E9%83%A8%E5%88%86%E5%86%9B%E6%8F%B4%E8%B0%83%E9%85%8D%E7%BB%99%E4%B8%AD%E4%B8%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774641910000.webp","sourceId":"rfi"},{"id":1774641235000,"createdDate":"2026-03-27 19:53","name":"法国国际广播电台","title":"伊朗指美以空袭学校“非误炸”，联合国敦促美国尽快完成调查","content":"3月27日瑞士日内瓦举行的联合国人权理事会会议上，美以联合对伊朗米纳布一所学校进行的空袭再次成为焦点。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260327-%E4%BC%8A%E6%9C%97%E6%8C%87%E7%BE%8E%E4%BB%A5%E7%A9%BA%E8%A2%AD%E5%AD%A6%E6%A0%A1-%E9%9D%9E%E8%AF%AF%E7%82%B8-%EF%BC%8C%E8%81%94%E5%90%88%E5%9B%BD%E6%95%A6%E4%BF%83%E7%BE%8E%E5%9B%BD%E5%B0%BD%E5%BF%AB%E5%AE%8C%E6%88%90%E8%B0%83%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774641235000.webp","sourceId":"rfi"},{"id":1774640610000,"createdDate":"2026-03-27 19:43","name":"法国国际广播电台","title":"G7会议结束各国重申：必须永久恢复霍尔木兹海峡的通航自由   鲁比奥表示：美国在伊朗的军事行动可能将在“两周内”结束","content":"在法国举行的七国集团（G7）会议周五（3月27日）结束后，各国部长最终发表联合声明，就伊朗问题作出表态，特别是针对霍尔木兹海峡几近瘫痪的局面表示担忧。声明重申“必须永久恢复霍尔木兹海峡的自由、安全通航”。美国国务卿鲁比奥表示，美国在伊朗的军事行动可能将在“两周内”结束。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260327-g7%E4%BC%9A%E8%AE%AE%E5%90%8E%E5%90%84%E5%9B%BD%E5%8F%91%E8%A1%A8%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E-%E5%BF%85%E9%A1%BB%E6%B0%B8%E4%B9%85%E6%81%A2%E5%A4%8D%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%9A%84%E9%80%9A%E8%88%AA%E8%87%AA%E7%94%B1-%E9%B2%81%E6%AF%94%E5%A5%A5%E7%A6%BB%E5%BC%80%E5%89%8D%E8%AF%B4-%E7%BE%8E%E5%9B%BD%E5%9C%A8%E4%BC%8A%E6%9C%97%E7%9A%84%E5%86%9B%E4%BA%8B%E8%A1%8C%E5%8A%A8%E5%8F%AF%E8%83%BD%E5%B0%86%E5%9C%A8-%E4%B8%A4%E5%91%A8%E5%86%85-%E7%BB%93%E6%9D%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774640610000.webp","sourceId":"rfi"},{"id":1774639307000,"createdDate":"2026-03-27 19:21","name":"法国国际广播电台","title":"美股连跌恐创四年最长纪录 中东战火与油价飙升加剧衰退忧虑","content":"美国股市27日全面下跌，主要指数同步走弱，市场朝连续第五周收黑迈进，恐创近四年来最长跌势。投资人对中东局势升温与能源价格飙涨感到忧心，加上通膨压力再起与经济衰退疑虑升高，拖累整体市场信心。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260327-%E7%BE%8E%E8%82%A1%E8%BF%9E%E8%B7%8C%E6%81%90%E5%88%9B%E5%9B%9B%E5%B9%B4%E6%9C%80%E9%95%BF%E7%BA%AA%E5%BD%95-%E4%B8%AD%E4%B8%9C%E6%88%98%E7%81%AB%E4%B8%8E%E6%B2%B9%E4%BB%B7%E9%A3%99%E5%8D%87%E5%8A%A0%E5%89%A7%E8%A1%B0%E9%80%80%E5%BF%A7%E8%99%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774639307000.webp","sourceId":"rfi"},{"id":1774634792000,"createdDate":"2026-03-27 18:06","name":"法国国际广播电台","title":"以色列威胁攻击“将升级和扩大”后，伊朗称核设施遭袭，但“未导致任何放射性物质外泄”","content":"据伊朗官方媒体报道，伊朗核设施周五（3月27日）遭到袭击，而就在几小时之前，以色列威胁将“升级和扩大”针对德黑兰的行动。伊朗迅速威胁进行报复，以色列则宣称对袭击负责。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260327-%E4%BB%A5%E8%89%B2%E5%88%97%E5%A8%81%E8%83%81%E6%94%BB%E5%87%BB-%E5%B0%86%E5%8D%87%E7%BA%A7%E5%92%8C%E6%89%A9%E5%A4%A7-%E5%90%8E%EF%BC%8C%E4%BC%8A%E6%9C%97%E7%A7%B0%E6%A0%B8%E8%AE%BE%E6%96%BD%E9%81%AD%E8%A2%AD%EF%BC%8C%E4%BD%86-%E6%9C%AA%E5%AF%BC%E8%87%B4%E4%BB%BB%E4%BD%95%E6%94%BE%E5%B0%84%E6%80%A7%E7%89%A9%E8%B4%A8%E5%A4%96%E6%B3%84","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774634792000.webp","sourceId":"rfi"},{"id":1774632830000,"createdDate":"2026-03-27 17:33","name":"法国国际广播电台","title":"美媒：FBI局长邮箱遭黑客入侵，疑似与伊朗有关","content":"综合法新社与美联社消息，多家美国媒体周五（3月27日）报道，疑似与伊朗有关的黑客组织“汉达拉”（Handala）入侵了美国联邦调查局（FBI）局长卡什·帕特尔的个人邮箱，并在网上发布了从邮箱中获取的文件和照片。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260327-%E7%BE%8E%E5%AA%92-fbi%E5%B1%80%E9%95%BF%E9%82%AE%E7%AE%B1%E9%81%AD%E9%BB%91%E5%AE%A2%E5%85%A5%E4%BE%B5%EF%BC%8C%E7%96%91%E4%BC%BC%E4%B8%8E%E4%BC%8A%E6%9C%97%E6%9C%89%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774632830000.webp","sourceId":"rfi"},{"id":1774632364000,"createdDate":"2026-03-27 17:26","name":"法国国际广播电台","title":"挪威称“安全局势恶化”，将在2035年前额外投入超100亿欧元用于国防","content":"挪威周五（3月27日）宣布，鉴于安全局势恶化，未来十年将额外投入1150亿挪威克朗（超过100亿欧元）用于国防。挪威是北约成员国，并且该国与俄罗斯接壤。挪威与俄罗斯在北极地区拥有一条长达198公里的陆地边界，并在巴伦支海拥有海上边界。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260327-%E6%8C%AA%E5%A8%81%E7%A7%B0-%E5%AE%89%E5%85%A8%E5%B1%80%E5%8A%BF%E6%81%B6%E5%8C%96-%EF%BC%8C%E5%B0%86%E5%9C%A82035%E5%B9%B4%E5%89%8D%E9%A2%9D%E5%A4%96%E6%8A%95%E5%85%A5%E8%B6%85100%E4%BA%BF%E6%AC%A7%E5%85%83%E7%94%A8%E4%BA%8E%E5%9B%BD%E9%98%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774632364000.webp","sourceId":"rfi"}]