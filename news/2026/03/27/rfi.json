[{"id":1774596876000,"createdDate":"2026-03-27 07:34","name":"法国国际广播电台","title":"继财经官员访港 英官方报告称会就保障国家安全加强与港合作","content":"一度因北京在香港实施《港区国安法》而冷下来的港英关系有解冻迹象，继英国投资事务部长和伦敦金融城市长在过去半年内访港后，英国外相顾绮慧(YvetteCooper)在一份政府报告中表明，会在保障英国安全方面加强与香港的合作，包括打击严重的有组织罪行。但她没有指明，会否考虑重新启动已中断近六年的移交逃犯协定。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260327-%E7%BB%A7%E8%B4%A2%E7%BB%8F%E5%AE%98%E5%91%98%E8%AE%BF%E6%B8%AF-%E8%8B%B1%E5%AE%98%E6%96%B9%E6%8A%A5%E5%91%8A%E7%A7%B0%E4%BC%9A%E5%B0%B1%E4%BF%9D%E9%9A%9C%E5%9B%BD%E5%AE%B6%E5%AE%89%E5%85%A8%E5%8A%A0%E5%BC%BA%E4%B8%8E%E6%B8%AF%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774596876000.webp","sourceId":"rfi"},{"id":1774574488000,"createdDate":"2026-03-27 01:21","name":"法国国际广播电台","title":"乌克兰的麦田正被战争变成化学定时炸弹","content":"乌克兰素有“欧洲粮仓”之称，然而俄乌战争正在把乌克兰的麦田变成化学定时炸弹。在满目疮痍的土地背后，真正的危险是看不见的：铅、镉和镍渗入土壤，直接威胁农业生产。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260327-%E4%B9%8C%E5%85%8B%E5%85%B0%E7%9A%84%E9%BA%A6%E7%94%B0%E6%AD%A3%E8%A2%AB%E6%88%98%E4%BA%89%E5%8F%98%E6%88%90%E5%8C%96%E5%AD%A6%E5%AE%9A%E6%97%B6%E7%82%B8%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/27/1774574488000.webp","sourceId":"rfi"}]