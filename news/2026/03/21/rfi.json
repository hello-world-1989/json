[{"id":1774082125000,"createdDate":"2026-03-21 08:35","name":"法国国际广播电台","title":"不满兴建火葬场：广东信宜数百村人连日抗议 警民对峙激化","content":"中国广东茂名信宜近期爆发警民冲突，当地村民不满地方政府以修路名义征地，实为在村落、学校附近兴建火葬场，村民集结抗议，防暴警察镇压示威民众，导致多人受伤。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260321-%E4%B8%8D%E6%BB%A1%E5%85%B4%E5%BB%BA%E7%81%AB%E8%91%AC%E5%9C%BA-%E5%B9%BF%E4%B8%9C%E4%BF%A1%E5%AE%9C%E6%95%B0%E7%99%BE%E6%9D%91%E4%BA%BA%E8%BF%9E%E6%97%A5%E6%8A%97%E8%AE%AE-%E8%AD%A6%E6%B0%91%E5%AF%B9%E5%B3%99%E6%BF%80%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774082125000.webp","sourceId":"rfi"},{"id":1774081620000,"createdDate":"2026-03-21 08:27","name":"法国国际广播电台","title":"孟加拉国已向国际机构申请超20亿美元紧急贷款  以缓解国内能源危机","content":"法新社消息称，据政府消息人士周六（3月21日）透露，目前因中东战争导致油气价格飙升，孟加拉国已向国际机构申请超过20亿美元的紧急贷款，以应对本国国内能源成本急剧上涨。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260321-%E5%AD%9F%E5%8A%A0%E6%8B%89%E5%9B%BD%E5%B7%B2%E5%90%91%E5%9B%BD%E9%99%85%E6%9C%BA%E6%9E%84%E7%94%B3%E8%AF%B7%E8%B6%8520%E4%BA%BF%E7%BE%8E%E5%85%83%E7%B4%A7%E6%80%A5%E8%B4%B7%E6%AC%BE-%E4%BB%A5%E7%BC%93%E8%A7%A3%E5%9B%BD%E5%86%85%E8%83%BD%E6%BA%90%E5%8D%B1%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774081620000.webp","sourceId":"rfi"},{"id":1774081015000,"createdDate":"2026-03-21 08:16","name":"法国国际广播电台","title":"俄罗斯近日提议停助伊朗换取美方弃援乌克兰，遭华盛顿拒绝，欧洲深感忧心","content":"据知情人士透露，俄罗斯曾提议，如果华盛顿停止向乌克兰提供足以打击俄罗斯目标的援助，俄方将不再为伊朗提供打击美军的目标情报。但这一提议遭到了美方的拒绝。据一名不具名欧洲外交官向媒体形容俄方提议“令人发指”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260321-%E4%BF%84%E7%BD%97%E6%96%AF%E8%BF%91%E6%97%A5%E6%8F%90%E8%AE%AE%E5%81%9C%E5%8A%A9%E4%BC%8A%E6%9C%97%E6%8D%A2%E5%8F%96%E7%BE%8E%E6%96%B9%E5%BC%83%E6%8F%B4%E4%B9%8C%E5%85%8B%E5%85%B0%EF%BC%8C%E9%81%AD%E5%8D%8E%E7%9B%9B%E9%A1%BF%E6%8B%92%E7%BB%9D%EF%BC%8C%E6%AC%A7%E6%B4%B2%E4%BB%8D%E6%84%9F%E5%BF%A7%E5%BF%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774081015000.webp","sourceId":"rfi"}]