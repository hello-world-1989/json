[{"id":1774082125000,"createdDate":"2026-03-21 08:35","name":"法国国际广播电台","title":"不满兴建火葬场：广东信宜数百村人连日抗议 警民对峙激化","content":"中国广东茂名信宜近期爆发警民冲突，当地村民不满地方政府以修路名义征地，实为在村落、学校附近兴建火葬场，村民集结抗议，防暴警察镇压示威民众，导致多人受伤。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260321-%E4%B8%8D%E6%BB%A1%E5%85%B4%E5%BB%BA%E7%81%AB%E8%91%AC%E5%9C%BA-%E5%B9%BF%E4%B8%9C%E4%BF%A1%E5%AE%9C%E6%95%B0%E7%99%BE%E6%9D%91%E4%BA%BA%E8%BF%9E%E6%97%A5%E6%8A%97%E8%AE%AE-%E8%AD%A6%E6%B0%91%E5%AF%B9%E5%B3%99%E6%BF%80%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774082125000.webp","sourceId":"rfi"},{"id":1774081620000,"createdDate":"2026-03-21 08:27","name":"法国国际广播电台","title":"孟加拉国已向国际机构申请超20亿美元紧急贷款  以缓解国内能源危机","content":"法新社消息称，据政府消息人士周六（3月21日）透露，目前因中东战争导致油气价格飙升，孟加拉国已向国际机构申请超过20亿美元的紧急贷款，以应对本国国内能源成本急剧上涨。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260321-%E5%AD%9F%E5%8A%A0%E6%8B%89%E5%9B%BD%E5%B7%B2%E5%90%91%E5%9B%BD%E9%99%85%E6%9C%BA%E6%9E%84%E7%94%B3%E8%AF%B7%E8%B6%8520%E4%BA%BF%E7%BE%8E%E5%85%83%E7%B4%A7%E6%80%A5%E8%B4%B7%E6%AC%BE-%E4%BB%A5%E7%BC%93%E8%A7%A3%E5%9B%BD%E5%86%85%E8%83%BD%E6%BA%90%E5%8D%B1%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774081620000.webp","sourceId":"rfi"},{"id":1774081015000,"createdDate":"2026-03-21 08:16","name":"法国国际广播电台","title":"俄罗斯近日提议停助伊朗换取美方弃援乌克兰，遭华盛顿拒绝，欧洲深感忧心","content":"据知情人士透露，俄罗斯曾提议，如果华盛顿停止向乌克兰提供足以打击俄罗斯目标的援助，俄方将不再为伊朗提供打击美军的目标情报。但这一提议遭到了美方的拒绝。据一名不具名欧洲外交官向媒体形容俄方提议“令人发指”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260321-%E4%BF%84%E7%BD%97%E6%96%AF%E8%BF%91%E6%97%A5%E6%8F%90%E8%AE%AE%E5%81%9C%E5%8A%A9%E4%BC%8A%E6%9C%97%E6%8D%A2%E5%8F%96%E7%BE%8E%E6%96%B9%E5%BC%83%E6%8F%B4%E4%B9%8C%E5%85%8B%E5%85%B0%EF%BC%8C%E9%81%AD%E5%8D%8E%E7%9B%9B%E9%A1%BF%E6%8B%92%E7%BB%9D%EF%BC%8C%E6%AC%A7%E6%B4%B2%E4%BB%8D%E6%84%9F%E5%BF%A7%E5%BF%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774081015000.webp","sourceId":"rfi"},{"id":1774106729000,"createdDate":"2026-03-21 15:25","name":"法国国际广播电台","title":"K-pop王者归来：防弹少年团首尔开唱 全球粉丝泪目嗨欢","content":"法新社发自首尔的电稿称，周六21日晚，韩国现象级组合防弹少年团（BTS）时隔近四年再次全员合体登台。这场在首尔市中心举行的K-pop盛宴点燃了现场巨量粉丝的热情，并向全球数百万在线观看的观众进行了实时直播。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260321-k-pop%E7%8E%8B%E8%80%85%E5%BD%92%E6%9D%A5-%E9%98%B2%E5%BC%B9%E5%B0%91%E5%B9%B4%E5%9B%A2%E9%A6%96%E5%B0%94%E5%BC%80%E5%94%B1-%E5%85%A8%E7%90%83%E7%B2%89%E4%B8%9D%E6%B3%AA%E7%9B%AE%E5%97%A8%E6%AC%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774106729000.webp","sourceId":"rfi"},{"id":1774104913000,"createdDate":"2026-03-21 14:55","name":"法国国际广播电台","title":"知情权高于一切！法官推翻五角大楼针对媒体的严苛新规","content":"六个月后，法律终于给出了裁决：五角大楼无权限制记者的信息获取渠道。去年，美国“战争部”针对军方内部的消息源获取实施了极为严苛的新规，并威胁要对泄露机密信息的记者提起诉讼。随后，包括《纽约时报》、《华盛顿邮报》及CNN顶级名记在内的几乎所有媒体，都以交回五角大楼通行证的方式表达抗议。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260321-%E7%9F%A5%E6%83%85%E6%9D%83%E9%AB%98%E4%BA%8E%E4%B8%80%E5%88%87-%E6%B3%95%E5%AE%98%E6%8E%A8%E7%BF%BB%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC%E9%92%88%E5%AF%B9%E5%AA%92%E4%BD%93%E7%9A%84%E4%B8%A5%E8%8B%9B%E6%96%B0%E8%A7%84","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774104913000.webp","sourceId":"rfi"},{"id":1774103532000,"createdDate":"2026-03-21 14:32","name":"法国国际广播电台","title":"赖清德：核二、核三具重启运转条件 三月底送核安会审议","content":"基于中东战争引发的全球能源紧缺，据中央社报道，台湾总统赖清德今天（3月21日）说，立法院通过核管法，政府要依法行政，经济部审慎评估后回文台电，表达核二、核三两座核能发电站具重启运转条件，台湾电力公司已在准备重启程序，预计3月底重启计划送核安会审议。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260321-%E8%B5%96%E6%B8%85%E5%BE%B7-%E6%A0%B8%E4%BA%8C-%E6%A0%B8%E4%B8%89%E5%85%B7%E9%87%8D%E5%90%AF%E8%BF%90%E8%BD%AC%E6%9D%A1%E4%BB%B6-%E4%B8%89%E6%9C%88%E5%BA%95%E9%80%81%E6%A0%B8%E5%AE%89%E4%BC%9A%E5%AE%A1%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774103532000.webp","sourceId":"rfi"},{"id":1774102210000,"createdDate":"2026-03-21 14:10","name":"法国国际广播电台","title":"五角大楼：美军将长期用Palantir研发的Maven AI进行精确打击","content":"路透社华盛顿消息，五角大楼将把科技初创公司Palantir的AI系统Maven列为“正式在编项目”，确定美军将长期使用该公司的武器目标锁定技术。五角大楼强调，未来将以AI驱动决策为核心战略，加速各军种的全面整合。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260321-%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC-%E7%BE%8E%E5%86%9B%E5%B0%86%E9%95%BF%E6%9C%9F%E7%94%A8palantir%E7%A0%94%E5%8F%91%E7%9A%84maven-ai%E8%BF%9B%E8%A1%8C%E7%B2%BE%E7%A1%AE%E6%89%93%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774102210000.webp","sourceId":"rfi"},{"id":1774097806000,"createdDate":"2026-03-21 12:56","name":"法国国际广播电台","title":"德国顶尖通信学者跳槽华为 柏林高度警惕国安风险","content":"据中央社21日发自柏林的电稿称，德国一名重量级通信技术学者近日入职中国电信设备巨头华为，负责光学芯片研发。德国政府与情报机构发出警告称，这项人事变动可能导致涉及关键基础设施的相关技术与知识外流，带来国家安全风险。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260321-%E5%BE%B7%E5%9B%BD%E9%A1%B6%E5%B0%96%E9%80%9A%E4%BF%A1%E5%AD%A6%E8%80%85%E8%B7%B3%E6%A7%BD%E5%8D%8E%E4%B8%BA-%E6%9F%8F%E6%9E%97%E9%AB%98%E5%BA%A6%E8%AD%A6%E6%83%95%E5%9B%BD%E5%AE%89%E9%A3%8E%E9%99%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774097806000.webp","sourceId":"rfi"},{"id":1774096214000,"createdDate":"2026-03-21 12:30","name":"法国国际广播电台","title":"战损扩大：不仅中东美军基地遭袭 4000公里外美英联合基地也成伊朗导弹目标","content":"据美智库最新分析显示，伊朗的报复性袭击已导致美军在中东地区的军事基础设施损失约8亿美元，伊朗的导弹打击范围也显著扩大，近日还首次尝试袭击远在印度洋的美英联合军事基地。这些都显示出，美国为打击伊朗所付出的代价将会越来越大。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260321-%E6%88%98%E6%8D%9F%E6%89%A9%E5%A4%A7-%E4%B8%8D%E4%BB%85%E4%B8%AD%E4%B8%9C%E7%BE%8E%E5%86%9B%E5%9F%BA%E5%9C%B0%E9%81%AD%E8%A2%AD-4000%E5%85%AC%E9%87%8C%E5%A4%96%E7%BE%8E%E8%8B%B1%E8%81%94%E5%90%88%E5%9F%BA%E5%9C%B0%E4%B9%9F%E6%88%90%E4%BC%8A%E6%9C%97%E5%AF%BC%E5%BC%B9%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774096214000.webp","sourceId":"rfi"},{"id":1774093036000,"createdDate":"2026-03-21 11:37","name":"法国国际广播电台","title":"快讯：纳坦兹核设施遭美以空袭、国际原子能机构呼吁“军事克制”","content":"路透社引述伊朗塔斯尼姆通讯社报道，美国和以色列今天（3月21日）对纳坦兹铀浓缩设施发动袭击。与此同时，美国向中东增派数千名士兵，并谴责其北约盟友试图远离冲突、缺乏支持。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260321-%E5%BF%AB%E8%AE%AF-%E7%BA%B3%E5%9D%A6%E5%85%B9%E6%A0%B8%E8%AE%BE%E6%96%BD%E9%81%AD%E7%BE%8E%E4%BB%A5%E7%A9%BA%E8%A2%AD-%E5%9B%BD%E9%99%85%E5%8E%9F%E5%AD%90%E8%83%BD%E6%9C%BA%E6%9E%84%E5%91%BC%E5%90%81-%E5%86%9B%E4%BA%8B%E5%85%8B%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774093036000.webp","sourceId":"rfi"},{"id":1774089788000,"createdDate":"2026-03-21 10:43","name":"法国国际广播电台","title":"中东战火持续 特朗普要“逐步减少”对伊军事行动 但排除停火","content":"美国和以色列联合对伊朗进行军事行动已经有三周，短期内仍看不到战争结束的迹象，虽然美国总统特朗普表示正在考虑“逐步减少”针对伊朗的军事行动，但今天周六针锋相对的袭击仍在继续。另外在波斯新年之际，俄罗斯总统普京重申支持伊朗 。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260321-%E4%B8%AD%E4%B8%9C%E6%88%98%E7%81%AB%E6%8C%81%E7%BB%AD-%E7%89%B9%E6%9C%97%E6%99%AE%E8%A6%81-%E9%80%90%E6%AD%A5%E5%87%8F%E5%B0%91-%E5%AF%B9%E4%BC%8A%E5%86%9B%E4%BA%8B%E8%A1%8C%E5%8A%A8-%E4%BD%86%E6%8E%92%E9%99%A4%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774089788000.webp","sourceId":"rfi"},{"id":1774089390000,"createdDate":"2026-03-21 10:36","name":"法国国际广播电台","title":"俄乌战争：莫斯科称基辅向其发射近300架无人机","content":"在乌克兰和美国谈判代表于今天周六在美国举行会晤之际，俄罗斯国防部称乌克兰于周五晚至周六凌晨向俄罗斯发射了283架无人机，这是双方爆发战争以来数量最多的一次。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260321-%E4%BF%84%E4%B9%8C%E6%88%98%E4%BA%89-%E8%8E%AB%E6%96%AF%E7%A7%91%E7%A7%B0%E5%9F%BA%E8%BE%85%E5%90%91%E5%85%B6%E5%8F%91%E5%B0%84%E8%BF%91300%E6%9E%B6%E6%97%A0%E4%BA%BA%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774089390000.webp","sourceId":"rfi"},{"id":1774084725000,"createdDate":"2026-03-21 09:18","name":"法国国际广播电台","title":"美国宣布伊朗石油制裁“豁免30天” 释出1.4亿桶原油缓解压力","content":"美国财长贝森特表示，特朗普政府已发布为期30天的制裁豁免令，允许从海上购买伊朗石油，以缓解自美以对伊朗发动战争以来能源供应面临的压力。新许可允许出售截至3月20日已装载上船的伊朗原油及石油产品。该许可证已发布在美国财政部网站上。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260321-%E7%BE%8E%E5%9B%BD%E5%AE%A3%E5%B8%83%E4%BC%8A%E6%9C%97%E7%9F%B3%E6%B2%B9%E5%88%B6%E8%A3%81-%E8%B1%81%E5%85%8D30%E5%A4%A9-%E9%87%8A%E5%87%BA1-4%E4%BA%BF%E6%A1%B6%E5%8E%9F%E6%B2%B9%E7%BC%93%E8%A7%A3%E5%8E%8B%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774084725000.webp","sourceId":"rfi"},{"id":1774084545000,"createdDate":"2026-03-21 09:15","name":"法国国际广播电台","title":"特朗普大骂北约赞美日本 伊朗称对日本油轮“网开一面”","content":"围绕伊朗宣布封锁石油运输要冲——霍尔木兹海峡，由于北约表示不会应特朗普的要求出兵卷入战争，特朗普总统3月20日在社交媒体上发文称：“如果没有美国，北约不过是‘纸老虎’。他们不愿参与阻止伊朗拥有核武器的斗争。”而在20日他谈到日本时表示：“虽然存在宪法上的限制，但如果有需要，日本会提供支持”，“日本是比北约更优秀的盟友”，而据共同社21日报道，伊朗外长阿拉格奇于20日接受共同通信社电话采访时表示，有关处于封锁状态的能源运输要冲霍尔木兹海峡，经过与日方协商，已准备允许与日本相关的船舶通行。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260321-%E7%89%B9%E6%9C%97%E6%99%AE%E5%A4%A7%E9%AA%82%E5%8C%97%E7%BA%A6%E8%B5%9E%E7%BE%8E%E6%97%A5%E6%9C%AC-%E4%BC%8A%E6%9C%97%E7%A7%B0%E5%AF%B9%E6%97%A5%E6%9C%AC%E6%B2%B9%E8%BD%AE-%E7%BD%91%E5%BC%80%E4%B8%80%E9%9D%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774084545000.webp","sourceId":"rfi"},{"id":1774135445000,"createdDate":"2026-03-21 23:24","name":"法国国际广播电台","title":"伊朗向4000公里外英美基地发射导弹释放了什么信号","content":"英国周六证实，伊朗周五向位于印度洋中部的美英联合军事基地迪戈加西亚发射了两枚弹道导弹。尽管“并未击中基地”，但专家指出，伊朗通过此举向外界显示其军事打击能力远远超过中东地区。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260321-%E4%BC%8A%E6%9C%97%E5%90%914000%E5%85%AC%E9%87%8C%E5%A4%96%E8%8B%B1%E7%BE%8E%E5%9F%BA%E5%9C%B0%E5%8F%91%E5%B0%84%E5%AF%BC%E5%BC%B9%E9%87%8A%E6%94%BE%E4%BA%86%E4%BB%80%E4%B9%88%E4%BF%A1%E5%8F%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774135445000.webp","sourceId":"rfi"},{"id":1774133879000,"createdDate":"2026-03-21 22:57","name":"法国国际广播电台","title":"中东战争:肯尼亚拟海湾撤侨50万","content":"面对中东地区爆发的战争，非洲国家肯尼亚（leKenya）正在考虑接回其在海湾地区的50万侨民。这是本台法广非洲组（RFIAfrique）2026年03月21日星期六的最新法文消息之一。为筹备这一预计庞大规模的行动，肯尼亚外交部已于两天前的本周四向国会请求拨款4亿肯尼亚先令（KES/shillingskényan）。不过，肯尼亚反对派阵营担心，这项行动有高昂代价的潜在可能性。肯尼亚的中文国名，也有译作肯亚（JamhuriyaKenya）。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260321-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89-%E8%82%AF%E5%B0%BC%E4%BA%9A%E6%8B%9F%E6%B5%B7%E6%B9%BE%E6%92%A4%E4%BE%A850%E4%B8%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774133879000.webp","sourceId":"rfi"},{"id":1774132498000,"createdDate":"2026-03-21 22:34","name":"法国国际广播电台","title":"美国宣布：已摧毁伊朗一处藏有武器的地下掩体","content":"美国军方周六宣布，已摧毁伊朗一处藏有武器的地下掩体，这个掩体威胁着霍尔木兹海峡的石油和天然气运输。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260321-%E7%BE%8E%E5%9B%BD%E5%AE%A3%E5%B8%83-%E5%B7%B2%E6%91%A7%E6%AF%81%E4%BC%8A%E6%9C%97%E4%B8%80%E5%A4%84%E8%97%8F%E6%9C%89%E6%AD%A6%E5%99%A8%E7%9A%84%E5%9C%B0%E4%B8%8B%E6%8E%A9%E4%BD%93","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774132498000.webp","sourceId":"rfi"},{"id":1774132056000,"createdDate":"2026-03-21 22:27","name":"法国国际广播电台","title":"肯尼亚和乌干达总统庆祝中国援建铁路延伸段竣工 ：铁路年运营收入1.65亿美元，年还债额10亿美元","content":"肯尼亚和乌干达两国总统周六在两国边境附近会晤，共同庆祝耗资数十亿美元、历经波折的中国援建铁路延伸段竣工。这条铁路的建设使肯尼亚背负了沉重的债务。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260321-%E8%82%AF%E5%B0%BC%E4%BA%9A%E5%92%8C%E4%B9%8C%E5%B9%B2%E8%BE%BE%E6%80%BB%E7%BB%9F%E5%BA%86%E7%A5%9D%E4%B8%AD%E5%9B%BD%E6%8F%B4%E5%BB%BA%E9%93%81%E8%B7%AF%E5%BB%B6%E4%BC%B8%E6%AE%B5%E7%AB%A3%E5%B7%A5-%E9%93%81%E8%B7%AF%E5%B9%B4%E8%BF%90%E8%90%A5%E6%94%B6%E5%85%A51-65%E4%BA%BF%E7%BE%8E%E5%85%83%EF%BC%8C%E5%B9%B4%E8%BF%98%E5%80%BA%E9%A2%9D10%E4%BA%BF%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774132056000.webp","sourceId":"rfi"},{"id":1774131630000,"createdDate":"2026-03-21 22:20","name":"法国国际广播电台","title":"泽连斯基： 美国和乌克兰谈判代表在美国举行会晤， 争取重启以结束乌克兰战争为目的的谈判","content":"乌克兰总统泽连斯基周六表示，为了重启以结束乌克兰战争为目的的谈判， 美国和乌克兰谈判代表在美国举行会晤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260321-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%B9%8C%E5%85%8B%E5%85%B0%E8%B0%88%E5%88%A4%E4%BB%A3%E8%A1%A8%E5%9C%A8%E7%BE%8E%E5%9B%BD%E4%B8%BE%E8%A1%8C%E4%BC%9A%E6%99%A4%EF%BC%8C-%E4%BA%89%E5%8F%96%E9%87%8D%E5%90%AF%E4%BB%A5%E7%BB%93%E6%9D%9F%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E4%BA%89%E4%B8%BA%E7%9B%AE%E7%9A%84%E7%9A%84%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774131630000.webp","sourceId":"rfi"},{"id":1774130310000,"createdDate":"2026-03-21 21:58","name":"法国国际广播电台","title":"欧洲从中国进口的汽车首次超过对华出口","content":"据德国《明镜》周刊报道，多年来，欧洲汽车制造商一直是全球汽车市场的霸主，这几乎被视为理所当然。然而，风向正在发生变化。根据安永（EY）的一项分析报告，欧盟从中国进口的汽车数量首次超过其对中国的出口。去年，欧盟向中国出口的汽车及零部件下降了34%，降至160亿欧元。自2022年以来，这一出口额已减少超过一半。与此同时，从中国进口的相关产品增长了8%，达到220亿欧元。短短数年间，原本高达数百亿欧元的贸易顺差已转为逆差。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260321-%E6%AC%A7%E6%B4%B2%E4%BB%8E%E4%B8%AD%E5%9B%BD%E8%BF%9B%E5%8F%A3%E7%9A%84%E6%B1%BD%E8%BD%A6%E9%A6%96%E6%AC%A1%E8%B6%85%E8%BF%87%E5%AF%B9%E5%8D%8E%E5%87%BA%E5%8F%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774130310000.webp","sourceId":"rfi"},{"id":1774126729000,"createdDate":"2026-03-21 20:58","name":"法国国际广播电台","title":"TSA缺工美国机场大排长龙 特朗普扬言派移民局警察进驻","content":"随着美国国土安全部部分停摆持续，全美机场正陷入前所未见的运作混乱。运输安全管理局（TSA）人员因长期领不到薪资，出现大规模请假与离职潮，各地安检人力吃紧，导致排队时间动辄超过2至3小时，航班延误与取消数量急剧攀升。从纽约到德州，多座大型机场已出现长时间壅塞情况，甚至有旅客在清晨即排起长龙，整体航空运输体系濒临失序。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260321-tsa%E7%BC%BA%E5%B7%A5%E7%BE%8E%E5%9B%BD%E6%9C%BA%E5%9C%BA%E5%A4%A7%E6%8E%92%E9%95%BF%E9%BE%99-%E7%89%B9%E6%9C%97%E6%99%AE%E6%89%AC%E8%A8%80%E6%B4%BE%E7%A7%BB%E6%B0%91%E5%B1%80%E8%AD%A6%E5%AF%9F%E8%BF%9B%E9%A9%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774126729000.webp","sourceId":"rfi"},{"id":1774125911000,"createdDate":"2026-03-21 20:45","name":"法国国际广播电台","title":"危险升级 报复美以轰炸核设施 伊朗袭击以色列核重地迪莫纳","content":"美以周六轰炸伊朗中部的纳坦兹核设施后，以色列一座拥有核研究和开发中心的重镇当晚遭伊朗多次导弹袭击，以色列军方承认导弹拦截失败，最新报告显示至少30多人受伤。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260321-%E5%8D%B1%E9%99%A9%E5%8D%87%E7%BA%A7-%E6%8A%A5%E5%A4%8D%E7%BE%8E%E4%BB%A5%E8%BD%B0%E7%82%B8%E6%A0%B8%E8%AE%BE%E6%96%BD-%E4%BC%8A%E6%9C%97%E8%A2%AD%E5%87%BB%E4%BB%A5%E8%89%B2%E5%88%97%E6%A0%B8%E9%87%8D%E5%9C%B0%E8%BF%AA%E8%8E%AB%E7%BA%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/21/1774125911000.webp","sourceId":"rfi"}]