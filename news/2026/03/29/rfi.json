[{"id":1774771268000,"createdDate":"2026-03-29 08:01","name":"法国国际广播电台","title":"自卫官闯入中国驻日大使馆 日本警方对自卫队驻屯地进行搜查","content":"因日本陆上自卫队自卫官村田晃大（23岁）闯入中国大使馆被捕，东京警视厅公安部3月29日上午对该男子所属的陆上自卫队宫崎县驻屯地进行了搜查。警方表示，将通过此次搜查，进一步推进对相关嫌疑的取证工作。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260329-%E8%87%AA%E5%8D%AB%E5%AE%98%E9%97%AF%E5%85%A5%E4%B8%AD%E5%9B%BD%E9%A9%BB%E6%97%A5%E5%A4%A7%E4%BD%BF%E9%A6%86-%E6%97%A5%E6%9C%AC%E8%AD%A6%E6%96%B9%E5%AF%B9%E8%87%AA%E5%8D%AB%E9%98%9F%E9%A9%BB%E5%B1%AF%E5%9C%B0%E8%BF%9B%E8%A1%8C%E6%90%9C%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774771268000.webp","sourceId":"rfi"}]