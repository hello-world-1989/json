[{"id":1774771268000,"createdDate":"2026-03-29 08:01","name":"法国国际广播电台","title":"自卫官闯入中国驻日大使馆 日本警方对自卫队驻屯地进行搜查","content":"因日本陆上自卫队自卫官村田晃大（23岁）闯入中国大使馆被捕，东京警视厅公安部3月29日上午对该男子所属的陆上自卫队宫崎县驻屯地进行了搜查。警方表示，将通过此次搜查，进一步推进对相关嫌疑的取证工作。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260329-%E8%87%AA%E5%8D%AB%E5%AE%98%E9%97%AF%E5%85%A5%E4%B8%AD%E5%9B%BD%E9%A9%BB%E6%97%A5%E5%A4%A7%E4%BD%BF%E9%A6%86-%E6%97%A5%E6%9C%AC%E8%AD%A6%E6%96%B9%E5%AF%B9%E8%87%AA%E5%8D%AB%E9%98%9F%E9%A9%BB%E5%B1%AF%E5%9C%B0%E8%BF%9B%E8%A1%8C%E6%90%9C%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774771268000.webp","sourceId":"rfi"},{"id":1774796550000,"createdDate":"2026-03-29 15:02","name":"法国国际广播电台","title":"FBI局长促公布对“中国女间谍”方芳调查文件 涉事议员：因为我是州长竞选热门人选","content":"据《纽约时报》援引知情人士报导称，特朗普政府官员已下令美国联邦调查局（FBI）特工收集十年前针对一名民主党籍联邦众议员及其与一名疑似中国间谍关系的调查文件。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260329-fbi%E5%B1%80%E9%95%BF%E5%8A%9B%E4%BF%83%E5%85%AC%E5%B8%83%E5%AF%B9-%E4%B8%AD%E5%9B%BD%E5%A5%B3%E9%97%B4%E8%B0%8D-%E6%96%B9%E8%8A%B3%E8%B0%83%E6%9F%A5%E6%96%87%E4%BB%B6-%E6%B6%89%E4%BA%8B%E8%AE%AE%E5%91%98-%E5%9B%A0%E4%B8%BA%E6%88%91%E6%98%AF%E5%B7%9E%E9%95%BF%E7%AB%9E%E9%80%89%E7%83%AD%E9%97%A8%E4%BA%BA%E9%80%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774796550000.webp","sourceId":"rfi"},{"id":1774791626000,"createdDate":"2026-03-29 13:40","name":"法国国际广播电台","title":"五角大楼制定在伊朗开展“数周”地面行动方案 沙土埃巴四国召开外长会","content":"伊朗官员声称已做好应对美国地面进攻的准备，并于周日指责华盛顿正准备发动地面进攻。与此同时，伊朗仍在寻求谈判，地区大国也在巴基斯坦举行会谈，试图结束这场冲突。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260329-%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC%E5%88%B6%E5%AE%9A%E5%9C%A8%E4%BC%8A%E6%9C%97%E5%BC%80%E5%B1%95-%E6%95%B0%E5%91%A8-%E5%9C%B0%E9%9D%A2%E8%A1%8C%E5%8A%A8%E6%96%B9%E6%A1%88-%E6%B2%99%E5%9C%9F%E5%9F%83%E5%B7%B4%E5%9B%9B%E5%9B%BD%E5%8F%AC%E5%BC%80%E5%A4%96%E9%95%BF%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774791626000.webp","sourceId":"rfi"},{"id":1774786700000,"createdDate":"2026-03-29 12:18","name":"法国国际广播电台","title":"一中国游客承认在关岛安德森空军基地非法拍摄国防设施","content":"根据关岛地区法院的文件，一名中国游客承认在位于伊戈村的安德森空军基地拍摄照片。冯炳坤（BingkunFen、音译）最初被指控擅闯军事用地并拍摄国防设施。作为认罪协议的一部分，对他的擅闯军事用地的指控被撤销。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260329-%E4%B8%80%E4%B8%AD%E5%9B%BD%E6%B8%B8%E5%AE%A2%E6%89%BF%E8%AE%A4%E5%9C%A8%E5%85%B3%E5%B2%9B%E5%AE%89%E5%BE%B7%E6%A3%AE%E7%A9%BA%E5%86%9B%E5%9F%BA%E5%9C%B0%E9%9D%9E%E6%B3%95%E6%8B%8D%E6%91%84%E5%9B%BD%E9%98%B2%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774786700000.webp","sourceId":"rfi"},{"id":1774784691000,"createdDate":"2026-03-29 11:44","name":"法国国际广播电台","title":"欧洲盟友：俄罗斯对伊朗的援助远超美国承认的程度","content":"欧洲盟友警告美国，华盛顿低估了俄罗斯对伊朗的军事支持。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260329-%E6%AC%A7%E6%B4%B2%E7%9B%9F%E5%8F%8B-%E4%BF%84%E7%BD%97%E6%96%AF%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%9A%84%E6%8F%B4%E5%8A%A9%E8%BF%9C%E8%B6%85%E7%BE%8E%E5%9B%BD%E6%89%BF%E8%AE%A4%E7%9A%84%E7%A8%8B%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774784691000.webp","sourceId":"rfi"},{"id":1774782026000,"createdDate":"2026-03-29 11:00","name":"法国国际广播电台","title":"中东战火升级  恐重创全球能源与经济","content":"目前，由美国、以色列联合针对伊朗实施军事打击引起的中东安全危机正进入高度紧张时刻。媒体纷纷爆料美军或将对伊朗展开为期数周的地面攻势。这对外界而言意味着撼动全球能源供应系统的霍尔木兹海峡威胁仍将持续存在。围绕石油、粮食与转移劳工等议题，东南亚国家联盟（ASEAN）峰会决定于今年5月如期在菲律宾举行，重点讨论中东战争带来的经济冲击并且寻求因应之道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260329-%E4%B8%AD%E4%B8%9C%E6%88%98%E7%81%AB%E5%8D%87%E7%BA%A7-%E6%81%90%E9%87%8D%E5%88%9B%E5%85%A8%E7%90%83%E8%83%BD%E6%BA%90%E4%B8%8E%E7%BB%8F%E6%B5%8E-1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774782026000.webp","sourceId":"rfi"},{"id":1774781338000,"createdDate":"2026-03-29 10:48","name":"法国国际广播电台","title":"非洲偷渡客尝试潜入中东遭海难","content":"在世界各国民众纷纷因伊朗战事而远离中东及海湾地区之际，在亚非两大洲的交界地带，临近出入苏伊士运河海上航道红海要冲曼德海峡（ledétroitdeBabel-Mandeb）附近，一艘搭载了超过320人的船只，逆人潮而行，从东非出发试图潜入阿拉伯半岛上的中东国家也门，但不幸于2026年03月24日周二至25日周三夜间在吉布提水域发生海难。至少有近10死亡和45人失踪。这是本台法广非洲组（RFIAfrique）2026年03月28日星期六上网的法文消息之一。本台法广（RFI）非洲通讯员发自内罗毕（Nairobi）的法文报道说，国际移民组织（OIM-Organisationinternationaledesmigration）在一份新闻通报中表示，这是一批试图进入西亚的移民。另外，本台法广（RFI）今天03月29号周日更新的法文报道显示，反对美以两国打击伊朗的也门胡塞武装已开始卷入中东地区当前战事，并于昨天03月28日周六两次向以色列发射导弹和无人机。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260329-%E9%9D%9E%E6%B4%B2%E5%81%B7%E6%B8%A1%E5%AE%A2%E5%B0%9D%E8%AF%95%E6%BD%9C%E5%85%A5%E4%B8%AD%E4%B8%9C%E9%81%AD%E6%B5%B7%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774781338000.webp","sourceId":"rfi"},{"id":1774780659000,"createdDate":"2026-03-29 10:37","name":"法国国际广播电台","title":"二战后日本作战部队将首次重返菲律宾 参加美澳菲日四国联演","content":"二战结束后，日本具备作战能力的部队将首次重返菲律宾——这次不是以占领者的身份，而是以紧密伙伴的身份。预计至少有数百名日本自卫队人员将抵达菲律宾，与菲律宾、美国和澳大利亚的军队共同参加一年一度的“肩并肩”联合军事演习，这将是迄今为止规模最大的一次，也标志着区域安全合作迈出了新的一步。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260329-%E4%BA%8C%E6%88%98%E5%90%8E%E6%97%A5%E6%9C%AC%E4%BD%9C%E6%88%98%E9%83%A8%E9%98%9F%E5%B0%86%E9%A6%96%E6%AC%A1%E9%87%8D%E8%BF%94%E8%8F%B2%E5%BE%8B%E5%AE%BE-%E5%8F%82%E5%8A%A0%E7%BE%8E%E6%BE%B3%E8%8F%B2%E6%97%A5%E5%9B%9B%E5%9B%BD%E8%81%94%E6%BC%94","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774780659000.webp","sourceId":"rfi"},{"id":1774778573000,"createdDate":"2026-03-29 10:02","name":"法国国际广播电台","title":"欧盟高官证实正探索与美英建立西方钢铁联盟 应对中国产能过剩","content":"欧盟委员会贸易和经济安全委员谢夫乔维奇（MarošŠefčovič）周六证实，欧盟正在探索与美国和英国建立西方钢铁联盟，以应对中国的工业产能过剩问题。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260329-%E6%AC%A7%E7%9B%9F%E9%AB%98%E5%AE%98%E8%AF%81%E5%AE%9E%E6%AD%A3%E6%8E%A2%E7%B4%A2%E4%B8%8E%E7%BE%8E%E8%8B%B1%E5%BB%BA%E7%AB%8B%E8%A5%BF%E6%96%B9%E9%92%A2%E9%93%81%E8%81%94%E7%9B%9F-%E5%BA%94%E5%AF%B9%E4%B8%AD%E5%9B%BD%E4%BA%A7%E8%83%BD%E8%BF%87%E5%89%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774778573000.webp","sourceId":"rfi"},{"id":1774778345000,"createdDate":"2026-03-29 09:59","name":"法国国际广播电台","title":"伊战阴影下 法国总马克龙下周出访日韩","content":"法国总统马克龙将于下周二（3月31号）至周五出访日本和韩国，试图与这两个亚洲国家就中东战争寻求“共同解决方案”。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260329-%E4%BC%8A%E6%88%98%E9%98%B4%E5%BD%B1%E4%B8%8B-%E6%B3%95%E5%9B%BD%E6%80%BB%E9%A9%AC%E5%85%8B%E9%BE%99%E4%B8%8B%E5%91%A8%E5%87%BA%E8%AE%BF%E6%97%A5%E9%9F%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774778345000.webp","sourceId":"rfi"},{"id":1774776848000,"createdDate":"2026-03-29 09:34","name":"法国国际广播电台","title":"驻港公署特派员就电子设备“安全警告”一事约见美驻港总领事","content":"中国外交部驻港公署特派员崔建春周五约见了美国驻港总领事伊珠丽（JulieEadeh），就美国驻港总领馆就港府修订《香港国安法第四十三条实施细则》发布“安全警告”一事提出严正交涉，表示强烈不满和坚决反对。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260329-%E9%A9%BB%E6%B8%AF%E5%85%AC%E7%BD%B2%E7%89%B9%E6%B4%BE%E5%91%98%E5%B0%B1%E7%94%B5%E5%AD%90%E8%AE%BE%E5%A4%87-%E5%AE%89%E5%85%A8%E8%AD%A6%E5%91%8A-%E4%B8%80%E4%BA%8B%E7%BA%A6%E8%A7%81%E7%BE%8E%E9%A9%BB%E6%B8%AF%E6%80%BB%E9%A2%86%E4%BA%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774776848000.webp","sourceId":"rfi"},{"id":1774775173000,"createdDate":"2026-03-29 09:06","name":"法国国际广播电台","title":"泽连斯基：100%确信俄正向伊朗提供中东美军情报，这符合俄利益","content":"据乌克兰总统泽连斯基（VolodymyrZelenskyy）向美国全国广播公司（NBC）提供的乌方情报摘要显示，在伊朗袭击该基地并造成美军人员受伤的前几天，俄罗斯曾三次拍摄了位于沙特的一处美国空军基地的卫星图像。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260329-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-100-%E7%A1%AE%E4%BF%A1%E4%BF%84%E6%AD%A3%E5%90%91%E4%BC%8A%E6%9C%97%E6%8F%90%E4%BE%9B%E4%B8%AD%E4%B8%9C%E7%BE%8E%E5%86%9B%E6%83%85%E6%8A%A5%EF%BC%8C%E8%BF%99%E7%AC%A6%E5%90%88%E4%BF%84%E5%88%A9%E7%9B%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774775173000.webp","sourceId":"rfi"},{"id":1774773773000,"createdDate":"2026-03-29 08:42","name":"法国国际广播电台","title":"民众党329声援柯文哲游行集会破万人，是否将影响台湾九合一选举？","content":"前民众党主席柯文哲一审被判有期徒刑17年，褫夺公权6年。民众党号召支持者上凯道游行支持。国民党团虽在判决后表示，拒绝政治判决并阻止司法崩坏，且全力支持，绝不缺席。但主席郑丽文29日则因既定行程无法出席。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260329-%E6%B0%91%E4%BC%97%E5%85%9A329%E5%A3%B0%E6%8F%B4%E6%9F%AF%E6%96%87%E5%93%B2%E6%B8%B8%E8%A1%8C%E9%9B%86%E4%BC%9A%E7%A0%B4%E4%B8%87%E4%BA%BA%EF%BC%8C%E6%98%AF%E5%90%A6%E5%B0%86%E5%BD%B1%E5%93%8D%E5%8F%B0%E6%B9%BE%E4%B9%9D%E5%90%88%E4%B8%80%E9%80%89%E4%B8%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774773773000.webp","sourceId":"rfi"},{"id":1774772196000,"createdDate":"2026-03-29 08:16","name":"法国国际广播电台","title":"中国知名教育博主张雪峰去世，网络热议","content":"37年前的3月26号，中国著名诗人海子在秦皇岛山海关附近卧轨自杀，年仅25岁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%BE%AE%E8%A8%80%E5%BE%AE%E8%AF%AD/20260329-%E4%B8%AD%E5%9B%BD%E7%9F%A5%E5%90%8D%E6%95%99%E8%82%B2%E5%8D%9A%E4%B8%BB%E5%BC%A0%E9%9B%AA%E5%B3%B0%E5%8E%BB%E4%B8%96%EF%BC%8C%E7%BD%91%E7%BB%9C%E7%83%AD%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774772196000.webp","sourceId":"rfi"},{"id":1774819059000,"createdDate":"2026-03-29 21:17","name":"法国国际广播电台","title":"伊朗空袭给海湾国家带来巨损 阿联酋要求伊朗赔偿","content":"自2月28日伊朗战争爆发以来，伊朗的空袭给海湾国家带来巨大损失。阿联酋总统顾问安瓦尔・加尔格什（AnwarGargesh）周日（3月29日）要求伊朗进行赔偿。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260329-%E4%BC%8A%E6%9C%97%E7%A9%BA%E8%A2%AD%E7%BB%99%E6%B5%B7%E6%B9%BE%E5%9B%BD%E5%AE%B6%E5%B8%A6%E6%9D%A5%E5%B7%A8%E6%8D%9F-%E9%98%BF%E8%81%94%E9%85%8B%E8%A6%81%E6%B1%82%E4%BC%8A%E6%9C%97%E8%B5%94%E5%81%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774819059000.webp","sourceId":"rfi"},{"id":1774817938000,"createdDate":"2026-03-29 20:58","name":"法国国际广播电台","title":"刚果(布)2026总统大选结果落定","content":"非洲国家刚果共和国宪法法院（laCourconstitutionnelle）于2026年03月28日星期六做出裁决，驳回了该国总统候选人DaveMafoula提出的取消03月15日大选第一轮投票结果的请求，确认现总统德尼·萨苏·恩格索（PrésidentDenisSassouNguesso）在2026年的总统选举中胜出，赢得五连任。这是本台法广非洲组（RFIAfrique)在03月29日星期天上网的最新法文消息之一。作为刚果（布）反对派阵营的总统候选人之一，DaveMafoula感到遗憾，而现总统的律师则表示满意。刚果共和国现总统预计将于两周后的04月16日举行其五连任的总统宣誓就职仪式。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260329-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%88%9A%E6%9E%9C-%E5%B8%83-2026%E6%80%BB%E7%BB%9F%E5%A4%A7%E9%80%89%E7%BB%93%E6%9E%9C%E8%90%BD%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774817938000.webp","sourceId":"rfi"},{"id":1774817920000,"createdDate":"2026-03-29 20:58","name":"法国国际广播电台","title":"法德英意发声明   深切关注以具歧视性死刑法案","content":"法、德、意和英国周日发表联合声明，对以色列一项旨在扩大死刑适用范围的法案表示“深切关注”。该法案原定于以色列议会（Knesset）进行投票表决。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260329-%E6%B3%95%E5%BE%B7%E8%8B%B1%E6%84%8F%E5%8F%91%E5%A3%B0%E6%98%8E-%E6%B7%B1%E5%88%87%E5%85%B3%E6%B3%A8%E4%BB%A5%E5%85%B7%E6%AD%A7%E8%A7%86%E6%80%A7%E6%AD%BB%E5%88%91%E6%B3%95%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774817920000.webp","sourceId":"rfi"},{"id":1774817616000,"createdDate":"2026-03-29 20:53","name":"法国国际广播电台","title":"耶路撒冷棕枝主日弥撒受阻","content":"天主教耶路撒冷拉丁宗主教区表示，以色列警方阻止主教进入老城基督徒区的圣墓教堂，导致他无法主持棕枝主日弥撒。西班牙首相桑切斯谴责以色列“毫无理由或正当理由”地阻止耶路撒冷拉丁礼宗主教进入圣墓教堂主持棕枝主日弥撒，称这是“对宗教自由的无端攻击”。欧盟谴责这是“侵犯宗教自由”的行为。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260329-%E8%80%B6%E8%B7%AF%E6%92%92%E5%86%B7%E6%A3%95%E6%9E%9D%E4%B8%BB%E6%97%A5%E5%BC%A5%E6%92%92%E5%8F%97%E9%98%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774817616000.webp","sourceId":"rfi"},{"id":1774817385000,"createdDate":"2026-03-29 20:49","name":"法国国际广播电台","title":"伊朗发电设施遭到袭击   多地停电","content":"伊朗能源部周日宣布，由于发电设施遭到袭击，德黑兰及其周边地区以及邻近的阿尔伯兹省（Alborz）出现停电。据伊朗国家电视台报道，“这些地区的电力已被切断，目前正在努力解决问题。”美国总统特朗普此前曾威胁称，如果德黑兰不重新开放具有战略意义的霍尔木兹海峡，他将对伊朗的发电厂发动袭击，但之后又多次推迟最后通牒。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260329-%E4%BC%8A%E6%9C%97%E5%8F%91%E7%94%B5%E8%AE%BE%E6%96%BD%E9%81%AD%E5%88%B0%E8%A2%AD%E5%87%BB-%E5%A4%9A%E5%9C%B0%E5%81%9C%E7%94%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774817385000.webp","sourceId":"rfi"},{"id":1774817195000,"createdDate":"2026-03-29 20:46","name":"法国国际广播电台","title":"伊朗：迎战美地面军事行动","content":"伊朗周日表示，已做好应对美国地面军事行动的准备，并指责华盛顿一边声称寻求谈判，一边却在筹划地面进攻。与此同时，几个主要地区国家的外长在巴基斯坦举行会议，试图结束战争。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260329-%E4%BC%8A%E6%9C%97-%E8%BF%8E%E6%88%98%E7%BE%8E%E5%9C%B0%E9%9D%A2%E5%86%9B%E4%BA%8B%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774817195000.webp","sourceId":"rfi"},{"id":1774817111000,"createdDate":"2026-03-29 20:45","name":"法国国际广播电台","title":"伊朗战争：特朗普批评默茨并威胁北约","content":"据德国电视一台报道：在伊朗战争问题上，美国总统唐纳德·特朗普批评默茨并威胁北约。北约仍然拒绝对霍尔木兹海峡提供军事保障。此前，默茨曾批评特朗普。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260329-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89-%E7%89%B9%E6%9C%97%E6%99%AE%E6%89%B9%E8%AF%84%E9%BB%98%E8%8C%A8%E5%B9%B6%E5%A8%81%E8%83%81%E5%8C%97%E7%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774817111000.webp","sourceId":"rfi"},{"id":1774817062000,"createdDate":"2026-03-29 20:44","name":"法国国际广播电台","title":"受益俄领空      中航新增飞往欧洲的航班、航线","content":"尽管欧洲仍然是中国游客的热门目的地，但中国主要航空公司正对欧洲大陆发起前所未有的攻势。在2026年夏季（3月下旬至10月下旬），他们计划比去年增加近2900个飞往欧洲的航班，从而在与欧洲和海湾地区航空公司的竞争中占据显著优势。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260329-%E5%8F%97%E7%9B%8A%E4%BF%84%E9%A2%86%E7%A9%BA-%E4%B8%AD%E8%88%AA%E6%96%B0%E5%A2%9E%E9%A3%9E%E5%BE%80%E6%AC%A7%E6%B4%B2%E7%9A%84%E8%88%AA%E7%8F%AD-%E8%88%AA%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774817062000.webp","sourceId":"rfi"},{"id":1774816736000,"createdDate":"2026-03-29 20:38","name":"法国国际广播电台","title":"一艘俄油轮靠近古巴港口     考验美国的禁运措施","content":"一艘受制裁的俄罗斯油轮预计将于周一抵达古巴，此举无视了美国对古巴的燃料供应封锁。据海事分析公司Kpler称，载有73万桶原油的“阿纳托利·科洛德金”号（L'AnatolyKolodkin）油轮周日位于海地北部，正驶往古巴西部的马坦萨斯港（Matanzas）。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260329-%E4%B8%80%E8%89%98%E4%BF%84%E6%B2%B9%E8%BD%AE%E9%9D%A0%E8%BF%91%E5%8F%A4%E5%B7%B4%E6%B8%AF%E5%8F%A3-%E8%80%83%E9%AA%8C%E7%BE%8E%E5%9B%BD%E7%9A%84%E7%A6%81%E8%BF%90%E6%8E%AA%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774816736000.webp","sourceId":"rfi"},{"id":1774816709000,"createdDate":"2026-03-29 20:38","name":"法国国际广播电台","title":"伊朗议长：要把登陆美军烧成灰并彻底惩罚美海湾盟友","content":"在约2500名受过两栖登陆训练的美国陆战队员抵达中东后，伊朗国会议长卡利巴夫（MohammadBagherGhalibaf）稍早表示，在巴基斯坦进行的会谈不过是掩人耳目的幌子。据伊朗国营媒体报导，伊朗国会议长威胁说，伊朗部队“正在等待美军抵达地面，然后把他们烧成灰烬，并且彻底惩罚他们的区域盟友”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260329-%E4%BC%8A%E6%9C%97%E8%AE%AE%E9%95%BF-%E8%A6%81%E6%8A%8A%E7%99%BB%E9%99%86%E7%BE%8E%E5%86%9B%E7%83%A7%E6%88%90%E7%81%B0%E5%B9%B6%E5%BD%BB%E5%BA%95%E6%83%A9%E7%BD%9A%E7%BE%8E%E6%B5%B7%E6%B9%BE%E7%9B%9F%E5%8F%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774816709000.webp","sourceId":"rfi"},{"id":1774816473000,"createdDate":"2026-03-29 20:34","name":"法国国际广播电台","title":"人权观察组织促请萨尔瓦多打击黑帮勿殃及无辜","content":"人权观察组织（HRW）呼吁萨尔瓦多总统纳伊布·布克莱（NayibBukele）政府结束其为打击帮派而展开的为期四年的紧急状态。这场“战争”已导致约9.1万人被捕。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260329-%E4%BA%BA%E6%9D%83%E8%A7%82%E5%AF%9F%E7%BB%84%E7%BB%87%E4%BF%83%E8%AF%B7%E8%90%A8%E5%B0%94%E7%93%A6%E5%A4%9A%E6%89%93%E5%87%BB%E9%BB%91%E5%B8%AE%E5%8B%BF%E6%AE%83%E5%8F%8A%E6%97%A0%E8%BE%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774816473000.webp","sourceId":"rfi"}]