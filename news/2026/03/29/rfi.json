[{"id":1774771268000,"createdDate":"2026-03-29 08:01","name":"法国国际广播电台","title":"自卫官闯入中国驻日大使馆 日本警方对自卫队驻屯地进行搜查","content":"因日本陆上自卫队自卫官村田晃大（23岁）闯入中国大使馆被捕，东京警视厅公安部3月29日上午对该男子所属的陆上自卫队宫崎县驻屯地进行了搜查。警方表示，将通过此次搜查，进一步推进对相关嫌疑的取证工作。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260329-%E8%87%AA%E5%8D%AB%E5%AE%98%E9%97%AF%E5%85%A5%E4%B8%AD%E5%9B%BD%E9%A9%BB%E6%97%A5%E5%A4%A7%E4%BD%BF%E9%A6%86-%E6%97%A5%E6%9C%AC%E8%AD%A6%E6%96%B9%E5%AF%B9%E8%87%AA%E5%8D%AB%E9%98%9F%E9%A9%BB%E5%B1%AF%E5%9C%B0%E8%BF%9B%E8%A1%8C%E6%90%9C%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774771268000.webp","sourceId":"rfi"},{"id":1774796550000,"createdDate":"2026-03-29 15:02","name":"法国国际广播电台","title":"FBI局长促公布对“中国女间谍”方芳调查文件 涉事议员：因为我是州长竞选热门人选","content":"据《纽约时报》援引知情人士报导称，特朗普政府官员已下令美国联邦调查局（FBI）特工收集十年前针对一名民主党籍联邦众议员及其与一名疑似中国间谍关系的调查文件。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260329-fbi%E5%B1%80%E9%95%BF%E5%8A%9B%E4%BF%83%E5%85%AC%E5%B8%83%E5%AF%B9-%E4%B8%AD%E5%9B%BD%E5%A5%B3%E9%97%B4%E8%B0%8D-%E6%96%B9%E8%8A%B3%E8%B0%83%E6%9F%A5%E6%96%87%E4%BB%B6-%E6%B6%89%E4%BA%8B%E8%AE%AE%E5%91%98-%E5%9B%A0%E4%B8%BA%E6%88%91%E6%98%AF%E5%B7%9E%E9%95%BF%E7%AB%9E%E9%80%89%E7%83%AD%E9%97%A8%E4%BA%BA%E9%80%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774796550000.webp","sourceId":"rfi"},{"id":1774791626000,"createdDate":"2026-03-29 13:40","name":"法国国际广播电台","title":"五角大楼制定在伊朗开展“数周”地面行动方案 沙土埃巴四国召开外长会","content":"伊朗官员声称已做好应对美国地面进攻的准备，并于周日指责华盛顿正准备发动地面进攻。与此同时，伊朗仍在寻求谈判，地区大国也在巴基斯坦举行会谈，试图结束这场冲突。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260329-%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC%E5%88%B6%E5%AE%9A%E5%9C%A8%E4%BC%8A%E6%9C%97%E5%BC%80%E5%B1%95-%E6%95%B0%E5%91%A8-%E5%9C%B0%E9%9D%A2%E8%A1%8C%E5%8A%A8%E6%96%B9%E6%A1%88-%E6%B2%99%E5%9C%9F%E5%9F%83%E5%B7%B4%E5%9B%9B%E5%9B%BD%E5%8F%AC%E5%BC%80%E5%A4%96%E9%95%BF%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774791626000.webp","sourceId":"rfi"},{"id":1774786700000,"createdDate":"2026-03-29 12:18","name":"法国国际广播电台","title":"一中国游客承认在关岛安德森空军基地非法拍摄国防设施","content":"根据关岛地区法院的文件，一名中国游客承认在位于伊戈村的安德森空军基地拍摄照片。冯炳坤（BingkunFen、音译）最初被指控擅闯军事用地并拍摄国防设施。作为认罪协议的一部分，对他的擅闯军事用地的指控被撤销。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260329-%E4%B8%80%E4%B8%AD%E5%9B%BD%E6%B8%B8%E5%AE%A2%E6%89%BF%E8%AE%A4%E5%9C%A8%E5%85%B3%E5%B2%9B%E5%AE%89%E5%BE%B7%E6%A3%AE%E7%A9%BA%E5%86%9B%E5%9F%BA%E5%9C%B0%E9%9D%9E%E6%B3%95%E6%8B%8D%E6%91%84%E5%9B%BD%E9%98%B2%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774786700000.webp","sourceId":"rfi"},{"id":1774784691000,"createdDate":"2026-03-29 11:44","name":"法国国际广播电台","title":"欧洲盟友：俄罗斯对伊朗的援助远超美国承认的程度","content":"欧洲盟友警告美国，华盛顿低估了俄罗斯对伊朗的军事支持。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260329-%E6%AC%A7%E6%B4%B2%E7%9B%9F%E5%8F%8B-%E4%BF%84%E7%BD%97%E6%96%AF%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%9A%84%E6%8F%B4%E5%8A%A9%E8%BF%9C%E8%B6%85%E7%BE%8E%E5%9B%BD%E6%89%BF%E8%AE%A4%E7%9A%84%E7%A8%8B%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774784691000.webp","sourceId":"rfi"},{"id":1774782026000,"createdDate":"2026-03-29 11:00","name":"法国国际广播电台","title":"中东战火升级  恐重创全球能源与经济","content":"目前，由美国、以色列联合针对伊朗实施军事打击引起的中东安全危机正进入高度紧张时刻。媒体纷纷爆料美军或将对伊朗展开为期数周的地面攻势。这对外界而言意味着撼动全球能源供应系统的霍尔木兹海峡威胁仍将持续存在。围绕石油、粮食与转移劳工等议题，东南亚国家联盟（ASEAN）峰会决定于今年5月如期在菲律宾举行，重点讨论中东战争带来的经济冲击并且寻求因应之道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260329-%E4%B8%AD%E4%B8%9C%E6%88%98%E7%81%AB%E5%8D%87%E7%BA%A7-%E6%81%90%E9%87%8D%E5%88%9B%E5%85%A8%E7%90%83%E8%83%BD%E6%BA%90%E4%B8%8E%E7%BB%8F%E6%B5%8E-1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774782026000.webp","sourceId":"rfi"},{"id":1774781338000,"createdDate":"2026-03-29 10:48","name":"法国国际广播电台","title":"非洲偷渡客尝试潜入中东遭海难","content":"在世界各国民众纷纷因伊朗战事而远离中东及海湾地区之际，在亚非两大洲的交界地带，临近出入苏伊士运河海上航道红海要冲曼德海峡（ledétroitdeBabel-Mandeb）附近，一艘搭载了超过320人的船只，逆人潮而行，从东非出发试图潜入阿拉伯半岛上的中东国家也门，但不幸于2026年03月24日周二至25日周三夜间在吉布提水域发生海难。至少有近10死亡和45人失踪。这是本台法广非洲组（RFIAfrique）2026年03月28日星期六上网的法文消息之一。本台法广（RFI）非洲通讯员发自内罗毕（Nairobi）的法文报道说，国际移民组织（OIM-Organisationinternationaledesmigration）在一份新闻通报中表示，这是一批试图进入西亚的移民。另外，本台法广（RFI）今天03月29号周日更新的法文报道显示，反对美以两国打击伊朗的也门胡塞武装已开始卷入中东地区当前战事，并于昨天03月28日周六两次向以色列发射导弹和无人机。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260329-%E9%9D%9E%E6%B4%B2%E5%81%B7%E6%B8%A1%E5%AE%A2%E5%B0%9D%E8%AF%95%E6%BD%9C%E5%85%A5%E4%B8%AD%E4%B8%9C%E9%81%AD%E6%B5%B7%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774781338000.webp","sourceId":"rfi"},{"id":1774780659000,"createdDate":"2026-03-29 10:37","name":"法国国际广播电台","title":"二战后日本作战部队将首次重返菲律宾 参加美澳菲日四国联演","content":"二战结束后，日本具备作战能力的部队将首次重返菲律宾——这次不是以占领者的身份，而是以紧密伙伴的身份。预计至少有数百名日本自卫队人员将抵达菲律宾，与菲律宾、美国和澳大利亚的军队共同参加一年一度的“肩并肩”联合军事演习，这将是迄今为止规模最大的一次，也标志着区域安全合作迈出了新的一步。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260329-%E4%BA%8C%E6%88%98%E5%90%8E%E6%97%A5%E6%9C%AC%E4%BD%9C%E6%88%98%E9%83%A8%E9%98%9F%E5%B0%86%E9%A6%96%E6%AC%A1%E9%87%8D%E8%BF%94%E8%8F%B2%E5%BE%8B%E5%AE%BE-%E5%8F%82%E5%8A%A0%E7%BE%8E%E6%BE%B3%E8%8F%B2%E6%97%A5%E5%9B%9B%E5%9B%BD%E8%81%94%E6%BC%94","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774780659000.webp","sourceId":"rfi"},{"id":1774778573000,"createdDate":"2026-03-29 10:02","name":"法国国际广播电台","title":"欧盟高官证实正探索与美英建立西方钢铁联盟 应对中国产能过剩","content":"欧盟委员会贸易和经济安全委员谢夫乔维奇（MarošŠefčovič）周六证实，欧盟正在探索与美国和英国建立西方钢铁联盟，以应对中国的工业产能过剩问题。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260329-%E6%AC%A7%E7%9B%9F%E9%AB%98%E5%AE%98%E8%AF%81%E5%AE%9E%E6%AD%A3%E6%8E%A2%E7%B4%A2%E4%B8%8E%E7%BE%8E%E8%8B%B1%E5%BB%BA%E7%AB%8B%E8%A5%BF%E6%96%B9%E9%92%A2%E9%93%81%E8%81%94%E7%9B%9F-%E5%BA%94%E5%AF%B9%E4%B8%AD%E5%9B%BD%E4%BA%A7%E8%83%BD%E8%BF%87%E5%89%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774778573000.webp","sourceId":"rfi"},{"id":1774778345000,"createdDate":"2026-03-29 09:59","name":"法国国际广播电台","title":"伊战阴影下 法国总马克龙下周出访日韩","content":"法国总统马克龙将于下周二（3月31号）至周五出访日本和韩国，试图与这两个亚洲国家就中东战争寻求“共同解决方案”。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260329-%E4%BC%8A%E6%88%98%E9%98%B4%E5%BD%B1%E4%B8%8B-%E6%B3%95%E5%9B%BD%E6%80%BB%E9%A9%AC%E5%85%8B%E9%BE%99%E4%B8%8B%E5%91%A8%E5%87%BA%E8%AE%BF%E6%97%A5%E9%9F%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774778345000.webp","sourceId":"rfi"},{"id":1774776848000,"createdDate":"2026-03-29 09:34","name":"法国国际广播电台","title":"驻港公署特派员就电子设备“安全警告”一事约见美驻港总领事","content":"中国外交部驻港公署特派员崔建春周五约见了美国驻港总领事伊珠丽（JulieEadeh），就美国驻港总领馆就港府修订《香港国安法第四十三条实施细则》发布“安全警告”一事提出严正交涉，表示强烈不满和坚决反对。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260329-%E9%A9%BB%E6%B8%AF%E5%85%AC%E7%BD%B2%E7%89%B9%E6%B4%BE%E5%91%98%E5%B0%B1%E7%94%B5%E5%AD%90%E8%AE%BE%E5%A4%87-%E5%AE%89%E5%85%A8%E8%AD%A6%E5%91%8A-%E4%B8%80%E4%BA%8B%E7%BA%A6%E8%A7%81%E7%BE%8E%E9%A9%BB%E6%B8%AF%E6%80%BB%E9%A2%86%E4%BA%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774776848000.webp","sourceId":"rfi"},{"id":1774775173000,"createdDate":"2026-03-29 09:06","name":"法国国际广播电台","title":"泽连斯基：100%确信俄正向伊朗提供中东美军情报，这符合俄利益","content":"据乌克兰总统泽连斯基（VolodymyrZelenskyy）向美国全国广播公司（NBC）提供的乌方情报摘要显示，在伊朗袭击该基地并造成美军人员受伤的前几天，俄罗斯曾三次拍摄了位于沙特的一处美国空军基地的卫星图像。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260329-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-100-%E7%A1%AE%E4%BF%A1%E4%BF%84%E6%AD%A3%E5%90%91%E4%BC%8A%E6%9C%97%E6%8F%90%E4%BE%9B%E4%B8%AD%E4%B8%9C%E7%BE%8E%E5%86%9B%E6%83%85%E6%8A%A5%EF%BC%8C%E8%BF%99%E7%AC%A6%E5%90%88%E4%BF%84%E5%88%A9%E7%9B%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774775173000.webp","sourceId":"rfi"},{"id":1774773773000,"createdDate":"2026-03-29 08:42","name":"法国国际广播电台","title":"民众党329声援柯文哲游行集会破万人，是否将影响台湾九合一选举？","content":"前民众党主席柯文哲一审被判有期徒刑17年，褫夺公权6年。民众党号召支持者上凯道游行支持。国民党团虽在判决后表示，拒绝政治判决并阻止司法崩坏，且全力支持，绝不缺席。但主席郑丽文29日则因既定行程无法出席。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260329-%E6%B0%91%E4%BC%97%E5%85%9A329%E5%A3%B0%E6%8F%B4%E6%9F%AF%E6%96%87%E5%93%B2%E6%B8%B8%E8%A1%8C%E9%9B%86%E4%BC%9A%E7%A0%B4%E4%B8%87%E4%BA%BA%EF%BC%8C%E6%98%AF%E5%90%A6%E5%B0%86%E5%BD%B1%E5%93%8D%E5%8F%B0%E6%B9%BE%E4%B9%9D%E5%90%88%E4%B8%80%E9%80%89%E4%B8%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774773773000.webp","sourceId":"rfi"},{"id":1774772196000,"createdDate":"2026-03-29 08:16","name":"法国国际广播电台","title":"中国知名教育博主张雪峰去世，网络热议","content":"37年前的3月26号，中国著名诗人海子在秦皇岛山海关附近卧轨自杀，年仅25岁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%BE%AE%E8%A8%80%E5%BE%AE%E8%AF%AD/20260329-%E4%B8%AD%E5%9B%BD%E7%9F%A5%E5%90%8D%E6%95%99%E8%82%B2%E5%8D%9A%E4%B8%BB%E5%BC%A0%E9%9B%AA%E5%B3%B0%E5%8E%BB%E4%B8%96%EF%BC%8C%E7%BD%91%E7%BB%9C%E7%83%AD%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/29/1774772196000.webp","sourceId":"rfi"}]