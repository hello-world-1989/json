[{"id":1773362167000,"createdDate":"2026-03-13 00:36","name":"法国国际广播电台","title":"中国骤变“OpenClaw”全球最大养殖实验场：考验习近平的监管策略","content":"据彭博社周四12日报道，OpenClaw（中文称“养龙虾”）在中国掀起的热潮正在考验北京对人工智能的态度，因为北京试图在追求尖端创新和关注数据安全之间取得平衡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E4%B8%AD%E5%9B%BD%E9%AA%A4%E5%8F%98-openclaw-%E5%85%A8%E7%90%83%E6%9C%80%E5%A4%A7%E5%85%BB%E6%AE%96%E5%AE%9E%E9%AA%8C%E5%9C%BA-%E8%80%83%E9%AA%8C%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%9A%84%E7%9B%91%E7%AE%A1%E7%AD%96%E7%95%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773362167000.webp","sourceId":"rfi"},{"id":1773386860000,"createdDate":"2026-03-13 07:27","name":"法国国际广播电台","title":"台湾民调：若中国攻台且美国未出兵协助，近6成受访者表示愿不计代价抵抗","content":"中研院公布民调，研究学者表示，无论是学术机构还是政府智库进行的调查，都呈现出相当一致的趋势，也就是绝大多数台湾人表示愿意抵抗外敌、保卫台湾。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E5%8F%B0%E6%B9%BE%E6%B0%91%E8%B0%83-%E8%8B%A5%E4%B8%AD%E5%9B%BD%E6%94%BB%E5%8F%B0%E4%B8%94%E7%BE%8E%E5%9B%BD%E6%9C%AA%E5%87%BA%E5%85%B5%E5%8D%8F%E5%8A%A9%EF%BC%8C%E8%BF%916%E6%88%90%E5%8F%97%E8%AE%BF%E8%80%85%E8%A1%A8%E7%A4%BA%E6%84%BF%E4%B8%8D%E8%AE%A1%E4%BB%A3%E4%BB%B7%E6%8A%B5%E6%8A%97","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773386860000.webp","sourceId":"rfi"},{"id":1773386290000,"createdDate":"2026-03-13 07:18","name":"法国国际广播电台","title":"支联会涉煽动颠覆案 法庭裁定表证成立","content":"已解散的支联会及其前正副主席李卓人丶何俊仁和邹幸彤，被控煽动颠覆国家政权罪的案件，控方本周完成开案陈辞，法庭今(13日)早裁定，案件表证成立，并将案件押后至下周二(17日)续审，届时，李卓人和邹幸彤将会就指控展开争辩。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E6%94%AF%E8%81%94%E4%BC%9A%E6%B6%89%E7%85%BD%E5%8A%A8%E9%A2%A0%E8%A6%86%E6%A1%88-%E6%B3%95%E5%BA%AD%E8%A3%81%E5%AE%9A%E8%A1%A8%E8%AF%81%E6%88%90%E7%AB%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773386290000.webp","sourceId":"rfi"},{"id":1773385854000,"createdDate":"2026-03-13 07:10","name":"法国国际广播电台","title":"港府新教学建议强调国安斗争未停 倡学生若要参政需自幼爱国","content":"香港教育局向全港中小学发出最新的教学建议，要求学校加强国家安全教育内容，让学生认识「香港维护国家安全的斗争从未停止」，以及日后若要参与治理香港工作，必须先成为坚定的爱国爱港人士等。评论认为，港府在教学建议中强调爱国要保持斗争思维，只会让香港的下一代变成红卫兵或「两面人」。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E6%B8%AF%E5%BA%9C%E6%96%B0%E6%95%99%E5%AD%A6%E5%BB%BA%E8%AE%AE%E5%BC%BA%E8%B0%83%E5%9B%BD%E5%AE%89%E6%96%97%E4%BA%89%E6%9C%AA%E5%81%9C-%E5%80%A1%E5%AD%A6%E7%94%9F%E8%8B%A5%E8%A6%81%E5%8F%82%E6%94%BF%E9%9C%80%E8%87%AA%E5%B9%BC%E7%88%B1%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773385854000.webp","sourceId":"rfi"},{"id":1773420577000,"createdDate":"2026-03-13 16:49","name":"法国国际广播电台","title":"塔克拉玛干沙漠成碳汇又面临哪些挑战？","content":"美国国家科学院院刊今年年初刊登了一篇由中美学者联合撰写的有关中国的绿色长城计划如何使新疆塔克拉玛干变成一个可以吸收二氧化碳的沙漠碳汇的文章，文章引发了国际气候环保领域的广泛关注，西方各大媒体纷纷聚焦报道了这一气候领域近期来难得的积极消息。不过，也有专家认为必须谨慎对待类似的大面积改变地面覆盖的行为。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E5%A2%83%E4%B8%8E%E5%8F%91%E5%B1%95/20260313-%E5%A1%94%E5%85%8B%E6%8B%89%E7%8E%9B%E5%B9%B2%E6%B2%99%E6%BC%A0%E6%88%90%E7%A2%B3%E6%B1%87%E5%8F%88%E9%9D%A2%E4%B8%B4%E5%93%AA%E4%BA%9B%E6%8C%91%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773420577000.webp","sourceId":"rfi"},{"id":1773419662000,"createdDate":"2026-03-13 16:34","name":"法国国际广播电台","title":"中国正在考虑修建“地下长城”以保护其战略基础设施","content":"面对日益分裂的世界和自身资源的脆弱性，中国当局正在讨论一项修建“地下长城”的计划。这项由国有企业巨头中国电力建设集团公司（PowerChina）倡导的构想，旨在打造一个庞大的地下防御网络，以保护其最宝贵的资产，包括能源、矿产和国防基础设施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E4%B8%AD%E5%9B%BD%E6%AD%A3%E5%9C%A8%E8%80%83%E8%99%91%E4%BF%AE%E5%BB%BA-%E5%9C%B0%E4%B8%8B%E9%95%BF%E5%9F%8E-%E4%BB%A5%E4%BF%9D%E6%8A%A4%E5%85%B6%E6%88%98%E7%95%A5%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773419662000.webp","sourceId":"rfi"},{"id":1773418726000,"createdDate":"2026-03-13 16:18","name":"法国国际广播电台","title":"港媒：被北京两度列名制裁的卢比奥将陪同特朗普访华","content":"美国总统特朗普按计划将于本月31日出访中国，并与中国国家主席习近平举行“特习会”。据香港媒体报道称，曾两度被北京列名制裁的国务卿卢比奥也将陪同总统一起访华。如此一来，卢比奥届时如何入境，是否正式撤销制裁或特事特办，将是媒体关注的焦点。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E6%B8%AF%E5%AA%92-%E8%A2%AB%E5%8C%97%E4%BA%AC%E4%B8%A4%E5%BA%A6%E5%88%B6%E8%A3%81%E7%9A%84%E5%8D%A2%E6%AF%94%E5%A5%A5%E5%B0%86%E9%99%AA%E5%90%8C%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773418726000.webp","sourceId":"rfi"},{"id":1773417084000,"createdDate":"2026-03-13 15:51","name":"法国国际广播电台","title":"政治风险日增白宫暂时松绑俄油制裁 莫斯科因油价飙涨每天赚进1.5亿美元","content":"面对日益严峻的能源危机，美国政府周四12日宣布签发新的俄罗斯石油许可证，暂时允许各国购买已在海上的俄罗斯原油与各种石油产品，期限为30天。这些产品原本遭到美国制裁。美国财长贝森特说，这是为了稳定全球能源市场。随着美国11月中期选举逼近之际，高油价对特朗普构成重大政治风险，动摇他对选民的经济承诺，并助长民主党人对共和党政府的批评。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260313-%E6%94%BF%E6%B2%BB%E9%A3%8E%E9%99%A9%E6%97%A5%E5%A2%9E%E7%99%BD%E5%AE%AB%E5%AE%A3%E5%B8%83%E6%9A%82%E6%97%B6%E6%9D%BE%E7%BB%91%E4%BF%84%E6%B2%B9%E5%88%B6%E8%A3%81-%E8%8E%AB%E6%96%AF%E7%A7%91%E5%9B%A0%E6%B2%B9%E4%BB%B7%E9%A3%99%E6%B6%A8%E6%AF%8F%E5%A4%A9%E8%B5%9A%E8%BF%9B1-5%E4%BA%BF%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773417084000.webp","sourceId":"rfi"},{"id":1773415327000,"createdDate":"2026-03-13 15:22","name":"法国国际广播电台","title":"美防长：今对伊朗发起“开战来规模最大”空袭 证实加油机坠毁人员全死 昨未露面的穆杰塔巴恐已“毁容”","content":"美国防长海格塞斯与参谋首长联席会议主席凯恩上将，今天13日在五角大楼举行伊朗战事简报与记者会期间，预告当天将对伊朗发起“迄今规模最大”的攻击。此外，海格塞斯在记者会上也证实美军KC-135加油机坠毁造成4名官兵殉职，并且表示伊朗新任最高领袖穆杰塔巴恐怕已经“毁容”了。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260313-%E7%BE%8E%E9%98%B2%E9%95%BF-%E4%BB%8A%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%8F%91%E8%B5%B7-%E5%BC%80%E6%88%98%E6%9D%A5%E8%A7%84%E6%A8%A1%E6%9C%80%E5%A4%A7-%E7%A9%BA%E8%A2%AD-%E8%AF%81%E5%AE%9E%E5%8A%A0%E6%B2%B9%E6%9C%BA%E5%9D%A0%E6%AF%81-%E6%98%A8%E6%9C%AA%E9%9C%B2%E9%9D%A2%E7%9A%84%E7%A9%86%E6%9D%B0%E5%A1%94%E5%B7%B4%E6%81%90%E5%B7%B2-%E6%AF%81%E5%AE%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773415327000.webp","sourceId":"rfi"},{"id":1773413471000,"createdDate":"2026-03-13 14:51","name":"法国国际广播电台","title":"才传中国斡旋，阿富汗塔利班指巴基斯坦轰炸喀布尔、坎大哈等多地造成伤亡","content":"路透社指出，在中国介入调解之下，巴基斯坦与阿富汗塔利班政府之间在过去一个星期未出现空袭行动，且沿着两国约2600公里国境交界地带爆发的冲突也正在减少，然而周五13日却再度爆发攻击事件。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260313-%E6%89%8D%E4%BC%A0%E4%B8%AD%E5%9B%BD%E6%96%A1%E6%97%8B%EF%BC%8C%E9%98%BF%E5%AF%8C%E6%B1%97%E5%A1%94%E5%88%A9%E7%8F%AD%E6%8C%87%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E8%BD%B0%E7%82%B8%E5%96%80%E5%B8%83%E5%B0%94-%E5%9D%8E%E5%A4%A7%E5%93%88%E7%AD%89%E5%A4%9A%E5%9C%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773413471000.webp","sourceId":"rfi"},{"id":1773407413000,"createdDate":"2026-03-13 13:10","name":"法国国际广播电台","title":"CNN：开战前美国低估伊朗封锁霍尔木兹海峡的冲击 贝森特：若条件具备美军可与国际联盟为邮轮护航","content":"在美以两国联手袭击伊朗后，德黑兰封锁了作为重要原油输出通道的霍尔木兹海峡，并扬言将使国际油价飙升至每桶200美元以上。据CNN援引知情人士消息称，白宫国安团队和五角大楼在发动这场战争前，低估了伊朗封锁霍尔木兹海峡的决心及其带来的经济冲击，尤其是能源领域。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260313-cnn-%E5%BC%80%E6%88%98%E5%89%8D%E7%BE%8E%E5%9B%BD%E4%BD%8E%E4%BC%B0%E4%BC%8A%E6%9C%97%E5%B0%81%E9%94%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%9A%84%E5%86%B2%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773407413000.webp","sourceId":"rfi"},{"id":1773405193000,"createdDate":"2026-03-13 12:33","name":"法国国际广播电台","title":"路透独家：特朗普将在访华后批准对台军售案 台立法院今授权先签四种武器合同","content":"路透社华盛顿/台北消息，据知情人士透露，一项包含先进拦截导弹的重大美国对台军售方案已准备就绪，正等待总统特朗普批准，并可能在他本月底访问中国后正式签署。据悉，军售协议价值约140亿美元，将成为美国对台军售史上规模最大的一次。目前，台湾正面临来自中国持续上升的军事压力。此外，台湾立法院13日授权相关部门，在正式批准国防预算前，先就该110亿美元方案中的四项武器系统签署合同，以确保交易能在截止日期前达成。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260313-%E8%B7%AF%E9%80%8F%E7%8B%AC%E5%AE%B6-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B0%86%E5%9C%A8%E8%AE%BF%E5%8D%8E%E5%90%8E%E6%89%B9%E5%87%86%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E6%A1%88-%E5%8F%B0%E7%AB%8B%E6%B3%95%E9%99%A2%E4%BB%8A%E6%8E%88%E6%9D%83%E5%85%88%E7%AD%BE%E5%9B%9B%E7%A7%8D%E6%AD%A6%E5%99%A8%E5%90%88%E5%90%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773405193000.webp","sourceId":"rfi"},{"id":1773396082000,"createdDate":"2026-03-13 10:01","name":"法国国际广播电台","title":"日本官房长官对伊朗声明表示深刻忧虑 日本45艘航船被困波斯湾","content":"日本内阁官房长官木原稔在13日的记者会上，对霍尔木兹海峡持续封锁一事以及伊朗最高领袖莫吉塔巴·哈梅内伊发表的声明表示“深刻忧虑”,他同时强调：“为使局势尽快降温，日本将与包括七国集团在内的有关国家保持密切合作，尽一切外交努力。”日本国土交通大臣金子恭之在13日内阁会议后的记者会上透露，截至当日，在波斯湾内有45艘与日本相关的船舶正在受困待机。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E6%97%A5%E6%9C%AC%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%A3%B0%E6%98%8E%E8%A1%A8%E7%A4%BA%E6%B7%B1%E5%88%BB%E5%BF%A7%E8%99%91-%E6%97%A5%E6%9C%AC45%E8%89%98%E8%88%AA%E8%88%B9%E8%A2%AB%E5%9B%B0%E6%B3%A2%E6%96%AF%E6%B9%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773396082000.webp","sourceId":"rfi"},{"id":1773393757000,"createdDate":"2026-03-13 09:22","name":"法国国际广播电台","title":"泽连斯基到访巴黎 ：中东战争“不会转移”对乌克兰的关注","content":"在中东战争正占据全球的注意力之际，乌克兰总统泽连斯基在结束对罗马尼亚访问后周五（3月13号）抵达巴黎，与法国总统马克龙举行会谈，商讨如何加大对俄罗斯的施压。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260313-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%88%B0%E8%AE%BF%E5%B7%B4%E9%BB%8E-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89-%E4%B8%8D%E4%BC%9A%E8%BD%AC%E7%A7%BB-%E5%AF%B9%E4%B9%8C%E5%85%8B%E5%85%B0%E7%9A%84%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773393757000.webp","sourceId":"rfi"},{"id":1773393553000,"createdDate":"2026-03-13 09:19","name":"法国国际广播电台","title":"伊拉克库尔德斯坦遇袭 首名法国军人殉职 马克龙：这类攻击令人无法接受","content":"法国证实首名军人在伊拉克库尔德斯坦地区遇袭阵亡。法国总统马克龙周四晚推文表示，这类攻击令人无法接受。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260313-%E4%BC%8A%E6%8B%89%E5%85%8B%E5%BA%93%E5%B0%94%E5%BE%B7%E6%96%AF%E5%9D%A6%E9%81%87%E8%A2%AD-%E9%A6%96%E5%90%8D%E6%B3%95%E5%9B%BD%E5%86%9B%E4%BA%BA%E6%AE%89%E8%81%8C-%E9%A9%AC%E5%85%8B%E9%BE%99-%E8%BF%99%E7%B1%BB%E6%94%BB%E5%87%BB%E4%BB%A4%E4%BA%BA%E6%97%A0%E6%B3%95%E6%8E%A5%E5%8F%97","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773393553000.webp","sourceId":"rfi"},{"id":1773392008000,"createdDate":"2026-03-13 08:53","name":"法国国际广播电台","title":"彭博社：普京“幕后操盘”伊朗战争 支援德黑兰反击美以联军","content":"彭博社报道指，俄罗斯情报部门支持伊朗对美国、以色列和海湾盟友进行致命报复，以及人们担心中国也可能在帮助德黑兰，这表明随着与伊朗的战争不断扩大，美国对手之间的联系正在加深。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260313-%E5%BD%AD%E5%8D%9A%E7%A4%BE-%E6%99%AE%E4%BA%AC-%E5%B9%95%E5%90%8E%E6%93%8D%E7%9B%98-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89-%E6%94%AF%E6%8F%B4%E5%BE%B7%E9%BB%91%E5%85%B0%E5%8F%8D%E5%87%BB%E7%BE%8E%E4%BB%A5%E8%81%94%E5%86%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773392008000.webp","sourceId":"rfi"}]