[{"id":1773362167000,"createdDate":"2026-03-13 00:36","name":"法国国际广播电台","title":"中国骤变“OpenClaw”全球最大养殖实验场：考验习近平的监管策略","content":"据彭博社周四12日报道，OpenClaw（中文称“养龙虾”）在中国掀起的热潮正在考验北京对人工智能的态度，因为北京试图在追求尖端创新和关注数据安全之间取得平衡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E4%B8%AD%E5%9B%BD%E9%AA%A4%E5%8F%98-openclaw-%E5%85%A8%E7%90%83%E6%9C%80%E5%A4%A7%E5%85%BB%E6%AE%96%E5%AE%9E%E9%AA%8C%E5%9C%BA-%E8%80%83%E9%AA%8C%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%9A%84%E7%9B%91%E7%AE%A1%E7%AD%96%E7%95%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773362167000.webp","sourceId":"rfi"},{"id":1773386860000,"createdDate":"2026-03-13 07:27","name":"法国国际广播电台","title":"台湾民调：若中国攻台且美国未出兵协助，近6成受访者表示愿不计代价抵抗","content":"中研院公布民调，研究学者表示，无论是学术机构还是政府智库进行的调查，都呈现出相当一致的趋势，也就是绝大多数台湾人表示愿意抵抗外敌、保卫台湾。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E5%8F%B0%E6%B9%BE%E6%B0%91%E8%B0%83-%E8%8B%A5%E4%B8%AD%E5%9B%BD%E6%94%BB%E5%8F%B0%E4%B8%94%E7%BE%8E%E5%9B%BD%E6%9C%AA%E5%87%BA%E5%85%B5%E5%8D%8F%E5%8A%A9%EF%BC%8C%E8%BF%916%E6%88%90%E5%8F%97%E8%AE%BF%E8%80%85%E8%A1%A8%E7%A4%BA%E6%84%BF%E4%B8%8D%E8%AE%A1%E4%BB%A3%E4%BB%B7%E6%8A%B5%E6%8A%97","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773386860000.webp","sourceId":"rfi"},{"id":1773386290000,"createdDate":"2026-03-13 07:18","name":"法国国际广播电台","title":"支联会涉煽动颠覆案 法庭裁定表证成立","content":"已解散的支联会及其前正副主席李卓人丶何俊仁和邹幸彤，被控煽动颠覆国家政权罪的案件，控方本周完成开案陈辞，法庭今(13日)早裁定，案件表证成立，并将案件押后至下周二(17日)续审，届时，李卓人和邹幸彤将会就指控展开争辩。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E6%94%AF%E8%81%94%E4%BC%9A%E6%B6%89%E7%85%BD%E5%8A%A8%E9%A2%A0%E8%A6%86%E6%A1%88-%E6%B3%95%E5%BA%AD%E8%A3%81%E5%AE%9A%E8%A1%A8%E8%AF%81%E6%88%90%E7%AB%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773386290000.webp","sourceId":"rfi"},{"id":1773385854000,"createdDate":"2026-03-13 07:10","name":"法国国际广播电台","title":"港府新教学建议强调国安斗争未停 倡学生若要参政需自幼爱国","content":"香港教育局向全港中小学发出最新的教学建议，要求学校加强国家安全教育内容，让学生认识「香港维护国家安全的斗争从未停止」，以及日后若要参与治理香港工作，必须先成为坚定的爱国爱港人士等。评论认为，港府在教学建议中强调爱国要保持斗争思维，只会让香港的下一代变成红卫兵或「两面人」。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E6%B8%AF%E5%BA%9C%E6%96%B0%E6%95%99%E5%AD%A6%E5%BB%BA%E8%AE%AE%E5%BC%BA%E8%B0%83%E5%9B%BD%E5%AE%89%E6%96%97%E4%BA%89%E6%9C%AA%E5%81%9C-%E5%80%A1%E5%AD%A6%E7%94%9F%E8%8B%A5%E8%A6%81%E5%8F%82%E6%94%BF%E9%9C%80%E8%87%AA%E5%B9%BC%E7%88%B1%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773385854000.webp","sourceId":"rfi"}]