[{"id":1773362167000,"createdDate":"2026-03-13 00:36","name":"法国国际广播电台","title":"中国骤变“OpenClaw”全球最大养殖实验场：考验习近平的监管策略","content":"据彭博社周四12日报道，OpenClaw（中文称“养龙虾”）在中国掀起的热潮正在考验北京对人工智能的态度，因为北京试图在追求尖端创新和关注数据安全之间取得平衡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E4%B8%AD%E5%9B%BD%E9%AA%A4%E5%8F%98-openclaw-%E5%85%A8%E7%90%83%E6%9C%80%E5%A4%A7%E5%85%BB%E6%AE%96%E5%AE%9E%E9%AA%8C%E5%9C%BA-%E8%80%83%E9%AA%8C%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%9A%84%E7%9B%91%E7%AE%A1%E7%AD%96%E7%95%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773362167000.webp","sourceId":"rfi"},{"id":1773386860000,"createdDate":"2026-03-13 07:27","name":"法国国际广播电台","title":"台湾民调：若中国攻台且美国未出兵协助，近6成受访者表示愿不计代价抵抗","content":"中研院公布民调，研究学者表示，无论是学术机构还是政府智库进行的调查，都呈现出相当一致的趋势，也就是绝大多数台湾人表示愿意抵抗外敌、保卫台湾。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E5%8F%B0%E6%B9%BE%E6%B0%91%E8%B0%83-%E8%8B%A5%E4%B8%AD%E5%9B%BD%E6%94%BB%E5%8F%B0%E4%B8%94%E7%BE%8E%E5%9B%BD%E6%9C%AA%E5%87%BA%E5%85%B5%E5%8D%8F%E5%8A%A9%EF%BC%8C%E8%BF%916%E6%88%90%E5%8F%97%E8%AE%BF%E8%80%85%E8%A1%A8%E7%A4%BA%E6%84%BF%E4%B8%8D%E8%AE%A1%E4%BB%A3%E4%BB%B7%E6%8A%B5%E6%8A%97","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773386860000.webp","sourceId":"rfi"},{"id":1773386290000,"createdDate":"2026-03-13 07:18","name":"法国国际广播电台","title":"支联会涉煽动颠覆案 法庭裁定表证成立","content":"已解散的支联会及其前正副主席李卓人丶何俊仁和邹幸彤，被控煽动颠覆国家政权罪的案件，控方本周完成开案陈辞，法庭今(13日)早裁定，案件表证成立，并将案件押后至下周二(17日)续审，届时，李卓人和邹幸彤将会就指控展开争辩。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E6%94%AF%E8%81%94%E4%BC%9A%E6%B6%89%E7%85%BD%E5%8A%A8%E9%A2%A0%E8%A6%86%E6%A1%88-%E6%B3%95%E5%BA%AD%E8%A3%81%E5%AE%9A%E8%A1%A8%E8%AF%81%E6%88%90%E7%AB%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773386290000.webp","sourceId":"rfi"},{"id":1773385854000,"createdDate":"2026-03-13 07:10","name":"法国国际广播电台","title":"港府新教学建议强调国安斗争未停 倡学生若要参政需自幼爱国","content":"香港教育局向全港中小学发出最新的教学建议，要求学校加强国家安全教育内容，让学生认识「香港维护国家安全的斗争从未停止」，以及日后若要参与治理香港工作，必须先成为坚定的爱国爱港人士等。评论认为，港府在教学建议中强调爱国要保持斗争思维，只会让香港的下一代变成红卫兵或「两面人」。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E6%B8%AF%E5%BA%9C%E6%96%B0%E6%95%99%E5%AD%A6%E5%BB%BA%E8%AE%AE%E5%BC%BA%E8%B0%83%E5%9B%BD%E5%AE%89%E6%96%97%E4%BA%89%E6%9C%AA%E5%81%9C-%E5%80%A1%E5%AD%A6%E7%94%9F%E8%8B%A5%E8%A6%81%E5%8F%82%E6%94%BF%E9%9C%80%E8%87%AA%E5%B9%BC%E7%88%B1%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773385854000.webp","sourceId":"rfi"},{"id":1773420577000,"createdDate":"2026-03-13 16:49","name":"法国国际广播电台","title":"塔克拉玛干沙漠成碳汇又面临哪些挑战？","content":"美国国家科学院院刊今年年初刊登了一篇由中美学者联合撰写的有关中国的绿色长城计划如何使新疆塔克拉玛干变成一个可以吸收二氧化碳的沙漠碳汇的文章，文章引发了国际气候环保领域的广泛关注，西方各大媒体纷纷聚焦报道了这一气候领域近期来难得的积极消息。不过，也有专家认为必须谨慎对待类似的大面积改变地面覆盖的行为。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E5%A2%83%E4%B8%8E%E5%8F%91%E5%B1%95/20260313-%E5%A1%94%E5%85%8B%E6%8B%89%E7%8E%9B%E5%B9%B2%E6%B2%99%E6%BC%A0%E6%88%90%E7%A2%B3%E6%B1%87%E5%8F%88%E9%9D%A2%E4%B8%B4%E5%93%AA%E4%BA%9B%E6%8C%91%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773420577000.webp","sourceId":"rfi"},{"id":1773419662000,"createdDate":"2026-03-13 16:34","name":"法国国际广播电台","title":"中国正在考虑修建“地下长城”以保护其战略基础设施","content":"面对日益分裂的世界和自身资源的脆弱性，中国当局正在讨论一项修建“地下长城”的计划。这项由国有企业巨头中国电力建设集团公司（PowerChina）倡导的构想，旨在打造一个庞大的地下防御网络，以保护其最宝贵的资产，包括能源、矿产和国防基础设施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E4%B8%AD%E5%9B%BD%E6%AD%A3%E5%9C%A8%E8%80%83%E8%99%91%E4%BF%AE%E5%BB%BA-%E5%9C%B0%E4%B8%8B%E9%95%BF%E5%9F%8E-%E4%BB%A5%E4%BF%9D%E6%8A%A4%E5%85%B6%E6%88%98%E7%95%A5%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773419662000.webp","sourceId":"rfi"},{"id":1773418726000,"createdDate":"2026-03-13 16:18","name":"法国国际广播电台","title":"港媒：被北京两度列名制裁的卢比奥将陪同特朗普访华","content":"美国总统特朗普按计划将于本月31日出访中国，并与中国国家主席习近平举行“特习会”。据香港媒体报道称，曾两度被北京列名制裁的国务卿卢比奥也将陪同总统一起访华。如此一来，卢比奥届时如何入境，是否正式撤销制裁或特事特办，将是媒体关注的焦点。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E6%B8%AF%E5%AA%92-%E8%A2%AB%E5%8C%97%E4%BA%AC%E4%B8%A4%E5%BA%A6%E5%88%B6%E8%A3%81%E7%9A%84%E5%8D%A2%E6%AF%94%E5%A5%A5%E5%B0%86%E9%99%AA%E5%90%8C%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773418726000.webp","sourceId":"rfi"},{"id":1773417084000,"createdDate":"2026-03-13 15:51","name":"法国国际广播电台","title":"政治风险日增白宫暂时松绑俄油制裁 莫斯科因油价飙涨每天赚进1.5亿美元","content":"面对日益严峻的能源危机，美国政府周四12日宣布签发新的俄罗斯石油许可证，暂时允许各国购买已在海上的俄罗斯原油与各种石油产品，期限为30天。这些产品原本遭到美国制裁。美国财长贝森特说，这是为了稳定全球能源市场。随着美国11月中期选举逼近之际，高油价对特朗普构成重大政治风险，动摇他对选民的经济承诺，并助长民主党人对共和党政府的批评。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260313-%E6%94%BF%E6%B2%BB%E9%A3%8E%E9%99%A9%E6%97%A5%E5%A2%9E%E7%99%BD%E5%AE%AB%E5%AE%A3%E5%B8%83%E6%9A%82%E6%97%B6%E6%9D%BE%E7%BB%91%E4%BF%84%E6%B2%B9%E5%88%B6%E8%A3%81-%E8%8E%AB%E6%96%AF%E7%A7%91%E5%9B%A0%E6%B2%B9%E4%BB%B7%E9%A3%99%E6%B6%A8%E6%AF%8F%E5%A4%A9%E8%B5%9A%E8%BF%9B1-5%E4%BA%BF%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773417084000.webp","sourceId":"rfi"},{"id":1773415327000,"createdDate":"2026-03-13 15:22","name":"法国国际广播电台","title":"美防长：今对伊朗发起“开战来规模最大”空袭 证实加油机坠毁人员全死 昨未露面的穆杰塔巴恐已“毁容”","content":"美国防长海格塞斯与参谋首长联席会议主席凯恩上将，今天13日在五角大楼举行伊朗战事简报与记者会期间，预告当天将对伊朗发起“迄今规模最大”的攻击。此外，海格塞斯在记者会上也证实美军KC-135加油机坠毁造成4名官兵殉职，并且表示伊朗新任最高领袖穆杰塔巴恐怕已经“毁容”了。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260313-%E7%BE%8E%E9%98%B2%E9%95%BF-%E4%BB%8A%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%8F%91%E8%B5%B7-%E5%BC%80%E6%88%98%E6%9D%A5%E8%A7%84%E6%A8%A1%E6%9C%80%E5%A4%A7-%E7%A9%BA%E8%A2%AD-%E8%AF%81%E5%AE%9E%E5%8A%A0%E6%B2%B9%E6%9C%BA%E5%9D%A0%E6%AF%81-%E6%98%A8%E6%9C%AA%E9%9C%B2%E9%9D%A2%E7%9A%84%E7%A9%86%E6%9D%B0%E5%A1%94%E5%B7%B4%E6%81%90%E5%B7%B2-%E6%AF%81%E5%AE%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773415327000.webp","sourceId":"rfi"},{"id":1773413471000,"createdDate":"2026-03-13 14:51","name":"法国国际广播电台","title":"才传中国斡旋，阿富汗塔利班指巴基斯坦轰炸喀布尔、坎大哈等多地造成伤亡","content":"路透社指出，在中国介入调解之下，巴基斯坦与阿富汗塔利班政府之间在过去一个星期未出现空袭行动，且沿着两国约2600公里国境交界地带爆发的冲突也正在减少，然而周五13日却再度爆发攻击事件。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260313-%E6%89%8D%E4%BC%A0%E4%B8%AD%E5%9B%BD%E6%96%A1%E6%97%8B%EF%BC%8C%E9%98%BF%E5%AF%8C%E6%B1%97%E5%A1%94%E5%88%A9%E7%8F%AD%E6%8C%87%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E8%BD%B0%E7%82%B8%E5%96%80%E5%B8%83%E5%B0%94-%E5%9D%8E%E5%A4%A7%E5%93%88%E7%AD%89%E5%A4%9A%E5%9C%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773413471000.webp","sourceId":"rfi"},{"id":1773407413000,"createdDate":"2026-03-13 13:10","name":"法国国际广播电台","title":"CNN：开战前美国低估伊朗封锁霍尔木兹海峡的冲击 贝森特：若条件具备美军可与国际联盟为邮轮护航","content":"在美以两国联手袭击伊朗后，德黑兰封锁了作为重要原油输出通道的霍尔木兹海峡，并扬言将使国际油价飙升至每桶200美元以上。据CNN援引知情人士消息称，白宫国安团队和五角大楼在发动这场战争前，低估了伊朗封锁霍尔木兹海峡的决心及其带来的经济冲击，尤其是能源领域。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260313-cnn-%E5%BC%80%E6%88%98%E5%89%8D%E7%BE%8E%E5%9B%BD%E4%BD%8E%E4%BC%B0%E4%BC%8A%E6%9C%97%E5%B0%81%E9%94%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%9A%84%E5%86%B2%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773407413000.webp","sourceId":"rfi"},{"id":1773405193000,"createdDate":"2026-03-13 12:33","name":"法国国际广播电台","title":"路透独家：特朗普将在访华后批准对台军售案 台立法院今授权先签四种武器合同","content":"路透社华盛顿/台北消息，据知情人士透露，一项包含先进拦截导弹的重大美国对台军售方案已准备就绪，正等待总统特朗普批准，并可能在他本月底访问中国后正式签署。据悉，军售协议价值约140亿美元，将成为美国对台军售史上规模最大的一次。目前，台湾正面临来自中国持续上升的军事压力。此外，台湾立法院13日授权相关部门，在正式批准国防预算前，先就该110亿美元方案中的四项武器系统签署合同，以确保交易能在截止日期前达成。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260313-%E8%B7%AF%E9%80%8F%E7%8B%AC%E5%AE%B6-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B0%86%E5%9C%A8%E8%AE%BF%E5%8D%8E%E5%90%8E%E6%89%B9%E5%87%86%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E6%A1%88-%E5%8F%B0%E7%AB%8B%E6%B3%95%E9%99%A2%E4%BB%8A%E6%8E%88%E6%9D%83%E5%85%88%E7%AD%BE%E5%9B%9B%E7%A7%8D%E6%AD%A6%E5%99%A8%E5%90%88%E5%90%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773405193000.webp","sourceId":"rfi"},{"id":1773396082000,"createdDate":"2026-03-13 10:01","name":"法国国际广播电台","title":"日本官房长官对伊朗声明表示深刻忧虑 日本45艘航船被困波斯湾","content":"日本内阁官房长官木原稔在13日的记者会上，对霍尔木兹海峡持续封锁一事以及伊朗最高领袖莫吉塔巴·哈梅内伊发表的声明表示“深刻忧虑”,他同时强调：“为使局势尽快降温，日本将与包括七国集团在内的有关国家保持密切合作，尽一切外交努力。”日本国土交通大臣金子恭之在13日内阁会议后的记者会上透露，截至当日，在波斯湾内有45艘与日本相关的船舶正在受困待机。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E6%97%A5%E6%9C%AC%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%A3%B0%E6%98%8E%E8%A1%A8%E7%A4%BA%E6%B7%B1%E5%88%BB%E5%BF%A7%E8%99%91-%E6%97%A5%E6%9C%AC45%E8%89%98%E8%88%AA%E8%88%B9%E8%A2%AB%E5%9B%B0%E6%B3%A2%E6%96%AF%E6%B9%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773396082000.webp","sourceId":"rfi"},{"id":1773393757000,"createdDate":"2026-03-13 09:22","name":"法国国际广播电台","title":"泽连斯基到访巴黎 ：中东战争“不会转移”对乌克兰的关注","content":"在中东战争正占据全球的注意力之际，乌克兰总统泽连斯基在结束对罗马尼亚访问后周五（3月13号）抵达巴黎，与法国总统马克龙举行会谈，商讨如何加大对俄罗斯的施压。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260313-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%88%B0%E8%AE%BF%E5%B7%B4%E9%BB%8E-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89-%E4%B8%8D%E4%BC%9A%E8%BD%AC%E7%A7%BB-%E5%AF%B9%E4%B9%8C%E5%85%8B%E5%85%B0%E7%9A%84%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773393757000.webp","sourceId":"rfi"},{"id":1773393553000,"createdDate":"2026-03-13 09:19","name":"法国国际广播电台","title":"伊拉克库尔德斯坦遇袭 首名法国军人殉职 马克龙：这类攻击令人无法接受","content":"法国证实首名军人在伊拉克库尔德斯坦地区遇袭阵亡。法国总统马克龙周四晚推文表示，这类攻击令人无法接受。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260313-%E4%BC%8A%E6%8B%89%E5%85%8B%E5%BA%93%E5%B0%94%E5%BE%B7%E6%96%AF%E5%9D%A6%E9%81%87%E8%A2%AD-%E9%A6%96%E5%90%8D%E6%B3%95%E5%9B%BD%E5%86%9B%E4%BA%BA%E6%AE%89%E8%81%8C-%E9%A9%AC%E5%85%8B%E9%BE%99-%E8%BF%99%E7%B1%BB%E6%94%BB%E5%87%BB%E4%BB%A4%E4%BA%BA%E6%97%A0%E6%B3%95%E6%8E%A5%E5%8F%97","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773393553000.webp","sourceId":"rfi"},{"id":1773392008000,"createdDate":"2026-03-13 08:53","name":"法国国际广播电台","title":"彭博社：普京“幕后操盘”伊朗战争 支援德黑兰反击美以联军","content":"彭博社报道指，俄罗斯情报部门支持伊朗对美国、以色列和海湾盟友进行致命报复，以及人们担心中国也可能在帮助德黑兰，这表明随着与伊朗的战争不断扩大，美国对手之间的联系正在加深。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260313-%E5%BD%AD%E5%8D%9A%E7%A4%BE-%E6%99%AE%E4%BA%AC-%E5%B9%95%E5%90%8E%E6%93%8D%E7%9B%98-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89-%E6%94%AF%E6%8F%B4%E5%BE%B7%E9%BB%91%E5%85%B0%E5%8F%8D%E5%87%BB%E7%BE%8E%E4%BB%A5%E8%81%94%E5%86%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773392008000.webp","sourceId":"rfi"},{"id":1773446224000,"createdDate":"2026-03-13 23:57","name":"法国国际广播电台","title":"民族团结法：联合国人权高级专员表示担忧","content":"联合国人权事务高级专员福尔克尔·蒂尔克（VolkerTürk）周五表示对前一天中国人大通过的“民族团结法”感到“担忧”，他认为该法律可能会“限制宗教和文化自由”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E6%B3%95-%E8%81%94%E5%90%88%E5%9B%BD%E4%BA%BA%E6%9D%83%E9%AB%98%E7%BA%A7%E4%B8%93%E5%91%98%E8%A1%A8%E7%A4%BA%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773446224000.webp","sourceId":"rfi"},{"id":1773445890000,"createdDate":"2026-03-13 23:51","name":"法国国际广播电台","title":"民族团结法：中国进一步加强对少数民族的管控和同化","content":"法国世界报周五关注全国人大3月12日通过的《民族团结进步促进法》。该报表示，这部新的法律旨在进一步加强对少数民族的管控，并加快对维吾尔族、藏族和蒙古族等群体的同化进程。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260313-%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E6%B3%95-%E4%B8%AD%E5%9B%BD%E8%BF%9B%E4%B8%80%E6%AD%A5%E5%8A%A0%E5%BC%BA%E5%AF%B9%E5%B0%91%E6%95%B0%E6%B0%91%E6%97%8F%E7%9A%84%E7%AE%A1%E6%8E%A7%E5%92%8C%E5%90%8C%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773445890000.webp","sourceId":"rfi"},{"id":1773442189000,"createdDate":"2026-03-13 22:49","name":"法国国际广播电台","title":"法广采访非洲科特迪瓦防务顾问","content":"欢迎您进入法国国际广播电台（RadioFranceInternationale）中文节目[法语世界]（Chroniquefrancophonie）专栏2026年03月13日星期五第147集。在本次节目的时间段里，我们向大家播出本台法广(RFI)法语栏目[非洲大咖嘉宾]（LeGrandInvitéAfrique）专栏记者西迪（SidyYansané）对西非法语国家科特迪瓦（Côted'Ivoire）的防务与安全问题专家亚瑟·班加（ArthurBanga）的采访录音片段。话题围绕简称[西非经共体]（CEDEAO）的[西非国家经济共同体]于近日再次宣称启动待命部队（laForceenattente）。非洲国家科特迪瓦的中文，也有译作象牙海岸（Côted'Ivoire）。由尼古拉编译和播报，感谢收听。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C/20260313-%E6%B3%95%E5%B9%BFrfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C-%E7%AC%AC147%E9%9B%86-%E6%B3%95%E5%B9%BF%E9%87%87%E8%AE%BF%E9%9D%9E%E6%B4%B2%E7%A7%91%E7%89%B9%E8%BF%AA%E7%93%A6%E9%98%B2%E5%8A%A1%E9%A1%BE%E9%97%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773442189000.webp","sourceId":"rfi"},{"id":1773441832000,"createdDate":"2026-03-13 22:43","name":"法国国际广播电台","title":"美以在伊朗掉入不对称战争的陷阱","content":"美国以色列28日对伊朗发动突袭，一举炸死哈梅内伊，且炸死许多高级将领，然而哈梅内伊被炸死了，儿子顺势继位，虽然偶尔可能从德黑兰的某些个角落听到打倒毛拉政权的呼声，但伊朗政体没有被推翻。这个被禁运几十年的毛拉政权，竟然以其自成体系的无人机，点燃了海湾国家，实质封锁了霍尔木兹海峡。油价飙升到百元以上，而且还看不到尽头。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E7%BE%8E%E4%BB%A5%E5%9C%A8%E4%BC%8A%E6%9C%97%E6%8E%89%E5%85%A5%E4%B8%8D%E5%AF%B9%E7%A7%B0%E6%88%98%E4%BA%89%E7%9A%84%E9%99%B7%E9%98%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773441832000.webp","sourceId":"rfi"},{"id":1773440199000,"createdDate":"2026-03-13 22:16","name":"法国国际广播电台","title":"伊朗无人机为何很难被干扰","content":"造价低廉的伊朗沙赫德无人机，一出动成百上千，给海湾国家的美军基地、石油设施，豪奢园区，城市风景线造成相当破坏，也给国际游客及投资人留下阴影。为什么这些无人机难以被干扰？伊朗是否换用了中国的北斗导航系统？下面我们介绍一下专家的看法。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260313-%E4%BC%8A%E6%9C%97%E6%97%A0%E4%BA%BA%E6%9C%BA%E4%B8%BA%E4%BD%95%E5%BE%88%E9%9A%BE%E8%A2%AB%E5%B9%B2%E6%89%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773440199000.webp","sourceId":"rfi"},{"id":1773435793000,"createdDate":"2026-03-13 21:03","name":"法国国际广播电台","title":"巴拿马希望中国中远海运恢复在巴尔博亚港的运营","content":"巴拿马运河事务部长何塞·拉蒙·伊卡萨（JoseRamonIcaza）周五（3月13日）表示，巴拿马政府希望中国中远海运能重新考虑不使用巴拿马运河入口处巴尔博亚港的决定。本周早些时候，当地报纸《拉普伦萨》刊登了中远海运向客户发布的公告，称该公司暂停在巴尔博亚港的运营。对于早前有关暂停运营的询问，中远海运没有回应。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260313-%E5%B7%B4%E6%8B%BF%E9%A9%AC%E5%B8%8C%E6%9C%9B%E4%B8%AD%E5%9B%BD%E4%B8%AD%E8%BF%9C%E6%B5%B7%E8%BF%90%E6%81%A2%E5%A4%8D%E5%9C%A8%E5%B7%B4%E5%B0%94%E5%8D%9A%E4%BA%9A%E6%B8%AF%E7%9A%84%E8%BF%90%E8%90%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773435793000.webp","sourceId":"rfi"},{"id":1773435667000,"createdDate":"2026-03-13 21:01","name":"法国国际广播电台","title":"美媒：美军将向中东增派约2500名海军陆战队员和三艘舰艇","content":"据多家美国媒体周五（3月13日）报道，美国军方将在中东部署更多海军陆战队部队和舰艇。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260313-%E7%BE%8E%E5%AA%92-%E7%BE%8E%E5%86%9B%E5%B0%86%E5%90%91%E4%B8%AD%E4%B8%9C%E5%A2%9E%E6%B4%BE%E7%BA%A62500%E5%90%8D%E6%B5%B7%E5%86%9B%E9%99%86%E6%88%98%E9%98%9F%E5%91%98%E5%92%8C%E4%B8%89%E8%89%98%E8%88%B0%E8%89%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773435667000.webp","sourceId":"rfi"},{"id":1773435086000,"createdDate":"2026-03-13 20:51","name":"法国国际广播电台","title":"北约在土耳其领空拦截第三枚伊朗导弹，总统埃尔多安表示拒绝被卷入战争","content":"土耳其国防部周五在一份声明中表示：“一枚从伊朗发射、进入土耳其领空的弹道导弹已被部署在东地中海的北约防空与反导系统成功拦截。”声明称，“目前正与相关国家进行讨论，以澄清此次事件的各个方面。”土耳其总统埃尔多安则表示，拒绝让土耳其因“挑衅”而卷入战争。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260313-%E5%8C%97%E7%BA%A6%E5%9C%A8%E5%9C%9F%E8%80%B3%E5%85%B6%E9%A2%86%E7%A9%BA%E6%8B%A6%E6%88%AA%E7%AC%AC%E4%B8%89%E6%9E%9A%E4%BC%8A%E6%9C%97%E5%AF%BC%E5%BC%B9%EF%BC%8C%E6%80%BB%E7%BB%9F%E5%9F%83%E5%B0%94%E5%A4%9A%E5%AE%89%E8%A1%A8%E7%A4%BA%E6%8B%92%E7%BB%9D%E8%A2%AB%E5%8D%B7%E5%85%A5%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773435086000.webp","sourceId":"rfi"},{"id":1773435044000,"createdDate":"2026-03-13 20:50","name":"法国国际广播电台","title":"因计划探视前总统博索纳罗，巴西撤销一位美国外交官签证","content":"巴西总统卢拉周五（3月13日）宣布，已撤销一名美国外交官的签证，该外交官原计划探视前总统雅伊尔·博索纳罗（JairBolsonaro），巴西当局怀疑此举在选举年可能构成干涉。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260313-%E5%9B%A0%E8%AE%A1%E5%88%92%E6%8E%A2%E8%A7%86%E5%89%8D%E6%80%BB%E7%BB%9F%E5%8D%9A%E7%B4%A2%E7%BA%B3%E7%BD%97%EF%BC%8C%E5%B7%B4%E8%A5%BF%E6%92%A4%E9%94%80%E4%B8%80%E4%BD%8D%E7%BE%8E%E5%9B%BD%E5%A4%96%E4%BA%A4%E5%AE%98%E7%AD%BE%E8%AF%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773435044000.webp","sourceId":"rfi"},{"id":1773430795000,"createdDate":"2026-03-13 19:39","name":"法国国际广播电台","title":"戴高乐号航母中东执行任务之际，马克龙将于下周三前往新一代法国航母建设工地参观","content":"爱丽舍宫于周五（3月13日）宣布，法国总统马克龙将于下周三（3月18日）前往南特附近的印德尔（Indre），参观新一代法国航空母舰的NavalGroup建造工地，该航母计划于2038年服役。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260313-%E6%88%B4%E9%AB%98%E4%B9%90%E5%8F%B7-%E8%88%AA%E6%AF%8D%E4%B8%AD%E4%B8%9C%E6%89%A7%E8%A1%8C%E4%BB%BB%E5%8A%A1%E4%B9%8B%E9%99%85%EF%BC%8C%E9%A9%AC%E5%85%8B%E9%BE%99%E5%B0%86%E4%BA%8E%E4%B8%8B%E5%91%A8%E4%B8%89%E5%89%8D%E5%BE%80%E6%96%B0%E4%B8%80%E4%BB%A3%E6%B3%95%E5%9B%BD%E8%88%AA%E6%AF%8D%E5%BB%BA%E9%80%A0%E5%B7%A5%E5%9C%B0%E5%8F%82%E8%A7%82","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773430795000.webp","sourceId":"rfi"},{"id":1773429999000,"createdDate":"2026-03-13 19:26","name":"法国国际广播电台","title":"包括总统和外长在内的多名伊朗高官公开上街游行，挑衅美以轰炸，美国悬赏1000万美元征集伊朗领导人信息","content":"周五（3月13日），伊朗高层领导人在德黑兰市中心公开参加游行，尽管城市周边一直有轰炸，他们仍冒险出现在街头，挑战美国和以色列。当天晚些时候，美国宣布，将提供1000万美元悬赏，以获取关于伊朗领导人下落的信息。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260313-%E5%8C%85%E6%8B%AC%E6%80%BB%E7%BB%9F%E5%92%8C%E5%A4%96%E9%95%BF%E5%9C%A8%E5%86%85%E7%9A%84%E5%A4%9A%E5%90%8D%E4%BC%8A%E6%9C%97%E9%AB%98%E5%AE%98%E5%85%AC%E5%BC%80%E4%B8%8A%E8%A1%97%E6%B8%B8%E8%A1%8C%EF%BC%8C%E6%8C%91%E8%A1%85%E7%BE%8E%E4%BB%A5%E8%BD%B0%E7%82%B8%EF%BC%8C%E7%BE%8E%E5%9B%BD%E6%82%AC%E8%B5%8F1000%E4%B8%87%E7%BE%8E%E5%85%83%E5%BE%81%E9%9B%86%E4%BC%8A%E6%9C%97%E9%A2%86%E5%AF%BC%E4%BA%BA%E4%BF%A1%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773429999000.webp","sourceId":"rfi"},{"id":1773428223000,"createdDate":"2026-03-13 18:57","name":"法国国际广播电台","title":"伊朗政府封锁互联网超14天，伊朗人如何保持通信？","content":"法新社消息称，监测网络通信自由的机构Netblocks周五（3月13日）表示，伊朗政府实施的互联网封锁超过14天。不过，伊朗民众仍然有多种方式试图绕过这一限制，不过其中不少方式都“代价”高昂。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260313-%E4%BC%8A%E6%9C%97%E6%94%BF%E5%BA%9C%E5%B0%81%E9%94%81%E4%BA%92%E8%81%94%E7%BD%91%E8%B6%8514%E5%A4%A9%EF%BC%8C%E4%BC%8A%E6%9C%97%E4%BA%BA%E5%A6%82%E4%BD%95%E4%BF%9D%E6%8C%81%E9%80%9A%E4%BF%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773428223000.webp","sourceId":"rfi"},{"id":1773427458000,"createdDate":"2026-03-13 18:44","name":"法国国际广播电台","title":"伊朗战争已让莫斯科充分受益，美国放松石油制裁又为俄罗斯带来新的利好？","content":"综合法新社与美联社消息，美国财政部周四（3月12日）宣布，对俄罗斯石油制裁给予30天豁免，持续至4月11日，目的是释放滞留在海上的俄罗斯货物，并缓解因伊朗战争造成的供应短缺。乌克兰总统泽连斯基周五（3月13日）表示，美国在伊朗战争背景下对俄罗斯石油制裁给予的30天豁免“不是正确的决定”，不会帮助制止俄罗斯持续超过四年的入侵乌克兰。法新社分析，美国的放松制裁这一决定无疑将会让俄罗斯受益。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260313-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E5%B7%B2%E8%AE%A9%E4%BF%84%E7%BD%97%E6%96%AF%E5%85%85%E5%88%86%E5%8F%97%E7%9B%8A%EF%BC%8C%E7%BE%8E%E5%9B%BD%E6%94%BE%E6%9D%BE%E7%9F%B3%E6%B2%B9%E5%88%B6%E8%A3%81%E5%8F%88%E4%B8%BA%E4%BF%84%E7%BD%97%E6%96%AF%E5%B8%A6%E6%9D%A5%E6%96%B0%E7%9A%84%E5%88%A9%E5%A5%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773427458000.webp","sourceId":"rfi"},{"id":1773425481000,"createdDate":"2026-03-13 18:11","name":"法国国际广播电台","title":"美国防部长批评CNN伊朗战争报道是“假新闻”，表示期待CNN尽快被接管，接管人为特朗普亲近人士","content":"由于对CNN关于伊朗战争的报道不满，美国五角大楼负责人皮特·赫格塞斯周五（3月13日）表示，他期待这家新闻频道尽快被大卫·埃里森接管。埃里森是派拉蒙天空之舞公司（ParamountSkydance）的负责人，该公司是一家美国跨国大众传媒和娱乐集团，而这位负责人同时也是美国总统特朗普的亲近人士。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260313-%E7%BE%8E%E5%9B%BD%E9%98%B2%E9%83%A8%E9%95%BF%E6%89%B9%E8%AF%84cnn%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%8A%A5%E9%81%93%E6%98%AF-%E5%81%87%E6%96%B0%E9%97%BB-%EF%BC%8C%E8%A1%A8%E7%A4%BA%E6%9C%9F%E5%BE%85cnn%E5%B0%BD%E5%BF%AB%E8%A2%AB%E6%8E%A5%E7%AE%A1%EF%BC%8C%E6%8E%A5%E7%AE%A1%E4%BA%BA%E4%B8%BA%E7%89%B9%E6%9C%97%E6%99%AE%E4%BA%B2%E8%BF%91%E4%BA%BA%E5%A3%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/13/1773425481000.webp","sourceId":"rfi"}]