[{"id":1773218606000,"createdDate":"2026-03-11 08:43","name":"法国国际广播电台","title":"国际能源署提议释放创纪录的石油储备 规模超过俄乌战争","content":"路透社消息称，据《华尔街日报》援引知情官员报道，国际能源署（IEA）提议动用战略石油储备以稳定市场。受该消息影响，布伦特原油价格回吐了此前近4%的涨幅，回落至每桶约88美元。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260311-%E5%9B%BD%E9%99%85%E8%83%BD%E6%BA%90%E7%BD%B2%E6%8F%90%E8%AE%AE%E9%87%8A%E6%94%BE%E5%88%9B%E7%BA%AA%E5%BD%95%E7%9A%84%E7%9F%B3%E6%B2%B9%E5%82%A8%E5%A4%87-%E8%A7%84%E6%A8%A1%E8%B6%85%E8%BF%87%E4%BF%84%E4%B9%8C%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773218606000.webp","sourceId":"rfi"},{"id":1773215868000,"createdDate":"2026-03-11 07:57","name":"法国国际广播电台","title":"联合国五专家促中港政府结束对邹幸彤和李卓人的不公检控 港府拒回应","content":"联合国五名人权专家高度关注香港法院正在审理的支联会案，认为港府在案件开审前关押李卓人和邹幸彤逾1500天的做法，是严重侵犯人权，并去信中国政府，要求港府结束对李卓人和邹幸彤的不公检控，但中港政府在60日的回覆期完结后仍没作出回应，而审讯亦在继续。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E8%81%94%E5%90%88%E5%9B%BD%E4%BA%94%E4%B8%93%E5%AE%B6%E4%BF%83%E4%B8%AD%E6%B8%AF%E6%94%BF%E5%BA%9C%E7%BB%93%E6%9D%9F%E5%AF%B9%E9%82%B9%E5%B9%B8%E5%BD%A4%E5%92%8C%E6%9D%8E%E5%8D%93%E4%BA%BA%E7%9A%84%E4%B8%8D%E5%85%AC%E6%A3%80%E6%8E%A7-%E6%B8%AF%E5%BA%9C%E6%8B%92%E5%9B%9E%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773215868000.webp","sourceId":"rfi"},{"id":1773215540000,"createdDate":"2026-03-11 07:52","name":"法国国际广播电台","title":"高市首相会见美国驻日大使  日美首脑会谈将如期举行","content":"日本时间3月10日下午，美国驻日大使乔治·格拉斯礼节性拜访了日本首相高市早苗，高市早苗与他举行了约25分钟的会谈。格拉斯大使表示，在高市首相与美国总统特朗普强有力的领导下，日美同盟比以往任何时候都更加牢固，并再次表明美国对日美同盟以及“自由开放的印太地区”的坚定承诺。高市首相表示，期待即将进行的访美之行能够再次展现牢不可破的日美同盟。双方还就当前围绕伊朗局势在内的国际形势交换了意见。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E4%BC%9A%E8%A7%81%E7%BE%8E%E5%9B%BD%E9%A9%BB%E6%97%A5%E5%A4%A7%E4%BD%BF-%E6%97%A5%E7%BE%8E%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88%E5%B0%86%E5%A6%82%E6%9C%9F%E4%B8%BE%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773215540000.webp","sourceId":"rfi"},{"id":1773215358000,"createdDate":"2026-03-11 07:49","name":"法国国际广播电台","title":"支联会「煽颠案」续审 法官质疑部分证据要用多番联想才能与串谋连结","content":"已解散的支联会及其前正副主席李卓人丶何俊仁和邹幸彤，被控煽动颠覆国家政权罪(简称煽颠)的案件，法庭继续处理控方欲以「共谋者原则」处理证据从而确认各被告串谋的问题，当中，法官质疑，控方以个别被告受访丶没有谈及支联会和「结束一党专政」的视频作为串谋证据呈堂，须要「很多联想力」，才能把该段访问内容与支联会和「结束一党专政」串连。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E6%94%AF%E8%81%94%E4%BC%9A-%E7%85%BD%E9%A2%A0%E6%A1%88-%E7%BB%AD%E5%AE%A1-%E6%B3%95%E5%AE%98%E8%B4%A8%E7%96%91%E9%83%A8%E5%88%86%E8%AF%81%E6%8D%AE%E8%A6%81%E7%94%A8%E5%A4%9A%E7%95%AA%E8%81%94%E6%83%B3%E6%89%8D%E8%83%BD%E4%B8%8E%E4%B8%B2%E8%B0%8B%E8%BF%9E%E7%BB%93","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773215358000.webp","sourceId":"rfi"},{"id":1773198575000,"createdDate":"2026-03-11 03:09","name":"法国国际广播电台","title":"美国最后一刻筹备“习特会” 中国不满且担忧","content":"据彭博社10日报道，距离特朗普与习近平会晤仅剩三周，北京对美国准备不足感到不满，认为这可能会将这次具有里程碑意义的峰会限制在贸易协议上，而关键外交与安全议题则被搁置一旁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E7%BE%8E%E5%9B%BD%E6%9C%80%E5%90%8E%E4%B8%80%E5%88%BB%E7%AD%B9%E5%A4%87-%E4%B9%A0%E7%89%B9%E4%BC%9A-%E4%B8%AD%E5%9B%BD%E4%B8%8D%E6%BB%A1%E4%B8%94%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773198575000.webp","sourceId":"rfi"},{"id":1773246166000,"createdDate":"2026-03-11 16:22","name":"法国国际广播电台","title":"地缘政治动荡再加移民政策争议令2026足球世界杯成败难料","content":"距离6月11日，2026世界杯足球赛在美国开赛已经只剩下三个月的时间。2026年恰好是美国建国250周年。如果说重返白宫特朗普决心要借这次体育赛事体现他要让美国再次伟大的雄心的话，他上任一年多来的许多政策已经令这次本就规格不凡的赛事能否成功面对更多挑战。2月28日，美国与以色列联合对伊朗发动的军事打击行动以及该行动在中东地区引发的连带动荡更预先给这次体育盛事蒙上又一层阴影。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260311-%E5%9C%B0%E7%BC%98%E6%94%BF%E6%B2%BB%E5%8A%A8%E8%8D%A1%E5%86%8D%E5%8A%A0%E7%A7%BB%E6%B0%91%E6%94%BF%E7%AD%96%E4%BA%89%E8%AE%AE%E4%BB%A42026%E8%B6%B3%E7%90%83%E4%B8%96%E7%95%8C%E6%9D%AF%E6%88%90%E8%B4%A5%E9%9A%BE%E6%96%99","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773246166000.webp","sourceId":"rfi"},{"id":1773245351000,"createdDate":"2026-03-11 16:09","name":"法国国际广播电台","title":"中国加深与朝鲜互动，向特朗普释放信号：“仍掌影响金正恩决策之钥”","content":"在美国总统特朗普准备访华并表示有意重启与朝鲜最高领导人金正恩的对话之际，据路透社一项调查发现，北京正在加深与朝鲜的接触，包括建立更紧密的经济联系。这些动作显示中国试图重新强化它对朝鲜的影响力，并向美国释放信号，北京仍掌握可影响金正恩决策的关键。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E4%B8%AD%E5%9B%BD%E5%8A%A0%E6%B7%B1%E4%B8%8E%E6%9C%9D%E9%B2%9C%E4%BA%92%E5%8A%A8%EF%BC%8C%E5%90%91%E7%89%B9%E6%9C%97%E6%99%AE%E9%87%8A%E6%94%BE%E4%BF%A1%E5%8F%B7-%E4%BB%8D%E6%8E%8C%E5%BD%B1%E5%93%8D%E9%87%91%E6%AD%A3%E6%81%A9%E5%86%B3%E7%AD%96%E4%B9%8B%E9%92%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773245351000.webp","sourceId":"rfi"},{"id":1773242254000,"createdDate":"2026-03-11 15:17","name":"法国国际广播电台","title":"快讯：国际能源署宣布释放4亿桶战略石油储备，日德率先行动","content":"国际能源署（IEA）宣布，其32个成员国于3月11日周三达成“一致决定”，将从战略储备中向市场投放4亿桶原油。这是该机构历史上规模最大的一次储备释放行动。早些时候，日本首相高市早苗已表示，日本将自行释放战略石油储备，释放行动最早可能于3月16日开始。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260311-%E5%BF%AB%E8%AE%AF-%E5%9B%BD%E9%99%85%E8%83%BD%E6%BA%90%E7%BD%B2%E5%AE%A3%E5%B8%83%E9%87%8A%E6%94%BE4%E4%BA%BF%E6%A1%B6%E6%88%98%E7%95%A5%E7%9F%B3%E6%B2%B9%E5%82%A8%E5%A4%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773242254000.webp","sourceId":"rfi"},{"id":1773240239000,"createdDate":"2026-03-11 14:43","name":"法国国际广播电台","title":"日本部署1千公里长程导弹 中国国防部指责：“彻底撕下自卫伪装”","content":"针对日本防卫省昨天10日宣布3月底部署射程约1000公里、可触及中国本土的新型长程飞弹，中国国防部发言人蒋斌今天11日宣称，此举“彻底撕下自卫的伪装”，充分证明日本“新型军国主义”已不只是危险苗头，而是赤裸裸的现实威胁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E6%97%A5%E6%9C%AC%E9%83%A8%E7%BD%B21%E5%8D%83%E5%85%AC%E9%87%8C%E9%95%BF%E7%A8%8B%E5%AF%BC%E5%BC%B9-%E4%B8%AD%E5%9B%BD%E5%9B%BD%E9%98%B2%E9%83%A8%E6%8C%87%E8%B4%A3-%E5%BD%BB%E5%BA%95%E6%92%95%E4%B8%8B%E8%87%AA%E5%8D%AB%E4%BC%AA%E8%A3%85","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773240239000.webp","sourceId":"rfi"},{"id":1773239822000,"createdDate":"2026-03-11 14:37","name":"法国国际广播电台","title":"视频 马克龙总统访问塞浦路斯 讨论地区安全问题","content":"法国总统马克龙访问塞浦路斯，声援曾遭受本次中东战火牵连到欧盟成员国，法国总统马克龙的目标是盟国“采取严格的防御”，应对伊朗的袭击，请看尼古拉斯·沙蒙坦的视频报道报道","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260311-%E8%A7%86%E9%A2%91-%E9%A9%AC%E5%85%8B%E9%BE%99%E6%80%BB%E7%BB%9F%E8%AE%BF%E9%97%AE%E5%A1%9E%E6%B5%A6%E8%B7%AF%E6%96%AF-%E8%AE%A8%E8%AE%BA%E5%9C%B0%E5%8C%BA%E5%AE%89%E5%85%A8%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773239822000.webp","sourceId":"rfi"},{"id":1773237551000,"createdDate":"2026-03-11 13:59","name":"法国国际广播电台","title":"绿色和平为何反对法国重整核能计划？","content":"2026年3月11日是日本福岛核事故十五周年的纪念日，15年前这场史无前例的核灾难曾经对全世界的核能开发造成致命性的打击，德国随后宣布走出核能计划，法国作为核能大国也立即叫停了新的开发计划，并且决定关闭老旧的核电站。不过，15年后，虽然福岛核事故的阴影未散，核能开发再度被推向前台，五年前爆发的俄罗斯入侵乌克兰的战争所激发了新一波的能源危机被十多年天前美国与以色列对伊朗发动的攻击进一步加剧，与此同时，能源自主成为当务之急，法国总统马克龙在3月10日举行的核能峰会以及随后的七大工业国峰会上都提出了重整核能开发的重要性，不过，对绿色和平等反对核组织来说，法国今天重启核能不仅远水救不了近火，经济代价昂贵难以承受，而且所谓通过开发核能来达到能源自主的目标也不过是一个脱离现实的空想。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260311-%E7%BB%BF%E8%89%B2%E5%92%8C%E5%B9%B3%E7%BB%84%E7%BB%87%E4%B8%BA%E4%BD%95%E5%8F%8D%E5%AF%B9%E6%B3%95%E5%9B%BD%E9%87%8D%E6%95%B4%E6%A0%B8%E8%83%BD%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773237551000.webp","sourceId":"rfi"},{"id":1773234323000,"createdDate":"2026-03-11 13:05","name":"法国国际广播电台","title":"中国警告美国：人工智能军事化或令世界陷入“终结者”式末日","content":"法新社北京消息，中国周三11日向美国政府发出警告，称在军事领域无节制地使用人工智能（AI）可能会让世界陷入电影《终结者》式的末日，即出现机器夺取权力的局面。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E4%B8%AD%E5%9B%BD%E8%AD%A6%E5%91%8A%E7%BE%8E%E5%9B%BD-%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E5%86%9B%E4%BA%8B%E5%8C%96%E6%88%96%E4%BB%A4%E4%B8%96%E7%95%8C%E9%99%B7%E5%85%A5-%E7%BB%88%E7%BB%93%E8%80%85-%E5%BC%8F%E6%9C%AB%E6%97%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773234323000.webp","sourceId":"rfi"},{"id":1773230538000,"createdDate":"2026-03-11 12:02","name":"法国国际广播电台","title":"视频 以色列空袭 黎巴嫩66万多人流离失所","content":"黎巴嫩正经历一场人道主义灾难，以色列空袭的短短几天内已经造成近70万名平民逃离战区。面对以色列的攻势，男女老少纷纷离开家园。黎巴嫩军队今天上午在黎巴嫩南部城市提尔附近回击。请看France24特派记者约翰·博丁报道","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260311-%E8%A7%86%E9%A2%91-%E4%BB%A5%E8%89%B2%E5%88%97%E7%A9%BA%E8%A2%AD-%E9%BB%8E%E5%B7%B4%E5%AB%A966%E4%B8%87%E5%A4%9A%E4%BA%BA%E6%B5%81%E7%A6%BB%E5%A4%B1%E6%89%80","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773230538000.webp","sourceId":"rfi"},{"id":1773230369000,"createdDate":"2026-03-11 11:59","name":"法国国际广播电台","title":"美国对伊朗战争目标不明，与以同盟裂痕却渐明！海湾国家深感不安","content":"据本台法语部报道，尽管海湾国家将地区稳定视为首要任务，但华盛顿在伊朗问题上不断变化的战略目标令其深感忧虑，因为这使他们无法预见最终结局。在中东战争进入第12天之际，美国总统特朗普暗示对伊朗军事行动可能很快结束，这让一个新问题浮出水面：以色列和美国在何时以及在何种条件下结束这场冲突上，存在着截然不同的想法。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260311-%E7%BE%8E%E5%9B%BD%E5%AF%B9%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E7%9B%AE%E6%A0%87%E4%B8%8D%E6%98%8E%EF%BC%8C%E4%B8%8E%E4%BB%A5%E5%90%8C%E7%9B%9F%E8%A3%82%E7%97%95%E6%B8%90%E6%98%8E-%E6%B5%B7%E6%B9%BE%E5%9B%BD%E5%AE%B6%E6%B7%B1%E6%84%9F%E4%B8%8D%E5%AE%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773230369000.webp","sourceId":"rfi"},{"id":1773230020000,"createdDate":"2026-03-11 11:53","name":"法国国际广播电台","title":"再有货船在海湾地区水域遇袭，美军击沉多艘伊朗布雷船只","content":"随着美国和以色列联手发动的针对伊朗军事打击行动的推进，经过海湾地区尤其是经过霍尔木兹海峡的货船被战火殃及的风险不断升高。3月11日，法新社引述英国海事贸易行动办公室(UKMTO)消息报道，当日至少有两艘货船先后在阿拉伯联合酋长国附近水域被不明飞行物击中。美军日前也宣布，击毁了16艘在霍尔木兹海峡布雷的伊朗船只。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260311-%E5%86%8D%E6%9C%89%E8%B4%A7%E8%88%B9%E5%9C%A8%E6%B5%B7%E6%B9%BE%E5%9C%B0%E5%8C%BA%E6%B0%B4%E5%9F%9F%E9%81%87%E8%A2%AD%EF%BC%8C%E7%BE%8E%E5%86%9B%E5%87%BB%E6%B2%89%E5%A4%9A%E8%89%98%E4%BC%8A%E6%9C%97%E5%B8%83%E9%9B%B7%E8%88%B9%E5%8F%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773230020000.webp","sourceId":"rfi"},{"id":1773226604000,"createdDate":"2026-03-11 10:56","name":"法国国际广播电台","title":"是否与美国沟通伊朗战事？中国外交部回避提问","content":"据中央社报道，美国与以色列攻击伊朗后，中国外长王毅近日接连致电波斯湾国家与以色列外长讨论局势，但迄未与美国方面接触。中国外交部发言人郭嘉昆今天11日对中方是否与美国沟通回避作答，仅指中方与“包括冲突当事方在内的有关各方”保持着沟通和对话。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E6%98%AF%E5%90%A6%E4%B8%8E%E7%BE%8E%E5%9B%BD%E6%B2%9F%E9%80%9A%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%8B-%E4%B8%AD%E5%9B%BD%E5%A4%96%E4%BA%A4%E9%83%A8%E5%9B%9E%E9%81%BF%E6%8F%90%E9%97%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773226604000.webp","sourceId":"rfi"},{"id":1773222066000,"createdDate":"2026-03-11 09:41","name":"法国国际广播电台","title":"美国和中央情报局改变伊朗命运：73年前的一个被遗忘政变故事","content":"在美国总统唐纳德·特朗普领导下的美国继续轰炸伊朗，试图推翻伊朗伊斯兰共和国之际，73年前，美国和中央情报局曾经改变了伊朗的命运；这是一个被遗忘的政变的故事，本节目让我们重温一番伊朗历史上一个鲜为人知的篇章：1953年，那一年，一场政变导致一位民族主义的总理下台。然而，在幕后，白宫和中央情报局早已开始操纵，试图让伊朗国王重新掌权，但其政权最终在1979年被推翻。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260311-%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%B8%AD%E5%A4%AE%E6%83%85%E6%8A%A5%E5%B1%80%E6%94%B9%E5%8F%98%E4%BC%8A%E6%9C%97%E5%91%BD%E8%BF%90-73%E5%B9%B4%E5%89%8D%E4%B8%80%E4%B8%AA%E8%A2%AB%E9%81%97%E5%BF%98%E6%94%BF%E5%8F%98%E6%95%85%E4%BA%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773222066000.webp","sourceId":"rfi"},{"id":1773219805000,"createdDate":"2026-03-11 09:03","name":"法国国际广播电台","title":"纽时：中国在伊朗战争爆发前 就已开始囤积石油","content":"据《纽约时报》报道指出，今年前两个月，在中东冲突爆发导致能源供应线瘫痪之前，作为应对地缘政治紧张局势的持续战略，中国已加大石油采购力度。与此同时，彭博社报道也指出，由于美伊战乱扰乱石油生产和运输，中国庞大的原油储备为其炼油商提供了喘息之机──这是多年来储备和多元化供应的回报。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E7%BA%BD%E6%97%B6-%E4%B8%AD%E5%9B%BD%E5%9C%A8%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E7%88%86%E5%8F%91%E5%89%8D-%E5%B0%B1%E5%B7%B2%E5%BC%80%E5%A7%8B%E5%9B%A4%E7%A7%AF%E7%9F%B3%E6%B2%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773219805000.webp","sourceId":"rfi"},{"id":1773218923000,"createdDate":"2026-03-11 08:48","name":"法国国际广播电台","title":"巴拿马运河之争：中国远洋航运暂停在巴尔博亚港的运营","content":"据巴拿马媒体刊登的一份内部备忘录显示，中国远洋航运公司周二（3月10号）宣布，在巴拿马一家法院撤销了香港长江和记实业有限公司持有的巴拿马运河港口特许经营权后，该公司将暂停在巴尔博亚港的运营。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260311-%E5%B7%B4%E6%8B%BF%E9%A9%AC%E8%BF%90%E6%B2%B3%E4%B9%8B%E4%BA%89-%E4%B8%AD%E5%9B%BD%E8%BF%9C%E6%B4%8B%E8%88%AA%E8%BF%90%E6%9A%82%E5%81%9C%E5%9C%A8%E5%B7%B4%E5%B0%94%E5%8D%9A%E4%BA%9A%E6%B8%AF%E7%9A%84%E8%BF%90%E8%90%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773218923000.webp","sourceId":"rfi"},{"id":1773218860000,"createdDate":"2026-03-11 08:47","name":"法国国际广播电台","title":"国际能源署考虑释放储备：亚洲股市延涨，油价企稳","content":"法新社香港消息，周三11日亚洲股市延续涨势，油价企稳，此前据《华尔街日报》报道称国际能源署（IEA）正考虑释放创纪录数量的储备，以应对飙升的油价。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260311-%E5%9B%BD%E9%99%85%E8%83%BD%E6%BA%90%E7%BD%B2%E8%80%83%E8%99%91%E9%87%8A%E6%94%BE%E5%82%A8%E5%A4%87-%E4%BA%9A%E6%B4%B2%E8%82%A1%E5%B8%82%E5%BB%B6%E6%B6%A8%EF%BC%8C%E6%B2%B9%E4%BB%B7%E4%BC%81%E7%A8%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773218860000.webp","sourceId":"rfi"},{"id":1773268161000,"createdDate":"2026-03-11 22:29","name":"法国国际广播电台","title":"美国能否与伊朗拼消耗战","content":"美以发动的这场战争，现在让人怀疑所谓推翻政权只是一句空话，可能顶多换汤不换药，甚至连汤都不换。有人讽刺：美国用了二十年时间，在阿富汗把塔利班换成了塔利班，特朗普只用了一个多星期，就把一个哈梅内伊换成另一个哈梅内伊。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E7%BE%8E%E5%9B%BD%E8%83%BD%E5%90%A6%E4%B8%8E%E4%BC%8A%E6%9C%97%E6%8B%BC%E6%B6%88%E8%80%97%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773268161000.webp","sourceId":"rfi"},{"id":1773265589000,"createdDate":"2026-03-11 21:46","name":"法国国际广播电台","title":"德国《世界报》：伊朗是德国推进经济力量扩张战略中的一枚关键棋子","content":"德国媒体如何看待伊朗战争？","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E5%BE%B7%E5%9B%BD-%E4%B8%96%E7%95%8C%E6%8A%A5-%E4%BC%8A%E6%9C%97%E6%98%AF%E5%BE%B7%E5%9B%BD%E6%8E%A8%E8%BF%9B%E7%BB%8F%E6%B5%8E%E5%8A%9B%E9%87%8F%E6%89%A9%E5%BC%A0%E6%88%98%E7%95%A5%E4%B8%AD%E7%9A%84%E4%B8%80%E6%9E%9A%E5%85%B3%E9%94%AE%E6%A3%8B%E5%AD%90","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773265589000.webp","sourceId":"rfi"},{"id":1773265023000,"createdDate":"2026-03-11 21:37","name":"法国国际广播电台","title":"知情人士透露：伊朗在霍尔木兹海峡已布设约12枚水雷  特朗普宣布“28艘伊朗布雷船已被击中”","content":"路透社消息称，据两位知情人士表示，伊朗在霍尔木兹海峡布设了约12枚水雷，这一举动可能会让当前的局势变得更加复杂，尤其是重新开放这一重要石油和液化天然气航道。与此同时，特朗普则宣布“28艘伊朗布雷船已被击中”。法新社发布了一篇分析文章，指出伊朗的水雷策略此前就被使用过并预测伊朗可能拥有5000至6000枚海雷，尤其是漂浮式水雷，难以拦截。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260311-%E7%9F%A5%E6%83%85%E4%BA%BA%E5%A3%AB%E9%80%8F%E9%9C%B2-%E4%BC%8A%E6%9C%97%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%B7%B2%E5%B8%83%E8%AE%BE%E7%BA%A612%E6%9E%9A%E6%B0%B4%E9%9B%B7-%E4%BD%86%E6%8B%92%E7%BB%9D%E9%80%8F%E9%9C%B2%E7%BE%8E%E5%9B%BD%E5%A6%82%E4%BD%95%E5%BA%94%E5%AF%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773265023000.webp","sourceId":"rfi"},{"id":1773264930000,"createdDate":"2026-03-11 21:35","name":"法国国际广播电台","title":"FBI警告：伊朗或以无人机袭击美国西岸　加州警方接获潜在威胁通报","content":"美国联邦执法机构近日向加州多个警察部门发出安全警告，指出伊朗可能以无人机对美国西岸发动报复性袭击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-fbi%E8%AD%A6%E5%91%8A-%E4%BC%8A%E6%9C%97%E6%88%96%E4%BB%A5%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB%E7%BE%8E%E5%9B%BD%E8%A5%BF%E5%B2%B8-%E5%8A%A0%E5%B7%9E%E8%AD%A6%E6%96%B9%E6%8E%A5%E8%8E%B7%E6%BD%9C%E5%9C%A8%E5%A8%81%E8%83%81%E9%80%9A%E6%8A%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773264930000.webp","sourceId":"rfi"},{"id":1773264488000,"createdDate":"2026-03-11 21:28","name":"法国国际广播电台","title":"伊朗最高领袖为何至今未露面","content":"伊朗新任最高领袖、哈梅内伊之子穆杰塔巴·哈梅内伊上周末任命以来一直没有露面，原因不明，他可能在战争初期受伤？或者躲避起来，以防遭美国以色列暗杀？","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E4%BC%8A%E6%9C%97%E6%9C%80%E9%AB%98%E9%A2%86%E8%A2%96%E4%B8%BA%E4%BD%95%E8%87%B3%E4%BB%8A%E6%9C%AA%E9%9C%B2%E9%9D%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773264488000.webp","sourceId":"rfi"},{"id":1773262098000,"createdDate":"2026-03-11 20:48","name":"法国国际广播电台","title":"伊朗：准备开展持久战，有能力“摧毁整个美国经济及全球经济”","content":"中东的冲突已经入第12天，伊朗周三（3月11日）表示，已经为一场持久战争做好准备，伊朗革命卫队代表阿里·法达维甚至威胁要发动“消耗战”，有能力“摧毁整个美国经济及全球经济”。目前，这场战争已严重威胁全球石油供应。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260311-%E4%BC%8A%E6%9C%97-%E5%87%86%E5%A4%87%E5%BC%80%E5%B1%95%E6%8C%81%E4%B9%85%E6%88%98%EF%BC%8C%E6%9C%89%E8%83%BD%E5%8A%9B-%E6%91%A7%E6%AF%81%E6%95%B4%E4%B8%AA%E7%BE%8E%E5%9B%BD%E7%BB%8F%E6%B5%8E%E5%8F%8A%E5%85%A8%E7%90%83%E7%BB%8F%E6%B5%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773262098000.webp","sourceId":"rfi"},{"id":1773261232000,"createdDate":"2026-03-11 20:33","name":"法国国际广播电台","title":"台湾问题-多项因素表明:中国最早可能在2026年发动攻击","content":"面对台海两岸关系的紧张现况，一些台湾问题分析人士担心一场“风暴”即将到来。未来几个月，政治、军事和战略因素的综合作用可能会彻底改变台湾脆弱的平衡局面。鉴于北京方面的考量、美国政策的不确定性以及世界其他地区冲突的演变，一些分析人士因此担心一场“风暴”即将到来。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98-%E5%A4%9A%E9%A1%B9%E5%9B%A0%E7%B4%A0%E8%A1%A8%E6%98%8E-%E4%B8%AD%E5%9B%BD%E6%9C%80%E6%97%A9%E5%8F%AF%E8%83%BD%E5%9C%A82026%E5%B9%B4%E5%8F%91%E5%8A%A8%E6%94%BB%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773261232000.webp","sourceId":"rfi"},{"id":1773259154000,"createdDate":"2026-03-11 19:59","name":"法国国际广播电台","title":"伊拉克最高什叶派宗教领袖呼吁：希望伊朗新任最高领袖维护“国家团结”","content":"伊拉克数百万什叶派穆斯林及全球什叶派的最高宗教权威大阿亚图拉阿里·西斯塔尼（AliSistani）周三（3月11日）向伊朗新任最高领袖表示祝愿，希望最高领袖能够“维护国家团结与和谐”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260311-%E4%BC%8A%E6%8B%89%E5%85%8B%E6%9C%80%E9%AB%98%E4%BB%80%E5%8F%B6%E6%B4%BE%E5%AE%97%E6%95%99%E9%A2%86%E8%A2%96%E5%91%BC%E5%90%81-%E5%B8%8C%E6%9C%9B%E4%BC%8A%E6%9C%97%E6%96%B0%E4%BB%BB%E6%9C%80%E9%AB%98%E9%A2%86%E8%A2%96%E7%BB%B4%E6%8A%A4-%E5%9B%BD%E5%AE%B6%E5%9B%A2%E7%BB%93","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773259154000.webp","sourceId":"rfi"},{"id":1773258731000,"createdDate":"2026-03-11 19:52","name":"法国国际广播电台","title":"中东战争：罗马尼亚允许美国使用本国基地为作战飞机加油","content":"罗马尼亚周三（3月11日）批准美国在其领土上的空军基地加油，以支持参与中东冲突的飞机。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260311-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89-%E7%BD%97%E9%A9%AC%E5%B0%BC%E4%BA%9A%E5%85%81%E8%AE%B8%E7%BE%8E%E5%9B%BD%E4%BD%BF%E7%94%A8%E6%9C%AC%E5%9B%BD%E5%9F%BA%E5%9C%B0%E4%B8%BA%E4%BD%9C%E6%88%98%E9%A3%9E%E6%9C%BA%E5%8A%A0%E6%B2%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773258731000.webp","sourceId":"rfi"},{"id":1773258386000,"createdDate":"2026-03-11 19:46","name":"法国国际广播电台","title":"美军一架P-8A反潜机飞越台湾海峡","content":"路透社消息称，一架美国海军P-8A波塞冬反潜机于周三飞越台湾海峡国际空域，美国第七舰队表示，此举表明美国对“自由开放的印太地区”的承诺。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260311-%E7%BE%8E%E5%86%9B%E4%B8%80%E6%9E%B6p-8a%E5%8F%8D%E6%BD%9C%E6%9C%BA%E9%A3%9E%E8%B6%8A%E5%8F%B0%E6%B9%BE%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773258386000.webp","sourceId":"rfi"},{"id":1773256975000,"createdDate":"2026-03-11 19:22","name":"法国国际广播电台","title":"乌克兰称在意大利冬残奥会遭“系统性施压”","content":"乌克兰国家残奥委员会日前指责国际残奥委员会以及米兰科尔蒂纳2026年冬残奥会的赛事组织方，对乌克兰代表团施加了“系统性压力”。乌方称，这些压力体现在对国旗悬挂、团队简报活动以及运动员配饰等方面的限制。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260311-%E4%B9%8C%E5%85%8B%E5%85%B0%E7%A7%B0%E5%9C%A8%E6%84%8F%E5%A4%A7%E5%88%A9%E5%86%AC%E6%AE%8B%E5%A5%A5%E4%BC%9A%E9%81%AD-%E7%B3%BB%E7%BB%9F%E6%80%A7%E6%96%BD%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773256975000.webp","sourceId":"rfi"},{"id":1773255316000,"createdDate":"2026-03-11 18:55","name":"法国国际广播电台","title":"挪威美领馆爆炸案后续：三名伊拉克裔兄弟被捕","content":"挪威警方周三（3月11日）宣布，三名伊拉克裔兄弟因涉嫌对美国驻奥斯陆大使馆实施“炸弹恐怖袭击”而被捕。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260311-%E6%8C%AA%E5%A8%81%E7%BE%8E%E9%A2%86%E9%A6%86%E7%88%86%E7%82%B8%E6%A1%88%E5%90%8E%E7%BB%AD-%E4%B8%89%E5%90%8D%E4%BC%8A%E6%8B%89%E5%85%8B%E8%A3%94%E5%85%84%E5%BC%9F%E8%A2%AB%E6%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773255316000.webp","sourceId":"rfi"},{"id":1773254283000,"createdDate":"2026-03-11 18:38","name":"法国国际广播电台","title":"英国政府证实：斯塔默在任命曼德尔森前，就已被明确警告此人与爱泼斯坦的关系存在“风险”","content":"英国政府周三公布的文件显示，在任命彼得·曼德尔森为驻美国大使之前，英国首相斯塔默已被警告，曼德尔森与美国性犯罪者杰弗里·爱泼斯坦之间的关系存在“风险”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260311-%E8%8B%B1%E5%9B%BD%E6%94%BF%E5%BA%9C%E8%AF%81%E5%AE%9E-%E6%96%AF%E5%A1%94%E9%BB%98%E5%9C%A8%E4%BB%BB%E5%91%BD%E6%9B%BC%E5%BE%B7%E5%B0%94%E6%A3%AE%E5%89%8D%EF%BC%8C%E5%B0%B1%E5%B7%B2%E8%A2%AB%E6%98%8E%E7%A1%AE%E8%AD%A6%E5%91%8A%E6%AD%A4%E4%BA%BA%E4%B8%8E%E7%88%B1%E6%B3%BC%E6%96%AF%E5%9D%A6%E7%9A%84%E5%85%B3%E7%B3%BB%E5%AD%98%E5%9C%A8-%E9%A3%8E%E9%99%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773254283000.webp","sourceId":"rfi"},{"id":1773253704000,"createdDate":"2026-03-11 18:28","name":"法国国际广播电台","title":"特朗普称伊朗“几乎已没有可打击的目标了”  美国军方暗示接下来的目标是伊朗港口","content":"美国总统特朗普周三（3月11日）在接受新闻网站Axios电话采访时表示，伊朗“几乎已经没有什么可打击的目标了”。连日来，特朗普不断发表有关美国对伊朗军事行动即将结束的言论。与此同时，美国军方暗示，接下来可能会对伊朗的港口发动打击。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260311-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E4%BC%8A%E6%9C%97-%E5%87%A0%E4%B9%8E%E5%B7%B2%E6%B2%A1%E6%9C%89%E5%8F%AF%E6%89%93%E5%87%BB%E7%9A%84%E7%9B%AE%E6%A0%87%E4%BA%86-%E7%BE%8E%E5%9B%BD%E5%86%9B%E6%96%B9%E6%9A%97%E7%A4%BA%E6%8E%A5%E4%B8%8B%E6%9D%A5%E7%9A%84%E7%9B%AE%E6%A0%87%E6%98%AF%E4%BC%8A%E6%9C%97%E6%B8%AF%E5%8F%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773253704000.webp","sourceId":"rfi"},{"id":1773252457000,"createdDate":"2026-03-11 18:07","name":"法国国际广播电台","title":"伊朗学校遭轰炸事件：《纽约时报》披露是美国军方错误定位所致  特朗普称“并不知情”","content":"法新社援引《纽约时报》周三（3月11日）披露的一项美国军方内部调查的初步结果，该结果显示，美国军方在目标坐标上的错误，导致2月28日对伊朗一所学校的轰炸，造成150多人死亡。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260311-%E4%BC%8A%E6%9C%97%E5%AD%A6%E6%A0%A1%E9%81%AD%E8%BD%B0%E7%82%B8%E4%BA%8B%E4%BB%B6-%E7%BA%BD%E7%BA%A6%E6%97%B6%E6%8A%A5-%E6%8A%AB%E9%9C%B2%E6%98%AF%E7%BE%8E%E5%9B%BD%E5%86%9B%E6%96%B9%E9%94%99%E8%AF%AF%E5%AE%9A%E4%BD%8D%E6%89%80%E8%87%B4-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0-%E5%B9%B6%E4%B8%8D%E7%9F%A5%E6%83%85","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773252457000.webp","sourceId":"rfi"},{"id":1773251834000,"createdDate":"2026-03-11 17:57","name":"法国国际广播电台","title":"黎巴嫩：联合国安理会呼吁“冲突降级”保护平民  法国将对黎巴嫩的人道援助量增加至三倍","content":"黎巴嫩战争已进入第十天，法国外交部长周三（3月11日）宣布，为应对以色列对亲伊朗真主党展开军事行动，法国将对黎巴嫩的人道主义援助增加至三倍，并于周四向南部流离失所的难民运送60吨物资。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260311-%E9%BB%8E%E5%B7%B4%E5%AB%A9-%E8%81%94%E5%90%88%E5%9B%BD%E5%AE%89%E7%90%86%E4%BC%9A%E5%91%BC%E5%90%81-%E5%86%B2%E7%AA%81%E9%99%8D%E7%BA%A7-%E4%BF%9D%E6%8A%A4%E5%B9%B3%E6%B0%91-%E6%B3%95%E5%9B%BD%E5%B0%86%E5%AF%B9%E9%BB%8E%E5%B7%B4%E5%AB%A9%E7%9A%84%E4%BA%BA%E9%81%93%E6%8F%B4%E5%8A%A9%E9%87%8F%E5%A2%9E%E5%8A%A0%E8%87%B3%E4%B8%89%E5%80%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773251834000.webp","sourceId":"rfi"}]