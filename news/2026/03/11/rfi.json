[{"id":1773218606000,"createdDate":"2026-03-11 08:43","name":"法国国际广播电台","title":"国际能源署提议释放创纪录的石油储备 规模超过俄乌战争","content":"路透社消息称，据《华尔街日报》援引知情官员报道，国际能源署（IEA）提议动用战略石油储备以稳定市场。受该消息影响，布伦特原油价格回吐了此前近4%的涨幅，回落至每桶约88美元。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260311-%E5%9B%BD%E9%99%85%E8%83%BD%E6%BA%90%E7%BD%B2%E6%8F%90%E8%AE%AE%E9%87%8A%E6%94%BE%E5%88%9B%E7%BA%AA%E5%BD%95%E7%9A%84%E7%9F%B3%E6%B2%B9%E5%82%A8%E5%A4%87-%E8%A7%84%E6%A8%A1%E8%B6%85%E8%BF%87%E4%BF%84%E4%B9%8C%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773218606000.webp","sourceId":"rfi"},{"id":1773215868000,"createdDate":"2026-03-11 07:57","name":"法国国际广播电台","title":"联合国五专家促中港政府结束对邹幸彤和李卓人的不公检控 港府拒回应","content":"联合国五名人权专家高度关注香港法院正在审理的支联会案，认为港府在案件开审前关押李卓人和邹幸彤逾1500天的做法，是严重侵犯人权，并去信中国政府，要求港府结束对李卓人和邹幸彤的不公检控，但中港政府在60日的回覆期完结后仍没作出回应，而审讯亦在继续。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E8%81%94%E5%90%88%E5%9B%BD%E4%BA%94%E4%B8%93%E5%AE%B6%E4%BF%83%E4%B8%AD%E6%B8%AF%E6%94%BF%E5%BA%9C%E7%BB%93%E6%9D%9F%E5%AF%B9%E9%82%B9%E5%B9%B8%E5%BD%A4%E5%92%8C%E6%9D%8E%E5%8D%93%E4%BA%BA%E7%9A%84%E4%B8%8D%E5%85%AC%E6%A3%80%E6%8E%A7-%E6%B8%AF%E5%BA%9C%E6%8B%92%E5%9B%9E%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773215868000.webp","sourceId":"rfi"},{"id":1773215540000,"createdDate":"2026-03-11 07:52","name":"法国国际广播电台","title":"高市首相会见美国驻日大使  日美首脑会谈将如期举行","content":"日本时间3月10日下午，美国驻日大使乔治·格拉斯礼节性拜访了日本首相高市早苗，高市早苗与他举行了约25分钟的会谈。格拉斯大使表示，在高市首相与美国总统特朗普强有力的领导下，日美同盟比以往任何时候都更加牢固，并再次表明美国对日美同盟以及“自由开放的印太地区”的坚定承诺。高市首相表示，期待即将进行的访美之行能够再次展现牢不可破的日美同盟。双方还就当前围绕伊朗局势在内的国际形势交换了意见。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E4%BC%9A%E8%A7%81%E7%BE%8E%E5%9B%BD%E9%A9%BB%E6%97%A5%E5%A4%A7%E4%BD%BF-%E6%97%A5%E7%BE%8E%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88%E5%B0%86%E5%A6%82%E6%9C%9F%E4%B8%BE%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773215540000.webp","sourceId":"rfi"},{"id":1773215358000,"createdDate":"2026-03-11 07:49","name":"法国国际广播电台","title":"支联会「煽颠案」续审 法官质疑部分证据要用多番联想才能与串谋连结","content":"已解散的支联会及其前正副主席李卓人丶何俊仁和邹幸彤，被控煽动颠覆国家政权罪(简称煽颠)的案件，法庭继续处理控方欲以「共谋者原则」处理证据从而确认各被告串谋的问题，当中，法官质疑，控方以个别被告受访丶没有谈及支联会和「结束一党专政」的视频作为串谋证据呈堂，须要「很多联想力」，才能把该段访问内容与支联会和「结束一党专政」串连。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E6%94%AF%E8%81%94%E4%BC%9A-%E7%85%BD%E9%A2%A0%E6%A1%88-%E7%BB%AD%E5%AE%A1-%E6%B3%95%E5%AE%98%E8%B4%A8%E7%96%91%E9%83%A8%E5%88%86%E8%AF%81%E6%8D%AE%E8%A6%81%E7%94%A8%E5%A4%9A%E7%95%AA%E8%81%94%E6%83%B3%E6%89%8D%E8%83%BD%E4%B8%8E%E4%B8%B2%E8%B0%8B%E8%BF%9E%E7%BB%93","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773215358000.webp","sourceId":"rfi"},{"id":1773198575000,"createdDate":"2026-03-11 03:09","name":"法国国际广播电台","title":"美国最后一刻筹备“习特会” 中国不满且担忧","content":"据彭博社10日报道，距离特朗普与习近平会晤仅剩三周，北京对美国准备不足感到不满，认为这可能会将这次具有里程碑意义的峰会限制在贸易协议上，而关键外交与安全议题则被搁置一旁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260311-%E7%BE%8E%E5%9B%BD%E6%9C%80%E5%90%8E%E4%B8%80%E5%88%BB%E7%AD%B9%E5%A4%87-%E4%B9%A0%E7%89%B9%E4%BC%9A-%E4%B8%AD%E5%9B%BD%E4%B8%8D%E6%BB%A1%E4%B8%94%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/11/1773198575000.webp","sourceId":"rfi"}]