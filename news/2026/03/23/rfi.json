[{"id":1774254502000,"createdDate":"2026-03-23 08:28","name":"法国国际广播电台","title":"法国地方选举结果出炉 各党总结经验教训","content":"在没有明确胜者的市政选举之后，各政治阵营周一将总结此次选举的经验教训，而关于2027年总统大选的联盟和策略问题已成为当前辩论的焦点。在巴黎、里昂和马赛这三大城市中，局势保持稳定。在巴黎，社会党人埃马纽埃尔·格雷古瓦庆祝胜利，甚至在地铁和骑行街头时都在庆祝。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260323-%E6%B3%95%E5%9B%BD%E5%9C%B0%E6%96%B9%E9%80%89%E4%B8%BE%E7%BB%93%E6%9E%9C%E5%87%BA%E7%82%89-%E5%90%84%E5%85%9A%E6%B4%BE%E6%80%BB%E7%BB%93%E7%BB%8F%E9%AA%8C%E6%95%99%E8%AE%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774254502000.webp","sourceId":"rfi"},{"id":1774253900000,"createdDate":"2026-03-23 08:18","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第24： 浪漫主义群星之三：荷尔德林  第四节《许佩里翁》一位德意志人的希腊灵魂","content":"席勒和他所弘扬的希腊理想既给荷尔德林以压力又给他带来希望。他的这种心理挣扎体现在他的书信体小说《许佩里翁》中。书中主人公许佩里翁就是荷尔德林本人。他以这部小说展现了一个德意志人的希腊灵魂，他的理想追求和破灭的希望。小说中的女性狄奥提玛则是他一生刻骨铭心的爱人。荷尔德林因她而快乐和心碎。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260323-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%89-%E8%8D%B7%E5%B0%94%E5%BE%B7%E6%9E%97-%E7%AC%AC%E5%9B%9B%E8%8A%82-%E8%AE%B8%E4%BD%A9%E9%87%8C%E7%BF%81-%E4%B8%80%E4%BD%8D%E5%BE%B7%E6%84%8F%E5%BF%97%E4%BA%BA%E7%9A%84%E5%B8%8C%E8%85%8A%E7%81%B5%E9%AD%82","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774253900000.webp","sourceId":"rfi"},{"id":1774252370000,"createdDate":"2026-03-23 07:52","name":"法国国际广播电台","title":"港府「加辣」国安法： 境外人士须提供涉港活动资料 不提供电子设备密码属违法","content":"港府即日起修订维护《港区国安法》第四十三条实施细则，扩大法例的权力，包括赋权执法人员要求任何人提供需要的密码和解码，以及让海关人员可以冻结及充公被指是犯罪相关的财产等。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260323-%E6%B8%AF%E5%BA%9C-%E5%8A%A0%E8%BE%A3-%E5%9B%BD%E5%AE%89%E6%B3%95-%E5%A2%83%E5%A4%96%E4%BA%BA%E5%A3%AB%E9%A1%BB%E6%8F%90%E4%BE%9B%E6%B6%89%E6%B8%AF%E6%B4%BB%E5%8A%A8%E8%B5%84%E6%96%99-%E4%B8%8D%E6%8F%90%E4%BE%9B%E7%94%B5%E5%AD%90%E8%AE%BE%E5%A4%87%E5%AF%86%E7%A0%81%E5%B1%9E%E8%BF%9D%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774252370000.webp","sourceId":"rfi"},{"id":1774252107000,"createdDate":"2026-03-23 07:48","name":"法国国际广播电台","title":"美国会新报告：中国以财政和人海战术干预联合国内部运作","content":"美国众议院「美中战略竞争特别委员会」（HouseSelectCommitteeonChina）的调查报告指出，有证据显示，中国透过「财政武器化」，即利用延迟或拖延支付联合国费用等手段，干预和削弱其人权调查工作。另外又增加中国人在联合国任职的人数和藉着大量与中共有联系的组织去渗透其咨询架构，试图从内部重塑联合国淮则，扩张影响力，以达致操纵联合国为中共服务的目标。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260323-%E7%BE%8E%E5%9B%BD%E4%BC%9A%E6%96%B0%E6%8A%A5%E5%91%8A-%E4%B8%AD%E5%9B%BD%E4%BB%A5%E8%B4%A2%E6%94%BF%E5%92%8C%E4%BA%BA%E6%B5%B7%E6%88%98%E6%9C%AF%E5%B9%B2%E9%A2%84%E8%81%94%E5%90%88%E5%9B%BD%E5%86%85%E9%83%A8%E8%BF%90%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774252107000.webp","sourceId":"rfi"},{"id":1774241989000,"createdDate":"2026-03-23 04:59","name":"法国国际广播电台","title":"伊朗为何扬言破坏海湾邻国逾6000万人的饮水源：开战来最危险时刻？","content":"综合法新社、本台法语部报道及智库分析，在美国总统特朗普于21日发出48小时最后通牒，警告伊朗若不重开霍尔木兹海峡将遭\"毁灭性打击\"后，伊朗于22日强硬回应，扬言将对波斯湾邻国的民用基础设施展开全面报复，攻击目标包括海水淡化设施。此举被分析人士视为比打击油气设施更为致命的冲突升级，因为这直接威胁到科威特、阿曼、沙特阿拉伯、巴林、卡塔尔及阿联酋逾6000万居民赖以为生的饮用水供应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260323-%E4%BC%8A%E6%9C%97%E4%B8%BA%E4%BD%95%E6%89%AC%E8%A8%80%E7%A0%B4%E5%9D%8F%E6%B5%B7%E6%B9%BE%E9%82%BB%E5%9B%BD%E9%80%BE6000%E4%B8%87%E4%BA%BA%E7%9A%84%E9%A5%AE%E6%B0%B4%E6%BA%90-%E5%BC%80%E6%88%98%E6%9D%A5%E6%9C%80%E5%8D%B1%E9%99%A9%E6%97%B6%E5%88%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774241989000.webp","sourceId":"rfi"}]