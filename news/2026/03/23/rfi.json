[{"id":1774254502000,"createdDate":"2026-03-23 08:28","name":"法国国际广播电台","title":"法国地方选举结果出炉 各党总结经验教训","content":"在没有明确胜者的市政选举之后，各政治阵营周一将总结此次选举的经验教训，而关于2027年总统大选的联盟和策略问题已成为当前辩论的焦点。在巴黎、里昂和马赛这三大城市中，局势保持稳定。在巴黎，社会党人埃马纽埃尔·格雷古瓦庆祝胜利，甚至在地铁和骑行街头时都在庆祝。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260323-%E6%B3%95%E5%9B%BD%E5%9C%B0%E6%96%B9%E9%80%89%E4%B8%BE%E7%BB%93%E6%9E%9C%E5%87%BA%E7%82%89-%E5%90%84%E5%85%9A%E6%B4%BE%E6%80%BB%E7%BB%93%E7%BB%8F%E9%AA%8C%E6%95%99%E8%AE%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774254502000.webp","sourceId":"rfi"},{"id":1774253900000,"createdDate":"2026-03-23 08:18","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第24： 浪漫主义群星之三：荷尔德林  第四节《许佩里翁》一位德意志人的希腊灵魂","content":"席勒和他所弘扬的希腊理想既给荷尔德林以压力又给他带来希望。他的这种心理挣扎体现在他的书信体小说《许佩里翁》中。书中主人公许佩里翁就是荷尔德林本人。他以这部小说展现了一个德意志人的希腊灵魂，他的理想追求和破灭的希望。小说中的女性狄奥提玛则是他一生刻骨铭心的爱人。荷尔德林因她而快乐和心碎。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260323-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%89-%E8%8D%B7%E5%B0%94%E5%BE%B7%E6%9E%97-%E7%AC%AC%E5%9B%9B%E8%8A%82-%E8%AE%B8%E4%BD%A9%E9%87%8C%E7%BF%81-%E4%B8%80%E4%BD%8D%E5%BE%B7%E6%84%8F%E5%BF%97%E4%BA%BA%E7%9A%84%E5%B8%8C%E8%85%8A%E7%81%B5%E9%AD%82","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774253900000.webp","sourceId":"rfi"},{"id":1774252370000,"createdDate":"2026-03-23 07:52","name":"法国国际广播电台","title":"港府「加辣」国安法： 境外人士须提供涉港活动资料 不提供电子设备密码属违法","content":"港府即日起修订维护《港区国安法》第四十三条实施细则，扩大法例的权力，包括赋权执法人员要求任何人提供需要的密码和解码，以及让海关人员可以冻结及充公被指是犯罪相关的财产等。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260323-%E6%B8%AF%E5%BA%9C-%E5%8A%A0%E8%BE%A3-%E5%9B%BD%E5%AE%89%E6%B3%95-%E5%A2%83%E5%A4%96%E4%BA%BA%E5%A3%AB%E9%A1%BB%E6%8F%90%E4%BE%9B%E6%B6%89%E6%B8%AF%E6%B4%BB%E5%8A%A8%E8%B5%84%E6%96%99-%E4%B8%8D%E6%8F%90%E4%BE%9B%E7%94%B5%E5%AD%90%E8%AE%BE%E5%A4%87%E5%AF%86%E7%A0%81%E5%B1%9E%E8%BF%9D%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774252370000.webp","sourceId":"rfi"},{"id":1774252107000,"createdDate":"2026-03-23 07:48","name":"法国国际广播电台","title":"美国会新报告：中国以财政和人海战术干预联合国内部运作","content":"美国众议院「美中战略竞争特别委员会」（HouseSelectCommitteeonChina）的调查报告指出，有证据显示，中国透过「财政武器化」，即利用延迟或拖延支付联合国费用等手段，干预和削弱其人权调查工作。另外又增加中国人在联合国任职的人数和藉着大量与中共有联系的组织去渗透其咨询架构，试图从内部重塑联合国淮则，扩张影响力，以达致操纵联合国为中共服务的目标。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260323-%E7%BE%8E%E5%9B%BD%E4%BC%9A%E6%96%B0%E6%8A%A5%E5%91%8A-%E4%B8%AD%E5%9B%BD%E4%BB%A5%E8%B4%A2%E6%94%BF%E5%92%8C%E4%BA%BA%E6%B5%B7%E6%88%98%E6%9C%AF%E5%B9%B2%E9%A2%84%E8%81%94%E5%90%88%E5%9B%BD%E5%86%85%E9%83%A8%E8%BF%90%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774252107000.webp","sourceId":"rfi"},{"id":1774241989000,"createdDate":"2026-03-23 04:59","name":"法国国际广播电台","title":"伊朗为何扬言破坏海湾邻国逾6000万人的饮水源：开战来最危险时刻？","content":"综合法新社、本台法语部报道及智库分析，在美国总统特朗普于21日发出48小时最后通牒，警告伊朗若不重开霍尔木兹海峡将遭\"毁灭性打击\"后，伊朗于22日强硬回应，扬言将对波斯湾邻国的民用基础设施展开全面报复，攻击目标包括海水淡化设施。此举被分析人士视为比打击油气设施更为致命的冲突升级，因为这直接威胁到科威特、阿曼、沙特阿拉伯、巴林、卡塔尔及阿联酋逾6000万居民赖以为生的饮用水供应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260323-%E4%BC%8A%E6%9C%97%E4%B8%BA%E4%BD%95%E6%89%AC%E8%A8%80%E7%A0%B4%E5%9D%8F%E6%B5%B7%E6%B9%BE%E9%82%BB%E5%9B%BD%E9%80%BE6000%E4%B8%87%E4%BA%BA%E7%9A%84%E9%A5%AE%E6%B0%B4%E6%BA%90-%E5%BC%80%E6%88%98%E6%9D%A5%E6%9C%80%E5%8D%B1%E9%99%A9%E6%97%B6%E5%88%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774241989000.webp","sourceId":"rfi"},{"id":1774281661000,"createdDate":"2026-03-23 16:01","name":"法国国际广播电台","title":"以媒消息指：如何停战...... 白宫的交涉对象为伊朗议长","content":"美国总统特朗普周一（3月23日）表示，美伊在过去24小时内进行了对话，双方已就15项要点达成“重大共识”，并补充称可能很快会达成协议以平息战争。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260323-%E4%BB%A5%E5%AA%92%E6%B6%88%E6%81%AF%E6%8C%87-%E5%A6%82%E4%BD%95%E5%81%9C%E6%88%98-%E7%99%BD%E5%AE%AB%E7%9A%84%E4%BA%A4%E6%B6%89%E5%AF%B9%E8%B1%A1%E4%B8%BA%E4%BC%8A%E6%9C%97%E8%AE%AE%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774281661000.webp","sourceId":"rfi"},{"id":1774280294000,"createdDate":"2026-03-23 15:38","name":"法国国际广播电台","title":"中国宣布限制国内燃油涨价 中石化：采购改道亚丁湾五月前供应无虞","content":"法新社北京消息，中国政府周一23日宣布，将限制国内成品油价格的上涨幅度，以减轻中东战争导致国际原油价格暴涨给国内用户带来的负担。此外，中国油价将于23日深夜12时调整，预计加满一箱50升的92号汽油需多付人民币86.5元，此轮调整将是今年以来最大涨幅。目前在北京一个加油站，排队加油的车龙长达100多米。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260323-%E4%B8%AD%E5%9B%BD%E5%AE%A3%E5%B8%83%E9%99%90%E5%88%B6%E5%9B%BD%E5%86%85%E7%87%83%E6%B2%B9%E6%B6%A8%E4%BB%B7-%E4%B8%AD%E7%9F%B3%E5%8C%96-%E9%87%87%E8%B4%AD%E6%94%B9%E9%81%93%E4%BA%9A%E4%B8%81%E6%B9%BE%E4%BA%94%E6%9C%88%E5%89%8D%E4%BE%9B%E5%BA%94%E6%97%A0%E8%99%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774280294000.webp","sourceId":"rfi"},{"id":1774277651000,"createdDate":"2026-03-23 14:54","name":"法国国际广播电台","title":"含北约成员在内的22国愿有条件助力霍尔木兹海峡安全","content":"北大西洋公约组织秘书长马克-吕特22日接受美国福克斯新闻视频采访时表示，包括多个北约成员在内的22个国家正齐心协力，响应美国总统号召，确保霍尔木兹海峡传统无阻。不过，在这则福克斯新闻的采访中，吕特并未明确这些国家会在何时以及何种条件下参加确保海峡通行安全的努力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260323-%E5%90%AB%E5%8C%97%E7%BA%A6%E6%88%90%E5%91%98%E5%9C%A8%E5%86%85%E7%9A%8422%E5%9B%BD%E6%84%BF%E6%9C%89%E6%9D%A1%E4%BB%B6%E5%8A%A9%E5%8A%9B%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774277651000.webp","sourceId":"rfi"},{"id":1774276876000,"createdDate":"2026-03-23 14:41","name":"法国国际广播电台","title":"德黑兰自认“胜券在握” 专家警告这可是对特朗普的“致命误判”","content":"伊朗战争进入第四周，中东局势正陷入一场关于意志与代价的危险博弈。德黑兰方面正释放出强烈的“胜利主义”信号，试图通过掌控霍尔木兹海峡这一全球能源咽喉，迫使华盛顿接受一项足以巩固其数十年地区霸权的“天价”和解方案。然而，据《华尔街日报》引述多位分析人士警告，这种心态可能正引导伊朗步入一场对美国总统特朗普意志的致命误判。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260323-%E5%BE%B7%E9%BB%91%E5%85%B0%E8%87%AA%E8%AE%A4-%E8%83%9C%E5%88%B8%E5%9C%A8%E6%8F%A1-%E4%B8%93%E5%AE%B6%E8%AD%A6%E5%91%8A%E8%BF%99%E5%8F%AF%E6%98%AF%E5%AF%B9%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84-%E8%87%B4%E5%91%BD%E8%AF%AF%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774276876000.webp","sourceId":"rfi"},{"id":1774273744000,"createdDate":"2026-03-23 13:49","name":"法国国际广播电台","title":"欧盟与南方共同市场协议于5月1日起临时实施","content":"欧盟委员会今天周一已决定从5月1日起临时实施欧盟与南方共同市场协议，该协定遭到欧洲农民和法国的反对，但得到德国和西班牙的支持。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260323-%E6%AC%A7%E7%9B%9F%E4%B8%8E%E5%8D%97%E6%96%B9%E5%85%B1%E5%90%8C%E5%B8%82%E5%9C%BA%E5%8D%8F%E8%AE%AE%E4%BA%8E5%E6%9C%881%E6%97%A5%E8%B5%B7%E4%B8%B4%E6%97%B6%E5%AE%9E%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774273744000.webp","sourceId":"rfi"},{"id":1774270158000,"createdDate":"2026-03-23 12:49","name":"法国国际广播电台","title":"最后通牒的“惊喜”！特朗普：结束伊战谈判“进展顺利”军事行动推迟五天","content":"法新社德黑兰消息，美国总统特朗普周一3月23日表示，有关“全面停火”的讨论进展“非常良好且富有成效”。特朗普还宣布，将对伊朗发电站或能源基础设施的所有袭击计划推迟“五天”执行。在中东战争爆发三周后，这一出人意料的表态令全球市场大感慰藉。德黑兰方面尚未立即做出回应，但在过去几天里，伊朗曾一度排除与美国对话的可能性。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260323-%E5%8F%B7%E5%A4%96-%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%8B%E8%BE%BE%E6%9C%80%E5%90%8E%E9%80%9A%E7%89%92%E5%90%8E%E4%BB%8A%E7%A7%B0-%E7%BB%93%E6%9D%9F%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E7%9A%84%E8%B0%88%E5%88%A4-%E8%BF%9B%E5%B1%95%E9%9D%9E%E5%B8%B8%E9%A1%BA%E5%88%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774270158000.webp","sourceId":"rfi"},{"id":1774265470000,"createdDate":"2026-03-23 11:31","name":"法国国际广播电台","title":"法国前总理、左翼领袖若斯潘逝世、享年88岁","content":"法国左翼领袖利昂内尔·若斯潘于3月22日星期日逝世，享年88岁。若斯潘曾在希拉克执政期间担任总理近五年（1997-2002年），在2002年总统选举失败后退出政坛。今年1月，若斯潘曾表示自己接受了“一次大手术”，但未透露任何细节。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260323-%E6%B3%95%E5%9B%BD%E5%89%8D%E6%80%BB%E7%90%86-%E5%B7%A6%E7%BF%BC%E9%A2%86%E8%A2%96%E8%8B%A5%E6%96%AF%E6%BD%98%E9%80%9D%E4%B8%96-%E4%BA%AB%E5%B9%B488%E5%B2%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774265470000.webp","sourceId":"rfi"},{"id":1774263268000,"createdDate":"2026-03-23 10:54","name":"法国国际广播电台","title":"「视频」纽约机场飞机与汽车相撞事故致两人死亡数十受伤","content":"美国时间22日晚间，纽约拉瓜迪亚机场发生飞机与地面车辆相撞事故。多家美国媒体报道称，飞机的正副驾驶员都在事故中丧生。ABC电视台还报道称另有13人受伤送医。其中11人为机上乘客，另外两人当时正在出事车辆中。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260323-%E8%A7%86%E9%A2%91-%E7%BA%BD%E7%BA%A6%E6%9C%BA%E5%9C%BA%E9%A3%9E%E6%9C%BA%E4%B8%8E%E6%B1%BD%E8%BD%A6%E7%9B%B8%E6%92%9E%E4%BA%8B%E6%95%85%E8%87%B4%E4%B8%A4%E4%BA%BA%E6%AD%BB%E4%BA%A1%E6%95%B0%E5%8D%81%E5%8F%97%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774263268000.webp","sourceId":"rfi"},{"id":1774262197000,"createdDate":"2026-03-23 10:36","name":"法国国际广播电台","title":"匈牙利涉向俄泄欧盟会议细节  波兰总理：早有怀疑","content":"波兰总理图斯克周一（3月23号）表示，对于《华盛顿邮报》报导匈牙利政府多年来向俄罗斯提供欧盟理事会会议详细资讯一事，波兰 “早就有所怀疑 ”。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260323-%E5%8C%88%E7%89%99%E5%88%A9%E6%B6%89%E5%90%91%E4%BF%84%E6%B3%84%E6%AC%A7%E7%9B%9F%E4%BC%9A%E8%AE%AE%E7%BB%86%E8%8A%82-%E6%B3%A2%E5%85%B0%E6%80%BB%E7%90%86-%E6%97%A9%E6%9C%89%E6%80%80%E7%96%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774262197000.webp","sourceId":"rfi"},{"id":1774257169000,"createdDate":"2026-03-23 09:12","name":"法国国际广播电台","title":"全球局势演变 AI世代到来，台湾总统松口提准备重启核电","content":"台湾总统赖清德提出重启核电，引发热议。在野党批评非核家园政策失败，但乐见其放下反核神主牌。专家表示，因应全球AI世代，台湾也必须确保能源供应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260323-%E5%85%A8%E7%90%83%E5%B1%80%E5%8A%BF%E6%BC%94%E5%8F%98-ai%E4%B8%96%E4%BB%A3%E5%88%B0%E6%9D%A5%EF%BC%8C%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E6%9D%BE%E5%8F%A3%E6%8F%90%E5%87%86%E5%A4%87%E9%87%8D%E5%90%AF%E6%A0%B8%E7%94%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774257169000.webp","sourceId":"rfi"},{"id":1774256949000,"createdDate":"2026-03-23 09:09","name":"法国国际广播电台","title":"日本官房长官否定美驻联合国大使有关日本自卫队将支援美国的言论","content":"围绕中东局势，美国驻联合国大使宣称日本首相高市“已承诺由自卫队提供支援”，对此，日本内阁官房长官木原稔23日予以否认，表示“并不存在作出具体承诺的事实”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260323-%E6%97%A5%E6%9C%AC%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E5%90%A6%E5%AE%9A%E7%BE%8E%E9%A9%BB%E8%81%94%E5%90%88%E5%9B%BD%E5%A4%A7%E4%BD%BF%E6%9C%89%E5%85%B3%E6%97%A5%E6%9C%AC%E8%87%AA%E5%8D%AB%E9%98%9F%E5%B0%86%E6%94%AF%E6%8F%B4%E7%BE%8E%E5%9B%BD%E7%9A%84%E8%A8%80%E8%AE%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/23/1774256949000.webp","sourceId":"rfi"}]