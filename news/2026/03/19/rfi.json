[{"id":1773908166000,"createdDate":"2026-03-19 08:16","name":"法国国际广播电台","title":"英荷四国在联合国呼吁释放邹幸彤及黎智英兼废国安法 港府续反对","content":"正受战火蹂躏的伊朗和早前被美国实施斩首行动的委内瑞拉，其人权状况是联合国人权理事会的关注重点，但香港人权收况亦受到英国和荷兰等四个国家的关注，四国代表在会上发言时，重申要求释放前支联会副主席邹幸彤丶停止对包括传媒大亨黎智英等人士的检控，又或废除备受批评的《港区国安法》。不过，香港副律政司张国钧反驳指，要求废除国安法是虚伪之举；重申要求释放罪犯，是与法治精神背道而驰。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260319-%E8%8B%B1%E8%8D%B7%E5%9B%9B%E5%9B%BD%E5%9C%A8%E8%81%94%E5%90%88%E5%9B%BD%E5%91%BC%E5%90%81%E9%87%8A%E6%94%BE%E9%82%B9%E5%B9%B8%E5%BD%A4%E5%8F%8A%E9%BB%8E%E6%99%BA%E8%8B%B1%E5%85%BC%E5%BA%9F%E5%9B%BD%E5%AE%89%E6%B3%95-%E6%B8%AF%E5%BA%9C%E7%BB%AD%E5%8F%8D%E5%AF%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773908166000.webp","sourceId":"rfi"},{"id":1773888333000,"createdDate":"2026-03-19 02:45","name":"法国国际广播电台","title":"Shein, Temu：对其小包裹征收 2 欧元税是否达到了预期目标？","content":"面对Shein,Temu的小包裹，法国实施征收2欧元税是否达到了预期目标呢？法国下令对来自非欧盟国家的小包裹征收2欧元的关税，导致来自中国的空运量急剧下降。然而，令法国机场十分沮丧的是，Shein和Temu等公司正将货物转运至邻国，然后再通过陆路运往法国。那么，这种征税2欧元的做法是徒劳的吗？","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260319-shein-temu-%E5%AF%B9%E5%85%B6%E5%B0%8F%E5%8C%85%E8%A3%B9%E5%BE%81%E6%94%B6-2-%E6%AC%A7%E5%85%83%E7%A8%8E%E6%98%AF%E5%90%A6%E8%BE%BE%E5%88%B0%E4%BA%86%E9%A2%84%E6%9C%9F%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773888333000.webp","sourceId":"rfi"},{"id":1773936334000,"createdDate":"2026-03-19 16:05","name":"法国国际广播电台","title":"曾任总装备部副部长 中国科学院官网撤下刘国治院士简历","content":"3月18日，查询中国科学院官网发现，中央军委科技委原主任、中国科学院院士刘国治的个人信息也被撤下，相关简介页面无法正常访问。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260319-%E6%9B%BE%E4%BB%BB%E6%80%BB%E8%A3%85%E5%A4%87%E9%83%A8%E5%89%AF%E9%83%A8%E9%95%BF-%E4%B8%AD%E5%9B%BD%E7%A7%91%E5%AD%A6%E9%99%A2%E6%92%A4%E4%B8%8B%E5%88%98%E5%9B%BD%E6%B2%BB%E9%99%A2%E5%A3%AB%E7%AE%80%E5%8E%86","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773936334000.webp","sourceId":"rfi"},{"id":1773933448000,"createdDate":"2026-03-19 15:17","name":"法国国际广播电台","title":"特朗普是否当面向高市要求日本护航受关注 英法德日等称愿参与适当努力","content":"美国总统特朗普（DonaldTrump）可能利用周四在白宫与日本首相高市早苗会晤的机会，敦促日方在伊朗战争中提供帮助。鉴于东京方面正权衡其能够提供多少支持，这可能会让高市陷入尴尬境地。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260319-%E7%89%B9%E6%9C%97%E6%99%AE%E6%98%AF%E5%90%A6%E5%BD%93%E9%9D%A2%E5%90%91%E9%AB%98%E5%B8%82%E8%A6%81%E6%B1%82%E6%97%A5%E6%9C%AC%E6%8A%A4%E8%88%AA%E5%8F%97%E5%85%B3%E6%B3%A8-%E8%8B%B1%E6%B3%95%E5%BE%B7%E6%97%A5%E7%AD%89%E7%A7%B0%E6%84%BF%E5%8F%82%E4%B8%8E%E9%80%82%E5%BD%93%E5%8A%AA%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773933448000.webp","sourceId":"rfi"},{"id":1773933157000,"createdDate":"2026-03-19 15:12","name":"法国国际广播电台","title":"欧洲联盟在伊朗战争阴影下的多重危机中召开领导人峰会","content":"欧洲联盟27国领导人19日在布鲁塞尔举行峰会。美国和以色列对伊朗的军事行动背景下全球能源价格飙升以及欧盟对乌克兰急需的援助款项因成员国匈牙利政府的坚持而难以到位无疑是这次峰会需要面对的两大难题，而伊朗战争下的中东危机也正考验欧洲在动荡的地缘政治关系重组中的自身定位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260319-%E6%AC%A7%E6%B4%B2%E8%81%94%E7%9B%9F%E5%9C%A8%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E9%98%B4%E5%BD%B1%E4%B8%8B%E7%9A%84%E5%A4%9A%E9%87%8D%E5%8D%B1%E6%9C%BA%E4%B8%AD%E5%B1%95%E5%BC%80%E9%A2%86%E5%AF%BC%E4%BA%BA%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773933157000.webp","sourceId":"rfi"},{"id":1773931252000,"createdDate":"2026-03-19 14:40","name":"法国国际广播电台","title":"伊朗袭击致卡塔尔17%的LNG产能瘫痪至多五年 中国等长期合同受影响","content":"卡塔尔能源公司（QatarEnergy）首席执行官卡比（Saadal-Kaabi）周四告诉路透社，伊朗的袭击导致卡塔尔17%的液化天然气（LNG）出口能力瘫痪，造成每年约200亿美元的收入损失，并威胁到对欧洲和亚洲的供应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260319-%E4%BC%8A%E6%9C%97%E8%A2%AD%E5%87%BB%E8%87%B4%E5%8D%A1%E5%A1%94%E5%B0%9417-%E7%9A%84lng%E4%BA%A7%E8%83%BD%E7%98%AB%E7%97%AA%E8%87%B3%E5%A4%9A%E4%BA%94%E5%B9%B4-%E4%B8%AD%E5%9B%BD%E7%AD%89%E9%95%BF%E6%9C%9F%E5%90%88%E5%90%8C%E5%8F%97%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773931252000.webp","sourceId":"rfi"},{"id":1773928106000,"createdDate":"2026-03-19 13:48","name":"法国国际广播电台","title":"黄仁勋：H200最快几周内进入中国市场 明年初推动允许对华销售Blackwell","content":"英伟达首席执行官黄仁勋周三向Punchbowl新闻网表示，这家人工智能巨头的H200芯片最早将在几周内进入中国市场。报导指，由于华盛顿和北京方面都对向中国销售这些芯片设置了障碍，英伟达不得不重启整个供应链，因此实际上市时间可能会稍长一些。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260319-%E9%BB%84%E4%BB%81%E5%8B%8B-h200%E6%9C%80%E5%BF%AB%E5%87%A0%E5%91%A8%E5%86%85%E8%BF%9B%E5%85%A5%E4%B8%AD%E5%9B%BD%E5%B8%82%E5%9C%BA-%E6%98%8E%E5%B9%B4%E5%88%9D%E6%8E%A8%E5%8A%A8%E5%85%81%E8%AE%B8%E5%AF%B9%E5%8D%8E%E9%94%80%E5%94%AEblackwell","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773928106000.webp","sourceId":"rfi"},{"id":1773924364000,"createdDate":"2026-03-19 12:46","name":"法国国际广播电台","title":"阿尔及利亚扩大天然气出口欧洲","content":"中东战争导致“对阿尔及利亚天然气的需求加速增长”。这是本台法广非洲组（RFIAfrique）今天（2026年3月19号星期四）的最新法文消息之一。北非国家阿尔及利亚迅速做出反应，增加对欧洲的天然气出口。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260319-%E6%B3%95%E5%B9%BFrfi-%E9%9D%9E%E6%B4%B2-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%98%BF%E5%B0%94%E5%8F%8A%E5%88%A9%E4%BA%9A%E6%89%A9%E5%A4%A7%E5%A4%A9%E7%84%B6%E6%B0%94%E5%87%BA%E5%8F%A3%E6%AC%A7%E6%B4%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773924364000.webp","sourceId":"rfi"},{"id":1773924178000,"createdDate":"2026-03-19 12:42","name":"法国国际广播电台","title":"美能源部副部长：中国“显然”在进行爆炸性核试验","content":"美国能源部负责核安全的副部长威廉姆斯（BrandonWilliams）在华盛顿举行的戈维尼（Govini）防务会议上向Axios新闻网表示，中国“显然”正在进行爆炸性核试验，并且“试图将其掩盖”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260319-%E7%BE%8E%E5%9B%BD%E8%83%BD%E6%BA%90%E9%83%A8%E5%89%AF%E9%83%A8%E9%95%BF-%E4%B8%AD%E5%9B%BD-%E6%98%BE%E7%84%B6-%E5%9C%A8%E8%BF%9B%E8%A1%8C%E7%88%86%E7%82%B8%E6%80%A7%E6%A0%B8%E8%AF%95%E9%AA%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773924178000.webp","sourceId":"rfi"},{"id":1773921776000,"createdDate":"2026-03-19 12:02","name":"法国国际广播电台","title":"泰国保守派政党领袖阿努廷再度当选政府总理","content":"泰国今年2月大选后产生的新议会19日投票推举政府总理。在立法选举中胜出的民族主义保守派政党自豪党领袖阿努廷再度当选。泰柬边境的紧张关系以及泰国经济增长乏力仍将是阿努廷新政府必须面对的挑战。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260319-%E6%B3%B0%E5%9B%BD%E4%BF%9D%E5%AE%88%E6%B4%BE%E6%94%BF%E5%85%9A%E9%A2%86%E8%A2%96%E9%98%BF%E5%8A%AA%E5%BB%B7%E5%86%8D%E5%BA%A6%E5%BD%93%E9%80%89%E6%94%BF%E5%BA%9C%E6%80%BB%E7%90%86","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773921776000.webp","sourceId":"rfi"},{"id":1773921267000,"createdDate":"2026-03-19 11:54","name":"法国国际广播电台","title":"中方对以防长称军队可击杀任何伊朗官员表震惊 指不可接受","content":"就以色列近日接连击杀伊朗最高国家安全委员会秘书拉里贾尼、巴斯基民兵组织指挥官格拉姆雷扎·苏莱曼尼、伊朗情报部长哈提卜等高官一事，中国外交部发言人林剑在周四的例行记者会上应询时表示，中方“一贯反对在国际关系中使用武力，杀害伊朗国家领导人和攻击平民目标的行径更不可接受”，并指“中方敦促当事方立即停止军事行动，防止将地区局势推向不可收拾的地步”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260319-%E4%B8%AD%E6%96%B9%E5%AF%B9%E4%BB%A5%E9%98%B2%E9%95%BF%E7%A7%B0%E5%86%9B%E9%98%9F%E5%8F%AF%E5%87%BB%E6%9D%80%E4%BB%BB%E4%BD%95%E4%BC%8A%E6%9C%97%E5%AE%98%E5%91%98%E8%A1%A8%E9%9C%87%E6%83%8A-%E4%BF%83%E5%81%9C%E7%81%AB%E6%AD%A2%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773921267000.webp","sourceId":"rfi"},{"id":1773916962000,"createdDate":"2026-03-19 10:42","name":"法国国际广播电台","title":"美国情报部门:中国暂时无意在2027年入侵台湾","content":"美国情报部门评估认为，中国暂无计划在2027年入侵台湾。且寻求在不诉诸武力的情况下控制台湾。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260319-%E7%BE%8E%E5%9B%BD%E6%83%85%E6%8A%A5%E9%83%A8%E9%97%A8-%E4%B8%AD%E5%9B%BD%E6%9A%82%E6%97%B6%E6%97%A0%E6%84%8F%E5%9C%A82027%E5%B9%B4%E5%85%A5%E4%BE%B5%E5%8F%B0%E6%B9%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773916962000.webp","sourceId":"rfi"},{"id":1773915750000,"createdDate":"2026-03-19 10:22","name":"法国国际广播电台","title":"Shein第三方卖家平台不会被暂停运营 政府上诉遭巴黎上诉法院驳回","content":"巴黎上诉法院周四裁定，并未像法国政府要求的那样暂停Shein第三方卖家市场平台——SheinMarketplace的运营。其销售来自Shein亚洲合作伙伴的产品。此前，法国政府发现该平台出现非法产品，包括儿童色情玩偶等，相关产品已被下架。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260319-shein%E7%AC%AC%E4%B8%89%E6%96%B9%E5%8D%96%E5%AE%B6%E5%B9%B3%E5%8F%B0%E4%B8%8D%E4%BC%9A%E8%A2%AB%E6%9A%82%E5%81%9C%E8%BF%90%E8%90%A5-%E6%94%BF%E5%BA%9C%E4%B8%8A%E8%AF%89%E9%81%AD%E5%B7%B4%E9%BB%8E%E4%B8%8A%E8%AF%89%E6%B3%95%E9%99%A2%E9%A9%B3%E5%9B%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773915750000.webp","sourceId":"rfi"},{"id":1773914563000,"createdDate":"2026-03-19 10:02","name":"法国国际广播电台","title":"国台办称统一台湾能源资源保障会更好 台官员指认知作战","content":"中国国务院台办发言人陈斌华在周三的记者会上宣称，“和平统一后，两岸将实现互联互通、应通尽通，完全可以弥补台湾在电力、天然气、原油等方面的短缺”。对此，台湾经济部次长何晋沧周四答询立委时则回应称，这属于认知作战一部分，台湾在能源方面已做足准备，有安全存量，也有因应做法，一定会确保能源供应无虞。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260319-%E5%9B%BD%E5%8F%B0%E5%8A%9E%E7%A7%B0%E7%BB%9F%E4%B8%80%E5%8F%B0%E6%B9%BE%E8%83%BD%E6%BA%90%E8%B5%84%E6%BA%90%E4%BF%9D%E9%9A%9C%E4%BC%9A%E6%9B%B4%E5%A5%BD-%E5%8F%B0%E5%AE%98%E5%91%98%E6%8C%87%E8%AE%A4%E7%9F%A5%E4%BD%9C%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773914563000.webp","sourceId":"rfi"},{"id":1773912664000,"createdDate":"2026-03-19 09:31","name":"法国国际广播电台","title":"尼泊尔调查《习近平谈治国理政》在一大学焚书被烧事件","content":"尼泊尔官员周四表示，在该国东部一所大学发生焚烧中国国家主席习近平著作的部分书籍事件后，当局正在对此展开调查。此前，中国驻尼泊尔大使馆已就此事表示关切。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260319-%E5%B0%BC%E6%B3%8A%E5%B0%94%E8%B0%83%E6%9F%A5-%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%B0%88%E6%B2%BB%E5%9B%BD%E7%90%86%E6%94%BF-%E5%9C%A8%E4%B8%80%E5%A4%A7%E5%AD%A6%E7%84%9A%E4%B9%A6%E8%A2%AB%E7%83%A7%E4%BA%8B%E4%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773912664000.webp","sourceId":"rfi"},{"id":1773911473000,"createdDate":"2026-03-19 09:11","name":"法国国际广播电台","title":"伊朗袭击海湾多国能源设施 特朗普促收手威胁炸毁整个南帕尔斯气田","content":"美国总统特朗普（DonaldTrump）最新表示，愤怒的以色列已“猛烈痛击”并袭击了伊朗的主要气田，这标志着这场冲突显著升级，但特朗普表态称，除非伊朗进行报复，否则以色列不会再发动此类袭击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260319-%E4%BC%8A%E6%9C%97%E6%8A%A5%E5%A4%8D%E8%A2%AD%E5%87%BB%E6%B5%B7%E6%B9%BE%E5%A4%9A%E5%9B%BD%E8%83%BD%E6%BA%90%E8%AE%BE%E6%96%BD-%E7%89%B9%E6%9C%97%E6%99%AE%E4%BF%83%E6%94%B6%E6%89%8B%E5%A8%81%E8%83%81%E7%82%B8%E6%AF%81%E6%95%B4%E4%B8%AA%E5%8D%97%E5%B8%95%E5%B0%94%E6%96%AF%E6%B0%94%E7%94%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773911473000.webp","sourceId":"rfi"},{"id":1773911047000,"createdDate":"2026-03-19 09:04","name":"法国国际广播电台","title":"路透社报导中国加强拉拢巴拉圭促外交转向 台学者：转向中国可能性不大","content":"中国过去一年赞助巴拉圭政界人士访中更提供奢侈赠品，希望说服其背离长期盟友台湾。台学者：中方作法还不足以在未来两年内改变台巴邦交关系，另外特朗普联合拉美抗中，巴拉圭弃台可能性不大。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260319-%E8%B7%AF%E9%80%8F%E7%A4%BE%E6%8A%A5%E5%AF%BC%E4%B8%AD%E5%9B%BD%E5%8A%A0%E5%BC%BA%E6%8B%89%E6%8B%A2%E5%B7%B4%E6%8B%89%E5%9C%AD%E4%BF%83%E5%A4%96%E4%BA%A4%E8%BD%AC%E5%90%91-%E5%8F%B0%E5%AD%A6%E8%80%85-%E8%BD%AC%E5%90%91%E4%B8%AD%E5%9B%BD%E5%8F%AF%E8%83%BD%E6%80%A7%E4%B8%8D%E5%A4%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773911047000.webp","sourceId":"rfi"},{"id":1773910485000,"createdDate":"2026-03-19 08:54","name":"法国国际广播电台","title":"日本否定美国将高市“台湾有事”发言定位为“重大政策转变”","content":"日本内阁官房长官木原稔在19日的记者会上，对美国情报总监办公室发布《2026年度威胁评估》将首相高市早苗围绕“台湾有事”的发言分析为“重大政策转变”表示了否认态度，称“这一说法并不准确”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260319-%E6%97%A5%E6%9C%AC%E5%90%A6%E5%AE%9A%E7%BE%8E%E5%9B%BD%E5%B0%86%E9%AB%98%E5%B8%82-%E5%8F%B0%E6%B9%BE%E6%9C%89%E4%BA%8B-%E5%8F%91%E8%A8%80%E5%AE%9A%E4%BD%8D%E4%B8%BA-%E9%87%8D%E5%A4%A7%E6%94%BF%E7%AD%96%E8%BD%AC%E5%8F%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/19/1773910485000.webp","sourceId":"rfi"}]