[{"id":1772467720000,"createdDate":"2026-03-02 16:08","name":"法国国际广播电台","title":"马克龙：将加强核武库，并让欧洲盟友参与核战略革新","content":"路透社巴黎消息，法国总统马克龙周一（3月2日）表示，随着全球冲突跨越核门槛的风险日益增加，法国将扩大其核武库规模并加强其威慑力。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260302-%E9%A9%AC%E5%85%8B%E9%BE%99-%E5%B0%86%E5%8A%A0%E5%BC%BA%E6%A0%B8%E6%AD%A6%E5%BA%93%EF%BC%8C%E5%B9%B6%E8%AE%A9%E6%AC%A7%E6%B4%B2%E7%9B%9F%E5%8F%8B%E5%8F%82%E4%B8%8E%E6%A0%B8%E6%88%98%E7%95%A5%E9%9D%A9%E6%96%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772467720000.webp","sourceId":"rfi"},{"id":1772466646000,"createdDate":"2026-03-02 15:50","name":"法国国际广播电台","title":"不同于英国，西班牙拒为美以两国提供军事基地攻打伊朗","content":"路透社马德里消息，西班牙外交部长阿尔瓦雷斯（JoseManuelAlbares）周一表明，西班牙不会允许境内军事基地被用于对伊朗发动攻击。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260302-%E4%B8%8D%E5%90%8C%E4%BA%8E%E8%8B%B1%E5%9B%BD%EF%BC%8C%E8%A5%BF%E7%8F%AD%E7%89%99%E6%8B%92%E4%B8%BA%E7%BE%8E%E4%BB%A5%E4%B8%A4%E5%9B%BD%E6%8F%90%E4%BE%9B%E5%86%9B%E4%BA%8B%E5%9F%BA%E5%9C%B0%E6%94%BB%E6%89%93%E4%BC%8A%E6%9C%97","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772466646000.webp","sourceId":"rfi"},{"id":1772464423000,"createdDate":"2026-03-02 15:13","name":"法国国际广播电台","title":"分析：核心高层多遭击杀 伊朗政权何以维持 快速反击？","content":"美以打击伊朗，尽管包括最高精神领袖哈梅内伊在内多名高层核心官员在轰炸最初即遭“斩首式”击杀，但伊朗仍能对以色列和位于邻国的美国军事基地发射一轮轮导弹，其回应速度甚至快于去年六月“以伊12日战争”时，德黑兰何以在高层遭重创下维持其政权、作出快速回应？","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260302-%E5%88%86%E6%9E%90-%E6%A0%B8%E5%BF%83%E9%AB%98%E5%B1%82%E5%A4%9A%E9%81%AD%E5%87%BB%E6%9D%80-%E4%BC%8A%E6%9C%97%E6%94%BF%E6%9D%83%E4%BD%95%E4%BB%A5%E7%BB%B4%E6%8C%81-%E5%BF%AB%E9%80%9F%E5%8F%8D%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772464423000.webp","sourceId":"rfi"},{"id":1772463388000,"createdDate":"2026-03-02 14:56","name":"法国国际广播电台","title":"中东战火 扰乱全球航空交通","content":"自美以针对伊朗开始军事行动，德黑兰回应以来，中东多座主要机场持续关闭，导致数十万旅客今天周一滞留在世界各地，严重影响了该地区具有全球影响力的主要航空公司运营。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260302-%E4%B8%AD%E4%B8%9C%E6%88%98%E7%81%AB-%E6%89%B0%E4%B9%B1%E5%85%A8%E7%90%83%E8%88%AA%E7%A9%BA%E4%BA%A4%E9%80%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772463388000.webp","sourceId":"rfi"},{"id":1772462204000,"createdDate":"2026-03-02 14:36","name":"法国国际广播电台","title":"印度洋查戈斯群岛出现主权争端","content":"随着南亚岛国马尔代夫（lesMaldives）对印度洋中的查戈斯群岛（l'archipeldeChagos）的归属提出主权要求，非洲岛国毛里求斯（Maurice）能否从英国手中顺利接管这片领土和领海出现节外生枝。路易港（portlouis）方面于三天前上星期五做出紧急反应，宣布立即中断和马累（Malé）当局之间的外交关系。毛里求斯副总理和外长两人先后分别就与马尔代夫（lesMaldives）之间的关系现状进行了公开说明。非洲岛国毛里求斯（Maurice）的国名，中文也有译作模里西斯共和國（RepublicofMauritius）。亚洲岛国马尔代夫（lesMaldives）的中文国名也有译作馬爾地夫（RepublicofMaldives,）。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260302-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%8D%B0%E5%BA%A6%E6%B4%8B%E6%9F%A5%E6%88%88%E6%96%AF%E7%BE%A4%E5%B2%9B%E5%87%BA%E7%8E%B0%E4%B8%BB%E6%9D%83%E4%BA%89%E7%AB%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772462204000.webp","sourceId":"rfi"},{"id":1772457340000,"createdDate":"2026-03-02 13:15","name":"法国国际广播电台","title":"美以空袭前《纽约时报》指“伊朗版Delcy”人选 拉里贾尼受关注 《经济学人》称伊朗恐走向民兵割據","content":"美国以色列联合轰炸伊朗，惊人地一举击杀自1989年掌权至今的最高领袖哈梅内伊（AliKhamenei）。虽然此等“斩首”行动成功之前，人们还未敢确定特朗普的开战目标是跟以色列一贯主张的“政权更迭”，但在哈梅内伊确定死亡之后，大家都将特朗普的战争目标解读为“政权更迭”。对此《纽约时报》曾于2月22日刊登的一篇有关伊朗备战准备的报道中，有3名资深伊朗官员向该报提到了三个“伊朗版Delcy Rodriguez”的潜在人选名单。英媒《经济学人》则警告，美国政府若想强推政权更迭，显然低估了伊朗政治的复杂程度。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260302-%E7%BE%8E%E4%BB%A5%E7%A9%BA%E8%A2%AD%E5%89%8D-%E7%BA%BD%E6%97%B6%E6%8C%87-%E4%BC%8A%E6%9C%97%E7%89%88delcy-%E6%8B%89%E9%87%8C%E8%B4%BE%E5%B0%BC%E5%8F%97%E5%85%B3%E6%B3%A8-%E7%BB%8F%E6%B5%8E%E5%AD%A6%E4%BA%BA-%E7%A7%B0%E4%BC%8A%E6%9C%97%E6%81%90%E8%B5%B0%E5%90%91%E6%B0%91%E5%85%B5%E5%89%B2%E6%93%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772457340000.webp","sourceId":"rfi"},{"id":1772455240000,"createdDate":"2026-03-02 12:40","name":"法国国际广播电台","title":"特朗普：有三个“非常好”的人选可为伊朗新领导人","content":"美国总统特朗普星期天（3月1日）接受《纽约时报》访问时暗示，“我有三个非常好的人选……我现在不会透露他们是谁，先把事情办成再说。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260302-%E7%89%B9%E6%9C%97%E6%99%AE-%E6%9C%89%E4%B8%89%E4%B8%AA-%E9%9D%9E%E5%B8%B8%E5%A5%BD-%E7%9A%84%E4%BA%BA%E9%80%89%E5%8F%AF%E4%B8%BA%E4%BC%8A%E6%9C%97%E6%96%B0%E9%A2%86%E5%AF%BC%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772455240000.webp","sourceId":"rfi"},{"id":1772454682000,"createdDate":"2026-03-02 12:31","name":"法国国际广播电台","title":"促进贸易：莫迪会晤到访的卡尼","content":"加拿大总理卡尼周一与印度总理莫迪会晤，希望促进贸易多元化并改善紧张的双边关系。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260302-%E4%BF%83%E8%BF%9B%E8%B4%B8%E6%98%93-%E8%8E%AB%E8%BF%AA%E4%BC%9A%E6%99%A4%E5%88%B0%E8%AE%BF%E7%9A%84%E5%8D%A1%E5%B0%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772454682000.webp","sourceId":"rfi"},{"id":1772454095000,"createdDate":"2026-03-02 12:21","name":"法国国际广播电台","title":"中东战火蔓延黎巴嫩：黎巴嫩真主党入局、以色列反击升级真主党情报首长已死","content":"据本台法语部报道，在避开了于2月28日（周六）爆发的“美以对伊战争”两天后，黎巴嫩最终在3月2日周一凌晨被卷入了冲突。在真主党声称对以色列北部发动火箭弹袭击后，以色列军队对黎巴嫩多个地区发动了大规模空袭。据悉，这一黎巴嫩什叶派组织此举是为了报复伊朗最高领袖阿里·哈梅内伊（AliKhamenei）被杀。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260302-%E4%B8%AD%E4%B8%9C%E6%88%98%E7%81%AB%E8%94%93%E5%BB%B6%E9%BB%8E%E5%B7%B4%E5%AB%A9-%E9%BB%8E%E5%B7%B4%E5%AB%A9%E7%9C%9F%E4%B8%BB%E5%85%9A%E5%85%A5%E5%B1%80-%E4%BB%A5%E8%89%B2%E5%88%97%E5%8F%8D%E5%87%BB%E5%8D%87%E7%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772454095000.webp","sourceId":"rfi"},{"id":1772452483000,"createdDate":"2026-03-02 11:54","name":"法国国际广播电台","title":"因应中东战火，卓荣泰指示稳定物价、启动能源应变小组","content":"以联手袭击伊朗后，中东战火持续升温，也冲击油价涨幅。台湾行政院长卓荣泰周一（3月2日）取消临时行程，邀集四部会开会，提出启动应变措施，协调能源供应和稳定物价。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260302-%E5%9B%A0%E5%BA%94%E4%B8%AD%E4%B8%9C%E6%88%98%E7%81%AB%EF%BC%8C%E5%8D%93%E8%8D%A3%E6%B3%B0%E6%8C%87%E7%A4%BA%E7%A8%B3%E5%AE%9A%E7%89%A9%E4%BB%B7-%E5%90%AF%E5%8A%A8%E8%83%BD%E6%BA%90%E5%BA%94%E5%8F%98%E5%B0%8F%E7%BB%84","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772452483000.webp","sourceId":"rfi"},{"id":1772450184000,"createdDate":"2026-03-02 11:16","name":"法国国际广播电台","title":"【视频】冲突急剧升级 特朗普称打击伊朗行动或将持续四周","content":"中东局势正急剧升级，在美以轰炸伊朗的第三天，德黑兰多处目标继续遭到空袭，据伊朗方面表示，伊朗国家电视台、警察局和一家医院在周日当天和夜间被袭。作为回应，伊朗对色列本土发动新一轮导弹攻击，并打击美军在中东地区的基地，阿布扎比、沙特和阿曼均传出发生爆炸，其中阿曼境内是首次受到类似攻击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260302-%E8%A7%86%E9%A2%91-%E5%86%B2%E7%AA%81%E6%80%A5%E5%89%A7%E5%8D%87%E7%BA%A7-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E6%89%93%E5%87%BB%E4%BC%8A%E6%9C%97%E8%A1%8C%E5%8A%A8%E6%88%96%E6%8C%81%E7%BB%AD%E5%9B%9B%E5%91%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772450184000.webp","sourceId":"rfi"},{"id":1772446756000,"createdDate":"2026-03-02 10:19","name":"法国国际广播电台","title":"霍尔木兹海峡邮轮遭袭，若被封专家：伊朗“无异拿石头砸自己的脚”","content":"自霍尔木兹海峡附近遭袭后，这条关键水道几乎陷入停滞，数十艘满载原油的油轮滞留在波斯湾内观望局势。区域物流受扰，出口随之放缓，短期产量面临威胁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260302-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%82%AE%E8%BD%AE%E9%81%AD%E8%A2%AD%EF%BC%8C%E8%8B%A5%E8%A2%AB%E5%B0%81%E4%B8%93%E5%AE%B6-%E4%BC%8A%E6%9C%97-%E6%97%A0%E5%BC%82%E6%8B%BF%E7%9F%B3%E5%A4%B4%E7%A0%B8%E8%87%AA%E5%B7%B1%E7%9A%84%E8%84%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772446756000.webp","sourceId":"rfi"},{"id":1772445303000,"createdDate":"2026-03-02 09:55","name":"法国国际广播电台","title":"1986年来首次！英军塞浦路斯基地遭无人机袭击","content":"据路透社报道，一架无人机周一（3月2日）凌晨袭击了英国皇家空军位于塞浦路斯阿克罗蒂里的基地，造成轻微损毁，无人员伤亡。塞浦路斯总统和英国国防部证实了这一消息。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260302-1986%E5%B9%B4%E6%9D%A5%E9%A6%96%E6%AC%A1-%E8%8B%B1%E5%86%9B%E5%A1%9E%E6%B5%A6%E8%B7%AF%E6%96%AF%E5%9F%BA%E5%9C%B0%E9%81%AD%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772445303000.webp","sourceId":"rfi"},{"id":1772443706000,"createdDate":"2026-03-02 09:28","name":"法国国际广播电台","title":"中国马年“两会”：你需要知道什么？","content":"法新社北京3月2日电稿称，本周，来自中国各地的数千名代表齐聚北京，参加被称为“两会”的年度立法周期。在这场年度政治盛会上，中国领导人将在全球和国内重重挑战中，阐明这个世界第二大经济体的发展航向。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260302-%E4%B8%AD%E5%9B%BD%E9%A9%AC%E5%B9%B4-%E4%B8%A4%E4%BC%9A-%E4%BD%A0%E9%9C%80%E8%A6%81%E7%9F%A5%E9%81%93%E4%BB%80%E4%B9%88","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772443706000.webp","sourceId":"rfi"},{"id":1772443172000,"createdDate":"2026-03-02 09:19","name":"法国国际广播电台","title":"一中国公民在伊朗遇难 北京再呼吁中东地区停火并回归外交途径","content":"一名中国公民在德黑兰遇害后，中国周一（3月2号）再次紧急呼吁中东地区停火并恢复外交途径。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260302-%E4%B8%80%E4%B8%AD%E5%9B%BD%E5%85%AC%E6%B0%91%E5%9C%A8%E4%BC%8A%E6%9C%97%E9%81%87%E9%9A%BE-%E5%8C%97%E4%BA%AC%E5%86%8D%E5%91%BC%E5%90%81%E4%B8%AD%E4%B8%9C%E5%9C%B0%E5%8C%BA%E5%81%9C%E7%81%AB%E5%B9%B6%E5%9B%9E%E5%BD%92%E5%A4%96%E4%BA%A4%E9%80%94%E5%BE%84","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772443172000.webp","sourceId":"rfi"},{"id":1772443132000,"createdDate":"2026-03-02 09:18","name":"法国国际广播电台","title":"特朗普：不达目标不停战计划续攻“四到五周” 德黑兰：何时停战由伊方决定","content":"美国总统特朗普星期天3月1日发表视频讲话称，美国和以色列将继续对伊朗的军事行动，直到达成所有目标。特朗普在接受《纽约时报》采访时说，美国打算继续攻打伊朗“四到五周时间”。伊朗外交部长阿拉格齐亦在当天回应，伊朗将决定这场美以强加的侵略战争何时以及如何结束。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260302-%E7%89%B9%E6%9C%97%E6%99%AE-%E4%B8%8D%E8%BE%BE%E7%9B%AE%E6%A0%87%E4%B8%8D%E5%81%9C%E6%88%98%E8%AE%A1%E5%88%92%E7%BB%AD%E6%94%BB-%E5%9B%9B%E5%88%B0%E4%BA%94%E5%91%A8-%E5%BE%B7%E9%BB%91%E5%85%B0-%E4%BD%95%E6%97%B6%E5%81%9C%E6%88%98%E7%94%B1%E4%BC%8A%E6%96%B9%E5%86%B3%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772443132000.webp","sourceId":"rfi"},{"id":1772441478000,"createdDate":"2026-03-02 08:51","name":"法国国际广播电台","title":"伊朗报复空袭：科威特称数架美军战机坠毁境内，机组人员生还","content":"法新社科威特消息，伊朗报复美国与以色列空袭、对波湾多个地区展开攻击之际，科威特国防部周一（3月2日）表示，数架美军战机今晨坠毁科威特境内，所幸机组人员全数生还。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260302-%E4%BC%8A%E6%9C%97%E6%8A%A5%E5%A4%8D%E7%A9%BA%E8%A2%AD-%E7%A7%91%E5%A8%81%E7%89%B9%E7%A7%B0%E6%95%B0%E6%9E%B6%E7%BE%8E%E5%86%9B%E6%88%98%E6%9C%BA%E5%9D%A0%E6%AF%81%E5%A2%83%E5%86%85%EF%BC%8C%E6%9C%BA%E7%BB%84%E4%BA%BA%E5%91%98%E7%94%9F%E8%BF%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772441478000.webp","sourceId":"rfi"},{"id":1772440248000,"createdDate":"2026-03-02 08:30","name":"法国国际广播电台","title":"日本担心原油断供 首相披露石油储备存量","content":"美以对伊朗展开攻击后，日本众议院预算委员会2日上午举行会议，高市早苗首相与全体阁僚出席，就2026年度预算案进行了第二天的基本质询。针对有信息称霍尔木兹海峡已被封锁一事，首相表示“正在就事实关系进行信息收集”，并称已确认周边海域的日本船舶船员全部安全。此外，她说明日本的石油储备“目前有254天份”。外相茂木敏充强调：“如果事态长期化，将密切关注对能源供应及国内价格的影响。”日本担心进口原油超过九成依赖中东的日本石油来源断供。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260302-%E6%97%A5%E6%9C%AC%E6%8B%85%E5%BF%83%E5%8E%9F%E6%B2%B9%E6%96%AD%E4%BE%9B-%E9%A6%96%E7%9B%B8%E6%8A%AB%E9%9C%B2%E7%9F%B3%E6%B2%B9%E5%82%A8%E5%A4%87%E5%AD%98%E9%87%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772440248000.webp","sourceId":"rfi"},{"id":1772439539000,"createdDate":"2026-03-02 08:18","name":"法国国际广播电台","title":"伊朗受袭 亚洲股市几乎全跌 港股受累大 惟港官称香港终将受惠「安全港」","content":"在美国和以色列侵袭伊朗丶美国总统特朗普表明，消灭拥有核武恐怖政权的行动，会持续至达成所有目标为止，更预告战事可能持续多四星期後，中东局势不稳定性持续，亚洲33个股市板块中，只有四个微升，其馀均出现0.1%至3.38%的跌幅，当中包括香港。不过，香港财政司司长陈茂波估计，伊朗受袭虽会令金融市场反应巨大，以致出现波动，但相信香港仍会是「安全港」，亦不会影响香港开拓中东市场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260302-%E4%BC%8A%E6%9C%97%E5%8F%97%E8%A2%AD-%E4%BA%9A%E6%B4%B2%E8%82%A1%E5%B8%82%E5%87%A0%E4%B9%8E%E5%85%A8%E8%B7%8C-%E6%B8%AF%E8%82%A1%E5%8F%97%E7%B4%AF%E5%A4%A7-%E6%83%9F%E6%B8%AF%E5%AE%98%E7%A7%B0%E9%A6%99%E6%B8%AF%E7%BB%88%E5%B0%86%E5%8F%97%E6%83%A0-%E5%AE%89%E5%85%A8%E6%B8%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772439539000.webp","sourceId":"rfi"},{"id":1772495958000,"createdDate":"2026-03-02 23:59","name":"法国国际广播电台","title":"伊朗战争：中国再次给人“行动太少、反应太晚”的印象","content":"法国世界报周一表示，中国是伊朗政权的支持者，中国也是伊朗石油的最大买家，在美国和以色列对伊朗发动袭击后，中国表达了愤怒，中国外交部长王毅3月1日（星期日）表示，在谈判正进行的时候对伊朗发动攻击是“不可接受”的。王毅还说，“更不能通过暗杀一个主权国家的领导人来推动政权更迭”。但是，中国再次给人“行动太少、反应太晚”的印象。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260302-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89-%E4%B8%AD%E5%9B%BD%E5%86%8D%E6%AC%A1%E7%BB%99%E4%BA%BA-%E8%A1%8C%E5%8A%A8%E5%A4%AA%E5%B0%91-%E5%8F%8D%E5%BA%94%E5%A4%AA%E6%99%9A-%E7%9A%84%E5%8D%B0%E8%B1%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772495958000.webp","sourceId":"rfi"},{"id":1772494092000,"createdDate":"2026-03-02 23:28","name":"法国国际广播电台","title":"法国核威慑战略重大变革 增加核弹头数量  向欧洲开放","content":"法国总统马克龙周一宣布增加核弹头扩大法国核武库，但不再公布数量。并提出一项由八个欧洲国家参与但“不共享最终决策权”的“前沿威慑”计划。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260302-%E6%B3%95%E5%9B%BD%E6%A0%B8%E5%A8%81%E6%85%91%E6%88%98%E7%95%A5%E9%87%8D%E5%A4%A7%E5%8F%98%E9%9D%A9-%E5%A2%9E%E5%8A%A0%E6%A0%B8%E5%BC%B9%E5%A4%B4%E6%95%B0%E9%87%8F-%E5%90%91%E6%AC%A7%E6%B4%B2%E5%BC%80%E6%94%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772494092000.webp","sourceId":"rfi"},{"id":1772492254000,"createdDate":"2026-03-02 22:57","name":"法国国际广播电台","title":"暴君死了 伊朗政体依旧在顽抗","content":"美以发动的伊朗战争瞬息万变，首日，当统治伊朗长达37年的精神领袖哈梅内伊被“斩首”，欢呼“哈梅内伊之死为伊朗历史翻开了新的一页 ”大有人在，次日，当绝地求生的伊斯兰政权把炸弹投向吸引全球金融精英的迪拜，一场将给全球带来深刻影响的大混乱爆发了。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260302-%E6%9A%B4%E5%90%9B%E6%AD%BB%E4%BA%86-%E4%BC%8A%E6%9C%97%E6%94%BF%E4%BD%93%E4%BE%9D%E6%97%A7%E5%9C%A8%E9%A1%BD%E6%8A%97","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772492254000.webp","sourceId":"rfi"},{"id":1772490775000,"createdDate":"2026-03-02 22:32","name":"法国国际广播电台","title":"特朗普不排除对伊朗派遣地面部队　称美军伤亡恐将增加","content":"美国总统唐特朗普（DonaldTrump）周一明确表示，不排除在必要时向伊朗派遣地面部队，强调美以联合展开的“史诗之怒行动”（OperationEpicFury）进展“远远超前”，已在首日击毙49名伊朗高层领导人，包括最高领袖哈梅内伊（AliKhamenei）。他直言，若战局需要，将动用地面兵力，并警告冲突可能持续数周甚至更久，同时坦承美军伤亡恐将增加。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260302-%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%8D%E6%8E%92%E9%99%A4%E5%AF%B9%E4%BC%8A%E6%9C%97%E6%B4%BE%E9%81%A3%E5%9C%B0%E9%9D%A2%E9%83%A8%E9%98%9F-%E7%A7%B0%E7%BE%8E%E5%86%9B%E4%BC%A4%E4%BA%A1%E6%81%90%E5%B0%86%E5%A2%9E%E5%8A%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772490775000.webp","sourceId":"rfi"},{"id":1772490149000,"createdDate":"2026-03-02 22:22","name":"法国国际广播电台","title":"中国呼吁海湾国家\"团结抵抗外部干预\"　一名中国公民在德黑兰遇难","content":"在美以对伊朗发动打击并引发地区冲突持续扩大的背景下，中国外交部长王毅周一(3月2日）呼吁海湾国家\"加强团结，共同反对外部干预\"。一名中国公民在德黑兰遇难。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260302-%E4%B8%AD%E5%9B%BD%E5%91%BC%E5%90%81%E6%B5%B7%E6%B9%BE%E5%9B%BD%E5%AE%B6-%E5%9B%A2%E7%BB%93%E6%8A%B5%E6%8A%97%E5%A4%96%E9%83%A8%E5%B9%B2%E9%A2%84-%E4%B8%80%E5%90%8D%E4%B8%AD%E5%9B%BD%E5%85%AC%E6%B0%91%E5%9C%A8%E5%BE%B7%E9%BB%91%E5%85%B0%E9%81%87%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772490149000.webp","sourceId":"rfi"},{"id":1772489821000,"createdDate":"2026-03-02 22:17","name":"法国国际广播电台","title":"中东冲突升温之际 默茨启程赴美会晤特朗普","content":"德国总理默茨周一（3月2日）启程前往华盛顿，将于周二会晤美国总统特朗普，成为中东战争爆发以来首位与特朗普面对面会谈的欧洲领导人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260302-%E4%B8%AD%E4%B8%9C%E5%86%B2%E7%AA%81%E5%8D%87%E6%B8%A9-%E9%BB%98%E8%8C%A8%E5%90%AF%E7%A8%8B%E8%B5%B4%E7%BE%8E%E4%BC%9A%E6%99%A4%E7%89%B9%E6%9C%97%E6%99%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772489821000.webp","sourceId":"rfi"},{"id":1772489758000,"createdDate":"2026-03-02 22:15","name":"法国国际广播电台","title":"英国保证，其在塞浦路斯的基地不会被美国用于对伊朗采取行动","content":"英国首相斯塔默周一表示，不会让美国利用英国在塞浦路斯的军事基地对伊朗采取行动。此前，在周日深夜至周一凌晨，英国在塞浦路斯的阿克罗蒂里空军基地遭到伊朗无人机的袭击，这是自此次中东战争爆发以来，首次有欧盟国家的领土遭到波及。塞浦路斯政府对此表示强烈关切，并称将要求伦敦提供保证，确保位于塞浦路斯境内的英国军事基地仅用于人道主义目的。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260302-%E8%8B%B1%E5%9B%BD%E4%BF%9D%E8%AF%81%EF%BC%8C%E5%85%B6%E5%9C%A8%E5%A1%9E%E6%B5%A6%E8%B7%AF%E6%96%AF%E7%9A%84%E5%9F%BA%E5%9C%B0%E4%B8%8D%E4%BC%9A%E8%A2%AB%E7%BE%8E%E5%9B%BD%E7%94%A8%E4%BA%8E%E5%AF%B9%E4%BC%8A%E6%9C%97%E9%87%87%E5%8F%96%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772489758000.webp","sourceId":"rfi"},{"id":1772488359000,"createdDate":"2026-03-02 21:52","name":"法国国际广播电台","title":"中东战火蔓延黎巴嫩　美军48小时内打击伊朗超过1250目标","content":"美国与以色列针对伊朗的空袭行动周一(3月2日）持续扩大，战火蔓延至黎巴嫩。以色列在回应真主党袭击后对黎巴嫩境内发动打击，伊朗则继续以导弹和无人机攻击海湾国家。美军称在48小时内打击伊朗1250多个目标。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260302-%E4%B8%AD%E4%B8%9C%E6%88%98%E7%81%AB%E8%94%93%E5%BB%B6%E9%BB%8E%E5%B7%B4%E5%AB%A9-%E7%BE%8E%E5%86%9B48%E5%B0%8F%E6%97%B6%E6%89%93%E5%87%BB%E4%BC%8A%E6%9C%97%E8%B6%85%E8%BF%871250%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772488359000.webp","sourceId":"rfi"},{"id":1772488135000,"createdDate":"2026-03-02 21:48","name":"法国国际广播电台","title":"特朗普宣布对伊四大战略目标 军事行动或持续四至五周","content":"美国总统特朗普周一（3月2日）表示，美军针对伊朗展开的大规模军事行动预计将持续四至五周，甚至可能更久，并强调美国已为长期作战做好准备，将“坚持到底”。特朗普同时首次系统列出本轮军事行动的四大目标，包括摧毁伊朗的弹道导弹能力、削弱其海军力量、确保其无法获得核武器，以及阻止德黑兰在境外支持武装组织。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260302-%E7%89%B9%E6%9C%97%E6%99%AE%E5%85%AC%E5%B8%83%E5%AF%B9%E4%BC%8A%E5%9B%9B%E5%A4%A7%E6%88%98%E7%95%A5%E7%9B%AE%E6%A0%87-%E5%86%9B%E4%BA%8B%E8%A1%8C%E5%8A%A8%E6%88%96%E6%8C%81%E7%BB%AD%E5%9B%9B%E8%87%B3%E4%BA%94%E5%91%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/02/1772488135000.webp","sourceId":"rfi"}]