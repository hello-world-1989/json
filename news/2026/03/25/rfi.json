[{"id":1774426247000,"createdDate":"2026-03-25 08:10","name":"法国国际广播电台","title":"香港《国安法》扩权引国际关注 台陆委会：赴港要慎思","content":"港府公布修订《港区国安法》实施细则，加入执法者可要求任何人提供手机密码丶违者可被判囚及罚款，事件持续受到国际社会批评。台湾大陆委员会批评，新修订侵犯人权，提醒民众赴港要慎思；而在海外的香港人权资讯中心更提醒Apple等国际科企交代如何在上述法规和联合国商企人权原则下保护香港及全球用户权益。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260325-%E9%A6%99%E6%B8%AF-%E5%9B%BD%E5%AE%89%E6%B3%95-%E6%89%A9%E6%9D%83%E5%BC%95%E5%9B%BD%E9%99%85%E5%85%B3%E6%B3%A8-%E5%8F%B0%E9%99%86%E5%A7%94%E4%BC%9A-%E8%B5%B4%E6%B8%AF%E8%A6%81%E6%85%8E%E6%80%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774426247000.webp","sourceId":"rfi"},{"id":1774425063000,"createdDate":"2026-03-25 07:51","name":"法国国际广播电台","title":"港府把《苹果》列为「受禁组织」 同日以售《黎智英传》涉煽动而拘捕书店人士","content":"港府在《维护国家安全条例》生效两周年和修订《港区国安法》实施细则之际，同步动用两条国安法例，既藉《国安法》剔除《苹果日报》三家公司的注册，又引用俗称23条的《国安条例》去拘捕出售该报创办人黎智英传记的书店负责人和员工，指他们售卖的，是具煽动意图刊物。评论认为事态严重，指港人除失去看书自由外，港府更可能借此检取独立书店客户名单，找出思想还未完全服从官方者的名单。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260325-%E6%B8%AF%E5%BA%9C%E6%8A%8A-%E8%8B%B9%E6%9E%9C-%E5%88%97%E4%B8%BA-%E5%8F%97%E7%A6%81%E7%BB%84%E7%BB%87-%E5%90%8C%E6%97%A5%E4%BB%A5%E5%94%AE-%E9%BB%8E%E6%99%BA%E8%8B%B1%E4%BC%A0-%E6%B6%89%E7%85%BD%E5%8A%A8%E8%80%8C%E6%8B%98%E6%8D%95%E4%B9%A6%E5%BA%97%E4%BA%BA%E5%A3%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774425063000.webp","sourceId":"rfi"},{"id":1774424809000,"createdDate":"2026-03-25 07:46","name":"法国国际广播电台","title":"日本自卫队员持刀翻墙进入中国驻日使馆 中方强烈抗议","content":"隶属于宫崎县“虾野驻屯地”的日本陆上自卫官村田晃大，被怀疑于日本时间24日上午9点左右翻墙闯入位于东京港区的中国大使馆院内。中国外交部发言人林剑3月24日在例行记者会上表示：中方对这一事件深感震惊，已向日方严正交涉、提出强烈抗议。有关事件严重违反《维也纳外交关系公约》，严重威胁中方外交人员人身安全和外交设施安全，性质影响极为恶劣。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260325-%E6%97%A5%E6%9C%AC%E8%87%AA%E5%8D%AB%E9%98%9F%E5%91%98%E6%8C%81%E5%88%80%E7%BF%BB%E5%A2%99%E8%BF%9B%E5%85%A5%E4%B8%AD%E5%9B%BD%E9%A9%BB%E6%97%A5%E4%BD%BF%E9%A6%86-%E4%B8%AD%E6%96%B9%E5%BC%BA%E7%83%88%E6%8A%97%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774424809000.webp","sourceId":"rfi"},{"id":1774408358000,"createdDate":"2026-03-25 03:12","name":"法国国际广播电台","title":"中东冲突已令人恐惧，但想象一下：中国攻打台湾对全球可能发生什么影响？","content":"各位听众，当前爆发的中东战争导致因恐惧经济滞涨而市场动荡不安。然而，如果发生中国对台湾发动战争，这将对全球经济和金融带来更为巨大的冲击和影响。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260325-%E4%B8%AD%E4%B8%9C%E5%86%B2%E7%AA%81%E5%B7%B2%E4%BB%A4%E4%BA%BA%E6%81%90%E6%83%A7%EF%BC%8C%E4%BD%86%E6%83%B3%E8%B1%A1%E4%B8%80%E4%B8%8B-%E4%B8%AD%E5%9B%BD%E6%94%BB%E6%89%93%E5%8F%B0%E6%B9%BE%E5%AF%B9%E5%85%A8%E7%90%83%E5%8F%AF%E8%83%BD%E5%8F%91%E7%94%9F%E4%BB%80%E4%B9%88%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774408358000.webp","sourceId":"rfi"},{"id":1774456536000,"createdDate":"2026-03-25 16:35","name":"法国国际广播电台","title":"因“友谊”输油管道仍未修复  匈牙利宣布将“逐步减少对基辅的天然气供应”","content":"匈牙利总理欧尔班周三（3月25日）称，为了打破石油封锁并保障匈牙利的能源供应安全，现在必须采取新的措施。他宣布，只要乌克兰尚未恢复通过“友谊”输油管道（德鲁日巴管道）输送俄罗斯石油，他将“逐步减少对乌克兰的天然气供应”。上述表态是他在Facebook发布的一段视频中作出的。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260325-%E5%9B%A0-%E5%8F%8B%E8%B0%8A-%E8%BE%93%E6%B2%B9%E7%AE%A1%E9%81%93%E4%BB%8D%E6%9C%AA%E4%BF%AE%E5%A4%8D-%E5%8C%88%E7%89%99%E5%88%A9%E5%AE%A3%E5%B8%83%E5%B0%86-%E9%80%90%E6%AD%A5%E5%87%8F%E5%B0%91%E5%AF%B9%E5%9F%BA%E8%BE%85%E7%9A%84%E5%A4%A9%E7%84%B6%E6%B0%94%E4%BE%9B%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774456536000.webp","sourceId":"rfi"},{"id":1774452281000,"createdDate":"2026-03-25 15:24","name":"法国国际广播电台","title":"风生水起的电子竞技是否可以看作是体育？","content":"电子游戏风靡全球多年，伴随着电子竞技是否可以看作是体育活动的争议始终未见分晓。很多家长为孩子痴迷于电子游戏耽误学业而不安，电子游戏对孩童的心理影响也引发争议，但电子竞技比赛却规模越来越大，系列电子游戏《使命召唤》2026第四季比赛就将在26日至28日在被看作是欧洲最大演出厅的巴黎拉德芳斯体育馆举行。电子竞技如今还堂而皇之的获得了一个英文名称Esport，也就是electronicsport两个词的合体，既是电子，也是体育。但是，电竞游戏是否可以看作是体育呢？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260325-%E9%A3%8E%E7%94%9F%E6%B0%B4%E8%B5%B7%E7%9A%84%E7%94%B5%E5%AD%90%E7%AB%9E%E6%8A%80%E6%98%AF%E5%90%A6%E5%8F%AF%E4%BB%A5%E7%9C%8B%E4%BD%9C%E6%98%AF%E4%BD%93%E8%82%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774452281000.webp","sourceId":"rfi"},{"id":1774451877000,"createdDate":"2026-03-25 15:17","name":"法国国际广播电台","title":"伊朗国家电视台称已拒绝美方和平计划 伊朗高官指初步反应“并不积极”","content":"伊朗国家电视台周三援引一名未具名高级官员的话称，伊朗已拒绝了美国为结束中东战争提出的和平计划。据伊朗英语新闻电视台（PressTV）报导，该官员表示：“伊朗对美国旨在结束这场正在进行的、由外部强加的战争的提议作出了否定回应”。该官员称，“战争的结束将取决于伊朗何时决定结束，而非特朗普设想的结束（时间）”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260325-%E4%BC%8A%E6%9C%97%E5%9B%BD%E5%AE%B6%E7%94%B5%E8%A7%86%E5%8F%B0%E7%A7%B0%E5%B7%B2%E6%8B%92%E7%BB%9D%E7%BE%8E%E6%96%B9%E5%92%8C%E5%B9%B3%E8%AE%A1%E5%88%92-%E4%BC%8A%E6%9C%97%E9%AB%98%E5%AE%98%E6%8C%87%E5%88%9D%E6%AD%A5%E5%8F%8D%E5%BA%94-%E5%B9%B6%E4%B8%8D%E7%A7%AF%E6%9E%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774451877000.webp","sourceId":"rfi"},{"id":1774449959000,"createdDate":"2026-03-25 14:45","name":"法国国际广播电台","title":"小马科斯：菲中关系重置肯定会发生，而且现在就在发生","content":"菲律宾总统小马科斯（FerdinandMarcosJr.）周二在马尼拉总统府受访时表示，随着全球地缘政治格局的持续变化，菲中关系“重置”或许不可避免。他还重申了菲方在当前中东冲突中反对战争的立场。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260325-%E5%B0%8F%E9%A9%AC%E7%A7%91%E6%96%AF-%E8%8F%B2%E4%B8%AD%E5%85%B3%E7%B3%BB%E9%87%8D%E7%BD%AE%E8%82%AF%E5%AE%9A%E4%BC%9A%E5%8F%91%E7%94%9F%EF%BC%8C%E8%80%8C%E4%B8%94%E7%8E%B0%E5%9C%A8%E5%B0%B1%E5%9C%A8%E5%8F%91%E7%94%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774449959000.webp","sourceId":"rfi"},{"id":1774448740000,"createdDate":"2026-03-25 14:25","name":"法国国际广播电台","title":"油价上涨：中国司机开始少开车、换电车","content":"随着中东局势持续升级，国际原油价格大幅波动，全球能源市场面临新的不确定性。受供应受阻与市场紧张情绪影响，原油价格持续上涨，并通过进口渠道传导至多个依赖能源进口的亚洲国家，进一步加剧通胀与能源安全压力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260325-%E6%B2%B9%E4%BB%B7%E4%B8%8A%E6%B6%A8-%E4%B8%AD%E5%9B%BD%E5%8F%B8%E6%9C%BA%E5%BC%80%E5%A7%8B%E5%B0%91%E5%BC%80%E8%BD%A6-%E6%8D%A2%E7%94%B5%E8%BD%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774448740000.webp","sourceId":"rfi"},{"id":1774448083000,"createdDate":"2026-03-25 14:14","name":"法国国际广播电台","title":"2026上海国际半导体展览会在激烈竞争背景下开幕","content":"由国际半导体产业协会（SEMI）与中国电子商会联合主办的SemiconChina2026暨上海国际半导体展览会3月25日在上海新国际博览中心开幕。在数字科技及人工智能技术快速发展而大国竞争尤其是中美高科技竞争激烈的背景下，展览会自然也备受舆论关注。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260325-2026%E4%B8%8A%E6%B5%B7%E5%9B%BD%E9%99%85%E5%8D%8A%E5%AF%BC%E4%BD%93%E5%B1%95%E8%A7%88%E4%BC%9A%E5%9C%A8%E6%BF%80%E7%83%88%E7%AB%9E%E4%BA%89%E8%83%8C%E6%99%AF%E4%B8%8B%E5%BC%80%E5%B9%95","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774448083000.webp","sourceId":"rfi"},{"id":1774444470000,"createdDate":"2026-03-25 13:14","name":"法国国际广播电台","title":"中国据报限制人工智能新星Manus公司CEO、首席科学家出境","content":"据英国《金融时报》报导称，中国已限制人工智能（AI）初创公司Manus的两名联合创始人出境，此举正值监管机构正在审查脸书母公司Meta以20亿美元收购这家AI代理工具公司是否违反了中方的投资规定。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260325-%E4%B8%AD%E5%9B%BD%E6%8D%AE%E6%8A%A5%E9%99%90%E5%88%B6ai%E6%96%B0%E6%98%9Fmanus%E5%85%AC%E5%8F%B8ceo-%E9%A6%96%E5%B8%AD%E7%A7%91%E5%AD%A6%E5%AE%B6%E5%87%BA%E5%A2%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774444470000.webp","sourceId":"rfi"},{"id":1774441489000,"createdDate":"2026-03-25 12:24","name":"法国国际广播电台","title":"日官房长官就自卫队队员擅闯中国大使馆一事表遗憾 中方：已表达强烈不满","content":"就一名陆上自卫队队员因涉嫌擅闯位于东京都的中国驻日大使馆区域而被捕一事，日本内阁官房长官木原稔在周三上午的记者会上表示“十分令人遗憾”，并称日本政府已向中方说明，将防止此类事件再次发生，采取适当措施。木原透露，已采取增派警力等措施，加强该大使馆的警备工作。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260325-%E6%97%A5%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E5%B0%B1%E8%87%AA%E5%8D%AB%E9%98%9F%E9%98%9F%E5%91%98%E6%93%85%E9%97%AF%E4%B8%AD%E5%9B%BD%E5%A4%A7%E4%BD%BF%E9%A6%86%E4%B8%80%E4%BA%8B%E8%A1%A8%E9%81%97%E6%86%BE-%E4%B8%AD%E6%96%B9-%E5%B7%B2%E8%A1%A8%E8%BE%BE%E5%BC%BA%E7%83%88%E4%B8%8D%E6%BB%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774441489000.webp","sourceId":"rfi"},{"id":1774439064000,"createdDate":"2026-03-25 11:44","name":"法国国际广播电台","title":"航空工业集团原董事长谭瑞松被判死缓 涉贪污、受贿、内幕交易等","content":"据官媒新华社报导，3月25日，辽宁省大连市中级人民法院一审公开宣判中国航空工业集团有限公司原党组书记、董事长谭瑞松贪污、受贿、内幕交易、泄露内幕信息案，对被告人谭瑞松以贪污罪判处有期徒刑十五年，并处罚金人民币五百万元；以受贿罪判处死刑，缓期二年执行，剥夺政治权利终身，并处没收个人全部财产；以内幕交易、泄露内幕信息罪判处有期徒刑六年，并处罚金，决定执行死刑，缓期二年执行，剥夺政治权利终身，并处没收个人全部财产；对谭瑞松贪污犯罪所得财物返还被害单位，受贿犯罪所得财物及孳息依法予以追缴，上缴国库，继续追缴内幕交易违法所得。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260325-%E8%88%AA%E7%A9%BA%E5%B7%A5%E4%B8%9A%E9%9B%86%E5%9B%A2%E5%8E%9F%E8%91%A3%E4%BA%8B%E9%95%BF%E8%B0%AD%E7%91%9E%E6%9D%BE%E8%A2%AB%E5%88%A4%E6%AD%BB%E7%BC%93-%E6%B6%89%E8%B4%AA%E6%B1%A1-%E5%8F%97%E8%B4%BF-%E5%86%85%E5%B9%95%E4%BA%A4%E6%98%93%E7%AD%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774439064000.webp","sourceId":"rfi"},{"id":1774434308000,"createdDate":"2026-03-25 10:25","name":"法国国际广播电台","title":"美国据报已起草15点停火方案 巴官员称伊朗已收到","content":"据彭博社援引知情人士报导称，美国已起草一份旨在结束与伊朗战争的15点计划，这凸显了随着战争带来的经济影响不断加剧，特朗普政府解决这场冲突的紧迫性日益增强。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260325-%E7%BE%8E%E5%9B%BD%E6%8D%AE%E6%8A%A5%E5%B7%B2%E8%B5%B7%E8%8D%8915%E7%82%B9%E5%81%9C%E7%81%AB%E6%96%B9%E6%A1%88-%E5%B7%B4%E5%AE%98%E5%91%98%E7%A7%B0%E4%BC%8A%E6%9C%97%E5%B7%B2%E6%94%B6%E5%88%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774434308000.webp","sourceId":"rfi"},{"id":1774433704000,"createdDate":"2026-03-25 10:15","name":"法国国际广播电台","title":"中国面临清洁能源创纪录增长与煤炭复兴之间的能源困境？","content":"第十六届中国国际清洁能源博览会（CleanEnergyExpoChina）于3月25至27号号在北京国家会议中心召开之际，主办方认为可以从多角度、全方位展示参展企业在构建以新能源为主体的新型电力系统方面的科技成果，促进能源行业融合发展、转型升级，共同打造行业盛会。但中国面临可再生能源创纪录增长与煤炭复兴之间的能源困境受到关注。","newsLink":"https://www.rfi.fr/cn/%E7%94%9F%E6%80%81/20260325-%E4%B8%AD%E5%9B%BD%E9%9D%A2%E4%B8%B4%E5%8F%AF%E5%86%8D%E7%94%9F%E8%83%BD%E6%BA%90%E5%88%9B%E7%BA%AA%E5%BD%95%E5%A2%9E%E9%95%BF%E4%B8%8E%E7%85%A4%E7%82%AD%E5%A4%8D%E5%85%B4%E4%B9%8B%E9%97%B4%E7%9A%84%E8%83%BD%E6%BA%90%E5%9B%B0%E5%A2%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774433704000.webp","sourceId":"rfi"},{"id":1774430745000,"createdDate":"2026-03-25 09:25","name":"法国国际广播电台","title":"《苹果日报》3间公司成“受禁组织” 大批警员进入封锁厂房大楼","content":"综合消息显示，《苹果日报》3间公司昨日在公司登记册中被剔除，经刊宪后告解散，并已成为“受禁组织”。香港警方于当地时间周三（25日）下午2时许，封锁《苹果日报》位于将军澳工业邨的厂房大楼。《明报》记者下午2时许在场所见，至少有数十名警员在场，有探员手持行李箱。警员至3时许陆续离开。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260325-%E8%8B%B9%E6%9E%9C%E6%97%A5%E6%8A%A5-3%E9%97%B4%E5%85%AC%E5%8F%B8%E6%88%90-%E5%8F%97%E7%A6%81%E7%BB%84%E7%BB%87-%E5%A4%A7%E6%89%B9%E8%AD%A6%E5%91%98%E8%BF%9B%E5%85%A5%E5%B0%81%E9%94%81%E5%8E%82%E6%88%BF%E5%A4%A7%E6%A5%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774430745000.webp","sourceId":"rfi"},{"id":1774429925000,"createdDate":"2026-03-25 09:12","name":"法国国际广播电台","title":"南韩、喀麦隆与丹麦 台湾外交部强烈抗议近来国名一再遭他国矮化","content":"南韩电子入境卡洗统将台湾国民列为中国（台湾），台湾外交部表示抗议并要求在31日前更正，否则将采反制措施。外交部同时也对WTO主办国喀麦隆与丹麦对矮化国名事件表达谴责。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260325-%E5%8D%97%E9%9F%A9-%E5%96%80%E9%BA%A6%E9%9A%86%E4%B8%8E%E4%B8%B9%E9%BA%A6-%E5%8F%B0%E6%B9%BE%E5%A4%96%E4%BA%A4%E9%83%A8%E5%BC%BA%E7%83%88%E6%8A%97%E8%AE%AE%E8%BF%91%E6%9D%A5%E5%9B%BD%E5%90%8D%E4%B8%80%E5%86%8D%E9%81%AD%E4%BB%96%E5%9B%BD%E7%9F%AE%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774429925000.webp","sourceId":"rfi"},{"id":1774475219000,"createdDate":"2026-03-25 21:46","name":"法国国际广播电台","title":"中远海运宣布恢复前往海湾国家的集装箱订舱服务  伊朗称允许“非敌对船只”通过霍尔木兹海峡","content":"今日出刊的法国《世界报》头条依旧聚焦法国国内的市政选举，距离上周日（3月22日）的第二轮市政选举投票已经过去三天了，《世界报》重新复盘本轮投票所揭露出的法国当前国内政治格局，以及各党派接下来的发展趋势，以应对2027年的总统大选。本期报纸的国际版则刊登该报驻北京特派记者发布的分析文章，指出当前霍尔木兹海峡仍有船只可以通行，但这些船只都是“非敌对船只”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260325-%E4%B8%AD%E8%BF%9C%E6%B5%B7%E8%BF%90%E5%AE%A3%E5%B8%83%E6%81%A2%E5%A4%8D%E5%89%8D%E5%BE%80%E6%B5%B7%E6%B9%BE%E5%9B%BD%E5%AE%B6%E7%9A%84%E9%9B%86%E8%A3%85%E7%AE%B1%E8%AE%A2%E8%88%B1%E6%9C%8D%E5%8A%A1-%E4%BC%8A%E6%9C%97%E7%A7%B0%E5%85%81%E8%AE%B8-%E9%9D%9E%E6%95%8C%E5%AF%B9%E8%88%B9%E5%8F%AA-%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774475219000.webp","sourceId":"rfi"},{"id":1774473482000,"createdDate":"2026-03-25 21:18","name":"法国国际广播电台","title":"伊朗议长：敌人正准备攻占一座岛屿","content":"伊朗议会议长穆罕默德·巴盖尔·加利巴夫（MohammadBagherGhalibaf）周三警告称，伊朗的“敌人”正准备在某个地区国家的帮助下入侵其位于波斯湾的一座岛屿。白宫新闻秘书卡罗琳·莱维特25日在新闻发布会上表示：“特朗普总统并非虚张声势，他已做好让伊朗付出惨痛代价的准备。伊朗不应再次误判形势。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260325-%E4%BC%8A%E6%9C%97%E8%AE%AE%E9%95%BF-%E6%95%8C%E4%BA%BA%E6%AD%A3%E5%87%86%E5%A4%87%E6%94%BB%E5%8D%A0%E4%B8%80%E5%BA%A7%E5%B2%9B%E5%B1%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774473482000.webp","sourceId":"rfi"},{"id":1774473368000,"createdDate":"2026-03-25 21:16","name":"法国国际广播电台","title":"五年内    法将额外投资85亿欧元军火订单","content":"法国总理塞巴斯蒂安·勒科尔努周三宣布，作为军事规划法（LPM）修订的一部分，到2030年将追加总额达85亿欧元的军火订单。该修订案将于5月至6月提交议会审议。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260325-%E4%BA%94%E5%B9%B4%E5%86%85-%E6%B3%95%E5%B0%86%E9%A2%9D%E5%A4%96%E6%8A%95%E8%B5%8485%E4%BA%BF%E6%AC%A7%E5%85%83%E5%86%9B%E7%81%AB%E8%AE%A2%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774473368000.webp","sourceId":"rfi"},{"id":1774473171000,"createdDate":"2026-03-25 21:12","name":"法国国际广播电台","title":"菲国防部长未表态会采购法国造的潜艇","content":"巴黎正在举行战略和国防论坛。来法的菲律宾国防部长吉尔伯特·特奥多罗（GilbertTeodoro）对法新社表示，菲律宾和法国将加强军事合作。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260325-%E8%8F%B2%E5%9B%BD%E9%98%B2%E9%83%A8%E9%95%BF%E6%9C%AA%E8%A1%A8%E6%80%81%E4%BC%9A%E9%87%87%E8%B4%AD%E6%B3%95%E5%9B%BD%E9%80%A0%E7%9A%84%E6%BD%9C%E8%89%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774473171000.webp","sourceId":"rfi"},{"id":1774472908000,"createdDate":"2026-03-25 21:08","name":"法国国际广播电台","title":"科索沃：宪法法院驳回总统解散议会的法令","content":"科索沃宪法法院周三驳回了总统维约萨·奥斯马尼(VjosaOsmani)3月初颁布的解散议会并要求举行新的议会选举的法令。科索沃已陷入一年多的政治僵局。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260325-%E7%A7%91%E7%B4%A2%E6%B2%83-%E5%AE%AA%E6%B3%95%E6%B3%95%E9%99%A2%E9%A9%B3%E5%9B%9E%E6%80%BB%E7%BB%9F%E8%A7%A3%E6%95%A3%E8%AE%AE%E4%BC%9A%E7%9A%84%E6%B3%95%E4%BB%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774472908000.webp","sourceId":"rfi"},{"id":1774472795000,"createdDate":"2026-03-25 21:06","name":"法国国际广播电台","title":"Meta、YouTube双双将对判决提出上诉","content":"洛杉矶一名法官判Meta与Google旗下平台为青少年网络成瘾负责，这是一个史无前例的判决。Meta表示“不同意”这一裁决。另据最新消息,Meta和YouTube都将对判决提出上诉。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260325-youtube%E5%8F%8C%E5%8F%8C%E5%B0%86%E5%AF%B9%E5%88%A4%E5%86%B3%E6%8F%90%E5%87%BA%E4%B8%8A%E8%AF%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774472795000.webp","sourceId":"rfi"},{"id":1774472462000,"createdDate":"2026-03-25 21:01","name":"法国国际广播电台","title":"美国政府放宽加油站汽油销售限制","content":"美国政府周三决定放宽加油站燃油销售的限制，以缓解与中东战争相关的油价飙升。美国环境保护署（EPA）署长李·泽尔丁在德克萨斯州休斯顿举行的CERAWeek能源​​论坛上宣布，将放宽E15汽油（由85%的石油和15%的乙醇组成）的销售规定。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260325-%E7%BE%8E%E5%9B%BD%E6%94%BF%E5%BA%9C%E6%94%BE%E5%AE%BD%E5%8A%A0%E6%B2%B9%E7%AB%99%E6%B1%BD%E6%B2%B9%E9%94%80%E5%94%AE%E9%99%90%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774472462000.webp","sourceId":"rfi"},{"id":1774470605000,"createdDate":"2026-03-25 20:30","name":"法国国际广播电台","title":"伊朗战争的中间调停国: 为何是巴基斯坦？","content":"依靠其重要地理位置、与伊朗的传统盟友关系、与美国的历史合作、什叶派人口的国内影响力，以及穆尼尔元帅的个人权力与外交能力，巴基斯坦成为伊朗和美国之间冲突的重要调停国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260325-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E7%9A%84%E4%B8%AD%E9%97%B4%E8%B0%83%E5%81%9C%E5%9B%BD-%E4%B8%BA%E4%BD%95%E6%98%AF%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774470605000.webp","sourceId":"rfi"},{"id":1774467638000,"createdDate":"2026-03-25 19:40","name":"法国国际广播电台","title":"美国禁止进口外国制造的新款路由器","content":"去年秋天，美国曾将目标对准另一家中国公司。这一次，目标是美国知名Wi-Fi路由器品牌TP-Link，该公司被指控收集公民数据，并面临在美国境内销售的禁令。而今范围扩大了，所有在国外生产的新型Wi-Fi路由器都将禁止在美国销售。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260325-%E7%BE%8E%E5%9B%BD%E7%A6%81%E6%AD%A2%E8%BF%9B%E5%8F%A3%E5%A4%96%E5%9B%BD%E5%88%B6%E9%80%A0%E7%9A%84%E6%96%B0%E6%AC%BE%E8%B7%AF%E7%94%B1%E5%99%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774467638000.webp","sourceId":"rfi"},{"id":1774467407000,"createdDate":"2026-03-25 19:36","name":"法国国际广播电台","title":"津巴布韦称15名公民为俄作战在乌克兰身亡，涉人口贩运","content":"2026年3月25日，津巴布韦方面通报称，有15名本国公民在乌克兰为俄罗斯作战期间死亡。这一消息使津巴布韦成为又一个报告本国人员在俄乌冲突前线身亡的非洲国家。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260325-%E6%B4%A5%E5%B7%B4%E5%B8%83%E9%9F%A6%E7%A7%B015%E5%90%8D%E5%85%AC%E6%B0%91%E4%B8%BA%E4%BF%84%E4%BD%9C%E6%88%98%E5%9C%A8%E4%B9%8C%E5%85%8B%E5%85%B0%E8%BA%AB%E4%BA%A1%EF%BC%8C%E6%B6%89%E4%BA%BA%E5%8F%A3%E8%B4%A9%E8%BF%90","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774467407000.webp","sourceId":"rfi"},{"id":1774467288000,"createdDate":"2026-03-25 19:34","name":"法国国际广播电台","title":"人形机器人和梅拉尼娅同步出现在白宫东厅","content":"一台名为“Figure3”的人形机器人在白宫东厅出现在美国总统第一夫人身旁，当时在场的还有法国第一夫人布丽吉特和嘉宾，这是“携手共育未来”全球联盟峰会的第二天。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260325-%E4%BA%BA%E5%BD%A2%E6%9C%BA%E5%99%A8%E4%BA%BA%E5%92%8C%E6%A2%85%E6%8B%89%E5%B0%BC%E5%A8%85%E5%90%8C%E6%AD%A5%E5%87%BA%E7%8E%B0%E5%9C%A8%E7%99%BD%E5%AE%AB%E4%B8%9C%E5%8E%85","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774467288000.webp","sourceId":"rfi"},{"id":1774467013000,"createdDate":"2026-03-25 19:30","name":"法国国际广播电台","title":"洛克希德马丁将把精确打击导弹产量提高四倍","content":"美国国防部周三宣布与国防承包商达成协议，提高导弹生产量。中东冲突迫使华盛顿迅速动用其军火储备。五角大楼3月25日宣布，将“萨德”（THAAD）系统关键部件的产量提高四倍。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260325-%E6%B4%9B%E5%85%8B%E5%B8%8C%E5%BE%B7%E9%A9%AC%E4%B8%81%E5%B0%86%E6%8A%8A%E7%B2%BE%E7%A1%AE%E6%89%93%E5%87%BB%E5%AF%BC%E5%BC%B9%E4%BA%A7%E9%87%8F%E6%8F%90%E9%AB%98%E5%9B%9B%E5%80%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774467013000.webp","sourceId":"rfi"},{"id":1774466052000,"createdDate":"2026-03-25 19:14","name":"法国国际广播电台","title":"国会施压白宫说明 传唤卢比奥等解释伊朗战争","content":"众议院外交委员会民主党首席议员米克斯（GregoryMeeks）25日正式提出动议，要求传唤国务卿卢比奥（MarcoRubio）、美国特使维特科夫（SteveWitkoff）及特朗普女婿库什纳（JaredKushner）赴国会作证，针对美国总统特朗普（DonaldTrump）主导的对伊朗军事行动与外交谈判进行公开说明。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260325-%E5%9B%BD%E4%BC%9A%E6%96%BD%E5%8E%8B%E7%99%BD%E5%AE%AB%E8%AF%B4%E6%98%8E-%E4%BC%A0%E5%94%A4%E5%8D%A2%E6%AF%94%E5%A5%A5%E7%AD%89%E8%A7%A3%E9%87%8A%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774466052000.webp","sourceId":"rfi"},{"id":1774461960000,"createdDate":"2026-03-25 18:06","name":"法国国际广播电台","title":"特朗普将于5月14日至15日访华","content":"美国总统特朗普访华日期已定。3月25日，白宫发言人在新闻发布会上表示：“我很高兴地宣布，期待已久的特朗普总统与习近平主席的会晤将于5月14日至15日在北京举行。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260325-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B0%86%E4%BA%8E5%E6%9C%8814%E6%97%A5%E8%87%B315%E6%97%A5%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/25/1774461960000.webp","sourceId":"rfi"}]