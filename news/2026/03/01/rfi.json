[{"id":1772354488000,"createdDate":"2026-03-01 08:41","name":"法国国际广播电台","title":"86岁的哈梅内伊死后，伊朗权力如何交接？","content":"伊朗最高领袖、86岁的阿亚图拉·阿里·哈梅内伊在美国和以色列的联合袭击中丧生，伊朗于周日（3月1日）确认此事，并进行了对以色列和海湾国家的导弹报复。至于权力交接，伊朗表示，未来将由总统马苏德·佩泽什基安、最高法院首席法官霍拉姆霍赛因·穆赫森尼·埃贾伊以及宪法监护委员会成员组成的三人领导小组接管过渡工作。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260301-86%E5%B2%81%E7%9A%84%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E6%AD%BB%E5%90%8E%EF%BC%8C%E4%BC%8A%E6%9C%97%E6%9D%83%E5%8A%9B%E5%A6%82%E4%BD%95%E4%BA%A4%E6%8E%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772354488000.webp","sourceId":"rfi"},{"id":1772382356000,"createdDate":"2026-03-01 16:25","name":"法国国际广播电台","title":"人物小传：哈梅内伊的一生","content":"据美联社报道，伊朗最高领袖阿亚图拉·阿里·哈梅内伊（AyatollahAliKhamenei）数十年来巩固了神权统治，将伊朗塑造成地区强权，并且因核计划问题与以色列和美国对峙，镇压国内的民主抗议。如今，他在美以联合空袭中身亡，享年86岁。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260301-%E4%BA%BA%E7%89%A9%E5%B0%8F%E4%BC%A0-%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E7%9A%84%E4%B8%80%E7%94%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772382356000.webp","sourceId":"rfi"},{"id":1772377405000,"createdDate":"2026-03-01 15:03","name":"法国国际广播电台","title":"OPEC+决定大幅提高产油量  但分析指出：如果石油无法通过霍尔木兹海峡运输，产量再多也于事无补","content":"由于伊朗战争令中东局势及原油运输路线动荡，沙特阿拉伯、俄罗斯及其他六个OPEC+成员国周日（3月1日）决定将4月份的石油日产量配额上调20.6万桶，高于市场此前预期。霍尔木兹海峡是全球石油贸易的关键通道，全球约四分之一的石油和五分之一的液化天然气经此运输。周六，伊朗革命卫队已宣布关闭该航道，警告称由于美国和以色列的袭击，该水域存在危险。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260301-opec-%E5%86%B3%E5%AE%9A%E5%A4%A7%E5%B9%85%E6%8F%90%E9%AB%98%E4%BA%A7%E6%B2%B9%E9%87%8F-%E4%BD%86%E5%88%86%E6%9E%90%E6%8C%87%E5%87%BA-%E5%A6%82%E6%9E%9C%E7%9F%B3%E6%B2%B9%E6%97%A0%E6%B3%95%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E8%BF%90%E8%BE%93%EF%BC%8C%E4%BA%A7%E9%87%8F%E5%86%8D%E5%A4%9A%E4%B9%9F%E4%BA%8E%E4%BA%8B%E6%97%A0%E8%A1%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772377405000.webp","sourceId":"rfi"},{"id":1772376217000,"createdDate":"2026-03-01 14:43","name":"法国国际广播电台","title":"“228事件”79周年：赖清德提林宅血案，批评威权政府销毁证据伤害人民","content":"据中央社报导，2月28日，“二二八事件”（“228事件”）79周年当天，赖总统等人出席纪念仪式，并到228和平纪念公园向受难者献花，他表示，与林宅血案相关档案已全数解密，遗憾的是，当年许多证据遭系统性破坏，“谁能销毁档案？只有当权政府才有这样的能力”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260301-228%E4%BA%8B%E4%BB%B6-79%E5%91%A8%E5%B9%B4-%E8%B5%96%E6%B8%85%E5%BE%B7%E6%8F%90%E6%9E%97%E5%AE%85%E8%A1%80%E6%A1%88%EF%BC%8C%E6%89%B9%E8%AF%84%E5%A8%81%E6%9D%83%E6%94%BF%E5%BA%9C%E9%94%80%E6%AF%81%E8%AF%81%E6%8D%AE%E4%BC%A4%E5%AE%B3%E4%BA%BA%E6%B0%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772376217000.webp","sourceId":"rfi"},{"id":1772367720000,"createdDate":"2026-03-01 12:22","name":"法国国际广播电台","title":"在以美国军事行动中身亡的伊朗最高精神领袖哈梅内伊","content":"德黑兰周日证实，伊朗最高精神领袖·哈梅内伊在美以联合对伊朗的军事行动中遇害身亡。伊朗随后对包括以色列在内的以及多个驻扎在阿拉伯国家的美军基地为目标进行报复。哈梅内伊的死讯是周六由特朗普宣布的，伊朗国家电视台也证实了这一消息，伊朗革命卫队承诺将对肇事者进行“严厉的惩罚”。针对哈梅内伊的过世前伊朗王储礼萨·巴列维在X上表示“：“随着他的去世，伊斯兰共和国实际上已经终结，并将很快被扔进历史的垃圾堆里。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260301-%E5%9C%A8%E4%BB%A5%E7%BE%8E%E5%9B%BD%E5%86%9B%E4%BA%8B%E8%A1%8C%E5%8A%A8%E4%B8%AD%E8%BA%AB%E4%BA%A1%E7%9A%84%E4%BC%8A%E6%9C%97%E6%9C%80%E9%AB%98%E7%B2%BE%E7%A5%9E%E9%A2%86%E8%A2%96%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772367720000.webp","sourceId":"rfi"},{"id":1772367285000,"createdDate":"2026-03-01 12:14","name":"法国国际广播电台","title":"法国称对哈梅内伊之死只能“表示满意”  欧盟呼吁尊重国际法并称必须采取行动缓和冲突","content":"法国政府发言人莫德·布雷热翁莫德·布雷热翁周日表示，伊朗最高领袖阿里·哈梅内伊在美以轰炸中遇害，法国只能“表示满意”，因为他是“一位血腥独裁者”，同时法国重申对国际法的尊重。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260301-%E6%B3%95%E5%9B%BD-%E5%AF%B9%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E4%B9%8B%E6%AD%BB%E5%8F%AA%E8%83%BD-%E8%A1%A8%E7%A4%BA%E6%BB%A1%E6%84%8F-%E5%AF%B9%E7%BE%8E%E4%BB%A5%E5%86%9B%E4%BA%8B%E8%A1%8C%E5%8A%A8%E6%8C%81%E4%BF%9D%E7%95%99%E6%84%8F%E8%A7%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772367285000.webp","sourceId":"rfi"},{"id":1772365803000,"createdDate":"2026-03-01 11:50","name":"法国国际广播电台","title":"伊朗呼吁为哈梅内伊之死复仇 特朗普：若继续报复将以“前所未有的力量”进行打击","content":"伊朗周日（3月1日）呼吁为最高领袖哈梅内伊的死亡复仇。美国前总统特朗普威胁称，如果伊朗继续报复行动，将以“前所未有的力量”进行打击。伊朗总统马苏德·佩泽什基安马苏德·佩泽什基安周日表示，为最高领袖复仇是“合法且正当的权利与责任”，并谴责这是对穆斯林的“战争宣言”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260301-%E4%BC%8A%E6%9C%97%E5%91%BC%E5%90%81%E4%B8%BA%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E4%B9%8B%E6%AD%BB%E5%A4%8D%E4%BB%87-%E7%89%B9%E6%9C%97%E6%99%AE-%E8%8B%A5%E7%BB%A7%E7%BB%AD%E6%8A%A5%E5%A4%8D%E5%B0%86%E4%BB%A5-%E5%89%8D%E6%89%80%E6%9C%AA%E6%9C%89%E7%9A%84%E5%8A%9B%E9%87%8F-%E8%BF%9B%E8%A1%8C%E6%89%93%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772365803000.webp","sourceId":"rfi"},{"id":1772365633000,"createdDate":"2026-03-01 11:47","name":"法国国际广播电台","title":"哈梅内伊之死、美国反对声、以色列的团结…..未来几周决定中东几十年走向？","content":"周日«世界报»网站上的头条继续实时关注伊朗局势，从多个角度进行分析评论。最新消息显示，最高领导人阿里·哈梅内伊被证实已经死亡后，伊朗也证实其陆军总参谋长兼国防部长阿米尔·哈塔米，革命卫队司令穆罕默德·帕克普尔以及最高领袖的亲密顾问阿里·沙姆哈尼等40名军方高层领导死亡消息。伊朗正在进行政治过渡。周六晚，美国总统特朗普宣布空袭将“在本周内持续进行，不会中断”。以色列前国防部长、军官约阿夫·加兰特在进攻开始前总结道：“未来几周将决定中东未来几十年的走向。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260301-%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E4%B9%8B%E6%AD%BB-%E7%BE%8E%E5%9B%BD%E5%8F%8D%E5%AF%B9%E5%A3%B0-%E4%BB%A5%E8%89%B2%E5%88%97%E7%9A%84%E5%9B%A2%E7%BB%93-%E6%9C%AA%E6%9D%A5%E5%87%A0%E5%91%A8%E5%86%B3%E5%AE%9A%E4%B8%AD%E4%B8%9C%E5%87%A0%E5%8D%81%E5%B9%B4%E8%B5%B0%E5%90%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772365633000.webp","sourceId":"rfi"},{"id":1772361652000,"createdDate":"2026-03-01 10:40","name":"法国国际广播电台","title":"泰媒：中东强权之战  非小国可控","content":"正值美国和伊朗重启核谈判之际，以色列与美国突然对伊朗采取军事行动，造成伊朗最高军政领袖身亡。伊朗方面针对多个美军基地还以报复袭击，武装冲突蔓延至多个中东国家。新加坡前总理李显龙警告说，世界正进入一个高度不确定时期，“战争已经开始”小国唯自强且具备足够韧性，方能应对即将到来的所有冲击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260301-%E6%B3%B0%E5%AA%92-%E4%B8%AD%E4%B8%9C%E5%BC%BA%E6%9D%83%E4%B9%8B%E6%88%98-%E9%9D%9E%E5%B0%8F%E5%9B%BD%E5%8F%AF%E6%8E%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772361652000.webp","sourceId":"rfi"},{"id":1772361240000,"createdDate":"2026-03-01 10:34","name":"法国国际广播电台","title":"一篇“未来备忘录”引发市场震荡，网络热议","content":"近日，纽约一家专注股权投资的研究机构CitriniResearch发布了一篇题为《2028全球智能危机》的长文，结果导致纽约股市部分版块暴跌。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%BE%AE%E8%A8%80%E5%BE%AE%E8%AF%AD/20260301-%E4%B8%80%E7%AF%87-%E6%9C%AA%E6%9D%A5%E5%A4%87%E5%BF%98%E5%BD%95-%E5%BC%95%E5%8F%91%E5%B8%82%E5%9C%BA%E9%9C%87%E8%8D%A1%EF%BC%8C%E7%BD%91%E7%BB%9C%E7%83%AD%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772361240000.webp","sourceId":"rfi"},{"id":1772359468000,"createdDate":"2026-03-01 10:04","name":"法国国际广播电台","title":"巴基斯坦亲伊朗示威者强闯美领馆，高喊“将为我们领袖的死复仇”：造成至少9人死亡","content":"综合法新社与美联社消息，据当地当局称，周日数百名抗议者冲击巴基斯坦港口城市卡拉奇的美国领事馆后，与警方及准军事部队发生暴力冲突，造成至少9人死亡，约24人受伤，其中部分伤势危重。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260301-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E4%BA%B2%E4%BC%8A%E6%9C%97%E7%A4%BA%E5%A8%81%E8%80%85%E5%BC%BA%E9%97%AF%E7%BE%8E%E9%A2%86%E9%A6%86%EF%BC%8C%E9%AB%98%E5%96%8A-%E5%B0%86%E4%B8%BA%E6%88%91%E4%BB%AC%E9%A2%86%E8%A2%96%E7%9A%84%E6%AD%BB%E5%A4%8D%E4%BB%87-%E9%80%A0%E6%88%90%E8%87%B3%E5%B0%919%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772359468000.webp","sourceId":"rfi"},{"id":1772358709000,"createdDate":"2026-03-01 09:51","name":"法国国际广播电台","title":"伊拉克宣布为哈梅内伊举行三天全国哀悼 数百名抗议者试图攻入巴格达的美国使馆","content":"在以色列和美国对伊朗的空袭中，伊朗最高领袖阿亚图拉·阿里·哈梅内伊去世后，伊拉克于周日（3月1日）宣布为期三天的全国哀悼。此外，周日早晨，数百名抗议者试图冲击位于巴格达的美国大使馆高度戒备区域。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260301-%E4%BC%8A%E6%8B%89%E5%85%8B%E5%AE%A3%E5%B8%83%E4%B8%BA%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E4%B8%BE%E8%A1%8C%E4%B8%89%E5%A4%A9%E5%85%A8%E5%9B%BD%E5%93%80%E6%82%BC-%E6%95%B0%E7%99%BE%E5%90%8D%E6%8A%97%E8%AE%AE%E8%80%85%E8%AF%95%E5%9B%BE%E6%94%BB%E5%85%A5%E5%B7%B4%E6%A0%BC%E8%BE%BE%E7%9A%84%E7%BE%8E%E5%9B%BD%E4%BD%BF%E9%A6%86","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772358709000.webp","sourceId":"rfi"},{"id":1772357396000,"createdDate":"2026-03-01 09:29","name":"法国国际广播电台","title":"日本发表伊朗局势谈话  原经产相表示大国打破国际规则的时代到来","content":"日本时间2月28日，美国和以色列宣布已对伊朗实施攻击,伊朗最高领袖阿里·哈梅内伊在袭击中身亡，为此，日本外务大臣茂木敏充3月1日发表谈话，表示希望尽管平息局势，而日本原经产大臣斎藤健表示：“大国公然打破国际规则的时代正在到来。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260301-%E6%97%A5%E6%9C%AC%E5%8F%91%E8%A1%A8%E4%BC%8A%E6%9C%97%E5%B1%80%E5%8A%BF%E8%B0%88%E8%AF%9D-%E5%8E%9F%E7%BB%8F%E4%BA%A7%E7%9B%B8%E8%A1%A8%E7%A4%BA%E5%A4%A7%E5%9B%BD%E6%89%93%E7%A0%B4%E5%9B%BD%E9%99%85%E8%A7%84%E5%88%99%E7%9A%84%E6%97%B6%E4%BB%A3%E5%88%B0%E6%9D%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772357396000.webp","sourceId":"rfi"},{"id":1772357319000,"createdDate":"2026-03-01 09:28","name":"法国国际广播电台","title":"《纽约时报》披露击毙细节：中情局提前掌握哈梅内伊周六开会行程，后与以色列共享情报","content":"法新社援引《纽约时报》周日的报道称，美国中央情报局（CIA）获悉阿里·哈梅内伊原定于周六上午在德黑兰参加一次高级别会议，这一情报使美以军方得以将其锁定并实施打击。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260301-%E7%BA%BD%E7%BA%A6%E6%97%B6%E6%8A%A5-%E6%8A%AB%E9%9C%B2%E5%87%BB%E6%AF%99%E7%BB%86%E8%8A%82-%E4%B8%AD%E6%83%85%E5%B1%80%E6%8F%90%E5%89%8D%E6%8E%8C%E6%8F%A1%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E5%91%A8%E5%85%AD%E5%BC%80%E4%BC%9A%E8%A1%8C%E7%A8%8B%EF%BC%8C%E5%90%8E%E4%B8%8E%E4%BB%A5%E8%89%B2%E5%88%97%E5%85%B1%E4%BA%AB%E6%83%85%E6%8A%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772357319000.webp","sourceId":"rfi"},{"id":1772356087000,"createdDate":"2026-03-01 09:08","name":"法国国际广播电台","title":"美以袭击伊朗：中国“深表关切”呼吁立即停火  敦促侨民撤离","content":"美国和以色列周六对伊朗发动袭击，目标是其军事能力。据伊朗国家媒体证实，伊朗最高领袖阿里·哈梅内伊在行动中丧生。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260301-%E7%BE%8E%E4%BB%A5%E8%A2%AD%E5%87%BB%E4%BC%8A%E6%9C%97-%E4%B8%AD%E5%9B%BD-%E6%B7%B1%E8%A1%A8%E5%85%B3%E5%88%87-%E5%91%BC%E5%90%81%E7%AB%8B%E5%8D%B3%E5%81%9C%E7%81%AB-%E6%95%A6%E4%BF%83%E4%BE%A8%E6%B0%91%E6%92%A4%E7%A6%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772356087000.webp","sourceId":"rfi"},{"id":1772356023000,"createdDate":"2026-03-01 09:07","name":"法国国际广播电台","title":"伊朗寻求报复：多哈、迪拜等多地遭导弹袭击，阿联酋至少2人死亡","content":"周六（3月1日）美国和以色列联合行动并导致哈梅内伊身亡，伊朗寻求报复，接连对海湾地区大部分君主制国家进行了空袭，导致至少两人在阿联酋死亡，引发了该地区可能爆发冲突的担忧。法新社记者周日早晨目击了卡塔尔多哈、阿联酋迪拜以及巴林首都马纳马的爆炸。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260301-%E4%BC%8A%E6%9C%97%E5%AF%BB%E6%B1%82%E6%8A%A5%E5%A4%8D-%E5%A4%9A%E5%93%88-%E8%BF%AA%E6%8B%9C%E7%AD%89%E5%A4%9A%E5%9C%B0%E9%81%AD%E5%AF%BC%E5%BC%B9%E8%A2%AD%E5%87%BB%EF%BC%8C%E9%98%BF%E8%81%94%E9%85%8B%E8%87%B3%E5%B0%912%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772356023000.webp","sourceId":"rfi"},{"id":1772355077000,"createdDate":"2026-03-01 08:51","name":"法国国际广播电台","title":"医生是个克隆人——人工智能步入中国医院临床应用","content":"在怀孕期间，一名上海女性咨询了当地一位知名的妇产科医生，但她从未踏入过医生的诊室：她是通过人工智能（AI）驱动的数字克隆人与医生进行交流的。","newsLink":"https://www.rfi.fr/cn/%E5%8C%BB%E7%94%9F%E6%98%AF%E4%B8%AA%E5%85%8B%E9%9A%86%E4%BA%BA-%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E6%AD%A5%E5%85%A5%E4%B8%AD%E5%9B%BD%E5%8C%BB%E9%99%A2%E4%B8%B4%E5%BA%8A%E5%BA%94%E7%94%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772355077000.webp","sourceId":"rfi"},{"id":1772406709000,"createdDate":"2026-03-01 23:11","name":"法国国际广播电台","title":"非洲古巴音乐的马里名笛手逝世","content":"在非洲内陆国马里首都巴马科（Bamako），2026年02月28日去世的音乐人BoncanaMaïga是一位著名的长笛演奏家。他也是非洲古巴音乐（lamusiqueafro-cubaine）的重要名人之一，曾创立了[马里奇观乐团]（西班牙文：LasMaravillasdelMali）和[非洲乐团]（Africando）等极具象征性的乐队。此外，他也是一位才华横溢的制作人。本台法广非洲组（RFIAfrique）报道引述马里官方消息说，BoncanaMaïga的葬礼定于2026年03月01日星期天在其位于巴马科的故居举行。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260301-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2%E5%8F%A4%E5%B7%B4%E9%9F%B3%E4%B9%90%E7%9A%84%E9%A9%AC%E9%87%8C%E5%90%8D%E7%AC%9B%E6%89%8B%E9%80%9D%E4%B8%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772406709000.webp","sourceId":"rfi"},{"id":1772400474000,"createdDate":"2026-03-01 21:27","name":"法国国际广播电台","title":"媒体分析：美以联手打伊朗 痛到北京中南海","content":"美国总统特朗普联手以色列攻击伊朗，并呼吁推翻伊朗政权。如何看待这对中国的影响？","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260301-%E5%AA%92%E4%BD%93%E5%88%86%E6%9E%90-%E7%BE%8E%E4%BB%A5%E8%81%94%E6%89%8B%E6%89%93%E4%BC%8A%E6%9C%97-%E7%97%9B%E5%88%B0%E5%8C%97%E4%BA%AC%E4%B8%AD%E5%8D%97%E6%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772400474000.webp","sourceId":"rfi"},{"id":1772399642000,"createdDate":"2026-03-01 21:14","name":"法国国际广播电台","title":"法英德采取“防御行动”以“摧毁”伊朗的军力","content":"德国、法国和英国领导人周日表示，他们已做好准备，采取“必要且适度的防御行动”，以应对伊朗旨在“从源头上摧毁”德黑兰军事能力的报复性打击。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260301-%E6%B3%95%E8%8B%B1%E5%BE%B7%E9%87%87%E5%8F%96-%E9%98%B2%E5%BE%A1%E8%A1%8C%E5%8A%A8-%E4%BB%A5-%E6%91%A7%E6%AF%81-%E4%BC%8A%E6%9C%97%E7%9A%84%E5%86%9B%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772399642000.webp","sourceId":"rfi"},{"id":1772399372000,"createdDate":"2026-03-01 21:09","name":"法国国际广播电台","title":"巴黎数千名伊朗人欢庆离自由近了一步","content":"哈梅内伊身亡后，数千名伊朗民众于3月1日在巴黎举行示威游行。他们高喊：“我们离自由更近了一步”。一些示威民众不希望恢复君主制，而是希望国内有彻底的权力更替。当天数千人在德国各地举行示威游行，声援“伊朗自由”。1800人在勃兰登堡门前聚集，载歌载舞，挥舞着伊朗、以色列和美国的国旗。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260301-%E5%B7%B4%E9%BB%8E%E6%95%B0%E5%8D%83%E5%90%8D%E4%BC%8A%E6%9C%97%E4%BA%BA%E6%AC%A2%E5%BA%86%E7%A6%BB%E8%87%AA%E7%94%B1%E8%BF%91%E4%BA%86%E4%B8%80%E6%AD%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772399372000.webp","sourceId":"rfi"},{"id":1772399226000,"createdDate":"2026-03-01 21:07","name":"法国国际广播电台","title":"马克龙：法国将提升其在海湾地区的军事“态势”","content":"美国总统特朗普声称“9艘伊朗船只”已被击沉。美国军方表示，已摧毁伊朗革命卫队总部。美国中央司令部在X频道发布声明称：“伊朗伊斯兰革命卫队（IRGC）在过去47年中杀害了超过1000名美国人。昨天，美国的大规模打击斩首了这条毒蛇。美国拥有地球上最强大的武装力量，而伊朗伊斯兰革命卫队如今已无总部可言。”发表声明的同时还附上了一段驱逐舰发射导弹的视频。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260301-%E9%A9%AC%E5%85%8B%E9%BE%99-%E6%B3%95%E5%9B%BD%E5%B0%86%E6%8F%90%E5%8D%87%E5%85%B6%E5%9C%A8%E6%B5%B7%E6%B9%BE%E5%9C%B0%E5%8C%BA%E7%9A%84%E5%86%9B%E4%BA%8B-%E6%80%81%E5%8A%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772399226000.webp","sourceId":"rfi"},{"id":1772399036000,"createdDate":"2026-03-01 21:03","name":"法国国际广播电台","title":"中国谴责哈梅内伊遇袭身亡","content":"中国周日谴责了美国和以色列对伊朗首都发动的袭击中，伊朗最高领袖阿里·哈梅内伊（AliKhamenei）遇袭身亡的事件。中国外交部在一份通过美国X公司社交媒体平台发布的声明中表示：“袭击和杀害伊朗最高领袖是对伊朗主权和安全的严重侵犯。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260301-%E4%B8%AD%E5%9B%BD%E8%B0%B4%E8%B4%A3%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E9%81%87%E8%A2%AD%E8%BA%AB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772399036000.webp","sourceId":"rfi"},{"id":1772398880000,"createdDate":"2026-03-01 21:01","name":"法国国际广播电台","title":"三名美军在对伊朗的行动中丧生","content":"美国中央司令部（Centcom）周日宣布，在对伊朗的军事行动中，三名美军士兵阵亡，五名士兵重伤，这是美军在此次冲突中首次出现伤亡。中央司令部在声明中没有透露阵亡士兵的具体位置和身份。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260301-%E4%B8%89%E5%90%8D%E7%BE%8E%E5%86%9B%E5%9C%A8%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%9A%84%E8%A1%8C%E5%8A%A8%E4%B8%AD%E4%B8%A7%E7%94%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772398880000.webp","sourceId":"rfi"},{"id":1772398771000,"createdDate":"2026-03-01 20:59","name":"法国国际广播电台","title":"2026年巴黎农展会参观人数降27.9%","content":"2026年巴黎国际农业展（SIA）的参观人数比往年下降了27.9%，农展主席周日承认，由于缺少牛群，本届展会将“与以往任何一届都截然不同”，但他同时保证明年将会改观。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260301-2026%E5%B9%B4%E5%B7%B4%E9%BB%8E%E5%86%9C%E5%B1%95%E4%BC%9A%E5%8F%82%E8%A7%82%E4%BA%BA%E6%95%B0%E9%99%8D27-9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772398771000.webp","sourceId":"rfi"},{"id":1772398615000,"createdDate":"2026-03-01 20:56","name":"法国国际广播电台","title":"两架无人机袭击法驻阿联酋海军基地    两个集装箱起火","content":"法军长期驻扎阿联酋海军基地3月1日遭到伊朗发射的两架无人机的袭击，法国国防部长证实了上述消息，但没有提供详情。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260301-%E4%B8%A4%E6%9E%B6%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB%E6%B3%95%E9%A9%BB%E9%98%BF%E8%81%94%E9%85%8B%E6%B5%B7%E5%86%9B%E5%9F%BA%E5%9C%B0-%E4%B8%A4%E4%B8%AA%E9%9B%86%E8%A3%85%E7%AE%B1%E8%B5%B7%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772398615000.webp","sourceId":"rfi"},{"id":1772398239000,"createdDate":"2026-03-01 20:50","name":"法国国际广播电台","title":"60艘法国船舶滞留波斯湾","content":"据法国船东协会（ArmateursdeFrance）主席洛朗·马滕斯（LaurentMartens）证实，60艘悬挂法国国旗或属于法国公司的船只被迫滞留在波斯湾。他周日解释说，这些船只途经霍尔木兹海峡后接到法国海军的指示，不得不避航。他还补充说，这些法国船只并非优先攻击目标。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260301-60%E8%89%98%E6%B3%95%E5%9B%BD%E8%88%B9%E8%88%B6%E6%BB%9E%E7%95%99%E6%B3%A2%E6%96%AF%E6%B9%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772398239000.webp","sourceId":"rfi"},{"id":1772397922000,"createdDate":"2026-03-01 20:45","name":"法国国际广播电台","title":"从3月1日起法国对小额包裹收2欧元税费","content":"从3月1日开始，来自欧盟以外国家、价值低于150欧元的包裹将被征收新税。平台可能会将这部分成本转嫁给消费者。来自欧盟以外、低于150欧元的包裹将被征收每件2欧元的附加税。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260301-%E4%BB%8E3%E6%9C%881%E6%97%A5%E8%B5%B7%E6%B3%95%E5%9B%BD%E5%AF%B9%E5%B0%8F%E9%A2%9D%E5%8C%85%E8%A3%B9%E6%94%B62%E6%AC%A7%E5%85%83%E7%A8%8E%E8%B4%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772397922000.webp","sourceId":"rfi"},{"id":1772397581000,"createdDate":"2026-03-01 20:39","name":"法国国际广播电台","title":"哈梅内伊之死让世界更加分裂与对立？","content":"伊朗最高领袖哈梅内伊（AliKhamenei）2月28日死于美国和以色列联手空袭。这一消息开始令人难以置信，但立即得到伊朗部分民众的欢迎，而另一部分伊朗人则表示悲痛和愤怒。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260301-%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E4%B9%8B%E6%AD%BB%E8%AE%A9%E4%B8%96%E7%95%8C%E6%9B%B4%E5%8A%A0%E5%88%86%E8%A3%82%E4%B8%8E%E5%AF%B9%E7%AB%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772397581000.webp","sourceId":"rfi"},{"id":1772392318000,"createdDate":"2026-03-01 19:11","name":"法国国际广播电台","title":"非洲多方对美以打击伊朗的反应","content":"非洲大陆上的国家和泛非组织纷纷对美国和以色列于昨天（2026年02月28日周六）发起打击伊朗的行动做出反应。本台法广非洲组（RFIAfrique)的法文报道说，部分国家呼吁缓和事态，另有一些国家则立场清晰。这是本台法广非洲组（RFIAfrique）今天2026年03月01号星期日上网的最新法文消息之一。[非洲联盟]（UA）和[金砖组织]（BRICS）成员国之一南非(AfriqueduSud)的态度都是焦点。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260301-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2%E5%A4%9A%E6%96%B9%E5%AF%B9%E7%BE%8E%E4%BB%A5%E6%89%93%E5%87%BB%E4%BC%8A%E6%9C%97%E7%9A%84%E5%8F%8D%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772392318000.webp","sourceId":"rfi"},{"id":1772384778000,"createdDate":"2026-03-01 17:06","name":"法国国际广播电台","title":"《法兰克福汇报》：特朗普成了干预主义者","content":"据《南德意志报》报道：面对中东局势升级，德国总理默茨（基民盟）于周六谴责伊朗，却未批评以色列和美国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260301-%E6%B3%95%E5%85%B0%E5%85%8B%E7%A6%8F%E6%B1%87%E6%8A%A5-%E7%89%B9%E6%9C%97%E6%99%AE%E6%88%90%E4%BA%86%E5%B9%B2%E9%A2%84%E4%B8%BB%E4%B9%89%E8%80%85","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772384778000.webp","sourceId":"rfi"},{"id":1772384215000,"createdDate":"2026-03-01 16:56","name":"法国国际广播电台","title":"特朗普对伊动武未经国会授权 参众两院酝酿表决制衡总统权力","content":"美国总统特朗普（DonaldTrump）未经国会正式授权，下令与以色列对伊朗展开大规模军事行动，并在空袭中击毙伊朗最高领袖哈梅内伊（AyatollahAliKhamenei），震撼国会。美国国会两院多名议员随即要求迅速就《战争权力决议案》进行表决，限制总统动武权限，警告此举可能违宪且将美国拖入另一场中东长期战争。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260301-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AF%B9%E4%BC%8A%E5%8A%A8%E6%AD%A6%E6%9C%AA%E7%BB%8F%E5%9B%BD%E4%BC%9A%E6%8E%88%E6%9D%83-%E5%8F%82%E4%BC%97%E4%B8%A4%E9%99%A2%E9%85%9D%E9%85%BF%E8%A1%A8%E5%86%B3%E5%88%B6%E8%A1%A1%E6%80%BB%E7%BB%9F%E6%9D%83%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/01/1772384215000.webp","sourceId":"rfi"}]