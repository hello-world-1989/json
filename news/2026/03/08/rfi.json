[{"id":1772959546000,"createdDate":"2026-03-08 08:45","name":"法国国际广播电台","title":"台湾现职行政院长时隔54年访日","content":"台湾行政院长卓荣泰7日访问日本，并在东京巨蛋观看了正在举行的世界棒球经典赛（WBC）。日本与台湾没有外交关系，现任行政院长访日极为罕见，除过境或航班紧急降落等情况外，自1972年日台断交以来，这是台湾现任行政院长时隔54年首次访日并被媒体披露。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260308-%E5%8F%B0%E6%B9%BE%E7%8E%B0%E8%81%8C%E8%A1%8C%E6%94%BF%E9%99%A2%E9%95%BF%E6%97%B6%E9%9A%9454%E5%B9%B4%E8%AE%BF%E6%97%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772959546000.webp","sourceId":"rfi"},{"id":1772958394000,"createdDate":"2026-03-08 08:26","name":"法国国际广播电台","title":"挪威奥斯陆美国大使馆前发生爆炸","content":"挪威警方宣布，在周六晚至周日（3月8日）凌晨，奥斯陆美国大使馆前发生了一起强烈爆炸，但没有造成人员伤亡。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260308-%E6%8C%AA%E5%A8%81%E5%A5%A5%E6%96%AF%E9%99%86%E7%BE%8E%E5%9B%BD%E5%A4%A7%E4%BD%BF%E9%A6%86%E5%89%8D%E5%8F%91%E7%94%9F%E7%88%86%E7%82%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772958394000.webp","sourceId":"rfi"},{"id":1772982741000,"createdDate":"2026-03-08 15:12","name":"法国国际广播电台","title":"乌克兰的无人机专家下周将前往中东，帮助应对伊朗的无人机 ，泽连斯基希望换取美国“爱国者”防空系统导弹","content":"乌克兰总统泽连斯基周日(3月8日)表示，乌克兰的无人机专家“下周”将前往中东。基辅希望通过分享其在应对伊朗设计无人机方面积累的经验，换取对其防空至关重要的导弹。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260308-%E4%B9%8C%E5%85%8B%E5%85%B0%E7%9A%84%E6%97%A0%E4%BA%BA%E6%9C%BA%E4%B8%93%E5%AE%B6%E4%B8%8B%E5%91%A8%E5%B0%86%E5%89%8D%E5%BE%80%E4%B8%AD%E4%B8%9C%EF%BC%8C%E5%B8%AE%E5%8A%A9%E5%BA%94%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%9A%84%E6%97%A0%E4%BA%BA%E6%9C%BA-%EF%BC%8C%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%B8%8C%E6%9C%9B%E6%8D%A2%E5%8F%96%E7%BE%8E%E5%9B%BD-%E7%88%B1%E5%9B%BD%E8%80%85-%E9%98%B2%E7%A9%BA%E7%B3%BB%E7%BB%9F%E5%AF%BC%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772982741000.webp","sourceId":"rfi"},{"id":1772982181000,"createdDate":"2026-03-08 15:03","name":"法国国际广播电台","title":"马克龙将于周一前往塞浦路斯，以示“声援与支持”","content":"法国总统府爱丽舍宫周日宣布，马克龙将于周一(3月9日)前往塞浦路斯，以“表达法国的声援与支持”。上周，塞浦路斯因中东冲突相关的无人机和导弹袭击而受到打击。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260308-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%B0%86%E4%BA%8E%E5%91%A8%E4%B8%80%E5%89%8D%E5%BE%80%E5%A1%9E%E6%B5%A6%E8%B7%AF%E6%96%AF%EF%BC%8C%E4%BB%A5%E7%A4%BA-%E5%A3%B0%E6%8F%B4%E4%B8%8E%E6%94%AF%E6%8C%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772982181000.webp","sourceId":"rfi"},{"id":1772981425000,"createdDate":"2026-03-08 14:50","name":"法国国际广播电台","title":"“三八”国际妇女权利日：法国一女子协会建立虚拟博物馆  展示塑造电子游戏生态系统的女性人物","content":"致力于推动电子游戏行业性别平等的协会“法国电子游戏女性协会”（WomeninGamesFrance）与Endorah团队合作，在《我的世界》游戏中推出一座虚拟博物馆，以纪念和展示电子游戏行业中的女性贡献者。该项目于周日（3月8日）国际妇女权利日当天上线。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260308-%E4%B8%89%E5%85%AB-%E5%9B%BD%E9%99%85%E5%A6%87%E5%A5%B3%E6%9D%83%E5%88%A9%E6%97%A5-%E6%B3%95%E5%9B%BD%E4%B8%80%E5%A5%B3%E5%AD%90%E5%8D%8F%E4%BC%9A%E5%BB%BA%E7%AB%8B%E8%99%9A%E6%8B%9F%E5%8D%9A%E7%89%A9%E9%A6%86-%E5%B1%95%E7%A4%BA%E5%A1%91%E9%80%A0%E7%94%B5%E5%AD%90%E6%B8%B8%E6%88%8F%E7%94%9F%E6%80%81%E7%B3%BB%E7%BB%9F%E7%9A%84%E5%A5%B3%E6%80%A7%E4%BA%BA%E7%89%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772981425000.webp","sourceId":"rfi"},{"id":1772971174000,"createdDate":"2026-03-08 11:59","name":"法国国际广播电台","title":"黎巴嫩官员向法新社透露：包括外交官在内的117名伊朗人，昨夜已乘俄罗斯飞机撤离，但未透露目的地","content":"周日（3月8日）一名要求匿名的黎巴嫩官员向法新社透露，一百多名伊朗人，包括外交官，已于昨夜从贝鲁特乘坐俄罗斯飞机撤离。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260308-%E9%BB%8E%E5%B7%B4%E5%AB%A9%E5%AE%98%E5%91%98%E5%90%91%E6%B3%95%E6%96%B0%E7%A4%BE%E9%80%8F%E9%9C%B2-%E5%8C%85%E6%8B%AC%E5%A4%96%E4%BA%A4%E5%AE%98%E5%9C%A8%E5%86%85%E7%9A%84117%E5%90%8D%E4%BC%8A%E6%9C%97%E4%BA%BA%EF%BC%8C%E6%98%A8%E5%A4%9C%E5%B7%B2%E4%B9%98%E5%9D%90%E4%BF%84%E7%BD%97%E6%96%AF%E9%A3%9E%E6%9C%BA%E6%92%A4%E7%A6%BB%EF%BC%8C%E4%BD%86%E6%9C%AA%E9%80%8F%E9%9C%B2%E7%9B%AE%E7%9A%84%E5%9C%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772971174000.webp","sourceId":"rfi"},{"id":1772969701000,"createdDate":"2026-03-08 11:35","name":"法国国际广播电台","title":"哈梅内伊继任者人被确定但没公布，伊朗燃料断供","content":"负责选择伊朗新任最高领袖的宗教机构伊朗88名专家会议成员已于周日已经完成任命投票，但还没有公布人选。法新社援引据伊朗梅尔通讯社报道，专家会议成员阿拉莫霍达表示：“人选已经确定”。他说，他们的秘书处稍后将公布人选。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260308-%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E7%BB%A7%E4%BB%BB%E8%80%85%E4%BA%BA%E8%A2%AB%E7%A1%AE%E5%AE%9A%E4%BD%86%E6%B2%A1%E5%85%AC%E5%B8%83%EF%BC%8C%E4%BC%8A%E6%9C%97%E7%87%83%E6%96%99%E6%96%AD%E4%BE%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772969701000.webp","sourceId":"rfi"},{"id":1772969663000,"createdDate":"2026-03-08 11:34","name":"法国国际广播电台","title":"韩国乌山基地的美军大型运输机近期纷纷离开韩国，引发可能往中东地区调遣的猜测","content":"曾集结在韩国京畿jī道平泽市乌山基地的美军大型运输机近期纷纷离开韩国，韩联社说这引发外界对驻韩美军防空武器或被调遣往中东地区的猜测，但也不能排除乌山基地近期的频繁动向与将于9日启动的韩美“自由护盾”联合军演有关。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260308-%E9%9F%A9%E5%9B%BD%E4%B9%8C%E5%B1%B1%E5%9F%BA%E5%9C%B0%E7%9A%84%E7%BE%8E%E5%86%9B%E5%A4%A7%E5%9E%8B%E8%BF%90%E8%BE%93%E6%9C%BA%E8%BF%91%E6%9C%9F%E7%BA%B7%E7%BA%B7%E7%A6%BB%E5%BC%80%E9%9F%A9%E5%9B%BD%EF%BC%8C%E5%BC%95%E5%8F%91%E5%8F%AF%E8%83%BD%E5%BE%80%E4%B8%AD%E4%B8%9C%E5%9C%B0%E5%8C%BA%E8%B0%83%E9%81%A3%E7%9A%84%E7%8C%9C%E6%B5%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772969663000.webp","sourceId":"rfi"},{"id":1772968096000,"createdDate":"2026-03-08 11:08","name":"法国国际广播电台","title":"台日重大突破：断交54年后，首位阁揆踏上日本领土看球赛","content":"台湾行政院长卓荣泰7日亲赴东京看球替台湾队加油。这是自1972年台日断交以来，54年来首位踏上日本领土的现任行政院长。日媒称这是外交突破，也是台日关系的重大进展。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260308-%E5%8F%B0%E6%97%A5%E9%87%8D%E5%A4%A7%E7%AA%81%E7%A0%B4-%E6%96%AD%E4%BA%A454%E5%B9%B4%E5%90%8E%EF%BC%8C%E9%A6%96%E4%BD%8D%E9%98%81%E6%8F%86%E8%B8%8F%E4%B8%8A%E6%97%A5%E6%9C%AC%E9%A2%86%E5%9C%9F%E7%9C%8B%E7%90%83%E8%B5%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772968096000.webp","sourceId":"rfi"},{"id":1772964035000,"createdDate":"2026-03-08 10:00","name":"法国国际广播电台","title":"伊朗称有能力至少再战六个月，并持续袭击海湾国家，海水淡化厂成为攻击目标","content":"中东的冲突进入第九天。伊朗星期日(3月8日)表示，有能力继续与美国和以色列至少再打六个月的战争。与此同时，海湾国家夜间遭袭，海水淡化厂成为攻击新目标。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260308-%E4%BC%8A%E6%9C%97%E7%A7%B0%E6%9C%89%E8%83%BD%E5%8A%9B%E8%87%B3%E5%B0%91%E5%86%8D%E6%88%98%E5%85%AD%E4%B8%AA%E6%9C%88%EF%BC%8C%E5%B9%B6%E6%8C%81%E7%BB%AD%E8%A2%AD%E5%87%BB%E6%B5%B7%E6%B9%BE%E5%9B%BD%E5%AE%B6%EF%BC%8C%E6%B5%B7%E6%B0%B4%E6%B7%A1%E5%8C%96%E5%8E%82%E6%88%90%E4%B8%BA%E6%94%BB%E5%87%BB%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772964035000.webp","sourceId":"rfi"},{"id":1772962932000,"createdDate":"2026-03-08 09:42","name":"法国国际广播电台","title":"中国外长王毅：希望2026年成为中美关系的“标志性年份”  但仍未确认3月底的“特习会”","content":"周日（3月8日）上午，中国外交部举行新闻发布会，外交部长王毅就“中国外交政策和对外关系”相关问题回答中外记者提问，对国际事务进行了全面概述。他称，希望2026年成为中美关系走向健康、稳定、可持续发展的一个标志性年份。预计本月底两国领导人将会面，美联社认为，这场新闻发布会传达了总体来说相对积极的信号。法新社则判断，中国并未最终确认特习会，因此这场新闻发布会只是重述了中美关系的基本原则。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260308-%E4%B8%AD%E5%9B%BD%E5%A4%96%E9%95%BF%E7%8E%8B%E6%AF%85-%E5%B8%8C%E6%9C%9B2026%E5%B9%B4%E6%88%90%E4%B8%BA%E4%B8%AD%E7%BE%8E%E5%85%B3%E7%B3%BB%E7%9A%84-%E6%A0%87%E5%BF%97%E6%80%A7%E5%B9%B4%E4%BB%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772962932000.webp","sourceId":"rfi"},{"id":1772960902000,"createdDate":"2026-03-08 09:08","name":"法国国际广播电台","title":"四座油库遭袭后：德黑兰暂时中断燃料供应  特朗普称对与伊朗谈判不感兴趣","content":"伊朗一名官员周日（3月8日）表示，夜间美国和以色列对德黑兰及周边地区的四处油库以及一个石油产品物流基地发动袭击，造成四人死亡。在连夜轰炸的同时，特朗普称对与伊朗谈判不感兴趣。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260308-%E7%BE%8E%E5%9B%BD%E4%BB%A5%E8%89%B2%E5%88%97%E8%BF%9E%E5%A4%9C%E8%BD%B0%E7%82%B8%E5%BE%B7%E9%BB%91%E5%85%B0%E5%9B%9B%E5%BA%A7%E6%B2%B9%E5%BA%93-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E5%AF%B9%E4%B8%8E%E5%BE%B7%E9%BB%91%E5%85%B0%E8%B0%88%E5%88%A4%E4%B8%8D%E6%84%9F%E5%85%B4%E8%B6%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772960902000.webp","sourceId":"rfi"},{"id":1772959903000,"createdDate":"2026-03-08 08:51","name":"法国国际广播电台","title":"黎巴嫩：以色列空袭贝鲁特旅游区一家酒店，造成至少4人死亡","content":"黎巴嫩卫生部星期日（3月8日）宣布，以色列对贝鲁特市中心一家酒店发动的空袭已造成至少4人死亡、10人受伤。以色列方面则表示，之所以发动袭击，是因为酒店有驻扎在黎巴嫩首都的伊朗伊斯兰革命卫队指挥官。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260308-%E9%BB%8E%E5%B7%B4%E5%AB%A9-%E4%BB%A5%E8%89%B2%E5%88%97%E7%A9%BA%E8%A2%AD%E8%B4%9D%E9%B2%81%E7%89%B9%E6%97%85%E6%B8%B8%E5%8C%BA%E4%B8%80%E5%AE%B6%E9%85%92%E5%BA%97%EF%BC%8C%E9%80%A0%E6%88%90%E8%87%B3%E5%B0%914%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772959903000.webp","sourceId":"rfi"},{"id":1773012266000,"createdDate":"2026-03-08 23:24","name":"法国国际广播电台","title":"伊朗战争：美以军事优势明显，但未来仍然充满着不确定性","content":"在美国和以色列对伊朗发动“史诗之怒”军事行动一个多星期后，美国和以色列的军事优势明显，在战场上取得了显著的成果，且几乎没有遭受重大的损失。但未来仍然充满着不确定性。美以两国仍然没有明确战争的最终目标，与此同时，中东地区的局势也日益混乱。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%9B%BD%E9%99%85%E7%BA%B5%E6%A8%AA/20260308-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89-%E7%BE%8E%E4%BB%A5%E5%86%9B%E4%BA%8B%E4%BC%98%E5%8A%BF%E6%98%8E%E6%98%BE%EF%BC%8C%E4%BD%86%E6%9C%AA%E6%9D%A5%E4%BB%8D%E7%84%B6%E5%85%85%E6%BB%A1%E7%9D%80%E4%B8%8D%E7%A1%AE%E5%AE%9A%E6%80%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1773012266000.webp","sourceId":"rfi"},{"id":1773006448000,"createdDate":"2026-03-08 21:47","name":"法国国际广播电台","title":"特朗普称赞梅洛尼是“伟大领袖” 从何说起","content":"美国总统特朗普在日前访谈中称赞意大利愿在伊朗战争中援助美国和以色列，意大利总理梅洛尼被特朗普封为是“伟大领袖”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260308-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E8%B5%9E%E6%A2%85%E6%B4%9B%E5%B0%BC%E6%98%AF-%E4%BC%9F%E5%A4%A7%E9%A2%86%E8%A2%96-%E4%BB%8E%E4%BD%95%E8%AF%B4%E8%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1773006448000.webp","sourceId":"rfi"},{"id":1773004887000,"createdDate":"2026-03-08 21:21","name":"法国国际广播电台","title":"美以开战伊朗：美军阵亡添一人 以军首度有士兵阵亡","content":"美国军方8日宣布，一名在沙特阿拉伯服役的军人在伊朗攻击中受伤，不幸身亡，成为战争爆发以来第7位阵亡美军。以色列军方8日也通报战争爆发以来首度有士兵阵亡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260308-%E7%BE%8E%E4%BB%A5%E5%BC%80%E6%88%98%E4%BC%8A%E6%9C%97-%E7%BE%8E%E5%86%9B%E9%98%B5%E4%BA%A1%E6%B7%BB%E4%B8%80%E4%BA%BA-%E4%BB%A5%E5%86%9B%E9%A6%96%E5%BA%A6%E6%9C%89%E5%A3%AB%E5%85%B5%E9%98%B5%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1773004887000.webp","sourceId":"rfi"},{"id":1773003746000,"createdDate":"2026-03-08 21:02","name":"法国国际广播电台","title":"伊官宣：哈梅内伊的儿子为新一届精神领袖","content":"法国总统马克龙周日分别与美国总统特朗普和伊朗总统马苏德·佩泽希齐扬通话。另据最新消息，伊朗宗教领袖哈梅内伊在美以袭击行动中丧生一周之后，伊朗8日宣布，哈梅内伊的儿子穆杰塔巴·哈梅内伊为新一届精神领袖，伊朗官方刚刚公布这一消息。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260308-%E9%A9%AC%E5%85%8B%E9%BE%99%E4%B8%8E%E7%89%B9%E6%9C%97%E6%99%AE%E5%92%8C%E4%BC%8A%E6%9C%97%E6%80%BB%E7%BB%9F%E9%80%9A%E7%94%B5%E8%AF%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1773003746000.webp","sourceId":"rfi"},{"id":1773003645000,"createdDate":"2026-03-08 21:00","name":"法国国际广播电台","title":"斯塔默和特朗普交谈   关注中东冲突","content":"英国首相府8日报道称，英国首相斯塔默和美国总统特朗普周日就中东冲突进行了通话。此前，美国总统多次批评英国领导人对战争的处理方式。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260308-%E6%96%AF%E5%A1%94%E9%BB%98%E5%92%8C%E7%89%B9%E6%9C%97%E6%99%AE%E4%BA%A4%E8%B0%88-%E5%85%B3%E6%B3%A8%E4%B8%AD%E4%B8%9C%E5%86%B2%E7%AA%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1773003645000.webp","sourceId":"rfi"},{"id":1773003473000,"createdDate":"2026-03-08 20:57","name":"法国国际广播电台","title":"美方否认曾空袭伊朗能源基础设施","content":"据伊朗国家石油产品分销公司消息，7日晚，位于伊朗首都德黑兰和厄尔布尔士省的4处储油设施及一处石油产品转运中心遭袭击，导致4名油罐车司机身亡。这是自战争爆发以来，伊朗能源基础设施首次遭到袭击。而美国方面否认空袭了伊朗油设施。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260308-%E7%BE%8E%E6%96%B9%E5%90%A6%E8%AE%A4%E6%9B%BE%E7%A9%BA%E8%A2%AD%E4%BC%8A%E6%9C%97%E8%83%BD%E6%BA%90%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1773003473000.webp","sourceId":"rfi"},{"id":1773003312000,"createdDate":"2026-03-08 20:55","name":"法国国际广播电台","title":"爱护流浪动物   法媒关注中国暖心猫咖","content":"中国的宠物产业迅速发展，但同时也有一些养不起猫、狗的主人丢弃了它们。法国《世界报》记者8日刊文表示：在中国，很多动物因为兽医费用过高而被遗弃。95后的北京青年韩子豪创建的“山谷店”引发了法国记者的极大兴趣。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260308-%E7%88%B1%E6%8A%A4%E6%B5%81%E6%B5%AA%E5%8A%A8%E7%89%A9-%E6%B3%95%E5%AA%92%E5%85%B3%E6%B3%A8%E4%B8%AD%E5%9B%BD%E6%9A%96%E5%BF%83%E7%8C%AB%E5%92%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1773003312000.webp","sourceId":"rfi"},{"id":1773002921000,"createdDate":"2026-03-08 20:48","name":"法国国际广播电台","title":"再拖2分钟    美驻卡塔尔军事基地就会遭炸","content":"美国在卡塔尔的一个空军基地险些遭炸。据美国有线电视新闻网（CNN）周三晚间援引知情人士报道，是卡塔尔击落了两架准备袭击多哈附近乌代德（Al-Udeid）军事基地的伊朗轰炸机。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260308-%E5%86%8D%E6%8B%962%E5%88%86%E9%92%9F-%E7%BE%8E%E9%A9%BB%E5%8D%A1%E5%A1%94%E5%B0%94%E5%86%9B%E4%BA%8B%E5%9F%BA%E5%9C%B0%E5%B0%B1%E4%BC%9A%E9%81%AD%E7%82%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1773002921000.webp","sourceId":"rfi"},{"id":1773002793000,"createdDate":"2026-03-08 20:46","name":"法国国际广播电台","title":"特朗普：“没有我的认可   新领导人呆不长”！","content":"没有特朗普的许可，伊朗新的领导人呆不长。3月8日特朗普在接受美国广播公司（ABC）新闻采访时宣称，伊朗下一任领导人“如果得不到他的认可，他的任期不会长久”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260308-%E7%89%B9%E6%9C%97%E6%99%AE-%E6%B2%A1%E6%9C%89%E6%88%91%E7%9A%84%E8%AE%A4%E5%8F%AF-%E6%96%B0%E9%A2%86%E5%AF%BC%E4%BA%BA%E5%91%86%E4%B8%8D%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1773002793000.webp","sourceId":"rfi"},{"id":1773002688000,"createdDate":"2026-03-08 20:44","name":"法国国际广播电台","title":"法国将主持G7财长视频会议","content":"法国经济和财政部周日宣布，作为七国集团（G7）轮值主席国的法国将于周一通过视频会议主持召开G7财长会议，以“从经济角度评估海湾地区的局势”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260308-%E6%B3%95%E5%9B%BD%E5%B0%86%E4%B8%BB%E6%8C%81g7%E8%B4%A2%E9%95%BF%E8%A7%86%E9%A2%91%E4%BC%9A%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1773002688000.webp","sourceId":"rfi"},{"id":1773002273000,"createdDate":"2026-03-08 20:37","name":"法国国际广播电台","title":"芝加哥枢机主教狠批混剪伊朗战事视频","content":"白宫此前发布了一段关于其在伊朗军事行动的视频。美国芝加哥教区枢机主教布莱斯·库皮奇（BlaseCupich）批评白宫发布的一段将好莱坞电影片段与美军对伊朗发动空袭的真实画面混剪接在一起的视频“令人作呕”且“骇人听闻”。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260308-%E8%8A%9D%E5%8A%A0%E5%93%A5%E6%9E%A2%E6%9C%BA%E4%B8%BB%E6%95%99%E7%8B%A0%E6%89%B9%E6%B7%B7%E5%89%AA%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%8B%E8%A7%86%E9%A2%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1773002273000.webp","sourceId":"rfi"},{"id":1773002065000,"createdDate":"2026-03-08 20:34","name":"法国国际广播电台","title":"德绿党在地方选举中反超默茨领导的保守党","content":"根据不完全统计选举结果，在周日举行的德国巴登-符腾堡州（Bade-Wurtemberg）地方选举中，德国绿党以微弱优势击败了总理默茨领导的保守党。近年来实力显著增强的极右翼政党德国另类选择党（AfD）位列第三，巩固了其作为德国主要反对党的地位。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260308-%E5%BE%B7%E7%BB%BF%E5%85%9A%E5%9C%A8%E5%9C%B0%E6%96%B9%E9%80%89%E4%B8%BE%E4%B8%AD%E5%8F%8D%E8%B6%85%E9%BB%98%E8%8C%A8%E9%A2%86%E5%AF%BC%E7%9A%84%E4%BF%9D%E5%AE%88%E5%85%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1773002065000.webp","sourceId":"rfi"},{"id":1773001852000,"createdDate":"2026-03-08 20:30","name":"法国国际广播电台","title":"中东战争抬升油价创伤南非经济","content":"围绕打击伊朗的本次中东战争对南非的影响之一是抬升的燃油价格危及国家预算。这是本台法广（RFI）非洲通讯员法文报道的一个角度。比勒陀利亚（Pretoria）的石油大量依赖从中东地区的进口。和世界许多国家一样，南非也在担忧中东战争带来的经济影响。对该国的消费者而言，主要影响在于油价上涨，以及南非货币兰特（lerand）兑美元（ledollar）走弱。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260308-%E6%B3%95%E5%B9%BFrfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E6%8A%AC%E5%8D%87%E6%B2%B9%E4%BB%B7%E5%88%9B%E4%BC%A4%E5%8D%97%E9%9D%9E%E7%BB%8F%E6%B5%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1773001852000.webp","sourceId":"rfi"},{"id":1772999764000,"createdDate":"2026-03-08 19:56","name":"法国国际广播电台","title":"巴黎：圣文生·德·保禄教堂圣物“不翼而飞”","content":"保存在巴黎十区的圣文生·德·保禄教堂（Saint-Vincent-de-Paul）内的一件无价之宝于周六“丢失”，很可能是被盗。被盗的圣物原本在一个小型玻璃柜中公开展示。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260308-%E5%B7%B4%E9%BB%8E-%E5%9C%A3%E6%96%87%E7%94%9F%C2%B7%E5%BE%B7%C2%B7%E4%BF%9D%E7%A6%84%E6%95%99%E5%A0%82%E5%9C%A3%E7%89%A9-%E4%B8%8D%E7%BF%BC%E8%80%8C%E9%A3%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772999764000.webp","sourceId":"rfi"},{"id":1772993985000,"createdDate":"2026-03-08 18:19","name":"法国国际广播电台","title":"塞内加尔2026年3.8妇女节新闻","content":"2026年03月08日国际妇女节（Journéeinternationaledesdroitsdesfemmes）来临之际，本台法广（RFI）非洲通讯员发自塞内加尔首都的报道围绕通过小屏幕与针对妇女的暴力行为做斗争。就此，一名接受采访的女权活动人士表示，打算要直接联系一些连续剧的制作公司（lesmaisonsdeproduction），呼吁不要以浪漫式叙述（romancer）妇女所遭受的暴力。在塞内加尔在去年（2025年），至少有18名女性被她们的伴侣杀害。达喀尔当局此刻正在担忧这类暴力事件的增长。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260308-%E6%B3%95%E5%B9%BFrfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%A1%9E%E5%86%85%E5%8A%A0%E5%B0%942026%E5%B9%B43-8%E5%A6%87%E5%A5%B3%E8%8A%82%E6%96%B0%E9%97%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772993985000.webp","sourceId":"rfi"}]