[{"id":1772959546000,"createdDate":"2026-03-08 08:45","name":"法国国际广播电台","title":"台湾现职行政院长时隔54年访日","content":"台湾行政院长卓荣泰7日访问日本，并在东京巨蛋观看了正在举行的世界棒球经典赛（WBC）。日本与台湾没有外交关系，现任行政院长访日极为罕见，除过境或航班紧急降落等情况外，自1972年日台断交以来，这是台湾现任行政院长时隔54年首次访日并被媒体披露。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260308-%E5%8F%B0%E6%B9%BE%E7%8E%B0%E8%81%8C%E8%A1%8C%E6%94%BF%E9%99%A2%E9%95%BF%E6%97%B6%E9%9A%9454%E5%B9%B4%E8%AE%BF%E6%97%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772959546000.webp","sourceId":"rfi"},{"id":1772958394000,"createdDate":"2026-03-08 08:26","name":"法国国际广播电台","title":"挪威奥斯陆美国大使馆前发生爆炸","content":"挪威警方宣布，在周六晚至周日（3月8日）凌晨，奥斯陆美国大使馆前发生了一起强烈爆炸，但没有造成人员伤亡。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260308-%E6%8C%AA%E5%A8%81%E5%A5%A5%E6%96%AF%E9%99%86%E7%BE%8E%E5%9B%BD%E5%A4%A7%E4%BD%BF%E9%A6%86%E5%89%8D%E5%8F%91%E7%94%9F%E7%88%86%E7%82%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/08/1772958394000.webp","sourceId":"rfi"}]