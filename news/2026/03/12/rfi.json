[{"id":1773304760000,"createdDate":"2026-03-12 08:39","name":"法国国际广播电台","title":"美国对16个贸易伙伴展开301“产能过剩”调查，中国台湾名列其中","content":"美国最高法院裁定总统特朗普的“对等关税”政策违法违宪后，特朗普政府周三（3/11）宣布，将对16个主要贸易伙伴的“产能过剩”展开新一轮贸易调查，以重塑关税施压力度，迫使对方继续谈判并履行贸易协议，中国台湾也名列其中。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260312-%E7%BE%8E%E5%9B%BD%E5%AF%B916%E4%B8%AA%E8%B4%B8%E6%98%93%E4%BC%99%E4%BC%B4%E5%B1%95%E5%BC%80301-%E4%BA%A7%E8%83%BD%E8%BF%87%E5%89%A9-%E8%B0%83%E6%9F%A5%EF%BC%8C%E4%B8%AD%E5%9B%BD%E5%8F%B0%E6%B9%BE%E5%90%8D%E5%88%97%E5%85%B6%E4%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773304760000.webp","sourceId":"rfi"},{"id":1773303889000,"createdDate":"2026-03-12 08:24","name":"法国国际广播电台","title":"高市早苗谴责伊朗封锁霍尔木兹海峡 日本放出储备石油","content":"日本首相高市早苗11日参加了七国集团（G7）领导人线上会议，就中东局势进行了磋商。G7领导人对包括日本、美国和欧洲等在内的国际能源署（IEA）成员国决定协调释放石油储备表示欢迎。首相说明称，她已谴责了伊朗在原油运输要冲霍尔木兹海峡威胁航行安全的行为，并要求其立即停止，并表示日本将率先向市场放出储备石油。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260312-%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E8%B0%B4%E8%B4%A3%E4%BC%8A%E6%9C%97%E5%B0%81%E9%94%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E6%97%A5%E6%9C%AC%E6%94%BE%E5%87%BA%E5%82%A8%E5%A4%87%E7%9F%B3%E6%B2%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773303889000.webp","sourceId":"rfi"},{"id":1773300130000,"createdDate":"2026-03-12 07:22","name":"法国国际广播电台","title":"阿里云之父提醒香港创科发展要搞清方向 「不能为人才而人才」","content":"全国人大会议今（12日）午闭幕，会通過包括「十五五」规划纲要在內的多项決议，其中，规划提出要加速建设香港成为国际创科中心的建议。「阿里云之父」王坚接受港媒专访指出，香港要发展创科需先有综合计划，并提醒港府「不能为人才而人才」。评论认为，王坚是侧面点出香港的创科发展规划没有灵魂和目标，只是盲目执行北京指示，担心這只會令香港沦为中国科技企业的提款机。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260312-%E9%98%BF%E9%87%8C%E4%BA%91%E4%B9%8B%E7%88%B6%E6%8F%90%E9%86%92%E9%A6%99%E6%B8%AF%E5%88%9B%E7%A7%91%E5%8F%91%E5%B1%95%E8%A6%81%E6%90%9E%E6%B8%85%E6%96%B9%E5%90%91-%E4%B8%8D%E8%83%BD%E4%B8%BA%E4%BA%BA%E6%89%8D%E8%80%8C%E4%BA%BA%E6%89%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773300130000.webp","sourceId":"rfi"},{"id":1773299789000,"createdDate":"2026-03-12 07:16","name":"法国国际广播电台","title":"《苹果案》上诉期满仅两被告提上诉 律政司放弃就黎智英欺诈案撤控上诉","content":"香港传媒大亨黎智英及《苹果日报》多名前高层等，早前因串谋勾结外力罪成被重判。该案上诉期限于本周届满，司法机构证实，仅收到前英文版总编冯伟光及执行总编林文宗就刑罚提出上诉。另外，港府决定不会就黎智英另一宗欺诈案上诉得直一事，采取进一步的法律行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260312-%E8%8B%B9%E6%9E%9C%E6%A1%88-%E4%B8%8A%E8%AF%89%E6%9C%9F%E6%BB%A1%E4%BB%85%E4%B8%A4%E8%A2%AB%E5%91%8A%E6%8F%90%E4%B8%8A%E8%AF%89-%E5%BE%8B%E6%94%BF%E5%8F%B8%E6%94%BE%E5%BC%83%E5%B0%B1%E9%BB%8E%E6%99%BA%E8%8B%B1%E6%AC%BA%E8%AF%88%E6%A1%88%E6%92%A4%E6%8E%A7%E4%B8%8A%E8%AF%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773299789000.webp","sourceId":"rfi"},{"id":1773277567000,"createdDate":"2026-03-12 01:06","name":"法国国际广播电台","title":"彭博观点：一场在日本进行的棒球赛，如何在台湾问题上考验中国","content":"台湾行政院长卓荣泰上周末7日现身东京巨蛋，在世界棒球经典赛中为台湾队加油助威，此举引发了一场地缘政治风暴。然而，据彭博社观点作家卡里什玛·瓦斯瓦尼本周三11日指出，真正具有意义的，却不止是这场比赛本身，而是东京与台北正在试探：北京究竟还能在多大程度上实际管控双方的互动。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260312-%E5%BD%AD%E5%8D%9A%E8%A7%82%E7%82%B9-%E4%B8%80%E5%9C%BA%E5%9C%A8%E6%97%A5%E6%9C%AC%E8%BF%9B%E8%A1%8C%E7%9A%84%E6%A3%92%E7%90%83%E8%B5%9B%EF%BC%8C%E5%A6%82%E4%BD%95%E5%9C%A8%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98%E4%B8%8A%E8%80%83%E9%AA%8C%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773277567000.webp","sourceId":"rfi"},{"id":1773359474000,"createdDate":"2026-03-12 23:51","name":"法国国际广播电台","title":"泽连斯基：乌克兰正等待白宫批准美乌无人机生产协议","content":"乌克兰总统泽连斯基周四在社交媒体上发文表示，乌克兰正在等待白宫批准去年由基辅提出的重大无人机生产协议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260312-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E4%B9%8C%E5%85%8B%E5%85%B0%E6%AD%A3%E7%AD%89%E5%BE%85%E7%99%BD%E5%AE%AB%E6%89%B9%E5%87%86%E7%BE%8E%E4%B9%8C%E6%97%A0%E4%BA%BA%E6%9C%BA%E7%94%9F%E4%BA%A7%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773359474000.webp","sourceId":"rfi"},{"id":1773359190000,"createdDate":"2026-03-12 23:46","name":"法国国际广播电台","title":"帮助俄罗斯绕过制裁：香港扮演着重要而复杂的中转角色","content":"法国世界报周四根据美国非政府组织“香港自由委员会基金会”（CFHKF）2月18日发布的报告指出，香港正在成为欧洲受限产品流向俄罗斯的重要中转地，使得部分被禁止出口到俄罗斯的技术和设备，得以绕过西方的制裁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260312-%E5%B8%AE%E5%8A%A9%E4%BF%84%E7%BD%97%E6%96%AF%E7%BB%95%E8%BF%87%E5%88%B6%E8%A3%81-%E9%A6%99%E6%B8%AF%E6%89%AE%E6%BC%94%E7%9D%80%E9%87%8D%E8%A6%81%E8%80%8C%E5%A4%8D%E6%9D%82%E7%9A%84%E4%B8%AD%E8%BD%AC%E8%A7%92%E8%89%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773359190000.webp","sourceId":"rfi"},{"id":1773354224000,"createdDate":"2026-03-12 22:23","name":"法国国际广播电台","title":"习特会逼近 中方的期待会否落空","content":"中国国家主席习近平预计在月底接待来访的美国总统特朗普，最新消息是，美国财长贝森特，中国副总理何立峰从这个周日起在巴黎会谈两天，为特习会铺路。贝森特特别放话，得益于特朗普与习近平之间的相互尊重，双方经贸对话“正在取得进展”，一切似乎都在有条不紊地进行，然而多家媒体连日来曝出的却是北京方面颇有受挫感的消息。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260312-%E4%B9%A0%E7%89%B9%E4%BC%9A%E9%80%BC%E8%BF%91-%E4%B8%AD%E6%96%B9%E7%9A%84%E6%9C%9F%E5%BE%85%E4%BC%9A%E5%90%A6%E8%90%BD%E7%A9%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773354224000.webp","sourceId":"rfi"},{"id":1773353797000,"createdDate":"2026-03-12 22:16","name":"法国国际广播电台","title":"德国电视一台：中国领导层更重视自主发展","content":"德语媒体如何评价刚刚闭幕的中国人大会议？","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260312-%E5%BE%B7%E5%9B%BD%E7%94%B5%E8%A7%86%E4%B8%80%E5%8F%B0-%E4%B8%AD%E5%9B%BD%E9%A2%86%E5%AF%BC%E5%B1%82%E6%9B%B4%E9%87%8D%E8%A7%86%E8%87%AA%E4%B8%BB%E5%8F%91%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773353797000.webp","sourceId":"rfi"},{"id":1773351297000,"createdDate":"2026-03-12 21:34","name":"法国国际广播电台","title":"特习会前奏 中美主管经贸高官周日在巴黎会谈","content":"美国财政部周四宣布，美中高级别贸易谈判这个周日至周一在巴黎举行。此举被视为是在为美国总统特朗普与中国国家主席习近平在北京的会晤铺路。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260312-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%89%8D%E5%A5%8F-%E4%B8%AD%E7%BE%8E%E4%B8%BB%E7%AE%A1%E7%BB%8F%E8%B4%B8%E9%AB%98%E5%AE%98%E5%91%A8%E6%97%A5%E5%9C%A8%E5%B7%B4%E9%BB%8E%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773351297000.webp","sourceId":"rfi"},{"id":1773349974000,"createdDate":"2026-03-12 21:12","name":"法国国际广播电台","title":"联合国安理会就伊朗核制裁产生摩擦：美国指责中俄保护伊朗  中国称美国是伊朗核危机的“挑起者”","content":"美国及其西方盟友周四（3月12日）在联合国就伊朗核意图与俄罗斯和中国发生冲突。在15个成员国组成的联合国安理会会议上（本月由美国担任轮值主席国），俄罗斯和中国试图阻止就监督和执行联合国对伊朗制裁的“1737委员会”进行讨论，但未能成功。他们的阻拦以11票赞成、2票反对、2票弃权被否决。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260312-%E8%81%94%E5%90%88%E5%9B%BD%E5%AE%89%E7%90%86%E4%BC%9A%E5%B0%B1%E4%BC%8A%E6%9C%97%E6%A0%B8%E5%88%B6%E8%A3%81%E4%BA%A7%E7%94%9F%E6%91%A9%E6%93%A6-%E7%BE%8E%E5%9B%BD%E6%8C%87%E8%B4%A3%E4%B8%AD%E4%BF%84%E4%BF%9D%E6%8A%A4%E4%BC%8A%E6%9C%97-%E4%B8%AD%E5%9B%BD%E7%A7%B0%E7%BE%8E%E5%9B%BD%E6%98%AF%E4%BC%8A%E6%9C%97%E6%A0%B8%E5%8D%B1%E6%9C%BA%E7%9A%84-%E6%8C%91%E8%B5%B7%E8%80%85","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773349974000.webp","sourceId":"rfi"},{"id":1773349017000,"createdDate":"2026-03-12 20:56","name":"法国国际广播电台","title":"继伊朗新领袖发表首次声明后，内塔尼亚胡称：以色列正在“碾压”伊朗及真主党","content":"以色列总理内塔尼亚胡周四（3月12日）晚间表示，以色列正在“碾压”伊朗及由德黑兰支持的黎巴嫩伊斯兰主义组织真主党，这是他自以色列和美国对伊朗发起军事行动以来举行首次新闻发布会。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260312-%E7%BB%A7%E4%BC%8A%E6%9C%97%E6%96%B0%E9%A2%86%E8%A2%96%E5%8F%91%E8%A1%A8%E9%A6%96%E6%AC%A1%E5%A3%B0%E6%98%8E%E5%90%8E%EF%BC%8C%E5%86%85%E5%A1%94%E5%B0%BC%E4%BA%9A%E8%83%A1%E7%A7%B0-%E4%BB%A5%E8%89%B2%E5%88%97%E6%AD%A3%E5%9C%A8-%E7%A2%BE%E5%8E%8B-%E4%BC%8A%E6%9C%97%E5%8F%8A%E7%9C%9F%E4%B8%BB%E5%85%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773349017000.webp","sourceId":"rfi"},{"id":1773348192000,"createdDate":"2026-03-12 20:43","name":"法国国际广播电台","title":"北约秘书长再次呼吁加快发展防务工业  称中东和乌克兰战场正在迅速消耗军备库存","content":"北约秘书长马克·吕特（MarkRutte）周四（3月12日）在布鲁塞尔举行的比利时首届国防展（Bedex）上再次呼吁防务工业加快生产，因为中东和乌克兰的两场大战正在迅速消耗军备库存。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260312-%E5%8C%97%E7%BA%A6%E7%A7%98%E4%B9%A6%E9%95%BF%E5%86%8D%E6%AC%A1%E5%91%BC%E5%90%81%E5%8A%A0%E5%BF%AB%E5%8F%91%E5%B1%95%E9%98%B2%E5%8A%A1%E5%B7%A5%E4%B8%9A-%E7%A7%B0%E4%B8%AD%E4%B8%9C%E5%92%8C%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E5%9C%BA%E6%AD%A3%E5%9C%A8%E8%BF%85%E9%80%9F%E6%B6%88%E8%80%97%E5%86%9B%E5%A4%87%E5%BA%93%E5%AD%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773348192000.webp","sourceId":"rfi"},{"id":1773348055000,"createdDate":"2026-03-12 20:40","name":"法国国际广播电台","title":"伊朗战争紧张局势下 中俄两大强国利益分歧加剧","content":"自十多天前美国以色列开打伊朗，中东战事爆发以来，中俄这两个世界大国的命运已经间接地发生了非常不同的变化。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260312-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E7%B4%A7%E5%BC%A0%E5%B1%80%E5%8A%BF%E4%B8%8B-%E4%B8%AD%E4%BF%84%E4%B8%A4%E5%A4%A7%E5%BC%BA%E5%9B%BD%E5%88%A9%E7%9B%8A%E5%88%86%E6%AD%A7%E5%8A%A0%E5%89%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773348055000.webp","sourceId":"rfi"},{"id":1773343595000,"createdDate":"2026-03-12 19:26","name":"法国国际广播电台","title":"国际能源署：中东战争导致全球石油供应下降7.5%，造成历史上最严重的供应中断","content":"国际能源署周四（3月12日）指出，霍尔木兹海峡的封锁造成了“历史上最严重的石油供应中断”。由于这一海峡被封锁，海湾国家被迫将石油产量削减三分之一，导致全球石油供应减少约7.5%。自中东冲突爆发以来，海湾国家的多处能源设施遭到攻击，而霍尔木兹海峡的封锁也是导致供应出现严重问题的原因。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260312-%E5%9B%BD%E9%99%85%E8%83%BD%E6%BA%90%E7%BD%B2-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E5%AF%BC%E8%87%B4%E5%85%A8%E7%90%83%E7%9F%B3%E6%B2%B9%E4%BE%9B%E5%BA%94%E4%B8%8B%E9%99%8D7-5-%EF%BC%8C%E9%80%A0%E6%88%90%E5%8E%86%E5%8F%B2%E4%B8%8A%E6%9C%80%E4%B8%A5%E9%87%8D%E7%9A%84%E4%BE%9B%E5%BA%94%E4%B8%AD%E6%96%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773343595000.webp","sourceId":"rfi"},{"id":1773342533000,"createdDate":"2026-03-12 19:08","name":"法国国际广播电台","title":"伊朗新任最高领袖发表首次声明，包含5点关键信息","content":"伊朗国家电视台周四播出了伊朗新任最高领袖穆杰塔巴·哈梅内伊（MojtabaKhamenei）的首次声明。在声明中，他威胁要为其父亲被刺杀进行报复，但这份声明并非由他本人亲自发表。现年56岁的穆杰塔巴·哈梅内伊本人在袭击中受伤，但他的具体所在地以及健康状况仍然不明。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260312-%E4%BC%8A%E6%9C%97%E6%96%B0%E4%BB%BB%E6%9C%80%E9%AB%98%E9%A2%86%E8%A2%96%E5%8F%91%E8%A1%A8%E9%A6%96%E6%AC%A1%E5%A3%B0%E6%98%8E%EF%BC%8C%E5%8C%85%E5%90%AB5%E7%82%B9%E5%85%B3%E9%94%AE%E4%BF%A1%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773342533000.webp","sourceId":"rfi"},{"id":1773341516000,"createdDate":"2026-03-12 18:51","name":"法国国际广播电台","title":"美国密歇根州一座犹太教堂发生枪击事件，开枪男子已被击毙","content":"法新社周四（3月12日）消息称，密歇根州西布卢姆菲尔德一座犹太教堂内发生枪击事件，一名个人与安保人员之间发生交火，据多家美国媒体报道，向保安开枪的男子已经死亡。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260312-%E7%BE%8E%E5%9B%BD%E5%AF%86%E6%AD%87%E6%A0%B9%E5%B7%9E%E4%B8%80%E5%BA%A7%E7%8A%B9%E5%A4%AA%E6%95%99%E5%A0%82%E5%8F%91%E7%94%9F%E6%9E%AA%E5%87%BB%E4%BA%8B%E4%BB%B6%EF%BC%8C%E5%BC%80%E6%9E%AA%E7%94%B7%E5%AD%90%E5%B7%B2%E8%A2%AB%E5%87%BB%E6%AF%99","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773341516000.webp","sourceId":"rfi"},{"id":1773340016000,"createdDate":"2026-03-12 18:26","name":"法国国际广播电台","title":"法新社独家：伊朗副外长隐晦指出，已放行部分盟友船只通过霍尔木兹海峡，但未具体指明是哪些国家","content":"伊朗外交部副部长马吉德·塔赫特-拉万奇周四（3月12日）接受法新社采访，称伊朗不希望未来再被“强加”一场战争，并回应华盛顿的指控。关于霍尔木兹海峡是否通过部分国家的船只，这位副外长也作出了回应。法新社曾分析，自上周以来，一些在海湾地区航行或停泊的船只公开标示与中国有关，其中部分船只已经通过霍尔木兹海峡。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260312-%E6%B3%95%E6%96%B0%E7%A4%BE%E7%8B%AC%E5%AE%B6-%E4%BC%8A%E6%9C%97%E5%89%AF%E5%A4%96%E9%95%BF%E9%9A%90%E6%99%A6%E6%8C%87%E5%87%BA%EF%BC%8C%E5%B7%B2%E6%94%BE%E8%A1%8C%E9%83%A8%E5%88%86%E7%9B%9F%E5%8F%8B%E8%88%B9%E5%8F%AA%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%EF%BC%8C%E4%BD%86%E6%9C%AA%E5%85%B7%E4%BD%93%E6%8C%87%E6%98%8E%E6%98%AF%E5%93%AA%E4%BA%9B%E5%9B%BD%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773340016000.webp","sourceId":"rfi"},{"id":1773338068000,"createdDate":"2026-03-12 17:54","name":"法国国际广播电台","title":"油价再次逼近100美元每桶，多家航空公司上调长途航线票价","content":"法新社周四（3月12日）消息称，由于中东战争引发油价飙升，法国航空和荷兰皇家航空已上调远程航线票价，全球许多航空公司也采取了类似措施。在此之前，多家航空公司近几天已宣布对机票加收燃油附加费，包括北欧航空、国泰航空、印度航空以及澳洲航空。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260312-%E6%B2%B9%E4%BB%B7%E5%86%8D%E6%AC%A1%E9%80%BC%E8%BF%91100%E7%BE%8E%E5%85%83%E6%AF%8F%E6%A1%B6%EF%BC%8C%E5%A4%9A%E5%AE%B6%E8%88%AA%E7%A9%BA%E5%85%AC%E5%8F%B8%E4%B8%8A%E8%B0%83%E9%95%BF%E9%80%94%E8%88%AA%E7%BA%BF%E7%A5%A8%E4%BB%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773338068000.webp","sourceId":"rfi"},{"id":1773333971000,"createdDate":"2026-03-12 16:46","name":"法国国际广播电台","title":"伊朗新最高领袖首次讲话：誓言复仇继续封锁霍尔木兹海峡！全球迎来通胀恶战","content":"路透社迪拜3月12日电稿称，伊朗新任最高领袖穆杰塔巴·哈梅内伊（MojtabaKhamenei）周四12日通过国家电视台宣读的一份声明表示，伊朗将继续战斗并持续关闭霍尔木兹海峡的。这是他在接替遇袭身亡的父亲后，首次发表的公开言论。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260312-%E4%BC%8A%E6%9C%97%E6%96%B0%E6%9C%80%E9%AB%98%E9%A2%86%E8%A2%96%E9%A6%96%E6%AC%A1%E8%AE%B2%E8%AF%9D-%E8%AA%93%E8%A8%80%E5%A4%8D%E4%BB%87%E7%BB%A7%E7%BB%AD%E5%B0%81%E9%94%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E6%B2%B9%E4%BB%B7%E5%86%8D%E9%A3%99%E7%A0%B4100%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773333971000.webp","sourceId":"rfi"},{"id":1773331666000,"createdDate":"2026-03-12 16:07","name":"法国国际广播电台","title":"巴黎「自由谈」沙龙纪要与述评:民间艺术的传承与超越―当代 “行吟”艺术家杨雨樵谈「民间谭的讲述与口头程式」","content":"新年伊始（1月10日），巴黎「自由谈」沙龙荣幸邀请正在巴黎驻地创作的台湾跨领域叙事与声音艺术家、民间谭口传文学叙事者杨雨樵先生莅临沙龙、以「民间谭的讲述与口头程式」为题，为我们带来了一场拓展艺术视野，唤醒审美意识的精彩演讲。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260312-%E5%B7%B4%E9%BB%8E-%E8%87%AA%E7%94%B1%E8%B0%88-%E6%B2%99%E9%BE%99%E7%BA%AA%E8%A6%81%E4%B8%8E%E8%BF%B0%E8%AF%84-%E6%B0%91%E9%97%B4%E8%89%BA%E6%9C%AF%E7%9A%84%E4%BC%A0%E6%89%BF%E4%B8%8E%E8%B6%85%E8%B6%8A%E2%80%95%E5%BD%93%E4%BB%A3-%E8%A1%8C%E5%90%9F-%E8%89%BA%E6%9C%AF%E5%AE%B6%E6%9D%A8%E9%9B%A8%E6%A8%B5%E8%B0%88-%E6%B0%91%E9%97%B4%E8%B0%AD%E7%9A%84%E8%AE%B2%E8%BF%B0%E4%B8%8E%E5%8F%A3%E5%A4%B4%E7%A8%8B%E5%BC%8F","thumbnail":"","detailImage":"","sourceId":"rfi"},{"id":1773330082000,"createdDate":"2026-03-12 15:41","name":"法国国际广播电台","title":"台湾总统赖清德收到非洲友邦斯威士兰邀访 或四月出行","content":"据中央社报道，台湾外交部周四12日证实，收到非洲友邦斯威士兰（台称：史瓦帝尼）邀访，总统赖清德若有相关规划，总统府会适时对外说明。斯威士兰是台湾在非洲大陆的最后一个友邦。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260312-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E8%B5%96%E6%B8%85%E5%BE%B7%E6%94%B6%E5%88%B0%E9%9D%9E%E6%B4%B2%E5%8F%8B%E9%82%A6%E6%96%AF%E5%A8%81%E5%A3%AB%E5%85%B0%E9%82%80%E8%AE%BF-%E6%88%96%E5%9B%9B%E6%9C%88%E5%87%BA%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773330082000.webp","sourceId":"rfi"},{"id":1773327693000,"createdDate":"2026-03-12 15:01","name":"法国国际广播电台","title":"打击金融犯罪 香港逮捕八人 不乏知名券商与对冲基金管理高层","content":"据路透社报道，香港当局周四12日表示，已对两家经纪商（券商）和一家对冲基金发起内幕交易调查，并逮捕了八名相关人员。这是香港自2017年以来对金融业力度最大的一次打击行动。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260312-%E6%89%93%E5%87%BB%E9%87%91%E8%9E%8D%E7%8A%AF%E7%BD%AA-%E9%A6%99%E6%B8%AF%E9%80%AE%E6%8D%95%E5%85%AB%E4%BA%BA-%E4%B8%8D%E4%B9%8F%E7%9F%A5%E5%90%8D%E5%88%B8%E5%95%86%E4%B8%8E%E5%AF%B9%E5%86%B2%E5%9F%BA%E9%87%91%E7%AE%A1%E7%90%86%E9%AB%98%E5%B1%82","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773327693000.webp","sourceId":"rfi"},{"id":1773324322000,"createdDate":"2026-03-12 14:05","name":"法国国际广播电台","title":"台陆委会警告：中国“民族团结法”可能用来打击“台独”支持者","content":"路透社台北电稿称，台北官员表示，中国周四12日刚刚通过的一项关于民族团结的新法律，可能为北京方面打击其视为“分裂分子”的台湾人提供另一个法律依据，因为该法律包含了关于保护国家主权和安全的措辞。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260312-%E5%8F%B0%E9%99%86%E5%A7%94%E4%BC%9A%E8%AD%A6%E5%91%8A-%E4%B8%AD%E5%9B%BD-%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E6%B3%95-%E5%8F%AF%E8%83%BD%E7%94%A8%E6%9D%A5%E6%89%93%E5%87%BB-%E5%8F%B0%E7%8B%AC-%E6%94%AF%E6%8C%81%E8%80%85","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773324322000.webp","sourceId":"rfi"},{"id":1773316600000,"createdDate":"2026-03-12 11:56","name":"法国国际广播电台","title":"美对伊朗战争首周已耗逾113亿美元 特朗普豪称“赢了”但“不想提前撤军”","content":"法新社华盛顿消息，《纽约时报》周三11日报道，五角大楼向国会议员进行的一次简报显示，美国对伊朗战争的第一周已耗费超过113亿美元。据评估，美国目前每天的战争支出达10亿美元。另外为了抑制因伊朗战争造成的油价高涨，美国能源部11日晚宣布，美国将在未来120天内释放1.72亿桶战略石油储备。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260312-%E7%BE%8E%E5%AF%B9%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E9%A6%96%E5%91%A8%E5%B7%B2%E8%80%97%E9%80%BE113%E4%BA%BF%E7%BE%8E%E5%85%83-%E7%89%B9%E6%9C%97%E6%99%AE%E8%B1%AA%E7%A7%B0-%E8%B5%A2%E4%BA%86-%E4%BD%86-%E4%B8%8D%E6%83%B3%E6%8F%90%E5%89%8D%E6%92%A4%E5%86%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773316600000.webp","sourceId":"rfi"},{"id":1773315142000,"createdDate":"2026-03-12 11:32","name":"法国国际广播电台","title":"中国通过的新《民族团结法》遭人权捍卫者的批评","content":"中国全国人民代表大会周四通过了一项新的“民族团结法”。人权倡导者认为，该法案对国内少数民族的语言和文化具有破坏性。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260312-%E4%B8%AD%E5%9B%BD%E9%80%9A%E8%BF%87%E7%9A%84%E6%96%B0-%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E6%B3%95-%E9%81%AD%E4%BA%BA%E6%9D%83%E6%8D%8D%E5%8D%AB%E8%80%85%E7%9A%84%E6%89%B9%E8%AF%84","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773315142000.webp","sourceId":"rfi"},{"id":1773310807000,"createdDate":"2026-03-12 10:20","name":"法国国际广播电台","title":"中国正重新加强对朝鲜的控制，金正恩准备接受了吗？","content":"日益密切的贸易关系和新的边境基础设施表明，北京正在将平壤拉回其势力范围，并推动这个孤立的邻国走向期待已久的重新开放。此前，美国总统特朗普也表示有兴趣恢复与朝鲜领导人的对话。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260312-%E4%B8%AD%E5%9B%BD%E6%AD%A3%E9%87%8D%E6%96%B0%E5%8A%A0%E5%BC%BA%E5%AF%B9%E6%9C%9D%E9%B2%9C%E7%9A%84%E6%8E%A7%E5%88%B6%EF%BC%8C%E9%87%91%E6%AD%A3%E6%81%A9%E5%87%86%E5%A4%87%E6%8E%A5%E5%8F%97%E4%BA%86%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773310807000.webp","sourceId":"rfi"},{"id":1773308913000,"createdDate":"2026-03-12 09:48","name":"法国国际广播电台","title":"共同社独家：东京向援乌日企指出华为5G有信息外泄隐患","content":"据共同社独家援引相关人士11日透露，日本政府已向积极支持乌克兰重建的日企发出警告，指出使用中国通信设备巨头华为技术的第五代（5G）移动通信系统有技术或敏感信息外泄隐患。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260312-%E5%85%B1%E5%90%8C%E7%A4%BE%E7%8B%AC%E5%AE%B6-%E4%B8%9C%E4%BA%AC%E5%90%91%E6%8F%B4%E4%B9%8C%E6%97%A5%E4%BC%81%E6%8C%87%E5%87%BA%E5%8D%8E%E4%B8%BA5g%E6%9C%89%E4%BF%A1%E6%81%AF%E5%A4%96%E6%B3%84%E9%9A%90%E6%82%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773308913000.webp","sourceId":"rfi"},{"id":1773306727000,"createdDate":"2026-03-12 09:12","name":"法国国际广播电台","title":"中朝客运列车中断6年后恢复运行","content":"中朝两国间客运列车在中断六年之后于周四（3月12号）恢复运行。据相关旅行社和售票点向法新社透露，首列列车从中国边境城市丹东出发，开往朝鲜首都平壤。北京至平壤的列车计划于当天下午发车。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260312-%E4%B8%AD%E6%9C%9D%E5%AE%A2%E8%BF%90%E5%88%97%E8%BD%A6%E4%B8%AD%E6%96%AD6%E5%B9%B4%E5%90%8E%E6%81%A2%E5%A4%8D%E8%BF%90%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773306727000.webp","sourceId":"rfi"},{"id":1773306332000,"createdDate":"2026-03-12 09:05","name":"法国国际广播电台","title":"郭嘉昆：反对以“产能过剩”借口行“政治操弄” 卓荣泰：因贸易协议站相对有利位置","content":"法新社北京消息，中国周四12日表示，美国宣布对数十个国家发起的新贸易调查属于“政治操弄”。与此同时，台湾行政院长卓荣泰说，美方会把过去台美对等贸易协议（ART）作为未来301调查对应的条件与基础，台湾已取得相对比较有利的地位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260312-%E9%83%AD%E5%98%89%E6%98%86-%E5%8F%8D%E5%AF%B9%E4%BB%A5%E4%BA%A7%E8%83%BD%E8%BF%87%E5%89%A9%E4%B8%BA%E5%80%9F%E5%8F%A3%E8%BF%9B%E8%A1%8C-%E6%94%BF%E6%B2%BB%E6%93%8D%E5%BC%84-%E5%8D%93%E8%8D%A3%E6%B3%B0-%E5%9B%A0%E8%B4%B8%E6%98%93%E5%8D%8F%E8%AE%AE%E5%8F%96%E5%BE%97%E7%9B%B8%E5%AF%B9%E6%9C%89%E5%88%A9%E4%BD%8D%E7%BD%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/12/1773306332000.webp","sourceId":"rfi"}]