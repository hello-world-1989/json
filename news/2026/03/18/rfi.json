[{"id":1773819993000,"createdDate":"2026-03-18 07:46","name":"法国国际广播电台","title":"港府拟订白名单 方便大陆人入境推动北都发展 评论料易成「新香港」","content":"香港政府为加快北部都会区(简称北都)发展，大幅缩短建设所须时间和程序，当中包括订定「白名单」，方便中国内地人员往来区内香港园区，至于是否就名单设立配额，发展局只表示，会留交相关政策局考虑。但有评论指，北都面积和人口为现时香港总人口和面积的三分之一，日后难免会改变香港生活模式，但港人对该区发展「无感」，任由港府规划，可能加速出现「新香港」。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260318-%E6%B8%AF%E5%BA%9C%E6%8B%9F%E8%AE%A2%E7%99%BD%E5%90%8D%E5%8D%95-%E6%96%B9%E4%BE%BF%E5%A4%A7%E9%99%86%E4%BA%BA%E5%85%A5%E5%A2%83%E6%8E%A8%E5%8A%A8%E5%8C%97%E9%83%BD%E5%8F%91%E5%B1%95-%E8%AF%84%E8%AE%BA%E6%96%99%E6%98%93%E6%88%90-%E6%96%B0%E9%A6%99%E6%B8%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773819993000.webp","sourceId":"rfi"},{"id":1773819477000,"createdDate":"2026-03-18 07:37","name":"法国国际广播电台","title":"日本首相访美前表示：日本向中东派遣自卫队须在切实停火之后","content":"日本首相高市早苗在日本时间18日下午乘政府专机赴美，19日在白宫与美国总统特朗普举行会谈。特朗普因对伊朗发动攻击，要求包括日本在内的各国在确保霍尔木兹海峡安全方面提供合作。围绕向霍尔木兹海峡派遣舰艇的问题，日本国会参议院展开了热烈的讨论。高市首相表示，如果特朗普总统“忘记了日本法律对自卫队派遣存在限制，将会明确地向其说明”。此外，她还指出，向霍尔木兹海峡周边以调查研究为目的派遣自卫队，“必须以停火已经稳固确立为前提条件”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260318-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E8%AE%BF%E7%BE%8E%E5%89%8D%E8%A1%A8%E7%A4%BA-%E6%97%A5%E6%9C%AC%E5%90%91%E4%B8%AD%E4%B8%9C%E6%B4%BE%E9%81%A3%E8%87%AA%E5%8D%AB%E9%98%9F%E9%A1%BB%E5%9C%A8%E5%88%87%E5%AE%9E%E5%81%9C%E7%81%AB%E4%B9%8B%E5%90%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773819477000.webp","sourceId":"rfi"},{"id":1773819219000,"createdDate":"2026-03-18 07:33","name":"法国国际广播电台","title":"香港再有新闻平台结束 雅虎香港4月起分期停媒体内容","content":"有超过十五年历史的雅虎香港新闻团队，将于本月底被位于美国的母公司遣散，并于4月起，分阶段结束新闻丶财经等原创的媒体内容业务，并于6月底关闭雅虎香港网页，只馀电邮及搜寻引擎服务。新闻部员工对此感到可惜，称又失去一个自由工作空间。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260318-%E9%A6%99%E6%B8%AF%E5%86%8D%E6%9C%89%E6%96%B0%E9%97%BB%E5%B9%B3%E5%8F%B0%E7%BB%93%E6%9D%9F-%E9%9B%85%E8%99%8E%E9%A6%99%E6%B8%AF4%E6%9C%88%E8%B5%B7%E5%88%86%E6%9C%9F%E5%81%9C%E5%AA%92%E4%BD%93%E5%86%85%E5%AE%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773819219000.webp","sourceId":"rfi"},{"id":1773849401000,"createdDate":"2026-03-18 15:56","name":"法国国际广播电台","title":"解放军代表团下周将在布鲁塞尔与欧盟和北约举行安全政策对话","content":"据《南华早报》报导，鉴于伊朗战争引发的全球安全担忧日益加剧，中国人民解放军的一个代表团将于下周前往布鲁塞尔，与欧盟和北约举行会谈。官方消息证实，欧盟-中国安全与防务磋商将于下周二举行，北约与解放军国际军事合作办公室的会谈也安排在同一周。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260318-%E8%A7%A3%E6%94%BE%E5%86%9B%E4%BB%A3%E8%A1%A8%E5%9B%BE%E4%B8%8B%E5%91%A8%E5%B0%86%E5%9C%A8%E5%B8%83%E9%B2%81%E5%A1%9E%E5%B0%94%E4%B8%8E%E6%AC%A7%E7%9B%9F%E5%92%8C%E5%8C%97%E7%BA%A6%E4%B8%BE%E8%A1%8C%E5%AE%89%E5%85%A8%E6%94%BF%E7%AD%96%E5%AF%B9%E8%AF%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773849401000.webp","sourceId":"rfi"},{"id":1773847587000,"createdDate":"2026-03-18 15:26","name":"法国国际广播电台","title":"美贸易代表指疏通霍尔木兹海峡符合中国最佳利益 白宫授权外籍船运输能源以平抑油价","content":"美国贸易代表格里尔（JamiesonGreer）表示，重新开放霍尔木兹海峡符合中国的最佳利益，美国总统特朗普日前曾寻求多国帮助，以恢复这条关键水道的航运。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260318-%E7%BE%8E%E8%B4%B8%E6%98%93%E4%BB%A3%E8%A1%A8%E6%8C%87%E7%96%8F%E9%80%9A%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%AC%A6%E5%90%88%E4%B8%AD%E5%9B%BD%E6%9C%80%E4%BD%B3%E5%88%A9%E7%9B%8A-%E7%99%BD%E5%AE%AB%E6%8E%88%E6%9D%83%E5%A4%96%E7%B1%8D%E8%88%B9%E8%BF%90%E8%BE%93%E8%83%BD%E6%BA%90%E4%BB%A5%E5%B9%B3%E6%8A%91%E6%B2%B9%E4%BB%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773847587000.webp","sourceId":"rfi"},{"id":1773845646000,"createdDate":"2026-03-18 14:54","name":"法国国际广播电台","title":"白宫：中方同意特朗普推迟访问，总统5月份国内有事要处理","content":"白宫新闻秘书莱维特（KarolineLeavitt）周三在答记者问时表示，中方已同意美国总统特朗普推迟其访华计划。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260318-%E7%99%BD%E5%AE%AB-%E4%B8%AD%E6%96%B9%E5%90%8C%E6%84%8F%E7%89%B9%E6%9C%97%E6%99%AE%E6%8E%A8%E8%BF%9F%E8%AE%BF%E9%97%AE%EF%BC%8C%E6%80%BB%E7%BB%9F5%E6%9C%88%E4%BB%BD%E5%9B%BD%E5%86%85%E6%9C%89%E4%BA%8B%E8%A6%81%E5%A4%84%E7%90%86","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773845646000.webp","sourceId":"rfi"},{"id":1773844807000,"createdDate":"2026-03-18 14:40","name":"法国国际广播电台","title":"能源短缺，供电中断：古巴人如何看战争威胁？","content":"委内瑞拉马杜罗政权2026年年初垮台后，古巴陷入事实上的能源封锁。这种局面于2026年3月16日令古巴陷入大面积供电中断陷入黑暗。尽管24小时候，电网逐渐恢复运作，但美国特朗普政府的压力仍在不断加码，引发对美国可能发动军事行动的担忧。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260318-%E8%83%BD%E6%BA%90%E7%9F%AD%E7%BC%BA%EF%BC%8C%E4%BE%9B%E7%94%B5%E4%B8%AD%E6%96%AD-%E5%8F%A4%E5%B7%B4%E4%BA%BA%E5%A6%82%E4%BD%95%E7%9C%8B%E6%88%98%E4%BA%89%E5%A8%81%E8%83%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773844807000.webp","sourceId":"rfi"},{"id":1773843659000,"createdDate":"2026-03-18 14:20","name":"法国国际广播电台","title":"西方官员指中国军方密切关注美国在伊朗展现的军事表现和能力","content":"据彭博社援引知情西方官员报导称，中国军方一直在研究美国总统特朗普对伊朗的战争，以期从中汲取经验教训，为未来可能发生的任何冲突做准备。中国军方密切关注美国的进攻能力，正值其认为印太地区的战略平衡正向其倾斜。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260318-%E8%A5%BF%E6%96%B9%E5%AE%98%E5%91%98%E6%8C%87%E4%B8%AD%E5%9B%BD%E5%86%9B%E6%96%B9%E5%AF%86%E5%88%87%E5%85%B3%E6%B3%A8%E7%BE%8E%E5%9B%BD%E5%9C%A8%E4%BC%8A%E6%9C%97%E5%B1%95%E7%8E%B0%E7%9A%84%E5%86%9B%E4%BA%8B%E8%A1%A8%E7%8E%B0%E5%92%8C%E8%83%BD%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773843659000.webp","sourceId":"rfi"},{"id":1773837847000,"createdDate":"2026-03-18 12:44","name":"法国国际广播电台","title":"中国已批准进口英伟达H200人工智能芯片 黄仁勋：我们的供应链正加速运转","content":"据路透社援引知情人士报导称，英伟达已获得北京方面的批准，可以向中国市场销售其性能第二强的人工智能（AI）芯片，并且正准备推出一款可被销往中国市场的GroqAI芯片版本。这项期待已久的监管批准为这家美国芯片制造商恢复销售H200芯片铺平了道路。H200芯片曾是美中关系中的一个主要焦点，而中国市场一度贡献了英伟达13%的总收入。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260318-%E4%B8%AD%E5%9B%BD%E5%B7%B2%E6%89%B9%E5%87%86%E8%BF%9B%E5%8F%A3%E8%8B%B1%E4%BC%9F%E8%BE%BEh200%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E8%8A%AF%E7%89%87-%E9%BB%84%E4%BB%81%E5%8B%8B-%E6%88%91%E4%BB%AC%E7%9A%84%E4%BE%9B%E5%BA%94%E9%93%BE%E6%AD%A3%E5%8A%A0%E9%80%9F%E8%BF%90%E8%BD%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773837847000.webp","sourceId":"rfi"},{"id":1773837251000,"createdDate":"2026-03-18 12:34","name":"法国国际广播电台","title":"以色列称伊朗情报部长已身亡  打击力度正在“加大”","content":"法新社报道，以色列国防部长伊斯拉埃尔·卡茨周三（3月18号）宣布，伊朗情报部长伊斯梅尔·哈提卜（EsmaïlKhatib）在针对德黑兰的一次“精确打击”中丧生。伊朗政府并未立即证实这一消息。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260318-%E4%BB%A5%E8%89%B2%E5%88%97%E7%A7%B0%E4%BC%8A%E6%9C%97%E6%83%85%E6%8A%A5%E9%83%A8%E9%95%BF%E5%B7%B2%E8%BA%AB%E4%BA%A1-%E6%89%93%E5%87%BB%E5%8A%9B%E5%BA%A6%E6%AD%A3%E5%9C%A8-%E5%8A%A0%E5%A4%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773837251000.webp","sourceId":"rfi"},{"id":1773836890000,"createdDate":"2026-03-18 12:28","name":"法国国际广播电台","title":"台湾阁揆赴日观赛虽是外交突破，但在国内却陷入窝内吵","content":"台湾行政院长卓荣泰赴日观看球赛为台湾对打气，却引起正反意见两方攻防。支持者认为是外交突破，质疑者揪住公器私用指控不放。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260318-%E5%8F%B0%E6%B9%BE%E9%98%81%E6%8F%86%E8%B5%B4%E6%97%A5%E8%A7%82%E8%B5%9B%E8%99%BD%E6%98%AF%E5%A4%96%E4%BA%A4%E7%AA%81%E7%A0%B4%EF%BC%8C%E4%BD%86%E5%9C%A8%E5%9B%BD%E5%86%85%E5%8D%B4%E9%99%B7%E5%85%A5%E7%AA%9D%E5%86%85%E5%90%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773836890000.webp","sourceId":"rfi"},{"id":1773836458000,"createdDate":"2026-03-18 12:20","name":"法国国际广播电台","title":"视频 欧洲艺术博览会（TEFAF）展示博物馆级别艺术精品","content":"在2026年已经有39年历史的欧洲艺术博览会TEFAF从3月14日至19日在荷兰马斯特里赫特举行(TheEuropeanFineArtFair) ，吸引来自全球200多个国家的顶尖画廊齐聚一堂，展示欧洲精美绘画，雕塑，家具和瓷器等艺术品。目前中东战火持续，而第39届欧洲艺术博览会（TEFAF）宛如一座艺术精品堡垒让大家忘却纷扰，请看RFI视频报道。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260318-%E8%A7%86%E9%A2%91-%E6%AC%A7%E6%B4%B2%E8%89%BA%E6%9C%AF%E5%8D%9A%E8%A7%88%E4%BC%9A-tefaf-%E5%B1%95%E7%A4%BA%E5%8D%9A%E7%89%A9%E9%A6%86%E7%BA%A7%E5%88%AB%E8%89%BA%E6%9C%AF%E7%B2%BE%E5%93%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773836458000.webp","sourceId":"rfi"},{"id":1773836113000,"createdDate":"2026-03-18 12:15","name":"法国国际广播电台","title":"伊朗为安全局长拉里贾尼举行葬礼 情报部长据报也已丧生","content":"周三3月18号，中东战火进入第19天，轰炸声四起 ,在伊朗首都德黑兰为周二在以色列空袭中丧生的安全局局长阿里·拉里贾尼、巴斯基民兵组织指挥官戈拉姆雷扎·苏莱曼尼，以及遇难的80名水兵举行葬礼之际，以色列和美国对伊朗多个地区发动空袭，包括德黑兰。以色列国防部长以色列·卡茨当天宣布，另一名伊朗官员、情报部长伊斯梅尔·哈提卜在对德黑兰的一次“精确打击”中丧生。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260318-%E4%BC%8A%E6%9C%97%E4%B8%BA%E5%AE%89%E5%85%A8%E5%B1%80%E9%95%BF%E6%8B%89%E9%87%8C%E8%B4%BE%E5%B0%BC%E4%B8%BE%E8%A1%8C%E8%91%AC%E7%A4%BC-%E6%83%85%E6%8A%A5%E9%83%A8%E9%95%BF%E6%8D%AE%E6%8A%A5%E4%B9%9F%E5%B7%B2%E4%B8%A7%E7%94%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773836113000.webp","sourceId":"rfi"},{"id":1773835664000,"createdDate":"2026-03-18 12:07","name":"法国国际广播电台","title":"伊朗外长：中国等国可扮演调解人角色，最高领袖受皮外伤","content":"伊朗外交部长阿拉格齐最新在受访时表示，中国和其他几个国家可参与调解伊朗和美国之间的冲突。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260318-%E4%BC%8A%E6%9C%97%E5%A4%96%E9%95%BF-%E4%B8%AD%E5%9B%BD%E7%AD%89%E5%9B%BD%E5%8F%AF%E6%89%AE%E6%BC%94%E5%86%B2%E7%AA%81%E8%B0%83%E8%A7%A3%E4%BA%BA%E8%A7%92%E8%89%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773835664000.webp","sourceId":"rfi"},{"id":1773829327000,"createdDate":"2026-03-18 10:22","name":"法国国际广播电台","title":"比利时海关高官警告3欧元关税新政对遏制廉价中国商品涌入将收效甚微","content":"一位高级官员警告称，欧盟计划对小包裹征收的税款无法遏制廉价中国商品涌入欧盟的势头。Shein和Temu等电商企业的迅猛发展已使欧盟海关当局不堪重负，这些机构需要核查每年涌入该集团的数十亿件包裹是否符合欧方安全标准，并缴纳了正确的进口关税。但比利时海关与消费税署署长万德瓦伦（KristianVanderwaeren）警告称，布鲁塞尔计划废除“小额包裹免税”规则——该规则允许价值低于150欧元的商品免缴关税，但这可能对减少流入欧盟的低价值包裹数量收效甚微。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260318-%E6%AF%94%E5%88%A9%E6%97%B6%E6%B5%B7%E5%85%B3%E9%AB%98%E5%AE%98%E9%A2%84%E8%AE%A13%E6%AC%A7%E5%85%83%E5%85%B3%E7%A8%8E%E6%96%B0%E6%94%BF%E5%AF%B9%E9%81%8F%E5%88%B6%E5%BB%89%E4%BB%B7%E4%B8%AD%E5%9B%BD%E5%95%86%E5%93%81%E6%B6%8C%E5%85%A5%E5%B0%86%E6%94%B6%E6%95%88%E7%94%9A%E5%BE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773829327000.webp","sourceId":"rfi"},{"id":1773826901000,"createdDate":"2026-03-18 09:41","name":"法国国际广播电台","title":"伊朗全面收紧网络管控：对外连接近乎中断，内部监控升级","content":"综合法媒消息，近期，伊朗政府展开了一系列行动，包括逮捕销售星链终端的人员、加强监控，并在传统节日“火节”临近之际提高警戒级别。自3月15日以来，原本仍可连接外部网络的少数渠道正陆续被关闭。在2月28日美以发动袭击后，伊朗的互联网接入已被压缩至约1%，如今几乎完全无法使用。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260318-%E4%BC%8A%E6%9C%97%E5%85%A8%E9%9D%A2%E6%94%B6%E7%B4%A7%E7%BD%91%E7%BB%9C%E7%AE%A1%E6%8E%A7-%E5%AF%B9%E5%A4%96%E8%BF%9E%E6%8E%A5%E8%BF%91%E4%B9%8E%E4%B8%AD%E6%96%AD%EF%BC%8C%E5%86%85%E9%83%A8%E7%9B%91%E6%8E%A7%E5%8D%87%E7%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773826901000.webp","sourceId":"rfi"},{"id":1773826738000,"createdDate":"2026-03-18 09:38","name":"法国国际广播电台","title":"瑞典保安警察发布年度形势分析报告 指俄中伊构成最大威胁","content":"瑞典保安警察（Säpo）周三在其2025至2026年国家安全形势分析报告中指出，俄罗斯、中国和伊朗是瑞典面临的最大威胁。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260318-%E7%91%9E%E5%85%B8%E4%BF%9D%E5%AE%89%E8%AD%A6%E5%AF%9F%E5%8F%91%E5%B8%83%E5%B9%B4%E5%BA%A6%E5%BD%A2%E5%8A%BF%E5%88%86%E6%9E%90%E6%8A%A5%E5%91%8A-%E6%8C%87%E4%BF%84%E4%B8%AD%E4%BC%8A%E6%9E%84%E6%88%90%E6%9C%80%E5%A4%A7%E5%A8%81%E8%83%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773826738000.webp","sourceId":"rfi"},{"id":1773825107000,"createdDate":"2026-03-18 09:11","name":"法国国际广播电台","title":"防AI技术外流 中国就Meta收购Manus进行处罚据报包括高管出境禁令","content":"据《纽约时报》援引两名知情人士报导称，中国政府正在采取行动，对与Meta以20亿美元收购Manus一事有关的人员进行处罚。Manus是一家源于中国的新加坡人工智能初创公司。此举显然旨在阻止中国人工智能高管将业务迁至海外。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260318-%E9%98%B2ai%E6%8A%80%E6%9C%AF%E5%A4%96%E6%B5%81-%E4%B8%AD%E5%9B%BD%E5%B0%B1meta%E6%94%B6%E8%B4%ADmanus%E8%BF%9B%E8%A1%8C%E5%A4%84%E7%BD%9A%E6%8D%AE%E6%8A%A5%E5%8C%85%E6%8B%AC%E9%AB%98%E7%AE%A1%E5%87%BA%E5%A2%83%E7%A6%81%E4%BB%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773825107000.webp","sourceId":"rfi"},{"id":1773824286000,"createdDate":"2026-03-18 08:58","name":"法国国际广播电台","title":"非政府组织：巴基斯坦空袭致喀布尔戒毒中心 “数百人死伤”","content":"阿富汗当局周二(3月17号)宣布，周一晚间，巴基斯坦空袭喀布尔一家戒毒医院，造成约400人死亡。伊斯兰堡否认以任何此类设施为目标，称其袭击的是军事设施和“恐怖主义支持基础设施”。这是巴基斯坦和阿富汗之间持续数月的冲突中迄今为止最致命的一次袭击。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260318-%E9%9D%9E%E6%94%BF%E5%BA%9C%E7%BB%84%E7%BB%87%E8%AF%81%E5%AE%9E-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E7%A9%BA%E8%A2%AD%E8%87%B4%E5%96%80%E5%B8%83%E5%B0%94%E6%88%92%E6%AF%92%E4%B8%AD%E5%BF%83-%E6%95%B0%E7%99%BE%E4%BA%BA%E6%AD%BB%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773824286000.webp","sourceId":"rfi"},{"id":1773868048000,"createdDate":"2026-03-18 21:07","name":"法国国际广播电台","title":"一名美国联邦法官下令特朗普政府恢复“美国之音”","content":"周二（3月17日），一名美国联邦法官下令特朗普政府恢复美国之音（VOA）运营，将数百名被行政休假的员工重新召回。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260318-%E4%B8%80%E5%90%8D%E7%BE%8E%E5%9B%BD%E8%81%94%E9%82%A6%E6%B3%95%E5%AE%98%E4%B8%8B%E4%BB%A4%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E6%81%A2%E5%A4%8D-%E7%BE%8E%E5%9B%BD%E4%B9%8B%E9%9F%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773868048000.webp","sourceId":"rfi"},{"id":1773867352000,"createdDate":"2026-03-18 20:55","name":"法国国际广播电台","title":"伊朗总统警告袭击能源设施“可能产生不可控的后果”","content":"伊朗总统周三（3月18日）警告称，对能源基础设施的袭击可能带来“不可控的后果”。此前，伊朗国家电视台下午报道，南帕尔斯（South Pars）气田，同时也是世界上最大的天然气田，由伊朗和卡塔尔共享的部分设施发生火灾。据称，火灾是在伊朗南部甘甘（Kangan）附近受到“美以敌人”袭击后发生的。伊朗方面指责美国和以色列对南帕尔斯（South Pars）天然气场的设施发动了袭击。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260318-%E4%BC%8A%E6%9C%97%E6%80%BB%E7%BB%9F%E8%AD%A6%E5%91%8A%E8%A2%AD%E5%87%BB%E8%83%BD%E6%BA%90%E8%AE%BE%E6%96%BD-%E5%8F%AF%E8%83%BD%E4%BA%A7%E7%94%9F%E4%B8%8D%E5%8F%AF%E6%8E%A7%E7%9A%84%E5%90%8E%E6%9E%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773867352000.webp","sourceId":"rfi"},{"id":1773866532000,"createdDate":"2026-03-18 20:42","name":"法国国际广播电台","title":"美CIA局长：伊朗向中国俄罗斯求助","content":"美国中央情报局（CIA）局长拉特克利夫（JohnRatcliffe）18日在国会听证会上证实，伊朗正积极向中国、俄罗斯等美国对手寻求情报支援，这场中东战争可能正快速扩大为大国角力的潜在引爆点。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260318-%E7%BE%8Ecia%E5%B1%80%E9%95%BF-%E4%BC%8A%E6%9C%97%E5%90%91%E4%B8%AD%E5%9B%BD%E4%BF%84%E7%BD%97%E6%96%AF%E6%B1%82%E5%8A%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773866532000.webp","sourceId":"rfi"},{"id":1773865938000,"createdDate":"2026-03-18 20:32","name":"法国国际广播电台","title":"默茨拒绝德国参与伊朗战争","content":"据《法兰克福评论报》报道，在布鲁塞尔欧盟峰会前，德国总理默茨发表政府声明，重申了对美国和以色列对伊朗战争的批评，以及德国拒绝参战的立场。同时，他呼吁欧盟增强自信。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260318-%E9%BB%98%E8%8C%A8%E6%8B%92%E7%BB%9D%E5%BE%B7%E5%9B%BD%E5%8F%82%E4%B8%8E%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773865938000.webp","sourceId":"rfi"},{"id":1773865920000,"createdDate":"2026-03-18 20:32","name":"法国国际广播电台","title":"马克龙宣布法国新航母将命名为“自由法国”   预计于2038年接替“戴高乐号”","content":"法国总统马克龙周三（3月18日）宣布，预计于2038年接替“戴高乐号”（CharlesdeGaulle）的法国新航母将命名为“自由法国”（FranceLibre），以致敬法国“抵抗精神”的传统。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260318-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%AE%A3%E5%B8%83%E6%B3%95%E5%9B%BD%E6%96%B0%E8%88%AA%E6%AF%8D%E5%B0%86%E5%91%BD%E5%90%8D%E4%B8%BA-%E8%87%AA%E7%94%B1%E6%B3%95%E5%9B%BD-%E9%A2%84%E8%AE%A1%E4%BA%8E2038%E5%B9%B4%E6%8E%A5%E6%9B%BF-%E6%88%B4%E9%AB%98%E4%B9%90%E5%8F%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773865920000.webp","sourceId":"rfi"},{"id":1773865522000,"createdDate":"2026-03-18 20:25","name":"法国国际广播电台","title":"霍尔木兹海峡：特朗普与北约在此结怨","content":"美国总统特朗普上周15日开始警告北约成员国：如果不协助疏通霍尔木兹海峡，将面临“非常不利”的未来。这之后他对北约盟国再次表示不满。但阿联酋官员表示该国可能会加入美国主导的保护霍尔木兹海峡航运的行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260318-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%8E%E5%8C%97%E7%BA%A6%E5%9C%A8%E6%AD%A4%E7%BB%93%E6%80%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773865522000.webp","sourceId":"rfi"},{"id":1773864494000,"createdDate":"2026-03-18 20:08","name":"法国国际广播电台","title":"一艘受制裁的俄罗斯油轮正向古巴运输超70万桶石油","content":"法新社周三（3月18日）消息称，根据海运追踪平台Kpler的数据，一艘列入西方制裁名单的俄罗斯油轮正向古巴运输超过70万桶石油。目前，古巴因美国封锁而遭遇严重能源短缺。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260318-%E4%B8%80%E8%89%98%E5%8F%97%E5%88%B6%E8%A3%81%E7%9A%84%E4%BF%84%E7%BD%97%E6%96%AF%E6%B2%B9%E8%BD%AE%E6%AD%A3%E5%90%91%E5%8F%A4%E5%B7%B4%E8%BF%90%E8%BE%93%E8%B6%8570%E4%B8%87%E6%A1%B6%E7%9F%B3%E6%B2%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773864494000.webp","sourceId":"rfi"},{"id":1773863758000,"createdDate":"2026-03-18 19:55","name":"法国国际广播电台","title":"巴基斯坦宣布在开斋节期间与阿富汗停火","content":"据法新社报道，巴基斯坦与阿富汗在持续数月的紧张关系之后，于周三宣布，在开斋节期间实行临时停火。这一决定距离巴基斯坦对喀布尔的一次致命空袭仅两天。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260318-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%AE%A3%E5%B8%83%E5%9C%A8%E5%BC%80%E6%96%8B%E8%8A%82%E6%9C%9F%E9%97%B4%E4%B8%8E%E9%98%BF%E5%AF%8C%E6%B1%97%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773863758000.webp","sourceId":"rfi"},{"id":1773863447000,"createdDate":"2026-03-18 19:50","name":"法国国际广播电台","title":"法国市选风云：左翼联盟与右派分化","content":"法国《世界报》周三聚焦即将到来的市政选举第二轮投票。该报指出，这场地方选举不仅关系城市治理，也被视为2027年总统大选前的重要政治信号。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260318-%E6%B3%95%E5%9B%BD%E5%B8%82%E6%94%BF%E9%80%89%E4%B8%BE-%E8%81%94%E7%9B%9F%E9%87%8D%E7%BB%84%E4%B8%8E%E6%94%BF%E6%B2%BB%E7%89%88%E5%9B%BE%E7%9A%84%E4%BF%A1%E5%8F%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773863447000.webp","sourceId":"rfi"},{"id":1773861510000,"createdDate":"2026-03-18 19:18","name":"法国国际广播电台","title":"开战三周以来伊朗首次宣布执行死刑：因被指控为以色列从事间谍活动，一名瑞典人在伊朗遭处决","content":"一名拥有伊朗和瑞典双重国籍的男子周三（3月18日）在伊朗被处决，他被指控为以色列从事间谍活动。瑞典方面对此予以强烈谴责。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260318-%E5%BC%80%E6%88%98%E4%B8%89%E5%91%A8%E4%BB%A5%E6%9D%A5%E4%BC%8A%E6%9C%97%E9%A6%96%E6%AC%A1%E5%AE%A3%E5%B8%83%E6%89%A7%E8%A1%8C%E6%AD%BB%E5%88%91-%E5%9B%A0%E8%A2%AB%E6%8C%87%E6%8E%A7%E4%B8%BA%E4%BB%A5%E8%89%B2%E5%88%97%E4%BB%8E%E4%BA%8B%E9%97%B4%E8%B0%8D%E6%B4%BB%E5%8A%A8%EF%BC%8C%E4%B8%80%E5%90%8D%E7%91%9E%E5%85%B8%E4%BA%BA%E5%9C%A8%E4%BC%8A%E6%9C%97%E9%81%AD%E5%A4%84%E5%86%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773861510000.webp","sourceId":"rfi"},{"id":1773861443000,"createdDate":"2026-03-18 19:17","name":"法国国际广播电台","title":"霍尔木兹海峡：多国提议设立海上安全通道，撤离约2万名滞留海员","content":"联合国负责海事运输的机构周三（3月18日）提出一项建议，主张设立一条海上安全通道，以便让约2万名因伊朗战争被困在海湾地区的海员撤离。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260318-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E5%A4%9A%E5%9B%BD%E6%8F%90%E8%AE%AE%E8%AE%BE%E7%AB%8B%E6%B5%B7%E4%B8%8A%E5%AE%89%E5%85%A8%E9%80%9A%E9%81%93%EF%BC%8C%E6%92%A4%E7%A6%BB%E7%BA%A62%E4%B8%87%E5%90%8D%E6%BB%9E%E7%95%99%E6%B5%B7%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773861443000.webp","sourceId":"rfi"},{"id":1773859462000,"createdDate":"2026-03-18 18:44","name":"法国国际广播电台","title":"瑞士一滑雪区发生缆车坠落事故，致一人死亡","content":"瑞士中部恩格尔贝格铁力士滑雪度假区周三（3月18日）上午发生一起缆车事故，当地州警方表示，一节缆车车厢从钢缆上脱落，导致车内乘客死亡，但未能提供遇难者的年龄或国籍等更多信息。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260318-%E7%91%9E%E5%A3%AB%E4%B8%80%E6%BB%91%E9%9B%AA%E5%8C%BA%E5%8F%91%E7%94%9F%E7%BC%86%E8%BD%A6%E5%9D%A0%E8%90%BD%E4%BA%8B%E6%95%85%EF%BC%8C%E8%87%B4%E4%B8%80%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773859462000.webp","sourceId":"rfi"},{"id":1773858139000,"createdDate":"2026-03-18 18:22","name":"法国国际广播电台","title":"美国情报机构得出结论称伊朗并未重启核浓缩活动  与特朗普所称发动战争是因“迫在眉睫的核威胁”相矛盾","content":"美国情报机构周三（3月18日）得出结论称，伊朗并未尝试重启在2025年6月美以联合打击中被摧毁的核浓缩活动，这一判断与美国总统特朗普在对伊战争主要动机上的说法相矛盾。当前这场针对伊朗的战争已进入第三周，但特朗普政府仍难以为发动战争的合理性作出清晰解释。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260318-%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E5%BE%97%E5%87%BA%E7%BB%93%E8%AE%BA%E7%A7%B0%E4%BC%8A%E6%9C%97%E5%B9%B6%E6%9C%AA%E9%87%8D%E5%90%AF%E6%A0%B8%E6%B5%93%E7%BC%A9%E6%B4%BB%E5%8A%A8-%E4%B8%8E%E7%89%B9%E6%9C%97%E6%99%AE%E6%9C%AC%E4%BA%BA%E6%89%80%E7%A7%B0-%E8%BF%AB%E5%9C%A8%E7%9C%89%E7%9D%AB%E7%9A%84%E6%A0%B8%E5%A8%81%E8%83%81-%E7%9B%B8%E7%9F%9B%E7%9B%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773858139000.webp","sourceId":"rfi"},{"id":1773855020000,"createdDate":"2026-03-18 17:30","name":"法国国际广播电台","title":"拉里贾尼之死：伊朗新任最高领袖通过书面声明表示“凶手将很快付出代价”","content":"伊朗新任最高领袖穆杰塔巴·哈梅内伊周三（3月18日）在一份书面声明中向安全负责人阿里·拉里贾尼致敬。哈梅内伊还表示，凶手必将付出代价。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260318-%E6%8B%89%E9%87%8C%E8%B4%BE%E5%B0%BC%E4%B9%8B%E6%AD%BB-%E4%BC%8A%E6%9C%97%E6%96%B0%E4%BB%BB%E6%9C%80%E9%AB%98%E9%A2%86%E8%A2%96%E9%80%9A%E8%BF%87%E4%B9%A6%E9%9D%A2%E5%A3%B0%E6%98%8E%E8%A1%A8%E7%A4%BA-%E5%87%B6%E6%89%8B%E5%B0%86%E5%BE%88%E5%BF%AB%E4%BB%98%E5%87%BA%E4%BB%A3%E4%BB%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773855020000.webp","sourceId":"rfi"},{"id":1773854434000,"createdDate":"2026-03-18 17:20","name":"法国国际广播电台","title":"法新社：美以发动的战争进一步强化了伊朗革命卫队的影响力","content":"法新社周三（3月18日）消息称，据专家分析，美国和以色列发动的战争进一步强化了伊朗革命卫队这一伊斯兰共和国“意识形态军队”的政治影响力，现如今，革命卫队的权力已渗透至伊朗社会生活的方方面面。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260318-%E6%B3%95%E6%96%B0%E7%A4%BE-%E7%BE%8E%E4%BB%A5%E5%8F%91%E5%8A%A8%E7%9A%84%E6%88%98%E4%BA%89%E8%BF%9B%E4%B8%80%E6%AD%A5%E5%BC%BA%E5%8C%96%E4%BA%86%E4%BC%8A%E6%9C%97%E9%9D%A9%E5%91%BD%E5%8D%AB%E9%98%9F%E7%9A%84%E5%BD%B1%E5%93%8D%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/18/1773854434000.webp","sourceId":"rfi"}]