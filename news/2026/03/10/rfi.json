[{"id":1773102955000,"createdDate":"2026-03-10 00:35","name":"法国国际广播电台","title":"初期花粉季届临 流鼻涕、眼睛发痒、喉咙痛 如何保护自己免受过敏折磨","content":"各位听众，流鼻涕、眼睛发痒、喉咙痛：这些都是初次花粉季带来的折磨，如何保护自己免受过敏困扰》春天悄然来临，随之而来的是各种疾病和过敏症。罪魁祸首是什么？花粉，它会引发鼻炎、结膜炎，甚至在敏感人群中还会引发哮喘。为了缓解这些令人烦恼且可能影响健康的症状，以下是一些预防措施。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260310-%E5%88%9D%E6%9C%9F%E8%8A%B1%E7%B2%89%E5%AD%A3%E5%B1%8A%E4%B8%B4-%E6%B5%81%E9%BC%BB%E6%B6%95-%E7%9C%BC%E7%9D%9B%E5%8F%91%E7%97%92-%E5%96%89%E5%92%99%E7%97%9B-%E5%A6%82%E4%BD%95%E4%BF%9D%E6%8A%A4%E8%87%AA%E5%B7%B1%E5%85%8D%E5%8F%97%E8%BF%87%E6%95%8F%E6%8A%98%E7%A3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773102955000.webp","sourceId":"rfi"},{"id":1773130447000,"createdDate":"2026-03-10 08:14","name":"法国国际广播电台","title":"台湾行政院长外交突破自费赴日看球赛 在野党要求看帐单","content":"台湾行政院长卓荣泰在7日亲赴东京2026世界棒球经典赛看球，此举普遍受到国际媒体、学者正面评论为外交突破，然而，台湾国内在野则出现质疑公器私用声浪。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260310-%E5%8F%B0%E6%B9%BE%E8%A1%8C%E6%94%BF%E9%99%A2%E9%95%BF%E5%A4%96%E4%BA%A4%E7%AA%81%E7%A0%B4%E8%87%AA%E8%B4%B9%E8%B5%B4%E6%97%A5%E7%9C%8B%E7%90%83%E8%B5%9B-%E5%9C%A8%E9%87%8E%E5%85%9A%E8%A6%81%E6%B1%82%E7%9C%8B%E5%B8%90%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773130447000.webp","sourceId":"rfi"},{"id":1773130232000,"createdDate":"2026-03-10 08:10","name":"法国国际广播电台","title":"人大闭幕后香港需提交首份「五年规划」建议 能否跟上国家思维存在问号","content":"中国人大会议将在本周四(12日)闭幕，港府首份「五年规划」也快将出炉。人大常委李慧琼认为，香港要以「一国两制」的方式提出建议；但政协副主席梁振英称，香港应助力国家实际目标。评论指出，香港的规划既要配合国家，又要保留独特性，存在一定矛盾；加上由政务官负责筹备，思维上能否完全与国家接轨成疑。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260310-%E4%BA%BA%E5%A4%A7%E9%97%AD%E5%B9%95%E5%90%8E%E9%A6%99%E6%B8%AF%E9%9C%80%E6%8F%90%E4%BA%A4%E9%A6%96%E4%BB%BD-%E4%BA%94%E5%B9%B4%E8%A7%84%E5%88%92-%E5%BB%BA%E8%AE%AE-%E8%83%BD%E5%90%A6%E8%B7%9F%E4%B8%8A%E5%9B%BD%E5%AE%B6%E6%80%9D%E7%BB%B4%E5%AD%98%E5%9C%A8%E9%97%AE%E5%8F%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773130232000.webp","sourceId":"rfi"},{"id":1773127265000,"createdDate":"2026-03-10 07:21","name":"法国国际广播电台","title":"移澳港女涉2019年藏有镭射笔及喷漆 六年后返港后遭检控","content":"2019年反修例运动发生至今近七年，港府对当年曾参与示威的逾六千名被捕人士的检控仍未停止。最新一名被起诉者，是一名当年曾因藏有镭射笔及喷漆被捕但两年间仍未被检控的少女，她其后移居澳洲，事隔六年半返港后被捕和起诉。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260310-%E7%A7%BB%E6%BE%B3%E6%B8%AF%E5%A5%B3%E6%B6%892019%E5%B9%B4%E8%97%8F%E6%9C%89%E9%95%AD%E5%B0%84%E7%AC%94%E5%8F%8A%E5%96%B7%E6%BC%86-%E5%85%AD%E5%B9%B4%E5%90%8E%E8%BF%94%E6%B8%AF%E5%90%8E%E9%81%AD%E6%A3%80%E6%8E%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773127265000.webp","sourceId":"rfi"},{"id":1773156891000,"createdDate":"2026-03-10 15:34","name":"法国国际广播电台","title":"特朗普战争“即将结束”发言带动油价回落，股市反弹","content":"美国总统9日宣布战争结束已经迫在眉睫的发言似乎令连日来对国际能源供应链中断的惴惴不安的市场打了一剂强心针，亚洲市场石油价格9日经历过山车一般的起伏，10日下跌10%。各地股市则纷纷止跌回升。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260310-%E7%89%B9%E6%9C%97%E6%99%AE%E6%88%98%E4%BA%89-%E5%8D%B3%E5%B0%86%E7%BB%93%E6%9D%9F-%E5%8F%91%E8%A8%80%E5%B8%A6%E5%8A%A8%E6%B2%B9%E4%BB%B7%E5%9B%9E%E8%90%BD%EF%BC%8C%E8%82%A1%E5%B8%82%E5%8F%8D%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773156891000.webp","sourceId":"rfi"},{"id":1773154670000,"createdDate":"2026-03-10 14:57","name":"法国国际广播电台","title":"伊朗战争持续波及周边邻国，西方盟友提供防守性军事支援","content":"美以两国对伊朗的军事打击行动不断波及周边国家，并造成人员伤亡。欧洲多国陆续承诺向塞浦路斯提供军事援助，北约组织则已经在帮助土耳其拦截闯入领空的导弹。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260310-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%8C%81%E7%BB%AD%E6%B3%A2%E5%8F%8A%E5%91%A8%E8%BE%B9%E9%82%BB%E5%9B%BD%EF%BC%8C%E8%A5%BF%E6%96%B9%E7%9B%9F%E5%8F%8B%E9%98%B2%E5%AE%88%E6%80%A7%E9%A9%B0%E6%8F%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773154670000.webp","sourceId":"rfi"},{"id":1773153432000,"createdDate":"2026-03-10 14:37","name":"法国国际广播电台","title":"中东战争会演变成水资源争夺战吗？","content":"美国与以色列对伊朗发动的战争随着对石油设施以及海水淡化厂的袭击正在进入一个新的阶段， 3月8日，巴林当局声称,巴林的一家海水淡化厂因伊朗无人机袭击而受损。而前一天,伊朗谴责美国对伊朗格什姆岛发动了类似袭击,影响30个村庄的供水。伊朗此举或是对巴林允许美军在其领土发起对伊朗攻击的报复行为，虽然类似的攻击行为迅速遭到了遏制，伊朗谴责是美国首先发动水战，而华尔街日报则声称白宫对此予以否认，无论责任方是美国还是以色列，最先攻击水厂的一方无疑将战争推向了新的层面。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260310-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E4%BC%9A%E6%BC%94%E5%8F%98%E6%88%90%E6%B0%B4%E8%B5%84%E6%BA%90%E4%BA%89%E5%A4%BA%E6%88%98%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773153432000.webp","sourceId":"rfi"},{"id":1773145518000,"createdDate":"2026-03-10 12:25","name":"法国国际广播电台","title":"拒唱国歌被骂“叛国”：五名伊朗女足球员在澳大利亚获庇护","content":"在上周澳大利亚举行的女足亚洲杯期间，伊朗国家女子球队在首场比赛前因拒唱伊朗国歌被伊朗媒体指为“战时叛徒\"，球队在3月8日结束比赛，外界担心其回国后恐遭清算命运。在各方关注下，澳大利亚政府周一（3月10日）确认，已向其中五名球员提供人道庇护，这五名球员目前已受到澳警方的保护。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260310-%E6%8B%92%E5%94%B1%E5%9B%BD%E6%AD%8C%E8%A2%AB%E9%AA%82-%E5%8F%9B%E5%9B%BD-%E4%BA%94%E5%90%8D%E4%BC%8A%E6%9C%97%E5%A5%B3%E8%B6%B3%E7%90%83%E5%91%98%E8%8E%B7%E5%BE%97%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E5%BA%87%E6%8A%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773145518000.webp","sourceId":"rfi"},{"id":1773143699000,"createdDate":"2026-03-10 11:54","name":"法国国际广播电台","title":"特朗普称伊战即将结束，伊朗称要继续战斗，以总理称尚未达目标","content":"美国与以色列联手对伊朗发起的大规模军事打击行动进入第11天。接下来将如何发展，美以伊三方表述各异。美国总统9日称战争结束已经迫在眉睫。德黑兰当局则表示不太可能与美恢复谈判。以色列总理似乎认为战争目标尚未达到。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260310-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E4%BC%8A%E6%88%98%E5%8D%B3%E5%B0%86%E7%BB%93%E6%9D%9F%EF%BC%8C%E4%BC%8A%E6%9C%97%E7%A7%B0%E8%A6%81%E7%BB%A7%E7%BB%AD%E6%88%98%E6%96%97%EF%BC%8C%E4%BB%A5%E6%80%BB%E7%90%86%E7%A7%B0%E5%B0%9A%E6%9C%AA%E8%BE%BE%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773143699000.webp","sourceId":"rfi"},{"id":1773142674000,"createdDate":"2026-03-10 11:37","name":"法国国际广播电台","title":"流亡藏人团体在巴黎集会，纪念3-10拉萨起义67周年","content":"法国巴黎的流亡藏人团体以及自由西藏学生会3月10日下午14点30时，在巴黎市中心的共和国广场集会，然后行进到巴士底狱广场，以纪念67年前的拉萨抗暴起义。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260310-%E6%B5%81%E4%BA%A1%E8%97%8F%E4%BA%BA%E5%9B%A2%E4%BD%93%E5%9C%A8%E5%B7%B4%E9%BB%8E%E9%9B%86%E4%BC%9A%EF%BC%8C%E7%BA%AA%E5%BF%B53-10%E6%8B%89%E8%90%A8%E8%B5%B7%E4%B9%8967%E5%91%A8%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773142674000.webp","sourceId":"rfi"},{"id":1773135518000,"createdDate":"2026-03-10 09:38","name":"法国国际广播电台","title":"美军调动驻韩装备支援中东行动，韩国称对朝威慑不受影响","content":"美国和以色列军队已经对伊朗境内的战略目标发动打击超过一周，这引发了人们的担忧：如果冲突长期持续，华盛顿的注意力从亚洲转出，可能会威胁亚太地区和平与稳定。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260310-%E7%BE%8E%E5%86%9B%E8%B0%83%E5%8A%A8%E9%A9%BB%E9%9F%A9%E8%A3%85%E5%A4%87%E6%94%AF%E6%8F%B4%E4%B8%AD%E4%B8%9C%E8%A1%8C%E5%8A%A8%EF%BC%8C%E9%9F%A9%E5%9B%BD%E7%A7%B0%E5%AF%B9%E6%9C%9D%E5%A8%81%E6%85%91%E4%B8%8D%E5%8F%97%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773135518000.webp","sourceId":"rfi"},{"id":1773134035000,"createdDate":"2026-03-10 09:13","name":"法国国际广播电台","title":"巴黎举行第二届重振民用核能峰会","content":"在中东战火继续和国际能源价格价飙升之际，法国总统马克龙和国际原子能机构于今天周二举行第二届重振民用能峰会，共同引导公共和私人投资核能领域发展，包括支持小型核能反应堆。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260310-%E5%B7%B4%E9%BB%8E%E4%B8%BE%E8%A1%8C%E7%AC%AC%E4%BA%8C%E5%B1%8A%E9%87%8D%E6%8C%AF%E6%B0%91%E7%94%A8%E6%A0%B8%E8%83%BD%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773134035000.webp","sourceId":"rfi"},{"id":1773133873000,"createdDate":"2026-03-10 09:11","name":"法国国际广播电台","title":"日本伊朗外长举行电话会谈","content":"3月9日19时25分起，日本外务大臣茂木敏充与伊朗外交部长阿拉格奇举行了电话会谈。发言伊始，茂木大臣表示，针对中东地区持续发生相互攻击、地区局势不断恶化的情况，日本方面深感严重关切，并强烈呼吁有关各方尽早使事态降温、恢复平静。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260310-%E6%97%A5%E6%9C%AC%E4%BC%8A%E6%9C%97%E5%A4%96%E9%95%BF%E4%B8%BE%E8%A1%8C%E7%94%B5%E8%AF%9D%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773133873000.webp","sourceId":"rfi"},{"id":1773186852000,"createdDate":"2026-03-10 23:54","name":"法国国际广播电台","title":"中国正在迈向新的超级科技大国","content":"中国正加速崛起为全球重要的科学强国，并希望在几乎所有科研领域都占据领先地位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260310-%E4%B8%AD%E5%9B%BD%E6%AD%A3%E5%9C%A8%E8%BF%88%E5%90%91%E6%96%B0%E7%9A%84%E8%B6%85%E7%BA%A7%E7%A7%91%E6%8A%80%E5%A4%A7%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773186852000.webp","sourceId":"rfi"},{"id":1773186693000,"createdDate":"2026-03-10 23:51","name":"法国国际广播电台","title":"冯德莱恩：欧洲降低核电占比的决定是个战略错误","content":"中东战火致一度使油价飙升。欧盟委员会主席冯德莱恩在巴黎第二届核能峰会上表示，欧洲此前聚顶降低核电份额的决定是一个战略错误。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260310-%E5%86%AF%E5%BE%B7%E8%8E%B1%E6%81%A9-%E6%AC%A7%E6%B4%B2%E9%99%8D%E4%BD%8E%E6%A0%B8%E7%94%B5%E5%8D%A0%E6%AF%94%E7%9A%84%E5%86%B3%E5%AE%9A%E6%98%AF%E4%B8%AA%E6%88%98%E7%95%A5%E9%94%99%E8%AF%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773186693000.webp","sourceId":"rfi"},{"id":1773178280000,"createdDate":"2026-03-10 21:31","name":"法国国际广播电台","title":"五角大楼证实约140名美军在伊朗军事行动中受伤","content":"美国与伊朗军事冲突持续升高，美国国防部10日证实，自美军对伊朗发动军事行动以来的10天内，约有140名美军士兵受伤，其中8人伤势严重，另有7名士兵在行动中阵亡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260310-%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC%E8%AF%81%E5%AE%9E%E7%BA%A6140%E5%90%8D%E7%BE%8E%E5%86%9B%E5%9C%A8%E4%BC%8A%E6%9C%97%E5%86%9B%E4%BA%8B%E8%A1%8C%E5%8A%A8%E4%B8%AD%E5%8F%97%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773178280000.webp","sourceId":"rfi"},{"id":1773178122000,"createdDate":"2026-03-10 21:28","name":"法国国际广播电台","title":"巴黎峰会：力争到2050 年将核发电能力提高三倍","content":"法国于2026年3月10日举办了第二届核能峰会。中美出席，但俄罗斯缺席。中国外交部9日宣布，中共中央政治局委员、国务院副总理张国清12日应邀赴法国出席第二届核能峰会。来自约40个国家和国际组织的代表将与会，将由法国总统马克龙宣布峰会开幕。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260310-%E5%B7%B4%E9%BB%8E%E5%B3%B0%E4%BC%9A-%E5%8A%9B%E4%BA%89%E5%88%B02050-%E5%B9%B4%E5%B0%86%E6%A0%B8%E5%8F%91%E7%94%B5%E8%83%BD%E5%8A%9B%E6%8F%90%E9%AB%98%E4%B8%89%E5%80%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773178122000.webp","sourceId":"rfi"},{"id":1773177863000,"createdDate":"2026-03-10 21:24","name":"法国国际广播电台","title":"白宫辟谣：未护送任何油轮通过霍尔木兹海峡","content":"伊斯兰革命卫队（IRGC）周二表示，没有美国军舰“胆敢”接近具有战略意义的霍尔木兹海峡。此前，美国曾短暂宣布正在护送一艘油轮通过该海域。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260310-%E7%99%BD%E5%AE%AB%E8%BE%9F%E8%B0%A3-%E6%9C%AA%E6%8A%A4%E9%80%81%E4%BB%BB%E4%BD%95%E6%B2%B9%E8%BD%AE%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773177863000.webp","sourceId":"rfi"},{"id":1773177757000,"createdDate":"2026-03-10 21:22","name":"法国国际广播电台","title":"中国与德国贸易增加、与美国贸易减少","content":"据德新社报道：中国公布强劲贸易数据引发关注。中国与德国贸易增加、与美国贸易减少。但这些数据尚未反映伊朗冲突可能带来的影响。许多人正关注本月底特朗普与习近平的会晤。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260310-%E4%B8%AD%E5%9B%BD%E4%B8%8E%E5%BE%B7%E5%9B%BD%E8%B4%B8%E6%98%93%E5%A2%9E%E5%8A%A0-%E4%B8%8E%E7%BE%8E%E5%9B%BD%E8%B4%B8%E6%98%93%E5%87%8F%E5%B0%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773177757000.webp","sourceId":"rfi"},{"id":1773177752000,"createdDate":"2026-03-10 21:22","name":"法国国际广播电台","title":"油价加速下跌","content":"美国国防部10日报道称，在伊朗战争中，约有140名美国军人受伤。伊朗情报部10日宣布逮捕了30名涉嫌从事间谍活动的人员。此前，伊朗最高领袖穆杰塔巴·哈梅内伊于周日被任命为最高领袖，两天过去了，这位继承人及其妻子仍然找不到行踪。国家电视台泄露的唯一信息是，据称他在持续的冲突中“受伤”。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260310-%E6%B2%B9%E4%BB%B7%E5%8A%A0%E9%80%9F%E4%B8%8B%E8%B7%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773177752000.webp","sourceId":"rfi"},{"id":1773177641000,"createdDate":"2026-03-10 21:20","name":"法国国际广播电台","title":"中朝3月12日起恢复北京—平壤国际旅客列车","content":"中国国家铁路集团宣布，自2026年3月12日起，北京和辽宁丹东至朝鲜平壤之间将恢复双向国际旅客列车服务。过去几年受疫情及边境管控影响一度停运。消息称，北京至平壤的国际旅客列车将于3月12日起开行，每周一、三、四、六双向运行。列车在中国境内停靠北京站、天津站、山海关站、沈阳站和丹东站，在朝鲜境内停靠新义州站和终点平壤站。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260310-%E4%B8%AD%E6%9C%9D3%E6%9C%8812%E6%97%A5%E8%B5%B7%E6%81%A2%E5%A4%8D%E5%8C%97%E4%BA%AC-%E5%B9%B3%E5%A3%A4%E5%9B%BD%E9%99%85%E6%97%85%E5%AE%A2%E5%88%97%E8%BD%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773177641000.webp","sourceId":"rfi"},{"id":1773177333000,"createdDate":"2026-03-10 21:15","name":"法国国际广播电台","title":"英皇家“龙”号驱逐舰（HMS Dragon）驶向地中海","content":"英国国防部宣布，皇家“龙”号驱逐舰（HMSDragon）于周二离开英国朴茨茅斯港（Portsmouth），前往东地中海，以保护塞浦路斯及其英国基地免受伊朗袭击。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260310-%E8%8B%B1%E7%9A%87%E5%AE%B6-%E9%BE%99-%E5%8F%B7%E9%A9%B1%E9%80%90%E8%88%B0-hms-dragon-%E9%A9%B6%E5%90%91%E5%9C%B0%E4%B8%AD%E6%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773177333000.webp","sourceId":"rfi"},{"id":1773177243000,"createdDate":"2026-03-10 21:14","name":"法国国际广播电台","title":"真主党一名成员在德国被判刑","content":"一名黎巴嫩真主党成员周二被德国一家法院判处六年半监禁，罪名是组织出口用于制造针对以色列的爆炸无人机的设备。这名35岁的黎巴嫩公民名叫法德尔·Z（FadelZ），自2024年夏季被捕以来一直被羁押候审。德国北部策勒市（Celle）的法院在一份声明中表示，法德尔·Z“通过部分供述，极大地协助了对其指控的调查。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260310-%E7%9C%9F%E4%B8%BB%E5%85%9A%E4%B8%80%E5%90%8D%E6%88%90%E5%91%98%E5%9C%A8%E5%BE%B7%E5%9B%BD%E8%A2%AB%E5%88%A4%E5%88%91","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773177243000.webp","sourceId":"rfi"},{"id":1773177020000,"createdDate":"2026-03-10 21:10","name":"法国国际广播电台","title":"国泰航班悉尼至伦敦机票飙升至2万欧元","content":"机票价格飙升是中东战争的后果之一。据《卫报》报道，今年4月，搭乘国泰航空绕过海湾国家飞往伦敦的航班，价格不低于2万英镑（超过2.3万欧元）。这一票价远高于往常。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260310-%E5%9B%BD%E6%B3%B0%E8%88%AA%E7%8F%AD%E6%82%89%E5%B0%BC%E8%87%B3%E4%BC%A6%E6%95%A6%E6%9C%BA%E7%A5%A8%E9%A3%99%E5%8D%87%E8%87%B32%E4%B8%87%E6%AC%A7%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773177020000.webp","sourceId":"rfi"},{"id":1773176774000,"createdDate":"2026-03-10 21:06","name":"法国国际广播电台","title":"伊朗承认四名外交官在贝鲁特市中心一酒店被炸死","content":"伊朗常驻联合国代表团周二指责以色列周日袭击贝鲁特一家酒店，导致四名驻黎巴嫩的伊朗外交官遇难。这意味着伊朗承认其驻贝鲁特4名外交官被炸死。以色列军方声称对此次袭击负责。袭击目标是位于黎巴嫩温德姆华美达(RamadabyWyndhamLebanon)酒店，事发时间为夜间。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260310-%E4%BC%8A%E6%9C%97%E6%89%BF%E8%AE%A4%E5%9B%9B%E5%90%8D%E5%A4%96%E4%BA%A4%E5%AE%98%E5%9C%A8%E8%B4%9D%E9%B2%81%E7%89%B9%E5%B8%82%E4%B8%AD%E5%BF%83%E4%B8%80%E9%85%92%E5%BA%97%E8%A2%AB%E7%82%B8%E6%AD%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773176774000.webp","sourceId":"rfi"},{"id":1773176615000,"createdDate":"2026-03-10 21:03","name":"法国国际广播电台","title":"4月13日    利奥十四世开始了非洲之行","content":"罗马天主教教宗良十四世（PopeLeoXIV）4月将访问非洲4国，其中包括阿尔及利亚，这将是历来首次有教宗访问这个北非穆斯林国家。在访问非洲之前，教宗3月28日会先前往蔚蓝海岸（FrenchRiviera）的摩纳哥访问一天，这将是摩纳哥在现代首度迎来教宗访问。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260310-4%E6%9C%8813%E6%97%A5-%E5%88%A9%E5%A5%A5%E5%8D%81%E5%9B%9B%E4%B8%96%E5%BC%80%E5%A7%8B%E4%BA%86%E9%9D%9E%E6%B4%B2%E4%B9%8B%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773176615000.webp","sourceId":"rfi"},{"id":1773175381000,"createdDate":"2026-03-10 20:43","name":"法国国际广播电台","title":"美防长警告俄罗斯不得介入美伊冲突","content":"在美国总统特朗普与俄罗斯总统普京周一1个小时通话后，美国战争部长皮特‧海格塞斯（PeteHegseth）周二（3月10日）警告：要求俄罗斯不得介入美伊冲突。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260310-%E7%BE%8E%E9%98%B2%E9%95%BF%E8%AD%A6%E5%91%8A%E4%BF%84%E7%BD%97%E6%96%AF%E4%B8%8D%E5%BE%97%E4%BB%8B%E5%85%A5%E7%BE%8E%E4%BC%8A%E5%86%B2%E7%AA%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773175381000.webp","sourceId":"rfi"},{"id":1773173286000,"createdDate":"2026-03-10 20:08","name":"法国国际广播电台","title":"跟踪恐吓“李老师”的数名中国人被意大利驱逐","content":"据意大利媒体披露，意大利政府近日将被控监视和恐吓在意大利中国异议人士的8名中国人驱逐出境。此案再让意大利舆论聚焦中国设立“海外警察站”，在多国延伸镇压网络机制的问题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260310-%E8%B7%9F%E8%B8%AA%E6%81%90%E5%90%93-%E6%9D%8E%E8%80%81%E5%B8%88-%E7%9A%84%E6%95%B0%E5%90%8D%E4%B8%AD%E5%9B%BD%E4%BA%BA%E8%A2%AB%E6%84%8F%E5%A4%A7%E5%88%A9%E9%A9%B1%E9%80%90","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773173286000.webp","sourceId":"rfi"},{"id":1773165447000,"createdDate":"2026-03-10 17:57","name":"法国国际广播电台","title":"【视频】面对俄罗斯的威胁  波罗的海三国加强防御","content":"爱沙尼亚、拉脱维亚和立陶宛——这三个波罗的海国家担心自己成为普京的下一个目标。因此，它们决定部署一套强大的防御系统，以抵御来自俄罗斯的坦克地面入侵以及飞机和无人机的空中袭击。和法广同属法国世界媒体集团的法国电视24台的聚焦专栏，播放了法国电视2台同仁克莱尔·维罗夫、吕克·拉克鲁瓦和尼古拉斯·奥尔对此进行了报道。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260310-%E8%A7%86%E9%A2%91-%E9%9D%A2%E5%AF%B9%E4%BF%84%E7%BD%97%E6%96%AF%E7%9A%84%E5%A8%81%E8%83%81-%E6%B3%A2%E7%BD%97%E7%9A%84%E6%B5%B7%E4%B8%89%E5%9B%BD%E5%8A%A0%E5%BC%BA%E9%98%B2%E5%BE%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773165447000.webp","sourceId":"rfi"},{"id":1773163732000,"createdDate":"2026-03-10 17:28","name":"法国国际广播电台","title":"欧盟理事会主席科斯塔：中东战争目前唯一赢家是俄罗斯","content":"欧盟理事会主席科斯塔3月10日在布鲁塞尔向欧盟各国大使发表讲话时表示，随着能源价格上涨，国际对俄乌战争关注度下降，俄罗斯成为中东战争目前唯一的赢家。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260310-%E6%AC%A7%E7%9B%9F%E7%90%86%E4%BA%8B%E4%BC%9A%E4%B8%BB%E5%B8%AD%E7%A7%91%E6%96%AF%E5%A1%94-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E7%9B%AE%E5%89%8D%E5%94%AF%E4%B8%80%E8%B5%A2%E5%AE%B6%E6%98%AF%E4%BF%84%E7%BD%97%E6%96%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/10/1773163732000.webp","sourceId":"rfi"}]