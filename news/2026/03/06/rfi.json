[{"id":1772786323000,"createdDate":"2026-03-06 08:38","name":"法国国际广播电台","title":"英国议员因丈夫涉嫌为北京从事间谍活动遭停职   其丈夫与另外两名嫌疑人已获保释","content":"一名苏格兰工党女议员因丈夫涉嫌为中国从事间谍活动，被暂停在工党议会党团中的职务。此前，她的丈夫与另外两名嫌疑人于周四（3月5日）在该案中获准保释。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260306-%E8%8B%B1%E5%9B%BD%E8%AE%AE%E5%91%98%E5%9B%A0%E4%B8%88%E5%A4%AB%E6%B6%89%E5%AB%8C%E4%B8%BA%E5%8C%97%E4%BA%AC%E4%BB%8E%E4%BA%8B%E9%97%B4%E8%B0%8D%E6%B4%BB%E5%8A%A8%E9%81%AD%E5%81%9C%E8%81%8C-%E5%85%B6%E4%B8%88%E5%A4%AB%E4%B8%8E%E5%8F%A6%E5%A4%96%E4%B8%A4%E5%90%8D%E5%AB%8C%E7%96%91%E4%BA%BA%E5%B7%B2%E8%8E%B7%E4%BF%9D%E9%87%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772786323000.webp","sourceId":"rfi"},{"id":1772785550000,"createdDate":"2026-03-06 08:25","name":"法国国际广播电台","title":"黎智英律师称：不会对已判处的20年监禁提出上诉，但未说明缘由","content":"据路透社3月6日报道，不久前刚刚被判刑的黎智英决定不对其因危害国家安全罪被判处的20年监禁提出上诉，但未说明原因。这一消息来源是黎智英的律师。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260306-%E9%BB%8E%E6%99%BA%E8%8B%B1%E5%BE%8B%E5%B8%88%E7%A7%B0-%E4%B8%8D%E4%BC%9A%E5%AF%B9%E5%B7%B2%E5%88%A4%E5%A4%84%E7%9A%8420%E5%B9%B4%E7%9B%91%E7%A6%81%E6%8F%90%E5%87%BA%E4%B8%8A%E8%AF%89%EF%BC%8C%E4%BD%86%E6%9C%AA%E8%AF%B4%E6%98%8E%E7%BC%98%E7%94%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772785550000.webp","sourceId":"rfi"},{"id":1772784761000,"createdDate":"2026-03-06 08:12","name":"法国国际广播电台","title":"英国安首案：揭港府职员与前警队高层有参与 监视港人丶英国政客及台湾团体","content":"港府在英职员和英国边防人员涉嫌为港府监视在英离散港人的案件本周开审，揭发被这些影子警察监视或有兴趣监视的人，除了香港民主派的前立法会议员罗冠聪和许志峰等离散港人外，还包括英国国会议员和台湾推广全民防卫的民间组织「黑熊学院」。而在香港授意被告去监视或搜集资料的，至少包括三名前警队人员，部分人在退休後转往在港中资机构工作，当中最高级的，是两名前总警司。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260306-%E8%8B%B1%E5%9B%BD%E5%AE%89%E9%A6%96%E6%A1%88-%E6%8F%AD%E6%B8%AF%E5%BA%9C%E8%81%8C%E5%91%98%E4%B8%8E%E5%89%8D%E8%AD%A6%E9%98%9F%E9%AB%98%E5%B1%82%E6%9C%89%E5%8F%82%E4%B8%8E-%E7%9B%91%E8%A7%86%E6%B8%AF%E4%BA%BA%E4%B8%B6%E8%8B%B1%E5%9B%BD%E6%94%BF%E5%AE%A2%E5%8F%8A%E5%8F%B0%E6%B9%BE%E5%9B%A2%E4%BD%93","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772784761000.webp","sourceId":"rfi"},{"id":1772784271000,"createdDate":"2026-03-06 08:04","name":"法国国际广播电台","title":"丁薛祥：落实中港融合 香港须行政主导 吁司法配合","content":"中国国务院副总理丶中共中央港澳工作领导小组组长丁薛祥向香港和澳门的政协委员表明，未来落实「十五五」规划及香港与中国内地融合发展，行政主导都有重要意义及必要性；但真正落实不易，吁包括司法机关在内的各方配合。政协常委唐英年会后否认这是指香港在这方面做得不好。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260306-%E4%B8%81%E8%96%9B%E7%A5%A5-%E8%90%BD%E5%AE%9E%E4%B8%AD%E6%B8%AF%E8%9E%8D%E5%90%88-%E9%A6%99%E6%B8%AF%E9%A1%BB%E8%A1%8C%E6%94%BF%E4%B8%BB%E5%AF%BC-%E5%90%81%E5%8F%B8%E6%B3%95%E9%85%8D%E5%90%88","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772784271000.webp","sourceId":"rfi"},{"id":1772813009000,"createdDate":"2026-03-06 16:03","name":"法国国际广播电台","title":"美国能源部长：美海军将在“条件允许且合理时”护送商船通过霍尔木兹海峡","content":"美国能源部长克里斯·赖特周五（3月6日）表示，在中东冲突爆发一周后，美国海军将在“条件允许且合理时”护送试图通过霍尔木兹海峡的商船。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260306-%E7%BE%8E%E5%9B%BD%E8%83%BD%E6%BA%90%E9%83%A8%E9%95%BF-%E7%BE%8E%E6%B5%B7%E5%86%9B%E5%B0%86%E5%9C%A8-%E6%9D%A1%E4%BB%B6%E5%85%81%E8%AE%B8%E4%B8%94%E5%90%88%E7%90%86%E6%97%B6-%E6%8A%A4%E9%80%81%E5%95%86%E8%88%B9%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772813009000.webp","sourceId":"rfi"},{"id":1772812381000,"createdDate":"2026-03-06 15:53","name":"法国国际广播电台","title":"特朗普：不会与伊朗达成任何协议，只有无条件投降","content":"美国总统特朗普周五（3月6日）要求伊朗“无条件投降”，并表示美国打算参与选择该国未来的领导人，同时参与其战后重建。不过，他在相关表态中并未解释“投降”这一说法具体意味着什么。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260306-%E7%89%B9%E6%9C%97%E6%99%AE-%E4%B8%8D%E4%BC%9A%E4%B8%8E%E4%BC%8A%E6%9C%97%E8%BE%BE%E6%88%90%E4%BB%BB%E4%BD%95%E5%8D%8F%E8%AE%AE%EF%BC%8C%E5%8F%AA%E6%9C%89%E6%97%A0%E6%9D%A1%E4%BB%B6%E6%8A%95%E9%99%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772812381000.webp","sourceId":"rfi"},{"id":1772811026000,"createdDate":"2026-03-06 15:30","name":"法国国际广播电台","title":"港府限制记者车牌查册被指干预新闻自由 记协遗憾法院裁挑战败诉","content":"就运输署要求新闻工作者进行车牌查册时须先获批准的新安排，香港法院裁定，香港记者协会(记协)挑战上述规定的司法覆核败诉，意味记者日後要继续面对申请几乎无一成功的情况。记协发表声明，对裁决表示遗憾，认为判决并无充份考虑业界申请时的实际困难，会考虑是否提出上诉。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260306-%E6%B8%AF%E5%BA%9C%E9%99%90%E5%88%B6%E8%AE%B0%E8%80%85%E8%BD%A6%E7%89%8C%E6%9F%A5%E5%86%8C%E8%A2%AB%E6%8C%87%E5%B9%B2%E9%A2%84%E6%96%B0%E9%97%BB%E8%87%AA%E7%94%B1-%E8%AE%B0%E5%8D%8F%E9%81%97%E6%86%BE%E6%B3%95%E9%99%A2%E8%A3%81%E6%8C%91%E6%88%98%E8%B4%A5%E8%AF%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772811026000.webp","sourceId":"rfi"},{"id":1772810821000,"createdDate":"2026-03-06 15:27","name":"法国国际广播电台","title":"米兰冬残奥会开幕：七国因俄罗斯重返赛场抵制开幕式，唯一一位伊朗运动员被迫退赛","content":"在紧张的国际氛围下，2026年米兰科尔蒂纳冬残奥会（2026年3月6日至15日）拉开帷幕。由于反对俄罗斯重返赛场，七个国家宣布抵制开幕式，同时中东战争也为赛事蒙上阴影。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260306-%E7%B1%B3%E5%85%B0%E5%86%AC%E6%AE%8B%E5%A5%A5%E4%BC%9A%E5%BC%80%E5%B9%95-%E4%B8%83%E5%9B%BD%E5%9B%A0%E4%BF%84%E7%BD%97%E6%96%AF%E9%87%8D%E8%BF%94%E8%B5%9B%E5%9C%BA%E6%8A%B5%E5%88%B6%E5%BC%80%E5%B9%95%E5%BC%8F%EF%BC%8C%E5%94%AF%E4%B8%80%E4%B8%80%E4%BD%8D%E4%BC%8A%E6%9C%97%E8%BF%90%E5%8A%A8%E5%91%98%E8%A2%AB%E8%BF%AB%E9%80%80%E8%B5%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772810821000.webp","sourceId":"rfi"},{"id":1772810216000,"createdDate":"2026-03-06 15:16","name":"法国国际广播电台","title":"中东战火：法国戴高乐号航母已抵达地中海","content":"法国戴高乐号航母在途经直布罗陀海峡于今天周五下午进入地中海，并要驶向中东。法国要派遣戴高乐号航母到中东保护其公民和盟友免受伊朗袭击。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260306-%E4%B8%AD%E4%B8%9C%E6%88%98%E7%81%AB-%E6%B3%95%E5%9B%BD%E6%88%B4%E9%AB%98%E4%B9%90%E5%8F%B7%E8%88%AA%E6%AF%8D%E5%B7%B2%E6%8A%B5%E8%BE%BE%E5%9C%B0%E4%B8%AD%E6%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772810216000.webp","sourceId":"rfi"},{"id":1772808936000,"createdDate":"2026-03-06 14:55","name":"法国国际广播电台","title":"战争第七日以军空袭启动“新阶段”  特朗普：除非无条件投降 别无协议可能","content":"美以军事打击伊朗进入第七天，战火继续在中东蔓延。在宣布战争将进入“新阶段”之后，以色列军队周五（3月6日）对贝鲁特和德黑兰发动新一轮大规模空袭。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260306-%E6%88%98%E4%BA%89%E7%AC%AC%E4%B8%83%E6%97%A5%E4%BB%A5%E5%86%9B%E7%A9%BA%E8%A2%AD%E5%90%AF%E5%8A%A8-%E6%96%B0%E9%98%B6%E6%AE%B5-%E7%89%B9%E6%9C%97%E6%99%AE-%E9%99%A4%E9%9D%9E%E6%97%A0%E6%9D%A1%E4%BB%B6%E6%8A%95%E9%99%8D-%E5%88%AB%E6%97%A0%E5%8D%8F%E8%AE%AE%E5%8F%AF%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772808936000.webp","sourceId":"rfi"},{"id":1772808842000,"createdDate":"2026-03-06 14:54","name":"法国国际广播电台","title":"为松缓市场压力，美国暂允滞留海上的俄罗斯石油运往印度","content":"几个月前还以惩罚性关税逼迫印度停止购买俄罗斯石油的特朗普政府5日宣布，允许目前因制裁措施滞留海上的俄罗斯石油运往印度。美国财长贝森特在社交媒体X平台上解释说，这项临时措施是为了保证市场上的石油供应。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260306-%E4%B8%BA%E6%9D%BE%E7%BC%93%E5%B8%82%E5%9C%BA%E5%8E%8B%E5%8A%9B%EF%BC%8C%E7%BE%8E%E5%9B%BD%E6%9A%82%E5%85%81%E6%BB%9E%E7%95%99%E6%B5%B7%E4%B8%8A%E7%9A%84%E4%BF%84%E7%BD%97%E6%96%AF%E7%9F%B3%E6%B2%B9%E8%BF%90%E5%BE%80%E5%8D%B0%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772808842000.webp","sourceId":"rfi"},{"id":1772808709000,"createdDate":"2026-03-06 14:51","name":"法国国际广播电台","title":"乌克兰将“很快”向中东派遣无人机军事专家  希望以此换取美国的支持对抗俄罗斯","content":"一名乌克兰官员周五（3月6日）向法新社表示，基辅将“很快”向中东派遣军事人员，协助美国及其盟友应对伊朗无人机袭击，并希望以此换取在对抗俄罗斯问题上的外交和军事支持。据悉，俄罗斯大量使用无人机对乌克兰进行轰炸，而这些无人机由伊朗设计、如今已在俄罗斯生产，因此乌克兰在对抗这类武器方面积累了丰富经验。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260306-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%B0%86-%E5%BE%88%E5%BF%AB-%E5%90%91%E4%B8%AD%E4%B8%9C%E6%B4%BE%E9%81%A3%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%86%9B%E4%BA%8B%E4%B8%93%E5%AE%B6-%E5%B8%8C%E6%9C%9B%E4%BB%A5%E6%AD%A4%E6%8D%A2%E5%8F%96%E7%BE%8E%E5%9B%BD%E7%9A%84%E6%94%AF%E6%8C%81%E5%AF%B9%E6%8A%97%E4%BF%84%E7%BD%97%E6%96%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772808709000.webp","sourceId":"rfi"},{"id":1772800871000,"createdDate":"2026-03-06 12:41","name":"法国国际广播电台","title":"台媒：两会上习近平罕见“传纸条”","content":"台湾媒体上报6日报导，中国两会开幕式上一段“传纸条”画面意外成为焦点，法新社的镜头捕捉到中国国家主席习近平与全国政协主席王沪宁多次交谈，随后王沪宁又把讯息传给另一侧的多位高官，都有说有笑。过了一会儿，王沪宁将一张写着4行横排文字的纸条传给习近平，习近平看完后，跟王沪宁说了几句话，也将纸条交回给王沪宁。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260306-%E5%8F%B0%E5%AA%92-%E4%B8%A4%E4%BC%9A%E4%B8%8A%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%BD%95%E8%A7%81-%E4%BC%A0%E7%BA%B8%E6%9D%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772800871000.webp","sourceId":"rfi"},{"id":1772800781000,"createdDate":"2026-03-06 12:39","name":"法国国际广播电台","title":"中国称“充分意识到”当前经济挑战，将着力提振国内消费","content":"综合法新社与路透社消息，国家发改委负责人郑栅洁周五（3月6日）在答记者问时表示，中国“充分意识到”当前面临的经济增长挑战，并承诺将采取措施提振国内消费。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260306-%E4%B8%AD%E5%9B%BD%E7%A7%B0-%E5%85%85%E5%88%86%E6%84%8F%E8%AF%86%E5%88%B0-%E5%BD%93%E5%89%8D%E7%BB%8F%E6%B5%8E%E6%8C%91%E6%88%98%EF%BC%8C%E5%B0%86%E7%9D%80%E5%8A%9B%E6%8F%90%E6%8C%AF%E5%9B%BD%E5%86%85%E6%B6%88%E8%B4%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772800781000.webp","sourceId":"rfi"},{"id":1772796789000,"createdDate":"2026-03-06 11:33","name":"法国国际广播电台","title":"联合国2025年知识产权报告：中国专利申请量居首，华为自2017年来一直保持第一， 美国连续第四年下降","content":"联合国周五（3月6日）发布报告，显示2025年全球在数字通信技术和半导体领域提交的国际专利申请大幅增长，这反映出对人工智能的投资持续增加。而中国以73,718件国际专利申请位居世界第一，同比增长5.3%。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260306-%E8%81%94%E5%90%88%E5%9B%BD2025%E5%B9%B4%E7%9F%A5%E8%AF%86%E4%BA%A7%E6%9D%83%E6%8A%A5%E5%91%8A-%E4%B8%AD%E5%9B%BD%E4%B8%93%E5%88%A9%E7%94%B3%E8%AF%B7%E9%87%8F%E5%B1%85%E9%A6%96%EF%BC%8C%E5%8D%8E%E4%B8%BA%E8%87%AA2017%E5%B9%B4%E6%9D%A5%E4%B8%80%E7%9B%B4%E4%BF%9D%E6%8C%81%E7%AC%AC%E4%B8%80%EF%BC%8C-%E7%BE%8E%E5%9B%BD%E8%BF%9E%E7%BB%AD%E7%AC%AC%E5%9B%9B%E5%B9%B4%E4%B8%8B%E9%99%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772796789000.webp","sourceId":"rfi"},{"id":1772793953000,"createdDate":"2026-03-06 10:45","name":"法国国际广播电台","title":"中东战火目前对法国经济增长影响有限","content":"自中东冲突爆发引发国际油气价格飙升可能导致法国通胀飙，进而对经济增长造成压力。法国经济和财政部正努力安抚民众，强调目前的情况与2022年爆发俄罗斯入侵乌克兰引发的国际能源危机截然不同。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E7%BB%8F%E6%B5%8E/20260306-%E4%B8%AD%E4%B8%9C%E6%88%98%E7%81%AB%E7%9B%AE%E5%89%8D%E5%AF%B9%E6%B3%95%E5%9B%BD%E7%BB%8F%E6%B5%8E%E5%A2%9E%E9%95%BF%E5%BD%B1%E5%93%8D%E6%9C%89%E9%99%90","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772793953000.webp","sourceId":"rfi"},{"id":1772790933000,"createdDate":"2026-03-06 09:55","name":"法国国际广播电台","title":"澳大利亚谴责中国军用直升机在海上靠近澳军机，并进行“危险飞行”，中国外交部称“不知情”","content":"澳大利亚军方周五（3月6日）表示，一架中国军用直升机在黄海上空靠近一架澳大利亚军机进行危险飞行，并谴责这一“危险”操作。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260306-%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E8%B0%B4%E8%B4%A3%E4%B8%AD%E5%9B%BD%E5%86%9B%E7%94%A8%E7%9B%B4%E5%8D%87%E6%9C%BA%E5%9C%A8%E6%B5%B7%E4%B8%8A%E9%9D%A0%E8%BF%91%E6%BE%B3%E5%86%9B%E6%9C%BA%EF%BC%8C%E5%B9%B6%E8%BF%9B%E8%A1%8C-%E5%8D%B1%E9%99%A9%E9%A3%9E%E8%A1%8C-%EF%BC%8C%E4%B8%AD%E5%9B%BD%E5%A4%96%E4%BA%A4%E9%83%A8%E7%A7%B0-%E4%B8%8D%E7%9F%A5%E6%83%85","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772790933000.webp","sourceId":"rfi"},{"id":1772790163000,"createdDate":"2026-03-06 09:42","name":"法国国际广播电台","title":"匈牙利乌克兰争端升级：7名乌方银行员工运送3500万欧元现金时被扣押，欧尔班威胁阻止乌方一切重要物资过境","content":"匈牙利与乌克兰之间的争端周五（3月6日）进一步升级。匈牙利总理维克托·欧尔班周五（3月6日）在匈牙利国家广播电台表示：“在我们获得乌克兰方面批准恢复石油输送之前，我们将停止让那些对乌克兰至关重要的物资经由匈牙利过境。”周四至周五夜间，乌克兰政府指责匈牙利“扣押”了7名乌克兰银行员工。这些员工当时正从奥地利经过匈牙利运送资金，包括3500万欧元现金和9公斤黄金。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260306-%E5%8C%88%E7%89%99%E5%88%A9%E4%B9%8C%E5%85%8B%E5%85%B0%E4%BA%89%E7%AB%AF%E5%8D%87%E7%BA%A7-7%E5%90%8D%E4%B9%8C%E6%96%B9%E9%93%B6%E8%A1%8C%E5%91%98%E5%B7%A5%E8%BF%90%E9%80%813500%E4%B8%87%E6%AC%A7%E5%85%83%E7%8E%B0%E9%87%91%E6%97%B6%E8%A2%AB%E6%89%A3%E6%8A%BC%EF%BC%8C%E6%AC%A7%E5%B0%94%E7%8F%AD%E5%A8%81%E8%83%81%E9%98%BB%E6%AD%A2%E4%B9%8C%E6%96%B9%E4%B8%80%E5%88%87%E9%87%8D%E8%A6%81%E7%89%A9%E8%B5%84%E8%BF%87%E5%A2%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772790163000.webp","sourceId":"rfi"},{"id":1772788901000,"createdDate":"2026-03-06 09:21","name":"法国国际广播电台","title":"战争进入第七天：以色列发动新一轮空袭，并宣称战争已完成“突袭阶段”，现进入“下一阶段”","content":"目前，中东冲突已经入第七天。以色列军方周五（3月6日）对德黑兰发动了一系列“大规模”空袭，称目标是伊朗政权的基础设施，并表示这是对伊朗战争进入“新阶段”的一部分。法新社称，这场战争现在的重点是伊朗的国家基础设施及其黎巴嫩盟友真主党的据点。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260306-%E6%88%98%E4%BA%89%E8%BF%9B%E5%85%A5%E7%AC%AC%E4%B8%83%E5%A4%A9-%E4%BB%A5%E8%89%B2%E5%88%97%E5%8F%91%E5%8A%A8%E6%96%B0%E4%B8%80%E8%BD%AE%E7%A9%BA%E8%A2%AD%EF%BC%8C%E5%B9%B6%E5%AE%A3%E7%A7%B0%E6%88%98%E4%BA%89%E5%B7%B2%E5%AE%8C%E6%88%90-%E7%AA%81%E8%A2%AD%E9%98%B6%E6%AE%B5-%EF%BC%8C%E7%8E%B0%E8%BF%9B%E5%85%A5-%E4%B8%8B%E4%B8%80%E9%98%B6%E6%AE%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772788901000.webp","sourceId":"rfi"},{"id":1772788497000,"createdDate":"2026-03-06 09:14","name":"法国国际广播电台","title":"加拿大总理访日 日本希望加拿大成为日本稀土重要供应国","content":"3月6日至3月7日，加拿大总理马克·卡尼及其夫人将访问日本。日本时间6日晚，高市早苗首相将与卡尼总理举行会谈，随后将举行工作晚宴，并发表联合声明，联合声明核心内容是制定一份“全面战略路线图（行动计划）”，在加强防务合作、经济安全保障、能源安全等六个领域明确具体合作方向。双方还将通过首脑和阁僚的定期互访，加强日加之间的交流。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260306-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E6%80%BB%E7%90%86%E8%AE%BF%E6%97%A5-%E6%97%A5%E6%9C%AC%E5%B8%8C%E6%9C%9B%E5%8A%A0%E6%8B%BF%E5%A4%A7%E6%88%90%E4%B8%BA%E6%97%A5%E6%9C%AC%E7%A8%80%E5%9C%9F%E9%87%8D%E8%A6%81%E4%BE%9B%E5%BA%94%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772788497000.webp","sourceId":"rfi"},{"id":1772787935000,"createdDate":"2026-03-06 09:05","name":"法国国际广播电台","title":"美国和委内瑞拉将恢复中断六年的外交关系","content":"美国周四（3月5日）宣布，将恢复与委内瑞拉的外交与领事关系。美国与委内瑞拉外交关系自2019年起中断至今。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260306-%E7%BE%8E%E5%9B%BD%E5%92%8C%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E5%B0%86%E6%81%A2%E5%A4%8D%E4%B8%AD%E6%96%AD%E5%85%AD%E5%B9%B4%E7%9A%84%E5%A4%96%E4%BA%A4%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772787935000.webp","sourceId":"rfi"},{"id":1772787202000,"createdDate":"2026-03-06 08:53","name":"法国国际广播电台","title":"继一名NHK记者被捕后，又有一名日本公民在伊朗被逮捕","content":"日本政府周五（3月6日）表示，又有一名日本公民在伊朗被拘留。这是继今年1月底首名日本人被捕之后发生的第二起案件。日本政府呼吁伊朗方面“尽快释放”两人。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260306-%E7%BB%A7%E4%B8%80%E5%90%8Dnhk%E8%AE%B0%E8%80%85%E8%A2%AB%E6%8D%95%E5%90%8E%EF%BC%8C%E5%8F%88%E6%9C%89%E4%B8%80%E5%90%8D%E6%97%A5%E6%9C%AC%E5%85%AC%E6%B0%91%E5%9C%A8%E4%BC%8A%E6%9C%97%E8%A2%AB%E9%80%AE%E6%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772787202000.webp","sourceId":"rfi"}]