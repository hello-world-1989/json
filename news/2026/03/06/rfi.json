[{"id":1772786323000,"createdDate":"2026-03-06 08:38","name":"法国国际广播电台","title":"英国议员因丈夫涉嫌为北京从事间谍活动遭停职   其丈夫与另外两名嫌疑人已获保释","content":"一名苏格兰工党女议员因丈夫涉嫌为中国从事间谍活动，被暂停在工党议会党团中的职务。此前，她的丈夫与另外两名嫌疑人于周四（3月5日）在该案中获准保释。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260306-%E8%8B%B1%E5%9B%BD%E8%AE%AE%E5%91%98%E5%9B%A0%E4%B8%88%E5%A4%AB%E6%B6%89%E5%AB%8C%E4%B8%BA%E5%8C%97%E4%BA%AC%E4%BB%8E%E4%BA%8B%E9%97%B4%E8%B0%8D%E6%B4%BB%E5%8A%A8%E9%81%AD%E5%81%9C%E8%81%8C-%E5%85%B6%E4%B8%88%E5%A4%AB%E4%B8%8E%E5%8F%A6%E5%A4%96%E4%B8%A4%E5%90%8D%E5%AB%8C%E7%96%91%E4%BA%BA%E5%B7%B2%E8%8E%B7%E4%BF%9D%E9%87%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772786323000.webp","sourceId":"rfi"},{"id":1772785550000,"createdDate":"2026-03-06 08:25","name":"法国国际广播电台","title":"黎智英律师称：不会对已判处的20年监禁提出上诉，但未说明缘由","content":"据路透社3月6日报道，不久前刚刚被判刑的黎智英决定不对其因危害国家安全罪被判处的20年监禁提出上诉，但未说明原因。这一消息来源是黎智英的律师。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260306-%E9%BB%8E%E6%99%BA%E8%8B%B1%E5%BE%8B%E5%B8%88%E7%A7%B0-%E4%B8%8D%E4%BC%9A%E5%AF%B9%E5%B7%B2%E5%88%A4%E5%A4%84%E7%9A%8420%E5%B9%B4%E7%9B%91%E7%A6%81%E6%8F%90%E5%87%BA%E4%B8%8A%E8%AF%89%EF%BC%8C%E4%BD%86%E6%9C%AA%E8%AF%B4%E6%98%8E%E7%BC%98%E7%94%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772785550000.webp","sourceId":"rfi"},{"id":1772784761000,"createdDate":"2026-03-06 08:12","name":"法国国际广播电台","title":"英国安首案：揭港府职员与前警队高层有参与 监视港人丶英国政客及台湾团体","content":"港府在英职员和英国边防人员涉嫌为港府监视在英离散港人的案件本周开审，揭发被这些影子警察监视或有兴趣监视的人，除了香港民主派的前立法会议员罗冠聪和许志峰等离散港人外，还包括英国国会议员和台湾推广全民防卫的民间组织「黑熊学院」。而在香港授意被告去监视或搜集资料的，至少包括三名前警队人员，部分人在退休後转往在港中资机构工作，当中最高级的，是两名前总警司。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260306-%E8%8B%B1%E5%9B%BD%E5%AE%89%E9%A6%96%E6%A1%88-%E6%8F%AD%E6%B8%AF%E5%BA%9C%E8%81%8C%E5%91%98%E4%B8%8E%E5%89%8D%E8%AD%A6%E9%98%9F%E9%AB%98%E5%B1%82%E6%9C%89%E5%8F%82%E4%B8%8E-%E7%9B%91%E8%A7%86%E6%B8%AF%E4%BA%BA%E4%B8%B6%E8%8B%B1%E5%9B%BD%E6%94%BF%E5%AE%A2%E5%8F%8A%E5%8F%B0%E6%B9%BE%E5%9B%A2%E4%BD%93","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772784761000.webp","sourceId":"rfi"},{"id":1772784271000,"createdDate":"2026-03-06 08:04","name":"法国国际广播电台","title":"丁薛祥：落实中港融合 香港须行政主导 吁司法配合","content":"中国国务院副总理丶中共中央港澳工作领导小组组长丁薛祥向香港和澳门的政协委员表明，未来落实「十五五」规划及香港与中国内地融合发展，行政主导都有重要意义及必要性；但真正落实不易，吁包括司法机关在内的各方配合。政协常委唐英年会后否认这是指香港在这方面做得不好。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260306-%E4%B8%81%E8%96%9B%E7%A5%A5-%E8%90%BD%E5%AE%9E%E4%B8%AD%E6%B8%AF%E8%9E%8D%E5%90%88-%E9%A6%99%E6%B8%AF%E9%A1%BB%E8%A1%8C%E6%94%BF%E4%B8%BB%E5%AF%BC-%E5%90%81%E5%8F%B8%E6%B3%95%E9%85%8D%E5%90%88","thumbnail":"","detailImage":"news/detail/rfi/2026/03/06/1772784271000.webp","sourceId":"rfi"}]