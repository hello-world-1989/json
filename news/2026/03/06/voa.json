[{"id":1772763593000,"createdDate":"2026-03-06 02:19","name":"美国之音","title":"伊朗发动“不分青红皂白的”袭击之际，北约加强全联盟导弹防御态势","content":"北约星期四(3月5日)表示正在加强全联盟范围的弹道导弹防御，以回应伊朗在中东地区“不分青红皂白的”袭击。","newsLink":"https://www.voachinese.com/a/nato-to-increase-alliance-wide-ballistic-missile-defense-posture-amid-iran-s-indiscriminate-attacks-20260305/8121932.html","thumbnail":"","detailImage":"news/detail/voa/2026/03/06/1772763593000.webp","sourceId":"voa"},{"id":1772761755000,"createdDate":"2026-03-06 01:49","name":"美国之音","title":"特朗普总统：美以联合攻势六天内摧毁了伊朗政权近三分之二的导弹资产","content":"美国总统唐纳德·特朗普表示，自上星期六的军事行动开始以来，美以联合对伊朗恐怖政权发起的攻势已摧毁了其近三分之二的导弹和导弹发射装置。","newsLink":"https://www.voachinese.com/a/president-trump-says-us-israeli-offensive-has-destroyed-almost-two-thirds-of-iranian-regime-s-missile-assets-in-six-days--20260305/8121927.html","thumbnail":"","detailImage":"news/detail/voa/2026/03/06/1772761755000.webp","sourceId":"voa"},{"id":1772759698000,"createdDate":"2026-03-06 01:14","name":"美国之音","title":"以色列下令黎巴嫩南部大片地区全面撤离，并对贝鲁特真主党指挥中心发动袭击","content":"以色列星期四(3月5日)扩大了在黎巴嫩的疏散令范围，并下令贝鲁特南部几个街区的所有居民立即撤离。此前，以色列与伊朗支持的真主党恐怖组织之间的冲突不断升级。","newsLink":"https://www.voachinese.com/a/israel-orders-full-evacuation-of-large-parts-of-southern-lebanon-strikes-hezbollah-command-centers-in-beirut-20260305/8121921.html","thumbnail":"","detailImage":"news/detail/voa/2026/03/06/1772759698000.webp","sourceId":"voa"},{"id":1772758484000,"createdDate":"2026-03-06 00:54","name":"美国之音","title":"特朗普宣布新的国土安全部长人选","content":"美国总统唐纳德·特朗普星期四(3月5日)宣布为国土安全部选择了新部长，现任部长克里斯蒂·诺姆将另任新职。","newsLink":"https://www.voachinese.com/a/trump-announces-new-homeland-security-secretary-20260305/8121925.html","thumbnail":"","detailImage":"news/detail/voa/2026/03/06/1772758484000.webp","sourceId":"voa"},{"id":1772811518000,"createdDate":"2026-03-06 15:38","name":"美国之音","title":"特朗普总统表示愿意接受任何国家提供援助，抵御伊朗无人机袭击","content":"在乌克兰提出帮助抵御伊朗无人机袭击后，美国总统唐纳德·特朗普(DonaldTrump)表示，他将接受任何国家的援助。","newsLink":"https://www.voachinese.com/a/us-russia-ukraine-20260306/8122013.html",