[{"id":1772872695000,"createdDate":"2026-03-07 08:38","name":"法国国际广播电台","title":"美国批准向以色列出售1.2万枚炸弹  价值超1.5亿美元","content":"中东局势不断升级之际，美国国务院周五（3月6日）批准向以色列出售1.2万枚重470公斤的炸弹。据美国国务院政治军事事务局发布的新闻稿称，这笔军售价值1.518亿美元。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260307-%E7%BE%8E%E5%9B%BD%E6%89%B9%E5%87%86%E5%90%91%E4%BB%A5%E8%89%B2%E5%88%97%E5%87%BA%E5%94%AE1-2%E4%B8%87%E6%9E%9A%E7%82%B8%E5%BC%B9-%E4%BB%B7%E5%80%BC%E8%B6%851-5%E4%BA%BF%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772872695000.webp","sourceId":"rfi"},{"id":1772897065000,"createdDate":"2026-03-07 15:24","name":"法国国际广播电台","title":"美国开始使用英国军事基地对伊朗开展行动","content":"英国国防部周六（3月7日）宣布美国武装部队已经开始使用英国的军事基地，在中东冲突中开展“防御性行动”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260307-%E7%BE%8E%E5%9B%BD%E5%BC%80%E5%A7%8B%E4%BD%BF%E7%94%A8%E8%8B%B1%E5%9B%BD%E5%86%9B%E4%BA%8B%E5%9F%BA%E5%9C%B0%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%BC%80%E5%B1%95%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772897065000.webp","sourceId":"rfi"},{"id":1772896482000,"createdDate":"2026-03-07 15:14","name":"法国国际广播电台","title":"特朗普称“伊朗今天将遭到非常猛烈的打击”  伊朗誓言绝不投降","content":"美国总统特朗普周六（3月7日）表示，美国将“非常猛烈地”打击伊朗，并威胁称可能把打击范围扩大到“此前从未被视为目标的地区和人群”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260307-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0-%E4%BC%8A%E6%9C%97%E4%BB%8A%E5%A4%A9%E5%B0%86%E9%81%AD%E5%88%B0%E9%9D%9E%E5%B8%B8%E7%8C%9B%E7%83%88%E7%9A%84%E6%89%93%E5%87%BB-%E4%BC%8A%E6%9C%97%E8%AA%93%E8%A8%80%E7%BB%9D%E4%B8%8D%E6%8A%95%E9%99%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772896482000.webp","sourceId":"rfi"},{"id":1772889824000,"createdDate":"2026-03-07 13:23","name":"法国国际广播电台","title":"美国和以色列与伊朗的战争还没有停下来的迹象， 特朗普迎美军遗体","content":"美国和以色列与伊朗的战争还没有停下来的迹象。美国政府表示，与伊朗的战争可能会持续数周，可能长达四周或更久。美国总统特朗普曾表示，美国最大的几家国防企业已同意将先进武器的产量提高三倍。这场战争已造成六名美国军人死亡，特朗普将于周六在特拉华州多佛空军基地举行的遗体移交仪式上等待他们的遗体运回。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260307-%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%BB%A5%E8%89%B2%E5%88%97%E4%B8%8E%E4%BC%8A%E6%9C%97%E7%9A%84%E6%88%98%E4%BA%89%E8%BF%98%E6%B2%A1%E6%9C%89%E5%81%9C%E4%B8%8B%E6%9D%A5%E7%9A%84%E8%BF%B9%E8%B1%A1%EF%BC%8C-%E7%89%B9%E6%9C%97%E6%99%AE%E8%BF%8E%E7%BE%8E%E5%86%9B%E9%81%97%E4%BD%93","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772889824000.webp","sourceId":"rfi"},{"id":1772882919000,"createdDate":"2026-03-07 11:28","name":"法国国际广播电台","title":"法国年3月15日起举行市政选举，将对未来的总统选举和立法选举带来前瞻性民意信息","content":"法国将于2026年3月15日和22日这两个星期日举行市政选举，选出市议员。选出来的市议员们将再从市议员中选出全国34875个市镇的市长。这次选举对法国民主至关重要，因为选举结果将直接影响选民的日常生活：选举结果将决定地方事务的管理、城市规划、公共服务、住房、教育、文化活力和区域发展等方方面面。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260307-%E6%B3%95%E5%9B%BD%E5%B9%B43%E6%9C%8815%E6%97%A5%E8%B5%B7%E4%B8%BE%E8%A1%8C%E5%B8%82%E6%94%BF%E9%80%89%E4%B8%BE%EF%BC%8C%E5%B0%86%E5%AF%B9%E6%9C%AA%E6%9D%A5%E7%9A%84%E6%80%BB%E7%BB%9F%E9%80%89%E4%B8%BE%E5%92%8C%E7%AB%8B%E6%B3%95%E9%80%89%E4%B8%BE%E5%B8%A6%E6%9D%A5%E5%89%8D%E7%9E%BB%E6%80%A7%E6%B0%91%E6%84%8F%E4%BF%A1%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772882919000.webp","sourceId":"rfi"},{"id":1772881145000,"createdDate":"2026-03-07 10:59","name":"法国国际广播电台","title":"香港公司就两大运河港口接管向巴拿马政府索赔20亿美元","content":"总部位于香港的长和集团旗下子公司表示，已失去对巴拿马运河两大关键港口的控制权，并就港口被“非法”接管一事向巴拿马政府索赔20亿美元的损失。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260307-%E9%A6%99%E6%B8%AF%E5%85%AC%E5%8F%B8%E5%B0%B1%E4%B8%A4%E5%A4%A7%E8%BF%90%E6%B2%B3%E6%B8%AF%E5%8F%A3%E6%8E%A5%E7%AE%A1%E5%90%91%E5%B7%B4%E6%8B%BF%E9%A9%AC%E6%94%BF%E5%BA%9C%E7%B4%A2%E8%B5%9420%E4%BA%BF%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772881145000.webp","sourceId":"rfi"},{"id":1772880559000,"createdDate":"2026-03-07 10:49","name":"法国国际广播电台","title":"中国两会北京举行，十五五规划纲要提北京将掌握台海两岸关系主导权","content":"中国两会于4日在北京举行，其中十五五规划纲要草案以完整篇章形式处理两岸议题，被外界视为观察中国对台政策的重要窗口。国台办主任宋涛表示将贯彻纲要任务，坚决打击台独分裂势力。‘","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260307-%E4%B8%AD%E5%9B%BD%E4%B8%A4%E4%BC%9A%E5%8C%97%E4%BA%AC%E4%B8%BE%E8%A1%8C%EF%BC%8C%E5%8D%81%E4%BA%94%E4%BA%94%E8%A7%84%E5%88%92%E7%BA%B2%E8%A6%81%E6%8F%90%E5%8C%97%E4%BA%AC%E5%B0%86%E6%8E%8C%E6%8F%A1%E5%8F%B0%E6%B5%B7%E4%B8%A4%E5%B2%B8%E5%85%B3%E7%B3%BB%E4%B8%BB%E5%AF%BC%E6%9D%83","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772880559000.webp","sourceId":"rfi"},{"id":1772880232000,"createdDate":"2026-03-07 10:43","name":"法国国际广播电台","title":"日加首脑会谈：只批中国和伊朗不触碰美国","content":"日本时间3月6日19时15分起，日本首相高市早苗与正在访日的加拿大总理马克·卡尼举行了日加首脑会谈。并举行了《关于日本—加拿大全面战略伙伴关系的联合声明》签署仪式及联合记者会，并进行了约75分钟的工作晚餐。参考日本外务省发表的公告，在两国首脑会谈时和发表的联合声明中，在涉及国际问题时，只批判中国、伊朗及朝鲜等，回避触及美国等对他国发动的一系列军事行动。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260307-%E6%97%A5%E5%8A%A0%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88-%E5%8F%AA%E6%89%B9%E4%B8%AD%E5%9B%BD%E5%92%8C%E4%BC%8A%E6%9C%97%E4%B8%8D%E8%A7%A6%E7%A2%B0%E7%BE%8E%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772880232000.webp","sourceId":"rfi"},{"id":1772877278000,"createdDate":"2026-03-07 09:54","name":"法国国际广播电台","title":"俄罗斯对乌克兰发动新一轮袭击，至少七人遇难，包括两名儿童","content":"乌克兰官员表示，俄罗斯在周五（3月6日）至周六（3月7日）夜间向乌克兰发动新一轮无人机和导弹袭击，哈尔科夫（乌克兰东北部城市）至少造成七人死亡，其中包括两名儿童。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260307-%E4%BF%84%E7%BD%97%E6%96%AF%E5%AF%B9%E4%B9%8C%E5%85%8B%E5%85%B0%E5%8F%91%E5%8A%A8%E6%96%B0%E4%B8%80%E8%BD%AE%E8%A2%AD%E5%87%BB%EF%BC%8C%E8%87%B3%E5%B0%91%E4%B8%83%E4%BA%BA%E9%81%87%E9%9A%BE%EF%BC%8C%E5%8C%85%E6%8B%AC%E4%B8%A4%E5%90%8D%E5%84%BF%E7%AB%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772877278000.webp","sourceId":"rfi"},{"id":1772876711000,"createdDate":"2026-03-07 09:45","name":"法国国际广播电台","title":"战争进入第八天：以色列称80多架战斗机袭击德黑兰及伊朗中部，为冲突爆发以来最大规模空袭之一","content":"以色列军方表示，周六（3月7日）有80多架战斗机对德黑兰及伊朗中部的军事目标、导弹发射装置及其他目标发动了一轮空袭。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260307-%E6%88%98%E4%BA%89%E8%BF%9B%E5%85%A5%E7%AC%AC%E5%85%AB%E5%A4%A9-%E4%BB%A5%E8%89%B2%E5%88%97%E7%A7%B080%E5%A4%9A%E6%9E%B6%E6%88%98%E6%96%97%E6%9C%BA%E8%A2%AD%E5%87%BB%E5%BE%B7%E9%BB%91%E5%85%B0%E5%8F%8A%E4%BC%8A%E6%9C%97%E4%B8%AD%E9%83%A8%EF%BC%8C%E4%B8%BA%E5%86%B2%E7%AA%81%E7%88%86%E5%8F%91%E4%BB%A5%E6%9D%A5%E6%9C%80%E5%A4%A7%E8%A7%84%E6%A8%A1%E7%A9%BA%E8%A2%AD%E4%B9%8B%E4%B8%80","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772876711000.webp","sourceId":"rfi"},{"id":1772875637000,"createdDate":"2026-03-07 09:27","name":"法国国际广播电台","title":"拦截行动后，迪拜机场现已部分恢复运营","content":"迪拜国际机场周六（3月7日）宣布，在当天早些时候短暂停运之后，机场已部分恢复运营。该机场是国际客运量最大的机场，周六早晨，在机场上空发生了一次拦截行动，随后机场已暂时暂停所有运营。阿拉伯联合酋长国方面表示，该国正面临来自伊朗的袭击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260307-%E6%8B%A6%E6%88%AA%E8%A1%8C%E5%8A%A8%E5%90%8E%EF%BC%8C%E8%BF%AA%E6%8B%9C%E6%9C%BA%E5%9C%BA%E7%8E%B0%E5%B7%B2%E9%83%A8%E5%88%86%E6%81%A2%E5%A4%8D%E8%BF%90%E8%90%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772875637000.webp","sourceId":"rfi"},{"id":1772874636000,"createdDate":"2026-03-07 09:10","name":"法国国际广播电台","title":"伊朗总统拒绝美国\"无条件投降\"的要求  并就袭击邻国道歉","content":"伊朗总统马苏德·佩泽什基安周六（3月7日）表示，美国要求伊朗“无条件投降”的说法只是一个“他们应该带进坟墓里的幻想”。此番言论是佩泽什基安在国家电视台播出的一段预录讲话中发表的。他同时为伊朗对地区国家的袭击道歉，并表示德黑兰将停止这些行动，同时暗示这些袭击是军队内部沟通不畅造成的。他还将近期武装力量似乎出现的指挥和控制混乱归因于国家最高领导人及其他高层官员被杀。就在他发表讲话之际，伊朗在周六凌晨袭击了海湾阿拉伯国家，而以色列和美国仍在继续对伊朗实施空袭。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260307-%E4%BC%8A%E6%9C%97%E6%80%BB%E7%BB%9F%E6%8B%92%E7%BB%9D%E7%BE%8E%E5%9B%BD-%E6%97%A0%E6%9D%A1%E4%BB%B6%E6%8A%95%E9%99%8D-%E7%9A%84%E8%A6%81%E6%B1%82-%E5%B9%B6%E5%B0%B1%E8%A2%AD%E5%87%BB%E9%82%BB%E5%9B%BD%E9%81%93%E6%AD%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772874636000.webp","sourceId":"rfi"},{"id":1772873578000,"createdDate":"2026-03-07 08:52","name":"法国国际广播电台","title":"油价高企，美国或将扩大解除对俄罗斯石油制裁","content":"当前国际油价已升至2023年以来最高水平。美国财政部长贝森特周五（3月6日）表示，美国可能扩大对俄罗斯石油制裁的解除范围，以缓解市场压力。此外，美联社周五消息称，据两名熟悉美国情报的官员透露，俄罗斯已经向伊朗提供了一些信息，这些信息可能帮助德黑兰打击该地区的美国军舰、飞机以及其他军事资产，白宫则选择淡化相关报道。而此前，在3月5日，特朗普又向乌克兰总统泽连斯基施压，他说乌克兰总统是与俄罗斯达成协议的障碍，并坚称俄国总统普京的态度是合作。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260307-%E6%B2%B9%E4%BB%B7%E9%AB%98%E4%BC%81%EF%BC%8C%E7%BE%8E%E5%9B%BD%E6%88%96%E5%B0%86%E6%89%A9%E5%A4%A7%E8%A7%A3%E9%99%A4%E5%AF%B9%E4%BF%84%E7%BD%97%E6%96%AF%E7%9F%B3%E6%B2%B9%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772873578000.webp","sourceId":"rfi"},{"id":1772918234000,"createdDate":"2026-03-07 21:17","name":"法国国际广播电台","title":"以猛轰德黑兰        迪拜、耶路撒冷和麦纳麦均传出爆炸声","content":"伊朗周六对驻有美军的海湾邻国发动了多轮导弹和无人机袭击，誓言不顾特朗普的威胁，继续报复以色列和美国持续一周的攻势。据法新社记者报道，卡塔尔首都多哈和巴林首都麦纳麦当天下午都听到了爆炸声。伊朗司法部长戈拉姆侯赛因·穆赫辛尼·埃杰伊（GholamhosseinMohseniEjeï）断言，伊朗将继续袭击邻国境内“侵略”的目标，并援引“证据”称，该地区一些国家“已将自己置于敌人的掌控之下”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260307-%E4%BB%A5%E7%8C%9B%E8%BD%B0%E5%BE%B7%E9%BB%91%E5%85%B0-%E8%BF%AA%E6%8B%9C-%E8%80%B6%E8%B7%AF%E6%92%92%E5%86%B7%E5%92%8C%E9%BA%A6%E7%BA%B3%E9%BA%A6%E5%9D%87%E4%BC%A0%E5%87%BA%E7%88%86%E7%82%B8%E5%A3%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772918234000.webp","sourceId":"rfi"},{"id":1772918057000,"createdDate":"2026-03-07 21:14","name":"法国国际广播电台","title":"意大利派遣一艘海军护卫舰前往塞浦路斯","content":"意大利总理梅洛尼周六宣布，意大利派遣一艘海军护卫舰前往塞浦路斯执行任务，以保护该岛安全。此前数日，一架无人机袭击了岛上的一处英国基地。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260307-%E6%84%8F%E5%A4%A7%E5%88%A9%E6%B4%BE%E9%81%A3%E4%B8%80%E8%89%98%E6%B5%B7%E5%86%9B%E6%8A%A4%E5%8D%AB%E8%88%B0%E5%89%8D%E5%BE%80%E5%A1%9E%E6%B5%A6%E8%B7%AF%E6%96%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772918057000.webp","sourceId":"rfi"},{"id":1772917687000,"createdDate":"2026-03-07 21:08","name":"法国国际广播电台","title":"法6架撤侨航班周日将从阿联酋起飞","content":"法国外交部长让-诺埃尔·巴罗周六宣布，躲避战乱，已有4300名法国公民已返回法国，其中包括800名乘坐法国外交部包机回国的公民。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260307-%E6%B3%956%E6%9E%B6%E6%92%A4%E4%BE%A8%E8%88%AA%E7%8F%AD%E5%91%A8%E6%97%A5%E5%B0%86%E4%BB%8E%E9%98%BF%E8%81%94%E9%85%8B%E8%B5%B7%E9%A3%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772917687000.webp","sourceId":"rfi"},{"id":1772917618000,"createdDate":"2026-03-07 21:06","name":"法国国际广播电台","title":"西班牙巴塞罗那圣家堂建造144年终于封顶","content":"西班牙巴塞罗那大型教堂圣家堂（SagradaFamilia）已经建造了144年，终于在今年2月20日宣告封顶。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260307-%E8%A5%BF%E7%8F%AD%E7%89%99%E5%B7%B4%E5%A1%9E%E7%BD%97%E9%82%A3%E5%9C%A3%E5%AE%B6%E5%A0%82%E5%BB%BA%E9%80%A0144%E5%B9%B4%E7%BB%88%E4%BA%8E%E5%B0%81%E9%A1%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772917618000.webp","sourceId":"rfi"},{"id":1772917451000,"createdDate":"2026-03-07 21:04","name":"法国国际广播电台","title":"法高速加油站柴油飙升   有的已升至2.5欧/升","content":"中东冲突升级扰乱石油供应，国际油价大幅上涨。度假返回的巴黎人在高速公路上领教了油价的厉害，价格高得离谱。从马赛赶到巴黎推销衣服品牌的爱德华（édouard）告诉巴黎人报《巴黎人报》，高速公路上加油站的价格太贵了，我不可能加满原油，少加一点儿，走出高速到超市加油站再说。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260307-%E6%B3%95%E9%AB%98%E9%80%9F%E5%8A%A0%E6%B2%B9%E7%AB%99%E6%9F%B4%E6%B2%B9%E9%A3%99%E5%8D%87-%E6%9C%89%E7%9A%84%E5%B7%B2%E5%8D%87%E8%87%B32-5%E6%AC%A7-%E5%8D%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772917451000.webp","sourceId":"rfi"},{"id":1772917192000,"createdDate":"2026-03-07 20:59","name":"法国国际广播电台","title":"伊朗总统：对遭攻击的周边国家表示歉意","content":"周六，伊朗连续第八天遭受轰炸，德黑兰多个地区以及包括伊斯法罕在内的伊朗其他地区均传出剧烈爆炸声。美国总统特朗普周五要求伊朗投降，伊朗总统马苏德·佩泽希齐扬(MasoudPezeshkian)称这一要求是“痴人说梦”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260307-%E4%BC%8A%E6%9C%97%E6%80%BB%E7%BB%9F-%E5%AF%B9%E9%81%AD%E6%94%BB%E5%87%BB%E7%9A%84%E5%91%A8%E8%BE%B9%E5%9B%BD%E5%AE%B6%E8%A1%A8%E7%A4%BA%E6%AD%89%E6%84%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772917192000.webp","sourceId":"rfi"},{"id":1772917028000,"createdDate":"2026-03-07 20:57","name":"法国国际广播电台","title":"特朗普出席“美洲之盾”峰会","content":"美国总统特朗普3月7日在佛罗里达州多拉（Doral）主持“美洲之盾”（ShieldoftheAmericas）峰会，会议宗旨意在宣布与几个拉美盟友组建“军事联盟”，“根除”贩毒集团，必要时甚至将动用导弹袭击。他还重申了对古巴的强硬言论。在佛罗里达州，他声称古巴“已是垂死之时”，并宣称他将“解决掉它”。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260307-%E7%89%B9%E6%9C%97%E6%99%AE%E5%87%BA%E5%B8%AD-%E7%BE%8E%E6%B4%B2%E4%B9%8B%E7%9B%BE-%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772917028000.webp","sourceId":"rfi"},{"id":1772916764000,"createdDate":"2026-03-07 20:52","name":"法国国际广播电台","title":"瑞典警方截获一艘盗乌粮食的俄船只","content":"瑞典警方于周五在其南部海岸附近拦截了一艘悬挂冒充船旗的货船，当局于周六宣布，该船涉嫌隶属于俄罗斯“幽灵船队”，并运输从乌克兰偷盗的粮食。这艘名为“卡法号”（Caffa）的货船长96米（315英尺），于2月24日从摩洛哥卡萨布兰卡出发，前往俄罗斯圣彼得堡。瑞典武装警察在瑞典南部特雷勒堡附近海域登船检查。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260307-%E7%91%9E%E5%85%B8%E8%AD%A6%E6%96%B9%E6%88%AA%E8%8E%B7%E4%B8%80%E8%89%98%E7%9B%97%E4%B9%8C%E7%B2%AE%E9%A3%9F%E7%9A%84%E4%BF%84%E8%88%B9%E5%8F%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772916764000.webp","sourceId":"rfi"},{"id":1772916051000,"createdDate":"2026-03-07 20:40","name":"法国国际广播电台","title":"以色列密集轰炸     黎巴嫩发生逃难潮","content":"黎巴嫩当局报告称，自周一以来，以色列对黎巴嫩发动猛烈轰炸，以回应亲伊朗真主党的袭击，导致超过45万人仓皇逃难。社会事务部长哈宁·赛义德（HaneenSayed）在新闻发布会上表示：“逃难人数高达45.4万人”，其中包括超过11万人被安置在接待中心。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260307-%E4%BB%A5%E8%89%B2%E5%88%97%E5%AF%86%E9%9B%86%E8%BD%B0%E7%82%B8-%E9%BB%8E%E5%B7%B4%E5%AB%A9%E5%8F%91%E7%94%9F%E9%80%83%E9%9A%BE%E6%BD%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772916051000.webp","sourceId":"rfi"},{"id":1772915823000,"createdDate":"2026-03-07 20:37","name":"法国国际广播电台","title":"“印度继续进口天然气    无需获得华盛顿的批准”","content":"一位政府消息人士在华盛顿周四宣布暂时授权新德里进口俄罗斯石油后表示，印度将继续进口俄罗斯石油，并且“从未需要获得”任何国家的批准。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260307-%E5%8D%B0%E5%BA%A6%E7%BB%A7%E7%BB%AD%E8%BF%9B%E5%8F%A3%E5%A4%A9%E7%84%B6%E6%B0%94-%E6%97%A0%E9%9C%80%E8%8E%B7%E5%BE%97%E5%8D%8E%E7%9B%9B%E9%A1%BF%E7%9A%84%E6%89%B9%E5%87%86","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772915823000.webp","sourceId":"rfi"},{"id":1772914717000,"createdDate":"2026-03-07 20:18","name":"法国国际广播电台","title":"开战一周特朗普要伊朗无条件投降的猫腻：寻找结束战争的话术","content":"2月28日，美国联手以色列对伊朗发起的军事行动整整持续了一周时间，特朗普提出要伊朗“无条件投降”，看似严厉，实则藏有寻找结束战争出路的猫腻。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260307-%E5%BC%80%E6%88%98%E4%B8%80%E5%91%A8%E7%89%B9%E6%9C%97%E6%99%AE%E8%A6%81%E4%BC%8A%E6%9C%97%E6%97%A0%E6%9D%A1%E4%BB%B6%E6%8A%95%E9%99%8D%E7%9A%84%E7%8C%AB%E8%85%BB-%E5%AF%BB%E6%89%BE%E7%BB%93%E6%9D%9F%E6%88%98%E4%BA%89%E5%87%BA%E8%B7%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772914717000.webp","sourceId":"rfi"},{"id":1772908031000,"createdDate":"2026-03-07 18:27","name":"法国国际广播电台","title":"德国电视一台：伊朗战争是中国并不乐见的战争","content":"伊朗战争是德国媒体关注的话题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260307-%E5%BE%B7%E5%9B%BD%E7%94%B5%E8%A7%86%E4%B8%80%E5%8F%B0-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%98%AF%E4%B8%AD%E5%9B%BD%E5%B9%B6%E4%B8%8D%E4%B9%90%E8%A7%81%E7%9A%84%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772908031000.webp","sourceId":"rfi"},{"id":1772907295000,"createdDate":"2026-03-07 18:14","name":"法国国际广播电台","title":"美国防长：不担心俄罗斯向伊朗提供情报","content":"美国国防部长赫格塞思（PeteHegseth）公开回应外界对俄罗斯可能支援伊朗的忧虑。他表示，美方并不担心，俄罗斯向伊朗提供美军部署情报的信息，并强调美国军方已掌握所有相关动向。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260307-%E7%BE%8E%E5%9B%BD%E9%98%B2%E9%95%BF-%E4%B8%8D%E6%8B%85%E5%BF%83%E4%BF%84%E7%BD%97%E6%96%AF%E5%90%91%E4%BC%8A%E6%9C%97%E6%8F%90%E4%BE%9B%E6%83%85%E6%8A%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/07/1772907295000.webp","sourceId":"rfi"}]