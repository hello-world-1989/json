[{"id":1774712233000,"createdDate":"2026-03-28 15:37","name":"法国国际广播电台","title":"泽连斯基会见阿联酋总统 与卡塔尔达成十年防务合作协议","content":"周六，乌克兰总统泽连斯基（VolodymyrZelenskyy）相继访问了阿联酋和卡塔尔，与这些国家同意在防务领域开展合作。此时，中东地区紧张局势正在升级。卡塔尔国防部当天发表声明称，多哈和基辅签署了一项国防合作协议，其中包括在反导弹和无人机系统方面交流专业知识。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260328-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E4%BC%9A%E8%A7%81%E9%98%BF%E8%81%94%E9%85%8B%E6%80%BB%E7%BB%9F-%E4%B8%8E%E5%8D%A1%E5%A1%94%E5%B0%94%E8%BE%BE%E6%88%90%E5%8D%81%E5%B9%B4%E9%98%B2%E5%8A%A1%E5%90%88%E4%BD%9C%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774712233000.webp","sourceId":"rfi"},{"id":1774710308000,"createdDate":"2026-03-28 15:05","name":"法国国际广播电台","title":"北京出台无人机新规：所有室外飞行活动均需申请，所有者需在4月30日前实名登记","content":"据中国公安部机关报《人民公安报》报导，北京市十六届人大常委会第二十三次会议3月27日表决通过《北京市无人驾驶航空器管理规定》，对无人驾驶航空器的飞行和销售、运输、存储等作出规范。规定自2026年5月1日起实施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260328-%E5%8C%97%E4%BA%AC%E5%87%BA%E5%8F%B0%E6%97%A0%E4%BA%BA%E6%9C%BA%E6%96%B0%E8%A7%84-%E6%89%80%E6%9C%89%E5%AE%A4%E5%A4%96%E9%A3%9E%E8%A1%8C%E6%B4%BB%E5%8A%A8%E5%9D%87%E9%9C%80%E7%94%B3%E8%AF%B7%EF%BC%8C%E6%89%80%E6%9C%89%E8%80%85%E9%9C%80%E5%9C%A84%E6%9C%8830%E6%97%A5%E5%89%8D%E5%AE%9E%E5%90%8D%E7%99%BB%E8%AE%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774710308000.webp","sourceId":"rfi"},{"id":1774706981000,"createdDate":"2026-03-28 14:09","name":"法国国际广播电台","title":"美前大使伯恩斯：在伊朗和委内瑞拉人眼中，中方都像个易变的朋友","content":"曾于拜登政府时期担任美国驻华大使的前资深外交官伯恩斯（NicholasBurns）在受访时表示，中国未能向伊朗提供有效的外交支持，并在美国干预委内瑞拉时保持沉默，这损害了其声称成为全球主要参与者的政治公信力。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260328-%E7%BE%8E%E5%89%8D%E5%A4%A7%E4%BD%BF%E4%BC%AF%E6%81%A9%E6%96%AF-%E5%9C%A8%E4%BC%8A%E6%9C%97%E5%92%8C%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E4%BA%BA%E7%9C%BC%E4%B8%AD%EF%BC%8C%E4%B8%AD%E6%96%B9%E9%83%BD%E5%83%8F%E4%B8%AA%E6%98%93%E5%8F%98%E7%9A%84%E6%9C%8B%E5%8F%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774706981000.webp","sourceId":"rfi"},{"id":1774701882000,"createdDate":"2026-03-28 12:44","name":"法国国际广播电台","title":"美参议员去年夏天来首度访台 促立法院通过国防特别预算","content":"美国两党参议员将于周六访台，期间将敦促台湾立法者通过国防特别预算，此行旨在面对日益加剧的中国军事压力时对台表达支持。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260328-%E7%BE%8E%E5%8F%82%E8%AE%AE%E5%91%98%E5%8E%BB%E5%B9%B4%E5%A4%8F%E5%A4%A9%E6%9D%A5%E9%A6%96%E6%AC%A1%E8%AE%BF%E5%8F%B0-%E4%BF%83%E7%AB%8B%E6%B3%95%E9%99%A2%E9%80%9A%E8%BF%87%E5%9B%BD%E9%98%B2%E7%89%B9%E5%88%AB%E9%A2%84%E7%AE%97","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774701882000.webp","sourceId":"rfi"},{"id":1774698822000,"createdDate":"2026-03-28 11:53","name":"法国国际广播电台","title":"美众院外交委通过谴责中国胁迫日本决议案 日本避提台湾问题","content":"美国众议院外交委员会在当地时间3月26日，以多数赞成通通过了一项决议案，谴责中国针对日本所采取的“胁迫性行为”，该决议与高市早苗就台湾有事问题在国会的答辩相关，而在3月19日（当地时间），在白宫举行了日本首相高市早苗与美国总统唐纳德·特朗普的日美首脑会谈。当天白宫公布的“事实清单（FactSheet）”中提到了包括台湾海峡稳定在内的内容，但日本外务省发布的文件中却没有相关表述。有舆论认为高市首相在对华关系上感到为难，希望尽量避免刺激中方。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260328-%E7%BE%8E%E4%BC%97%E9%99%A2%E5%A4%96%E4%BA%A4%E5%A7%94%E9%80%9A%E8%BF%87%E8%B0%B4%E8%B4%A3%E4%B8%AD%E5%9B%BD%E8%83%81%E8%BF%AB%E6%97%A5%E6%9C%AC%E5%86%B3%E8%AE%AE%E6%A1%88-%E6%97%A5%E6%9C%AC%E9%81%BF%E6%8F%90%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774698822000.webp","sourceId":"rfi"},{"id":1774697958000,"createdDate":"2026-03-28 11:39","name":"法国国际广播电台","title":"黄循财 ：东盟不会在中美之间选边站队 新加坡与中日都是朋友","content":"新加坡总理黄循财周六在受访时表示，东盟各国一致认为不应在中美竞争中选边站队，并一致希望保持东南亚地区的开放和包容。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260328-%E9%BB%84%E5%BE%AA%E8%B4%A2-%E4%B8%9C%E7%9B%9F%E4%B8%8D%E4%BC%9A%E5%9C%A8%E4%B8%AD%E7%BE%8E%E4%B9%8B%E9%97%B4%E9%80%89%E8%BE%B9%E7%AB%99%E9%98%9F-%E6%96%B0%E5%8A%A0%E5%9D%A1%E4%B8%8E%E4%B8%AD%E6%97%A5%E9%83%BD%E6%98%AF%E6%9C%8B%E5%8F%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774697958000.webp","sourceId":"rfi"},{"id":1774697364000,"createdDate":"2026-03-28 11:29","name":"法国国际广播电台","title":"因乌克兰战争产生的互不信任? 卢比奥恼怒回击欧盟提问","content":"在周五举行的七国集团（G7）外长会议上，欧盟外交政策负责人卡娅·卡拉斯问询美国国务卿马可·卢比奥，美国何时会对俄罗斯采取强硬立场时，遭到卢比奥的激烈反驳。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260328-%E5%9B%A0%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E4%BA%89%E4%BA%A7%E7%94%9F%E7%9A%84%E4%BA%92%E4%B8%8D%E4%BF%A1%E4%BB%BB-%E5%8D%A2%E6%AF%94%E5%A5%A5%E6%81%BC%E6%80%92%E5%9B%9E%E5%87%BB%E6%AC%A7%E7%9B%9F%E6%8F%90%E9%97%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774697364000.webp","sourceId":"rfi"},{"id":1774693022000,"createdDate":"2026-03-28 10:17","name":"法国国际广播电台","title":"收到习近平贺电 金正恩：感受到不变支持和友好情谊","content":"据官媒朝中社报导称，中国国家主席习近平周四（26日）致电朝鲜国务委员会委员长金正恩，祝贺其再次被推举为国务委员长。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260328-%E6%94%B6%E5%88%B0%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%B4%BA%E7%94%B5-%E9%87%91%E6%AD%A3%E6%81%A9-%E6%84%9F%E5%8F%97%E5%88%B0%E4%B8%8D%E5%8F%98%E6%94%AF%E6%8C%81%E5%92%8C%E5%8F%8B%E5%A5%BD%E6%83%85%E8%B0%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774693022000.webp","sourceId":"rfi"},{"id":1774691994000,"createdDate":"2026-03-28 09:59","name":"法国国际广播电台","title":"胡塞证实在当前战争中首次对以色列发动袭击 沙土埃三国外长访巴基斯坦","content":"也门胡塞武装周六上午向以色列发射弹道导弹，正式加入持续一个月的伊朗战争。这场战争已造成能源市场混乱，并导致数千人丧生。由伊朗支持的也门胡塞武装表示，将继续开展军事行动，直至美国和以色列停止对伊朗及其代理武装组织，包括黎巴嫩真主党的攻击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260328-%E8%83%A1%E5%A1%9E%E8%AF%81%E5%AE%9E%E5%9C%A8%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E4%B8%AD%E9%A6%96%E6%AC%A1%E5%AF%B9%E4%BB%A5%E8%89%B2%E5%88%97%E5%8F%91%E5%8A%A8%E8%A2%AD%E5%87%BB-%E6%B2%99%E5%9C%9F%E5%9F%83%E4%B8%89%E5%9B%BD%E5%A4%96%E9%95%BF%E8%AE%BF%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774691994000.webp","sourceId":"rfi"},{"id":1774689783000,"createdDate":"2026-03-28 09:23","name":"法国国际广播电台","title":"欧洲机构雇员成为中国间谍活动的目标","content":"一位欧洲安全部门消息人士周五(3月27日)表示，一项旨在通过虚假领英（LinkedIn）账号招募欧洲人员，获取欧盟和北约敏感信息的中国情报行动已被曝光。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260328-%E6%AC%A7%E6%B4%B2%E6%9C%BA%E6%9E%84%E9%9B%87%E5%91%98%E6%88%90%E4%B8%BA%E4%B8%AD%E5%9B%BD%E9%97%B4%E8%B0%8D%E6%B4%BB%E5%8A%A8%E7%9A%84%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774689783000.webp","sourceId":"rfi"},{"id":1774739810000,"createdDate":"2026-03-28 23:16","name":"法国国际广播电台","title":"塞内加尔拒绝非盟主席国一倡议","content":"在距离联合国（ONU）秘书长安东尼奥·古特雷斯（AntonioGuterres）任期在2026年末届满还有大半年之际，有关其接班人的竞争已是国际舆论的焦点。最新动态有非盟（UA）成员国于昨天周五以投票方式，拒绝支持其轮值主席国布隆迪总统提名的候选人、塞内加尔前总统马基·萨勒（MackySall）。这是本台法广非洲组（RFIAfrique）今天（2026年03月28日星期六）上网的最新法文消息之一。本台法广（RFI）非洲通讯员发自达喀尔（Dakar）的消息说，非洲55个成员国中，有近半数予以反对。其中，塞内加尔现执政当局的否决尤其引发关注。","newsLink":"https://www.rfi.fr/cn/rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%A1%9E%E5%86%85%E5%8A%A0%E5%B0%94%E6%8B%92%E7%BB%9D%E9%9D%9E%E7%9B%9F%E4%B8%BB%E5%B8%AD%E5%9B%BD%E4%B8%80%E5%80%A1%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774739810000.webp","sourceId":"rfi"},{"id":1774735890000,"createdDate":"2026-03-28 22:11","name":"法国国际广播电台","title":"菲律宾和中国举行两次外交会议 菲方提否“一中政策”？","content":"菲律宾外交部28日晚发布声明说，菲中两国于27日至28日在福建省泉州市接连举行第24次外交部磋商（FMC）及南海问题双边磋商机制（BCM）第11次会议。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260328-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%92%8C%E4%B8%AD%E5%9B%BD%E4%B8%BE%E8%A1%8C%E4%B8%A4%E6%AC%A1%E5%A4%96%E4%BA%A4%E4%BC%9A%E8%AE%AE-%E8%8F%B2%E6%96%B9%E6%8F%90%E5%90%A6-%E4%B8%80%E4%B8%AD%E6%94%BF%E7%AD%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774735890000.webp","sourceId":"rfi"},{"id":1774733250000,"createdDate":"2026-03-28 21:27","name":"法国国际广播电台","title":"马克龙：勿让伊拉克“被卷入持续升级的冲突”","content":"3月28日，法国总统马克龙呼吁采取“一切可能的措施”，防止伊拉克“被卷入持续升级的冲突”，该国正日益深陷中东冲突之中。马克龙在与伊拉克库尔德斯坦地区主席内奇尔万·巴尔扎尼通话后强调：“伊拉克及其境内库尔德斯坦地区的主权对地区稳定至关重要。”巴尔扎尼的住所周六上午遭到无人机袭击，马克龙称此次袭击“令人无法接受”。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260328-%E9%A9%AC%E5%85%8B%E9%BE%99-%E5%8B%BF%E8%AE%A9%E4%BC%8A%E6%8B%89%E5%85%8B-%E8%A2%AB%E5%8D%B7%E5%85%A5%E6%8C%81%E7%BB%AD%E5%8D%87%E7%BA%A7%E7%9A%84%E5%86%B2%E7%AA%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774733250000.webp","sourceId":"rfi"},{"id":1774733038000,"createdDate":"2026-03-28 21:23","name":"法国国际广播电台","title":"巴基斯坦：继续外交斡旋努力","content":"巴基斯坦政府周六宣布，巴基斯坦、沙特阿拉伯、埃及和土耳其的外长将于周日和周一在伊斯兰堡举行会晤，讨论中东战争局势。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260328-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6-%E7%BB%A7%E7%BB%AD%E5%A4%96%E4%BA%A4%E6%96%A1%E6%97%8B%E5%8A%AA%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774733038000.webp","sourceId":"rfi"},{"id":1774732784000,"createdDate":"2026-03-28 21:19","name":"法国国际广播电台","title":"特朗普让农民     “去买更大的拖拉机”","content":"美国中期选举至关重要，“农村”票仓不可忽视。路透社报道，特朗普在白宫南草坪举行的一场活动上对数百名冒着细雨农民和牧场主说道：“我希望约翰迪尔（JohnDeere）、凯斯（Case）以及其它所有公司——这些都是大公司，还有卡特彼勒（Caterpillar）……我希望这些公司能为你们提供价格更低的拖拉机和设备”。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260328-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%A9%E5%86%9C%E6%B0%91-%E5%8E%BB%E4%B9%B0%E6%9B%B4%E5%A4%A7%E7%9A%84%E6%8B%96%E6%8B%89%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774732784000.webp","sourceId":"rfi"},{"id":1774732623000,"createdDate":"2026-03-28 21:17","name":"法国国际广播电台","title":"中东最大的铝生产基地遭伊朗袭击","content":"中东最大的铝业制造商阿联酋环球铝业（EGA）3月28日表示，他们位于阿联酋一处重要生产基地在伊朗导弹与无人机攻击中遭受“重大损害”。路透社报导，阿联酋环球铝业在声明中指出，位于阿布扎比哈里发经济区（KhalifaEconomicZone）的设施遭到攻击，造成多名员工受伤，所幸均无生命危险。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260328-%E4%B8%AD%E4%B8%9C%E6%9C%80%E5%A4%A7%E7%9A%84%E9%93%9D%E7%94%9F%E4%BA%A7%E5%9F%BA%E5%9C%B0%E9%81%AD%E4%BC%8A%E6%9C%97%E8%A2%AD%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774732623000.webp","sourceId":"rfi"},{"id":1774731825000,"createdDate":"2026-03-28 21:03","name":"法国国际广播电台","title":"教宗在摩纳哥谴责贫富分化加剧","content":"教宗于3月28日上午9点搭乘直升机抵达摩纳哥，亲王夫妇在炮声礼响中迎接。随后一行人前往亲王宫，举行欢迎仪式、交换礼物，并在宫殿阳台向群众致词。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260328-%E6%95%99%E5%AE%97%E5%9C%A8%E6%91%A9%E7%BA%B3%E5%93%A5%E8%B0%B4%E8%B4%A3%E8%B4%AB%E5%AF%8C%E5%88%86%E5%8C%96%E5%8A%A0%E5%89%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774731825000.webp","sourceId":"rfi"},{"id":1774731521000,"createdDate":"2026-03-28 20:58","name":"法国国际广播电台","title":"以空袭黎巴嫩南部    三名记者殉职","content":"以色列28日在攻击黎巴嫩南部时造成3名记者死亡，当中包括真主党旗下灯塔新闻频道（AlManar）的著名战地记者。黎巴嫩当局谴责此次攻击为战争罪。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260328-%E4%BB%A5%E7%A9%BA%E8%A2%AD%E9%BB%8E%E5%B7%B4%E5%AB%A9%E5%8D%97%E9%83%A8-%E4%B8%89%E5%90%8D%E8%AE%B0%E8%80%85%E6%AE%89%E8%81%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774731521000.webp","sourceId":"rfi"},{"id":1774731380000,"createdDate":"2026-03-28 20:56","name":"法国国际广播电台","title":"抽水蓄能：中国又领先于西方国家","content":"中国正以惊人的速度建设水库，其目标是储存可再生能源。中国在可再生能源领域也大大领先于西方国家。目前，风能和太阳能发电占中国总发电量的47.3%。2020年12月，中国国家主席习近平曾宣布，到2030年，中国风能和太阳能装机容量将达到1200吉瓦。法新社记者28日报道说，实际上，中国在2024年7月就实现了这一目标，比政府设定的目标提前了整整六年。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260328-%E6%8A%BD%E6%B0%B4%E8%93%84%E8%83%BD-%E4%B8%AD%E5%9B%BD%E5%8F%88%E9%A2%86%E5%85%88%E4%BA%8E%E8%A5%BF%E6%96%B9%E5%9B%BD%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774731380000.webp","sourceId":"rfi"},{"id":1774730814000,"createdDate":"2026-03-28 20:46","name":"法国国际广播电台","title":"巴斯夫广东超级新厂将决定巴斯夫的未来","content":"德国化工巨头巴斯夫（BASF）在中国广东湛江新建的超级工厂“联产一体化基地”于周四正式投产。新联产基地占地约四平方公里，未来将有约2000名员工在此工作。该工厂将决定巴斯夫的未来。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260328-%E5%B7%B4%E6%96%AF%E5%A4%AB%E5%B9%BF%E4%B8%9C%E8%B6%85%E7%BA%A7%E6%96%B0%E5%8E%82%E5%B0%86%E5%86%B3%E5%AE%9A%E5%B7%B4%E6%96%AF%E5%A4%AB%E7%9A%84%E6%9C%AA%E6%9D%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774730814000.webp","sourceId":"rfi"},{"id":1774729905000,"createdDate":"2026-03-28 20:31","name":"法国国际广播电台","title":"身陷伊朗死胡同：特朗普施压无上限 出路难找见","content":"美军中央司令部日前表示，自2月28日战争开始以来，已有超过300名美军人员受伤，还有13名美军官兵阵亡。由于投资者对冲突迅速结束的希望消退，国际油价周五大幅上涨。全球股市指数本周收低，华尔街的标准普尔500指数连续第5周下跌。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260328-%E8%BA%AB%E9%99%B7%E4%BC%8A%E6%9C%97%E6%AD%BB%E8%83%A1%E5%90%8C-%E7%89%B9%E6%9C%97%E6%99%AE%E6%96%BD%E5%8E%8B%E6%97%A0%E4%B8%8A%E9%99%90-%E5%87%BA%E8%B7%AF%E6%89%BE%E4%B8%8D%E8%A7%81","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774729905000.webp","sourceId":"rfi"},{"id":1774727633000,"createdDate":"2026-03-28 19:53","name":"法国国际广播电台","title":"离香榭丽舍大道不远的美国银行险些遇袭","content":"巴黎的一家美国银行成为袭击的目标，幸好作案者没有得手。3月28日深夜3点25分左右，一名男子在巴黎第八区美国银行总部前放置爆炸装置后被捕。目前，此案已移交国家反恐检察官办公室，以查明幕后主使。法国内政部长把此事与中东战争相连。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260328-%E7%A6%BB%E9%A6%99%E6%A6%AD%E4%B8%BD%E8%88%8D%E5%A4%A7%E9%81%93%E4%B8%8D%E8%BF%9C%E7%9A%84%E7%BE%8E%E5%9B%BD%E9%93%B6%E8%A1%8C%E9%99%A9%E4%BA%9B%E9%81%87%E8%A2%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774727633000.webp","sourceId":"rfi"},{"id":1774720816000,"createdDate":"2026-03-28 18:00","name":"法国国际广播电台","title":"全美逾3000场“无王”抗议齐发　数百万人上街反对特朗普政府政策","content":"美国各地28日爆发大规模“无王”（NoKings）抗议行动，反对美国总统特朗普（DonaldTrump）政府政策。主办单位表示，全美50州已登记超过3100场活动，预计参与人数可能突破900万人，规模有望成为美国史上最大规模之一的单日非暴力示威。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260328-%E5%85%A8%E7%BE%8E%E9%80%BE3000%E5%9C%BA-%E6%97%A0%E7%8E%8B-%E6%8A%97%E8%AE%AE%E9%BD%90%E5%8F%91-%E6%95%B0%E7%99%BE%E4%B8%87%E4%BA%BA%E4%B8%8A%E8%A1%97%E5%8F%8D%E5%AF%B9%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E6%94%BF%E7%AD%96","thumbnail":"","detailImage":"news/detail/rfi/2026/03/28/1774720816000.webp","sourceId":"rfi"}]