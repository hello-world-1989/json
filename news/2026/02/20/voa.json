[{"id":1771611405000,"createdDate":"2026-02-20 18:16","name":"美国之音","title":"美战斗机在阿拉斯加海岸附近发现并拦截俄罗斯战机","content":"美国和加拿大的联合军事机构北美防空司令部(NORAD)表示，星期四(2月19日)，他们紧急出动战斗机，拦截了多架在阿拉斯加海岸附近的国际空域内发现的俄罗斯轰炸机、战斗机和一架侦察机。","newsLink":"https://www.voachinese.com/a/us-fighter-jets-detect-intercept-russian-warplanes-near-alaskan-coast-20260220/8115934.html","thumbnail":"","detailImage":"news/detail/voa/2026/02/20/1771611405000.webp","sourceId":"voa"},{"id":1771610610000,"createdDate":"2026-02-20 18:03","name":"美国之音","title":"特朗普称将指示战争部公布所有与不明飞行物相关的记录","content":"唐纳德·特朗普总统表示，他将指示战争部和其他政府机构公布所有与外星生命和不明飞行物(UFO)相关的记录。","newsLink":"https://www.voachinese.com/a/trump-says-he-will-direct-department-of-war-to-release-any-records-related-to-ufos-20260220/8115942.html","thumbnail":"","detailImage":"news/detail/voa/2026/02/20/1771610610000.webp","sourceId":"voa"}]