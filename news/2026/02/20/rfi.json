[{"id":1771547878000,"createdDate":"2026-02-20 00:37","name":"法国国际广播电台","title":"长江和记实业有限公司向巴拿马政府提出谈判请求，希望能继续运营巴拿马运河两大码头港口","content":"总部位于香港的长江和记实业有限公司周四向巴拿马政府提出请求，希望就继续运营巴拿马运河两大码头港口的事情展开谈判。之前，美国总统特朗普多次威胁称，美国将收回巴拿马运河这条他所谓的被中国控制的水道。巴拿马一直否认中国对这条连接大西洋和太平洋、全长50英里（80公里）的水道拥有控制权，这条水道主要由美国和中国使用。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260220-%E9%95%BF%E6%B1%9F%E5%92%8C%E8%AE%B0%E5%AE%9E%E4%B8%9A%E6%9C%89%E9%99%90%E5%85%AC%E5%8F%B8%E5%90%91%E5%B7%B4%E6%8B%BF%E9%A9%AC%E6%94%BF%E5%BA%9C%E6%8F%90%E5%87%BA%E8%B0%88%E5%88%A4%E8%AF%B7%E6%B1%82%EF%BC%8C%E5%B8%8C%E6%9C%9B%E8%83%BD%E7%BB%A7%E7%BB%AD%E8%BF%90%E8%90%A5%E5%B7%B4%E6%8B%BF%E9%A9%AC%E8%BF%90%E6%B2%B3%E4%B8%A4%E5%A4%A7%E7%A0%81%E5%A4%B4%E6%B8%AF%E5%8F%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771547878000.webp","sourceId":"rfi"},{"id":1771547265000,"createdDate":"2026-02-20 00:27","name":"法国国际广播电台","title":"美国在中东地区大规模集结兵力，威胁将对伊朗采取行动；波兰呼吁所有波兰公民离开伊朗","content":"美国在中东地区大规模集结兵力，并威胁将对伊朗采取行动的同时，星期四，美国总统特朗普敦促伊朗达成一项“有意义的”协议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260220-%E7%BE%8E%E5%9B%BD%E5%9C%A8%E4%B8%AD%E4%B8%9C%E5%9C%B0%E5%8C%BA%E5%A4%A7%E8%A7%84%E6%A8%A1%E9%9B%86%E7%BB%93%E5%85%B5%E5%8A%9B%EF%BC%8C%E5%A8%81%E8%83%81%E5%B0%86%E5%AF%B9%E4%BC%8A%E6%9C%97%E9%87%87%E5%8F%96%E8%A1%8C%E5%8A%A8-%E6%B3%A2%E5%85%B0%E5%91%BC%E5%90%81%E6%89%80%E6%9C%89%E6%B3%A2%E5%85%B0%E5%85%AC%E6%B0%91%E7%A6%BB%E5%BC%80%E4%BC%8A%E6%9C%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771547265000.webp","sourceId":"rfi"},{"id":1771546649000,"createdDate":"2026-02-20 00:17","name":"法国国际广播电台","title":"特朗普庆祝“和平委员会”成立，特朗普盟友阿尔巴尼亚总理驳斥欧洲关于特朗普试图“取代联合国”的担忧","content":"美国总统特朗普周四宣布“和平委员会”正式成立，承诺向加沙提供100亿美元援助，同时一些穆斯林占多数的国家也承诺提供资金和军力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260220-%E7%89%B9%E6%9C%97%E6%99%AE%E5%BA%86%E7%A5%9D-%E5%92%8C%E5%B9%B3%E5%A7%94%E5%91%98%E4%BC%9A-%E6%88%90%E7%AB%8B%EF%BC%8C%E7%89%B9%E6%9C%97%E6%99%AE%E7%9B%9F%E5%8F%8B%E9%98%BF%E5%B0%94%E5%B7%B4%E5%B0%BC%E4%BA%9A%E6%80%BB%E7%90%86%E9%A9%B3%E6%96%A5%E6%AC%A7%E6%B4%B2%E5%85%B3%E4%BA%8E%E7%89%B9%E6%9C%97%E6%99%AE%E8%AF%95%E5%9B%BE-%E5%8F%96%E4%BB%A3%E8%81%94%E5%90%88%E5%9B%BD-%E7%9A%84%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771546649000.webp","sourceId":"rfi"},{"id":1771546197000,"createdDate":"2026-02-20 00:09","name":"法国国际广播电台","title":"法国：欧盟委员会“本不该出席”特朗普的“和平委员会”首次会议","content":"法国表示，负责地中海事务的欧盟专员应该就其出席美国总统特朗普“和平委员会”的第一次会议作出解释，因为她“并未获得欧盟理事会的参加该会议的授权”。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260220-%E6%B3%95%E5%9B%BD-%E6%AC%A7%E7%9B%9F%E5%A7%94%E5%91%98%E4%BC%9A-%E6%9C%AC%E4%B8%8D%E8%AF%A5%E5%87%BA%E5%B8%AD-%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84-%E5%92%8C%E5%B9%B3%E5%A7%94%E5%91%98%E4%BC%9A-%E9%A6%96%E6%AC%A1%E4%BC%9A%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771546197000.webp","sourceId":"rfi"},{"id":1771545937000,"createdDate":"2026-02-20 00:05","name":"法国国际广播电台","title":"频繁陪父亮相的金主爱，有着怎样的政治角色？","content":"朝鲜最高领导人金正恩与其女儿金主爱近日一同出席平壤新建的一批住宅楼的落成仪式。法国世界报周四就此表示，金主爱频繁陪同父亲公开露面，引发外界对其政治角色的猜测。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260220-%E9%A2%91%E7%B9%81%E9%99%AA%E7%88%B6%E4%BA%AE%E7%9B%B8%E7%9A%84%E9%87%91%E4%B8%BB%E7%88%B1%EF%BC%8C%E6%9C%89%E7%9D%80%E6%80%8E%E6%A0%B7%E7%9A%84%E6%94%BF%E6%B2%BB%E8%A7%92%E8%89%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771545937000.webp","sourceId":"rfi"}]