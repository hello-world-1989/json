[{"id":1771547878000,"createdDate":"2026-02-20 00:37","name":"法国国际广播电台","title":"长江和记实业有限公司向巴拿马政府提出谈判请求，希望能继续运营巴拿马运河两大码头港口","content":"总部位于香港的长江和记实业有限公司周四向巴拿马政府提出请求，希望就继续运营巴拿马运河两大码头港口的事情展开谈判。之前，美国总统特朗普多次威胁称，美国将收回巴拿马运河这条他所谓的被中国控制的水道。巴拿马一直否认中国对这条连接大西洋和太平洋、全长50英里（80公里）的水道拥有控制权，这条水道主要由美国和中国使用。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260220-%E9%95%BF%E6%B1%9F%E5%92%8C%E8%AE%B0%E5%AE%9E%E4%B8%9A%E6%9C%89%E9%99%90%E5%85%AC%E5%8F%B8%E5%90%91%E5%B7%B4%E6%8B%BF%E9%A9%AC%E6%94%BF%E5%BA%9C%E6%8F%90%E5%87%BA%E8%B0%88%E5%88%A4%E8%AF%B7%E6%B1%82%EF%BC%8C%E5%B8%8C%E6%9C%9B%E8%83%BD%E7%BB%A7%E7%BB%AD%E8%BF%90%E8%90%A5%E5%B7%B4%E6%8B%BF%E9%A9%AC%E8%BF%90%E6%B2%B3%E4%B8%A4%E5%A4%A7%E7%A0%81%E5%A4%B4%E6%B8%AF%E5%8F%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771547878000.webp","sourceId":"rfi"},{"id":1771547265000,"createdDate":"2026-02-20 00:27","name":"法国国际广播电台","title":"美国在中东地区大规模集结兵力，威胁将对伊朗采取行动；波兰呼吁所有波兰公民离开伊朗","content":"美国在中东地区大规模集结兵力，并威胁将对伊朗采取行动的同时，星期四，美国总统特朗普敦促伊朗达成一项“有意义的”协议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260220-%E7%BE%8E%E5%9B%BD%E5%9C%A8%E4%B8%AD%E4%B8%9C%E5%9C%B0%E5%8C%BA%E5%A4%A7%E8%A7%84%E6%A8%A1%E9%9B%86%E7%BB%93%E5%85%B5%E5%8A%9B%EF%BC%8C%E5%A8%81%E8%83%81%E5%B0%86%E5%AF%B9%E4%BC%8A%E6%9C%97%E9%87%87%E5%8F%96%E8%A1%8C%E5%8A%A8-%E6%B3%A2%E5%85%B0%E5%91%BC%E5%90%81%E6%89%80%E6%9C%89%E6%B3%A2%E5%85%B0%E5%85%AC%E6%B0%91%E7%A6%BB%E5%BC%80%E4%BC%8A%E6%9C%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771547265000.webp","sourceId":"rfi"},{"id":1771546649000,"createdDate":"2026-02-20 00:17","name":"法国国际广播电台","title":"特朗普庆祝“和平委员会”成立，特朗普盟友阿尔巴尼亚总理驳斥欧洲关于特朗普试图“取代联合国”的担忧","content":"美国总统特朗普周四宣布“和平委员会”正式成立，承诺向加沙提供100亿美元援助，同时一些穆斯林占多数的国家也承诺提供资金和军力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260220-%E7%89%B9%E6%9C%97%E6%99%AE%E5%BA%86%E7%A5%9D-%E5%92%8C%E5%B9%B3%E5%A7%94%E5%91%98%E4%BC%9A-%E6%88%90%E7%AB%8B%EF%BC%8C%E7%89%B9%E6%9C%97%E6%99%AE%E7%9B%9F%E5%8F%8B%E9%98%BF%E5%B0%94%E5%B7%B4%E5%B0%BC%E4%BA%9A%E6%80%BB%E7%90%86%E9%A9%B3%E6%96%A5%E6%AC%A7%E6%B4%B2%E5%85%B3%E4%BA%8E%E7%89%B9%E6%9C%97%E6%99%AE%E8%AF%95%E5%9B%BE-%E5%8F%96%E4%BB%A3%E8%81%94%E5%90%88%E5%9B%BD-%E7%9A%84%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771546649000.webp","sourceId":"rfi"},{"id":1771546197000,"createdDate":"2026-02-20 00:09","name":"法国国际广播电台","title":"法国：欧盟委员会“本不该出席”特朗普的“和平委员会”首次会议","content":"法国表示，负责地中海事务的欧盟专员应该就其出席美国总统特朗普“和平委员会”的第一次会议作出解释，因为她“并未获得欧盟理事会的参加该会议的授权”。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260220-%E6%B3%95%E5%9B%BD-%E6%AC%A7%E7%9B%9F%E5%A7%94%E5%91%98%E4%BC%9A-%E6%9C%AC%E4%B8%8D%E8%AF%A5%E5%87%BA%E5%B8%AD-%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84-%E5%92%8C%E5%B9%B3%E5%A7%94%E5%91%98%E4%BC%9A-%E9%A6%96%E6%AC%A1%E4%BC%9A%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771546197000.webp","sourceId":"rfi"},{"id":1771545937000,"createdDate":"2026-02-20 00:05","name":"法国国际广播电台","title":"频繁陪父亮相的金主爱，有着怎样的政治角色？","content":"朝鲜最高领导人金正恩与其女儿金主爱近日一同出席平壤新建的一批住宅楼的落成仪式。法国世界报周四就此表示，金主爱频繁陪同父亲公开露面，引发外界对其政治角色的猜测。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260220-%E9%A2%91%E7%B9%81%E9%99%AA%E7%88%B6%E4%BA%AE%E7%9B%B8%E7%9A%84%E9%87%91%E4%B8%BB%E7%88%B1%EF%BC%8C%E6%9C%89%E7%9D%80%E6%80%8E%E6%A0%B7%E7%9A%84%E6%94%BF%E6%B2%BB%E8%A7%92%E8%89%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771545937000.webp","sourceId":"rfi"},{"id":1771577446000,"createdDate":"2026-02-20 08:50","name":"法国国际广播电台","title":"韩国前总统尹锡悦致歉，但重申当时的“戒严令”符合国家利益","content":"韩国前总统尹锡悦因在2024年宣布戒严令，于周四（2月19日）被判处无期徒刑。周五（2月20日），法新社称，他就此事件带来的“挫折与困难”向公众致歉，但同时重申自己是出于国家利益行事。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260220-%E9%9F%A9%E5%9B%BD%E5%89%8D%E6%80%BB%E7%BB%9F%E5%B0%B9%E9%94%A1%E6%82%A6%E8%87%B4%E6%AD%89%EF%BC%8C%E4%BD%86%E9%87%8D%E7%94%B3%E5%BD%93%E6%97%B6%E7%9A%84-%E6%88%92%E4%B8%A5%E4%BB%A4-%E7%AC%A6%E5%90%88%E5%9B%BD%E5%AE%B6%E5%88%A9%E7%9B%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771577446000.webp","sourceId":"rfi"},{"id":1771575505000,"createdDate":"2026-02-20 08:18","name":"法国国际广播电台","title":"港股马年首日未能开门红 惟财爷对市况乐观 有488家企业正排队上市","content":"香港股市在马年首个交易日虽然未能开门红，但香港交易所主席唐家成在开市仪式上公布好消息，包括今年头一个多月上市的新股，集资额已超过870亿港元(下同，折算约94.7亿欧元)，目前有488间企业正排队等候上市，达上市公司数目的两成。而财政司长陈茂波亦对今年马年的市况改口表示「乐观」，删除了官方稿中的「审慎」二字。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260220-%E6%B8%AF%E8%82%A1%E9%A9%AC%E5%B9%B4%E9%A6%96%E6%97%A5%E6%9C%AA%E8%83%BD%E5%BC%80%E9%97%A8%E7%BA%A2-%E6%83%9F%E8%B4%A2%E7%88%B7%E5%AF%B9%E5%B8%82%E5%86%B5%E4%B9%90%E8%A7%82-%E6%9C%89488%E5%AE%B6%E4%BC%81%E4%B8%9A%E6%AD%A3%E6%8E%92%E9%98%9F%E4%B8%8A%E5%B8%82","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771575505000.webp","sourceId":"rfi"},{"id":1771575189000,"createdDate":"2026-02-20 08:13","name":"法国国际广播电台","title":"京官要港「无处不旅游」遗祸 新春景点迫爆 缺配套致生态受灾","content":"在过去三天的「新正头」，有近55万人次的中国内地旅客入境香港，以致在来港深度游兴起的时期，西贡万宜水库东坝一带昨(19日)天全日人山人海，曾发生广州旅客取景拍照堕崖的破边洲亦成为不少人的「打卡位」，走在麦理浩径上的行山客亦有摩肩接踵之叹，而西贡有提供营地的咸田湾和西湾，更成为重灾区，年初二时有超出官方建议营位数目八倍的营帐竖立，更有人违法生火。有报章社论批评港府只为配合中央政府「『无处不旅游』的旨意」，但却未有配套，以致生态环境乱象丛生，沦为灾难。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260220-%E4%BA%AC%E5%AE%98%E8%A6%81%E6%B8%AF-%E6%97%A0%E5%A4%84%E4%B8%8D%E6%97%85%E6%B8%B8-%E9%81%97%E7%A5%B8-%E6%96%B0%E6%98%A5%E6%99%AF%E7%82%B9%E8%BF%AB%E7%88%86-%E7%BC%BA%E9%85%8D%E5%A5%97%E8%87%B4%E7%94%9F%E6%80%81%E5%8F%97%E7%81%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771575189000.webp","sourceId":"rfi"},{"id":1771604379000,"createdDate":"2026-02-20 16:19","name":"法国国际广播电台","title":"美最高法院6比3裁定特朗普全球关税违法","content":"美国联邦最高法院周五以6比3作出重大裁决，认定美国总统特朗普（DonaldTrump）援引《国际紧急经济权力法》（IEEPA）对全球多国实施的大规模关税措施违法，重挫他第二任期核心经济政策。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260220-%E7%BE%8E%E6%9C%80%E9%AB%98%E6%B3%95%E9%99%A26%E6%AF%943%E8%A3%81%E5%AE%9A%E7%89%B9%E6%9C%97%E6%99%AE%E5%85%A8%E7%90%83%E5%85%B3%E7%A8%8E%E8%BF%9D%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771604379000.webp","sourceId":"rfi"},{"id":1771601955000,"createdDate":"2026-02-20 15:39","name":"法国国际广播电台","title":"美媒：习近平是如何抓捕张又侠的","content":"美媒日前透出更多张又侠被习近平拿下的内幕：张又侠在前往中共中央党校途中被习派出的安全人员拦截，同时其寓所被搜查，儿子也被抓。在做这件事的几天前，习近平悄悄任命了一位领导北京安全部队的新指挥官。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260220-%E7%BE%8E%E5%AA%92-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%98%AF%E5%A6%82%E4%BD%95%E6%8A%93%E6%8D%95%E5%BC%A0%E5%8F%88%E4%BE%A0%E7%9A%84","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771601955000.webp","sourceId":"rfi"},{"id":1771599279000,"createdDate":"2026-02-20 14:54","name":"法国国际广播电台","title":"国际足联FIFA将筹款为“人口过剩”的加沙建设众多足球设施","content":"美国总统唐纳德·特朗普周四宣布设立一项7500万美元的基金，由国际足联FIFA协助募集，用于重建加沙的足球基础设施，包括50个迷你球场、5个标准球场、一个高端国际足联学院和一座可容纳20,000人的新国家级体育场。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260220-%E5%9B%BD%E9%99%85%E8%B6%B3%E8%81%94fifa%E5%B0%86%E7%AD%B9%E6%AC%BE%E4%B8%BA-%E4%BA%BA%E5%8F%A3%E8%BF%87%E5%89%A9-%E7%9A%84%E5%8A%A0%E6%B2%99%E5%BB%BA%E8%AE%BE%E4%BC%97%E5%A4%9A%E8%B6%B3%E7%90%83%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771599279000.webp","sourceId":"rfi"},{"id":1771594957000,"createdDate":"2026-02-20 13:42","name":"法国国际广播电台","title":"特朗普“和平委员会”首次会议40国代表出席，还将干预全球各地“热点地区”","content":"美国总统特朗普发起的“和平委员会”周四在华盛顿举行首次会议。他在会上表达了对加沙局势的乐观态度。此次会议的重点是脆弱的加沙停火协议后续步骤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260220-%E7%89%B9%E6%9C%97%E6%99%AE-%E5%92%8C%E5%B9%B3%E5%A7%94%E5%91%98%E4%BC%9A-%E9%A6%96%E6%AC%A1%E4%BC%9A%E8%AE%AE40%E5%9B%BD%E4%BB%A3%E8%A1%A8%E5%87%BA%E5%B8%AD%EF%BC%8C%E8%BF%98%E5%B0%86%E5%B9%B2%E9%A2%84%E5%85%A8%E7%90%83%E5%90%84%E5%9C%B0-%E7%83%AD%E7%82%B9%E5%9C%B0%E5%8C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771594957000.webp","sourceId":"rfi"},{"id":1771592592000,"createdDate":"2026-02-20 13:03","name":"法国国际广播电台","title":"无人机如何给乌克兰战场带来技术革命？","content":"俄罗斯全面入侵乌克兰的战争爆发将进入第五年。这不仅是二战以来的国际社会面对的最大规模的一场军事冲突，也是历史上，首次无人机在战场上无所不在，并发挥着重要作用的一场战争。相对于造价高昂的常规武器，无人机以其低廉的制作成本，成为俄乌双方都越来越多使用的武器。法广特约记者ThéoRenaudon近日在乌克兰走访了乌克兰军队为阻击俄罗斯无人机袭击而设立的小分队。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260220-%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%A6%82%E4%BD%95%E5%9C%A8%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E5%9C%BA%E5%B8%A6%E6%9D%A5%E6%8A%80%E6%9C%AF%E9%9D%A9%E5%91%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771592592000.webp","sourceId":"rfi"},{"id":1771589421000,"createdDate":"2026-02-20 12:10","name":"法国国际广播电台","title":"伊朗与俄罗斯在霍尔木兹等海域联合演习 中国似乎未参与","content":"伊朗和俄罗斯19日在伊朗南部海域启动联合军演。此刻正值美国持续扩大在阿拉伯海的军事存在。特朗普是否对伊朗进行军事打击受到密切关注。法新社说北京似乎没有参与此次演习。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260220-%E4%BC%8A%E6%9C%97%E4%B8%8E%E4%BF%84%E7%BD%97%E6%96%AF%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E7%AD%89%E6%B5%B7%E5%9F%9F%E8%81%94%E5%90%88%E6%BC%94%E4%B9%A0-%E4%B8%AD%E5%9B%BD%E4%BC%BC%E4%B9%8E%E6%9C%AA%E5%8F%82%E4%B8%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771589421000.webp","sourceId":"rfi"},{"id":1771584614000,"createdDate":"2026-02-20 10:50","name":"法国国际广播电台","title":"高市发表就任后首次施政方针演说，未来她将如何处理国内经济难题和对中关系？","content":"日本首相高市早苗周五（2月20日）在众院全体会议上发表就任后的首次施政方针演说，地缘政治紧张局势和日本国内的经济挑战成为此次讲话的核心议题。高市表示日本将强化防务，并为经济“按下增长按钮”，同时努力安抚金融市场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260220-%E9%AB%98%E5%B8%82%E5%8F%91%E8%A1%A8%E5%B0%B1%E4%BB%BB%E5%90%8E%E9%A6%96%E6%AC%A1%E6%96%BD%E6%94%BF%E6%96%B9%E9%92%88%E6%BC%94%E8%AF%B4%EF%BC%8C%E6%9C%AA%E6%9D%A5%E5%A5%B9%E5%B0%86%E5%A6%82%E4%BD%95%E5%A4%84%E7%90%86%E5%9B%BD%E5%86%85%E7%BB%8F%E6%B5%8E%E9%9A%BE%E9%A2%98%E5%92%8C%E5%AF%B9%E4%B8%AD%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771584614000.webp","sourceId":"rfi"},{"id":1771578657000,"createdDate":"2026-02-20 09:10","name":"法国国际广播电台","title":"高市首相施政演说对中俄朝军事动向严重关切 欲推进日中“战略互惠”","content":"2月20日，在日本第221届特别国会上，日本首相高市早苗发表施政方针演说，提出了“负责任的积极财政”“重新审视裁量劳动制”等政策，在外交方面，她提到对中俄朝军事活动的严重关切，但也谈到全面推进日中“战略互惠关系”。高市首相在日本众议院全体会议上发表施政方针演说，开头表示“得到了国民有力的支持与鼓励”，并提及此前众议院选举中取得的历史性大胜。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260220-%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E6%96%BD%E6%94%BF%E6%BC%94%E8%AF%B4%E5%AF%B9%E4%B8%AD%E4%BF%84%E6%9C%9D%E5%86%9B%E4%BA%8B%E5%8A%A8%E5%90%91%E4%B8%A5%E9%87%8D%E5%85%B3%E5%88%87-%E6%AC%B2%E6%8E%A8%E8%BF%9B%E6%97%A5%E4%B8%AD-%E6%88%98%E7%95%A5%E4%BA%92%E6%83%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/20/1771578657000.webp","sourceId":"rfi"}]