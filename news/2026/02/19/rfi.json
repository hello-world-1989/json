[{"id":1771489137000,"createdDate":"2026-02-19 08:18","name":"法国国际广播电台","title":"巴黎再有两名维人遭华威胁利诱 人权观察促法国在G7峰会推动应对跨境镇压","content":"国际人权组织「人权观察」获悉，中国正加强在法国的跨境镇压活动以打压海外的批华声音，最新例子是两名身处巴黎的维吾尔人被自称中国官员的男子威迫利诱，要求他们分别当间谍去监视当地的离散维族社群和停止在当地的活动。该组织呼吁法国总统马克龙在七大工业国组织(G7)高峰会落实G7声明，推动对应长臂管辖的工作。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260219-%E5%B7%B4%E9%BB%8E%E5%86%8D%E6%9C%89%E4%B8%A4%E5%90%8D%E7%BB%B4%E4%BA%BA%E9%81%AD%E5%8D%8E%E5%A8%81%E8%83%81%E5%88%A9%E8%AF%B1-%E4%BA%BA%E6%9D%83%E8%A7%82%E5%AF%9F%E4%BF%83%E6%B3%95%E5%9B%BD%E5%9C%A8g7%E5%B3%B0%E4%BC%9A%E6%8E%A8%E5%8A%A8%E5%BA%94%E5%AF%B9%E8%B7%A8%E5%A2%83%E9%95%87%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/19/1771489137000.webp","sourceId":"rfi"},{"id":1771487754000,"createdDate":"2026-02-19 07:55","name":"法国国际广播电台","title":"华尔街日报：中方政策顾问提议北京大规模购买美国国债 以换取美国反对台湾独立声明","content":"美国《华尔街日报》报导，特习在2月通话后，对台军售陷入卡关。熟知内情的美国官员表示，特朗普的幕僚对于是否批准对台军售案已出现立场动摇。但他同时强调，特朗普不会被习近平左右。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260219-%E5%8D%8E%E5%B0%94%E8%A1%97%E6%97%A5%E6%8A%A5-%E4%B8%AD%E6%96%B9%E6%94%BF%E7%AD%96%E9%A1%BE%E9%97%AE%E6%8F%90%E8%AE%AE%E5%8C%97%E4%BA%AC%E5%A4%A7%E8%A7%84%E6%A8%A1%E8%B4%AD%E4%B9%B0%E7%BE%8E%E5%9B%BD%E5%9B%BD%E5%80%BA-%E4%BB%A5%E6%8D%A2%E5%8F%96%E7%BE%8E%E5%9B%BD%E5%8F%8D%E5%AF%B9%E5%8F%B0%E6%B9%BE%E7%8B%AC%E7%AB%8B%E5%A3%B0%E6%98%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/19/1771487754000.webp","sourceId":"rfi"}]