[{"id":1771977851000,"createdDate":"2026-02-25 00:04","name":"法国国际广播电台","title":"泽连斯基：普京“未能实现其目标”，“我们守住了乌克兰”","content":"在俄罗斯入侵乌克兰整整四周年之际，乌克兰总统泽连斯基周二表示，普京“未能实现其目标”，“我们守住了乌克兰”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260225-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E6%99%AE%E4%BA%AC-%E6%9C%AA%E8%83%BD%E5%AE%9E%E7%8E%B0%E5%85%B6%E7%9B%AE%E6%A0%87-%EF%BC%8C-%E6%88%91%E4%BB%AC%E5%AE%88%E4%BD%8F%E4%BA%86%E4%B9%8C%E5%85%8B%E5%85%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1771977851000.webp","sourceId":"rfi"},{"id":1771977621000,"createdDate":"2026-02-25 00:00","name":"法国国际广播电台","title":"默茨访华：德中经济关系正处于历史性的转折点","content":"法国世界报周二关注德国总理默茨将于2月25日至26日对中国的访问。该报强调，德中经济关系正处于历史性的转折点。过去二十年中，德中经贸往来以高度互补为特征，但这一模式如今已不复存在。中国对德国制造的化工产品、汽车和设备的强劲需求，曾经推动了中国工业化的发展，也在2010年代为德国带来了显著的繁荣，但如今，这一阶段已经结束。这一局面对在中国问题上相对缺乏经验的德国总理来说，无疑增加了难度。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260225-%E9%BB%98%E8%8C%A8%E8%AE%BF%E5%8D%8E-%E5%BE%B7%E4%B8%AD%E7%BB%8F%E6%B5%8E%E5%85%B3%E7%B3%BB%E6%AD%A3%E5%A4%84%E4%BA%8E%E5%8E%86%E5%8F%B2%E6%80%A7%E7%9A%84%E8%BD%AC%E6%8A%98%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1771977621000.webp","sourceId":"rfi"},{"id":1772010047000,"createdDate":"2026-02-25 09:00","name":"法国国际广播电台","title":"中国严控对日出口 高市首相强调促进重要物资多元化","content":"中国商务部24日发布《商务部公告2026年第11号公布将20家日本实体列入出口管制管控名单》和《商务部公告2026年第12号公布将20家日本实体列入关注名单》，高市首相25日在参议院代表质询中，就中国以稀土为重点的出口管制表示：“为实现不依赖特定国家的强韧供应链，将与志同道合国家加强合作，推进供应来源多元化。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260225-%E4%B8%AD%E5%9B%BD%E4%B8%A5%E6%8E%A7%E5%AF%B9%E6%97%A5%E5%87%BA%E5%8F%A3-%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E5%BC%BA%E8%B0%83%E4%BF%83%E8%BF%9B%E9%87%8D%E8%A6%81%E7%89%A9%E8%B5%84%E5%A4%9A%E5%85%83%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772010047000.webp","sourceId":"rfi"},{"id":1772009734000,"createdDate":"2026-02-25 08:55","name":"法国国际广播电台","title":"美国商务部官员披露：英伟达H200芯片仍未出售给中国","content":"法新社周三（2月25日）消息称，据美国商务部官员披露，尽管美国的出口限制有所放宽，但迄今为止，英伟达（Nvidia）可用于训练和运行人工智能系统的高端H200芯片仍未向中国企业出售。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260225-%E7%BE%8E%E5%9B%BD%E5%95%86%E5%8A%A1%E9%83%A8%E5%AE%98%E5%91%98%E6%8A%AB%E9%9C%B2-%E8%8B%B1%E4%BC%9F%E8%BE%BEh200%E8%8A%AF%E7%89%87%E4%BB%8D%E6%9C%AA%E5%87%BA%E5%94%AE%E7%BB%99%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772009734000.webp","sourceId":"rfi"},{"id":1772009124000,"createdDate":"2026-02-25 08:45","name":"法国国际广播电台","title":"默茨访华首日再提中德之间的合作应“更加公平”","content":"北京时间周三（2月25日）上午，德国总理默茨抵达北京，正式开启对中国进行为期两天的访问。在访华首日，他呼吁与中国开展更加“公平”的合作。值得注意的是，这是他自2025年就任总理以来首次访问中国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260225-%E9%BB%98%E8%8C%A8%E8%AE%BF%E5%8D%8E%E9%A6%96%E6%97%A5%E5%86%8D%E6%8F%90%E4%B8%AD%E5%BE%B7%E4%B9%8B%E9%97%B4%E7%9A%84%E5%90%88%E4%BD%9C%E5%BA%94-%E6%9B%B4%E5%8A%A0%E5%85%AC%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772009124000.webp","sourceId":"rfi"},{"id":1772006625000,"createdDate":"2026-02-25 08:03","name":"法国国际广播电台","title":"反对巴拿马港口被接管：长和提兴讼 港府抗议 京称维权 评论料无解 料可取赔偿","content":"巴拿马政府强行接管由香港首富子公司在当地营运的两个运河港口，被夺权的长江和记公司(长和)发声明表示反对；港府相关官员亦向巴拿马驻港总领事提出严正抗议，对该国破坏合约精神之举表达「强烈不满和反对」；中港政府均表示，将坚决维护企业正当合法权益。不过，有评论指出，事件属政治决定，企业难有发言空间，而长和及中国政府之间亦未见有就统一战线达成共识，预料事件难望解决，长和能争取赔偿可能已属最佳结局。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260225-%E5%8F%8D%E5%AF%B9%E5%B7%B4%E6%8B%BF%E9%A9%AC%E6%B8%AF%E5%8F%A3%E8%A2%AB%E6%8E%A5%E7%AE%A1-%E9%95%BF%E5%92%8C%E6%8F%90%E5%85%B4%E8%AE%BC-%E6%B8%AF%E5%BA%9C%E6%8A%97%E8%AE%AE-%E4%BA%AC%E7%A7%B0%E7%BB%B4%E6%9D%83-%E8%AF%84%E8%AE%BA%E6%96%99%E6%97%A0%E8%A7%A3-%E6%96%99%E5%8F%AF%E5%8F%96%E8%B5%94%E5%81%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772006625000.webp","sourceId":"rfi"},{"id":1772036501000,"createdDate":"2026-02-25 16:21","name":"法国国际广播电台","title":"美韩将在三月举行联合军演  以应对朝鲜局势升温","content":"美联社消息称，美韩两国军方周三（2月25日）表示，两国将进行“自由之盾”年度春季联合演习，演习定于3月9日至19日举行，目的是为了加强两国的联合防御能力， 以应对朝鲜局势升温。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260225-%E7%BE%8E%E9%9F%A9%E5%B0%86%E5%9C%A8%E4%B8%89%E6%9C%88%E4%B8%BE%E8%A1%8C%E8%81%94%E5%90%88%E5%86%9B%E6%BC%94-%E4%BB%A5%E5%BA%94%E5%AF%B9%E6%9C%9D%E9%B2%9C%E5%B1%80%E5%8A%BF%E5%8D%87%E6%B8%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772036501000.webp","sourceId":"rfi"},{"id":1772036395000,"createdDate":"2026-02-25 16:19","name":"法国国际广播电台","title":"巴西东南部严重洪灾已造成至少数十人死亡，数千人被迫撤离","content":"巴西官员周三表示，东南部米纳斯吉拉斯州连日暴雨引发洪灾和山体滑坡，已造成至少36人死亡，仍有数十人失踪。救援人员连夜展开搜救，而未来几天当地仍预报有强降雨，灾情或进一步恶化。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260225-%E5%B7%B4%E8%A5%BF%E4%B8%9C%E5%8D%97%E9%83%A8%E4%B8%A5%E9%87%8D%E6%B4%AA%E7%81%BE%E5%B7%B2%E9%80%A0%E6%88%90%E8%87%B3%E5%B0%91%E6%95%B0%E5%8D%81%E4%BA%BA%E6%AD%BB%E4%BA%A1%EF%BC%8C%E6%95%B0%E5%8D%83%E4%BA%BA%E8%A2%AB%E8%BF%AB%E6%92%A4%E7%A6%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772036395000.webp","sourceId":"rfi"},{"id":1772032823000,"createdDate":"2026-02-25 15:20","name":"法国国际广播电台","title":"匈牙利阻挠欧盟向乌克兰提供贷款 遭德国和比利时外长愤怒谴责","content":"法新社周三（2月25日）消息称，德国和比利时外交部长谴责匈牙利，因为该国威胁否决欧盟向乌克兰提供贷款的计划。而前一天（2月24日），俄罗斯入侵乌克兰正好满四周年。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260225-%E5%8C%88%E7%89%99%E5%88%A9%E9%98%BB%E6%8C%A0%E6%AC%A7%E7%9B%9F%E5%90%91%E4%B9%8C%E5%85%8B%E5%85%B0%E6%8F%90%E4%BE%9B%E8%B4%B7%E6%AC%BE-%E9%81%AD%E5%BE%B7%E5%9B%BD%E5%92%8C%E6%AF%94%E5%88%A9%E6%97%B6%E5%A4%96%E9%95%BF%E6%84%A4%E6%80%92%E8%B0%B4%E8%B4%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772032823000.webp","sourceId":"rfi"},{"id":1772031232000,"createdDate":"2026-02-25 14:53","name":"法国国际广播电台","title":"默茨宣布中国向空客（Airbus）订购多达120架飞机","content":"访华首日，德国总理默茨周三（2月25日）表示，中国将向欧洲飞机制造商空客（Airbus）订购“最多120架”飞机。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260225-%E9%BB%98%E8%8C%A8%E5%AE%A3%E5%B8%83%E4%B8%AD%E5%9B%BD%E5%90%91%E7%A9%BA%E5%AE%A2-airbus-%E8%AE%A2%E8%B4%AD%E5%A4%9A%E8%BE%BE120%E6%9E%B6%E9%A3%9E%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772031232000.webp","sourceId":"rfi"},{"id":1772030599000,"createdDate":"2026-02-25 14:43","name":"法国国际广播电台","title":"婴儿奶粉遭污染: 欧盟加强对涉事中国原料的海关检查","content":"法新社周三（2月25日）消息称，欧盟决定加强对来自中国的一种涉事物质的边境检查，这种物质被认为与婴儿配方奶粉受毒素污染事件有关，该事件已在法国等国引发司法调查。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260225-%E5%A9%B4%E5%84%BF%E5%A5%B6%E7%B2%89%E9%81%AD%E6%B1%A1%E6%9F%93-%E6%AC%A7%E7%9B%9F%E5%8A%A0%E5%BC%BA%E5%AF%B9%E6%B6%89%E4%BA%8B%E4%B8%AD%E5%9B%BD%E5%8E%9F%E6%96%99%E7%9A%84%E6%B5%B7%E5%85%B3%E6%A3%80%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772030599000.webp","sourceId":"rfi"},{"id":1772029805000,"createdDate":"2026-02-25 14:30","name":"法国国际广播电台","title":"被美国列入黑名单禁售 全球最大无人机制造商大疆（DJI）提起法律诉讼","content":"全球最大的无人机制造商中国企业DJI（大疆创新）周三（2月25日）宣布，已就被美国联邦通信委员会（FCC）列入黑名单、禁止其在美国销售产品一事提起诉讼。早在2022年，五角大楼就已将大疆列入与中国军方有关联的企业名单。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260225-%E8%A2%AB%E7%BE%8E%E5%9B%BD%E5%88%97%E5%85%A5%E9%BB%91%E5%90%8D%E5%8D%95%E4%B8%94%E7%A6%81%E5%94%AE-%E5%85%A8%E7%90%83%E6%9C%80%E5%A4%A7%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%88%B6%E9%80%A0%E5%95%86%E5%A4%A7%E7%96%86-dji-%E6%8F%90%E8%B5%B7%E6%B3%95%E5%BE%8B%E8%AF%89%E8%AE%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772029805000.webp","sourceId":"rfi"},{"id":1772027941000,"createdDate":"2026-02-25 13:59","name":"法国国际广播电台","title":"特朗普国情咨文中的“黄金时代”与低迷民调","content":"重返白宫十三个月后，美国总统唐纳德·特朗普于周二（2月24日）晚间在国会大厦发表了第二次国情咨文讲话。目前距离中期选举仅剩几个月之际，他试图扭转低迷民调，同时应对国内外日益严峻的挑战。特朗普称他在就职演说中承诺的“黄金时代”仍然触手可及，但在多大程度上能够说服美国选民还是未知数。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260225-%E7%89%B9%E6%9C%97%E6%99%AE%E5%9B%BD%E6%83%85%E5%92%A8%E6%96%87%E4%B8%AD%E7%9A%84-%E9%BB%84%E9%87%91%E6%97%B6%E4%BB%A3-%E4%B8%8E%E4%BD%8E%E8%BF%B7%E6%B0%91%E8%B0%83","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772027941000.webp","sourceId":"rfi"},{"id":1772022367000,"createdDate":"2026-02-25 12:26","name":"法国国际广播电台","title":"默茨与习近平及李强会谈 涉贸易及稀土","content":"综合法新社与美联社消息，默茨率领由众多企业高管组成的重要代表团访华首日，虽然就一些分歧议题进行了沟通，但取得的成果极其有限。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260225-%E9%BB%98%E8%8C%A8%E4%B8%8E%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%8F%8A%E6%9D%8E%E5%BC%BA%E4%BC%9A%E8%B0%88-%E6%B6%89%E8%B4%B8%E6%98%93%E5%8F%8A%E7%A8%80%E5%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772022367000.webp","sourceId":"rfi"},{"id":1772014568000,"createdDate":"2026-02-25 10:16","name":"法国国际广播电台","title":"对接中国「十五五」 港府破格用外汇基金1500亿建北都 强调不影响金融稳定","content":"港府在首份表明要对接中国五年经济规划的财政预算案中，破天荒地从稳定港币的外汇基金中分两年转拨共1500亿港元(下同，折算约为162.7亿欧元)至基本工程储备基金，以支持有助发展中国经济的北部都会区(简称「北都」)及其他基建项目。面对质疑，港府官员强调，转拨后仍有105%的偿付能力，不影响外汇基金保持香港货币金融体系的稳定性。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260225-%E5%AF%B9%E6%8E%A5%E4%B8%AD%E5%9B%BD-%E5%8D%81%E4%BA%94%E4%BA%94-%E6%B8%AF%E5%BA%9C%E7%A0%B4%E6%A0%BC%E7%94%A8%E5%A4%96%E6%B1%87%E5%9F%BA%E9%87%911500%E4%BA%BF%E5%BB%BA%E5%8C%97%E9%83%BD-%E5%BC%BA%E8%B0%83%E4%B8%8D%E5%BD%B1%E5%93%8D%E9%87%91%E8%9E%8D%E7%A8%B3%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772014568000.webp","sourceId":"rfi"},{"id":1772014341000,"createdDate":"2026-02-25 10:12","name":"法国国际广播电台","title":"香港提早转亏为盈29亿 惟学者指靠「借债当收入」 盈馀意义不大","content":"在经历连续五年财赤后，香港预期本财政年度转亏为盈，料可录得29亿港元(下同，折算约为3.14亿欧元)盈馀，提早达标。港府更预期，今年经济增长可维持在2.5%至3.5%会继续蓬勃，支持下一个财政年度的盈馀会扩大至221亿。不过，有关盈馀的出现，与港府往后五年丶每年发债1600亿至2200亿有关。经济学者李兆波指出，港府这种「发债当收入」的做法，令盈馀的出现，意义不大；若计及债务，财赤可说非常严重。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260225-%E9%A6%99%E6%B8%AF%E6%8F%90%E6%97%A9%E8%BD%AC%E4%BA%8F%E4%B8%BA%E7%9B%8829%E4%BA%BF-%E6%83%9F%E5%AD%A6%E8%80%85%E6%8C%87%E9%9D%A0-%E5%80%9F%E5%80%BA%E5%BD%93%E6%94%B6%E5%85%A5-%E7%9B%88%E9%A6%80%E6%84%8F%E4%B9%89%E4%B8%8D%E5%A4%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772014341000.webp","sourceId":"rfi"},{"id":1772014078000,"createdDate":"2026-02-25 10:07","name":"法国国际广播电台","title":"《纽时》报导晶片危机，全球经济最脆弱的「单一故障点」就在台湾","content":"美国《纽约时报》报导美国极度依赖台湾晶片为其一大弱点，并细数从拜登到特朗普两任美国总统以来，美方持续想要摆脱极度倚赖台湾晶片的各种努力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260225-%E7%BA%BD%E6%97%B6-%E6%8A%A5%E5%AF%BC%E6%99%B6%E7%89%87%E5%8D%B1%E6%9C%BA%EF%BC%8C%E5%85%A8%E7%90%83%E7%BB%8F%E6%B5%8E%E6%9C%80%E8%84%86%E5%BC%B1%E7%9A%84-%E5%8D%95%E4%B8%80%E6%95%85%E9%9A%9C%E7%82%B9-%E5%B0%B1%E5%9C%A8%E5%8F%B0%E6%B9%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772014078000.webp","sourceId":"rfi"},{"id":1772012496000,"createdDate":"2026-02-25 09:41","name":"法国国际广播电台","title":"特朗普指责伊朗研制可打击美国的武器，遭伊朗驳斥","content":"美国总统特朗普周二（2月24日）指责伊朗研制可打击美国的武器，并继续追求“阴险的核野心”，同时表示更倾向于通过外交途径解决问题。伊朗周三（2月25日）驳斥相关说法为“弥天大谎”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260225-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8C%87%E8%B4%A3%E4%BC%8A%E6%9C%97%E7%A0%94%E5%88%B6%E5%8F%AF%E6%89%93%E5%87%BB%E7%BE%8E%E5%9B%BD%E7%9A%84%E6%AD%A6%E5%99%A8%EF%BC%8C%E9%81%AD%E4%BC%8A%E6%9C%97%E9%A9%B3%E6%96%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772012496000.webp","sourceId":"rfi"},{"id":1772011334000,"createdDate":"2026-02-25 09:22","name":"法国国际广播电台","title":"特朗普发表史上最长的国情咨文演讲，称美国正步入“黄金时代”","content":"美国总统特朗普周二（2月24日）晚在国会发表创纪录时长的国情咨文演讲，大力宣扬他任期内美国的经济成就，称美国正步入一个“黄金时代”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260225-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%91%E8%A1%A8%E5%8F%B2%E4%B8%8A%E6%9C%80%E9%95%BF%E7%9A%84%E5%9B%BD%E6%83%85%E5%92%A8%E6%96%87%E6%BC%94%E8%AE%B2%EF%BC%8C%E7%A7%B0%E7%BE%8E%E5%9B%BD%E6%AD%A3%E6%AD%A5%E5%85%A5-%E9%BB%84%E9%87%91%E6%97%B6%E4%BB%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772011334000.webp","sourceId":"rfi"},{"id":1772010564000,"createdDate":"2026-02-25 09:09","name":"法国国际广播电台","title":"美伊紧张局势加剧之际 印度总理莫迪访问以色列","content":"中东局势因美伊紧张局势陷入不稳定之际，印度总理纳伦德拉·莫迪预计将于周三（2月25号）抵达以色列，进行为期两天的访问，重点是加强两国在安全、经济和技术方面的合作。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260225-%E7%BE%8E%E4%BC%8A%E7%B4%A7%E5%BC%A0%E5%B1%80%E5%8A%BF%E5%8A%A0%E5%89%A7%E4%B9%8B%E9%99%85-%E5%8D%B0%E5%BA%A6%E6%80%BB%E7%90%86%E8%8E%AB%E8%BF%AA%E8%AE%BF%E9%97%AE%E4%BB%A5%E8%89%B2%E5%88%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772010564000.webp","sourceId":"rfi"},{"id":1772010463000,"createdDate":"2026-02-25 09:07","name":"法国国际广播电台","title":"日本NHK驻伊朗德黑兰分社负责人被捕","content":"综合法新社与日本公共电视台NHK的报道，NHK驻伊朗德黑兰分社负责人在伊朗被逮捕。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260225-%E6%97%A5%E6%9C%ACnhk%E9%A9%BB%E4%BC%8A%E6%9C%97%E5%BE%B7%E9%BB%91%E5%85%B0%E5%88%86%E7%A4%BE%E8%B4%9F%E8%B4%A3%E4%BA%BA%E8%A2%AB%E6%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1772010463000.webp","sourceId":"rfi"}]