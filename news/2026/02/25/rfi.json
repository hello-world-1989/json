[{"id":1771977851000,"createdDate":"2026-02-25 00:04","name":"法国国际广播电台","title":"泽连斯基：普京“未能实现其目标”，“我们守住了乌克兰”","content":"在俄罗斯入侵乌克兰整整四周年之际，乌克兰总统泽连斯基周二表示，普京“未能实现其目标”，“我们守住了乌克兰”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260225-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E6%99%AE%E4%BA%AC-%E6%9C%AA%E8%83%BD%E5%AE%9E%E7%8E%B0%E5%85%B6%E7%9B%AE%E6%A0%87-%EF%BC%8C-%E6%88%91%E4%BB%AC%E5%AE%88%E4%BD%8F%E4%BA%86%E4%B9%8C%E5%85%8B%E5%85%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1771977851000.webp","sourceId":"rfi"},{"id":1771977621000,"createdDate":"2026-02-25 00:00","name":"法国国际广播电台","title":"默茨访华：德中经济关系正处于历史性的转折点","content":"法国世界报周二关注德国总理默茨将于2月25日至26日对中国的访问。该报强调，德中经济关系正处于历史性的转折点。过去二十年中，德中经贸往来以高度互补为特征，但这一模式如今已不复存在。中国对德国制造的化工产品、汽车和设备的强劲需求，曾经推动了中国工业化的发展，也在2010年代为德国带来了显著的繁荣，但如今，这一阶段已经结束。这一局面对在中国问题上相对缺乏经验的德国总理来说，无疑增加了难度。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260225-%E9%BB%98%E8%8C%A8%E8%AE%BF%E5%8D%8E-%E5%BE%B7%E4%B8%AD%E7%BB%8F%E6%B5%8E%E5%85%B3%E7%B3%BB%E6%AD%A3%E5%A4%84%E4%BA%8E%E5%8E%86%E5%8F%B2%E6%80%A7%E7%9A%84%E8%BD%AC%E6%8A%98%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/25/1771977621000.webp","sourceId":"rfi"}]