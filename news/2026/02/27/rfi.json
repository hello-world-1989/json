[{"id":1772181644000,"createdDate":"2026-02-27 08:40","name":"法国国际广播电台","title":"巴基斯坦向阿富汗宣战，中国称“冲突烈度超过以往”并呼吁尽快停火","content":"巴基斯坦政府周五（2月27日）在阿富汗前一日于边境发动攻势后，向阿富汗塔利班政权宣布进入“公开战争”状态。作为报复，巴基斯坦对包括首都在内的多处阿富汗目标实施轰炸。中国表达关切。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%90%91%E9%98%BF%E5%AF%8C%E6%B1%97%E5%AE%A3%E6%88%98%EF%BC%8C%E4%B8%AD%E5%9B%BD%E7%A7%B0-%E5%86%B2%E7%AA%81%E7%83%88%E5%BA%A6%E8%B6%85%E8%BF%87%E4%BB%A5%E5%BE%80-%E5%B9%B6%E5%91%BC%E5%90%81%E5%B0%BD%E5%BF%AB%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772181644000.webp","sourceId":"rfi"},{"id":1772179810000,"createdDate":"2026-02-27 08:10","name":"法国国际广播电台","title":"未受升空失利影响 中国维持2030年前踏足月球 港澳航天员最快今年飞天","content":"中国近几个月的火箭升空出现至少五次失利，但载人航天工程办公室(下称航天办)表明，仍会以2030年前实现中国人首次登陆月球为目标，而今年将会进行两次载人飞行任务和一次货运飞船补给任务，来自港澳地区的航天员有望最早今年执行飞行任务，与航天办官员早前宣布港澳航天员首次参与孩行的时间表一致。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260227-%E6%9C%AA%E5%8F%97%E5%8D%87%E7%A9%BA%E5%A4%B1%E5%88%A9%E5%BD%B1%E5%93%8D-%E4%B8%AD%E5%9B%BD%E7%BB%B4%E6%8C%812030%E5%B9%B4%E5%89%8D%E8%B8%8F%E8%B6%B3%E6%9C%88%E7%90%83-%E6%B8%AF%E6%BE%B3%E8%88%AA%E5%A4%A9%E5%91%98%E6%9C%80%E5%BF%AB%E4%BB%8A%E5%B9%B4%E9%A3%9E%E5%A4%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772179810000.webp","sourceId":"rfi"}]