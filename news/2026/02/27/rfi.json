[{"id":1772181644000,"createdDate":"2026-02-27 08:40","name":"法国国际广播电台","title":"巴基斯坦向阿富汗宣战，中国称“冲突烈度超过以往”并呼吁尽快停火","content":"巴基斯坦政府周五（2月27日）在阿富汗前一日于边境发动攻势后，向阿富汗塔利班政权宣布进入“公开战争”状态。作为报复，巴基斯坦对包括首都在内的多处阿富汗目标实施轰炸。中国表达关切。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%90%91%E9%98%BF%E5%AF%8C%E6%B1%97%E5%AE%A3%E6%88%98%EF%BC%8C%E4%B8%AD%E5%9B%BD%E7%A7%B0-%E5%86%B2%E7%AA%81%E7%83%88%E5%BA%A6%E8%B6%85%E8%BF%87%E4%BB%A5%E5%BE%80-%E5%B9%B6%E5%91%BC%E5%90%81%E5%B0%BD%E5%BF%AB%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772181644000.webp","sourceId":"rfi"},{"id":1772179810000,"createdDate":"2026-02-27 08:10","name":"法国国际广播电台","title":"未受升空失利影响 中国维持2030年前踏足月球 港澳航天员最快今年飞天","content":"中国近几个月的火箭升空出现至少五次失利，但载人航天工程办公室(下称航天办)表明，仍会以2030年前实现中国人首次登陆月球为目标，而今年将会进行两次载人飞行任务和一次货运飞船补给任务，来自港澳地区的航天员有望最早今年执行飞行任务，与航天办官员早前宣布港澳航天员首次参与孩行的时间表一致。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260227-%E6%9C%AA%E5%8F%97%E5%8D%87%E7%A9%BA%E5%A4%B1%E5%88%A9%E5%BD%B1%E5%93%8D-%E4%B8%AD%E5%9B%BD%E7%BB%B4%E6%8C%812030%E5%B9%B4%E5%89%8D%E8%B8%8F%E8%B6%B3%E6%9C%88%E7%90%83-%E6%B8%AF%E6%BE%B3%E8%88%AA%E5%A4%A9%E5%91%98%E6%9C%80%E5%BF%AB%E4%BB%8A%E5%B9%B4%E9%A3%9E%E5%A4%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772179810000.webp","sourceId":"rfi"},{"id":1772208137000,"createdDate":"2026-02-27 16:02","name":"法国国际广播电台","title":"联合国批评中国：未能充分采取行动改善新疆地区维吾尔族人的处境","content":"联合国人权事务高级专员沃尔克·图尔克(VolkerTürk)27日批评中国未能充分采取行动，改善新疆地区维吾尔族人的处境。这一谴责距离联合国发布一份针对新疆措辞严厉的人权报告已过去三年多。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E8%81%94%E5%90%88%E5%9B%BD%E6%89%B9%E8%AF%84%E4%B8%AD%E5%9B%BD-%E6%9C%AA%E8%83%BD%E5%85%85%E5%88%86%E9%87%87%E5%8F%96%E8%A1%8C%E5%8A%A8%E6%94%B9%E5%96%84%E6%96%B0%E7%96%86%E5%9C%B0%E5%8C%BA%E7%BB%B4%E5%90%BE%E5%B0%94%E6%97%8F%E4%BA%BA%E7%9A%84%E5%A4%84%E5%A2%83","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772208137000.webp","sourceId":"rfi"},{"id":1772207159000,"createdDate":"2026-02-27 15:45","name":"法国国际广播电台","title":"德黑兰警告华盛顿必须放弃“过分的要求”, 关于伊朗核计划的技术磋商下周在维也纳举行","content":"据法新社周五看到的一份机密报告显示，国际原子能机构周五证实，关于伊朗核计划的技术磋商将于2026年3月2日开始的那一周在维也纳举行。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260227-%E5%BE%B7%E9%BB%91%E5%85%B0%E8%AD%A6%E5%91%8A%E5%8D%8E%E7%9B%9B%E9%A1%BF%E5%BF%85%E9%A1%BB%E6%94%BE%E5%BC%83-%E8%BF%87%E5%88%86%E7%9A%84%E8%A6%81%E6%B1%82-%E5%85%B3%E4%BA%8E%E4%BC%8A%E6%9C%97%E6%A0%B8%E8%AE%A1%E5%88%92%E7%9A%84%E6%8A%80%E6%9C%AF%E7%A3%8B%E5%95%86%E4%B8%8B%E5%91%A8%E5%9C%A8%E7%BB%B4%E4%B9%9F%E7%BA%B3%E4%B8%BE%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772207159000.webp","sourceId":"rfi"},{"id":1772203601000,"createdDate":"2026-02-27 14:46","name":"法国国际广播电台","title":"视频 爱泼斯坦案：希拉里·克林顿在听证会上辩护","content":"美国前总统比尔·克林顿本周五接受美国国会质询，此前克林顿夫妇最初拒绝出席听证会，但最终迫于起诉压力做出让步。在美国国会的第一轮问答环节结束后，希拉里克林顿这位前总统候选人谴责听证会的成员，称其偏袒共和党，并为她的丈夫辩护，请看France24记者埃米莉·缪塞的报道","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E8%A7%86%E9%A2%91-%E7%88%B1%E6%B3%BC%E6%96%AF%E5%9D%A6%E6%A1%88-%E5%B8%8C%E6%8B%89%E9%87%8C%C2%B7%E5%85%8B%E6%9E%97%E9%A1%BF%E5%9C%A8%E5%90%AC%E8%AF%81%E4%BC%9A%E4%B8%8A%E8%BE%A9%E6%8A%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772203601000.webp","sourceId":"rfi"},{"id":1772203323000,"createdDate":"2026-02-27 14:42","name":"法国国际广播电台","title":"视频 巴基斯坦与阿富汗军事行动升级","content":"巴基斯坦官员称，巴基斯坦于周四晚至周五凌晨对阿富汗主要城市的目标发动了空袭，两国之间的军事行动正在升级，请看France24报道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260227-%E8%A7%86%E9%A2%91-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E4%B8%8E%E9%98%BF%E5%AF%8C%E6%B1%97%E5%86%9B%E4%BA%8B%E8%A1%8C%E5%8A%A8%E5%8D%87%E7%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772203323000.webp","sourceId":"rfi"},{"id":1772202595000,"createdDate":"2026-02-27 14:29","name":"法国国际广播电台","title":"中国宣布自3月1日起暂时取消对部分加拿大产品的反歧视关税","content":"北京周五（2月27日）宣布，根据加拿大总理卡尼今年1月访华期间达成的协议，将自3月1日起暂时取消对部分加拿大产品征收的部分关税。这一声明是在加拿大放宽针对中国电动汽车和钢铁产品所采取措施之后作出的。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E4%B8%AD%E5%9B%BD%E5%AE%A3%E5%B8%83%E8%87%AA3%E6%9C%881%E6%97%A5%E8%B5%B7%E6%9A%82%E6%97%B6%E5%8F%96%E6%B6%88%E5%AF%B9%E9%83%A8%E5%88%86%E5%8A%A0%E6%8B%BF%E5%A4%A7%E4%BA%A7%E5%93%81%E7%9A%84%E5%8F%8D%E6%AD%A7%E8%A7%86%E5%85%B3%E7%A8%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772202595000.webp","sourceId":"rfi"},{"id":1772200975000,"createdDate":"2026-02-27 14:02","name":"法国国际广播电台","title":"刚果(金):在战乱中坚持的出版商","content":"法国国际广播电台（RadioFranceInternationale）中文节目[法语世界]（Chroniquefrancophonie）专栏2026年02月27日星期五第145集播出本台法广(RFI)法语栏目[非洲大咖嘉宾]（LeGrandInvitéAfrique）专栏记者奥利维耶（OlivierR）对到访巴黎的刚果民主共和国（RDCongo）出版人吉斯兰（GhislainKabuyaya）的采访录音片段。这位来自非洲法语大国的文化人，目前生活在处于战乱中的刚果（金）东部地区北基伍省的戈马城（Goma）。这集节目由尼古拉编译和播报，感谢收听。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C/20260227-%E6%B3%95%E5%B9%BFrfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C-%E7%AC%AC145%E9%9B%86-%E5%88%9A%E6%9E%9C-%E9%87%91-%E5%9C%A8%E6%88%98%E4%B9%B1%E4%B8%AD%E5%9D%9A%E6%8C%81%E7%9A%84%E5%87%BA%E7%89%88%E5%95%86","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772200975000.webp","sourceId":"rfi"},{"id":1772193622000,"createdDate":"2026-02-27 12:00","name":"法国国际广播电台","title":"中美同步发出警告：美国呼吁非必要人员离开以色列 中国敦促公民尽快撤离伊朗","content":"美国周五（2月27日）建议驻耶路撒冷大使馆的非必要人员离开以色列，此举是在美国威胁对伊朗进行军事打击的背景下，令地区紧张局势加剧。与此同时，中国也敦促公民尽快离开伊朗。而据中央社援引ABC消息，掌管美国在中东部队的美军中央司令部司令古柏今天向特朗普简报在伊朗可能采取的军事选项。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E4%B8%AD%E7%BE%8E%E5%90%8C%E6%AD%A5%E5%8F%91%E5%87%BA%E8%AD%A6%E5%91%8A-%E7%BE%8E%E5%9B%BD%E5%91%BC%E5%90%81%E9%9D%9E%E5%BF%85%E8%A6%81%E4%BA%BA%E5%91%98%E7%A6%BB%E5%BC%80%E4%BB%A5%E8%89%B2%E5%88%97-%E4%B8%AD%E5%9B%BD%E6%95%A6%E4%BF%83%E5%85%AC%E6%B0%91%E5%B0%BD%E5%BF%AB%E7%A6%BB%E5%BC%80%E4%BC%8A%E6%9C%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772193622000.webp","sourceId":"rfi"},{"id":1772192232000,"createdDate":"2026-02-27 11:37","name":"法国国际广播电台","title":"加印关系持续改善：加拿大总理卡尼抵达印度 寄望两国贸易额到2030年实现翻番","content":"据印度媒体报道，加拿大总理马克·卡尼周五（2月27日）抵达印度，他希望借此机会将双边贸易额翻一番，同时弥补与美国关系恶化带来的影响。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E5%8A%A0%E5%8D%B0%E5%85%B3%E7%B3%BB%E6%8C%81%E7%BB%AD%E6%94%B9%E5%96%84-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E6%80%BB%E7%90%86%E5%8D%A1%E5%B0%BC%E6%8A%B5%E8%BE%BE%E5%8D%B0%E5%BA%A6-%E5%AF%84%E6%9C%9B%E4%B8%A4%E5%9B%BD%E8%B4%B8%E6%98%93%E9%A2%9D%E5%88%B02030%E5%B9%B4%E5%AE%9E%E7%8E%B0%E7%BF%BB%E7%95%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772192232000.webp","sourceId":"rfi"},{"id":1772186239000,"createdDate":"2026-02-27 09:57","name":"法国国际广播电台","title":"俄罗斯宣布在扎波罗热核电站周边实施局部停火","content":"俄罗斯官员表示，为修复一条外部输电线路，乌克兰扎波罗热核电站附近周五起实施局部停火。俄罗斯军队在2022年2月对乌克兰发动全面入侵的最初几周内占领了扎波罗热核电站。该核电站是欧洲规模最大的核电站。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E4%BF%84%E7%BD%97%E6%96%AF%E5%AE%A3%E5%B8%83%E5%9C%A8%E6%89%8E%E6%B3%A2%E7%BD%97%E7%83%AD%E6%A0%B8%E7%94%B5%E7%AB%99%E5%91%A8%E8%BE%B9%E5%AE%9E%E6%96%BD%E5%B1%80%E9%83%A8%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772186239000.webp","sourceId":"rfi"},{"id":1772185572000,"createdDate":"2026-02-27 09:46","name":"法国国际广播电台","title":"争议多年后，韩国终于同意与谷歌地图共享数据","content":"综合法新社与美联社消息，韩国政府周五（2月27日）表示，将在满足特定安全要求的前提下，允许谷歌把韩国的高精度地图数据传输至海外服务器。此举回应了多年来外国游客的不满，他们抱怨谷歌地图在韩国无法有效使用。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E4%BA%89%E8%AE%AE%E5%A4%9A%E5%B9%B4%E5%90%8E%EF%BC%8C%E9%9F%A9%E5%9B%BD%E7%BB%88%E4%BA%8E%E5%90%8C%E6%84%8F%E4%B8%8E%E8%B0%B7%E6%AD%8C%E5%9C%B0%E5%9B%BE%E5%85%B1%E4%BA%AB%E6%95%B0%E6%8D%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772185572000.webp","sourceId":"rfi"},{"id":1772184795000,"createdDate":"2026-02-27 09:33","name":"法国国际广播电台","title":"伊朗警告美国不要在谈判中提出“任何过分要求”","content":"伊朗外交部长阿巴斯·阿拉格齐周五（2月27日）警告美国，在双方谈判中不要提出“任何过分要求”。此前一天，双方在日内瓦举行新一轮会谈后曾表现出一定乐观态度，伊朗方面表示，这些间接会谈将在未来几天继续进行。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E4%BC%8A%E6%9C%97%E8%AD%A6%E5%91%8A%E7%BE%8E%E5%9B%BD%E4%B8%8D%E8%A6%81%E5%9C%A8%E8%B0%88%E5%88%A4%E4%B8%AD%E6%8F%90%E5%87%BA-%E4%BB%BB%E4%BD%95%E8%BF%87%E5%88%86%E8%A6%81%E6%B1%82","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772184795000.webp","sourceId":"rfi"},{"id":1772184186000,"createdDate":"2026-02-27 09:23","name":"法国国际广播电台","title":"高市加紧推动国防改革 已批准建设情报机构提升“海外情报收集能力”","content":"日本首相高市早苗所属的执政党自民党已批准一项方案，旨在加强国家情报能力。一名党内负责人周五（2月27日）表示，此举正值高市推动国防政策重大改革之际。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E9%AB%98%E5%B8%82%E5%8A%A0%E7%B4%A7%E6%8E%A8%E5%8A%A8%E5%9B%BD%E9%98%B2%E6%94%B9%E9%9D%A9-%E5%B7%B2%E6%89%B9%E5%87%86%E5%BB%BA%E8%AE%BE%E6%83%85%E6%8A%A5%E6%9C%BA%E6%9E%84%E6%8F%90%E5%8D%87-%E6%B5%B7%E5%A4%96%E6%83%85%E6%8A%A5%E6%94%B6%E9%9B%86%E8%83%BD%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772184186000.webp","sourceId":"rfi"},{"id":1772183498000,"createdDate":"2026-02-27 09:11","name":"法国国际广播电台","title":"日本官房长官指中国利用AI贬损高市首相威胁国家安全","content":"日本内阁官房长官木原稔在27日的记者会上表示，针对美国OpenAI发布声明称，中国当局相关人员曾使用其对话式生成式人工智能（AI）“ChatGPT”，试图对高市早苗首相实施影响行动一事指出：“这是对国家安全的威胁，也动摇民主制度的根基，应尽快采取对策。”他还指出，“外国实施影响行动的情况在多个国家都有发生”，并表示将加强对影响行动的情报收集与分析能力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260227-%E6%97%A5%E6%9C%AC%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E6%8C%87%E4%B8%AD%E5%9B%BD%E5%88%A9%E7%94%A8ai%E8%B4%AC%E6%8D%9F%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E5%A8%81%E8%83%81%E5%9B%BD%E5%AE%B6%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772183498000.webp","sourceId":"rfi"},{"id":1772183423000,"createdDate":"2026-02-27 09:10","name":"法国国际广播电台","title":"涉“神韵”演出 澳大利亚总理官邸遭炸弹威胁短暂疏散","content":"法新社报道，涉法轮功艺术团“神韵”的在澳演出，澳大利亚总理阿尔巴尼斯在堪培拉的官邸本周因相关安全警报临时疏散。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260227-%E6%B6%89-%E7%A5%9E%E9%9F%B5-%E6%BC%94%E5%87%BA-%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E6%80%BB%E7%90%86%E5%AE%98%E9%82%B8%E9%81%AD%E7%82%B8%E5%BC%B9%E5%A8%81%E8%83%81%E7%9F%AD%E6%9A%82%E7%96%8F%E6%95%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772183423000.webp","sourceId":"rfi"},{"id":1772183198000,"createdDate":"2026-02-27 09:06","name":"法国国际广播电台","title":"美国、日本和菲律宾在台湾附近举行联合军演","content":"菲律宾军方周五（2月27日）宣布，美国、日本和菲律宾本周在巴士海峡附近举行了联合空中与海上演习。巴士海峡是分隔台湾与菲律宾并且具有重要战略意义的海上通道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260227-%E7%BE%8E%E5%9B%BD-%E6%97%A5%E6%9C%AC%E5%92%8C%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%9C%A8%E5%8F%B0%E6%B9%BE%E9%99%84%E8%BF%91%E4%B8%BE%E8%A1%8C%E8%81%94%E5%90%88%E5%86%9B%E6%BC%94","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772183198000.webp","sourceId":"rfi"}]