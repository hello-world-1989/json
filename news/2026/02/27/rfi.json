[{"id":1772181644000,"createdDate":"2026-02-27 08:40","name":"法国国际广播电台","title":"巴基斯坦向阿富汗宣战，中国称“冲突烈度超过以往”并呼吁尽快停火","content":"巴基斯坦政府周五（2月27日）在阿富汗前一日于边境发动攻势后，向阿富汗塔利班政权宣布进入“公开战争”状态。作为报复，巴基斯坦对包括首都在内的多处阿富汗目标实施轰炸。中国表达关切。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%90%91%E9%98%BF%E5%AF%8C%E6%B1%97%E5%AE%A3%E6%88%98%EF%BC%8C%E4%B8%AD%E5%9B%BD%E7%A7%B0-%E5%86%B2%E7%AA%81%E7%83%88%E5%BA%A6%E8%B6%85%E8%BF%87%E4%BB%A5%E5%BE%80-%E5%B9%B6%E5%91%BC%E5%90%81%E5%B0%BD%E5%BF%AB%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772181644000.webp","sourceId":"rfi"},{"id":1772179810000,"createdDate":"2026-02-27 08:10","name":"法国国际广播电台","title":"未受升空失利影响 中国维持2030年前踏足月球 港澳航天员最快今年飞天","content":"中国近几个月的火箭升空出现至少五次失利，但载人航天工程办公室(下称航天办)表明，仍会以2030年前实现中国人首次登陆月球为目标，而今年将会进行两次载人飞行任务和一次货运飞船补给任务，来自港澳地区的航天员有望最早今年执行飞行任务，与航天办官员早前宣布港澳航天员首次参与孩行的时间表一致。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260227-%E6%9C%AA%E5%8F%97%E5%8D%87%E7%A9%BA%E5%A4%B1%E5%88%A9%E5%BD%B1%E5%93%8D-%E4%B8%AD%E5%9B%BD%E7%BB%B4%E6%8C%812030%E5%B9%B4%E5%89%8D%E8%B8%8F%E8%B6%B3%E6%9C%88%E7%90%83-%E6%B8%AF%E6%BE%B3%E8%88%AA%E5%A4%A9%E5%91%98%E6%9C%80%E5%BF%AB%E4%BB%8A%E5%B9%B4%E9%A3%9E%E5%A4%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772179810000.webp","sourceId":"rfi"},{"id":1772208137000,"createdDate":"2026-02-27 16:02","name":"法国国际广播电台","title":"联合国批评中国：未能充分采取行动改善新疆地区维吾尔族人的处境","content":"联合国人权事务高级专员沃尔克·图尔克(VolkerTürk)27日批评中国未能充分采取行动，改善新疆地区维吾尔族人的处境。这一谴责距离联合国发布一份针对新疆措辞严厉的人权报告已过去三年多。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E8%81%94%E5%90%88%E5%9B%BD%E6%89%B9%E8%AF%84%E4%B8%AD%E5%9B%BD-%E6%9C%AA%E8%83%BD%E5%85%85%E5%88%86%E9%87%87%E5%8F%96%E8%A1%8C%E5%8A%A8%E6%94%B9%E5%96%84%E6%96%B0%E7%96%86%E5%9C%B0%E5%8C%BA%E7%BB%B4%E5%90%BE%E5%B0%94%E6%97%8F%E4%BA%BA%E7%9A%84%E5%A4%84%E5%A2%83","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772208137000.webp","sourceId":"rfi"},{"id":1772207159000,"createdDate":"2026-02-27 15:45","name":"法国国际广播电台","title":"德黑兰警告华盛顿必须放弃“过分的要求”, 关于伊朗核计划的技术磋商下周在维也纳举行","content":"据法新社周五看到的一份机密报告显示，国际原子能机构周五证实，关于伊朗核计划的技术磋商将于2026年3月2日开始的那一周在维也纳举行。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260227-%E5%BE%B7%E9%BB%91%E5%85%B0%E8%AD%A6%E5%91%8A%E5%8D%8E%E7%9B%9B%E9%A1%BF%E5%BF%85%E9%A1%BB%E6%94%BE%E5%BC%83-%E8%BF%87%E5%88%86%E7%9A%84%E8%A6%81%E6%B1%82-%E5%85%B3%E4%BA%8E%E4%BC%8A%E6%9C%97%E6%A0%B8%E8%AE%A1%E5%88%92%E7%9A%84%E6%8A%80%E6%9C%AF%E7%A3%8B%E5%95%86%E4%B8%8B%E5%91%A8%E5%9C%A8%E7%BB%B4%E4%B9%9F%E7%BA%B3%E4%B8%BE%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772207159000.webp","sourceId":"rfi"},{"id":1772203601000,"createdDate":"2026-02-27 14:46","name":"法国国际广播电台","title":"视频 爱泼斯坦案：希拉里·克林顿在听证会上辩护","content":"美国前总统比尔·克林顿本周五接受美国国会质询，此前克林顿夫妇最初拒绝出席听证会，但最终迫于起诉压力做出让步。在美国国会的第一轮问答环节结束后，希拉里克林顿这位前总统候选人谴责听证会的成员，称其偏袒共和党，并为她的丈夫辩护，请看France24记者埃米莉·缪塞的报道","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E8%A7%86%E9%A2%91-%E7%88%B1%E6%B3%BC%E6%96%AF%E5%9D%A6%E6%A1%88-%E5%B8%8C%E6%8B%89%E9%87%8C%C2%B7%E5%85%8B%E6%9E%97%E9%A1%BF%E5%9C%A8%E5%90%AC%E8%AF%81%E4%BC%9A%E4%B8%8A%E8%BE%A9%E6%8A%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772203601000.webp","sourceId":"rfi"},{"id":1772203323000,"createdDate":"2026-02-27 14:42","name":"法国国际广播电台","title":"视频 巴基斯坦与阿富汗军事行动升级","content":"巴基斯坦官员称，巴基斯坦于周四晚至周五凌晨对阿富汗主要城市的目标发动了空袭，两国之间的军事行动正在升级，请看France24报道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260227-%E8%A7%86%E9%A2%91-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E4%B8%8E%E9%98%BF%E5%AF%8C%E6%B1%97%E5%86%9B%E4%BA%8B%E8%A1%8C%E5%8A%A8%E5%8D%87%E7%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772203323000.webp","sourceId":"rfi"},{"id":1772202595000,"createdDate":"2026-02-27 14:29","name":"法国国际广播电台","title":"中国宣布自3月1日起暂时取消对部分加拿大产品的反歧视关税","content":"北京周五（2月27日）宣布，根据加拿大总理卡尼今年1月访华期间达成的协议，将自3月1日起暂时取消对部分加拿大产品征收的部分关税。这一声明是在加拿大放宽针对中国电动汽车和钢铁产品所采取措施之后作出的。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E4%B8%AD%E5%9B%BD%E5%AE%A3%E5%B8%83%E8%87%AA3%E6%9C%881%E6%97%A5%E8%B5%B7%E6%9A%82%E6%97%B6%E5%8F%96%E6%B6%88%E5%AF%B9%E9%83%A8%E5%88%86%E5%8A%A0%E6%8B%BF%E5%A4%A7%E4%BA%A7%E5%93%81%E7%9A%84%E5%8F%8D%E6%AD%A7%E8%A7%86%E5%85%B3%E7%A8%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772202595000.webp","sourceId":"rfi"},{"id":1772200975000,"createdDate":"2026-02-27 14:02","name":"法国国际广播电台","title":"刚果(金):在战乱中坚持的出版商","content":"法国国际广播电台（RadioFranceInternationale）中文节目[法语世界]（Chroniquefrancophonie）专栏2026年02月27日星期五第145集播出本台法广(RFI)法语栏目[非洲大咖嘉宾]（LeGrandInvitéAfrique）专栏记者奥利维耶（OlivierR）对到访巴黎的刚果民主共和国（RDCongo）出版人吉斯兰（GhislainKabuyaya）的采访录音片段。这位来自非洲法语大国的文化人，目前生活在处于战乱中的刚果（金）东部地区北基伍省的戈马城（Goma）。这集节目由尼古拉编译和播报，感谢收听。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C/20260227-%E6%B3%95%E5%B9%BFrfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C-%E7%AC%AC145%E9%9B%86-%E5%88%9A%E6%9E%9C-%E9%87%91-%E5%9C%A8%E6%88%98%E4%B9%B1%E4%B8%AD%E5%9D%9A%E6%8C%81%E7%9A%84%E5%87%BA%E7%89%88%E5%95%86","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772200975000.webp","sourceId":"rfi"},{"id":1772193622000,"createdDate":"2026-02-27 12:00","name":"法国国际广播电台","title":"中美同步发出警告：美国呼吁非必要人员离开以色列 中国敦促公民尽快撤离伊朗","content":"美国周五（2月27日）建议驻耶路撒冷大使馆的非必要人员离开以色列，此举是在美国威胁对伊朗进行军事打击的背景下，令地区紧张局势加剧。与此同时，中国也敦促公民尽快离开伊朗。而据中央社援引ABC消息，掌管美国在中东部队的美军中央司令部司令古柏今天向特朗普简报在伊朗可能采取的军事选项。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E4%B8%AD%E7%BE%8E%E5%90%8C%E6%AD%A5%E5%8F%91%E5%87%BA%E8%AD%A6%E5%91%8A-%E7%BE%8E%E5%9B%BD%E5%91%BC%E5%90%81%E9%9D%9E%E5%BF%85%E8%A6%81%E4%BA%BA%E5%91%98%E7%A6%BB%E5%BC%80%E4%BB%A5%E8%89%B2%E5%88%97-%E4%B8%AD%E5%9B%BD%E6%95%A6%E4%BF%83%E5%85%AC%E6%B0%91%E5%B0%BD%E5%BF%AB%E7%A6%BB%E5%BC%80%E4%BC%8A%E6%9C%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772193622000.webp","sourceId":"rfi"},{"id":1772192232000,"createdDate":"2026-02-27 11:37","name":"法国国际广播电台","title":"加印关系持续改善：加拿大总理卡尼抵达印度 寄望两国贸易额到2030年实现翻番","content":"据印度媒体报道，加拿大总理马克·卡尼周五（2月27日）抵达印度，他希望借此机会将双边贸易额翻一番，同时弥补与美国关系恶化带来的影响。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E5%8A%A0%E5%8D%B0%E5%85%B3%E7%B3%BB%E6%8C%81%E7%BB%AD%E6%94%B9%E5%96%84-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E6%80%BB%E7%90%86%E5%8D%A1%E5%B0%BC%E6%8A%B5%E8%BE%BE%E5%8D%B0%E5%BA%A6-%E5%AF%84%E6%9C%9B%E4%B8%A4%E5%9B%BD%E8%B4%B8%E6%98%93%E9%A2%9D%E5%88%B02030%E5%B9%B4%E5%AE%9E%E7%8E%B0%E7%BF%BB%E7%95%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772192232000.webp","sourceId":"rfi"},{"id":1772186239000,"createdDate":"2026-02-27 09:57","name":"法国国际广播电台","title":"俄罗斯宣布在扎波罗热核电站周边实施局部停火","content":"俄罗斯官员表示，为修复一条外部输电线路，乌克兰扎波罗热核电站附近周五起实施局部停火。俄罗斯军队在2022年2月对乌克兰发动全面入侵的最初几周内占领了扎波罗热核电站。该核电站是欧洲规模最大的核电站。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E4%BF%84%E7%BD%97%E6%96%AF%E5%AE%A3%E5%B8%83%E5%9C%A8%E6%89%8E%E6%B3%A2%E7%BD%97%E7%83%AD%E6%A0%B8%E7%94%B5%E7%AB%99%E5%91%A8%E8%BE%B9%E5%AE%9E%E6%96%BD%E5%B1%80%E9%83%A8%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772186239000.webp","sourceId":"rfi"},{"id":1772185572000,"createdDate":"2026-02-27 09:46","name":"法国国际广播电台","title":"争议多年后，韩国终于同意与谷歌地图共享数据","content":"综合法新社与美联社消息，韩国政府周五（2月27日）表示，将在满足特定安全要求的前提下，允许谷歌把韩国的高精度地图数据传输至海外服务器。此举回应了多年来外国游客的不满，他们抱怨谷歌地图在韩国无法有效使用。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E4%BA%89%E8%AE%AE%E5%A4%9A%E5%B9%B4%E5%90%8E%EF%BC%8C%E9%9F%A9%E5%9B%BD%E7%BB%88%E4%BA%8E%E5%90%8C%E6%84%8F%E4%B8%8E%E8%B0%B7%E6%AD%8C%E5%9C%B0%E5%9B%BE%E5%85%B1%E4%BA%AB%E6%95%B0%E6%8D%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772185572000.webp","sourceId":"rfi"},{"id":1772184795000,"createdDate":"2026-02-27 09:33","name":"法国国际广播电台","title":"伊朗警告美国不要在谈判中提出“任何过分要求”","content":"伊朗外交部长阿巴斯·阿拉格齐周五（2月27日）警告美国，在双方谈判中不要提出“任何过分要求”。此前一天，双方在日内瓦举行新一轮会谈后曾表现出一定乐观态度，伊朗方面表示，这些间接会谈将在未来几天继续进行。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E4%BC%8A%E6%9C%97%E8%AD%A6%E5%91%8A%E7%BE%8E%E5%9B%BD%E4%B8%8D%E8%A6%81%E5%9C%A8%E8%B0%88%E5%88%A4%E4%B8%AD%E6%8F%90%E5%87%BA-%E4%BB%BB%E4%BD%95%E8%BF%87%E5%88%86%E8%A6%81%E6%B1%82","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772184795000.webp","sourceId":"rfi"},{"id":1772184186000,"createdDate":"2026-02-27 09:23","name":"法国国际广播电台","title":"高市加紧推动国防改革 已批准建设情报机构提升“海外情报收集能力”","content":"日本首相高市早苗所属的执政党自民党已批准一项方案，旨在加强国家情报能力。一名党内负责人周五（2月27日）表示，此举正值高市推动国防政策重大改革之际。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E9%AB%98%E5%B8%82%E5%8A%A0%E7%B4%A7%E6%8E%A8%E5%8A%A8%E5%9B%BD%E9%98%B2%E6%94%B9%E9%9D%A9-%E5%B7%B2%E6%89%B9%E5%87%86%E5%BB%BA%E8%AE%BE%E6%83%85%E6%8A%A5%E6%9C%BA%E6%9E%84%E6%8F%90%E5%8D%87-%E6%B5%B7%E5%A4%96%E6%83%85%E6%8A%A5%E6%94%B6%E9%9B%86%E8%83%BD%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772184186000.webp","sourceId":"rfi"},{"id":1772183498000,"createdDate":"2026-02-27 09:11","name":"法国国际广播电台","title":"日本官房长官指中国利用AI贬损高市首相威胁国家安全","content":"日本内阁官房长官木原稔在27日的记者会上表示，针对美国OpenAI发布声明称，中国当局相关人员曾使用其对话式生成式人工智能（AI）“ChatGPT”，试图对高市早苗首相实施影响行动一事指出：“这是对国家安全的威胁，也动摇民主制度的根基，应尽快采取对策。”他还指出，“外国实施影响行动的情况在多个国家都有发生”，并表示将加强对影响行动的情报收集与分析能力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260227-%E6%97%A5%E6%9C%AC%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E6%8C%87%E4%B8%AD%E5%9B%BD%E5%88%A9%E7%94%A8ai%E8%B4%AC%E6%8D%9F%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E5%A8%81%E8%83%81%E5%9B%BD%E5%AE%B6%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772183498000.webp","sourceId":"rfi"},{"id":1772183423000,"createdDate":"2026-02-27 09:10","name":"法国国际广播电台","title":"涉“神韵”演出 澳大利亚总理官邸遭炸弹威胁短暂疏散","content":"法新社报道，涉法轮功艺术团“神韵”的在澳演出，澳大利亚总理阿尔巴尼斯在堪培拉的官邸本周因相关安全警报临时疏散。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260227-%E6%B6%89-%E7%A5%9E%E9%9F%B5-%E6%BC%94%E5%87%BA-%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E6%80%BB%E7%90%86%E5%AE%98%E9%82%B8%E9%81%AD%E7%82%B8%E5%BC%B9%E5%A8%81%E8%83%81%E7%9F%AD%E6%9A%82%E7%96%8F%E6%95%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772183423000.webp","sourceId":"rfi"},{"id":1772183198000,"createdDate":"2026-02-27 09:06","name":"法国国际广播电台","title":"美国、日本和菲律宾在台湾附近举行联合军演","content":"菲律宾军方周五（2月27日）宣布，美国、日本和菲律宾本周在巴士海峡附近举行了联合空中与海上演习。巴士海峡是分隔台湾与菲律宾并且具有重要战略意义的海上通道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260227-%E7%BE%8E%E5%9B%BD-%E6%97%A5%E6%9C%AC%E5%92%8C%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%9C%A8%E5%8F%B0%E6%B9%BE%E9%99%84%E8%BF%91%E4%B8%BE%E8%A1%8C%E8%81%94%E5%90%88%E5%86%9B%E6%BC%94","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772183198000.webp","sourceId":"rfi"},{"id":1772226556000,"createdDate":"2026-02-27 21:09","name":"法国国际广播电台","title":"美AI新创公司Anthropic不同意战争部不受限使用其AI技术","content":"美国人工智能（AI）新创公司Anthropic27日表示，尽管五角大厦施压，但该公司仍不同意美国战争部不受限制地使用其AI技术。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260227-%E7%BE%8Eai%E6%96%B0%E5%88%9B%E5%85%AC%E5%8F%B8anthropic%E4%B8%8D%E5%90%8C%E6%84%8F%E6%88%98%E4%BA%89%E9%83%A8%E4%B8%8D%E5%8F%97%E9%99%90%E4%BD%BF%E7%94%A8%E5%85%B6ai%E6%8A%80%E6%9C%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772226556000.webp","sourceId":"rfi"},{"id":1772225977000,"createdDate":"2026-02-27 20:59","name":"法国国际广播电台","title":"中东局势愈发紧张      法国建议其公民避免前往以色列","content":"美方近期持续对伊朗施加军事压力，向中东集结兵力，局势还在升级。法国外交部周五在其网站上发布消息称，“鉴于伊朗的安全局势及其潜在影响”，法国建议其公民不要前往“以色列、耶路撒冷和约旦河西岸地区，包括旅游和探亲”。周五晚间从伊斯坦布尔机场飞往德黑兰的航班全部取消。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260227-%E4%B8%AD%E4%B8%9C%E5%B1%80%E5%8A%BF%E6%84%88%E5%8F%91%E7%B4%A7%E5%BC%A0-%E6%B3%95%E5%9B%BD%E5%BB%BA%E8%AE%AE%E5%85%B6%E5%85%AC%E6%B0%91%E9%81%BF%E5%85%8D%E5%89%8D%E5%BE%80%E4%BB%A5%E8%89%B2%E5%88%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772225977000.webp","sourceId":"rfi"},{"id":1772225750000,"createdDate":"2026-02-27 20:55","name":"法国国际广播电台","title":"加拿大总理马克·卡尼访问印度","content":"加拿大总理马克·卡尼于周五开始访问印度，他希望此行能使加印贸易额翻一番，并缓解与美国日益恶化的关系。卡尼将于周一在新德里与印度总理纳伦德拉·莫迪会晤，他的目标是到2030年将加印贸易额提高一倍以上，达到700亿加元（约合430亿欧元）。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260227-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E6%80%BB%E7%90%86%E9%A9%AC%E5%85%8B%C2%B7%E5%8D%A1%E5%B0%BC%E8%AE%BF%E9%97%AE%E5%8D%B0%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772225750000.webp","sourceId":"rfi"},{"id":1772225459000,"createdDate":"2026-02-27 20:50","name":"法国国际广播电台","title":"巴基斯坦“公开宣战”      轰炸喀布尔","content":"联合国秘书长安东尼奥·古特雷斯（AntonioGuterres）周五呼吁阿富汗和巴基斯坦之间“立即停止敌对行动”。此前阿富汗在边境发动攻势，巴基斯坦已向其邻国宣战。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260227-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6-%E5%85%AC%E5%BC%80%E5%AE%A3%E6%88%98-%E8%BD%B0%E7%82%B8%E5%96%80%E5%B8%83%E5%B0%94","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772225459000.webp","sourceId":"rfi"},{"id":1772225212000,"createdDate":"2026-02-27 20:46","name":"法国国际广播电台","title":"沙特和卡塔尔正努力缓和阿富汗-巴基斯坦冲突","content":"沙特阿拉伯和卡塔尔正在加紧外交努力，以结束巴基斯坦和阿富汗之间致命的冲突。周五，巴基斯坦轰炸了包括首都喀布尔在内的几个阿富汗主要城市。此前一天，阿富汗军队在其边境发动攻势，巴基斯坦政府随即宣布对塔利班“公开宣战”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260227-%E6%B2%99%E7%89%B9%E5%92%8C%E5%8D%A1%E5%A1%94%E5%B0%94%E6%AD%A3%E5%8A%AA%E5%8A%9B%E7%BC%93%E5%92%8C%E9%98%BF%E5%AF%8C%E6%B1%97-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%86%B2%E7%AA%81","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772225212000.webp","sourceId":"rfi"},{"id":1772225076000,"createdDate":"2026-02-27 20:44","name":"法国国际广播电台","title":"比尔·克林顿：对爱泼斯坦犯下的罪行“一无所知”","content":"在国会委员会就其与杰弗里·爱泼斯坦的关系进行质询时，美国前总统比尔·克林顿（BillClinton）周五在闭门听证会上表示，在他与爱波斯坦相处的这段时间里，他“没有看到任何令他感到不安的事情”。克林顿在事先准备好的发言稿中告诉众议院监督委员会，如果他知道爱泼斯坦的犯罪活动，他绝不会登上爱泼斯坦的私人飞机。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260227-%E6%AF%94%E5%B0%94%C2%B7%E5%85%8B%E6%9E%97%E9%A1%BF-%E5%AF%B9%E7%88%B1%E6%B3%BC%E6%96%AF%E5%9D%A6%E7%8A%AF%E4%B8%8B%E7%9A%84%E7%BD%AA%E8%A1%8C-%E4%B8%80%E6%97%A0%E6%89%80%E7%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772225076000.webp","sourceId":"rfi"},{"id":1772224931000,"createdDate":"2026-02-27 20:42","name":"法国国际广播电台","title":"以色列：暂缓遣返面临撤离加沙的救援组织","content":"以色列最高法院周五暂缓了外国人道主义非政府组织的行动。这些非政府组织此前因拒绝遵守以色列政府要求其留在加沙地带和被占领的约旦河西岸而面临本周末被驱逐的威胁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260227-%E4%BB%A5%E8%89%B2%E5%88%97-%E6%9A%82%E7%BC%93%E9%81%A3%E8%BF%94%E9%9D%A2%E4%B8%B4%E6%92%A4%E7%A6%BB%E5%8A%A0%E6%B2%99%E7%9A%84%E6%95%91%E6%8F%B4%E7%BB%84%E7%BB%87","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772224931000.webp","sourceId":"rfi"},{"id":1772224712000,"createdDate":"2026-02-27 20:38","name":"法国国际广播电台","title":"网络攻击使1500万法国患者个人资料泄露","content":"软件发行商2月27日宣布，2025年底，法国1500名医生遭到网络攻击，导致患者个人数据泄露。法国卫生部估计，约有1500万人受到影响。据CegedimSanté公司称，该公司发行的MLM软件在法国被3800名医生使用，其中1500名医生在2025年底遭遇网络攻击，当时发现“应用程序请求行为异常”。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260227-%E7%BD%91%E7%BB%9C%E6%94%BB%E5%87%BB%E4%BD%BF1500%E4%B8%87%E6%B3%95%E5%9B%BD%E6%82%A3%E8%80%85%E4%B8%AA%E4%BA%BA%E8%B5%84%E6%96%99%E6%B3%84%E9%9C%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772224712000.webp","sourceId":"rfi"},{"id":1772224444000,"createdDate":"2026-02-27 20:34","name":"法国国际广播电台","title":"美国OpenAI披露：北京使用ChatGPT进行秘密镇压","content":"美国人工智能研发公司OpenAI在2月最新报告中披露：北京如何利用海外的人工智能（AI）工具，从事跨国镇压等损害西方社会的活动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260227-%E7%BE%8E%E5%9B%BDopenai%E6%8A%AB%E9%9C%B2-chatgpt%E6%88%90%E5%8C%97%E4%BA%AC%E7%A7%98%E5%AF%86%E9%95%87%E5%8E%8B%E5%B7%A5%E5%85%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772224444000.webp","sourceId":"rfi"},{"id":1772223490000,"createdDate":"2026-02-27 20:18","name":"法国国际广播电台","title":"特朗普称不排除“友好接管”古巴的可能性","content":"美国总统特朗普（DonaldTrump）周五告诉媒体，不排除对古巴进行“友好接管”的可能性，并透露古巴政府正与美方展开高层对话。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260227-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E4%B8%8D%E6%8E%92%E9%99%A4-%E5%8F%8B%E5%A5%BD%E6%8E%A5%E7%AE%A1-%E5%8F%A4%E5%B7%B4%E7%9A%84%E5%8F%AF%E8%83%BD%E6%80%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772223490000.webp","sourceId":"rfi"},{"id":1772215785000,"createdDate":"2026-02-27 18:09","name":"法国国际广播电台","title":"台湾纪念2.28 仍陷争议与对立","content":"明年就是台湾228事件80周年，对于1947年发生的官民冲突以及流血镇压事件，台湾社会至今仍旧陷入由于政治立场不同，而有不同的叙事。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260227-%E5%8F%B0%E6%B9%BE%E7%BA%AA%E5%BF%B52-28-%E4%BB%8D%E9%99%B7%E4%BA%89%E8%AE%AE%E4%B8%8E%E5%AF%B9%E7%AB%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772215785000.webp","sourceId":"rfi"},{"id":1772206364000,"createdDate":"2026-02-27 15:32","name":"法国国际广播电台","title":"克林顿夫妇赴国会闭门作证　希拉里称对爱泼斯坦案“毫不知情”","content":"前国务卿希拉里·克林顿（HillaryClinton）26日接受美国众议院监督委员会闭门取证时明确表示，她对已故性侵案富商爱泼斯坦（JeffreyEpstein）及其同伙麦克斯韦（GhislaineMaxwell）的犯罪行为“毫不知情”，并强烈批评共和党主导的调查具有党派动机。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260227-%E5%85%8B%E6%9E%97%E9%A1%BF%E5%A4%AB%E5%A6%87%E8%B5%B4%E5%9B%BD%E4%BC%9A%E9%97%AD%E9%97%A8%E4%BD%9C%E8%AF%81-%E5%B8%8C%E6%8B%89%E9%87%8C%E7%A7%B0%E5%AF%B9%E7%88%B1%E6%B3%BC%E6%96%AF%E5%9D%A6%E6%A1%88-%E6%AF%AB%E4%B8%8D%E7%9F%A5%E6%83%85","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772206364000.webp","sourceId":"rfi"},{"id":1772203926000,"createdDate":"2026-02-27 14:52","name":"法国国际广播电台","title":"巴基斯坦宣布对阿富汗展开“公开战争”  周边国家呼吁局势尽快降温","content":"巴基斯坦与阿富汗边境紧张局势急剧升级。在阿富汗前一天对巴方边境哨所攻击之后，巴基斯坦军队周五（2月27日）凌晨空袭了阿方在喀布尔、坎大哈省和帕克蒂亚省的重要军事设施。巴勒斯坦国防部长宣布，对阿富汗塔利班当局展开“公开战争”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260227-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%AE%A3%E5%B8%83%E5%AF%B9%E9%98%BF%E5%AF%8C%E6%B1%97%E5%B1%95%E5%BC%80-%E5%85%AC%E5%BC%80%E6%88%98%E4%BA%89-%E5%91%A8%E8%BE%B9%E5%9B%BD%E5%AE%B6%E5%91%BC%E5%90%81%E5%B1%80%E5%8A%BF%E5%B0%BD%E5%BF%AB%E9%99%8D%E6%B8%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/27/1772203926000.webp","sourceId":"rfi"}]