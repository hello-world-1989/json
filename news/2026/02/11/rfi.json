[{"id":1770797711000,"createdDate":"2026-02-11 08:15","name":"法国国际广播电台","title":"王志安质疑陈光诚是否为盲人案在东京开庭 陈光诚律师表达胜诉信心","content":"中国人权活动家陈光诚先生以名誉权受到侵害为由，将原中国中央电视台（CCTV）记者、现为网络媒体活动者的王志安告上日本东京地方法院，提起损害赔偿诉讼。索赔金额为3亿3千万日元。本案已被受理，并于2026年2月10日下午1时10分（东京时间）在第612号法庭开庭审理，原告方律师出庭，被告与其律师均没有出庭，下次审理定于4月7日在网络上举行。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260211-%E7%8E%8B%E5%BF%97%E5%AE%89%E8%B4%A8%E7%96%91%E9%99%88%E5%85%89%E8%AF%9A%E6%98%AF%E5%90%A6%E4%B8%BA%E7%9B%B2%E4%BA%BA%E6%A1%88%E5%9C%A8%E4%B8%9C%E4%BA%AC%E5%BC%80%E5%BA%AD-%E9%99%88%E5%85%89%E8%AF%9A%E5%BE%8B%E5%B8%88%E8%A1%A8%E8%BE%BE%E8%83%9C%E8%AF%89%E4%BF%A1%E5%BF%83","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770797711000.webp","sourceId":"rfi"},{"id":1770797185000,"createdDate":"2026-02-11 08:06","name":"法国国际广播电台","title":"首例：在港老父为流亡海外女儿处理保险 裁定罪犯国安 评论称打压升级 吁阻止","content":"因协助在海外被香港警方国安处通缉的女儿郭凤仪处理保险单的郭贤生，被裁定「企图处理潜逃者财产罪」罪名成立，成为首宗海外遭通缉人士的在港家人被国安法律定罪个案。两个国际人权组织认为，裁决举标志港府滥用法例打压异见行动升级，令人不安；强调这种「连坐」家人的手法，有违国际人权法，呼吁各国政府采取行动阻止北京这种长臂管豁。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260211-%E9%A6%96%E4%BE%8B-%E5%9C%A8%E6%B8%AF%E8%80%81%E7%88%B6%E4%B8%BA%E6%B5%81%E4%BA%A1%E6%B5%B7%E5%A4%96%E5%A5%B3%E5%84%BF%E5%A4%84%E7%90%86%E4%BF%9D%E9%99%A9-%E8%A3%81%E5%AE%9A%E7%BD%AA%E7%8A%AF%E5%9B%BD%E5%AE%89-%E8%AF%84%E8%AE%BA%E7%A7%B0%E6%89%93%E5%8E%8B%E5%8D%87%E7%BA%A7-%E5%90%81%E9%98%BB%E6%AD%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770797185000.webp","sourceId":"rfi"},{"id":1770796189000,"createdDate":"2026-02-11 07:49","name":"法国国际广播电台","title":"白宫不就营救黎智英表态 评论指只有美国有能力营救 但机会甚微","content":"香港传媒大亨黎智英被港府重囚20年，震惊欧美，不少网民认为，判刑後可开展拯救工作，更有人直言，还看美国总统特朗普；英国《泰晤士报》亦发社论表示，若黎智英承诺停止批评北京，可能获得释放。熟悉中国事务的评论员程翔亦认为，现在只有美国可以有实力从中国手中营救黎智英出狱，但预料机会甚微。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260211-%E7%99%BD%E5%AE%AB%E4%B8%8D%E5%B0%B1%E8%90%A5%E6%95%91%E9%BB%8E%E6%99%BA%E8%8B%B1%E8%A1%A8%E6%80%81-%E8%AF%84%E8%AE%BA%E6%8C%87%E5%8F%AA%E6%9C%89%E7%BE%8E%E5%9B%BD%E6%9C%89%E8%83%BD%E5%8A%9B%E8%90%A5%E6%95%91-%E4%BD%86%E6%9C%BA%E4%BC%9A%E7%94%9A%E5%BE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770796189000.webp","sourceId":"rfi"},{"id":1770828704000,"createdDate":"2026-02-11 16:51","name":"法国国际广播电台","title":"加拿大西部小镇发生校园枪击案 至少10人死亡25人受伤","content":"当地时间周二(2月10日)下午，加拿大不列颠哥伦比亚省（BC省）中部小镇坦布勒里岭（TumblerRidge）发生一起严重校园枪击事件，包括枪手在内至少10人死亡、25人受伤，其中2人伤势严重。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E4%B8%AD%E8%A5%BF%E9%83%A8%E5%B0%8F%E9%95%87%E5%8F%91%E7%94%9F%E6%A0%A1%E5%9B%AD%E6%9E%AA%E5%87%BB%E6%A1%88-%E8%87%B3%E5%B0%9110%E4%BA%BA%E6%AD%BB%E4%BA%A125%E4%BA%BA%E5%8F%97%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770828704000.webp","sourceId":"rfi"},{"id":1770823880000,"createdDate":"2026-02-11 15:31","name":"法国国际广播电台","title":"美国在孟加拉国采取行动对抗中国","content":"孟加拉国2月12日举行议会选举前夕，路透社发自达卡独家消息称，美国对中国在南亚影响力不断扩大表示担忧，计划向孟加拉国下一届政府提供美国及其盟友的防务系统，作为中国军事装备的替代方案。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260211-%E7%BE%8E%E5%9B%BD%E5%9C%A8%E5%AD%9F%E5%8A%A0%E6%8B%89%E5%9B%BD%E9%87%87%E5%8F%96%E8%A1%8C%E5%8A%A8%E5%AF%B9%E6%8A%97%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770823880000.webp","sourceId":"rfi"},{"id":1770823692000,"createdDate":"2026-02-11 15:28","name":"法国国际广播电台","title":"视频 佛教僧侣完成“和平游行”徒步穿越美国","content":"在当前国际地缘政治动荡紧张的局势下，一些人选择步行穿越美国传播和平的信息。去年十月20多位佛教僧侣从德克萨斯州出发，现在已抵达华盛顿。许多人到场迎接他们完成这段旅程的最后一程，他们的到来引发了公众的极大热情，请看France24视频。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260211-%E8%A7%86%E9%A2%91-%E4%BD%9B%E6%95%99%E5%83%A7%E4%BE%A3%E5%AE%8C%E6%88%90-%E5%92%8C%E5%B9%B3%E6%B8%B8%E8%A1%8C-%E5%BE%92%E6%AD%A5%E7%A9%BF%E8%B6%8A%E7%BE%8E%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770823692000.webp","sourceId":"rfi"},{"id":1770814311000,"createdDate":"2026-02-11 12:51","name":"法国国际广播电台","title":"台湾总统雄心勃勃的国防预算摆脱政治僵局","content":"台湾议会在一个反对党于周三改变态度后，终于将审议赖清德总统提出的2026年国防预算案。此前，该预算案因立法僵局已被拖延两个月。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260211-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E9%9B%84%E5%BF%83%E5%8B%83%E5%8B%83%E7%9A%84%E5%9B%BD%E9%98%B2%E9%A2%84%E7%AE%97%E6%91%86%E8%84%B1%E6%94%BF%E6%B2%BB%E5%83%B5%E5%B1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770814311000.webp","sourceId":"rfi"},{"id":1770814011000,"createdDate":"2026-02-11 12:46","name":"法国国际广播电台","title":"两名中国公民被澳大利亚以涉嫌“外国干涉”罪起诉","content":"2月11日，澳大利亚以涉嫌“外国干涉”罪起诉两名中国公民，两人被控为中国政府安全机构秘密收集澳大利亚佛教团体的相关信息。中国外交部当天回应表示，中方从不干涉别国内政，敦促澳方审慎妥善处理案件，保障中国公民合法权益。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260211-%E4%B8%A4%E5%90%8D%E4%B8%AD%E5%9B%BD%E5%85%AC%E6%B0%91%E8%A2%AB%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E4%BB%A5%E6%B6%89%E5%AB%8C-%E5%A4%96%E5%9B%BD%E5%B9%B2%E6%B6%89-%E7%BD%AA%E8%B5%B7%E8%AF%89","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770814011000.webp","sourceId":"rfi"},{"id":1770812655000,"createdDate":"2026-02-11 12:24","name":"法国国际广播电台","title":"内塔尼亚胡与特朗普周三会面试图说服美国对伊朗采取更强硬立场","content":"美国总统特朗普与以色列总理内塔尼亚胡定于周三在华盛顿会面。内塔尼亚胡希望说服特朗普对德黑兰施加最大压力，以终止其核计划与弹道导弹计划。据特朗普之前告诉媒体，“我更愿意达成协议，一个没有核武，没有导弹的协议”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260211-%E5%86%85%E5%A1%94%E5%B0%BC%E4%BA%9A%E8%83%A1%E4%B8%8E%E7%89%B9%E6%9C%97%E6%99%AE%E5%91%A8%E4%B8%89%E4%BC%9A%E9%9D%A2%E8%AF%95%E5%9B%BE%E8%AF%B4%E6%9C%8D%E7%BE%8E%E5%9B%BD%E5%AF%B9%E4%BC%8A%E6%9C%97%E9%87%87%E5%8F%96%E6%9B%B4%E5%BC%BA%E7%A1%AC%E7%AB%8B%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770812655000.webp","sourceId":"rfi"},{"id":1770808991000,"createdDate":"2026-02-11 11:23","name":"法国国际广播电台","title":"视频 美国向伊朗施压 再扣一艘逃离的油轮","content":"美国战争部长海格塞斯证实，美军部队在印度洋成功拦截并登上一艘涉嫌违反制裁、运送委内瑞拉原油前往中国的油轮“阿奎拉二号”。请看France24视频报道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E8%A7%86%E9%A2%91-%E7%BE%8E%E5%9B%BD%E5%90%91%E4%BC%8A%E6%9C%97%E6%96%BD%E5%8E%8B-%E5%86%8D%E6%89%A3%E4%B8%80%E8%89%98%E9%80%83%E7%A6%BB%E7%9A%84%E6%B2%B9%E8%BD%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770808991000.webp","sourceId":"rfi"},{"id":1770808034000,"createdDate":"2026-02-11 11:07","name":"法国国际广播电台","title":"在中国电动卡车占比29%而法国仅2%：欧洲未来会将市场拱手让给中国制造商？","content":"据法国经济媒体《回声报》报道，中国正以惊人速度推进卡车电动化，而欧洲却犹豫不决。法国可持续交通与环境协会（T&EFrance）电动车行专家玛丽·谢龙（MarieChéron）对此警告称，这已不再是技术问题，而是关系到欧洲工业竞争力和经济主权的战略挑战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E5%9C%A8%E4%B8%AD%E5%9B%BD%E7%94%B5%E5%8A%A8%E5%8D%A1%E8%BD%A6%E5%8D%A0%E6%AF%9429-%EF%BC%8C%E8%80%8C%E6%B3%95%E5%9B%BD%E4%BB%852-%E6%AC%A7%E6%B4%B2%E6%9C%AA%E6%9D%A5%E4%BC%9A%E5%B0%86%E5%B8%82%E5%9C%BA%E6%8B%B1%E6%89%8B%E8%AE%A9%E7%BB%99%E4%B8%AD%E5%9B%BD%E5%88%B6%E9%80%A0%E5%95%86","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770808034000.webp","sourceId":"rfi"},{"id":1770806392000,"createdDate":"2026-02-11 10:39","name":"法国国际广播电台","title":"美中贸易战拖累法葡萄酒和烈酒出口，欧洲如何摆脱对美国的依赖...","content":"周三2月11日法国主要日报头版各有侧重，例如《费加罗报》指出法国公务员的人数不断增加；《解放报》则推出“欧洲如何摆脱对美国的依赖”的专题。与此同时，全球两大经济体——美国和中国，作为法国葡萄酒和烈酒行业在欧洲以外的主要市场，因关税壁垒和欧元走强，导致法国葡萄酒和烈酒出口下降了8%，这是《回声报》行业版的话题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260211-%E7%BE%8E%E4%B8%AD%E8%B4%B8%E6%98%93%E6%88%98%E6%8B%96%E7%B4%AF%E6%B3%95%E8%91%A1%E8%90%84%E9%85%92%E5%92%8C%E7%83%88%E9%85%92%E5%87%BA%E5%8F%A3%EF%BC%8C%E6%AC%A7%E6%B4%B2%E5%A6%82%E4%BD%95%E6%91%86%E8%84%B1%E5%AF%B9%E7%BE%8E%E5%9B%BD%E7%9A%84%E4%BE%9D%E8%B5%96","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770806392000.webp","sourceId":"rfi"},{"id":1770805089000,"createdDate":"2026-02-11 10:18","name":"法国国际广播电台","title":"黎智英遭重判20年再次证明一国两制名存实亡 台湾应以此警惕被中共统治的下场","content":"现年78岁的香港壹传媒集团创办人黎智英被香港高院重判20年有期徒刑，华尔街日报社论直言，这无异于判他死刑，香港如今牢牢受到中国铁腕掌控，北京已清楚向台湾传达，在中共统治底下的生活会是什么模样。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260211-%E9%BB%8E%E6%99%BA%E8%8B%B1%E9%81%AD%E9%87%8D%E5%88%A420%E5%B9%B4%E5%86%8D%E6%AC%A1%E8%AF%81%E6%98%8E%E4%B8%80%E5%9B%BD%E4%B8%A4%E5%88%B6%E5%90%8D%E5%AD%98%E5%AE%9E%E4%BA%A1-%E5%8F%B0%E6%B9%BE%E5%BA%94%E4%BB%A5%E6%AD%A4%E8%AD%A6%E6%83%95%E8%A2%AB%E4%B8%AD%E5%85%B1%E7%BB%9F%E6%B2%BB%E7%9A%84%E4%B8%8B%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770805089000.webp","sourceId":"rfi"},{"id":1770803920000,"createdDate":"2026-02-11 09:58","name":"法国国际广播电台","title":"北极安全：挪威警告俄罗斯威胁，英国增加驻军","content":"挪威军方近日警告，不能排除未来俄罗斯为保护其核武库而对挪威采取军事行动的可能性。与此同时，英国宣布将把驻挪威英军人数翻一番。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260211-%E5%8C%97%E6%9E%81%E5%AE%89%E5%85%A8-%E6%8C%AA%E5%A8%81%E8%AD%A6%E5%91%8A%E4%BF%84%E7%BD%97%E6%96%AF%E5%A8%81%E8%83%81%EF%BC%8C%E8%8B%B1%E5%9B%BD%E5%A2%9E%E5%8A%A0%E9%A9%BB%E5%86%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770803920000.webp","sourceId":"rfi"},{"id":1770802428000,"createdDate":"2026-02-11 09:33","name":"法国国际广播电台","title":"柬埔寨称已关闭近200个诈骗中心 打击跨国诈骗活动","content":"柬埔寨一位高级政府官员表示，柬埔寨最近几周在打击跨国诈骗的行动中关闭了近200个诈骗中心，当局罕见允许公众进入其中一个中心，以表明他们正在打击针对全球各地民众的复杂诈骗活动。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260211-%E6%9F%AC%E5%9F%94%E5%AF%A8%E7%A7%B0%E5%B7%B2%E5%85%B3%E9%97%AD%E8%BF%91200%E4%B8%AA%E8%AF%88%E9%AA%97%E4%B8%AD%E5%BF%83-%E6%89%93%E5%87%BB%E8%B7%A8%E5%9B%BD%E8%AF%88%E9%AA%97%E6%B4%BB%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770802428000.webp","sourceId":"rfi"},{"id":1770801803000,"createdDate":"2026-02-11 09:23","name":"法国国际广播电台","title":"洪都拉斯副总统表示将逐步与台湾恢复邦交，寻求对洪国最有利外交关系","content":"根据洪都拉斯（台湾称：宏都拉斯）媒体《论坛报》报导，洪国总统阿斯夫拉向特朗普明确表达正考虑将外交承认由中国转回台湾。第一副总统梅西亚也在随后证实，并表示将采取循序渐进的策略进行同时审视与中签署的16项协议。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260211-%E6%B4%AA%E9%83%BD%E6%8B%89%E6%96%AF%E5%89%AF%E6%80%BB%E7%BB%9F%E8%A1%A8%E7%A4%BA%E5%B0%86%E9%80%90%E6%AD%A5%E4%B8%8E%E5%8F%B0%E6%B9%BE%E6%81%A2%E5%A4%8D%E9%82%A6%E4%BA%A4%EF%BC%8C%E5%AF%BB%E6%B1%82%E5%AF%B9%E6%B4%AA%E5%9B%BD%E6%9C%80%E6%9C%89%E5%88%A9%E5%A4%96%E4%BA%A4%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770801803000.webp","sourceId":"rfi"}]