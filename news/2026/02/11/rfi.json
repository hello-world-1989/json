[{"id":1770797711000,"createdDate":"2026-02-11 08:15","name":"法国国际广播电台","title":"王志安质疑陈光诚是否为盲人案在东京开庭 陈光诚律师表达胜诉信心","content":"中国人权活动家陈光诚先生以名誉权受到侵害为由，将原中国中央电视台（CCTV）记者、现为网络媒体活动者的王志安告上日本东京地方法院，提起损害赔偿诉讼。索赔金额为3亿3千万日元。本案已被受理，并于2026年2月10日下午1时10分（东京时间）在第612号法庭开庭审理，原告方律师出庭，被告与其律师均没有出庭，下次审理定于4月7日在网络上举行。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260211-%E7%8E%8B%E5%BF%97%E5%AE%89%E8%B4%A8%E7%96%91%E9%99%88%E5%85%89%E8%AF%9A%E6%98%AF%E5%90%A6%E4%B8%BA%E7%9B%B2%E4%BA%BA%E6%A1%88%E5%9C%A8%E4%B8%9C%E4%BA%AC%E5%BC%80%E5%BA%AD-%E9%99%88%E5%85%89%E8%AF%9A%E5%BE%8B%E5%B8%88%E8%A1%A8%E8%BE%BE%E8%83%9C%E8%AF%89%E4%BF%A1%E5%BF%83","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770797711000.webp","sourceId":"rfi"},{"id":1770797185000,"createdDate":"2026-02-11 08:06","name":"法国国际广播电台","title":"首例：在港老父为流亡海外女儿处理保险 裁定罪犯国安 评论称打压升级 吁阻止","content":"因协助在海外被香港警方国安处通缉的女儿郭凤仪处理保险单的郭贤生，被裁定「企图处理潜逃者财产罪」罪名成立，成为首宗海外遭通缉人士的在港家人被国安法律定罪个案。两个国际人权组织认为，裁决举标志港府滥用法例打压异见行动升级，令人不安；强调这种「连坐」家人的手法，有违国际人权法，呼吁各国政府采取行动阻止北京这种长臂管豁。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260211-%E9%A6%96%E4%BE%8B-%E5%9C%A8%E6%B8%AF%E8%80%81%E7%88%B6%E4%B8%BA%E6%B5%81%E4%BA%A1%E6%B5%B7%E5%A4%96%E5%A5%B3%E5%84%BF%E5%A4%84%E7%90%86%E4%BF%9D%E9%99%A9-%E8%A3%81%E5%AE%9A%E7%BD%AA%E7%8A%AF%E5%9B%BD%E5%AE%89-%E8%AF%84%E8%AE%BA%E7%A7%B0%E6%89%93%E5%8E%8B%E5%8D%87%E7%BA%A7-%E5%90%81%E9%98%BB%E6%AD%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770797185000.webp","sourceId":"rfi"},{"id":1770796189000,"createdDate":"2026-02-11 07:49","name":"法国国际广播电台","title":"白宫不就营救黎智英表态 评论指只有美国有能力营救 但机会甚微","content":"香港传媒大亨黎智英被港府重囚20年，震惊欧美，不少网民认为，判刑後可开展拯救工作，更有人直言，还看美国总统特朗普；英国《泰晤士报》亦发社论表示，若黎智英承诺停止批评北京，可能获得释放。熟悉中国事务的评论员程翔亦认为，现在只有美国可以有实力从中国手中营救黎智英出狱，但预料机会甚微。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260211-%E7%99%BD%E5%AE%AB%E4%B8%8D%E5%B0%B1%E8%90%A5%E6%95%91%E9%BB%8E%E6%99%BA%E8%8B%B1%E8%A1%A8%E6%80%81-%E8%AF%84%E8%AE%BA%E6%8C%87%E5%8F%AA%E6%9C%89%E7%BE%8E%E5%9B%BD%E6%9C%89%E8%83%BD%E5%8A%9B%E8%90%A5%E6%95%91-%E4%BD%86%E6%9C%BA%E4%BC%9A%E7%94%9A%E5%BE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770796189000.webp","sourceId":"rfi"},{"id":1770828704000,"createdDate":"2026-02-11 16:51","name":"法国国际广播电台","title":"加拿大西部小镇发生校园枪击案 至少10人死亡25人受伤","content":"当地时间周二(2月10日)下午，加拿大不列颠哥伦比亚省（BC省）中部小镇坦布勒里岭（TumblerRidge）发生一起严重校园枪击事件，包括枪手在内至少10人死亡、25人受伤，其中2人伤势严重。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E4%B8%AD%E8%A5%BF%E9%83%A8%E5%B0%8F%E9%95%87%E5%8F%91%E7%94%9F%E6%A0%A1%E5%9B%AD%E6%9E%AA%E5%87%BB%E6%A1%88-%E8%87%B3%E5%B0%9110%E4%BA%BA%E6%AD%BB%E4%BA%A125%E4%BA%BA%E5%8F%97%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770828704000.webp","sourceId":"rfi"},{"id":1770823880000,"createdDate":"2026-02-11 15:31","name":"法国国际广播电台","title":"美国在孟加拉国采取行动对抗中国","content":"孟加拉国2月12日举行议会选举前夕，路透社发自达卡独家消息称，美国对中国在南亚影响力不断扩大表示担忧，计划向孟加拉国下一届政府提供美国及其盟友的防务系统，作为中国军事装备的替代方案。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260211-%E7%BE%8E%E5%9B%BD%E5%9C%A8%E5%AD%9F%E5%8A%A0%E6%8B%89%E5%9B%BD%E9%87%87%E5%8F%96%E8%A1%8C%E5%8A%A8%E5%AF%B9%E6%8A%97%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770823880000.webp","sourceId":"rfi"},{"id":1770823692000,"createdDate":"2026-02-11 15:28","name":"法国国际广播电台","title":"视频 佛教僧侣完成“和平游行”徒步穿越美国","content":"在当前国际地缘政治动荡紧张的局势下，一些人选择步行穿越美国传播和平的信息。去年十月20多位佛教僧侣从德克萨斯州出发，现在已抵达华盛顿。许多人到场迎接他们完成这段旅程的最后一程，他们的到来引发了公众的极大热情，请看France24视频。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260211-%E8%A7%86%E9%A2%91-%E4%BD%9B%E6%95%99%E5%83%A7%E4%BE%A3%E5%AE%8C%E6%88%90-%E5%92%8C%E5%B9%B3%E6%B8%B8%E8%A1%8C-%E5%BE%92%E6%AD%A5%E7%A9%BF%E8%B6%8A%E7%BE%8E%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770823692000.webp","sourceId":"rfi"},{"id":1770814311000,"createdDate":"2026-02-11 12:51","name":"法国国际广播电台","title":"台湾总统雄心勃勃的国防预算摆脱政治僵局","content":"台湾议会在一个反对党于周三改变态度后，终于将审议赖清德总统提出的2026年国防预算案。此前，该预算案因立法僵局已被拖延两个月。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260211-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E9%9B%84%E5%BF%83%E5%8B%83%E5%8B%83%E7%9A%84%E5%9B%BD%E9%98%B2%E9%A2%84%E7%AE%97%E6%91%86%E8%84%B1%E6%94%BF%E6%B2%BB%E5%83%B5%E5%B1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770814311000.webp","sourceId":"rfi"},{"id":1770814011000,"createdDate":"2026-02-11 12:46","name":"法国国际广播电台","title":"两名中国公民被澳大利亚以涉嫌“外国干涉”罪起诉","content":"2月11日，澳大利亚以涉嫌“外国干涉”罪起诉两名中国公民，两人被控为中国政府安全机构秘密收集澳大利亚佛教团体的相关信息。中国外交部当天回应表示，中方从不干涉别国内政，敦促澳方审慎妥善处理案件，保障中国公民合法权益。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260211-%E4%B8%A4%E5%90%8D%E4%B8%AD%E5%9B%BD%E5%85%AC%E6%B0%91%E8%A2%AB%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E4%BB%A5%E6%B6%89%E5%AB%8C-%E5%A4%96%E5%9B%BD%E5%B9%B2%E6%B6%89-%E7%BD%AA%E8%B5%B7%E8%AF%89","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770814011000.webp","sourceId":"rfi"},{"id":1770812655000,"createdDate":"2026-02-11 12:24","name":"法国国际广播电台","title":"内塔尼亚胡与特朗普周三会面试图说服美国对伊朗采取更强硬立场","content":"美国总统特朗普与以色列总理内塔尼亚胡定于周三在华盛顿会面。内塔尼亚胡希望说服特朗普对德黑兰施加最大压力，以终止其核计划与弹道导弹计划。据特朗普之前告诉媒体，“我更愿意达成协议，一个没有核武，没有导弹的协议”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260211-%E5%86%85%E5%A1%94%E5%B0%BC%E4%BA%9A%E8%83%A1%E4%B8%8E%E7%89%B9%E6%9C%97%E6%99%AE%E5%91%A8%E4%B8%89%E4%BC%9A%E9%9D%A2%E8%AF%95%E5%9B%BE%E8%AF%B4%E6%9C%8D%E7%BE%8E%E5%9B%BD%E5%AF%B9%E4%BC%8A%E6%9C%97%E9%87%87%E5%8F%96%E6%9B%B4%E5%BC%BA%E7%A1%AC%E7%AB%8B%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770812655000.webp","sourceId":"rfi"},{"id":1770808991000,"createdDate":"2026-02-11 11:23","name":"法国国际广播电台","title":"视频 美国向伊朗施压 再扣一艘逃离的油轮","content":"美国战争部长海格塞斯证实，美军部队在印度洋成功拦截并登上一艘涉嫌违反制裁、运送委内瑞拉原油前往中国的油轮“阿奎拉二号”。请看France24视频报道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E8%A7%86%E9%A2%91-%E7%BE%8E%E5%9B%BD%E5%90%91%E4%BC%8A%E6%9C%97%E6%96%BD%E5%8E%8B-%E5%86%8D%E6%89%A3%E4%B8%80%E8%89%98%E9%80%83%E7%A6%BB%E7%9A%84%E6%B2%B9%E8%BD%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770808991000.webp","sourceId":"rfi"},{"id":1770808034000,"createdDate":"2026-02-11 11:07","name":"法国国际广播电台","title":"在中国电动卡车占比29%而法国仅2%：欧洲未来会将市场拱手让给中国制造商？","content":"据法国经济媒体《回声报》报道，中国正以惊人速度推进卡车电动化，而欧洲却犹豫不决。法国可持续交通与环境协会（T&EFrance）电动车行专家玛丽·谢龙（MarieChéron）对此警告称，这已不再是技术问题，而是关系到欧洲工业竞争力和经济主权的战略挑战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E5%9C%A8%E4%B8%AD%E5%9B%BD%E7%94%B5%E5%8A%A8%E5%8D%A1%E8%BD%A6%E5%8D%A0%E6%AF%9429-%EF%BC%8C%E8%80%8C%E6%B3%95%E5%9B%BD%E4%BB%852-%E6%AC%A7%E6%B4%B2%E6%9C%AA%E6%9D%A5%E4%BC%9A%E5%B0%86%E5%B8%82%E5%9C%BA%E6%8B%B1%E6%89%8B%E8%AE%A9%E7%BB%99%E4%B8%AD%E5%9B%BD%E5%88%B6%E9%80%A0%E5%95%86","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770808034000.webp","sourceId":"rfi"},{"id":1770806392000,"createdDate":"2026-02-11 10:39","name":"法国国际广播电台","title":"美中贸易战拖累法葡萄酒和烈酒出口，欧洲如何摆脱对美国的依赖...","content":"周三2月11日法国主要日报头版各有侧重，例如《费加罗报》指出法国公务员的人数不断增加；《解放报》则推出“欧洲如何摆脱对美国的依赖”的专题。与此同时，全球两大经济体——美国和中国，作为法国葡萄酒和烈酒行业在欧洲以外的主要市场，因关税壁垒和欧元走强，导致法国葡萄酒和烈酒出口下降了8%，这是《回声报》行业版的话题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260211-%E7%BE%8E%E4%B8%AD%E8%B4%B8%E6%98%93%E6%88%98%E6%8B%96%E7%B4%AF%E6%B3%95%E8%91%A1%E8%90%84%E9%85%92%E5%92%8C%E7%83%88%E9%85%92%E5%87%BA%E5%8F%A3%EF%BC%8C%E6%AC%A7%E6%B4%B2%E5%A6%82%E4%BD%95%E6%91%86%E8%84%B1%E5%AF%B9%E7%BE%8E%E5%9B%BD%E7%9A%84%E4%BE%9D%E8%B5%96","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770806392000.webp","sourceId":"rfi"},{"id":1770805089000,"createdDate":"2026-02-11 10:18","name":"法国国际广播电台","title":"黎智英遭重判20年再次证明一国两制名存实亡 台湾应以此警惕被中共统治的下场","content":"现年78岁的香港壹传媒集团创办人黎智英被香港高院重判20年有期徒刑，华尔街日报社论直言，这无异于判他死刑，香港如今牢牢受到中国铁腕掌控，北京已清楚向台湾传达，在中共统治底下的生活会是什么模样。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260211-%E9%BB%8E%E6%99%BA%E8%8B%B1%E9%81%AD%E9%87%8D%E5%88%A420%E5%B9%B4%E5%86%8D%E6%AC%A1%E8%AF%81%E6%98%8E%E4%B8%80%E5%9B%BD%E4%B8%A4%E5%88%B6%E5%90%8D%E5%AD%98%E5%AE%9E%E4%BA%A1-%E5%8F%B0%E6%B9%BE%E5%BA%94%E4%BB%A5%E6%AD%A4%E8%AD%A6%E6%83%95%E8%A2%AB%E4%B8%AD%E5%85%B1%E7%BB%9F%E6%B2%BB%E7%9A%84%E4%B8%8B%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770805089000.webp","sourceId":"rfi"},{"id":1770803920000,"createdDate":"2026-02-11 09:58","name":"法国国际广播电台","title":"北极安全：挪威警告俄罗斯威胁，英国增加驻军","content":"挪威军方近日警告，不能排除未来俄罗斯为保护其核武库而对挪威采取军事行动的可能性。与此同时，英国宣布将把驻挪威英军人数翻一番。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260211-%E5%8C%97%E6%9E%81%E5%AE%89%E5%85%A8-%E6%8C%AA%E5%A8%81%E8%AD%A6%E5%91%8A%E4%BF%84%E7%BD%97%E6%96%AF%E5%A8%81%E8%83%81%EF%BC%8C%E8%8B%B1%E5%9B%BD%E5%A2%9E%E5%8A%A0%E9%A9%BB%E5%86%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770803920000.webp","sourceId":"rfi"},{"id":1770802428000,"createdDate":"2026-02-11 09:33","name":"法国国际广播电台","title":"柬埔寨称已关闭近200个诈骗中心 打击跨国诈骗活动","content":"柬埔寨一位高级政府官员表示，柬埔寨最近几周在打击跨国诈骗的行动中关闭了近200个诈骗中心，当局罕见允许公众进入其中一个中心，以表明他们正在打击针对全球各地民众的复杂诈骗活动。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260211-%E6%9F%AC%E5%9F%94%E5%AF%A8%E7%A7%B0%E5%B7%B2%E5%85%B3%E9%97%AD%E8%BF%91200%E4%B8%AA%E8%AF%88%E9%AA%97%E4%B8%AD%E5%BF%83-%E6%89%93%E5%87%BB%E8%B7%A8%E5%9B%BD%E8%AF%88%E9%AA%97%E6%B4%BB%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770802428000.webp","sourceId":"rfi"},{"id":1770801803000,"createdDate":"2026-02-11 09:23","name":"法国国际广播电台","title":"洪都拉斯副总统表示将逐步与台湾恢复邦交，寻求对洪国最有利外交关系","content":"根据洪都拉斯（台湾称：宏都拉斯）媒体《论坛报》报导，洪国总统阿斯夫拉向特朗普明确表达正考虑将外交承认由中国转回台湾。第一副总统梅西亚也在随后证实，并表示将采取循序渐进的策略进行同时审视与中签署的16项协议。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260211-%E6%B4%AA%E9%83%BD%E6%8B%89%E6%96%AF%E5%89%AF%E6%80%BB%E7%BB%9F%E8%A1%A8%E7%A4%BA%E5%B0%86%E9%80%90%E6%AD%A5%E4%B8%8E%E5%8F%B0%E6%B9%BE%E6%81%A2%E5%A4%8D%E9%82%A6%E4%BA%A4%EF%BC%8C%E5%AF%BB%E6%B1%82%E5%AF%B9%E6%B4%AA%E5%9B%BD%E6%9C%80%E6%9C%89%E5%88%A9%E5%A4%96%E4%BA%A4%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770801803000.webp","sourceId":"rfi"},{"id":1770850782000,"createdDate":"2026-02-11 22:59","name":"法国国际广播电台","title":"舆论战：中国是如何向全球传媒强加其叙事观的","content":"据法国电视台TV5MONDE致力于辨别假新闻的节目《Avraidire》一月底谈到中国如何作为大外宣的隐形推手时，该台资深记者米莲·吉拉多对此表示，自2000年代初以来，中国已建立起一套完整的体系，旨在向全球媒体灌输其叙事。以下是该集节目相关分析摘要。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E8%88%86%E8%AE%BA%E6%88%98-%E4%B8%AD%E5%9B%BD%E6%98%AF%E5%A6%82%E4%BD%95%E5%90%91%E5%85%A8%E7%90%83%E4%BC%A0%E5%AA%92%E5%BC%BA%E5%8A%A0%E5%85%B6%E5%8F%99%E4%BA%8B%E8%A7%82%E7%9A%84","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770850782000.webp","sourceId":"rfi"},{"id":1770849751000,"createdDate":"2026-02-11 22:42","name":"法国国际广播电台","title":"张又侠落马半月后习近平的两个动作","content":"张又侠落马半月后，作为军委主席的中共总书记习近平的两个动作引起注意，一个是在北京通过视讯慰问官兵强调去年“很不平凡”，一个是慰问驻京部队老干部。另外与此密切相关的是解放军报9日搬出中共早期领导人张国焘与毛泽东权斗意欲“另立中央“的故事来比附习近平与张又侠，但诡异的是解放军报把此文删除了，尽管已转载的仍有迹可寻。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E5%BC%A0%E5%8F%88%E4%BE%A0%E8%90%BD%E9%A9%AC%E5%8D%8A%E6%9C%88%E5%90%8E%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%9A%84%E4%B8%A4%E4%B8%AA%E5%8A%A8%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770849751000.webp","sourceId":"rfi"},{"id":1770848860000,"createdDate":"2026-02-11 22:27","name":"法国国际广播电台","title":"马克龙：面对美中经济威胁 欧盟唯一的解决方案是独立强大","content":"出席比利时安特卫普欧盟工业界年度峰会的欧洲领袖周三纷纷表示，欧洲急需改革才能避免衰落，欧盟必须成为一个强大而独立的联盟。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E9%A9%AC%E5%85%8B%E9%BE%99-%E9%9D%A2%E5%AF%B9%E7%BE%8E%E4%B8%AD%E7%BB%8F%E6%B5%8E%E5%A8%81%E8%83%81-%E6%AC%A7%E7%9B%9F%E5%94%AF%E4%B8%80%E7%9A%84%E8%A7%A3%E5%86%B3%E6%96%B9%E6%A1%88%E6%98%AF%E7%8B%AC%E7%AB%8B%E5%BC%BA%E5%A4%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770848860000.webp","sourceId":"rfi"},{"id":1770846855000,"createdDate":"2026-02-11 21:54","name":"法国国际广播电台","title":"加拿大校园枪击案：凶手确认为18岁女性","content":"加拿大警方周三(2月11日）确认，周二在不列颠哥伦比亚省偏远社区坦布勒岭（TumblerRidge）制造校园枪击案的凶手为一名18岁女性，并称凶手存在精神健康问题。目前警方尚未公布作案动机。这起事件已成为加拿大历史上最严重的大规模枪击案之一。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E6%A0%A1%E5%9B%AD%E6%9E%AA%E5%87%BB%E6%A1%88-%E5%87%B6%E6%89%8B%E7%A1%AE%E8%AE%A4%E4%B8%BA18%E5%B2%81%E5%A5%B3%E6%80%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770846855000.webp","sourceId":"rfi"},{"id":1770846699000,"createdDate":"2026-02-11 21:51","name":"法国国际广播电台","title":"世卫组织呼吁美国共享新冠疫情溯源信息","content":"世界卫生组织周三(2月11日）呼吁已经退出该组织的美国，分享其可能掌握的有关新冠疫情起源的所有信息，世卫强调：查明病毒源头对于预防未来大流行至关重要。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E4%B8%96%E5%8D%AB%E7%BB%84%E7%BB%87%E5%91%BC%E5%90%81%E7%BE%8E%E5%9B%BD%E5%85%B1%E4%BA%AB%E6%96%B0%E5%86%A0%E7%96%AB%E6%83%85%E6%BA%AF%E6%BA%90%E4%BF%A1%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770846699000.webp","sourceId":"rfi"},{"id":1770846434000,"createdDate":"2026-02-11 21:47","name":"法国国际广播电台","title":"美跨党派议员呼吁收紧对华芯片设备出口","content":"美国国会多个关键委员会主席周二(2月10日）敦促国务院与商务部进一步收紧对华出口管制，限制中国获取先进芯片制造设备，并警告现行制度中的漏洞威胁美国国家安全。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E7%BE%8E%E8%B7%A8%E5%85%9A%E6%B4%BE%E8%AE%AE%E5%91%98%E5%91%BC%E5%90%81%E6%94%B6%E7%B4%A7%E5%AF%B9%E5%8D%8E%E8%8A%AF%E7%89%87%E8%AE%BE%E5%A4%87%E5%87%BA%E5%8F%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770846434000.webp","sourceId":"rfi"},{"id":1770846307000,"createdDate":"2026-02-11 21:45","name":"法国国际广播电台","title":"台湾乃人工智能竞赛最大赢家 1月份出口额飙升70% 16年来鲜见","content":"尽管面临美国总统唐纳德·特朗普的压力，但在人工智能领域的巨额投资推动下，台湾对美国的出口仍在激增。根据数据显示，16年来未见的加速：台湾成为人工智能竞赛的最大赢家，其1月份出口额飙升70%。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260211-%E5%8F%B0%E6%B9%BE%E4%B9%83%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E7%AB%9E%E8%B5%9B%E6%9C%80%E5%A4%A7%E8%B5%A2%E5%AE%B6-1%E6%9C%88%E4%BB%BD%E5%87%BA%E5%8F%A3%E9%A2%9D%E9%A3%99%E5%8D%8770-16%E5%B9%B4%E6%9D%A5%E9%B2%9C%E8%A7%81","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770846307000.webp","sourceId":"rfi"},{"id":1770846033000,"createdDate":"2026-02-11 21:40","name":"法国国际广播电台","title":"荷兰法院启动调查安世半导体 维持冻结中资母公司表决权","content":"荷兰法院周二(2月10日）裁决，对芯片制造商安世半导体（Nexperia）涉嫌管理不善展开调查，同时维持此前对其首席执行官张学政的停职裁决。这一决定对其中国母公司闻泰科技（Wingtech）构成重大打击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E8%8D%B7%E5%85%B0%E6%B3%95%E9%99%A2%E5%90%AF%E5%8A%A8%E8%B0%83%E6%9F%A5%E5%AE%89%E4%B8%96%E5%8D%8A%E5%AF%BC%E4%BD%93-%E7%BB%B4%E6%8C%81%E4%B8%AD%E8%B5%84%E6%AF%8D%E5%85%AC%E5%8F%B8%E8%A1%A8%E5%86%B3%E6%9D%83%E5%86%BB%E7%BB%93","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770846033000.webp","sourceId":"rfi"},{"id":1770845859000,"createdDate":"2026-02-11 21:37","name":"法国国际广播电台","title":"特朗普会晤内塔尼亚胡 强调继续与伊朗谈判 达成协议为“首选”","content":"美国总统特朗普周三(2月11日）在白宫会晤以色列总理内塔尼亚胡。特朗普强调将继续推进与伊朗的谈判，并称达成协议是他的“首选方案”；内塔尼亚胡则要求，美伊对话必须以保障以色列安全为前提。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E7%89%B9%E6%9C%97%E6%99%AE%E4%BC%9A%E6%99%A4%E5%86%85%E5%A1%94%E5%B0%BC%E4%BA%9A%E8%83%A1-%E5%BC%BA%E8%B0%83%E7%BB%A7%E7%BB%AD%E4%B8%8E%E4%BC%8A%E6%9C%97%E8%B0%88%E5%88%A4-%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE%E4%B8%BA-%E9%A6%96%E9%80%89","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770845859000.webp","sourceId":"rfi"},{"id":1770845815000,"createdDate":"2026-02-11 21:36","name":"法国国际广播电台","title":"美众院今表决终止加国关税　3共和党倒戈掀党内裂痕","content":"美国众议院预定于周三下午表决一项决议案，否决美国总统特朗普（DonaldTrump）对加拿大商品加征关税的措施。这项由纽约州民主党众议员米克斯（GregoryMeeks）提出的决议，以终止特朗普于2025年2月依据“国家紧急状态”所启动的关税权力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E7%BE%8E%E4%BC%97%E9%99%A2%E4%BB%8A%E8%A1%A8%E5%86%B3%E7%BB%88%E6%AD%A2%E5%8A%A0%E5%9B%BD%E5%85%B3%E7%A8%8E-3%E5%85%B1%E5%92%8C%E5%85%9A%E5%80%92%E6%88%88%E6%8E%80%E5%85%9A%E5%86%85%E8%A3%82%E7%97%95","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770845815000.webp","sourceId":"rfi"},{"id":1770845554000,"createdDate":"2026-02-11 21:32","name":"法国国际广播电台","title":"泽连斯基：只有在与莫斯科实现停火并获得安全保障后乌克兰才会举行选举","content":"乌克兰总统泽连斯基周三宣布，乌克兰只有在与莫斯科实现停火并获得“安全保障”后才会举行乌克兰选举。之前有报道称，基辅正在考虑在近期举行总统选举和全民公投。泽连斯基在一次线上新闻发布会上表示：“我们将在所有必要的安全保障到位后举行选举。”他补充说：“这很容易做到：实现停火，然后就可以举行选举了。”","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260211-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E5%8F%AA%E6%9C%89%E5%9C%A8%E4%B8%8E%E8%8E%AB%E6%96%AF%E7%A7%91%E5%AE%9E%E7%8E%B0%E5%81%9C%E7%81%AB%E5%B9%B6%E8%8E%B7%E5%BE%97%E5%AE%89%E5%85%A8%E4%BF%9D%E9%9A%9C%E5%90%8E%E4%B9%8C%E5%85%8B%E5%85%B0%E6%89%8D%E4%BC%9A%E4%B8%BE%E8%A1%8C%E9%80%89%E4%B8%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770845554000.webp","sourceId":"rfi"},{"id":1770833155000,"createdDate":"2026-02-11 18:05","name":"法国国际广播电台","title":"日本超8成受访新议员赞成把自卫队写入《宪法》","content":"共同社根据403名新当选议员的调查问卷统计，超过80%的答复者赞成将自卫队写入《宪法》。高市早苗在竞选期间呼吁修宪，把自卫队写入《宪法》第九条。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260211-%E6%97%A5%E6%9C%AC%E8%B6%858%E6%88%90%E5%8F%97%E8%AE%BF%E6%96%B0%E8%AE%AE%E5%91%98%E8%B5%9E%E6%88%90%E6%8A%8A%E8%87%AA%E5%8D%AB%E9%98%9F%E5%86%99%E5%85%A5-%E5%AE%AA%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770833155000.webp","sourceId":"rfi"},{"id":1770829218000,"createdDate":"2026-02-11 17:00","name":"法国国际广播电台","title":"军方“架空”习近平？自由时报刊文称张又侠罪在破坏軍委主席负责制","content":"台湾自由时报2月11日刊文分析张又侠案明显超越单纯贪腐问题，直指最高军事权力结构本身。这篇由中华经济研究院辅佐研究员廖明輝撰写的文章表示，当官方明确指控有人「践踏破坏」军委主席负责制，等同宣告其行为被视为“架空习近平”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260211-%E5%86%9B%E6%96%B9-%E6%9E%B6%E7%A9%BA-%E4%B9%A0%E8%BF%91%E5%B9%B3-%E8%87%AA%E7%94%B1%E6%97%B6%E6%8A%A5%E5%88%8A%E6%96%87%E7%A7%B0%E5%BC%A0%E5%8F%88%E4%BE%A0%E7%BD%AA%E5%9C%A8%E7%A0%B4%E5%9D%8F%E8%BB%8D%E5%A7%94%E4%B8%BB%E5%B8%AD%E8%B4%9F%E8%B4%A3%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770829218000.webp","sourceId":"rfi"},{"id":1770827609000,"createdDate":"2026-02-11 16:33","name":"法国国际广播电台","title":"面对中美 欧盟须采取行动提升竞争力 但面临“十大障碍”","content":"27个欧盟成员国的领导人将于周四(2月12号)在比利时阿尔登比森城堡举行欧洲理事会非正式闭门会议，讨论如何与中国这样的全球竞争对手以及美国这样不太可靠的盟友在经济上展开竞争。作为此次会议的准备，包括欧委会主席冯德莱恩、法国总统马克龙和德国总理默茨在内的几位领导人，周三在比利时与欧洲行业领袖举行峰会，阐明欧洲企业的要求。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260211-%E9%9D%A2%E5%AF%B9%E4%B8%AD%E7%BE%8E-%E6%AC%A7%E7%9B%9F%E9%A1%BB%E9%87%87%E5%8F%96%E8%A1%8C%E5%8A%A8%E6%8F%90%E5%8D%87%E7%AB%9E%E4%BA%89%E5%8A%9B-%E4%BD%86%E9%9D%A2%E4%B8%B4-%E5%8D%81%E5%A4%A7%E9%9A%9C%E7%A2%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770827609000.webp","sourceId":"rfi"},{"id":1770827492000,"createdDate":"2026-02-11 16:31","name":"法国国际广播电台","title":"「视频」俄罗斯限制使用Telegram软件引发网民抱怨","content":"俄罗斯再次收紧网络言论空间。2月10日，俄罗斯联邦信息技术和大众传媒监督机构（Roskomnadzor）以即时通讯软件Telegram（电报）有“违法”行为为由，宣布限制国民访问这款在俄罗斯深受欢迎的即时通讯软件，引发许多网民的抱怨。这款社交媒体软件的创始人帕维尔·杜罗夫（PavelDourov)谴责这项措施侵犯公民自由，非政府组织“无国界记者”谴责俄罗斯当局继续钳制资讯的传播。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260211-%E8%A7%86%E9%A2%91-%E4%BF%84%E7%BD%97%E6%96%AF%E9%99%90%E5%88%B6%E4%BD%BF%E7%94%A8telegram%E8%BD%AF%E4%BB%B6%E5%BC%95%E5%8F%91%E7%BD%91%E6%B0%91%E6%8A%B1%E6%80%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770827492000.webp","sourceId":"rfi"},{"id":1770821905000,"createdDate":"2026-02-11 14:58","name":"法国国际广播电台","title":"中俄联合开发北极航道 法德提议减少北极黑炭污染","content":"俄罗斯驻中国大使日前接受俄罗斯媒体采访时声称俄方正在积极发展北极航道，并且有意愿与包括中国在内的友好国家进行合作。他披露说，中俄两国首脑两年前决定设立一个北极航道问题小组委员会，委员会批准了一项路线图，其目标是在2030年使该航线的货运量达到2000万吨的目标。就在俄罗斯大使发表上述言论的同时，国际海事组织（IMOInternalMaritimeOrganization）正在伦敦召开会议，为其一周的会议讨论议题繁多，其中包括北极航运船只使用的燃料问题。欧洲的丹麦（代表格陵兰岛参加国际海事组织）法国、德国和太平洋的所罗门群岛共同向会议提交了一份文件（PPR13-6 ），提议在《国际防止船舶造成污染公约》（MARPOL）附则六中增加一项新的强制性北极燃料措施，要求在北极航行的船舶使用低黑碳排放的清洁燃料。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260211-%E4%B8%AD%E4%BF%84%E8%81%94%E5%90%88%E5%BC%80%E5%8F%91%E5%8C%97%E6%9E%81%E8%88%AA%E9%81%93-%E6%B3%95%E5%BE%B7%E6%8F%90%E8%AE%AE%E5%87%8F%E5%B0%91%E5%8C%97%E6%9E%81%E9%BB%91%E7%82%AD%E6%B1%A1%E6%9F%93","thumbnail":"","detailImage":"news/detail/rfi/2026/02/11/1770821905000.webp","sourceId":"rfi"}]