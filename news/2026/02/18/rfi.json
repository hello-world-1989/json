[{"id":1771373211000,"createdDate":"2026-02-18 00:06","name":"法国国际广播电台","title":"《金融时报》：欧盟准备规定电动车须70%零件本土制造才能获得补助","content":"根据英国《金融时报》的报导，欧盟为了拯救本土制造业，正计划作出如下的规定：电动车须要有至少70%的零件为欧盟制造才能获得补助；另外，建筑业使用的铝制品须要有25%为欧盟制造以及门窗塑料须要有30%为欧盟制造，才能获得补助。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260218-%E9%87%91%E8%9E%8D%E6%97%B6%E6%8A%A5-%E6%AC%A7%E7%9B%9F%E5%87%86%E5%A4%87%E8%A7%84%E5%AE%9A%E7%94%B5%E5%8A%A8%E8%BD%A6%E9%A1%BB70-%E9%9B%B6%E4%BB%B6%E6%9C%AC%E5%9C%9F%E5%88%B6%E9%80%A0%E6%89%8D%E8%83%BD%E8%8E%B7%E5%BE%97%E8%A1%A5%E5%8A%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771373211000.webp","sourceId":"rfi"},{"id":1771372892000,"createdDate":"2026-02-18 00:01","name":"法国国际广播电台","title":"央视春晚成了展示中国科技最新成果的重要舞台","content":"央视春晚上的功夫机器人吸引了法国世界报的关注。该报写道，此次央视春晚不仅是一场节日盛宴，也成为展示中国在机器人和人工智能领域最新成果的重要舞台。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260218-%E5%A4%AE%E8%A7%86%E6%98%A5%E6%99%9A%E6%88%90%E4%BA%86%E5%B1%95%E7%A4%BA%E4%B8%AD%E5%9B%BD%E7%A7%91%E6%8A%80%E6%9C%80%E6%96%B0%E6%88%90%E6%9E%9C%E7%9A%84%E9%87%8D%E8%A6%81%E8%88%9E%E5%8F%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771372892000.webp","sourceId":"rfi"},{"id":1771404508000,"createdDate":"2026-02-18 08:48","name":"法国国际广播电台","title":"港人庆新岁 乡绅为港求得中签惹热议","content":"过去四天，已有134万人次的港人离港，趁新春假期北上或外游渡岁，但留在香港守岁的仍占多数，而且不愁寂寞，继农历大年初一晚欣赏来自十多个国家或地区的46支表演队伍和花车巡游之后，今日更可按大年初二传统去车公庙祈福，晚上则可到维港两岸观赏烟花汇演。不过，网上对于新界乡议局主席刘业强为香港所求签文的解释，则意见纷纭。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E6%B8%AF%E4%BA%BA%E5%BA%86%E6%96%B0%E5%B2%81-%E4%B9%A1%E7%BB%85%E4%B8%BA%E6%B8%AF%E6%B1%82%E5%BE%97%E4%B8%AD%E7%AD%BE%E6%83%B9%E7%83%AD%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771404508000.webp","sourceId":"rfi"},{"id":1771403101000,"createdDate":"2026-02-18 08:25","name":"法国国际广播电台","title":"新春贺卡回函美国友人 习近平点出：中美关系希望在人民","content":"中国国家主席习近平回信与回赠新春贺卡给美国艾奥瓦州友人贝隆（LucaBerrone）。习近平说，中美关系希望在人民、基础在民间、未来在青年、活力在地方，无论形势如何变化，人民交流合作愿望不会改变。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E6%96%B0%E6%98%A5%E8%B4%BA%E5%8D%A1%E5%9B%9E%E5%87%BD%E7%BE%8E%E5%9B%BD%E5%8F%8B%E4%BA%BA-%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%82%B9%E5%87%BA-%E4%B8%AD%E7%BE%8E%E5%85%B3%E7%B3%BB%E5%B8%8C%E6%9C%9B%E5%9C%A8%E4%BA%BA%E6%B0%91","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771403101000.webp","sourceId":"rfi"},{"id":1771402739000,"createdDate":"2026-02-18 08:18","name":"法国国际广播电台","title":"港澳银行不良贷款比率分别高企2.01%和4.9% 澳门接近金融危机线","content":"受经济不景气影响，香港和澳门这两个中国特别行政区去年底的不良贷款比率(NPL)均达到历史高位。香港去年12月的NPL突破2%，创21年新高，当局强调，情况未损银行盈利能力，风险仍然可控，但会把信贷风险监察订为今年的首要工作目标；澳门同期的NPL虽较年中时的历史新高略为回落，但仍高企4.9%，接近中国官方指会引发金融危机的5%分界线。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E6%B8%AF%E6%BE%B3%E9%93%B6%E8%A1%8C%E4%B8%8D%E8%89%AF%E8%B4%B7%E6%AC%BE%E6%AF%94%E7%8E%87%E5%88%86%E5%88%AB%E9%AB%98%E4%BC%812-01-%E5%92%8C4-9-%E6%BE%B3%E9%97%A8%E6%8E%A5%E8%BF%91%E9%87%91%E8%9E%8D%E5%8D%B1%E6%9C%BA%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771402739000.webp","sourceId":"rfi"},{"id":1771400693000,"createdDate":"2026-02-18 07:44","name":"法国国际广播电台","title":"美国将在菲律宾部署更多导弹发射系统 北京高度警戒","content":"美联社马尼拉消息，美国计划在菲律宾部署更多高科技导弹系统，以遏制南中国海冲突升温。美菲两国作为条约盟友于周二17日再次谴责北京在具主权争议水域的“非法、胁迫性、攻击性和欺骗性活动”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E7%BE%8E%E5%9B%BD%E5%B0%86%E5%9C%A8%E8%8F%B2%E5%BE%8B%E5%AE%BE%E9%83%A8%E7%BD%B2%E6%9B%B4%E5%A4%9A%E5%AF%BC%E5%BC%B9%E5%8F%91%E5%B0%84%E7%B3%BB%E7%BB%9F-%E5%8C%97%E4%BA%AC%E9%AB%98%E5%BA%A6%E8%AD%A6%E6%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771400693000.webp","sourceId":"rfi"},{"id":1771376015000,"createdDate":"2026-02-18 00:53","name":"法国国际广播电台","title":"四小国在“人均战斗机数量”上超越美国、中国和俄罗斯——台湾赫然在列！","content":"虽然美国、中国、俄罗斯等军事大国战机数量，使其他国家难以望其项背，但要是依人口与战机的比例而言，前述三大国却远远比不上一些规模较小的国家。据《欧亚时报》报道指出，例如台湾战机与人口的比例，更是名列全球第四。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260218-%E5%9B%9B%E5%B0%8F%E5%9B%BD%E5%9C%A8-%E4%BA%BA%E5%9D%87%E6%88%98%E6%96%97%E6%9C%BA%E6%95%B0%E9%87%8F-%E4%B8%8A%E8%B6%85%E8%B6%8A%E7%BE%8E%E5%9B%BD-%E4%B8%AD%E5%9B%BD%E5%92%8C%E4%BF%84%E7%BD%97%E6%96%AF-%E5%8F%B0%E6%B9%BE%E8%B5%AB%E7%84%B6%E5%9C%A8%E5%88%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771376015000.webp","sourceId":"rfi"}]