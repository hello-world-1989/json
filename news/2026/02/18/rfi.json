[{"id":1771373211000,"createdDate":"2026-02-18 00:06","name":"法国国际广播电台","title":"《金融时报》：欧盟准备规定电动车须70%零件本土制造才能获得补助","content":"根据英国《金融时报》的报导，欧盟为了拯救本土制造业，正计划作出如下的规定：电动车须要有至少70%的零件为欧盟制造才能获得补助；另外，建筑业使用的铝制品须要有25%为欧盟制造以及门窗塑料须要有30%为欧盟制造，才能获得补助。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260218-%E9%87%91%E8%9E%8D%E6%97%B6%E6%8A%A5-%E6%AC%A7%E7%9B%9F%E5%87%86%E5%A4%87%E8%A7%84%E5%AE%9A%E7%94%B5%E5%8A%A8%E8%BD%A6%E9%A1%BB70-%E9%9B%B6%E4%BB%B6%E6%9C%AC%E5%9C%9F%E5%88%B6%E9%80%A0%E6%89%8D%E8%83%BD%E8%8E%B7%E5%BE%97%E8%A1%A5%E5%8A%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771373211000.webp","sourceId":"rfi"},{"id":1771372892000,"createdDate":"2026-02-18 00:01","name":"法国国际广播电台","title":"央视春晚成了展示中国科技最新成果的重要舞台","content":"央视春晚上的功夫机器人吸引了法国世界报的关注。该报写道，此次央视春晚不仅是一场节日盛宴，也成为展示中国在机器人和人工智能领域最新成果的重要舞台。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260218-%E5%A4%AE%E8%A7%86%E6%98%A5%E6%99%9A%E6%88%90%E4%BA%86%E5%B1%95%E7%A4%BA%E4%B8%AD%E5%9B%BD%E7%A7%91%E6%8A%80%E6%9C%80%E6%96%B0%E6%88%90%E6%9E%9C%E7%9A%84%E9%87%8D%E8%A6%81%E8%88%9E%E5%8F%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771372892000.webp","sourceId":"rfi"},{"id":1771404508000,"createdDate":"2026-02-18 08:48","name":"法国国际广播电台","title":"港人庆新岁 乡绅为港求得中签惹热议","content":"过去四天，已有134万人次的港人离港，趁新春假期北上或外游渡岁，但留在香港守岁的仍占多数，而且不愁寂寞，继农历大年初一晚欣赏来自十多个国家或地区的46支表演队伍和花车巡游之后，今日更可按大年初二传统去车公庙祈福，晚上则可到维港两岸观赏烟花汇演。不过，网上对于新界乡议局主席刘业强为香港所求签文的解释，则意见纷纭。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E6%B8%AF%E4%BA%BA%E5%BA%86%E6%96%B0%E5%B2%81-%E4%B9%A1%E7%BB%85%E4%B8%BA%E6%B8%AF%E6%B1%82%E5%BE%97%E4%B8%AD%E7%AD%BE%E6%83%B9%E7%83%AD%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771404508000.webp","sourceId":"rfi"},{"id":1771403101000,"createdDate":"2026-02-18 08:25","name":"法国国际广播电台","title":"新春贺卡回函美国友人 习近平点出：中美关系希望在人民","content":"中国国家主席习近平回信与回赠新春贺卡给美国艾奥瓦州友人贝隆（LucaBerrone）。习近平说，中美关系希望在人民、基础在民间、未来在青年、活力在地方，无论形势如何变化，人民交流合作愿望不会改变。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E6%96%B0%E6%98%A5%E8%B4%BA%E5%8D%A1%E5%9B%9E%E5%87%BD%E7%BE%8E%E5%9B%BD%E5%8F%8B%E4%BA%BA-%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%82%B9%E5%87%BA-%E4%B8%AD%E7%BE%8E%E5%85%B3%E7%B3%BB%E5%B8%8C%E6%9C%9B%E5%9C%A8%E4%BA%BA%E6%B0%91","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771403101000.webp","sourceId":"rfi"},{"id":1771402739000,"createdDate":"2026-02-18 08:18","name":"法国国际广播电台","title":"港澳银行不良贷款比率分别高企2.01%和4.9% 澳门接近金融危机线","content":"受经济不景气影响，香港和澳门这两个中国特别行政区去年底的不良贷款比率(NPL)均达到历史高位。香港去年12月的NPL突破2%，创21年新高，当局强调，情况未损银行盈利能力，风险仍然可控，但会把信贷风险监察订为今年的首要工作目标；澳门同期的NPL虽较年中时的历史新高略为回落，但仍高企4.9%，接近中国官方指会引发金融危机的5%分界线。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E6%B8%AF%E6%BE%B3%E9%93%B6%E8%A1%8C%E4%B8%8D%E8%89%AF%E8%B4%B7%E6%AC%BE%E6%AF%94%E7%8E%87%E5%88%86%E5%88%AB%E9%AB%98%E4%BC%812-01-%E5%92%8C4-9-%E6%BE%B3%E9%97%A8%E6%8E%A5%E8%BF%91%E9%87%91%E8%9E%8D%E5%8D%B1%E6%9C%BA%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771402739000.webp","sourceId":"rfi"},{"id":1771400693000,"createdDate":"2026-02-18 07:44","name":"法国国际广播电台","title":"美国将在菲律宾部署更多导弹发射系统 北京高度警戒","content":"美联社马尼拉消息，美国计划在菲律宾部署更多高科技导弹系统，以遏制南中国海冲突升温。美菲两国作为条约盟友于周二17日再次谴责北京在具主权争议水域的“非法、胁迫性、攻击性和欺骗性活动”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E7%BE%8E%E5%9B%BD%E5%B0%86%E5%9C%A8%E8%8F%B2%E5%BE%8B%E5%AE%BE%E9%83%A8%E7%BD%B2%E6%9B%B4%E5%A4%9A%E5%AF%BC%E5%BC%B9%E5%8F%91%E5%B0%84%E7%B3%BB%E7%BB%9F-%E5%8C%97%E4%BA%AC%E9%AB%98%E5%BA%A6%E8%AD%A6%E6%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771400693000.webp","sourceId":"rfi"},{"id":1771376015000,"createdDate":"2026-02-18 00:53","name":"法国国际广播电台","title":"四小国在“人均战斗机数量”上超越美国、中国和俄罗斯——台湾赫然在列！","content":"虽然美国、中国、俄罗斯等军事大国战机数量，使其他国家难以望其项背，但要是依人口与战机的比例而言，前述三大国却远远比不上一些规模较小的国家。据《欧亚时报》报道指出，例如台湾战机与人口的比例，更是名列全球第四。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260218-%E5%9B%9B%E5%B0%8F%E5%9B%BD%E5%9C%A8-%E4%BA%BA%E5%9D%87%E6%88%98%E6%96%97%E6%9C%BA%E6%95%B0%E9%87%8F-%E4%B8%8A%E8%B6%85%E8%B6%8A%E7%BE%8E%E5%9B%BD-%E4%B8%AD%E5%9B%BD%E5%92%8C%E4%BF%84%E7%BD%97%E6%96%AF-%E5%8F%B0%E6%B9%BE%E8%B5%AB%E7%84%B6%E5%9C%A8%E5%88%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771376015000.webp","sourceId":"rfi"},{"id":1771429912000,"createdDate":"2026-02-18 15:51","name":"法国国际广播电台","title":"中国学者解析：连任首相后的高市早苗，真的能对华强硬到底吗？","content":"高市早苗周三（2月18日）连任日本首相，对此有中国学者认为，高市一方面迫于中国强大压力需稳定中日关系，势将寻求重启对中接触与沟通。但她并不会放弃其抗中路线，这将使中日关系持续承受压力，进而制约日本外交回旋空间。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E4%B8%AD%E5%9B%BD%E5%AD%A6%E8%80%85%E8%A7%A3%E6%9E%90-%E8%BF%9E%E4%BB%BB%E9%A6%96%E7%9B%B8%E5%90%8E%E7%9A%84%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%EF%BC%8C%E7%9C%9F%E7%9A%84%E8%83%BD%E5%AF%B9%E5%8D%8E%E5%BC%BA%E7%A1%AC%E5%88%B0%E5%BA%95%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771429912000.webp","sourceId":"rfi"},{"id":1771425499000,"createdDate":"2026-02-18 14:38","name":"法国国际广播电台","title":"法国：财政部文件显示逾1.3万户富裕家庭不缴半毛个人所得税","content":"法新社巴黎消息，尽管拥有高额房地产资产，仍有数千名纳税人避开了个人所得税。经济财政部（Bercy）向参议员提交的一份文件显示，超过1.3万个缴纳房地产财富税（IFI）的家庭所缴纳的所得税为零，甚至为负数。这一消息证实了《世界报》（LeMonde）此前披露的信息。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260218-%E6%B3%95%E5%9B%BD-%E8%B4%A2%E6%94%BF%E9%83%A8%E6%96%87%E4%BB%B6%E6%98%BE%E7%A4%BA%E9%80%BE1-3%E4%B8%87%E6%88%B7%E5%AF%8C%E8%A3%95%E5%AE%B6%E5%BA%AD%E4%B8%8D%E7%BC%B4%E4%B8%AA%E4%BA%BA%E6%89%80%E5%BE%97%E7%A8%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771425499000.webp","sourceId":"rfi"},{"id":1771425288000,"createdDate":"2026-02-18 14:34","name":"法国国际广播电台","title":"咸海已奄奄一息 里海尚可救否？","content":"位于中亚的咸海曾经是世界上的第四大湖泊，而如今它却正面临消失的威胁，它的湖水面积在六十年内减少了百分之九十，导致此一灾难的原因，大量研究资料已表明，开辟新的绿洲，扩大水浇地，改变了天然水道的分布格局，是造成咸海干涸的主要原因。有关如何拯救咸海的讨论早已延续多年，不过，面对这一地球上最严重的环境灾难之一，世界上顶尖级的环境专家也只能望洋兴叹了。由此可见，环境问题真是牵一发而动全身，在沙漠中开辟绿洲自然会起到一定的积极作用，但是，其可能产生的负面影响往往会超出最初的评估。令人担忧的是世界上最大的内陆海 ,位于欧亚之间的里海似乎也正在面临同样的命运。根据近期公布的多项研究，里海海平面平均每年下降6厘米。照此速度，到本世纪末，里海的面积可能会减少多达30%。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260218-%E5%92%B8%E6%B5%B7%E5%B7%B2%E5%A5%84%E5%A5%84%E4%B8%80%E6%81%AF-%E9%87%8C%E6%B5%B7%E5%B0%9A%E5%8F%AF%E6%95%91%E5%90%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771425288000.webp","sourceId":"rfi"},{"id":1771424278000,"createdDate":"2026-02-18 14:17","name":"法国国际广播电台","title":"视频 社交媒体诱发成瘾 扎克伯格出庭面对法官","content":"社交网络是否故意让儿童上瘾？它们的设计初衷是否就是如此？这也把脸书、Instagram、WhatsApp和油管等社交媒体被推上了被告席。今天美国洛杉矶最高法院正等扎克伯格的重要证词，是这位Meta集团的掌门人在陪审团面前宣誓作证，讲述其应用程序的安全性，请看France24的洛伊克·皮亚拉特从洛杉矶报道。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260218-%E8%A7%86%E9%A2%91-%E7%94%A8%E7%A4%BE%E4%BA%A4%E5%AA%92%E4%BD%93%E6%88%90%E7%98%BE-%E6%89%8E%E5%85%8B%E4%BC%AF%E6%A0%BC%E5%87%BA%E5%BA%AD%E9%9D%A2%E5%AF%B9%E6%B3%95%E5%AE%98","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771424278000.webp","sourceId":"rfi"},{"id":1771423513000,"createdDate":"2026-02-18 14:05","name":"法国国际广播电台","title":"日本高市政权2.0 将全力推进经济政策及首脑外交","content":"高市早苗在2月8日的众院大选中以压倒性优势获胜后，第221届特别国会18日开幕，首相高市早苗在众院全体会议的首相指名选举中，毫无悬念当选为第105任首相。20日将进行高市的施政方针演说等政府四大演说，朝野政党的论战将正式展开。此次特别国会会期为150天，持续至7月17日。所有第一届高市内阁阁僚将继续任职，计划加紧促使因众院选举而迟迟未启动审议的2026年度预算案获得通过，并全力推进经济政策及首脑外交。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260218-%E6%97%A5%E6%9C%AC%E9%AB%98%E5%B8%82%E6%94%BF%E6%9D%832-0-%E5%B0%86%E5%85%A8%E5%8A%9B%E6%8E%A8%E8%BF%9B%E7%BB%8F%E6%B5%8E%E6%94%BF%E7%AD%96%E5%8F%8A%E9%A6%96%E8%84%91%E5%A4%96%E4%BA%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771423513000.webp","sourceId":"rfi"},{"id":1771420459000,"createdDate":"2026-02-18 13:14","name":"法国国际广播电台","title":"2030法国冬奥会申办成功为何麻烦不断?","content":"随着2026米兰冬季奥运会走向尾声，世人关注的目光开始转向下一届，也就是2030年将在法国阿尔卑斯山举行的冬奥会。不过，承办2030冬奥会当前在法国各界引发的更是与政治纷争交错的争议。才成立一年的主办机构也正陷入一场无休无止的人事纠纷，本已经起步晚于往常的准备工作尚未能启动。此番混乱所为何事？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260218-2030%E6%B3%95%E5%9B%BD%E5%86%AC%E5%A5%A5%E4%BC%9A%E7%94%B3%E5%8A%9E%E6%88%90%E5%8A%9F%E4%B8%BA%E4%BD%95%E9%BA%BB%E7%83%A6%E4%B8%8D%E6%96%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771420459000.webp","sourceId":"rfi"},{"id":1771418379000,"createdDate":"2026-02-18 12:39","name":"法国国际广播电台","title":"美国任命西藏人权特使，激怒了北京","content":"法新社北京消息，在华盛顿宣布任命一位促进西藏人权的特使后，北京周三（2月18日）指责美国“干涉中国内政”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E7%BE%8E%E5%9B%BD%E4%BB%BB%E5%91%BD%E8%A5%BF%E8%97%8F%E4%BA%BA%E6%9D%83%E7%89%B9%E4%BD%BF%EF%BC%8C%E6%BF%80%E6%80%92%E4%BA%86%E5%8C%97%E4%BA%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771418379000.webp","sourceId":"rfi"},{"id":1771417168000,"createdDate":"2026-02-18 12:19","name":"法国国际广播电台","title":"致命边境冲突五年后，印度开始放宽进口中国电力和煤炭设备的限制","content":"两名印度政府官员告诉路透社，在2020年发生致命的边境冲突后，印度已开始放宽对购买中国设备的限制，允许国有电力和煤炭公司开始有限度地进口，以应对日益严重的短缺和项目延误。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E8%87%B4%E5%91%BD%E8%BE%B9%E5%A2%83%E5%86%B2%E7%AA%81%E4%BA%94%E5%B9%B4%E5%90%8E%EF%BC%8C%E5%8D%B0%E5%BA%A6%E5%BC%80%E5%A7%8B%E6%94%BE%E5%AE%BD%E8%BF%9B%E5%8F%A3%E4%B8%AD%E5%9B%BD%E7%94%B5%E5%8A%9B%E5%92%8C%E7%85%A4%E7%82%AD%E8%AE%BE%E5%A4%87%E7%9A%84%E9%99%90%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771417168000.webp","sourceId":"rfi"},{"id":1771416711000,"createdDate":"2026-02-18 12:11","name":"法国国际广播电台","title":"台湾国防特别预算拖太久 美国参众议员发出罕见公开信 显示美国担忧已到达极点","content":"近日美国37名参众议员致函立法院长韩国瑜等人，呼吁支持赖清德总统的国防特别预算。民进党认为，美国此举表示其对台湾安全的极度担忧，更有可能影响美国对台军售。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260218-%E5%8F%B0%E6%B9%BE%E5%9B%BD%E9%98%B2%E7%89%B9%E5%88%AB%E9%A2%84%E7%AE%97%E6%8B%96%E5%A4%AA%E4%B9%85-%E7%BE%8E%E5%9B%BD%E5%8F%82%E4%BC%97%E8%AE%AE%E5%91%98%E5%8F%91%E5%87%BA%E7%BD%95%E8%A7%81%E5%85%AC%E5%BC%80%E4%BF%A1-%E6%98%BE%E7%A4%BA%E7%BE%8E%E5%9B%BD%E6%8B%85%E5%BF%A7%E5%B7%B2%E5%88%B0%E8%BE%BE%E6%9E%81%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771416711000.webp","sourceId":"rfi"},{"id":1771415984000,"createdDate":"2026-02-18 11:59","name":"法国国际广播电台","title":"克里姆林宫：中国和俄罗斯都没有进行过秘密核试验","content":"路透社莫斯科消息，克里姆林宫周三（2月18日）表示，无论是中国还是俄罗斯，均未进行秘密核试验，并指出北京方面已否认美国对其的指控。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E5%85%8B%E9%87%8C%E5%A7%86%E6%9E%97%E5%AE%AB-%E4%B8%AD%E5%9B%BD%E5%92%8C%E4%BF%84%E7%BD%97%E6%96%AF%E9%83%BD%E6%B2%A1%E6%9C%89%E8%BF%9B%E8%A1%8C%E8%BF%87%E7%A7%98%E5%AF%86%E6%A0%B8%E8%AF%95%E9%AA%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771415984000.webp","sourceId":"rfi"},{"id":1771414581000,"createdDate":"2026-02-18 11:36","name":"法国国际广播电台","title":"视频 马克龙到访印度 增售“阵风”战机谈判顺利","content":"在法国总统马克龙访问之际，印度已决定在该国空军原有36架采购订单的基础上，额外加购114架法国“阵风”战斗机，巴黎方面对达成这笔交易表示高度信心，请看France24报道。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260218-%E8%A7%86%E9%A2%91-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%88%B0%E8%AE%BF%E5%8D%B0%E5%BA%A6-%E5%A2%9E%E5%94%AE-%E9%98%B5%E9%A3%8E-%E6%88%98%E6%9C%BA%E8%B0%88%E5%88%A4%E9%A1%BA%E5%88%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771414581000.webp","sourceId":"rfi"},{"id":1771408342000,"createdDate":"2026-02-18 09:52","name":"法国国际广播电台","title":"美方披露中国2020年疑似核试验的新细节","content":"路透社华盛顿电稿称，一名美国高级官员周二（2月17日）披露了中国2020年6月疑似进行地下核试验的新细节。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E7%BE%8E%E6%96%B9%E6%8A%AB%E9%9C%B2%E4%B8%AD%E5%9B%BD2020%E5%B9%B4%E7%96%91%E4%BC%BC%E6%A0%B8%E8%AF%95%E9%AA%8C%E7%9A%84%E6%96%B0%E7%BB%86%E8%8A%82","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771408342000.webp","sourceId":"rfi"},{"id":1771407716000,"createdDate":"2026-02-18 09:41","name":"法国国际广播电台","title":"日内瓦俄乌停战谈判：泽连斯基面对美俄双重压力","content":"美国主导的新一轮俄乌战争停战谈判18日在日内瓦进入第二天。四年来坚持抵抗俄罗斯全面入侵的乌克兰此时在谈判桌上正面对双重压力，一是来自推动谈判的美国总统特朗普的政治压力，二是俄罗斯持续不断的大规模军事行动的压力。而谈判难以推进的一个核心症结，依然是土地问题。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260218-%E6%97%A5%E5%86%85%E7%93%A6%E4%BF%84%E4%B9%8C%E5%81%9C%E6%88%98%E8%B0%88%E5%88%A4-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E9%9D%A2%E5%AF%B9%E7%BE%8E%E4%BF%84%E5%8F%8C%E9%87%8D%E5%8E%8B%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771407716000.webp","sourceId":"rfi"},{"id":1771406766000,"createdDate":"2026-02-18 09:26","name":"法国国际广播电台","title":"自由亚洲电台宣布恢复对中国的广播","content":"路透社华盛顿消息，自由亚洲电台（RadioFreeAsia，简称RFA）首席执行官周二（2月17日）宣布，该台已恢复面向中国的广播。去年，特朗普政府的削减措施曾迫使这家由美国资助的媒体几乎停止运营。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E8%87%AA%E7%94%B1%E4%BA%9A%E6%B4%B2%E7%94%B5%E5%8F%B0%E5%AE%A3%E5%B8%83%E6%81%A2%E5%A4%8D%E5%AF%B9%E4%B8%AD%E5%9B%BD%E7%9A%84%E5%B9%BF%E6%92%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771406766000.webp","sourceId":"rfi"},{"id":1771406303000,"createdDate":"2026-02-18 09:18","name":"法国国际广播电台","title":"高市早苗当选日本第105代首相 第二届高市政权扬帆","content":"因日本众议院解散举行大选，新的一任首相指名选举在18日召集的特别国会上举行，在众议院全体会议上，高市早苗首相（自由民主党总裁）被指名为第105代首相（内阁总理大臣）。参议院的首相指名选举在第一次投票中没有任何候选人获得过半数，因此在高市早苗首相（自民党总裁）与中道改革联合代表小川淳也进行了决选投票，决选结果是高市早苗以多数选票当选日本第105代首相。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E5%BD%93%E9%80%89%E6%97%A5%E6%9C%AC%E7%AC%AC105%E4%BB%A3%E9%A6%96%E7%9B%B8-%E7%AC%AC%E4%BA%8C%E5%B1%8A%E9%AB%98%E5%B8%82%E6%94%BF%E6%9D%83%E6%89%AC%E5%B8%86","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771406303000.webp","sourceId":"rfi"},{"id":1771406090000,"createdDate":"2026-02-18 09:14","name":"法国国际广播电台","title":"秘鲁：总统赫里因私会中国商人丑闻遭罢免","content":"秘鲁国会周二（2月17号）罢免了上任仅四个月的总统何塞·赫里（JoseJeri），原因是赫里与一名中国商人举行了未上公开行程会面引发了政治丑闻。这一事件延续了过去十年来一直困扰着这个南美国家的政治动荡。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260218-%E7%A7%98%E9%B2%81-%E6%80%BB%E7%BB%9F%E8%B5%AB%E9%87%8C%E5%9B%A0%E7%A7%81%E4%BC%9A%E4%B8%AD%E5%9B%BD%E5%95%86%E4%BA%BA%E4%B8%91%E9%97%BB%E9%81%AD%E7%BD%A2%E5%85%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771406090000.webp","sourceId":"rfi"},{"id":1771406082000,"createdDate":"2026-02-18 09:14","name":"法国国际广播电台","title":"美议员：特朗普公然承认与习近平讨论对台军售，形同将台湾视为美中谈判筹码","content":"特朗普表示他正在与习近平讨论对台军售一事，且双方通话情况良好，并预告美国很快就会做出决定。美国议员肯纳表示，特朗普总统应重申美国对六项保证的承诺，并澄清美国对台政策并未改变。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E7%BE%8E%E8%AE%AE%E5%91%98-%E7%89%B9%E6%9C%97%E6%99%AE%E5%85%AC%E7%84%B6%E6%89%BF%E8%AE%A4%E4%B8%8E%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%A8%E8%AE%BA%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%EF%BC%8C%E5%BD%A2%E5%90%8C%E5%B0%86%E5%8F%B0%E6%B9%BE%E8%A7%86%E4%B8%BA%E7%BE%8E%E4%B8%AD%E8%B0%88%E5%88%A4%E7%AD%B9%E7%A0%81","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771406082000.webp","sourceId":"rfi"},{"id":1771405774000,"createdDate":"2026-02-18 09:09","name":"法国国际广播电台","title":"出于数据安全担忧 波兰禁止中国制造的汽车进入军事设施","content":"路透社华沙消息，波兰军方于周二17日晚间表示，出于对车载感测器可能被用于收集敏感数据的担忧，波兰已禁止中国制造的车辆进入军事设施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E5%87%BA%E4%BA%8E%E6%95%B0%E6%8D%AE%E5%AE%89%E5%85%A8%E6%8B%85%E5%BF%A7-%E6%B3%A2%E5%85%B0%E7%A6%81%E6%AD%A2%E4%B8%AD%E5%9B%BD%E5%88%B6%E9%80%A0%E7%9A%84%E6%B1%BD%E8%BD%A6%E8%BF%9B%E5%85%A5%E5%86%9B%E4%BA%8B%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771405774000.webp","sourceId":"rfi"},{"id":1771404863000,"createdDate":"2026-02-18 08:54","name":"法国国际广播电台","title":"人工智能：马克龙与莫迪携手展现应对美中竞争的雄心","content":"本周，新德里举办第四届全球人工智能峰会，正在印度访问的法国总统马克龙与印度总理莫迪共同表示，两国希望在人工智能领域加强合作，以在面对美国和中国这两大科技巨头时拥有更大的话语权。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260218-%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD-%E9%A9%AC%E5%85%8B%E9%BE%99%E4%B8%8E%E8%8E%AB%E8%BF%AA%E6%90%BA%E6%89%8B%E5%B1%95%E7%8E%B0%E5%BA%94%E5%AF%B9%E7%BE%8E%E4%B8%AD%E7%AB%9E%E4%BA%89%E7%9A%84%E9%9B%84%E5%BF%83","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771404863000.webp","sourceId":"rfi"},{"id":1771454633000,"createdDate":"2026-02-18 22:43","name":"法国国际广播电台","title":"八名被美国驱逐出境的塞内加尔、塞拉利昂和埃塞俄比亚的移民周一抵达喀麦隆","content":"八名塞内加尔、塞拉利昂和埃塞俄比亚的移民周一抵达喀麦隆，之前他们被美国驱逐出境。喀麦隆和美国均未公开任何关于这类移交的协议。自特朗普一年前重返白宫以来，他的政府已达成多项驱逐协议，这些协议遭到人权组织的强烈批评。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260218-%E5%85%AB%E5%90%8D%E8%A2%AB%E7%BE%8E%E5%9B%BD%E9%A9%B1%E9%80%90%E5%87%BA%E5%A2%83%E7%9A%84%E5%A1%9E%E5%86%85%E5%8A%A0%E5%B0%94-%E5%A1%9E%E6%8B%89%E5%88%A9%E6%98%82%E5%92%8C%E5%9F%83%E5%A1%9E%E4%BF%84%E6%AF%94%E4%BA%9A%E7%9A%84%E7%A7%BB%E6%B0%91%E5%91%A8%E4%B8%80%E6%8A%B5%E8%BE%BE%E5%96%80%E9%BA%A6%E9%9A%86","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771454633000.webp","sourceId":"rfi"},{"id":1771454370000,"createdDate":"2026-02-18 22:39","name":"法国国际广播电台","title":"丹麦国王弗雷德里克十世抵达格陵兰岛， 以表示对这片备受美国总统特朗普觊觎的丹麦自治领土的支持","content":"丹麦国王弗雷德里克十世周三抵达格陵兰岛，展开为期三天的极具象征意义的访问，以表示对这片备受美国总统特朗普觊觎的丹麦自治领土的支持。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260218-%E4%B8%B9%E9%BA%A6%E5%9B%BD%E7%8E%8B%E5%BC%97%E9%9B%B7%E5%BE%B7%E9%87%8C%E5%85%8B%E5%8D%81%E4%B8%96%E6%8A%B5%E8%BE%BE%E6%A0%BC%E9%99%B5%E5%85%B0%E5%B2%9B%EF%BC%8C-%E4%BB%A5%E8%A1%A8%E7%A4%BA%E5%AF%B9%E8%BF%99%E7%89%87%E5%A4%87%E5%8F%97%E7%BE%8E%E5%9B%BD%E6%80%BB%E7%BB%9F%E7%89%B9%E6%9C%97%E6%99%AE%E8%A7%8A%E8%A7%8E%E7%9A%84%E4%B8%B9%E9%BA%A6%E8%87%AA%E6%B2%BB%E9%A2%86%E5%9C%9F%E7%9A%84%E6%94%AF%E6%8C%81","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771454370000.webp","sourceId":"rfi"},{"id":1771454207000,"createdDate":"2026-02-18 22:36","name":"法国国际广播电台","title":"美国的“亚伯拉罕·林肯”号航母逼近，伊朗正在“起草”与美国未来谈判的框架","content":"伊朗最高外交官阿巴斯·阿拉格奇周三表示，德黑兰正在“起草”与美国未来谈判的框架。与此同时，美国能源部长表示，华盛顿将“无论如何”阻止伊朗的核计划。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260218-%E7%BE%8E%E5%9B%BD%E7%9A%84-%E4%BA%9A%E4%BC%AF%E6%8B%89%E7%BD%95%C2%B7%E6%9E%97%E8%82%AF-%E5%8F%B7%E8%88%AA%E6%AF%8D%E9%80%BC%E8%BF%91%EF%BC%8C%E4%BC%8A%E6%9C%97%E6%AD%A3%E5%9C%A8-%E8%B5%B7%E8%8D%89-%E4%B8%8E%E7%BE%8E%E5%9B%BD%E6%9C%AA%E6%9D%A5%E8%B0%88%E5%88%A4%E7%9A%84%E6%A1%86%E6%9E%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771454207000.webp","sourceId":"rfi"},{"id":1771454187000,"createdDate":"2026-02-18 22:36","name":"法国国际广播电台","title":"美国国务卿卢比奥与古巴共产党领导人卡斯特罗家族的改革派后裔秘密会谈","content":"美国国务卿马可·卢比奥与古巴共产党领导人卡斯特罗家族的一位后裔举行了秘密会谈，这些接触并非通过古巴政府的正常渠道，也不是谈判，而是“关于未来的讨论”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260218-%E7%BE%8E%E5%9B%BD%E5%9B%BD%E5%8A%A1%E5%8D%BF%E5%8D%A2%E6%AF%94%E5%A5%A5%E4%B8%8E%E5%8F%A4%E5%B7%B4%E5%85%B1%E4%BA%A7%E5%85%9A%E9%A2%86%E5%AF%BC%E4%BA%BA%E5%8D%A1%E6%96%AF%E7%89%B9%E7%BD%97%E5%AE%B6%E6%97%8F%E7%9A%84%E6%94%B9%E9%9D%A9%E6%B4%BE%E5%90%8E%E8%A3%94%E7%A7%98%E5%AF%86%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771454187000.webp","sourceId":"rfi"},{"id":1771454156000,"createdDate":"2026-02-18 22:35","name":"法国国际广播电台","title":"普京在莫斯科会见古巴外长，没有公开承诺提供任何具体的物质援助","content":"俄罗斯总统普京周三在莫斯科会见古巴外长布鲁诺·罗德里格斯时表示，莫斯科将“永远”与古巴站在一起，重申了对这个正遭受美国全面制裁的加勒比岛国的支持。但莫斯科没有公开承诺提供任何具体的物质援助。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260218-%E6%99%AE%E4%BA%AC%E5%9C%A8%E8%8E%AB%E6%96%AF%E7%A7%91%E4%BC%9A%E8%A7%81%E5%8F%A4%E5%B7%B4%E5%A4%96%E9%95%BF%EF%BC%8C%E6%B2%A1%E6%9C%89%E5%85%AC%E5%BC%80%E6%89%BF%E8%AF%BA%E6%8F%90%E4%BE%9B%E4%BB%BB%E4%BD%95%E5%85%B7%E4%BD%93%E7%9A%84%E7%89%A9%E8%B4%A8%E6%8F%B4%E5%8A%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771454156000.webp","sourceId":"rfi"},{"id":1771453895000,"createdDate":"2026-02-18 22:31","name":"法国国际广播电台","title":"高喊“美国制造”却将产线移往中国 特朗普金主保尔森关闭俄州工厂惹议","content":"曾高调抨击企业将工作外移、力挺关税政策与本土制造的亿万富豪，如今却被指亲手将美国工厂迁往中国。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260218-%E9%AB%98%E5%96%8A-%E7%BE%8E%E5%9B%BD%E5%88%B6%E9%80%A0-%E5%8D%B4%E5%B0%86%E4%BA%A7%E7%BA%BF%E7%A7%BB%E5%BE%80%E4%B8%AD%E5%9B%BD-%E7%89%B9%E6%9C%97%E6%99%AE%E9%87%91%E4%B8%BB%E4%BF%9D%E5%B0%94%E6%A3%AE%E5%85%B3%E9%97%AD%E4%BF%84%E5%B7%9E%E5%B7%A5%E5%8E%82%E6%83%B9%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771453895000.webp","sourceId":"rfi"},{"id":1771453222000,"createdDate":"2026-02-18 22:20","name":"法国国际广播电台","title":"中国春晚机器人表演武术 5到10年将出现中国科技圈？","content":"中国在人工智能（AI）领域迅速进展，让目前居市场主导地位的美国备感威胁。分析指出：中国将科技实力结合成本与供应链优势，很可能5到10年会看到中国科技圈的浮现。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260218-%E4%B8%AD%E5%9B%BD%E6%98%A5%E6%99%9A%E6%9C%BA%E5%99%A8%E4%BA%BA%E8%A1%A8%E6%BC%94%E6%AD%A6%E6%9C%AF-5%E5%88%B010%E5%B9%B4%E5%B0%86%E5%87%BA%E7%8E%B0%E4%B8%AD%E5%9B%BD%E7%A7%91%E6%8A%80%E5%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771453222000.webp","sourceId":"rfi"},{"id":1771445785000,"createdDate":"2026-02-18 20:16","name":"法国国际广播电台","title":"美国斡旋俄乌日内瓦和谈两天无重大突破","content":"俄乌两国在美国斡旋下召开的日内瓦和平会谈在17日和18日两天举行，俄乌美三方对谈判结果有不同评价，但都同意继续进行新的磋商。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260218-%E7%BE%8E%E5%9B%BD%E6%96%A1%E6%97%8B%E4%BF%84%E4%B9%8C%E6%97%A5%E5%86%85%E7%93%A6%E5%92%8C%E8%B0%88%E5%B0%9A%E6%9C%AA%E5%8F%96%E5%BE%97%E9%87%8D%E5%A4%A7%E7%AA%81%E7%A0%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771445785000.webp","sourceId":"rfi"},{"id":1771437677000,"createdDate":"2026-02-18 18:01","name":"法国国际广播电台","title":"欧盟对华关税令德国零售商损失数百万欧元","content":"据德国《商报》报道：欧洲制造商呼吁对中国产品征收关税。然而，这将使德国零售商的许多商品成本上升。他们警告称，消费者也将感受到明显影响。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260218-%E6%AC%A7%E7%9B%9F%E5%AF%B9%E5%8D%8E%E5%85%B3%E7%A8%8E%E4%BB%A4%E5%BE%B7%E5%9B%BD%E9%9B%B6%E5%94%AE%E5%95%86%E6%8D%9F%E5%A4%B1%E6%95%B0%E7%99%BE%E4%B8%87%E6%AC%A7%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771437677000.webp","sourceId":"rfi"},{"id":1771435309000,"createdDate":"2026-02-18 17:21","name":"法国国际广播电台","title":"波兰出台军事新规，中国汽车被列入禁令范围","content":"美联社2月18日消息，波兰军方宣布，已禁止中国汽车进入军事设施，以防止技术高度发达的车辆采集敏感信息。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260218-%E6%B3%A2%E5%85%B0%E5%87%BA%E5%8F%B0%E5%86%9B%E4%BA%8B%E6%96%B0%E8%A7%84%EF%BC%8C%E4%B8%AD%E5%9B%BD%E6%B1%BD%E8%BD%A6%E8%A2%AB%E5%88%97%E5%85%A5%E7%A6%81%E4%BB%A4%E8%8C%83%E5%9B%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771435309000.webp","sourceId":"rfi"}]