[{"id":1771373211000,"createdDate":"2026-02-18 00:06","name":"法国国际广播电台","title":"《金融时报》：欧盟准备规定电动车须70%零件本土制造才能获得补助","content":"根据英国《金融时报》的报导，欧盟为了拯救本土制造业，正计划作出如下的规定：电动车须要有至少70%的零件为欧盟制造才能获得补助；另外，建筑业使用的铝制品须要有25%为欧盟制造以及门窗塑料须要有30%为欧盟制造，才能获得补助。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260218-%E9%87%91%E8%9E%8D%E6%97%B6%E6%8A%A5-%E6%AC%A7%E7%9B%9F%E5%87%86%E5%A4%87%E8%A7%84%E5%AE%9A%E7%94%B5%E5%8A%A8%E8%BD%A6%E9%A1%BB70-%E9%9B%B6%E4%BB%B6%E6%9C%AC%E5%9C%9F%E5%88%B6%E9%80%A0%E6%89%8D%E8%83%BD%E8%8E%B7%E5%BE%97%E8%A1%A5%E5%8A%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771373211000.webp","sourceId":"rfi"},{"id":1771372892000,"createdDate":"2026-02-18 00:01","name":"法国国际广播电台","title":"央视春晚成了展示中国科技最新成果的重要舞台","content":"央视春晚上的功夫机器人吸引了法国世界报的关注。该报写道，此次央视春晚不仅是一场节日盛宴，也成为展示中国在机器人和人工智能领域最新成果的重要舞台。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260218-%E5%A4%AE%E8%A7%86%E6%98%A5%E6%99%9A%E6%88%90%E4%BA%86%E5%B1%95%E7%A4%BA%E4%B8%AD%E5%9B%BD%E7%A7%91%E6%8A%80%E6%9C%80%E6%96%B0%E6%88%90%E6%9E%9C%E7%9A%84%E9%87%8D%E8%A6%81%E8%88%9E%E5%8F%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/18/1771372892000.webp","sourceId":"rfi"}]