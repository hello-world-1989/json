[{"id":1770941643000,"createdDate":"2026-02-13 00:14","name":"法国国际广播电台","title":"乌克兰战争：是否重启与普京对话？欧洲分歧明显","content":"法国世界报周四刊出长篇文章表示，就乌克兰战争，欧洲在是否重启与普京对话问题上出现分歧。该报指出，法国总统马克龙试图说服欧洲各国领导人重新与克里姆林宫进行对话。不过，尽管和普京对话的问题如今已不再是禁忌，但是马克龙的倡议是否合适以及应该如何推进，欧洲各方的意见依然存在明显的分歧，","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260213-%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E4%BA%89-%E6%98%AF%E5%90%A6%E9%87%8D%E5%90%AF%E4%B8%8E%E6%99%AE%E4%BA%AC%E5%AF%B9%E8%AF%9D-%E6%AC%A7%E6%B4%B2%E5%88%86%E6%AD%A7%E6%98%8E%E6%98%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770941643000.webp","sourceId":"rfi"},{"id":1770941474000,"createdDate":"2026-02-13 00:11","name":"法国国际广播电台","title":"卢浮宫爆巨额门票诈骗案，一对中国籍导游夫妇涉案","content":"世界著名博物馆卢浮宫，在发生世纪大盗案之后，如今又爆出门票系统巨额诈骗案。一对在馆内活动的中国籍导游夫妇涉案。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260213-%E5%8D%A2%E6%B5%AE%E5%AE%AB%E7%88%86%E5%B7%A8%E9%A2%9D%E9%97%A8%E7%A5%A8%E8%AF%88%E9%AA%97%E6%A1%88%EF%BC%8C%E4%B8%80%E5%AF%B9%E4%B8%AD%E5%9B%BD%E7%B1%8D%E5%AF%BC%E6%B8%B8%E5%A4%AB%E5%A6%87%E6%B6%89%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770941474000.webp","sourceId":"rfi"},{"id":1770941443000,"createdDate":"2026-02-13 00:10","name":"法国国际广播电台","title":"日本扣押一艘中国渔船并逮捕船长","content":"法新社援引媒体周五报道称，日本当局扣押了一艘中国渔船并逮捕了船长，此举正值东京与北京之间关系本已紧张之际。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E6%97%A5%E6%9C%AC%E6%89%A3%E6%8A%BC%E4%B8%80%E8%89%98%E4%B8%AD%E5%9B%BD%E6%B8%94%E8%88%B9%E5%B9%B6%E9%80%AE%E6%8D%95%E8%88%B9%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770941443000.webp","sourceId":"rfi"},{"id":1770971373000,"createdDate":"2026-02-13 08:29","name":"法国国际广播电台","title":"报告：全球腐败恶化 香港反跃升至第12位 中国不变排第76位","content":"根据一项国际研究，全球腐败程度恶化，清廉指数十四年来首次下降，但香港反而跃升至第12位，在亚洲区内排第二，低于区内竞争对手新加坡，但高于排名在中档的台湾和中国内地。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260213-%E6%8A%A5%E5%91%8A-%E5%85%A8%E7%90%83%E8%85%90%E8%B4%A5%E6%81%B6%E5%8C%96-%E9%A6%99%E6%B8%AF%E5%8F%8D%E8%B7%83%E5%8D%87%E8%87%B3%E7%AC%AC12%E4%BD%8D-%E4%B8%AD%E5%9B%BD%E4%B8%8D%E5%8F%98%E6%8E%92%E7%AC%AC76%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770971373000.webp","sourceId":"rfi"},{"id":1770970892000,"createdDate":"2026-02-13 08:21","name":"法国国际广播电台","title":"就夺命大火发起联署的中大学生遭开除学籍 称事件源于\"政府意志\"","content":"造成168人死亡的香港大埔宏福苑火灾，有为灾情发起联署的学生继被警方拘捕后，遭就读的中文大学开除学籍。涉事学生关靖丰(MilesKwan)批评作出决定的纪律委员会不公平，认为自已虽未被起诉和定罪，却在“政府意志”和有人乐意惩罚政府希望打压者的情况下受到惩罚。消息在网上惹来网民一片骂声。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260213-%E5%B0%B1%E5%A4%BA%E5%91%BD%E5%A4%A7%E7%81%AB%E5%8F%91%E8%B5%B7%E8%81%94%E7%BD%B2%E7%9A%84%E4%B8%AD%E5%A4%A7%E5%AD%A6%E7%94%9F%E9%81%AD%E5%BC%80%E9%99%A4%E5%AD%A6%E7%B1%8D-%E7%A7%B0%E4%BA%8B%E4%BB%B6%E6%BA%90%E6%96%BC-%E6%94%BF%E5%BA%9C%E6%84%8F%E5%BF%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770970892000.webp","sourceId":"rfi"},{"id":1770970657000,"createdDate":"2026-02-13 08:17","name":"法国国际广播电台","title":"危害认定走入历史？特朗普政府气候政策再开倒车","content":"美国总统特朗普（DonaldTrump）政府本周四正式撤销2009年由环保署发布、认定温室气体危害公共健康与福祉的“危害认定”（endangermentfinding），一举动摇联邦气候监管的法律根基，形同拔除《清洁空气法》之下几乎所有减排规范的支柱。这项决定被白宫形容为“美国历史上规模最大的放松监管行动”，却也被环保团体痛批为，“对公共健康与气候安全最具破坏性的倒退”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260213-%E5%8D%B1%E5%AE%B3%E8%AE%A4%E5%AE%9A%E8%B5%B0%E5%85%A5%E5%8E%86%E5%8F%B2-%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E6%B0%94%E5%80%99%E6%94%BF%E7%AD%96%E5%86%8D%E5%BC%80%E5%80%92%E8%BD%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770970657000.webp","sourceId":"rfi"},{"id":1770970327000,"createdDate":"2026-02-13 08:12","name":"法国国际广播电台","title":"朝鲜警告：若再发现韩国无人机入侵朝鲜，将作出“严厉的回应”","content":"据朝中社消息，朝鲜周五（2月13日）警告称，若韩国的无人机再次入侵朝鲜，将作出“严厉的回应”。1月，一架韩国侦察无人机在朝韩边境附近被击落。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260213-%E6%9C%9D%E9%B2%9C%E8%AD%A6%E5%91%8A-%E8%8B%A5%E5%86%8D%E5%8F%91%E7%8E%B0%E9%9F%A9%E5%9B%BD%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%85%A5%E4%BE%B5%E6%9C%9D%E9%B2%9C%EF%BC%8C%E5%B0%86%E4%BD%9C%E5%87%BA-%E4%B8%A5%E5%8E%89%E7%9A%84%E5%9B%9E%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770970327000.webp","sourceId":"rfi"},{"id":1770948780000,"createdDate":"2026-02-13 02:13","name":"法国国际广播电台","title":"贸易战：欧洲准备好挑战中国了吗？","content":"法国总统埃马纽埃尔·马克龙在接受多家欧洲媒体采访时呼吁保护欧洲的工业。是巧合还是政府高层的偶然举动？2月9日星期一，法国战略与规划高级委员会发布了一份题为《欧洲工业面临中国碾压》的报告，建议欧洲对所有中国产品征收30%的关税。第二天，法国总统埃马纽埃尔·马克龙在接受多家欧洲媒体采访时呼吁“保护我们的工业。中国人正在这样做，美国人也在这样做。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E8%B4%B8%E6%98%93%E6%88%98-%E6%AC%A7%E6%B4%B2%E5%87%86%E5%A4%87%E5%A5%BD%E6%8C%91%E6%88%98%E4%B8%AD%E5%9B%BD%E4%BA%86%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770948780000.webp","sourceId":"rfi"}]