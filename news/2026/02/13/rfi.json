[{"id":1770941643000,"createdDate":"2026-02-13 00:14","name":"法国国际广播电台","title":"乌克兰战争：是否重启与普京对话？欧洲分歧明显","content":"法国世界报周四刊出长篇文章表示，就乌克兰战争，欧洲在是否重启与普京对话问题上出现分歧。该报指出，法国总统马克龙试图说服欧洲各国领导人重新与克里姆林宫进行对话。不过，尽管和普京对话的问题如今已不再是禁忌，但是马克龙的倡议是否合适以及应该如何推进，欧洲各方的意见依然存在明显的分歧，","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260213-%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E4%BA%89-%E6%98%AF%E5%90%A6%E9%87%8D%E5%90%AF%E4%B8%8E%E6%99%AE%E4%BA%AC%E5%AF%B9%E8%AF%9D-%E6%AC%A7%E6%B4%B2%E5%88%86%E6%AD%A7%E6%98%8E%E6%98%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770941643000.webp","sourceId":"rfi"},{"id":1770941474000,"createdDate":"2026-02-13 00:11","name":"法国国际广播电台","title":"卢浮宫爆巨额门票诈骗案，一对中国籍导游夫妇涉案","content":"世界著名博物馆卢浮宫，在发生世纪大盗案之后，如今又爆出门票系统巨额诈骗案。一对在馆内活动的中国籍导游夫妇涉案。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260213-%E5%8D%A2%E6%B5%AE%E5%AE%AB%E7%88%86%E5%B7%A8%E9%A2%9D%E9%97%A8%E7%A5%A8%E8%AF%88%E9%AA%97%E6%A1%88%EF%BC%8C%E4%B8%80%E5%AF%B9%E4%B8%AD%E5%9B%BD%E7%B1%8D%E5%AF%BC%E6%B8%B8%E5%A4%AB%E5%A6%87%E6%B6%89%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770941474000.webp","sourceId":"rfi"},{"id":1770941443000,"createdDate":"2026-02-13 00:10","name":"法国国际广播电台","title":"日本扣押一艘中国渔船并逮捕船长","content":"法新社援引媒体周五报道称，日本当局扣押了一艘中国渔船并逮捕了船长，此举正值东京与北京之间关系本已紧张之际。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E6%97%A5%E6%9C%AC%E6%89%A3%E6%8A%BC%E4%B8%80%E8%89%98%E4%B8%AD%E5%9B%BD%E6%B8%94%E8%88%B9%E5%B9%B6%E9%80%AE%E6%8D%95%E8%88%B9%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770941443000.webp","sourceId":"rfi"}]