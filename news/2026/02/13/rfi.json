[{"id":1770941643000,"createdDate":"2026-02-13 00:14","name":"法国国际广播电台","title":"乌克兰战争：是否重启与普京对话？欧洲分歧明显","content":"法国世界报周四刊出长篇文章表示，就乌克兰战争，欧洲在是否重启与普京对话问题上出现分歧。该报指出，法国总统马克龙试图说服欧洲各国领导人重新与克里姆林宫进行对话。不过，尽管和普京对话的问题如今已不再是禁忌，但是马克龙的倡议是否合适以及应该如何推进，欧洲各方的意见依然存在明显的分歧，","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260213-%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E4%BA%89-%E6%98%AF%E5%90%A6%E9%87%8D%E5%90%AF%E4%B8%8E%E6%99%AE%E4%BA%AC%E5%AF%B9%E8%AF%9D-%E6%AC%A7%E6%B4%B2%E5%88%86%E6%AD%A7%E6%98%8E%E6%98%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770941643000.webp","sourceId":"rfi"},{"id":1770941474000,"createdDate":"2026-02-13 00:11","name":"法国国际广播电台","title":"卢浮宫爆巨额门票诈骗案，一对中国籍导游夫妇涉案","content":"世界著名博物馆卢浮宫，在发生世纪大盗案之后，如今又爆出门票系统巨额诈骗案。一对在馆内活动的中国籍导游夫妇涉案。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260213-%E5%8D%A2%E6%B5%AE%E5%AE%AB%E7%88%86%E5%B7%A8%E9%A2%9D%E9%97%A8%E7%A5%A8%E8%AF%88%E9%AA%97%E6%A1%88%EF%BC%8C%E4%B8%80%E5%AF%B9%E4%B8%AD%E5%9B%BD%E7%B1%8D%E5%AF%BC%E6%B8%B8%E5%A4%AB%E5%A6%87%E6%B6%89%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770941474000.webp","sourceId":"rfi"},{"id":1770941443000,"createdDate":"2026-02-13 00:10","name":"法国国际广播电台","title":"日本扣押一艘中国渔船并逮捕船长","content":"法新社援引媒体周五报道称，日本当局扣押了一艘中国渔船并逮捕了船长，此举正值东京与北京之间关系本已紧张之际。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E6%97%A5%E6%9C%AC%E6%89%A3%E6%8A%BC%E4%B8%80%E8%89%98%E4%B8%AD%E5%9B%BD%E6%B8%94%E8%88%B9%E5%B9%B6%E9%80%AE%E6%8D%95%E8%88%B9%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770941443000.webp","sourceId":"rfi"},{"id":1770971373000,"createdDate":"2026-02-13 08:29","name":"法国国际广播电台","title":"报告：全球腐败恶化 香港反跃升至第12位 中国不变排第76位","content":"根据一项国际研究，全球腐败程度恶化，清廉指数十四年来首次下降，但香港反而跃升至第12位，在亚洲区内排第二，低于区内竞争对手新加坡，但高于排名在中档的台湾和中国内地。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260213-%E6%8A%A5%E5%91%8A-%E5%85%A8%E7%90%83%E8%85%90%E8%B4%A5%E6%81%B6%E5%8C%96-%E9%A6%99%E6%B8%AF%E5%8F%8D%E8%B7%83%E5%8D%87%E8%87%B3%E7%AC%AC12%E4%BD%8D-%E4%B8%AD%E5%9B%BD%E4%B8%8D%E5%8F%98%E6%8E%92%E7%AC%AC76%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770971373000.webp","sourceId":"rfi"},{"id":1770970892000,"createdDate":"2026-02-13 08:21","name":"法国国际广播电台","title":"就夺命大火发起联署的中大学生遭开除学籍 称事件源于\"政府意志\"","content":"造成168人死亡的香港大埔宏福苑火灾，有为灾情发起联署的学生继被警方拘捕后，遭就读的中文大学开除学籍。涉事学生关靖丰(MilesKwan)批评作出决定的纪律委员会不公平，认为自已虽未被起诉和定罪，却在“政府意志”和有人乐意惩罚政府希望打压者的情况下受到惩罚。消息在网上惹来网民一片骂声。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260213-%E5%B0%B1%E5%A4%BA%E5%91%BD%E5%A4%A7%E7%81%AB%E5%8F%91%E8%B5%B7%E8%81%94%E7%BD%B2%E7%9A%84%E4%B8%AD%E5%A4%A7%E5%AD%A6%E7%94%9F%E9%81%AD%E5%BC%80%E9%99%A4%E5%AD%A6%E7%B1%8D-%E7%A7%B0%E4%BA%8B%E4%BB%B6%E6%BA%90%E6%96%BC-%E6%94%BF%E5%BA%9C%E6%84%8F%E5%BF%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770970892000.webp","sourceId":"rfi"},{"id":1770970657000,"createdDate":"2026-02-13 08:17","name":"法国国际广播电台","title":"危害认定走入历史？特朗普政府气候政策再开倒车","content":"美国总统特朗普（DonaldTrump）政府本周四正式撤销2009年由环保署发布、认定温室气体危害公共健康与福祉的“危害认定”（endangermentfinding），一举动摇联邦气候监管的法律根基，形同拔除《清洁空气法》之下几乎所有减排规范的支柱。这项决定被白宫形容为“美国历史上规模最大的放松监管行动”，却也被环保团体痛批为，“对公共健康与气候安全最具破坏性的倒退”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260213-%E5%8D%B1%E5%AE%B3%E8%AE%A4%E5%AE%9A%E8%B5%B0%E5%85%A5%E5%8E%86%E5%8F%B2-%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E6%B0%94%E5%80%99%E6%94%BF%E7%AD%96%E5%86%8D%E5%BC%80%E5%80%92%E8%BD%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770970657000.webp","sourceId":"rfi"},{"id":1770970327000,"createdDate":"2026-02-13 08:12","name":"法国国际广播电台","title":"朝鲜警告：若再发现韩国无人机入侵朝鲜，将作出“严厉的回应”","content":"据朝中社消息，朝鲜周五（2月13日）警告称，若韩国的无人机再次入侵朝鲜，将作出“严厉的回应”。1月，一架韩国侦察无人机在朝韩边境附近被击落。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260213-%E6%9C%9D%E9%B2%9C%E8%AD%A6%E5%91%8A-%E8%8B%A5%E5%86%8D%E5%8F%91%E7%8E%B0%E9%9F%A9%E5%9B%BD%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%85%A5%E4%BE%B5%E6%9C%9D%E9%B2%9C%EF%BC%8C%E5%B0%86%E4%BD%9C%E5%87%BA-%E4%B8%A5%E5%8E%89%E7%9A%84%E5%9B%9E%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770970327000.webp","sourceId":"rfi"},{"id":1770948780000,"createdDate":"2026-02-13 02:13","name":"法国国际广播电台","title":"贸易战：欧洲准备好挑战中国了吗？","content":"法国总统埃马纽埃尔·马克龙在接受多家欧洲媒体采访时呼吁保护欧洲的工业。是巧合还是政府高层的偶然举动？2月9日星期一，法国战略与规划高级委员会发布了一份题为《欧洲工业面临中国碾压》的报告，建议欧洲对所有中国产品征收30%的关税。第二天，法国总统埃马纽埃尔·马克龙在接受多家欧洲媒体采访时呼吁“保护我们的工业。中国人正在这样做，美国人也在这样做。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E8%B4%B8%E6%98%93%E6%88%98-%E6%AC%A7%E6%B4%B2%E5%87%86%E5%A4%87%E5%A5%BD%E6%8C%91%E6%88%98%E4%B8%AD%E5%9B%BD%E4%BA%86%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770948780000.webp","sourceId":"rfi"},{"id":1770998934000,"createdDate":"2026-02-13 16:08","name":"法国国际广播电台","title":"俄罗斯异议人士霍多尔科夫斯基表示，与莫斯科对话欧洲应“统一发声”","content":"俄罗斯异议人士米哈伊尔·霍多尔科夫斯基周五接受法新社采访时表示，欧洲可能面临与俄罗斯长期紧张关系，堪比冷战，与莫斯科对话欧洲应“统一发声”，以确保自身利益得到重视。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-%E4%BF%84%E7%BD%97%E6%96%AF%E5%BC%82%E8%AE%AE%E4%BA%BA%E5%A3%AB%E9%9C%8D%E5%A4%9A%E5%B0%94%E7%A7%91%E5%A4%AB%E6%96%AF%E5%9F%BA%E8%A1%A8%E7%A4%BA%EF%BC%8C%E4%B8%8E%E8%8E%AB%E6%96%AF%E7%A7%91%E5%AF%B9%E8%AF%9D%E6%AC%A7%E6%B4%B2%E5%BA%94-%E7%BB%9F%E4%B8%80%E5%8F%91%E5%A3%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770998934000.webp","sourceId":"rfi"},{"id":1770991645000,"createdDate":"2026-02-13 14:07","name":"法国国际广播电台","title":"视频 第62届慕尼黑安全会议 卢比奥向欧洲施压","content":"有超过60位国家元首和政府首脑、约百位外交部长和国防部长以及来自120个国家的千多人出席慕尼黑安全会议，该会议被誉为“国防的达沃斯”，报道显示美国国务卿卢比奥继续对欧洲大陆的压力，请看France24的诺埃米·罗切报道","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E8%A7%86%E9%A2%91-%E7%AC%AC62%E5%B1%8A%E6%85%95%E5%B0%BC%E9%BB%91%E5%AE%89%E5%85%A8%E4%BC%9A%E8%AE%AE-%E5%8D%A2%E6%AF%94%E5%A5%A5%E5%90%91%E6%AC%A7%E6%B4%B2%E6%96%BD%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770991645000.webp","sourceId":"rfi"},{"id":1770991287000,"createdDate":"2026-02-13 14:01","name":"法国国际广播电台","title":"慕尼黑：美国务卿马可·卢比奥与中国外长王毅会晤","content":"美国国务卿马可·卢比奥周五在慕尼黑安全会议首日与中国外交部长王毅举行会谈。此时美中两国正展开激烈竞争。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-%E6%85%95%E5%B0%BC%E9%BB%91-%E7%BE%8E%E5%9B%BD%E5%8A%A1%E5%8D%BF%E9%A9%AC%E5%8F%AF%C2%B7%E5%8D%A2%E6%AF%94%E5%A5%A5%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%A4%96%E9%95%BF%E7%8E%8B%E6%AF%85%E4%BC%9A%E6%99%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770991287000.webp","sourceId":"rfi"},{"id":1770990233000,"createdDate":"2026-02-13 13:43","name":"法国国际广播电台","title":"日乌外长举行电话会谈 日本支援乌克兰越冬物资","content":"2月12日下午2点10分起约20分钟，日本外务大臣茂木敏充与乌克兰外交部长安德里·西比哈（AndriiSYBIHA）举行了电话会谈。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260213-%E6%97%A5%E4%B9%8C%E5%A4%96%E9%95%BF%E4%B8%BE%E8%A1%8C%E7%94%B5%E8%AF%9D%E4%BC%9A%E8%B0%88-%E6%97%A5%E6%9C%AC%E6%94%AF%E6%8F%B4%E4%B9%8C%E5%85%8B%E5%85%B0%E8%B6%8A%E5%86%AC%E7%89%A9%E8%B5%84","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770990233000.webp","sourceId":"rfi"},{"id":1770989436000,"createdDate":"2026-02-13 13:30","name":"法国国际广播电台","title":"慕尼黑：乌克兰外长称与中国外长讨论了“和平努力”","content":"乌克兰外交部长安德里·西比加（AndriïSybiga）周五表示，他在德国举行的慕尼黑年度安全会议期间，与中国外交部长王毅以讨论了“和平努力”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-%E6%85%95%E5%B0%BC%E9%BB%91-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%A4%96%E9%95%BF%E7%A7%B0%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%A4%96%E9%95%BF%E8%AE%A8%E8%AE%BA%E4%BA%86-%E5%92%8C%E5%B9%B3%E5%8A%AA%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770989436000.webp","sourceId":"rfi"},{"id":1770987275000,"createdDate":"2026-02-13 12:54","name":"法国国际广播电台","title":"SpaceX火箭载法国女宇航员索菲·阿德诺和两名美国宇航员及一名俄罗斯宇航员前往国际空间站","content":"美国太空探索技术公司（SpaceX）的一枚火箭于周五清晨从佛罗里达州发射升空，搭载着法国女宇航员索菲·阿德诺和两名美国宇航局（NASA）的宇航员以及一名俄罗斯宇航员，前往国际空间站（ISS）执行为期8-9个月的地球轨道科学任务。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-spacex%E7%81%AB%E7%AE%AD%E8%BD%BD%E6%B3%95%E5%9B%BD%E5%A5%B3%E5%AE%87%E8%88%AA%E5%91%98%E7%B4%A2%E8%8F%B2%C2%B7%E9%98%BF%E5%BE%B7%E8%AF%BA%E5%92%8C%E4%B8%A4%E5%90%8D%E7%BE%8E%E5%9B%BD%E5%AE%87%E8%88%AA%E5%91%98%E5%8F%8A%E4%B8%80%E5%90%8D%E4%BF%84%E7%BD%97%E6%96%AF%E5%AE%87%E8%88%AA%E5%91%98%E5%89%8D%E5%BE%80%E5%9B%BD%E9%99%85%E7%A9%BA%E9%97%B4%E7%AB%99","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770987275000.webp","sourceId":"rfi"},{"id":1770983330000,"createdDate":"2026-02-13 11:48","name":"法国国际广播电台","title":"日本扣押一艘中国渔船并逮捕船长：北京呼吁日本尊重船员的权利","content":"日本当局周五宣布扣押了一艘中国渔船并逮捕了该船的船长。该船当时位于日本专属经济区内。日本此举引发了北京的警告，中日两国关系正处于低谷。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-%E6%97%A5%E6%9C%AC%E6%89%A3%E6%8A%BC%E4%B8%80%E8%89%98%E4%B8%AD%E5%9B%BD%E6%B8%94%E8%88%B9%E5%B9%B6%E9%80%AE%E6%8D%95%E8%88%B9%E9%95%BF-%E5%8C%97%E4%BA%AC%E5%91%BC%E5%90%81%E6%97%A5%E6%9C%AC%E5%B0%8A%E9%87%8D%E8%88%B9%E5%91%98%E7%9A%84%E6%9D%83%E5%88%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770983330000.webp","sourceId":"rfi"},{"id":1770982173000,"createdDate":"2026-02-13 11:29","name":"法国国际广播电台","title":"视频：欧洲应对 GAFAM 在数字主权有哪些替代方案？","content":"布鲁塞尔和华盛顿之间的当前紧张关系凸显了欧洲在数字领域对美国的依赖。每年欧洲企业在云计算和软件方面的支出超过80%流向美国数字服务商，总额高达2640亿欧元。面对这种依赖，私营企业以及法国政府正在开发替代解决方案，请看艾丽丝·布罗加特、埃里卡·奥拉瓦里亚和托马斯·维洛的报道。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260213-%E8%A7%86%E9%A2%91-%E6%AC%A7%E6%B4%B2%E5%BA%94%E5%AF%B9-gafam-%E5%9C%A8%E6%95%B0%E5%AD%97%E4%B8%BB%E6%9D%83%E6%9C%89%E5%93%AA%E4%BA%9B%E6%9B%BF%E4%BB%A3%E6%96%B9%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770982173000.webp","sourceId":"rfi"},{"id":1770981763000,"createdDate":"2026-02-13 11:22","name":"法国国际广播电台","title":"“抹去五十年成果”？特朗普拆解气候监管基石","content":"周五，2月13日，法国主要日报聚焦美国环境政策、国际经济动向与科学探索等议题。《解放报》报道美国总统特朗普撤销构成气候监管法律基础的关键“危害性认定”，警示此举可能加剧空气污染，并削弱全球减排努力；《快报》分析美国贸易和货币政策对美元地位的影响，指出中国人民币有望借机提升国际使用比例；与此同时，《世界报》和《费加罗报》关注宇航员索菲·阿德诺——法国史上第二位前往太空的女性。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260213-%E7%89%B9%E6%9C%97%E6%99%AE%E5%BA%9F%E9%99%A4%E6%B0%94%E5%80%99%E6%B3%95%E8%A7%84%E5%BC%95%E5%8F%91%E4%BA%89%E8%AE%AE%EF%BC%8C%E7%BE%8E%E5%9B%BD%E7%8E%AF%E4%BF%9D%E6%94%BF%E7%AD%96%E9%9D%A2%E4%B8%B4%E9%87%8D%E5%A4%A7%E5%80%92%E9%80%80","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770981763000.webp","sourceId":"rfi"},{"id":1770981152000,"createdDate":"2026-02-13 11:12","name":"法国国际广播电台","title":"孟加拉国Z世代革命后首次选举：民族主义党获压倒性胜利，未来真的会好起来吗？","content":"孟加拉国民众于周四投票选举新一届议会，次日（2月13日），由塔里克·拉赫曼领导的孟加拉民族主义党（BNP）取得压倒性胜利。根据选举委员会公布的结果，民族主义党（BNP）在300个议席中赢得212席。由伊斯兰主义政党“伊斯兰大会党”（Jamaat-e-Islami）领导的联盟获得77席。因此可以说，孟加拉民族主义党（BNP）取得了压倒性的胜利。尽管竞选过程紧张且偶有暴力事件，但在超过30万名警察和士兵的安保下，周四的投票总体未发生重大事件。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260213-%E5%AD%9F%E5%8A%A0%E6%8B%89%E5%9B%BDz%E4%B8%96%E4%BB%A3%E9%9D%A9%E5%91%BD%E5%90%8E%E9%A6%96%E6%AC%A1%E9%80%89%E4%B8%BE-%E6%B0%91%E6%97%8F%E4%B8%BB%E4%B9%89%E5%85%9A%E8%8E%B7%E5%8E%8B%E5%80%92%E6%80%A7%E8%83%9C%E5%88%A9%EF%BC%8C%E6%9C%AA%E6%9D%A5%E7%9C%9F%E7%9A%84%E4%BC%9A%E5%A5%BD%E8%B5%B7%E6%9D%A5%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770981152000.webp","sourceId":"rfi"},{"id":1770976954000,"createdDate":"2026-02-13 10:02","name":"法国国际广播电台","title":"第62届慕尼黑安全会议开幕 默茨和马克龙发言是首日焦点","content":"第62届慕尼黑安全会议周五开幕，默茨与马克龙出席首日活动，丹麦首相将与美国国务卿卢比奥就格陵兰问题举行会谈。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-%E7%AC%AC62%E5%B1%8A%E6%85%95%E5%B0%BC%E9%BB%91%E5%AE%89%E5%85%A8%E4%BC%9A%E8%AE%AE%E5%BC%80%E5%B9%95-%E9%BB%98%E8%8C%A8%E5%92%8C%E9%A9%AC%E5%85%8B%E9%BE%99%E5%8F%91%E8%A8%80%E6%98%AF%E9%A6%96%E6%97%A5%E7%84%A6%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770976954000.webp","sourceId":"rfi"},{"id":1770974827000,"createdDate":"2026-02-13 09:27","name":"法国国际广播电台","title":"孟加拉国革命后首次选举：民族主义党获压倒性胜利","content":"孟加拉国选举委员会周五宣布，民族主义党（BNP）在议会选举中赢得绝对多数席位。这是自2024年夏季起义推翻前总理谢赫·哈西娜的强硬统治以来，该国举行的首次立法选举。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-%E5%AD%9F%E5%8A%A0%E6%8B%89%E5%9B%BD%E9%9D%A9%E5%91%BD%E5%90%8E%E9%A6%96%E6%AC%A1%E9%80%89%E4%B8%BE-%E6%B0%91%E6%97%8F%E4%B8%BB%E4%B9%89%E5%85%9A%E8%8E%B7%E5%8E%8B%E5%80%92%E6%80%A7%E8%83%9C%E5%88%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770974827000.webp","sourceId":"rfi"}]