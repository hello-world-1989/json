[{"id":1770941643000,"createdDate":"2026-02-13 00:14","name":"法国国际广播电台","title":"乌克兰战争：是否重启与普京对话？欧洲分歧明显","content":"法国世界报周四刊出长篇文章表示，就乌克兰战争，欧洲在是否重启与普京对话问题上出现分歧。该报指出，法国总统马克龙试图说服欧洲各国领导人重新与克里姆林宫进行对话。不过，尽管和普京对话的问题如今已不再是禁忌，但是马克龙的倡议是否合适以及应该如何推进，欧洲各方的意见依然存在明显的分歧，","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260213-%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E4%BA%89-%E6%98%AF%E5%90%A6%E9%87%8D%E5%90%AF%E4%B8%8E%E6%99%AE%E4%BA%AC%E5%AF%B9%E8%AF%9D-%E6%AC%A7%E6%B4%B2%E5%88%86%E6%AD%A7%E6%98%8E%E6%98%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770941643000.webp","sourceId":"rfi"},{"id":1770941474000,"createdDate":"2026-02-13 00:11","name":"法国国际广播电台","title":"卢浮宫爆巨额门票诈骗案，一对中国籍导游夫妇涉案","content":"世界著名博物馆卢浮宫，在发生世纪大盗案之后，如今又爆出门票系统巨额诈骗案。一对在馆内活动的中国籍导游夫妇涉案。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260213-%E5%8D%A2%E6%B5%AE%E5%AE%AB%E7%88%86%E5%B7%A8%E9%A2%9D%E9%97%A8%E7%A5%A8%E8%AF%88%E9%AA%97%E6%A1%88%EF%BC%8C%E4%B8%80%E5%AF%B9%E4%B8%AD%E5%9B%BD%E7%B1%8D%E5%AF%BC%E6%B8%B8%E5%A4%AB%E5%A6%87%E6%B6%89%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770941474000.webp","sourceId":"rfi"},{"id":1770941443000,"createdDate":"2026-02-13 00:10","name":"法国国际广播电台","title":"日本扣押一艘中国渔船并逮捕船长","content":"法新社援引媒体周五报道称，日本当局扣押了一艘中国渔船并逮捕了船长，此举正值东京与北京之间关系本已紧张之际。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E6%97%A5%E6%9C%AC%E6%89%A3%E6%8A%BC%E4%B8%80%E8%89%98%E4%B8%AD%E5%9B%BD%E6%B8%94%E8%88%B9%E5%B9%B6%E9%80%AE%E6%8D%95%E8%88%B9%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770941443000.webp","sourceId":"rfi"},{"id":1770971373000,"createdDate":"2026-02-13 08:29","name":"法国国际广播电台","title":"报告：全球腐败恶化 香港反跃升至第12位 中国不变排第76位","content":"根据一项国际研究，全球腐败程度恶化，清廉指数十四年来首次下降，但香港反而跃升至第12位，在亚洲区内排第二，低于区内竞争对手新加坡，但高于排名在中档的台湾和中国内地。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260213-%E6%8A%A5%E5%91%8A-%E5%85%A8%E7%90%83%E8%85%90%E8%B4%A5%E6%81%B6%E5%8C%96-%E9%A6%99%E6%B8%AF%E5%8F%8D%E8%B7%83%E5%8D%87%E8%87%B3%E7%AC%AC12%E4%BD%8D-%E4%B8%AD%E5%9B%BD%E4%B8%8D%E5%8F%98%E6%8E%92%E7%AC%AC76%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770971373000.webp","sourceId":"rfi"},{"id":1770970892000,"createdDate":"2026-02-13 08:21","name":"法国国际广播电台","title":"就夺命大火发起联署的中大学生遭开除学籍 称事件源于\"政府意志\"","content":"造成168人死亡的香港大埔宏福苑火灾，有为灾情发起联署的学生继被警方拘捕后，遭就读的中文大学开除学籍。涉事学生关靖丰(MilesKwan)批评作出决定的纪律委员会不公平，认为自已虽未被起诉和定罪，却在“政府意志”和有人乐意惩罚政府希望打压者的情况下受到惩罚。消息在网上惹来网民一片骂声。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260213-%E5%B0%B1%E5%A4%BA%E5%91%BD%E5%A4%A7%E7%81%AB%E5%8F%91%E8%B5%B7%E8%81%94%E7%BD%B2%E7%9A%84%E4%B8%AD%E5%A4%A7%E5%AD%A6%E7%94%9F%E9%81%AD%E5%BC%80%E9%99%A4%E5%AD%A6%E7%B1%8D-%E7%A7%B0%E4%BA%8B%E4%BB%B6%E6%BA%90%E6%96%BC-%E6%94%BF%E5%BA%9C%E6%84%8F%E5%BF%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770970892000.webp","sourceId":"rfi"},{"id":1770970657000,"createdDate":"2026-02-13 08:17","name":"法国国际广播电台","title":"危害认定走入历史？特朗普政府气候政策再开倒车","content":"美国总统特朗普（DonaldTrump）政府本周四正式撤销2009年由环保署发布、认定温室气体危害公共健康与福祉的“危害认定”（endangermentfinding），一举动摇联邦气候监管的法律根基，形同拔除《清洁空气法》之下几乎所有减排规范的支柱。这项决定被白宫形容为“美国历史上规模最大的放松监管行动”，却也被环保团体痛批为，“对公共健康与气候安全最具破坏性的倒退”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260213-%E5%8D%B1%E5%AE%B3%E8%AE%A4%E5%AE%9A%E8%B5%B0%E5%85%A5%E5%8E%86%E5%8F%B2-%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E6%B0%94%E5%80%99%E6%94%BF%E7%AD%96%E5%86%8D%E5%BC%80%E5%80%92%E8%BD%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770970657000.webp","sourceId":"rfi"},{"id":1770970327000,"createdDate":"2026-02-13 08:12","name":"法国国际广播电台","title":"朝鲜警告：若再发现韩国无人机入侵朝鲜，将作出“严厉的回应”","content":"据朝中社消息，朝鲜周五（2月13日）警告称，若韩国的无人机再次入侵朝鲜，将作出“严厉的回应”。1月，一架韩国侦察无人机在朝韩边境附近被击落。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260213-%E6%9C%9D%E9%B2%9C%E8%AD%A6%E5%91%8A-%E8%8B%A5%E5%86%8D%E5%8F%91%E7%8E%B0%E9%9F%A9%E5%9B%BD%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%85%A5%E4%BE%B5%E6%9C%9D%E9%B2%9C%EF%BC%8C%E5%B0%86%E4%BD%9C%E5%87%BA-%E4%B8%A5%E5%8E%89%E7%9A%84%E5%9B%9E%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770970327000.webp","sourceId":"rfi"},{"id":1770948780000,"createdDate":"2026-02-13 02:13","name":"法国国际广播电台","title":"贸易战：欧洲准备好挑战中国了吗？","content":"法国总统埃马纽埃尔·马克龙在接受多家欧洲媒体采访时呼吁保护欧洲的工业。是巧合还是政府高层的偶然举动？2月9日星期一，法国战略与规划高级委员会发布了一份题为《欧洲工业面临中国碾压》的报告，建议欧洲对所有中国产品征收30%的关税。第二天，法国总统埃马纽埃尔·马克龙在接受多家欧洲媒体采访时呼吁“保护我们的工业。中国人正在这样做，美国人也在这样做。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E8%B4%B8%E6%98%93%E6%88%98-%E6%AC%A7%E6%B4%B2%E5%87%86%E5%A4%87%E5%A5%BD%E6%8C%91%E6%88%98%E4%B8%AD%E5%9B%BD%E4%BA%86%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770948780000.webp","sourceId":"rfi"},{"id":1770998934000,"createdDate":"2026-02-13 16:08","name":"法国国际广播电台","title":"俄罗斯异议人士霍多尔科夫斯基表示，与莫斯科对话欧洲应“统一发声”","content":"俄罗斯异议人士米哈伊尔·霍多尔科夫斯基周五接受法新社采访时表示，欧洲可能面临与俄罗斯长期紧张关系，堪比冷战，与莫斯科对话欧洲应“统一发声”，以确保自身利益得到重视。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-%E4%BF%84%E7%BD%97%E6%96%AF%E5%BC%82%E8%AE%AE%E4%BA%BA%E5%A3%AB%E9%9C%8D%E5%A4%9A%E5%B0%94%E7%A7%91%E5%A4%AB%E6%96%AF%E5%9F%BA%E8%A1%A8%E7%A4%BA%EF%BC%8C%E4%B8%8E%E8%8E%AB%E6%96%AF%E7%A7%91%E5%AF%B9%E8%AF%9D%E6%AC%A7%E6%B4%B2%E5%BA%94-%E7%BB%9F%E4%B8%80%E5%8F%91%E5%A3%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770998934000.webp","sourceId":"rfi"},{"id":1770991645000,"createdDate":"2026-02-13 14:07","name":"法国国际广播电台","title":"视频 第62届慕尼黑安全会议 卢比奥向欧洲施压","content":"有超过60位国家元首和政府首脑、约百位外交部长和国防部长以及来自120个国家的千多人出席慕尼黑安全会议，该会议被誉为“国防的达沃斯”，报道显示美国国务卿卢比奥继续对欧洲大陆的压力，请看France24的诺埃米·罗切报道","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E8%A7%86%E9%A2%91-%E7%AC%AC62%E5%B1%8A%E6%85%95%E5%B0%BC%E9%BB%91%E5%AE%89%E5%85%A8%E4%BC%9A%E8%AE%AE-%E5%8D%A2%E6%AF%94%E5%A5%A5%E5%90%91%E6%AC%A7%E6%B4%B2%E6%96%BD%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770991645000.webp","sourceId":"rfi"},{"id":1770991287000,"createdDate":"2026-02-13 14:01","name":"法国国际广播电台","title":"慕尼黑：美国务卿马可·卢比奥与中国外长王毅会晤","content":"美国国务卿马可·卢比奥周五在慕尼黑安全会议首日与中国外交部长王毅举行会谈。此时美中两国正展开激烈竞争。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-%E6%85%95%E5%B0%BC%E9%BB%91-%E7%BE%8E%E5%9B%BD%E5%8A%A1%E5%8D%BF%E9%A9%AC%E5%8F%AF%C2%B7%E5%8D%A2%E6%AF%94%E5%A5%A5%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%A4%96%E9%95%BF%E7%8E%8B%E6%AF%85%E4%BC%9A%E6%99%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770991287000.webp","sourceId":"rfi"},{"id":1770990233000,"createdDate":"2026-02-13 13:43","name":"法国国际广播电台","title":"日乌外长举行电话会谈 日本支援乌克兰越冬物资","content":"2月12日下午2点10分起约20分钟，日本外务大臣茂木敏充与乌克兰外交部长安德里·西比哈（AndriiSYBIHA）举行了电话会谈。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260213-%E6%97%A5%E4%B9%8C%E5%A4%96%E9%95%BF%E4%B8%BE%E8%A1%8C%E7%94%B5%E8%AF%9D%E4%BC%9A%E8%B0%88-%E6%97%A5%E6%9C%AC%E6%94%AF%E6%8F%B4%E4%B9%8C%E5%85%8B%E5%85%B0%E8%B6%8A%E5%86%AC%E7%89%A9%E8%B5%84","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770990233000.webp","sourceId":"rfi"},{"id":1770989436000,"createdDate":"2026-02-13 13:30","name":"法国国际广播电台","title":"慕尼黑：乌克兰外长称与中国外长讨论了“和平努力”","content":"乌克兰外交部长安德里·西比加（AndriïSybiga）周五表示，他在德国举行的慕尼黑年度安全会议期间，与中国外交部长王毅以讨论了“和平努力”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-%E6%85%95%E5%B0%BC%E9%BB%91-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%A4%96%E9%95%BF%E7%A7%B0%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%A4%96%E9%95%BF%E8%AE%A8%E8%AE%BA%E4%BA%86-%E5%92%8C%E5%B9%B3%E5%8A%AA%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770989436000.webp","sourceId":"rfi"},{"id":1770987275000,"createdDate":"2026-02-13 12:54","name":"法国国际广播电台","title":"SpaceX火箭载法国女宇航员索菲·阿德诺和两名美国宇航员及一名俄罗斯宇航员前往国际空间站","content":"美国太空探索技术公司（SpaceX）的一枚火箭于周五清晨从佛罗里达州发射升空，搭载着法国女宇航员索菲·阿德诺和两名美国宇航局（NASA）的宇航员以及一名俄罗斯宇航员，前往国际空间站（ISS）执行为期8-9个月的地球轨道科学任务。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-spacex%E7%81%AB%E7%AE%AD%E8%BD%BD%E6%B3%95%E5%9B%BD%E5%A5%B3%E5%AE%87%E8%88%AA%E5%91%98%E7%B4%A2%E8%8F%B2%C2%B7%E9%98%BF%E5%BE%B7%E8%AF%BA%E5%92%8C%E4%B8%A4%E5%90%8D%E7%BE%8E%E5%9B%BD%E5%AE%87%E8%88%AA%E5%91%98%E5%8F%8A%E4%B8%80%E5%90%8D%E4%BF%84%E7%BD%97%E6%96%AF%E5%AE%87%E8%88%AA%E5%91%98%E5%89%8D%E5%BE%80%E5%9B%BD%E9%99%85%E7%A9%BA%E9%97%B4%E7%AB%99","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770987275000.webp","sourceId":"rfi"},{"id":1770983330000,"createdDate":"2026-02-13 11:48","name":"法国国际广播电台","title":"日本扣押一艘中国渔船并逮捕船长：北京呼吁日本尊重船员的权利","content":"日本当局周五宣布扣押了一艘中国渔船并逮捕了该船的船长。该船当时位于日本专属经济区内。日本此举引发了北京的警告，中日两国关系正处于低谷。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-%E6%97%A5%E6%9C%AC%E6%89%A3%E6%8A%BC%E4%B8%80%E8%89%98%E4%B8%AD%E5%9B%BD%E6%B8%94%E8%88%B9%E5%B9%B6%E9%80%AE%E6%8D%95%E8%88%B9%E9%95%BF-%E5%8C%97%E4%BA%AC%E5%91%BC%E5%90%81%E6%97%A5%E6%9C%AC%E5%B0%8A%E9%87%8D%E8%88%B9%E5%91%98%E7%9A%84%E6%9D%83%E5%88%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770983330000.webp","sourceId":"rfi"},{"id":1770982173000,"createdDate":"2026-02-13 11:29","name":"法国国际广播电台","title":"视频：欧洲应对 GAFAM 在数字主权有哪些替代方案？","content":"布鲁塞尔和华盛顿之间的当前紧张关系凸显了欧洲在数字领域对美国的依赖。每年欧洲企业在云计算和软件方面的支出超过80%流向美国数字服务商，总额高达2640亿欧元。面对这种依赖，私营企业以及法国政府正在开发替代解决方案，请看艾丽丝·布罗加特、埃里卡·奥拉瓦里亚和托马斯·维洛的报道。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260213-%E8%A7%86%E9%A2%91-%E6%AC%A7%E6%B4%B2%E5%BA%94%E5%AF%B9-gafam-%E5%9C%A8%E6%95%B0%E5%AD%97%E4%B8%BB%E6%9D%83%E6%9C%89%E5%93%AA%E4%BA%9B%E6%9B%BF%E4%BB%A3%E6%96%B9%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770982173000.webp","sourceId":"rfi"},{"id":1770981763000,"createdDate":"2026-02-13 11:22","name":"法国国际广播电台","title":"“抹去五十年成果”？特朗普拆解气候监管基石","content":"周五，2月13日，法国主要日报聚焦美国环境政策、国际经济动向与科学探索等议题。《解放报》报道美国总统特朗普撤销构成气候监管法律基础的关键“危害性认定”，警示此举可能加剧空气污染，并削弱全球减排努力；《快报》分析美国贸易和货币政策对美元地位的影响，指出中国人民币有望借机提升国际使用比例；与此同时，《世界报》和《费加罗报》关注宇航员索菲·阿德诺——法国史上第二位前往太空的女性。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260213-%E7%89%B9%E6%9C%97%E6%99%AE%E5%BA%9F%E9%99%A4%E6%B0%94%E5%80%99%E6%B3%95%E8%A7%84%E5%BC%95%E5%8F%91%E4%BA%89%E8%AE%AE%EF%BC%8C%E7%BE%8E%E5%9B%BD%E7%8E%AF%E4%BF%9D%E6%94%BF%E7%AD%96%E9%9D%A2%E4%B8%B4%E9%87%8D%E5%A4%A7%E5%80%92%E9%80%80","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770981763000.webp","sourceId":"rfi"},{"id":1770981152000,"createdDate":"2026-02-13 11:12","name":"法国国际广播电台","title":"孟加拉国Z世代革命后首次选举：民族主义党获压倒性胜利，未来真的会好起来吗？","content":"孟加拉国民众于周四投票选举新一届议会，次日（2月13日），由塔里克·拉赫曼领导的孟加拉民族主义党（BNP）取得压倒性胜利。根据选举委员会公布的结果，民族主义党（BNP）在300个议席中赢得212席。由伊斯兰主义政党“伊斯兰大会党”（Jamaat-e-Islami）领导的联盟获得77席。因此可以说，孟加拉民族主义党（BNP）取得了压倒性的胜利。尽管竞选过程紧张且偶有暴力事件，但在超过30万名警察和士兵的安保下，周四的投票总体未发生重大事件。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260213-%E5%AD%9F%E5%8A%A0%E6%8B%89%E5%9B%BDz%E4%B8%96%E4%BB%A3%E9%9D%A9%E5%91%BD%E5%90%8E%E9%A6%96%E6%AC%A1%E9%80%89%E4%B8%BE-%E6%B0%91%E6%97%8F%E4%B8%BB%E4%B9%89%E5%85%9A%E8%8E%B7%E5%8E%8B%E5%80%92%E6%80%A7%E8%83%9C%E5%88%A9%EF%BC%8C%E6%9C%AA%E6%9D%A5%E7%9C%9F%E7%9A%84%E4%BC%9A%E5%A5%BD%E8%B5%B7%E6%9D%A5%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770981152000.webp","sourceId":"rfi"},{"id":1770976954000,"createdDate":"2026-02-13 10:02","name":"法国国际广播电台","title":"第62届慕尼黑安全会议开幕 默茨和马克龙发言是首日焦点","content":"第62届慕尼黑安全会议周五开幕，默茨与马克龙出席首日活动，丹麦首相将与美国国务卿卢比奥就格陵兰问题举行会谈。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-%E7%AC%AC62%E5%B1%8A%E6%85%95%E5%B0%BC%E9%BB%91%E5%AE%89%E5%85%A8%E4%BC%9A%E8%AE%AE%E5%BC%80%E5%B9%95-%E9%BB%98%E8%8C%A8%E5%92%8C%E9%A9%AC%E5%85%8B%E9%BE%99%E5%8F%91%E8%A8%80%E6%98%AF%E9%A6%96%E6%97%A5%E7%84%A6%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770976954000.webp","sourceId":"rfi"},{"id":1770974827000,"createdDate":"2026-02-13 09:27","name":"法国国际广播电台","title":"孟加拉国革命后首次选举：民族主义党获压倒性胜利","content":"孟加拉国选举委员会周五宣布，民族主义党（BNP）在议会选举中赢得绝对多数席位。这是自2024年夏季起义推翻前总理谢赫·哈西娜的强硬统治以来，该国举行的首次立法选举。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260213-%E5%AD%9F%E5%8A%A0%E6%8B%89%E5%9B%BD%E9%9D%A9%E5%91%BD%E5%90%8E%E9%A6%96%E6%AC%A1%E9%80%89%E4%B8%BE-%E6%B0%91%E6%97%8F%E4%B8%BB%E4%B9%89%E5%85%9A%E8%8E%B7%E5%8E%8B%E5%80%92%E6%80%A7%E8%83%9C%E5%88%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1770974827000.webp","sourceId":"rfi"},{"id":1771027156000,"createdDate":"2026-02-13 23:59","name":"法国国际广播电台","title":"香港开始采用中国内地常见的做法：打击流亡异议人士的亲属","content":"法国世界报周五关注流亡海外的香港异议人士的家人开始成为当局打击的目标。该报表示，在对仍然留在香港的反对派人士作出判决之后，香港当局如今将矛头指向了那些已经离开的异议人士的家属。这标志着香港开始采用一种在中国内地早已司空见惯的做法：对身在海外的异议人士的亲属作为打击的对象。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260213-%E9%A6%99%E6%B8%AF%E5%BC%80%E5%A7%8B%E9%87%87%E7%94%A8%E4%B8%AD%E5%9B%BD%E5%86%85%E5%9C%B0%E5%B8%B8%E8%A7%81%E7%9A%84%E5%81%9A%E6%B3%95-%E6%89%93%E5%87%BB%E6%B5%81%E4%BA%A1%E5%BC%82%E8%AE%AE%E4%BA%BA%E5%A3%AB%E7%9A%84%E4%BA%B2%E5%B1%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1771027156000.webp","sourceId":"rfi"},{"id":1771023742000,"createdDate":"2026-02-13 23:02","name":"法国国际广播电台","title":"欧洲力图抹去万斯留下的不良印象","content":"万斯给欧洲人留下恶劣的印象，始于去年的慕尼黑安全会议，令欧洲震惊的是，这位上任才两月的美国副总统，满口教训欧洲如何做的语气，认为欧洲文明面临消亡危险，批评欧洲反民主排挤极右翼，对乌克兰战争采信俄方逻辑，形同拉开了几天后泽连斯基在白宫受辱的序曲，也敲响了美国至少部分拆毁自己亲手参与缔造的战后秩序的警钟。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E6%AC%A7%E6%B4%B2%E5%8A%9B%E5%9B%BE%E6%8A%B9%E5%8E%BB%E4%B8%87%E6%96%AF%E7%95%99%E4%B8%8B%E7%9A%84%E4%B8%8D%E8%89%AF%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1771023742000.webp","sourceId":"rfi"},{"id":1771021805000,"createdDate":"2026-02-13 22:30","name":"法国国际广播电台","title":"中央情报局为何公开招募中国军方线人？","content":"中国军队大整肃、高级将领纷纷落马之际，美国中央情报局发布视频公开在中国军队内部招募线人，此举招致北京愤怒，声称“将采取一切必要措施”粉碎图谋。不过，中情局如此招摇，也令人质疑其意图何在。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E4%B8%AD%E5%A4%AE%E6%83%85%E6%8A%A5%E5%B1%80%E4%B8%BA%E4%BD%95%E5%85%AC%E5%BC%80%E6%8B%9B%E5%8B%9F%E4%B8%AD%E5%9B%BD%E5%86%9B%E6%96%B9%E7%BA%BF%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1771021805000.webp","sourceId":"rfi"},{"id":1771019108000,"createdDate":"2026-02-13 21:45","name":"法国国际广播电台","title":"春节出境游回温 中国游客涌向俄澳泰韩 日本热度下滑","content":"随着农历新年长假即将来临，中国出境旅游明显升温。多家旅游机构表示，今年春节期间出国旅游人数预计将超过往年，俄罗斯、澳大利亚、泰国和韩国成为热门目的地，日本的吸引力则不如以往。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E6%98%A5%E8%8A%82%E5%87%BA%E5%A2%83%E6%B8%B8%E5%9B%9E%E6%B8%A9-%E4%B8%AD%E5%9B%BD%E6%B8%B8%E5%AE%A2%E6%B6%8C%E5%90%91%E4%BF%84%E6%BE%B3%E6%B3%B0%E9%9F%A9-%E6%97%A5%E6%9C%AC%E7%83%AD%E5%BA%A6%E4%B8%8B%E6%BB%91","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1771019108000.webp","sourceId":"rfi"},{"id":1771018835000,"createdDate":"2026-02-13 21:40","name":"法国国际广播电台","title":"海地招募警员在青年中获成功","content":"位于中美洲地区的岛国海地（Haïti）开始加强警力。本台法广（RFI）法语特派记者在该国首都的一座警察局前看到当地青年踊跃报名加入警察队伍。海地当局打算在今年（2026年）年底前增加警力大约4000人。这项计划的部分资金是由美国提供。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260213-%E6%B3%95%E5%B9%BF-rfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E6%B3%95%E8%AF%AD%E5%9B%BD%E5%AE%B6-%E6%B5%B7%E5%9C%B0%E6%8B%9B%E5%8B%9F%E8%AD%A6%E5%91%98%E5%9C%A8%E9%9D%92%E5%B9%B4%E4%B8%AD%E8%8E%B7%E6%88%90%E5%8A%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1771018835000.webp","sourceId":"rfi"},{"id":1771018821000,"createdDate":"2026-02-13 21:40","name":"法国国际广播电台","title":"美国撤回涉华军方企业更新名单 阿里巴巴、百度等在列后被移出","content":"美国政府周五(2月13日）稍早发布并更新了一份被指协助中国军方的中国企业名单，但在名单上线约一小时后即予以撤回。更新版本中新增多家中国大型企业，包括阿里巴巴和百度。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E7%BE%8E%E5%9B%BD%E6%92%A4%E5%9B%9E%E6%B6%89%E5%8D%8E%E5%86%9B%E6%96%B9%E4%BC%81%E4%B8%9A%E6%9B%B4%E6%96%B0%E5%90%8D%E5%8D%95-%E9%98%BF%E9%87%8C%E5%B7%B4%E5%B7%B4-%E7%99%BE%E5%BA%A6%E7%AD%89%E5%9C%A8%E5%88%97%E5%90%8E%E8%A2%AB%E7%A7%BB%E5%87%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1771018821000.webp","sourceId":"rfi"},{"id":1771018556000,"createdDate":"2026-02-13 21:35","name":"法国国际广播电台","title":"核谈判施压伊朗 特朗普派遣第二支航母打击群前往中东","content":"美国总统特朗普周五(2月13日）宣布，将“很快”向中东部署第二艘航空母舰，以强化对伊朗的军事威慑。特朗普同时警告，如果围绕伊朗核问题的外交谈判失败，伊朗将面临“极为严重”的后果。美伊一周前在阿曼重启谈判，但前景仍不明朗；国际原子能机构表示，与德黑兰就核查问题达成协议“极其困难”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E6%A0%B8%E8%B0%88%E5%88%A4%E6%96%BD%E5%8E%8B%E4%BC%8A%E6%9C%97-%E7%89%B9%E6%9C%97%E6%99%AE%E6%B4%BE%E9%81%A3%E7%AC%AC%E4%BA%8C%E6%94%AF%E8%88%AA%E6%AF%8D%E6%89%93%E5%87%BB%E7%BE%A4%E5%89%8D%E5%BE%80%E4%B8%AD%E4%B8%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1771018556000.webp","sourceId":"rfi"},{"id":1771018297000,"createdDate":"2026-02-13 21:31","name":"法国国际广播电台","title":"慕尼黑安全会议聚焦美欧裂痕：欧洲呼吁华盛顿回归理性 默茨敦促重建跨大西洋信任","content":"第62届慕尼黑安全会议在美国总统特朗普执政、美欧关系出现裂痕的背景下开幕。与会的欧洲各国领导人周五(2月13日）一致呼吁华盛顿“回归理性”，修复跨大西洋互信关系。法国总统马克龙批评外界长期以来以偏见和刻板印象歪曲欧洲形象，强调欧洲不应被丑化为一个衰落、失去活力的大陆，而应成为值得借鉴的“样板”；德国总理默茨则敦促与“美国朋友”携手“重振跨大西洋信任关系”。乌克兰战争、欧洲防务自主、格陵兰争议以及伊朗核问题，构成本届会议的核心议题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260213-%E6%85%95%E5%B0%BC%E9%BB%91%E5%AE%89%E5%85%A8%E4%BC%9A%E8%AE%AE%E8%81%9A%E7%84%A6%E7%BE%8E%E6%AC%A7%E8%A3%82%E7%97%95-%E6%AC%A7%E6%B4%B2%E5%91%BC%E5%90%81%E5%8D%8E%E7%9B%9B%E9%A1%BF%E5%9B%9E%E5%BD%92%E7%90%86%E6%80%A7-%E9%BB%98%E8%8C%A8%E6%95%A6%E4%BF%83%E9%87%8D%E5%BB%BA%E8%B7%A8%E5%A4%A7%E8%A5%BF%E6%B4%8B%E4%BF%A1%E4%BB%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1771018297000.webp","sourceId":"rfi"},{"id":1771011975000,"createdDate":"2026-02-13 19:46","name":"法国国际广播电台","title":"法国驻海地大使接受法广专访","content":"欢迎您进入法国国际广播电台（RadioFranceInternationale）中文节目[法语世界]（Chroniquefrancophonie）专栏的第144集。今天是2026年02月13日星期五。在本次节目时间里，我们向大家介绍本台法广(RFI)法语栏目[国际大咖嘉宾]（Legrandinvitéinternational）专栏记者朱利安（Julien）对法国驻海地大使安托万·米雄（MonsieurAntoineMichon）的采访录音片段，介绍加勒比海水域里的法语国家海地（Haïti）恢复治安有了新希望。这集节目由尼古拉编译和播报，感谢收听。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C/20260213-%E6%B3%95%E5%B9%BF-rfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C-%E7%AC%AC144%E9%9B%86-%E6%B3%95%E5%9B%BD%E9%A9%BB%E6%B5%B7%E5%9C%B0%E5%A4%A7%E4%BD%BF%E6%8E%A5%E5%8F%97%E6%B3%95%E5%B9%BF%E4%B8%93%E8%AE%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1771011975000.webp","sourceId":"rfi"},{"id":1771005264000,"createdDate":"2026-02-13 17:54","name":"法国国际广播电台","title":"长江十年禁鱼政策成绩显著  却难使灭绝物种起死回生","content":"国际著名的科学杂志2月12日发表了由多位中国学者与一名法国学者联名发表的有关长江禁渔政策的研究文章，文章的标题是 Fishingbanhaltssevendecades ofbiodiversitydeclineinthe YangtzeRiver（禁渔政策遏制了长江七十年来生物多样性的衰退）文章指出，中国从2021年开始推行的在长江支流以及干流上全面禁渔的政策在短短的时间内取得了显著的成果，虽然这些成果依然十分脆弱，文章却认为中国禁渔政策的经验值得他国的借鉴，亚马逊河以及湄公河等生物多样性受到威胁的河流或者可以效仿中国政府的做法 。不过，旅居德国的中国水利专家，对长江的生物多样性关注多年的王维洛先生却对这篇文章的科学性提出质疑。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E5%A2%83%E4%B8%8E%E5%8F%91%E5%B1%95/20260213-%E9%95%BF%E6%B1%9F%E5%8D%81%E5%B9%B4%E7%A6%81%E9%B1%BC%E6%94%BF%E7%AD%96%E6%88%90%E7%BB%A9%E6%98%BE%E8%91%97-%E5%8D%B4%E9%9A%BE%E9%81%8F%E5%88%B6%E6%BF%92%E5%8D%B1%E7%89%A9%E7%A7%8D%E7%9A%84%E6%B6%88%E5%A4%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1771005264000.webp","sourceId":"rfi"},{"id":1771002379000,"createdDate":"2026-02-13 17:06","name":"法国国际广播电台","title":"美国封锁能源 重创古巴旅游业 酒店关闭、航班停飞、计程车停运...","content":"法新社2月13日哈瓦那报道说：酒店关闭、航班停飞、旅游项目取消……华盛顿对古巴施加的能源“紧箍咒”正给该国的旅游业致命一击。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260213-%E7%BE%8E%E5%9B%BD%E5%B0%81%E9%94%81%E8%83%BD%E6%BA%90-%E9%87%8D%E5%88%9B%E5%8F%A4%E5%B7%B4%E6%97%85%E6%B8%B8%E4%B8%9A-%E9%85%92%E5%BA%97%E5%85%B3%E9%97%AD-%E8%88%AA%E7%8F%AD%E5%81%9C%E9%A3%9E-%E8%AE%A1%E7%A8%8B%E8%BD%A6%E5%81%9C%E8%BF%90","thumbnail":"","detailImage":"news/detail/rfi/2026/02/13/1771002379000.webp","sourceId":"rfi"}]