[{"id":1771746192000,"createdDate":"2026-02-22 07:43","name":"法国国际广播电台","title":"日美政府热议美国对日“核保护伞”及中俄核武问题","content":"日本外务省当地时间22日宣布，日美两国政府于2月19日（当地时间2月18日）在美国国务院举行了日美扩大威慑磋商（EDD）。美方由国务院及战争省共同担任联合主席，日方由外务省及防卫省共同担任联合主席。与会人员还包括日本统合幕僚监部以及美国参谋长联席会议、战略司令部和印太司令部。双方一致认为，美国的核态势和战略在遏制地区侵略、并在必要时加以应对方面发挥着重要作用。双方还对俄罗斯核武问题及中国秘密进行核试验等问题交换了意见。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260222-%E6%97%A5%E7%BE%8E%E6%94%BF%E5%BA%9C%E7%83%AD%E8%AE%AE%E7%BE%8E%E5%9B%BD%E5%AF%B9%E6%97%A5-%E6%A0%B8%E4%BF%9D%E6%8A%A4%E4%BC%9E-%E5%8F%8A%E4%B8%AD%E4%BF%84%E6%A0%B8%E6%AD%A6%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/02/22/1771746192000.webp","sourceId":"rfi"},{"id":1771777297000,"createdDate":"2026-02-22 16:21","name":"法国国际广播电台","title":"柏林电影节“金熊奖”授予恰塔克的反威权审查影片《黄信》","content":"第76届柏林国际电影节在政治争议和加沙战争引发的紧张气氛中落下帷幕。评审团最终将金熊奖授予伊尔克-恰塔克执导的影片《黄信》。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260222-%E6%9F%8F%E6%9E%97%E7%94%B5%E5%BD%B1%E8%8A%82-%E9%87%91%E7%86%8A%E5%A5%96-%E6%8E%88%E4%BA%88%E6%81%B0%E5%A1%94%E5%85%8B%E7%9A%84%E5%8F%8D%E5%A8%81%E6%9D%83%E5%AE%A1%E6%9F%A5%E5%BD%B1%E7%89%87-%E9%BB%84%E4%BF%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/02/22/1771777297000.webp","sourceId":"rfi"},{"id":1771774747000,"createdDate":"2026-02-22 15:39","name":"法国国际广播电台","title":"伊朗爆发新一轮示威冲突 德黑兰校园学生呼喊“独裁者去死”口号","content":"伊朗学生周六在德黑兰高呼反政府口号，这是继1月份抗议活动后人们再次爆发愤怒情绪，此时美国正与伊朗进行谈判，同时加大对德黑兰的军事压力。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260222-%E4%BC%8A%E6%9C%97%E7%88%86%E5%8F%91%E6%96%B0%E4%B8%80%E8%BD%AE%E7%A4%BA%E5%A8%81-%E5%BE%B7%E9%BB%91%E5%85%B0%E6%A0%A1%E5%9B%AD%E5%AD%A6%E7%94%9F%E5%91%BC%E5%96%8A-%E7%8B%AC%E8%A3%81%E8%80%85%E5%8E%BB%E6%AD%BB-%E5%8F%A3%E5%8F%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/22/1771774747000.webp","sourceId":"rfi"},{"id":1771767400000,"createdDate":"2026-02-22 13:36","name":"法国国际广播电台","title":"巴基斯坦对阿富汗境内发动致命空袭","content":"巴基斯坦周日宣布对阿富汗边境地区的武装团体实施了空袭。巴军方称“根据情报对七个恐怖分子藏身处进行了有选择打击”。阿富汗当地当局称，这次袭击造成数十人死伤，包括儿童。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260222-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%AF%B9%E9%98%BF%E5%AF%8C%E6%B1%97%E5%A2%83%E5%86%85%E5%8F%91%E5%8A%A8%E8%87%B4%E5%91%BD%E7%A9%BA%E8%A2%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/22/1771767400000.webp","sourceId":"rfi"},{"id":1771762787000,"createdDate":"2026-02-22 12:19","name":"法国国际广播电台","title":"澳大利亚军舰通过台湾海峡 中国海军跟踪监测 台湾重申该海峡系国际水道","content":"澳大利亚一艘军舰周五和周六穿越了台湾海峡，中国官媒称中国军队对此次行动进行了跟踪和监测。台湾国防部表示正严密监控岛屿周围，但重申台湾海峡是国际水道，各国享有航行自由权。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260222-%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E5%86%9B%E8%88%B0%E9%80%9A%E8%BF%87%E5%8F%B0%E6%B9%BE%E6%B5%B7%E5%B3%A1-%E4%B8%AD%E5%9B%BD%E6%B5%B7%E5%86%9B%E8%B7%9F%E8%B8%AA%E7%9B%91%E6%B5%8B-%E5%8F%B0%E6%B9%BE%E9%87%8D%E7%94%B3%E8%AF%A5%E6%B5%B7%E5%B3%A1%E7%B3%BB%E5%9B%BD%E9%99%85%E6%B0%B4%E9%81%93","thumbnail":"","detailImage":"news/detail/rfi/2026/02/22/1771762787000.webp","sourceId":"rfi"},{"id":1771762619000,"createdDate":"2026-02-22 12:16","name":"法国国际广播电台","title":"新德里人工智能峰会 呼吁安全、可信、稳健的人工智能","content":"法国周日各报头版分别报道在美国最高法院推翻特朗普关税措施后，特朗普迅速签署行政命令将全球关税从10%上调到15%。新德里人工智能峰会闭幕一天后，86个国签署并发布一项共同联合声明倡导“安全、可信、稳健”的人工智能。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260222-%E6%96%B0%E5%BE%B7%E9%87%8C%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E5%B3%B0%E4%BC%9A-%E5%91%BC%E5%90%81%E5%AE%89%E5%85%A8-%E5%8F%AF%E4%BF%A1-%E7%A8%B3%E5%81%A5%E7%9A%84%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/22/1771762619000.webp","sourceId":"rfi"},{"id":1771762147000,"createdDate":"2026-02-22 12:09","name":"法国国际广播电台","title":"俄乌战火将进入第五年 基辅谴责俄军对乌新一轮大规模空袭","content":"还有两天，俄罗斯侵略乌克兰的战争2月24日就将满四周年，乌克兰多地周日（2月22日）再次遭遇俄军大规模空袭，首都基辅及其周边地区、南部港口城市敖德萨以及中东部多个州连续传出爆炸声。基辅称，俄罗斯在夜间动用大量无人机以及弹道导弹、巡航导弹，对能源基础设施和部分居民区实施打击，造成至少一人死亡，多人受伤。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260222-%E4%BF%84%E4%B9%8C%E6%88%98%E7%81%AB%E5%B0%86%E8%BF%9B%E7%AC%AC%E4%BA%94%E5%B9%B4-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%A4%9A%E5%9C%B0%E5%86%8D%E9%81%AD%E5%A4%A7%E8%A7%84%E6%A8%A1%E7%A9%BA%E8%A2%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/22/1771762147000.webp","sourceId":"rfi"},{"id":1771754903000,"createdDate":"2026-02-22 10:08","name":"法国国际广播电台","title":"俄罗斯入侵乌克兰四周年前两天 基辅再遭导弹袭击","content":"基辅周日清晨发生爆炸，乌克兰当局称在俄罗斯入侵四周年纪念日前两天，再次遭到弹道导弹袭击。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260222-%E4%BF%84%E7%BD%97%E6%96%AF%E5%85%A5%E4%BE%B5%E4%B9%8C%E5%85%8B%E5%85%B0%E5%9B%9B%E5%91%A8%E5%B9%B4%E5%89%8D%E4%B8%A4%E5%A4%A9-%E5%9F%BA%E8%BE%85%E5%86%8D%E9%81%AD%E5%AF%BC%E5%BC%B9%E8%A2%AD%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/22/1771754903000.webp","sourceId":"rfi"},{"id":1771754669000,"createdDate":"2026-02-22 10:04","name":"法国国际广播电台","title":"2026年当人形机器人霸屏 普通人还有什么机会？","content":"今天，用网友@汪霞写在火马年除夕的一篇散文开篇，她在这篇题为《马蹄踏过六十年》的文章这样写道：丙午年的风，又转过来了。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%BE%AE%E8%A8%80%E5%BE%AE%E8%AF%AD/20260222-2026%E5%B9%B4%E5%BD%93%E4%BA%BA%E5%BD%A2%E6%9C%BA%E5%99%A8%E4%BA%BA%E9%9C%B8%E5%B1%8F-%E6%99%AE%E9%80%9A%E4%BA%BA%E8%BF%98%E6%9C%89%E4%BB%80%E4%B9%88%E6%9C%BA%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/02/22/1771754669000.webp","sourceId":"rfi"},{"id":1771754306000,"createdDate":"2026-02-22 09:58","name":"法国国际广播电台","title":"关税铁锤滑落  恐美引爆地缘冲突","content":"美国最高法院20日裁决关税违宪后，华盛顿政府再提出课征10%关税，全球贸易伙伴期待机遇降临之际，纷纷提醒谨慎把控自身局势，唯恐华盛顿未来在全球贸易博弈中再使出新手段。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260222-%E5%85%B3%E7%A8%8E%E9%93%81%E9%94%A4%E6%BB%91%E8%90%BD-%E6%81%90%E7%BE%8E%E5%BC%95%E7%88%86%E5%9C%B0%E7%BC%98%E5%86%B2%E7%AA%81","thumbnail":"","detailImage":"news/detail/rfi/2026/02/22/1771754306000.webp","sourceId":"rfi"},{"id":1771750503000,"createdDate":"2026-02-22 08:55","name":"法国国际广播电台","title":"特朗普宣布将向格陵兰派遣大型医院船 丹麦：格陵兰不需要特殊的医疗计划","content":"美国总统特朗普周六（2月21日）宣布，将向格陵兰派遣一艘医院船，以便为当地众多病患提供治疗。丹麦国防部长次日表示，对此并不知情，并称格陵兰岛不需要特殊的医疗计划。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260222-%E7%89%B9%E6%9C%97%E6%99%AE-%E5%B0%86%E5%90%91%E6%A0%BC%E9%99%B5%E5%85%B0%E6%B4%BE%E9%81%A3%E4%B8%80%E8%89%98%E5%A4%A7%E5%9E%8B%E5%8C%BB%E9%99%A2%E8%88%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/22/1771750503000.webp","sourceId":"rfi"}]