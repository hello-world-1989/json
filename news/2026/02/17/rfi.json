[{"id":1771317985000,"createdDate":"2026-02-17 08:46","name":"法国国际广播电台","title":"特朗普：正与习近平讨论对台军售问题“会很快做出决定”","content":"据彭博社报道，美国总统特朗普周一（2月16日）晚间在空军一号专机上对记者说：“我正在和他谈这个问题。我们进行了很好的一次对话，我们会在不久后作出决定。” 特朗普此番表态正值美中领导人计划于4月举行会晤之际，引发外界关注。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260217-%E7%89%B9%E6%9C%97%E6%99%AE-%E6%AD%A3%E4%B8%8E%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%A8%E8%AE%BA%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E9%97%AE%E9%A2%98-%E4%BC%9A%E5%BE%88%E5%BF%AB%E5%81%9A%E5%87%BA%E5%86%B3%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771317985000.webp","sourceId":"rfi"},{"id":1771317022000,"createdDate":"2026-02-17 08:30","name":"法国国际广播电台","title":"日中围绕王毅在慕尼黑安全会议上批判日本再交锋","content":"中国驻日大使馆在日本时间16日表示，针对日本政府就王毅外长在慕尼黑安全会议上的发言提出抗议并称其“不恰当”一事，中方反驳并拒绝，称“日本歪曲事实”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260217-%E6%97%A5%E4%B8%AD%E5%9B%B4%E7%BB%95%E7%8E%8B%E6%AF%85%E5%9C%A8%E6%85%95%E5%B0%BC%E9%BB%91%E5%AE%89%E5%85%A8%E4%BC%9A%E8%AE%AE%E4%B8%8A%E6%89%B9%E5%88%A4%E6%97%A5%E6%9C%AC%E5%86%8D%E4%BA%A4%E9%94%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771317022000.webp","sourceId":"rfi"},{"id":1771314905000,"createdDate":"2026-02-17 07:55","name":"法国国际广播电台","title":"从取消活动管窥国安红线：去年35项 不少「不可抗力」 涉反修例者续被针对","content":"香港警队专责国家安全的副处长简启恩日前抱怨，指有被噤言者或团体被迫解散与「不可抗力」因素有关是抹黑警方执法，引起网民热议，有社交平台频道盘点去年「被消失」的活动发现，至少有35项活动因为各种光怪陆离的原因被「放飞机」(即「放鸽子」)。当中，直言因「不可抗力」取消活动的，占五份之一；反而是场地问题的占最多，近四成，至於场地背後是否涉及不可抗力因素，则不得而知。肯定的是，捍卫新闻自由的香港记者协会是重灾区，是纪录中惟一一个多於一次被针对的组织。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260217-%E4%BB%8E%E5%8F%96%E6%B6%88%E6%B4%BB%E5%8A%A8%E7%AE%A1%E7%AA%A5%E5%9B%BD%E5%AE%89%E7%BA%A2%E7%BA%BF-%E5%8E%BB%E5%B9%B435%E9%A1%B9-%E4%B8%8D%E5%B0%91-%E4%B8%8D%E5%8F%AF%E6%8A%97%E5%8A%9B-%E6%B6%89%E5%8F%8D%E4%BF%AE%E4%BE%8B%E8%80%85%E7%BB%AD%E8%A2%AB%E9%92%88%E5%AF%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771314905000.webp","sourceId":"rfi"},{"id":1771346987000,"createdDate":"2026-02-17 16:49","name":"法国国际广播电台","title":"「拼桌吃年夜饭」今蔚然成风「反向春运」也越来越盛行","content":"据中央社报道，近年中国年轻人流行在社群平台约陌生人一起拼桌吃年夜饭，对只身在外的年轻人来说是缓解节日孤独的社交新模式。与此同时「反向春运」的新风潮越来越盛行，不再是子女返乡过年，而是父母去子女工作地过年。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260217-%E6%8B%BC%E6%A1%8C%E5%90%83%E5%B9%B4%E5%A4%9C%E9%A5%AD-%E4%BB%8A%E8%94%9A%E7%84%B6%E6%88%90%E9%A3%8E-%E5%8F%8D%E5%90%91%E6%98%A5%E8%BF%90-%E4%B9%9F%E8%B6%8A%E6%9D%A5%E8%B6%8A%E7%9B%9B%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771346987000.webp","sourceId":"rfi"},{"id":1771345525000,"createdDate":"2026-02-17 16:25","name":"法国国际广播电台","title":"成立近70载，香港学联为何突然宣布解散？","content":"2026年2月5日，香港学生联合会（HKFS）又称香港学联，宣布正式解散。该组织成立于1958年，有将近70年的历史，曾在动员香港学生社群积极参与社会运动中发挥了重要作用，因此该组织解散的决定令社会各界一度感到错愕和震惊。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%85%AC%E6%B0%91%E8%AE%BA%E5%9D%9B/20260217-%E6%88%90%E7%AB%8B%E8%BF%9170%E8%BD%BD%EF%BC%8C%E9%A6%99%E6%B8%AF%E5%AD%A6%E8%81%94%E4%B8%BA%E4%BD%95%E7%AA%81%E7%84%B6%E5%AE%A3%E5%B8%83%E8%A7%A3%E6%95%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771345525000.webp","sourceId":"rfi"},{"id":1771341789000,"createdDate":"2026-02-17 15:23","name":"法国国际广播电台","title":"继张又侠后谁会是习近平下一个清洗目标？促使“北京学”马年复兴","content":"2026年1月下旬，中国军方高层又再发生重大人事震荡：曾被习近平委以军队改革重任的张又侠上将，突然成为调查对象。当时《解放军报》指责其“削弱习近平权威、助长腐败、破坏军队战斗力”，但具体原因仍然成谜。对此《华尔街日报》的分析称，随着中国政治不透明度不断加剧，“北京学”（Pekingology）再度兴起，以预判那些即将陷入政治危局的高官。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260217-%E9%A9%AC%E5%B9%B4%E6%9D%A5%E4%B8%B4%EF%BC%8C%E8%B0%81%E4%BC%9A%E6%98%AF%E4%B9%A0%E8%BF%91%E5%B9%B3%E4%B8%8B%E4%B8%80%E4%B8%AA%E6%B8%85%E6%B4%97%E7%9B%AE%E6%A0%87-%E4%BF%83%E4%BD%BF-%E5%8C%97%E4%BA%AC%E5%AD%A6-%E5%A4%8D%E5%85%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771341789000.webp","sourceId":"rfi"},{"id":1771336806000,"createdDate":"2026-02-17 14:00","name":"法国国际广播电台","title":"视频 春节庆祝马年","content":"在中国和世界不同地方庆祝农历新年马年活动层出不穷，请看France24报道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260217-%E8%A7%86%E9%A2%91-%E6%98%A5%E8%8A%82%E5%BA%86%E7%A5%9D%E9%A9%AC%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771336806000.webp","sourceId":"rfi"},{"id":1771334047000,"createdDate":"2026-02-17 13:14","name":"法国国际广播电台","title":"美国非裔民权运动标志性人物：杰西·杰克逊牧师84岁辞世","content":"美国非裔民权运动领袖、马丁·路德·金的亲密战友杰西·杰克逊（JesseJackson）牧师逝世，享年84岁。周二2月17日其家人在声明中表示：“他对正义、平等和人权的坚定承诺，塑造了一场全球性的自由与尊严运动。”声明还透露，杰克逊牧师“于周二平静离世，家人陪伴在侧”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%BA%E6%9D%83/20260217-%E7%BE%8E%E5%9B%BD%E9%9D%9E%E8%A3%94%E6%B0%91%E6%9D%83%E8%BF%90%E5%8A%A8%E6%A0%87%E5%BF%97%E6%80%A7%E4%BA%BA%E7%89%A9-%E6%9D%B0%E8%A5%BF%C2%B7%E6%9D%B0%E5%85%8B%E9%80%8A%E7%89%A7%E5%B8%88%E8%BE%9E%E4%B8%96","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771334047000.webp","sourceId":"rfi"},{"id":1771333308000,"createdDate":"2026-02-17 13:01","name":"法国国际广播电台","title":"贸易、军购与AI合作 马克龙开启第四度印度访问","content":"法国总统马克龙周二（2月17日）开启对印度为期三天的访问。这是他对这一全球人口第一大国家的第四次到访，旨在进一步强化双边合作。爱丽舍宫表示，此行将推动法印伙伴关系“再上新台阶”。国防、经贸、人工智能将是访问围绕的三大重点，印度计划采购114架“阵风”战斗机尤其受到关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260217-%E8%B4%B8%E6%98%93-%E5%86%9B%E8%B4%AD%E4%B8%8Eai%E5%90%88%E4%BD%9C-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%BC%80%E5%90%AF%E7%AC%AC%E5%9B%9B%E5%BA%A6%E5%8D%B0%E5%BA%A6%E8%AE%BF%E9%97%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771333308000.webp","sourceId":"rfi"},{"id":1771333078000,"createdDate":"2026-02-17 12:57","name":"法国国际广播电台","title":"马克龙亲信、资深外交官勒让德取代雅克·朗接任阿拉伯世界研究院长","content":"法国总统马克龙的亲信顾问、资深外交官安娜-克莱尔·勒让德被任命为阿拉伯世界研究院长，接替因与爱泼斯坦私人关系而被迫离职的社会党籍前文化部长雅克·朗。法国政府当天上午提名她出任该职务，并已正式获批。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260217-%E9%A9%AC%E5%85%8B%E9%BE%99%E4%BA%B2%E4%BF%A1-%E8%B5%84%E6%B7%B1%E5%A4%96%E4%BA%A4%E5%AE%98%E5%8B%92%E8%AE%A9%E5%BE%B7%E5%8F%96%E4%BB%A3%E9%9B%85%E5%85%8B%C2%B7%E6%9C%97%E6%8E%A5%E4%BB%BB%E9%98%BF%E6%8B%89%E4%BC%AF%E4%B8%96%E7%95%8C%E7%A0%94%E7%A9%B6%E9%99%A2%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771333078000.webp","sourceId":"rfi"},{"id":1771332840000,"createdDate":"2026-02-17 12:54","name":"法国国际广播电台","title":"中国掀一巨型太空航母面纱 这是一真正大计划或只是一种宣传手法？","content":"几周前，中国推出了一个庞大的太空军事计划：也就是一艘命名为鸾鸟号（Luanniao）的巨型太空航母。中国的一家电视台公布了一个型号视屏揭露了一个长奖金250米的庞然怪物。这是中国真实正在打造的一个巨型太空航母，或者它仅仅只是一个中国对外威慑的大外宣呢？","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260217-%E4%B8%AD%E5%9B%BD%E6%8F%AD%E5%BC%80%E4%B8%80%E5%B7%A8%E5%9E%8B%E5%A4%AA%E7%A9%BA%E8%88%AA%E6%AF%8D%E9%9D%A2%E7%BA%B1-%E4%B8%80%E4%B8%AA%E7%9C%9F%E6%AD%A3%E5%A4%A7%E8%AE%A1%E5%88%92%E6%88%96%E5%8F%AA%E6%98%AF%E4%B8%80%E7%A7%8D%E5%AE%A3%E4%BC%A0%E6%89%8B%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771332840000.webp","sourceId":"rfi"},{"id":1771331537000,"createdDate":"2026-02-17 12:32","name":"法国国际广播电台","title":"菲律宾强硬回应中国大使馆就业警告：指责言论带有胁迫意味","content":"路透社马尼拉消息，菲律宾外交部周一晚间表示，菲律宾对中国驻马尼拉大使馆发表的“两国间持续外交争端可能导致数百万就业岗位流失”的言论表示“强烈反对”，并指出此类言论可能被视为胁迫行为。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260217-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%BC%BA%E7%A1%AC%E5%9B%9E%E5%BA%94%E4%B8%AD%E5%9B%BD%E5%A4%A7%E4%BD%BF%E9%A6%86%E5%B0%B1%E4%B8%9A%E8%AD%A6%E5%91%8A-%E6%8C%87%E8%B4%A3%E8%A8%80%E8%AE%BA%E5%B8%A6%E6%9C%89%E8%83%81%E8%BF%AB%E6%84%8F%E5%91%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771331537000.webp","sourceId":"rfi"},{"id":1771328913000,"createdDate":"2026-02-17 11:48","name":"法国国际广播电台","title":"视频 美伊日内瓦会议 特朗普威胁称若无协议将有“后果”","content":"美国和伊朗正在日内瓦举行会谈，旨在解决伊朗核问题，此次会谈的背景是地区局势高度紧张，华盛顿已在霍尔木兹海峡部署军舰，而德黑兰则举行了军事演习，请看比拉尔·塔拉贝的视频报道","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260217-%E8%A7%86%E9%A2%91-%E7%BE%8E%E4%BC%8A%E6%97%A5%E5%86%85%E7%93%A6%E4%BC%9A%E8%AE%AE-%E7%89%B9%E6%9C%97%E6%99%AE%E5%A8%81%E8%83%81%E7%A7%B0%E8%8B%A5%E6%97%A0%E5%8D%8F%E8%AE%AE%E5%B0%86%E6%9C%89-%E5%90%8E%E6%9E%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771328913000.webp","sourceId":"rfi"},{"id":1771328518000,"createdDate":"2026-02-17 11:41","name":"法国国际广播电台","title":"路透社：虽有制裁，外国汽车仍经中国流入俄罗斯","content":"据路透社日前审阅的登记数据以及对五名相关从业者的采访显示，数以万计的汽车正通过“灰色市场”方案从中国出口到俄罗斯。这些方案通常旨在规避西方和亚洲政府的制裁，以及汽车制造商退出俄罗斯市场的承诺。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260217-%E8%B7%AF%E9%80%8F%E7%A4%BE-%E8%99%BD%E6%9C%89%E5%88%B6%E8%A3%81%EF%BC%8C%E5%A4%96%E5%9B%BD%E6%B1%BD%E8%BD%A6%E4%BB%8D%E7%BB%8F%E4%B8%AD%E5%9B%BD%E6%B5%81%E5%85%A5%E4%BF%84%E7%BD%97%E6%96%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771328518000.webp","sourceId":"rfi"},{"id":1771321383000,"createdDate":"2026-02-17 09:43","name":"法国国际广播电台","title":"特朗普公开与习近平谈对台军售，台湾学者：形同推翻《六项保证》之一","content":"据台湾淡江大学整合战略与科技研究中心研究员揭仲指出，不管特朗普和习近平两位元首的讨论，是否会对美国去年12月17日所宣布的111亿美元对台军售，或华盛顿正在讨论的新一波对台军售造成影响，特朗普公开证实与习近平讨论未来对台军售事宜，已对日后美台军售造成重大影响，因为这代表美国现任总统公开推翻《六项保证》的内容之一，即“美国未同意就对台军售议题向中华人民共和国征询意见”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260217-%E7%89%B9%E6%9C%97%E6%99%AE%E5%85%AC%E5%BC%80%E4%B8%8E%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%B0%88%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%EF%BC%8C%E5%8F%B0%E6%B9%BE%E5%AD%A6%E8%80%85-%E5%BD%A2%E5%90%8C%E6%8E%A8%E7%BF%BB-%E5%85%AD%E9%A1%B9%E4%BF%9D%E8%AF%81-%E4%B9%8B%E4%B8%80","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771321383000.webp","sourceId":"rfi"},{"id":1771321039000,"createdDate":"2026-02-17 09:37","name":"法国国际广播电台","title":"台湾外长林佳龙：中国日益加剧的威权扩张主义已威胁台湾的民主制度","content":"台湾外交部长林佳龙接受美国《福斯数位新闻》专访表示，中国不断扩张的威权主义，已直接危及台湾的安全与民主制度，同时对印太地区甚至是全球的和平与稳定构成严峻挑战。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260217-%E5%8F%B0%E6%B9%BE%E5%A4%96%E9%95%BF%E6%9E%97%E4%BD%B3%E9%BE%99-%E4%B8%AD%E5%9B%BD%E6%97%A5%E7%9B%8A%E5%8A%A0%E5%89%A7%E7%9A%84%E5%A8%81%E6%9D%83%E6%89%A9%E5%BC%A0%E4%B8%BB%E4%B9%89%E5%B7%B2%E5%A8%81%E8%83%81%E5%8F%B0%E6%B9%BE%E7%9A%84%E6%B0%91%E4%B8%BB%E5%88%B6%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771321039000.webp","sourceId":"rfi"},{"id":1771320959000,"createdDate":"2026-02-17 09:35","name":"法国国际广播电台","title":"特朗普“我会间接参与谈判”警告伊朗：若不达成协议将面临后果","content":"据法新社报道，当被问到日内瓦美伊新一轮核谈判议题时，美国总统特朗普周一（2月16日）在飞往华盛顿的空军一号专机上对记者说：“我会参与谈判，以一种间接的方式。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260217-%E7%89%B9%E6%9C%97%E6%99%AE-%E6%88%91%E4%BC%9A%E9%97%B4%E6%8E%A5%E5%8F%82%E4%B8%8E%E8%B0%88%E5%88%A4-%E8%AD%A6%E5%91%8A%E4%BC%8A%E6%9C%97-%E8%8B%A5%E4%B8%8D%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE%E5%B0%86%E9%9D%A2%E4%B8%B4%E5%90%8E%E6%9E%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771320959000.webp","sourceId":"rfi"},{"id":1771320231000,"createdDate":"2026-02-17 09:23","name":"法国国际广播电台","title":"与美核谈判前夕 伊朗革命卫队竟在霍尔木兹海峡军演","content":"伊朗伊斯兰革命卫队星期一（2月16日）在中东战略要道霍尔木兹海峡展开军事演习，以应对“潜在的安全与军事威胁”。本次军演正值德黑兰与华盛顿在日内瓦展开新一轮核谈判之际，引发关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260217-%E4%B8%8E%E7%BE%8E%E6%A0%B8%E8%B0%88%E5%88%A4%E5%89%8D%E5%A4%95-%E4%BC%8A%E6%9C%97%E9%9D%A9%E5%91%BD%E5%8D%AB%E9%98%9F%E7%AB%9F%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%86%9B%E6%BC%94","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771320231000.webp","sourceId":"rfi"},{"id":1771319951000,"createdDate":"2026-02-17 09:19","name":"法国国际广播电台","title":"以色列启动约旦河西岸土地登记程序，八国发表联合声明谴责","content":"综合美联社、路透社消息，以色列政府决定启动一项涉及被占领约旦河西岸大片地区的土地监管程序。根据2月15日公布的以方决定，以色列将恢复自1967年中东战争以来在该地区被冻结的“土地所有权登记”程序。一旦针对某一特定区域启动登记，任何声称拥有土地权利的人都必须提交文件以证明所有权。该程序可能使以色列在未来开发中获得对大片土地的控制。对此，八个国家发表联合声明，强烈谴责。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260217-%E4%BB%A5%E8%89%B2%E5%88%97%E5%90%AF%E5%8A%A8%E7%BA%A6%E6%97%A6%E6%B2%B3%E8%A5%BF%E5%B2%B8%E5%9C%9F%E5%9C%B0%E7%99%BB%E8%AE%B0%E7%A8%8B%E5%BA%8F%EF%BC%8C%E5%85%AB%E5%9B%BD%E5%8F%91%E8%A1%A8%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E%E8%B0%B4%E8%B4%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771319951000.webp","sourceId":"rfi"},{"id":1771319645000,"createdDate":"2026-02-17 09:14","name":"法国国际广播电台","title":"俄乌日内瓦谈判聚焦领土问题 乌军收复失地取得2023年反攻以来最大战果","content":"俄乌自周二起在日内瓦重启新一轮和谈，俄方表示，谈判将聚焦于领土问题。与此同时，据国际观察称，乌克兰军队上周在数天内已收复200多平方公里被占领土，取得自2023年6月反攻以来的最大战果。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260217-%E4%BF%84%E4%B9%8C%E6%97%A5%E5%86%85%E7%93%A6%E8%B0%88%E5%88%A4%E8%81%9A%E7%84%A6%E9%A2%86%E5%9C%9F%E9%97%AE%E9%A2%98-%E4%B9%8C%E5%86%9B%E6%94%B6%E5%A4%8D%E5%A4%B1%E5%9C%B0%E5%8F%96%E5%BE%972023%E5%B9%B4%E5%8F%8D%E6%94%BB%E4%BB%A5%E6%9D%A5%E6%9C%80%E5%A4%A7%E6%88%98%E6%9E%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771319645000.webp","sourceId":"rfi"},{"id":1771318415000,"createdDate":"2026-02-17 08:53","name":"法国国际广播电台","title":"中日关系紧张之际 日本歌星幸田来未取消香港演唱会：突发不可抗力因素","content":"在新春马年首日，香港再传来大型活动因不可抗力因素取消的消息。日本乐坛天后幸田来未原定下月21日举行的香港站巡回演唱会，宣布因「突发不可抗力因素」而取消。据网上资料，幸田来未此次巡演，香港是惟一的海外站，而在日本，则会有16场巡回演出。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260217-%E4%B8%AD%E6%97%A5%E5%85%B3%E7%B3%BB%E7%B4%A7%E5%BC%A0%E4%B9%8B%E9%99%85-%E6%97%A5%E6%9C%AC%E6%AD%8C%E6%98%9F%E5%B9%B8%E7%94%B0%E6%9D%A5%E6%9C%AA%E5%8F%96%E6%B6%88%E9%A6%99%E6%B8%AF%E6%BC%94%E5%94%B1%E4%BC%9A-%E7%AA%81%E5%8F%91%E4%B8%8D%E5%8F%AF%E6%8A%97%E5%8A%9B%E5%9B%A0%E7%B4%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/17/1771318415000.webp","sourceId":"rfi"}]