[{"id":1770914047000,"createdDate":"2026-02-12 16:34","name":"法国国际广播电台","title":"特朗普政府将废黜美国气候减排基础法规","content":"唐纳德·特朗普定于周四废除一项美国温室气体减排的基础法规。法新社说，这一政策逆转引发科学家和环保人士的强烈抗议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260212-%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E5%B0%86%E5%BA%9F%E9%BB%9C%E7%BE%8E%E5%9B%BD%E6%B0%94%E5%80%99%E5%87%8F%E6%8E%92%E5%9F%BA%E7%A1%80%E6%B3%95%E8%A7%84","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770914047000.webp","sourceId":"rfi"},{"id":1770911315000,"createdDate":"2026-02-12 15:48","name":"法国国际广播电台","title":"“讲好中国故事”：北京如何在全球传媒中执行习近平的意志","content":"在法国电视台TV5MONDE致力于辨别假新闻的节目《Avraidire》一月底谈到中国作为利己信息传播的隐形推手时，索邦大学地缘政治研究员塞尔玛·米胡比对该台资深记者米莲·吉拉多指出，中国并不是单纯想“改善形象”，而是在有意识地塑造一种叙事，把自己呈现为一个参与建设“更公正世界秩序”的仁慈大国。在她看来，这种叙事并非空洞的宣传，而是服务于非常具体的现实目标，也就是让国际社会，尤其是非洲、东欧和中亚地区，更容易接受中国在经济、商业、外交以及地缘政治上的布局。正是在这样的背景下，理解中国如何一步步把自己的故事讲给全世界，甚至嵌入全球媒体体系，就显得尤为重要。本次中华世界，我们从该集节目视角出发，并试着以问答的形式来为听众朋友们拆解中国对外叙事是如何运作、又是如何影响国际舆论的。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%AD%E5%8D%8E%E4%B8%96%E7%95%8C/20260212-%E8%AE%B2%E5%A5%BD%E4%B8%AD%E5%9B%BD%E6%95%85%E4%BA%8B-%E5%8C%97%E4%BA%AC%E5%A6%82%E4%BD%95%E5%9C%A8%E5%85%A8%E7%90%83%E5%AA%92%E4%BC%A0%E4%B8%AD%E6%89%A7%E8%A1%8C%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%9A%84%E6%84%8F%E5%BF%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770911315000.webp","sourceId":"rfi"},{"id":1770910854000,"createdDate":"2026-02-12 15:40","name":"法国国际广播电台","title":"关注秘鲁中资钱凯港监管判决 美国警告称“失去主权是最大代价”","content":"美国周三对秘鲁司法部门近日作出的一项裁决表示关注。该裁决限制秘鲁公共监管机构Ositran对位于利马以北的钱凯港行使监管权职能。这个大型港口由中国远洋海运港口公司（CoscoShippingPorts）运营。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260212-%E5%85%B3%E6%B3%A8%E7%A7%98%E9%B2%81%E4%B8%AD%E8%B5%84%E9%92%B1%E5%87%AF%E6%B8%AF%E7%9B%91%E7%AE%A1%E5%88%A4%E5%86%B3-%E7%BE%8E%E5%9B%BD%E8%AD%A6%E5%91%8A%E7%A7%B0-%E5%A4%B1%E5%8E%BB%E4%B8%BB%E6%9D%83%E6%98%AF%E6%9C%80%E5%A4%A7%E4%BB%A3%E4%BB%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770910854000.webp","sourceId":"rfi"},{"id":1770908083000,"createdDate":"2026-02-12 14:54","name":"法国国际广播电台","title":"萨拉·穆拉利-英国国教会首位女性大主教","content":"自1月28日起，64岁的萨拉·穆拉利（SarahMullally）担任英国国教会、又称圣公会的坎特伯雷大主教，这是这个拥有近500年历史的教会首次由一位女性执掌其最高领导职位。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260212-%E8%90%A8%E6%8B%89%C2%B7%E7%A9%86%E6%8B%89%E5%88%A9-%E8%8B%B1%E5%9B%BD%E5%9B%BD%E6%95%99%E4%BC%9A%E9%A6%96%E4%BD%8D%E5%A5%B3%E6%80%A7%E5%A4%A7%E4%B8%BB%E6%95%99","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770908083000.webp","sourceId":"rfi"},{"id":1770907447000,"createdDate":"2026-02-12 14:44","name":"法国国际广播电台","title":"北约启动“北极哨兵”演习：安抚美国、加速北约“欧洲化”","content":"北约2月12日宣布启动新的军事任务“北极哨兵”（ArcticSentry）行动，旨在加强北极地区安全，同时旨在安抚美国、缓解美国总统唐纳德·特朗普提出希望获取格陵兰岛而引发的联盟紧张局势。","newsLink":"https://www.rfi.fr/cn/%E5%8C%97%E7%BA%A6%E5%90%AF%E5%8A%A8-%E5%8C%97%E6%9E%81%E5%93%A8%E5%85%B5-%E6%BC%94%E4%B9%A0-%E5%AE%89%E6%8A%9A%E7%BE%8E%E5%9B%BD-%E5%8A%A0%E9%80%9F%E5%8C%97%E7%BA%A6-%E6%AC%A7%E6%B4%B2%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770907447000.webp","sourceId":"rfi"},{"id":1770906342000,"createdDate":"2026-02-12 14:25","name":"法国国际广播电台","title":"欧盟乳制品：中国将减少反补贴关税","content":"中国周四宣布最终将对部分欧盟乳制品征收关税，税率最高可达11.7%，比去年12月实施的“临时性”关税明显降低。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260212-%E6%AC%A7%E7%9B%9F%E4%B9%B3%E5%88%B6%E5%93%81-%E4%B8%AD%E5%9B%BD%E5%B0%86%E5%87%8F%E5%B0%91%E5%8F%8D%E8%A1%A5%E8%B4%B4%E5%85%B3%E7%A8%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770906342000.webp","sourceId":"rfi"},{"id":1770903026000,"createdDate":"2026-02-12 13:30","name":"法国国际广播电台","title":"欧盟峰会：面对中美“双重夹击”27国商讨紧急自救措施","content":"欧盟27国领导人周四在比利时举行闭门会议，讨论如何摆脱中美双重压力，加快改革，重振竞争力，建设一个更“迅速”、更高效的欧洲。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260212-%E6%AC%A7%E7%9B%9F%E5%B3%B0%E4%BC%9A-%E9%9D%A2%E5%AF%B9%E4%B8%AD%E7%BE%8E-%E5%8F%8C%E9%87%8D%E5%A4%B9%E5%87%BB-27%E5%9B%BD%E5%95%86%E8%AE%A8%E7%B4%A7%E6%80%A5%E8%87%AA%E6%95%91%E6%8E%AA%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770903026000.webp","sourceId":"rfi"},{"id":1770900537000,"createdDate":"2026-02-12 12:48","name":"法国国际广播电台","title":"英国宣布向乌克兰提供5亿英镑防御俄罗斯空袭能源设施","content":"英国国防大臣约翰·希利周四宣布，英国将提供约5亿英镑（5.75亿欧元）的资金，帮助乌克兰更好地防御俄罗斯的袭击，这些袭击正在摧毁乌克兰的能源基础设施。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260212-%E8%8B%B1%E5%9B%BD%E5%AE%A3%E5%B8%83%E5%90%91%E4%B9%8C%E5%85%8B%E5%85%B0%E6%8F%90%E4%BE%9B5%E4%BA%BF%E8%8B%B1%E9%95%91%E9%98%B2%E5%BE%A1%E4%BF%84%E7%BD%97%E6%96%AF%E7%A9%BA%E8%A2%AD%E8%83%BD%E6%BA%90%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770900537000.webp","sourceId":"rfi"},{"id":1770900398000,"createdDate":"2026-02-12 12:46","name":"法国国际广播电台","title":"利比亚南部武装袭东部国民军","content":"利比亚南部武装团体[利比亚南部革命者](Lesrévolutionnairesdusudlibyen)声称，在不到两周的时间里，连续成功袭击东部的国民军（LNA-LibyanNationalArmy/Arméenationalelibyenne）部队，并夺取了利比亚与乍得之间的一处主要边境口岸。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260212-rfi-%E6%B3%95%E5%B9%BF-%E9%9D%9E%E6%B4%B2-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E5%88%A9%E6%AF%94%E4%BA%9A%E5%8D%97%E9%83%A8%E6%AD%A6%E8%A3%85%E8%A2%AD%E4%B8%9C%E9%83%A8%E5%9B%BD%E6%B0%91%E5%86%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770900398000.webp","sourceId":"rfi"},{"id":1770895798000,"createdDate":"2026-02-12 11:29","name":"法国国际广播电台","title":"《费加罗报》：中国竞争加剧，法国逾三成制造业面临冲击","content":"周四2月12日，法国主要日报聚焦工业竞争、能源转型与食品安全等议题。《费加罗报》警示中国竞争对欧洲制造业构成前所未有的压力，指出法国超过三分之一的工业产出面临冲击；《回声报》则披露政府即将公布的新十年能源路线图，强调强化核能与调整可再生能源发展节奏；与此同时，《世界报》和《解放报》关注食品中的重金属污染问题，并报道国民议会围绕禁止含镉化肥展开立法讨论。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260212-%E8%B4%B9%E5%8A%A0%E7%BD%97%E6%8A%A5-%E4%B8%AD%E5%9B%BD%E7%AB%9E%E4%BA%89%E5%8A%A0%E5%89%A7%EF%BC%8C%E6%B3%95%E5%9B%BD%E9%80%BE%E4%B8%89%E6%88%90%E5%88%B6%E9%80%A0%E4%B8%9A%E9%9D%A2%E4%B8%B4%E5%86%B2%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770895798000.webp","sourceId":"rfi"},{"id":1770894459000,"createdDate":"2026-02-12 11:07","name":"法国国际广播电台","title":"华裔小伙代表几内亚比绍首次出征冬奥","content":"西非国家几内亚比绍历史上首次参加冬奥会，代表该国征战米兰-科尔蒂纳丹佩佐冬奥会赛场的是一名19岁的华裔滑雪运动员温斯顿·唐（WinstonTang），他将参加高山滑雪回转项目的比赛。点击视频，来看他如何成为几内亚比绍史上首位出征冬奥的运动员。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260212-%E5%8D%8E%E8%A3%94%E5%B0%8F%E4%BC%99%E4%BB%A3%E8%A1%A8%E5%87%A0%E5%86%85%E4%BA%9A%E6%AF%94%E7%BB%8D%E9%A6%96%E6%AC%A1%E5%87%BA%E5%BE%81%E5%86%AC%E5%A5%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770894459000.webp","sourceId":"rfi"},{"id":1770893091000,"createdDate":"2026-02-12 10:44","name":"法国国际广播电台","title":"台湾总统赖清德接受法新社专访  北京方面称他是“危机制造者和战争煽动者”","content":"台湾总统赖清德接受法新社采访时警告称，如果中国接管台湾，将会带来严重后果。中国外交部发言人林剑在例行记者会上表示：“赖清德的言论进一步表明他顽固追求‘台独’，毫无疑问地证明他是和平破坏者、危机制造者和战争煽动者。”","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260212-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E8%B5%96%E6%B8%85%E5%BE%B7%E6%8E%A5%E5%8F%97%E6%B3%95%E6%96%B0%E7%A4%BE%E4%B8%93%E8%AE%BF-%E5%8C%97%E4%BA%AC%E6%96%B9%E9%9D%A2%E7%A7%B0%E4%BB%96%E6%98%AF-%E5%8D%B1%E6%9C%BA%E5%88%B6%E9%80%A0%E8%80%85%E5%92%8C%E6%88%98%E4%BA%89%E7%85%BD%E5%8A%A8%E8%80%85","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770893091000.webp","sourceId":"rfi"},{"id":1770892910000,"createdDate":"2026-02-12 10:41","name":"法国国际广播电台","title":"赖清德总统：强化国防目的是为确保对中国而言，永远没有一天是攻打台湾的吉日","content":"台湾总统赖清德接受法新社专访，他表示台海局势不仅攸关台湾自身安全，更牵动整个印太区域的战略平衡。他警告如果台湾被中国并吞，下一个受威胁的将是日本、菲律宾。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260212-%E8%B5%96%E6%B8%85%E5%BE%B7%E6%80%BB%E7%BB%9F-%E5%BC%BA%E5%8C%96%E5%9B%BD%E9%98%B2%E7%9B%AE%E7%9A%84%E6%98%AF%E4%B8%BA%E7%A1%AE%E4%BF%9D%E5%AF%B9%E4%B8%AD%E5%9B%BD%E8%80%8C%E8%A8%80%EF%BC%8C%E6%B0%B8%E8%BF%9C%E6%B2%A1%E6%9C%89%E4%B8%80%E5%A4%A9%E6%98%AF%E6%94%BB%E6%89%93%E5%8F%B0%E6%B9%BE%E7%9A%84%E5%90%89%E6%97%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770892910000.webp","sourceId":"rfi"},{"id":1770892441000,"createdDate":"2026-02-12 10:34","name":"法国国际广播电台","title":"日本经产大臣到达美国 日美欲投资人工钻石对抗中国","content":"根据日美关税协议，为就对美投资事宜进行磋商，日本经济产业大臣赤泽亮正于日本时间12日凌晨3点左右抵达美国首都华盛顿。去年7月，作为特朗普政府下调关税的条件之一，日本承诺对美投资，据称规模为80万亿日元，其中被选为首个项目的据说是“人造钻石”的制造业务，这也符合高市早苗首相“危急管理投资”的战略。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260212-%E6%97%A5%E6%9C%AC%E7%BB%8F%E4%BA%A7%E5%A4%A7%E8%87%A3%E5%88%B0%E8%BE%BE%E7%BE%8E%E5%9B%BD-%E6%97%A5%E7%BE%8E%E6%AC%B2%E6%8A%95%E8%B5%84%E4%BA%BA%E5%B7%A5%E9%92%BB%E7%9F%B3%E5%AF%B9%E6%8A%97%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770892441000.webp","sourceId":"rfi"},{"id":1770891953000,"createdDate":"2026-02-12 10:25","name":"法国国际广播电台","title":"港国安警抓人一年增两成 却拒谈夺命火灾被捕人数 更批以「不可抗力」喻受制属抹黑","content":"香港罪案数字去年大部分下跌，但因涉嫌违反国家安全法例的被捕人数却增至385人，较前年增加69人，增幅达21.8%，当中逾半已被检控，包括传媒大亨黎智英等人；但对宏福苑大火中有多少人涉嫌违反国安法例被捕，警方却拒绝透露，只是重申，有三人被送上法庭；至於有火灾中被噤言者称受到「不可抗力」因素而停止发放消息是否受警方要求时，相关的副处长扩及其他同类声称，指原因多样，批评使用有关字眼是诿过警方，抹黑执法行动。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260212-%E6%B8%AF%E5%9B%BD%E5%AE%89%E8%AD%A6%E6%8A%93%E4%BA%BA%E4%B8%80%E5%B9%B4%E5%A2%9E%E4%B8%A4%E6%88%90-%E5%8D%B4%E6%8B%92%E8%B0%88%E5%A4%BA%E5%91%BD%E7%81%AB%E7%81%BE%E8%A2%AB%E6%8D%95%E4%BA%BA%E6%95%B0-%E6%9B%B4%E6%89%B9%E4%BB%A5-%E4%B8%8D%E5%8F%AF%E6%8A%97%E5%8A%9B-%E5%96%BB%E5%8F%97%E5%88%B6%E5%B1%9E%E6%8A%B9%E9%BB%91","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770891953000.webp","sourceId":"rfi"},{"id":1770891223000,"createdDate":"2026-02-12 10:13","name":"法国国际广播电台","title":"马克龙推动恢复法俄高层对话，欧洲就是否重启对俄沟通分歧加剧","content":"俄罗斯总统府发言人德米特里·佩斯科夫2月11日证实称，俄法两国政府级高层近期确实有过接触。但“俄罗斯当前没有感知到法国有恢复与俄罗斯最高层对话的明确意愿，也未见相关具体行动”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260212-%E9%A9%AC%E5%85%8B%E9%BE%99%E6%8E%A8%E5%8A%A8%E6%81%A2%E5%A4%8D%E6%B3%95%E4%BF%84%E9%AB%98%E5%B1%82%E5%AF%B9%E8%AF%9D%EF%BC%8C%E6%AC%A7%E6%B4%B2%E5%B0%B1%E6%98%AF%E5%90%A6%E9%87%8D%E5%90%AF%E5%AF%B9%E4%BF%84%E6%B2%9F%E9%80%9A%E5%88%86%E6%AD%A7%E5%8A%A0%E5%89%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770891223000.webp","sourceId":"rfi"},{"id":1770936063000,"createdDate":"2026-02-12 22:41","name":"法国国际广播电台","title":"有华裔背景的两位杰出选手为何陡然卷入网络风暴","content":"打一捧一，一位瞬间被追捧，一位瞬间遭声讨，爆发于米兰冬奥赛场的这场网络风暴来得如此迅猛，大约让处于事态中心的谷爱凌(EileenGu)也好，刘美贤(AlisaLiu)也好，始料不及。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260212-%E6%9C%89%E5%8D%8E%E8%A3%94%E8%83%8C%E6%99%AF%E7%9A%84%E4%B8%A4%E4%BD%8D%E6%9D%B0%E5%87%BA%E9%80%89%E6%89%8B%E4%B8%BA%E4%BD%95%E9%99%A1%E7%84%B6%E5%8D%B7%E5%85%A5%E7%BD%91%E7%BB%9C%E9%A3%8E%E6%9A%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770936063000.webp","sourceId":"rfi"},{"id":1770935036000,"createdDate":"2026-02-12 22:23","name":"法国国际广播电台","title":"印度国防部批准购买一百多架法国阵风战斗机","content":"印度国防部在法国总统马克龙下周到访前批准购买114架新型阵风战斗机，马克龙称赞这是“里程碑”式的合同。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260212-%E5%8D%B0%E5%BA%A6%E5%9B%BD%E9%98%B2%E9%83%A8%E6%89%B9%E5%87%86%E8%B4%AD%E4%B9%B0%E4%B8%80%E7%99%BE%E5%A4%9A%E6%9E%B6%E6%B3%95%E5%9B%BD%E9%98%B5%E9%A3%8E%E6%88%98%E6%96%97%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770935036000.webp","sourceId":"rfi"},{"id":1770932851000,"createdDate":"2026-02-12 21:47","name":"法国国际广播电台","title":"路透：美国中情局发布新视频 招募中国军方线人","content":"路透社报道，在中国军方高层近日出现人事变动后，美国中央情报局（CIA）正试图利用可能出现的内部震荡，通过发布一段公开视频，面向中国军方人员招募潜在线人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260212-%E8%B7%AF%E9%80%8F-%E7%BE%8E%E5%9B%BD%E4%B8%AD%E6%83%85%E5%B1%80%E5%8F%91%E5%B8%83%E6%96%B0%E8%A7%86%E9%A2%91-%E6%8B%9B%E5%8B%9F%E4%B8%AD%E5%9B%BD%E5%86%9B%E6%96%B9%E7%BA%BF%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770932851000.webp","sourceId":"rfi"},{"id":1770932605000,"createdDate":"2026-02-12 21:43","name":"法国国际广播电台","title":"路透：特习会前 美方暂缓多项对华科技限制措施","content":"路透社援引多名消息人士透露，美国总统特朗普政府在美中两国元首计划于4月会晤前，已暂缓推进多项针对中国的重要科技安全限制措施，其中包括原拟禁止中国电信在美运营，以及限制中国设备用于美国数据中心的措施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260212-%E8%B7%AF%E9%80%8F-%E7%89%B9%E4%B9%A04%E6%9C%88%E4%BC%9A%E6%99%A4%E5%89%8D-%E7%BE%8E%E6%96%B9%E6%9A%82%E7%BC%93%E5%A4%9A%E9%A1%B9%E5%AF%B9%E5%8D%8E%E7%A7%91%E6%8A%80%E9%99%90%E5%88%B6%E6%8E%AA%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770932605000.webp","sourceId":"rfi"},{"id":1770932240000,"createdDate":"2026-02-12 21:37","name":"法国国际广播电台","title":"欧盟非正式峰会：27国承诺加快改革 提升竞争力 应对中美压力","content":"在比利时阿尔登·比森举行的欧盟非正式峰会周四(2月12日）晚间结束。欧盟27国领导人发表联合宣言，承诺加快推进结构性改革，削减内部壁垒，提升竞争力，打造一个更“迅速”、更高效、更具战略自主能力的欧洲，应对来自中国和美国日益加剧的经济与地缘政治压力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260212-%E6%AC%A7%E7%9B%9F%E9%9D%9E%E6%AD%A3%E5%BC%8F%E5%B3%B0%E4%BC%9A-27%E5%9B%BD%E6%89%BF%E8%AF%BA%E5%8A%A0%E5%BF%AB%E6%94%B9%E9%9D%A9-%E6%8F%90%E5%8D%87%E7%AB%9E%E4%BA%89%E5%8A%9B-%E5%BA%94%E5%AF%B9%E4%B8%AD%E7%BE%8E%E5%8E%8B%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770932240000.webp","sourceId":"rfi"},{"id":1770931674000,"createdDate":"2026-02-12 21:27","name":"法国国际广播电台","title":"特朗普警告伊朗：一个月内达成协议\"否则后果严重\"","content":"美国总统特朗普周四(2月12日）警告称，如果伊朗拒绝就其核计划达成协议，将面临“极其严重的灾难性后果”。而以色列总理内塔尼亚胡对相关协议能否达成表示“怀疑”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260212-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AD%A6%E5%91%8A%E4%BC%8A%E6%9C%97-%E4%B8%80%E4%B8%AA%E6%9C%88%E5%86%85%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE-%E5%90%A6%E5%88%99%E5%90%8E%E6%9E%9C%E4%B8%A5%E9%87%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770931674000.webp","sourceId":"rfi"},{"id":1770921733000,"createdDate":"2026-02-12 18:42","name":"法国国际广播电台","title":"非洲多国部长共议森林的未来","content":"非洲多国部长级官员本周聚集肯尼亚首都共议森林的未来。这一为期三天的会议预计于2026年02月12日周四闭幕。这次会议的目标是在十年内调动4亿美元的资金，用于更好地管理森林，使之成为发展的引擎。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260212-rfi-%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2%E5%A4%9A%E5%9B%BD%E9%83%A8%E9%95%BF%E5%85%B1%E8%AE%AE%E6%A3%AE%E6%9E%97%E7%9A%84%E6%9C%AA%E6%9D%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770921733000.webp","sourceId":"rfi"},{"id":1770919786000,"createdDate":"2026-02-12 18:09","name":"法国国际广播电台","title":"加拿大枪击案8人遇难25人伤 18岁跨性别嫌凶杀害母弟","content":"法新社的实地报道说，周三，夕阳西下，笼罩着悲痛的加拿大坦布勒里奇小镇。数百人聚集在镇中心广场，点燃蜡烛，悼念该国史上最致命大规模枪击案的八名遇难者。18岁的跨性别嫌凶还杀了自己的妈妈和继弟，并在被捕前自尽。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260212-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E6%9E%AA%E5%87%BB%E6%A1%888%E4%BA%BA%E9%81%87%E9%9A%BE25%E4%BA%BA%E4%BC%A4-18%E5%B2%81%E8%B7%A8%E6%80%A7%E5%88%AB%E5%AB%8C%E5%87%B6%E6%9D%80%E5%AE%B3%E6%AF%8D%E5%BC%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770919786000.webp","sourceId":"rfi"},{"id":1770915691000,"createdDate":"2026-02-12 17:01","name":"法国国际广播电台","title":"革命一年半后，孟加拉国等待议会选举结果","content":"孟加拉国周四开始缓慢计票，这是自2024年前总理谢赫·哈西娜铁腕统治结束以来首次举行的议会选举。两大主要候选人都发表了胜选声明，使选举气氛变得紧张。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260212-%E9%9D%A9%E5%91%BD%E4%B8%80%E5%B9%B4%E5%8D%8A%E5%90%8E%EF%BC%8C%E5%AD%9F%E5%8A%A0%E6%8B%89%E5%9B%BD%E7%AD%89%E5%BE%85%E8%AE%AE%E4%BC%9A%E9%80%89%E4%B8%BE%E7%BB%93%E6%9E%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/12/1770915691000.webp","sourceId":"rfi"}]