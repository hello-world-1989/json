[{"id":1771834747000,"createdDate":"2026-02-23 08:19","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第24浪漫主义群星之二： 诺瓦利斯第四节：夜之颂歌","content":"年仅29岁就去世的诺瓦利斯，在短短一生中经历了两段爱情生活。那位不满13岁的索菲之死给了诺瓦利斯无可挽回的打击，也激发他创作了德语诗歌中的不朽杰作《夜之颂歌》。在浪漫派同人之中，诺瓦利斯象一颗明亮的晚星，他的整个人格完美地体现了努力让世界诗化的诺瓦利斯自身就是一个诗化的人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260223-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%BA%8C-%E8%AF%BA%E7%93%A6%E5%88%A9%E6%96%AF%E7%AC%AC%E5%9B%9B%E8%8A%82-%E5%A4%9C%E4%B9%8B%E9%A2%82%E6%AD%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771834747000.webp","sourceId":"rfi"},{"id":1771834681000,"createdDate":"2026-02-23 08:18","name":"法国国际广播电台","title":"香港最大宗「串颠」案 12名民主派上诉全被驳回 政府欲令刘伟聪入狱亦失败","content":"香港最大批民主派人士因争取民主而被裁定「串谋颠覆国家政权罪」成的「47人」上诉案，今(23日)早裁决，三位国安法指定法官驳回所有上诉，即12名罪成被告就其定罪或刑罚所作上诉失败，维持监禁4年5个月至7年9个月。而政府就脱罪的刘伟聪所提上诉亦遭滑铁卢，刘维持无罪。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260223-%E9%A6%99%E6%B8%AF%E6%9C%80%E5%A4%A7%E5%AE%97-%E4%B8%B2%E9%A2%A0-%E6%A1%88-12%E5%90%8D%E6%B0%91%E4%B8%BB%E6%B4%BE%E4%B8%8A%E8%AF%89%E5%85%A8%E8%A2%AB%E9%A9%B3%E5%9B%9E-%E6%94%BF%E5%BA%9C%E6%AC%B2%E4%BB%A4%E5%88%98%E4%BC%9F%E8%81%AA%E5%85%A5%E7%8B%B1%E4%BA%A6%E5%A4%B1%E8%B4%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771834681000.webp","sourceId":"rfi"},{"id":1771834443000,"createdDate":"2026-02-23 08:14","name":"法国国际广播电台","title":"经批评后 港府拟在郊野营地引入预约制或收费","content":"经环保团体和报章社论批评当局对西贡露营地点在中国长假期间超负苛「头痛医头」后，负责部门强撑两天后，终于发文称，「参考今次黄金周嘅经验」，会在研究中的景点「长远管理策略」上引入优化方法，包括应否引入预约制和收费等，拟下半年谘询立法会。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260223-%E7%BB%8F%E6%89%B9%E8%AF%84%E5%90%8E-%E6%B8%AF%E5%BA%9C%E6%8B%9F%E5%9C%A8%E9%83%8A%E9%87%8E%E8%90%A5%E5%9C%B0%E5%BC%95%E5%85%A5%E9%A2%84%E7%BA%A6%E5%88%B6%E6%88%96%E6%94%B6%E8%B4%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771834443000.webp","sourceId":"rfi"},{"id":1771834101000,"createdDate":"2026-02-23 08:08","name":"法国国际广播电台","title":"日本自民党高官等纷纷批判特朗普欲以新关税对抗法庭判决","content":"美国联邦最高法院20日裁定，特朗普总统启动的对等关税等措施违反宪法，特朗普扬言将以新的关税措施对应，对此，包括自民党高官在内的日本各界，纷纷对特朗普进行了严厉的批判。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260223-%E6%97%A5%E6%9C%AC%E8%87%AA%E6%B0%91%E5%85%9A%E9%AB%98%E5%AE%98%E7%AD%89%E7%BA%B7%E7%BA%B7%E6%89%B9%E5%88%A4%E7%89%B9%E6%9C%97%E6%99%AE%E6%AC%B2%E4%BB%A5%E6%96%B0%E5%85%B3%E7%A8%8E%E5%AF%B9%E6%8A%97%E6%B3%95%E5%BA%AD%E5%88%A4%E5%86%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771834101000.webp","sourceId":"rfi"}]