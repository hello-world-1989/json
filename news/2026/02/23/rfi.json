[{"id":1771834747000,"createdDate":"2026-02-23 08:19","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第24浪漫主义群星之二： 诺瓦利斯第四节：夜之颂歌","content":"年仅29岁就去世的诺瓦利斯，在短短一生中经历了两段爱情生活。那位不满13岁的索菲之死给了诺瓦利斯无可挽回的打击，也激发他创作了德语诗歌中的不朽杰作《夜之颂歌》。在浪漫派同人之中，诺瓦利斯象一颗明亮的晚星，他的整个人格完美地体现了努力让世界诗化的诺瓦利斯自身就是一个诗化的人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260223-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%BA%8C-%E8%AF%BA%E7%93%A6%E5%88%A9%E6%96%AF%E7%AC%AC%E5%9B%9B%E8%8A%82-%E5%A4%9C%E4%B9%8B%E9%A2%82%E6%AD%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771834747000.webp","sourceId":"rfi"},{"id":1771834681000,"createdDate":"2026-02-23 08:18","name":"法国国际广播电台","title":"香港最大宗「串颠」案 12名民主派上诉全被驳回 政府欲令刘伟聪入狱亦失败","content":"香港最大批民主派人士因争取民主而被裁定「串谋颠覆国家政权罪」成的「47人」上诉案，今(23日)早裁决，三位国安法指定法官驳回所有上诉，即12名罪成被告就其定罪或刑罚所作上诉失败，维持监禁4年5个月至7年9个月。而政府就脱罪的刘伟聪所提上诉亦遭滑铁卢，刘维持无罪。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260223-%E9%A6%99%E6%B8%AF%E6%9C%80%E5%A4%A7%E5%AE%97-%E4%B8%B2%E9%A2%A0-%E6%A1%88-12%E5%90%8D%E6%B0%91%E4%B8%BB%E6%B4%BE%E4%B8%8A%E8%AF%89%E5%85%A8%E8%A2%AB%E9%A9%B3%E5%9B%9E-%E6%94%BF%E5%BA%9C%E6%AC%B2%E4%BB%A4%E5%88%98%E4%BC%9F%E8%81%AA%E5%85%A5%E7%8B%B1%E4%BA%A6%E5%A4%B1%E8%B4%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771834681000.webp","sourceId":"rfi"},{"id":1771834443000,"createdDate":"2026-02-23 08:14","name":"法国国际广播电台","title":"经批评后 港府拟在郊野营地引入预约制或收费","content":"经环保团体和报章社论批评当局对西贡露营地点在中国长假期间超负苛「头痛医头」后，负责部门强撑两天后，终于发文称，「参考今次黄金周嘅经验」，会在研究中的景点「长远管理策略」上引入优化方法，包括应否引入预约制和收费等，拟下半年谘询立法会。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260223-%E7%BB%8F%E6%89%B9%E8%AF%84%E5%90%8E-%E6%B8%AF%E5%BA%9C%E6%8B%9F%E5%9C%A8%E9%83%8A%E9%87%8E%E8%90%A5%E5%9C%B0%E5%BC%95%E5%85%A5%E9%A2%84%E7%BA%A6%E5%88%B6%E6%88%96%E6%94%B6%E8%B4%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771834443000.webp","sourceId":"rfi"},{"id":1771834101000,"createdDate":"2026-02-23 08:08","name":"法国国际广播电台","title":"日本自民党高官等纷纷批判特朗普欲以新关税对抗法庭判决","content":"美国联邦最高法院20日裁定，特朗普总统启动的对等关税等措施违反宪法，特朗普扬言将以新的关税措施对应，对此，包括自民党高官在内的日本各界，纷纷对特朗普进行了严厉的批判。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260223-%E6%97%A5%E6%9C%AC%E8%87%AA%E6%B0%91%E5%85%9A%E9%AB%98%E5%AE%98%E7%AD%89%E7%BA%B7%E7%BA%B7%E6%89%B9%E5%88%A4%E7%89%B9%E6%9C%97%E6%99%AE%E6%AC%B2%E4%BB%A5%E6%96%B0%E5%85%B3%E7%A8%8E%E5%AF%B9%E6%8A%97%E6%B3%95%E5%BA%AD%E5%88%A4%E5%86%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771834101000.webp","sourceId":"rfi"},{"id":1771864754000,"createdDate":"2026-02-23 16:39","name":"法国国际广播电台","title":"巴黎农展会：科特迪瓦要为棕榈油恢复名誉","content":"第62界国际农业博览会2月21日在巴黎的凡尔赛们展览馆拉开帷幕，继2025年的摩洛哥之后，西非农业强国科特迪瓦成为2026年巴黎国际农展会的主宾国。来自全球各地的30个国家的农业代表齐聚7号展厅，总共设立12个机构展馆，旨在促进交流、展示专业知识，并在世界农业领域之间搭建持久的桥梁。对于参观者而言，这是一个可以同时品尝到从阿尔及利亚到中国，包括意大利、摩洛哥、蒙古、尼日利亚、卢旺达、苏丹和瑞士等国的丰富多样的特色产品的难得的机会。对于专业人士而言，农展会的目标是促进国际交流、农业伙伴关系与合作。同去年一样，中国展台的规模十分有限，展出的产品也大多是茶叶类的运输保存方便的产品，今天被推向前台的是来自湖南的雪峰甜茶，现场推销者声称该甜茶具有天然甜味但却无糖分，而且具有抗氧化、抗癌变、抗过敏及降血压、降血糖、降血脂等功效。另有一家来自海南的商家推销凤梨以及衍生食物。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260223-%E5%B7%B4%E9%BB%8E%E5%86%9C%E5%B1%95%E4%BC%9A-%E7%A7%91%E7%89%B9%E8%BF%AA%E7%93%A6%E8%A6%81%E4%B8%BA%E6%A3%95%E6%A6%88%E6%B2%B9%E6%81%A2%E5%A4%8D%E5%90%8D%E8%AA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771864754000.webp","sourceId":"rfi"},{"id":1771864672000,"createdDate":"2026-02-23 16:37","name":"法国国际广播电台","title":"俄“幽灵舰队”中国籍船长案开庭 法国检方求刑一年 更多情况曝光","content":"俄罗斯幽灵舰队一艘油轮的船长拒不配合执法案2月23日在法国开庭。检方请求法院判处涉案中国籍船长最高刑罚：一年监禁和15万欧元罚款。法官将于3月30日作出裁决。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260223-%E4%BF%84-%E5%B9%BD%E7%81%B5%E8%88%B0%E9%98%9F-%E4%B8%AD%E5%9B%BD%E7%B1%8D%E8%88%B9%E9%95%BF%E6%A1%88%E5%BC%80%E5%BA%AD-%E6%B3%95%E5%9B%BD%E6%A3%80%E6%96%B9%E6%B1%82%E5%88%91%E4%B8%80%E5%B9%B4-%E4%BC%A0%E5%87%BA%E6%9B%B4%E5%A4%9A%E5%86%85%E5%B9%95","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771864672000.webp","sourceId":"rfi"},{"id":1771861534000,"createdDate":"2026-02-23 15:45","name":"法国国际广播电台","title":"美国协助击毙大毒枭 墨西哥陷暴力动荡","content":"周日，墨西哥最大贩毒集团之一的头目在一次由美国支持的军事行动中丧生，该国随即爆发暴力浪潮，当局正努力避免局势进一步恶化。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260223-%E7%BE%8E%E5%9B%BD%E5%8D%8F%E5%8A%A9%E5%87%BB%E6%AF%99%E5%A4%A7%E6%AF%92%E6%9E%AD-%E5%A2%A8%E8%A5%BF%E5%93%A5%E9%99%B7%E6%9A%B4%E5%8A%9B%E5%8A%A8%E8%8D%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771861534000.webp","sourceId":"rfi"},{"id":1771858436000,"createdDate":"2026-02-23 14:53","name":"法国国际广播电台","title":"欧盟中国敦促美国遵守贸易协议","content":"美国海关于本周二起停止征收部分关税，欧盟和北京呼吁华盛顿尊重贸易协议，并正进行磋商以缓和紧张局势。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E7%BB%8F%E6%B5%8E/20260223-%E6%AC%A7%E7%9B%9F%E4%B8%AD%E5%9B%BD%E6%95%A6%E4%BF%83%E7%BE%8E%E5%9B%BD%E9%81%B5%E5%AE%88%E8%B4%B8%E6%98%93%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771858436000.webp","sourceId":"rfi"},{"id":1771858112000,"createdDate":"2026-02-23 14:48","name":"法国国际广播电台","title":"乌克兰重建预计耗资超过5000亿欧元","content":"世界银行、欧盟和联合国与乌克兰今天周一联合发布报告指出，乌克兰在未来十年的战后重建预计耗资约5880亿美元，为5000多亿欧元，该报告指出重建成本持续攀升，预计将相当于乌克兰2025年GDP的三倍。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260223-%E4%B9%8C%E5%85%8B%E5%85%B0%E9%87%8D%E5%BB%BA%E9%A2%84%E8%AE%A1%E8%80%97%E8%B5%84%E8%B6%85%E8%BF%875000%E4%BA%BF%E6%AC%A7%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771858112000.webp","sourceId":"rfi"},{"id":1771849182000,"createdDate":"2026-02-23 12:19","name":"法国国际广播电台","title":"法广RFI特派记者: 乌克兰伤残军人遥控机器人在前线出色完成高风险任务","content":"在乌克兰与俄罗斯长达四年的战争中，随着海陆空无人机数量的激增，日常作战的面貌已然改变。无人机以破坏性著称，而某些联网地面机器人则被用于为士兵补给物资，甚至拯救士兵。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260223-%E6%B3%95%E5%B9%BFrfi%E7%89%B9%E6%B4%BE%E8%AE%B0%E8%80%85-%E4%B9%8C%E5%85%8B%E5%85%B0%E4%BC%A4%E6%AE%8B%E5%86%9B%E4%BA%BA%E9%81%A5%E6%8E%A7%E6%9C%BA%E5%99%A8%E4%BA%BA%E5%9C%A8%E5%89%8D%E7%BA%BF%E5%87%BA%E8%89%B2%E5%AE%8C%E6%88%90%E9%AB%98%E9%A3%8E%E9%99%A9%E4%BB%BB%E5%8A%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771849182000.webp","sourceId":"rfi"},{"id":1771847895000,"createdDate":"2026-02-23 11:58","name":"法国国际广播电台","title":"“来就是支持”：没有牛的巴黎国际农展 参观者依然踊跃","content":"在法国众多的年度展会中，很少有哪一个能像巴黎国际农业展这样，与民众的生活如此相关、此次受到喜爱和广泛参与。今年的第62届巴黎国际农展，2月21日至3月1日如期在巴黎凡尔赛门展览中心举行，由于前所未有展厅中首次没有牛，今年的农展会显得尤为特殊。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E7%94%9F%E6%B4%BB/20260223-%E6%9D%A5%E5%B0%B1%E6%98%AF%E6%94%AF%E6%8C%81-%E6%B2%A1%E6%9C%89%E7%89%9B%E7%9A%84%E5%B7%B4%E9%BB%8E%E5%9B%BD%E9%99%85%E5%86%9C%E5%B1%95-%E5%8F%82%E8%A7%82%E8%80%85%E4%BE%9D%E7%84%B6%E8%B8%8A%E8%B7%83","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771847895000.webp","sourceId":"rfi"},{"id":1771839122000,"createdDate":"2026-02-23 09:32","name":"法国国际广播电台","title":"乌克兰：俄军空袭扎波罗热和敖德萨 造成至少三人死亡","content":"在俄乌战争即将满4周年前夕，据乌克兰地方当局周一（2月23日）通报，俄罗斯当天对扎波罗热和敖德萨地区发动空袭，造成至少3人死亡、多人受伤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260223-%E4%B9%8C%E5%85%8B%E5%85%B0-%E4%BF%84%E5%86%9B%E7%A9%BA%E8%A2%AD%E6%89%8E%E6%B3%A2%E7%BD%97%E7%83%AD%E5%92%8C%E6%95%96%E5%BE%B7%E8%90%A8-%E9%80%A0%E6%88%90%E8%87%B3%E5%B0%91%E4%B8%89%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771839122000.webp","sourceId":"rfi"},{"id":1771838954000,"createdDate":"2026-02-23 09:29","name":"法国国际广播电台","title":"金正恩再“当选”朝劳动党总书记  习近平祝贺称愿携手开启“新篇章”","content":"据朝中社周一(2月23号)报道，朝鲜劳动党一致推举金正恩再次担任党总书记，并赞扬在其领导下，朝鲜核武库得到了“彻底”加强。中共中央总书记习近平祝贺“金正恩被推举为朝鲜劳动党总书记”，并承诺与他共同“谱写中朝友谊新篇章”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260223-%E6%9C%9D%E9%B2%9C-%E9%87%91%E6%AD%A3%E6%81%A9%E5%86%8D%E6%AC%A1-%E5%BD%93%E9%80%89-%E5%8A%B3%E5%8A%A8%E5%85%9A%E6%80%BB%E4%B9%A6%E8%AE%B0-%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%A5%9D%E8%B4%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771838954000.webp","sourceId":"rfi"},{"id":1771836896000,"createdDate":"2026-02-23 08:54","name":"法国国际广播电台","title":"特朗普关税变局使谈好的台美关税白忙一场？ 台学者：重谈台美协定是下策","content":"美国最高法院裁定特朗普的对等关税政策违法，但白宫迅速转向《1974年贸易法》122条款，将全球关税提高至15％。台湾谈判代表郑丽君表示，已签署台美投资合作投资备忘录不受此次美国最高法院判决影响。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260223-%E7%89%B9%E6%9C%97%E6%99%AE%E5%85%B3%E7%A8%8E%E5%8F%98%E5%B1%80%E4%BD%BF%E8%B0%88%E5%A5%BD%E7%9A%84%E5%8F%B0%E7%BE%8E%E5%85%B3%E7%A8%8E%E7%99%BD%E5%BF%99%E4%B8%80%E5%9C%BA-%E5%8F%B0%E5%AD%A6%E8%80%85-%E9%87%8D%E8%B0%88%E5%8F%B0%E7%BE%8E%E5%8D%8F%E5%AE%9A%E6%98%AF%E4%B8%8B%E7%AD%96","thumbnail":"","detailImage":"news/detail/rfi/2026/02/23/1771836896000.webp","sourceId":"rfi"}]