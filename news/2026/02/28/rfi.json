[{"id":1772238311000,"createdDate":"2026-02-28 00:25","name":"法国国际广播电台","title":"中国外交部提醒中国公民暂勿前往伊朗","content":"中国外交部周五发公告，提醒中国公民暂勿前往伊朗，已在当地的中国公民加强安全防范，尽快撤离。这是伊朗局势已很危急的最新信号。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260228-%E4%B8%AD%E5%9B%BD%E5%A4%96%E4%BA%A4%E9%83%A8%E6%8F%90%E9%86%92%E4%B8%AD%E5%9B%BD%E5%85%AC%E6%B0%91%E6%9A%82%E5%8B%BF%E5%89%8D%E5%BE%80%E4%BC%8A%E6%9C%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772238311000.webp","sourceId":"rfi"},{"id":1772237951000,"createdDate":"2026-02-28 00:19","name":"法国国际广播电台","title":"因为通往中国的海底电缆项目，智利与美国关系紧张","content":"法国世界报指出，拉美国家智利与美国因通往中国的海底电缆项目而关系紧张。这是美国干预他国内政的又一例证。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260228-%E5%9B%A0%E4%B8%BA%E9%80%9A%E5%BE%80%E4%B8%AD%E5%9B%BD%E7%9A%84%E6%B5%B7%E5%BA%95%E7%94%B5%E7%BC%86%E9%A1%B9%E7%9B%AE%EF%BC%8C%E6%99%BA%E5%88%A9%E4%B8%8E%E7%BE%8E%E5%9B%BD%E5%85%B3%E7%B3%BB%E7%B4%A7%E5%BC%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772237951000.webp","sourceId":"rfi"},{"id":1772266780000,"createdDate":"2026-02-28 08:19","name":"法国国际广播电台","title":"美国宣布已对伊朗发动“重大作战行动” 特朗普向伊朗人民喊话：你们的自由时刻近在眼前","content":"美国和以色列周六（2月28日）宣布对伊朗发动打击。此前数周，双方一直相互发出军事干预威胁。当天，伊朗多座城市传出爆炸声。特朗普周六宣布，美国已对伊朗发动“重大作战行动”。他在社交平台发布的视频讲话中还承诺，将“摧毁”伊朗伊斯兰共和国的导弹能力，并“彻底消灭”伊朗的海军力量。他表示，美方行动的目标是“消除德黑兰造成的迫在眉睫的威胁”。此外，他还向伊朗人民喊话称：“你们的自由时刻近在眼前。”","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260228-%E7%BE%8E%E5%9B%BD%E5%AE%A3%E5%B8%83%E5%B7%B2%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%8F%91%E5%8A%A8-%E9%87%8D%E5%A4%A7%E4%BD%9C%E6%88%98%E8%A1%8C%E5%8A%A8-%E7%89%B9%E6%9C%97%E6%99%AE%E5%90%91%E4%BC%8A%E6%9C%97%E4%BA%BA%E6%B0%91%E5%96%8A%E8%AF%9D-%E4%BD%A0%E4%BB%AC%E7%9A%84%E8%87%AA%E7%94%B1%E6%97%B6%E5%88%BB%E8%BF%91%E5%9C%A8%E7%9C%BC%E5%89%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772266780000.webp","sourceId":"rfi"},{"id":1772294286000,"createdDate":"2026-02-28 15:58","name":"法国国际广播电台","title":"多个国家卷入冲突  伊朗：袭击瞄准美军军事基地，并不针对海湾国家","content":"伊朗外交部长阿巴斯·阿拉格奇周六在NBC电视台上宣布，伊朗最高领袖阿里·哈梅内伊仍然活着，他还说伊朗“有兴趣”（对局势）进行降温，而且伊朗的袭击并不针对海湾国家。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260228-%E5%A4%9A%E4%B8%AA%E5%9B%BD%E5%AE%B6%E5%8D%B7%E5%85%A5%E5%86%B2%E7%AA%81-%E4%BC%8A%E6%9C%97-%E8%A2%AD%E5%87%BB%E7%9E%84%E5%87%86%E7%BE%8E%E5%86%9B%E5%86%9B%E4%BA%8B%E5%9F%BA%E5%9C%B0%EF%BC%8C%E5%B9%B6%E4%B8%8D%E9%92%88%E5%AF%B9%E6%B5%B7%E6%B9%BE%E5%9B%BD%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772294286000.webp","sourceId":"rfi"},{"id":1772288981000,"createdDate":"2026-02-28 14:29","name":"法国国际广播电台","title":"多国回应美国和以色列军事打击伊朗 中国：立即停止军事行动","content":"国际社会对以色列和美国的军事行动纷纷回应。中国外交部发言人周六（2月28日）就美国和以色列军事打击伊朗答记者问时，呼吁立即停火，避免紧张局势进一步升级。此前，伊朗为回应美国和以色列自当天上午以来实施的打击，发射了多轮导弹进行报复。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260228-%E5%A4%9A%E5%9B%BD%E5%9B%9E%E5%BA%94%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%BB%A5%E8%89%B2%E5%88%97%E5%86%9B%E4%BA%8B%E6%89%93%E5%87%BB%E4%BC%8A%E6%9C%97-%E4%B8%AD%E5%9B%BD%E5%91%BC%E5%90%81%E7%AB%8B%E5%8D%B3%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772288981000.webp","sourceId":"rfi"},{"id":1772281595000,"createdDate":"2026-02-28 12:26","name":"法国国际广播电台","title":"以美联合袭击伊朗后的局势和反应","content":"以色列和美国周六宣布，已对伊朗发动了一场被描述为“预防性”的空袭行动，与此同时，伊朗媒体报道了德黑兰和该国其他城市发生的多起爆炸事件。据以色列军方称，伊朗向以色列发射导弹进行报复。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260228-%E4%BB%A5%E7%BE%8E%E8%81%94%E5%90%88%E8%A2%AD%E5%87%BB%E4%BC%8A%E6%9C%97%E5%90%8E%E7%9A%84%E5%B1%80%E5%8A%BF%E5%92%8C%E5%8F%8D%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772281595000.webp","sourceId":"rfi"},{"id":1772281152000,"createdDate":"2026-02-28 12:19","name":"法国国际广播电台","title":"巴林遭袭，还有哪些美国在中东的军事基地会成为伊朗报复的目标？","content":"美国周六对伊朗发动的军事行动，已经引发了伊朗针对海湾国家巴林一处美军基地的导弹袭击。该基地是五角大楼在该地区众多可能成为德黑兰报复目标的设施之一。巴林宣布，疏散位于美军第五舰队总部所在的Juffair区居民，","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260228-%E5%B7%B4%E6%9E%97%E9%81%AD%E8%A2%AD%EF%BC%8C%E8%BF%98%E6%9C%89%E5%93%AA%E4%BA%9B%E7%BE%8E%E5%9B%BD%E5%9C%A8%E4%B8%AD%E4%B8%9C%E7%9A%84%E5%86%9B%E4%BA%8B%E5%9F%BA%E5%9C%B0%E4%BC%9A%E6%88%90%E4%B8%BA%E4%BC%8A%E6%9C%97%E6%8A%A5%E5%A4%8D%E7%9A%84%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772281152000.webp","sourceId":"rfi"},{"id":1772279467000,"createdDate":"2026-02-28 11:51","name":"法国国际广播电台","title":"德黑兰市区交通堵塞，居民争相回家避难 首批伤亡报告公布：伊朗南部一所学校至少24人死亡","content":"美国和以色列周六对伊朗发动了一系列空袭。据以色列公共广播报道，伊朗最高领袖哈梅内伊是袭击目标之一。与此同时，伊朗发射导弹进行回击，引发地区局势可能失控的担忧。据当地当局报告，已有首批伤亡报告，包括伊朗南部一所学校的24人死亡。海湾多座城市发生爆炸，部分城市内有美军基地，多国宣布关闭领空。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260228-%E5%BE%B7%E9%BB%91%E5%85%B0%E5%B8%82%E5%8C%BA%E4%BA%A4%E9%80%9A%E5%A0%B5%E5%A1%9E%EF%BC%8C%E5%B1%85%E6%B0%91%E4%BA%89%E7%9B%B8%E5%9B%9E%E5%AE%B6%E9%81%BF%E9%9A%BE-%E9%A6%96%E6%89%B9%E4%BC%A4%E4%BA%A1%E6%8A%A5%E5%91%8A%E5%85%AC%E5%B8%83-%E4%BC%8A%E6%9C%97%E5%8D%97%E9%83%A8%E4%B8%80%E6%89%80%E5%AD%A6%E6%A0%A1%E8%87%B3%E5%B0%9124%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772279467000.webp","sourceId":"rfi"},{"id":1772278781000,"createdDate":"2026-02-28 11:39","name":"法国国际广播电台","title":"玻利维亚一架满载现金的飞机坠毁造成 20人死亡，坠机现场出现抢劫","content":"周五，一架载满现钞的玻利维亚军用飞机坠毁，造成至少20人死亡，并引发居民争相在坠机现场抢夺散落的现金。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260228-%E7%8E%BB%E5%88%A9%E7%BB%B4%E4%BA%9A%E4%B8%80%E6%9E%B6%E6%BB%A1%E8%BD%BD%E7%8E%B0%E9%87%91%E7%9A%84%E9%A3%9E%E6%9C%BA%E5%9D%A0%E6%AF%81%E9%80%A0%E6%88%90-20%E4%BA%BA%E6%AD%BB%E4%BA%A1%EF%BC%8C%E5%9D%A0%E6%9C%BA%E7%8E%B0%E5%9C%BA%E5%87%BA%E7%8E%B0%E6%8A%A2%E5%8A%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772278781000.webp","sourceId":"rfi"},{"id":1772278233000,"createdDate":"2026-02-28 11:30","name":"法国国际广播电台","title":"日驻华使馆天皇诞辰祝贺会中方出席者规格大大降低","content":"2月27日晚，在日本驻华大使馆举行了天皇诞辰祝贺招待会。中方往年通常由外交部副部长级官员出席，但在围绕高市首相有关“台湾有事”的国会答辩导致日中关系持续紧张的背景下，今年降低规格，仅由外交部相关部门的实务工作人员参加，没有高层干部出席。日方为缓和紧张局势呼吁开展对话，而中方再次展现出回避两国高官接触的姿态。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260228-%E6%97%A5%E9%A9%BB%E5%8D%8E%E4%BD%BF%E9%A6%86%E5%A4%A9%E7%9A%87%E8%AF%9E%E8%BE%B0%E7%A5%9D%E8%B4%BA%E4%BC%9A%E4%B8%AD%E6%96%B9%E5%87%BA%E5%B8%AD%E8%80%85%E8%A7%84%E6%A0%BC%E5%A4%A7%E5%A4%A7%E9%99%8D%E4%BD%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772278233000.webp","sourceId":"rfi"},{"id":1772272200000,"createdDate":"2026-02-28 09:50","name":"法国国际广播电台","title":"七枚导弹落在总统府和官邸附近 哈梅内伊不在德黑兰已“被转移至安全地点”","content":"以色列和美国周六宣布，对伊朗发起一场被称为“先发制人”的空袭行动。与此同时，伊朗媒体报道称，首都德黑兰及该国其他多座城市发生多起爆炸。一名伊朗官员对路透社表示，哈梅内伊当时不在德黑兰，已被转移至安全地点。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260228-%E4%B8%83%E6%9E%9A%E5%AF%BC%E5%BC%B9%E8%90%BD%E5%9C%A8%E6%80%BB%E7%BB%9F%E5%BA%9C%E5%92%8C%E5%AE%98%E9%82%B8%E9%99%84%E8%BF%91-%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E4%B8%8D%E5%9C%A8%E5%BE%B7%E9%BB%91%E5%85%B0%E5%B7%B2-%E8%A2%AB%E8%BD%AC%E7%A7%BB%E8%87%B3%E5%AE%89%E5%85%A8%E5%9C%B0%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772272200000.webp","sourceId":"rfi"},{"id":1772272188000,"createdDate":"2026-02-28 09:49","name":"法国国际广播电台","title":"金正恩携女儿亮相射击场试射新型步枪 再度引发“接班人”猜测","content":"朝鲜领导人金正恩在为期一周的党代会结束后，向政府和军方高级官员赠送了新式狙击步枪。此外，官方媒体还刊登了一张他的女儿在射击场举枪瞄准的照片。近年来她频繁公开露面，外界猜测金正恩或正培养这位十几岁的女儿为未来接班人。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260228-%E9%87%91%E6%AD%A3%E6%81%A9%E6%90%BA%E5%A5%B3%E5%84%BF%E4%BA%AE%E7%9B%B8%E5%B0%84%E5%87%BB%E5%9C%BA%E8%AF%95%E5%B0%84%E6%96%B0%E5%9E%8B%E6%AD%A5%E6%9E%AA-%E5%86%8D%E5%BA%A6%E5%BC%95%E5%8F%91-%E6%8E%A5%E7%8F%AD%E4%BA%BA-%E7%8C%9C%E6%B5%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772272188000.webp","sourceId":"rfi"},{"id":1772272174000,"createdDate":"2026-02-28 09:49","name":"法国国际广播电台","title":"遭最高法院裁定多项关税无效后 特朗普政府寻求拖延程序","content":"根据周五（2月28日）提交给法院的一份文件，美国总统特朗普领导的政府请求推迟与向进口商退还关税有关的司法程序。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260228-%E9%81%AD%E6%9C%80%E9%AB%98%E6%B3%95%E9%99%A2%E8%A3%81%E5%AE%9A%E5%A4%9A%E9%A1%B9%E5%85%B3%E7%A8%8E%E6%97%A0%E6%95%88%E5%90%8E-%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E5%AF%BB%E6%B1%82%E6%8B%96%E5%BB%B6%E7%A8%8B%E5%BA%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772272174000.webp","sourceId":"rfi"},{"id":1772272158000,"createdDate":"2026-02-28 09:49","name":"法国国际广播电台","title":"冬奥刚落幕不久，米兰一辆电车撞进建筑物：造成2人死亡、至少40人受伤","content":"据法新社报道，周五（2月28日），意大利北部城市米兰一辆有轨电车脱轨后撞入一栋建筑物，造成2人死亡、至少40人受伤。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260228-%E5%86%AC%E5%A5%A5%E5%88%9A%E8%90%BD%E5%B9%95%E4%B8%8D%E4%B9%85%EF%BC%8C%E7%B1%B3%E5%85%B0%E4%B8%80%E8%BE%86%E7%94%B5%E8%BD%A6%E6%92%9E%E8%BF%9B%E5%BB%BA%E7%AD%91%E7%89%A9-%E9%80%A0%E6%88%902%E4%BA%BA%E6%AD%BB%E4%BA%A1-%E8%87%B3%E5%B0%9140%E4%BA%BA%E5%8F%97%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772272158000.webp","sourceId":"rfi"},{"id":1772270120000,"createdDate":"2026-02-28 09:15","name":"法国国际广播电台","title":"阿富汗声称俘获一名巴基斯坦飞行员 伊斯兰堡否认","content":"阿富汗和巴基斯坦两国冲突仍在持续。阿富汗当局周六声称在贾拉拉巴德（东部）附近俘获了一架巴基斯坦军机的飞行员，但巴基斯坦否认了这一说法。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260228-%E9%98%BF%E5%AF%8C%E6%B1%97%E5%A3%B0%E7%A7%B0%E4%BF%98%E8%8E%B7%E4%B8%80%E5%90%8D%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E9%A3%9E%E8%A1%8C%E5%91%98-%E4%BC%8A%E6%96%AF%E5%85%B0%E5%A0%A1%E5%90%A6%E8%AE%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772270120000.webp","sourceId":"rfi"},{"id":1772315755000,"createdDate":"2026-02-28 21:55","name":"法国国际广播电台","title":"塞拉利昂和几内亚外交化解危机","content":"西非国家塞拉利昂（laSierraLeone）与几内亚（laGuinée）于本周一（2026年02月23日）的共同边境地区出现的紧张状况到昨天周五（2026年02月27日）就已通过外交方式得到化解。这是本台法广非洲组（RFIAfrique）今天星期六（2026年02月28日）更新的最新法文消息之一。弗里敦（Freetown）方面宣布，科纳克里（Conakry）当局已释放了所有于本周初在两国边境争议地区被几内亚军人逮捕的塞拉里昂军警人员。几内亚总理称赞以外交努力管理危机事务。塞拉利昂的中文国名也有译作獅子山共和國（SierraLeone）。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260228-%E6%B3%95%E5%B9%BFrfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%A1%9E%E6%8B%89%E5%88%A9%E6%98%82%E5%92%8C%E5%87%A0%E5%86%85%E4%BA%9A%E5%A4%96%E4%BA%A4%E5%8C%96%E8%A7%A3%E5%8D%B1%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772315755000.webp","sourceId":"rfi"},{"id":1772312421000,"createdDate":"2026-02-28 21:00","name":"法国国际广播电台","title":"美以袭击伊朗    马克龙：“预先不知情    也未参与其中”","content":"法国总统马克龙表示，伊朗遭袭之前，法国“预先不知情，也未参与其中”。马克龙表示，“我们绝对优先考虑的显然是所有受影响国家公民的安全。其次是我们在所有这些国家的军事和外交基地的安全”；“最后我希望我们能够采取一切必要措施，确保外交工作恢复正常”。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260228-%E7%BE%8E%E4%BB%A5%E8%A2%AD%E5%87%BB%E4%BC%8A%E6%9C%97-%E9%A9%AC%E5%85%8B%E9%BE%99-%E9%A2%84%E5%85%88%E4%B8%8D%E7%9F%A5%E6%83%85-%E4%B9%9F%E6%9C%AA%E5%8F%82%E4%B8%8E%E5%85%B6%E4%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772312421000.webp","sourceId":"rfi"},{"id":1772312300000,"createdDate":"2026-02-28 20:58","name":"法国国际广播电台","title":"伊朗促请国际原子能机构召开紧急会议","content":"伊朗常驻维也纳联合国代表团周六呼吁国际原子能机构（IAEA）召开一次紧急特别会议。此前，以色列和美国对伊朗发动空袭，以色列军方表示，大约200架战斗机参与了对伊朗的“大规模”袭击，自袭击开始以来，已有约500个目标遭到攻击。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260228-%E4%BC%8A%E6%9C%97%E4%BF%83%E8%AF%B7%E5%9B%BD%E9%99%85%E5%8E%9F%E5%AD%90%E8%83%BD%E6%9C%BA%E6%9E%84%E5%8F%AC%E5%BC%80%E7%B4%A7%E6%80%A5%E4%BC%9A%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772312300000.webp","sourceId":"rfi"},{"id":1772312021000,"createdDate":"2026-02-28 20:53","name":"法国国际广播电台","title":"油轮被迫暂停通过霍尔木兹海峡","content":"28日，在伊朗境内目标遭到袭击后，由于地区安全风险剧增，全球多家大型石油公司及贸易巨头已正式宣布，暂停其石油与燃料船只通过霍尔木兹海峡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260228-%E6%B2%B9%E8%BD%AE%E8%A2%AB%E8%BF%AB%E6%9A%82%E5%81%9C%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772312021000.webp","sourceId":"rfi"},{"id":1772311865000,"createdDate":"2026-02-28 20:51","name":"法国国际广播电台","title":"专家：伊朗会将冲突区域化","content":"伊朗位于波斯湾北岸小半岛布什尔（Bouchehr）两个街区遭到导弹袭击。伊朗国家电视台宣布，伊朗向海湾地区的美国基地发射了新一轮导弹。以色列军方表示，伊朗最高领袖的住宅区遭到“三十枚炸弹”袭击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260228-%E4%B8%93%E5%AE%B6-%E4%BC%8A%E6%9C%97%E4%BC%9A%E5%B0%86%E5%86%B2%E7%AA%81%E5%8C%BA%E5%9F%9F%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772311865000.webp","sourceId":"rfi"},{"id":1772311752000,"createdDate":"2026-02-28 20:49","name":"法国国际广播电台","title":"对伊朗的打击：石油将会受何种冲击？","content":"周六美国和以色列对伊朗发动的空袭引发的冲突可能严重扰乱全球原油供应，并导致油价飙升至多年来的最高水平。在1979年伊斯兰革命和美国实施一系列经济制裁（特朗普近期对伊朗石油实施的“极限施压”政策）之前，伊朗的石油产量在20世纪70年代几乎是现在的两倍。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260228-%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%9A%84%E6%89%93%E5%87%BB-%E7%9F%B3%E6%B2%B9%E5%B0%86%E4%BC%9A%E5%8F%97%E4%BD%95%E7%A7%8D%E5%86%B2%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772311752000.webp","sourceId":"rfi"},{"id":1772311356000,"createdDate":"2026-02-28 20:42","name":"法国国际广播电台","title":"《繁花》登陆法国文艺流媒体平台MUBI","content":"中国著名导演王家卫的电视剧《繁花》终于和欧洲观众见面！这部视觉与叙事俱佳的盛宴已于2026年2月26日正式登陆法国文艺流媒体平台MUBI。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260228-%E7%B9%81%E8%8A%B1-%E7%99%BB%E9%99%86%E6%B3%95%E5%9B%BD%E6%96%87%E8%89%BA%E6%B5%81%E5%AA%92%E4%BD%93%E5%B9%B3%E5%8F%B0mubi","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772311356000.webp","sourceId":"rfi"},{"id":1772311041000,"createdDate":"2026-02-28 20:37","name":"法国国际广播电台","title":"勒布伦两兄弟（Les Lebrun）赢得大满贯赛双打冠军","content":"2026年2月28日晚，乒乓球WTT新加坡大满贯赛男双决赛落幕，法国兄弟费利克斯·勒布伦（Félix）和亚历克西·勒布伦（AlexisLebrun）首次获得大满贯双打冠军。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260228-%E5%8B%92%E5%B8%83%E4%BC%A6%E4%B8%A4%E5%85%84%E5%BC%9F-les-lebrun-%E8%B5%A2%E5%BE%97%E5%A4%A7%E6%BB%A1%E8%B4%AF%E8%B5%9B%E5%8F%8C%E6%89%93%E5%86%A0%E5%86%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772311041000.webp","sourceId":"rfi"},{"id":1772309449000,"createdDate":"2026-02-28 20:10","name":"法国国际广播电台","title":"内塔尼亚胡说有迹象显示伊朗最高领导人哈梅内伊已被击毙 美国总统特朗普对此表示确信","content":"周六（2月28日）晚间，以色列总理内塔尼亚胡在最新电视讲话中表示，有很多迹象表明伊朗最高领导人哈梅内伊已经被击毙。美国总统特朗普也在接受NBC采访时回应说：“我们确信，我们觉得这是正确的消息。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260228-%E5%86%85%E5%A1%94%E5%B0%BC%E4%BA%9A%E8%83%A1-%E5%BE%88%E5%A4%9A%E8%BF%B9%E8%B1%A1%E8%A1%A8%E6%98%8E%E4%BC%8A%E6%9C%97%E6%9C%80%E9%AB%98%E9%A2%86%E5%AF%BC%E4%BA%BA%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E5%B7%B2%E8%A2%AB%E5%87%BB%E6%AF%99","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772309449000.webp","sourceId":"rfi"},{"id":1772307061000,"createdDate":"2026-02-28 19:31","name":"法国国际广播电台","title":"两名伊朗高官死于美以空袭 伊朗小学遭波及罹难者或增至85人 以军对伊朗西部目标发动新一波打击","content":"美国28日周六稍早联手以色列攻击伊朗后，以军方表示，第一波攻击锁定伊朗首都德黑兰的数个地点，因为有伊朗高阶官员在那里聚集开会。不过，以色列官方尚未宣布袭击行动的结果。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260228-%E4%B8%A4%E5%90%8D%E4%BC%8A%E6%9C%97%E9%AB%98%E5%AE%98%E6%AD%BB%E4%BA%8E%E7%BE%8E%E4%BB%A5%E7%A9%BA%E8%A2%AD-%E4%BC%8A%E6%9C%97%E5%B0%8F%E5%AD%A6%E9%81%AD%E6%B3%A2%E5%8F%8A%E7%BD%B9%E9%9A%BE%E8%80%85%E6%88%96%E5%A2%9E%E8%87%B385%E4%BA%BA-%E4%BB%A5%E5%86%9B%E5%AF%B9%E4%BC%8A%E6%9C%97%E8%A5%BF%E9%83%A8%E7%9B%AE%E6%A0%87%E5%8F%91%E5%8A%A8%E6%96%B0%E4%B8%80%E6%B3%A2%E6%89%93%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772307061000.webp","sourceId":"rfi"},{"id":1772301294000,"createdDate":"2026-02-28 17:54","name":"法国国际广播电台","title":"科摩罗宣布2026年斋月利民措施","content":"在位于印度洋中的非洲岛国科摩罗（LesComores），当局在斋月(leRamadan)第八天公布了为方便该国民众在这个斋戒圣月（lemoissacré）里的日常生活而实施的各项措施。本台法广（RFI）非洲通讯员发回了该国政府秘书长（lesecrétairegénéraldugouvernement）的部分讲话录音片段，谈到物流问题和电网问题。科摩罗的中文也有译作[葛摩联盟]（UnionoftheComoros/UniondesComores）。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260228-%E6%B3%95%E5%B9%BFrfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E7%A7%91%E6%91%A9%E7%BD%97%E5%AE%A3%E5%B8%832026%E5%B9%B4%E6%96%8B%E6%9C%88%E5%88%A9%E6%B0%91%E6%8E%AA%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772301294000.webp","sourceId":"rfi"}]