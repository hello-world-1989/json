[{"id":1772238311000,"createdDate":"2026-02-28 00:25","name":"法国国际广播电台","title":"中国外交部提醒中国公民暂勿前往伊朗","content":"中国外交部周五发公告，提醒中国公民暂勿前往伊朗，已在当地的中国公民加强安全防范，尽快撤离。这是伊朗局势已很危急的最新信号。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260228-%E4%B8%AD%E5%9B%BD%E5%A4%96%E4%BA%A4%E9%83%A8%E6%8F%90%E9%86%92%E4%B8%AD%E5%9B%BD%E5%85%AC%E6%B0%91%E6%9A%82%E5%8B%BF%E5%89%8D%E5%BE%80%E4%BC%8A%E6%9C%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772238311000.webp","sourceId":"rfi"},{"id":1772237951000,"createdDate":"2026-02-28 00:19","name":"法国国际广播电台","title":"因为通往中国的海底电缆项目，智利与美国关系紧张","content":"法国世界报指出，拉美国家智利与美国因通往中国的海底电缆项目而关系紧张。这是美国干预他国内政的又一例证。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260228-%E5%9B%A0%E4%B8%BA%E9%80%9A%E5%BE%80%E4%B8%AD%E5%9B%BD%E7%9A%84%E6%B5%B7%E5%BA%95%E7%94%B5%E7%BC%86%E9%A1%B9%E7%9B%AE%EF%BC%8C%E6%99%BA%E5%88%A9%E4%B8%8E%E7%BE%8E%E5%9B%BD%E5%85%B3%E7%B3%BB%E7%B4%A7%E5%BC%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772237951000.webp","sourceId":"rfi"},{"id":1772266780000,"createdDate":"2026-02-28 08:19","name":"法国国际广播电台","title":"美国宣布已对伊朗发动“重大作战行动” 特朗普向伊朗人民喊话：你们的自由时刻近在眼前","content":"美国和以色列周六（2月28日）宣布对伊朗发动打击。此前数周，双方一直相互发出军事干预威胁。当天，伊朗多座城市传出爆炸声。特朗普周六宣布，美国已对伊朗发动“重大作战行动”。他在社交平台发布的视频讲话中还承诺，将“摧毁”伊朗伊斯兰共和国的导弹能力，并“彻底消灭”伊朗的海军力量。他表示，美方行动的目标是“消除德黑兰造成的迫在眉睫的威胁”。此外，他还向伊朗人民喊话称：“你们的自由时刻近在眼前。”","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260228-%E7%BE%8E%E5%9B%BD%E5%AE%A3%E5%B8%83%E5%B7%B2%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%8F%91%E5%8A%A8-%E9%87%8D%E5%A4%A7%E4%BD%9C%E6%88%98%E8%A1%8C%E5%8A%A8-%E7%89%B9%E6%9C%97%E6%99%AE%E5%90%91%E4%BC%8A%E6%9C%97%E4%BA%BA%E6%B0%91%E5%96%8A%E8%AF%9D-%E4%BD%A0%E4%BB%AC%E7%9A%84%E8%87%AA%E7%94%B1%E6%97%B6%E5%88%BB%E8%BF%91%E5%9C%A8%E7%9C%BC%E5%89%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/02/28/1772266780000.webp","sourceId":"rfi"}]