[{"id":1771922540000,"createdDate":"2026-02-24 08:42","name":"法国国际广播电台","title":"美国官员：中国 DeepSeek违规使用英伟达最先进芯片训练其模型","content":"根据路透社2月23日独家报道，美国政府一名高级官员表示，中国人工智能初创公司DeepSeek（深度求索）即将发布的新一代AI模型，使用了美国英伟达最先进的Blackwell人工智能芯片进行训练，此举可能违反了美国的出口管制规定。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260224-%E7%BE%8E%E5%9B%BD%E5%AE%98%E5%91%98-%E4%B8%AD%E5%9B%BD-deepseek%E8%BF%9D%E8%A7%84%E4%BD%BF%E7%94%A8%E8%8B%B1%E4%BC%9F%E8%BE%BE%E6%9C%80%E5%85%88%E8%BF%9B%E8%8A%AF%E7%89%87%E8%AE%AD%E7%BB%83%E5%85%B6%E6%A8%A1%E5%9E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771922540000.webp","sourceId":"rfi"},{"id":1771919792000,"createdDate":"2026-02-24 07:56","name":"法国国际广播电台","title":"日本抗议中国宣布严控出口军民两用物项的日本企业与大学等名单","content":"日本政府24日就中国当天宣布对日本20家企业和团体严格限制出口稀土等军民两用物项的措施表示抗议，并要求撤回。日本外务省亚洲大洋洲局局长金井正彰24日向中国驻日大使馆次席公使施泳表示：“该措施不可接受，令人遗憾”，并提出抗议。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260224-%E6%97%A5%E6%9C%AC%E6%8A%97%E8%AE%AE%E4%B8%AD%E5%9B%BD%E5%AE%A3%E5%B8%83%E4%B8%A5%E6%8E%A7%E5%87%BA%E5%8F%A3%E5%86%9B%E6%B0%91%E4%B8%A4%E7%94%A8%E7%89%A9%E9%A1%B9%E7%9A%84%E6%97%A5%E6%9C%AC%E4%BC%81%E4%B8%9A%E4%B8%8E%E5%A4%A7%E5%AD%A6%E7%AD%89%E5%90%8D%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771919792000.webp","sourceId":"rfi"},{"id":1771919418000,"createdDate":"2026-02-24 07:50","name":"法国国际广播电台","title":"香港铁路引入中国标淮 可望减成本 惟评论忧质素及外国参与降","content":"香港政府公布《香港铁路标淮》(下称《港标》)，在现时普遍采用的英国和欧洲标淮之上，引入中国「国家标淮」，并因应本地环境作出调整，为香港新铁路项目提供新规范，甚至成为大湾区标淮，料可缩短新铁路的工期和降低成本，强调表现水平维持不变。不过，有评论忧虑，中国内地认证也可造假，宏福苑夺命火灾中的棚网便是一例，会否影响香港铁路的长期稳定性，须拭目以待；而中国物料的「快丶多丶省」，将令外国竞投者因无法比拟而出局。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260224-%E9%A6%99%E6%B8%AF%E9%93%81%E8%B7%AF%E5%BC%95%E5%85%A5%E4%B8%AD%E5%9B%BD%E6%A0%87%E6%B7%AE-%E5%8F%AF%E6%9C%9B%E5%87%8F%E6%88%90%E6%9C%AC-%E6%83%9F%E8%AF%84%E8%AE%BA%E5%BF%A7%E8%B4%A8%E7%B4%A0%E5%8F%8A%E5%A4%96%E5%9B%BD%E5%8F%82%E4%B8%8E%E9%99%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771919418000.webp","sourceId":"rfi"},{"id":1771951427000,"createdDate":"2026-02-24 16:43","name":"法国国际广播电台","title":"墨西哥出动军队遏制毒枭之死引发的暴力浪潮 距世界杯还有四个月","content":"墨西哥其西部地区部署1万名士兵，以遏制因该国被通缉的头号毒枭死亡而引发的暴力浪潮。相关暴力已造成数十人死亡。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260224-%E5%A2%A8%E8%A5%BF%E5%93%A5%E5%87%BA%E5%8A%A8%E5%86%9B%E9%98%9F%E9%81%8F%E5%88%B6%E6%AF%92%E6%9E%AD%E4%B9%8B%E6%AD%BB%E5%BC%95%E5%8F%91%E7%9A%84%E6%9A%B4%E5%8A%9B%E6%B5%AA%E6%BD%AE-%E8%B7%9D%E4%B8%96%E7%95%8C%E6%9D%AF%E8%BF%98%E6%9C%89%E5%9B%9B%E4%B8%AA%E6%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771951427000.webp","sourceId":"rfi"},{"id":1771946079000,"createdDate":"2026-02-24 15:14","name":"法国国际广播电台","title":"北约秘书长：必须“每天”向乌克兰提供军事支持 光承诺援助不能结束战争","content":"北约秘书长马克·吕特在俄罗斯全面入侵乌克兰四周年之际强调说，基辅的盟友必须“每天”向乌克兰提供军事支持，直到与俄罗斯的战争结束。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260224-%E5%8C%97%E7%BA%A6%E7%A7%98%E4%B9%A6%E9%95%BF-%E5%BF%85%E9%A1%BB-%E6%AF%8F%E5%A4%A9-%E5%90%91%E4%B9%8C%E5%85%8B%E5%85%B0%E6%8F%90%E4%BE%9B%E5%86%9B%E4%BA%8B%E6%94%AF%E6%8C%81-%E5%85%89%E6%89%BF%E8%AF%BA%E6%8F%B4%E5%8A%A9%E4%B8%8D%E8%83%BD%E7%BB%93%E6%9D%9F%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771946079000.webp","sourceId":"rfi"},{"id":1771942405000,"createdDate":"2026-02-24 14:13","name":"法国国际广播电台","title":"乌克兰: 马克龙“非常怀疑”短期内实现和平的可能性","content":"法国总统埃马纽埃尔·马克龙周二与齐聚基辅纪念俄罗斯入侵乌克兰四周年的各国领导人举行视频会议时表示，他对短期内在乌克兰实现和平的可能性“非常怀疑”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260224-%E4%B9%8C%E5%85%8B%E5%85%B0-%E9%A9%AC%E5%85%8B%E9%BE%99-%E9%9D%9E%E5%B8%B8%E6%80%80%E7%96%91-%E7%9F%AD%E6%9C%9F%E5%86%85%E5%AE%9E%E7%8E%B0%E5%92%8C%E5%B9%B3%E7%9A%84%E5%8F%AF%E8%83%BD%E6%80%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771942405000.webp","sourceId":"rfi"},{"id":1771939482000,"createdDate":"2026-02-24 13:24","name":"法国国际广播电台","title":"盘点俄乌战争四年来的环境代价","content":"2026年2月24日是俄乌战争四周年的纪念日，这场战争对俄乌双方都造成了惨重的伤亡，使整个欧洲蒙上了沉重的阴影，也使战争的主战场乌克兰遭受着一场史无前例的环境灾难。法国智库急救恢复与发展组织（URD）的研究员，乌克兰医疗援助委员会主席弗朗索瓦·格律那瓦尔德（FrançoisGrünewald）在接受法广记者FlorentGuignard采访时介绍了他几年来在乌克兰各地走访后的观察。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260224-%E7%9B%98%E7%82%B9%E4%BF%84%E4%B9%8C%E6%88%98%E4%BA%89%E5%9B%9B%E5%B9%B4%E6%9D%A5%E7%9A%84%E7%8E%AF%E5%A2%83%E4%BB%A3%E4%BB%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771939482000.webp","sourceId":"rfi"},{"id":1771938738000,"createdDate":"2026-02-24 13:12","name":"法国国际广播电台","title":"视频 俄乌战争四年 无人机袭击乌克兰平民","content":"俄罗斯入侵乌克兰的四年战争中，俄罗斯无人机的袭击改变了成千上万乌克兰人的日常生活，请看视频报道。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260224-%E8%A7%86%E9%A2%91-%E4%BF%84%E4%B9%8C%E6%88%98%E4%BA%89%E5%9B%9B%E5%B9%B4-%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB%E4%B9%8C%E5%85%8B%E5%85%B0%E5%B9%B3%E6%B0%91","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771938738000.webp","sourceId":"rfi"},{"id":1771937950000,"createdDate":"2026-02-24 12:59","name":"法国国际广播电台","title":"马克龙：俄罗斯在四年战争后遭遇“军事、经济、战略”三重失败","content":"法国总统马克龙承诺将继续提供军事装备和培训“让乌克兰坚持下去，让俄罗斯明白时间不是它的朋友”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260224-%E9%A9%AC%E5%85%8B%E9%BE%99-%E4%BF%84%E7%BD%97%E6%96%AF%E5%9C%A8%E5%9B%9B%E5%B9%B4%E6%88%98%E4%BA%89%E5%90%8E%E9%81%AD%E9%81%87-%E5%86%9B%E4%BA%8B-%E7%BB%8F%E6%B5%8E-%E6%88%98%E7%95%A5-%E4%B8%89%E9%87%8D%E5%A4%B1%E8%B4%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771937950000.webp","sourceId":"rfi"},{"id":1771937347000,"createdDate":"2026-02-24 12:49","name":"法国国际广播电台","title":"乌战四周年 泽连斯基：普京没有打赢这场战争","content":"整整四年。2022年2月24日凌晨，世界在震惊中看到俄罗斯总统普京宣布对乌克兰发起军事入侵。炮火最早在基辅上空炸响，随后拉开了一场漫长而残酷的战争，成为了自第二次世界大战以来欧洲大陆最为血腥的冲突，数十万人伤亡，无数城市与村庄化为废墟，世界政治与安全格局也随之发生深刻改变。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260224-%E4%B9%8C%E6%88%98%E5%9B%9B%E5%91%A8%E5%B9%B4-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E6%99%AE%E4%BA%AC%E6%B2%A1%E6%9C%89%E6%89%93%E8%B5%A2%E8%BF%99%E5%9C%BA%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771937347000.webp","sourceId":"rfi"},{"id":1771937055000,"createdDate":"2026-02-24 12:44","name":"法国国际广播电台","title":"金正恩的妹妹金与正晋升成部长","content":"据朝中社周二报道，朝鲜最高领导人金正恩的妹妹金与正，在五年一次的党代会上获得了晋升。朝鲜劳动党中央委员会周一任命副部长金与正为部长。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260224-%E9%87%91%E6%AD%A3%E6%81%A9%E7%9A%84%E5%A6%B9%E5%A6%B9%E9%87%91%E4%B8%8E%E6%AD%A3%E6%99%8B%E5%8D%87%E6%88%90%E9%83%A8%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771937055000.webp","sourceId":"rfi"},{"id":1771934150000,"createdDate":"2026-02-24 11:55","name":"法国国际广播电台","title":"对冲最高法裁决：美国开征附加关税10% 而不是15%","content":"美国海关周二宣布，对所有进口到美国的商品征收10%的附加关税，享有豁免的商品除外。该税率为唐纳德·特朗普上周五宣布的水平，而非他在上周六改口的15%。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260224-%E5%AF%B9%E5%86%B2%E6%9C%80%E9%AB%98%E6%B3%95%E8%A3%81%E5%86%B3-%E7%BE%8E%E5%9B%BD%E5%BC%80%E5%BE%81%E9%99%84%E5%8A%A0%E5%85%B3%E7%A8%8E10-%E8%80%8C%E4%B8%8D%E6%98%AF15","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771934150000.webp","sourceId":"rfi"},{"id":1771928920000,"createdDate":"2026-02-24 10:28","name":"法国国际广播电台","title":"俄乌战争四周年，双方损失惨重，前景莫测","content":"今天是2月24日，是俄乌战争爆发四周年的日子。今天出版的法国各大日报头版关注的新闻焦点纷纷围绕此一话题展开。各报聚焦的其他重点新闻内容还有：美国最高法院作出裁决后，欧盟暂停与美国去年达成的美欧贸易协定条款；包括法国在内的近20个国家谴责以色列近期关于扩大其在约旦河西岸控制的决定为“事实上的吞并”战略；在经历了动荡的一年后，处于艰难时期的美国总统将发表国情咨文。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260224-%E4%BF%84%E4%B9%8C%E6%88%98%E4%BA%89%E5%9B%9B%E5%91%A8%E5%B9%B4%EF%BC%8C%E5%8F%8C%E6%96%B9%E6%8D%9F%E5%A4%B1%E6%83%A8%E9%87%8D%EF%BC%8C%E5%89%8D%E6%99%AF%E8%8E%AB%E6%B5%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771928920000.webp","sourceId":"rfi"},{"id":1771927362000,"createdDate":"2026-02-24 10:02","name":"法国国际广播电台","title":"中国访港澳旅客大升25%和两成 港客北上消费大增兼全面 澳门丁财两旺","content":"一共九天的中国超长春节假期结束，有150万人次的内地旅客入境香港度新岁，较去年春节大升25%；但受到港人外游人次几乎较大陆旅客多一倍的影响，消费市道并不均匀，大型食肆和着名品牌的市道有所上升，小店则未能受惠。同期，访问澳门的陆客亦超过120万人次，升幅约两成，日均升幅亦达7.2%，当地旅游业议会表示，旅客人次超出预期，带动社区经济和酒店入住率，形容是「丁财两旺」，有信心今年全年旅客量再破纪录。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260224-%E4%B8%AD%E5%9B%BD%E8%AE%BF%E6%B8%AF%E6%BE%B3%E6%97%85%E5%AE%A2%E5%A4%A7%E5%8D%8725-%E5%92%8C%E4%B8%A4%E6%88%90-%E6%B8%AF%E5%AE%A2%E5%8C%97%E4%B8%8A%E6%B6%88%E8%B4%B9%E5%A4%A7%E5%A2%9E%E5%85%BC%E5%85%A8%E9%9D%A2-%E6%BE%B3%E9%97%A8%E4%B8%81%E8%B4%A2%E4%B8%A4%E6%97%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/24/1771927362000.webp","sourceId":"rfi"}]