[{"id":1770567547000,"createdDate":"2026-02-08 16:19","name":"法国国际广播电台","title":"增加对华威慑、维护站点 美将向西澳斯特林基地部署至多4艘潜艇","content":"据《华尔街日报》报导，美国计划在未来几年内向位于澳大利亚西南部的斯特林海军基地部署至多四艘潜艇，首艘预计将于2027年抵达，此举旨在推进与太平洋盟友的军事一体化进程，以威慑中国。澳方正在澳大利亚皇家海军的该基地及其附近的维修区投资数十亿澳元。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260208-%E5%A2%9E%E5%8A%A0%E5%AF%B9%E5%8D%8E%E5%A8%81%E6%85%91%E7%BB%B4%E6%8A%A4%E7%AB%99%E7%82%B9-%E7%BE%8E%E5%B0%86%E5%90%91%E8%A5%BF%E6%BE%B3%E6%96%AF%E7%89%B9%E6%9E%97%E5%9F%BA%E5%9C%B0%E9%83%A8%E7%BD%B2%E8%87%B3%E5%A4%9A4%E8%89%98%E6%BD%9C%E8%89%87","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770567547000.webp","sourceId":"rfi"},{"id":1770563428000,"createdDate":"2026-02-08 15:10","name":"法国国际广播电台","title":"日本众院选举执政联盟远超“绝对安定多数” 赖清德向高市表祝贺","content":"日本众议院选举开票接近尾声，日本放送协会（NHK）报导指，执政联盟已赢得330个议席，远超获得“绝对安定多数”席位所需的261席，其中自民党301席，日本维新会29席。在野党共获得88个席位。仍有47个席位未开出。台湾总统赖清德通过社媒平台X已向日本首相、自民党总裁高市早苗表达了祝贺，并称“期待与您合作，使台日两国持续以共同的价值、互利合作的精神，携手面对区域挑战，促进印太地区的和平与繁荣”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E6%97%A5%E6%9C%AC%E4%BC%97%E9%99%A2%E9%80%89%E4%B8%BE%E6%89%A7%E6%94%BF%E8%81%94%E7%9B%9F%E8%BF%9C%E8%B6%85-%E7%BB%9D%E5%AF%B9%E5%AE%89%E5%AE%9A%E5%A4%9A%E6%95%B0-%E8%B5%96%E6%B8%85%E5%BE%B7%E5%90%91%E9%AB%98%E5%B8%82%E8%A1%A8%E7%A5%9D%E8%B4%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770563428000.webp","sourceId":"rfi"},{"id":1770562474000,"createdDate":"2026-02-08 14:54","name":"法国国际广播电台","title":"涉向中国出售北约军事机密的希腊军官被捕前已遭监视长达一年半","content":"希腊空军一名上校因涉嫌向中国出售北约军事机密，自周四起被拘留。据官员向希腊《每日新闻报》透露，该上校在被捕前已遭监视长达一年半。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260208-%E6%B6%89%E5%90%91%E4%B8%AD%E5%9B%BD%E5%87%BA%E5%94%AE%E5%8C%97%E7%BA%A6%E5%86%9B%E4%BA%8B%E6%9C%BA%E5%AF%86%E7%9A%84%E5%B8%8C%E8%85%8A%E5%86%9B%E5%AE%98%E8%A2%AB%E6%8D%95%E5%89%8D%E5%B7%B2%E9%81%AD%E7%9B%91%E8%A7%86%E9%95%BF%E8%BE%BE%E4%B8%80%E5%B9%B4%E5%8D%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770562474000.webp","sourceId":"rfi"},{"id":1770559684000,"createdDate":"2026-02-08 14:08","name":"法国国际广播电台","title":"日本众院选举执政联盟已获290席 小泉进次郎：宪法改革应迅速进行","content":"当地时间周日23时，日本众议院选举开票持续进行中，日本放送协会（NHK）报导指，执政联盟已赢得290个议席，其中自民党266席，日本维新会24席。在野党共获得72个席位。仍有103个席位未开出。自民党籍防卫大臣小泉进次郎稍早时在电视节目中表示，宪法改革“应该迅速进行”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E6%97%A5%E6%9C%AC%E4%BC%97%E9%99%A2%E9%80%89%E4%B8%BE%E6%89%A7%E6%94%BF%E8%81%94%E7%9B%9F%E5%B7%B2%E8%8E%B7287%E5%B8%AD-%E5%B0%8F%E6%B3%89%E8%BF%9B%E6%AC%A1%E9%83%8E-%E5%AE%AA%E6%B3%95%E6%94%B9%E9%9D%A9%E5%BA%94%E8%BF%85%E9%80%9F%E8%BF%9B%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770559684000.webp","sourceId":"rfi"},{"id":1770558218000,"createdDate":"2026-02-08 13:43","name":"法国国际广播电台","title":"泽连斯基签署法令制裁俄无人机导弹部件外国供应商 含中港实体","content":"据乌克兰总统府消息，在俄罗斯对乌克兰能源基础设施发动大规模空袭数小时后，泽连斯基（VolodymyrZelenskyy）总统周日对数十名向俄战争机器提供资金的个人和公司实施了制裁。这两项法令分别针对无人机和导弹部件的外国供应商，以及帮助俄方规避西方制裁的加密货币网络。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260208-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E7%AD%BE%E7%BD%B2%E6%B3%95%E4%BB%A4%E5%88%B6%E8%A3%81%E4%BF%84%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%92%8C%E5%AF%BC%E5%BC%B9%E9%83%A8%E4%BB%B6%E5%A4%96%E5%9B%BD%E4%BE%9B%E5%BA%94%E5%95%86-%E5%90%AB%E4%B8%AD%E6%B8%AF%E5%AE%9E%E4%BD%93","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770558218000.webp","sourceId":"rfi"},{"id":1770554149000,"createdDate":"2026-02-08 12:35","name":"法国国际广播电台","title":"台媒爆郑习会条件 国民党指均属臆測 萧旭岑斥通篇报导造假","content":"台湾《自由时报》周日独家报导称，来自北京的消息透露，中国“对台工作会议”中将讨论“郑习会”的筹备，“郑习会”预定将于3月中举行，几乎已排上时程。对此，国民党发言人、新北市议员江怡臻回应指，有关郑丽文主席访问大陆，目前尚未有讯息，相关报导均属臆测。曾于本周访问大陆的国民党副主席萧旭岑亦强烈驳斥，表示该报导“每一个字都是编造的”，并称党内律师已准备好，近期将召开记者会正式提告。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E5%8F%B0%E5%AA%92%E7%88%86%E9%83%91%E4%B9%A0%E4%BC%9A%E6%9D%A1%E4%BB%B6-%E5%9B%BD%E6%B0%91%E5%85%9A%E6%8C%87%E5%9D%87%E5%B1%9E%E8%87%86%E6%B8%AC-%E8%90%A7%E6%97%AD%E5%B2%91%E6%96%A5%E9%80%9A%E7%AF%87%E6%8A%A5%E5%AF%BC%E9%80%A0%E5%81%87","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770554149000.webp","sourceId":"rfi"},{"id":1770550227000,"createdDate":"2026-02-08 11:30","name":"法国国际广播电台","title":"哈马斯高级领导人：巴勒斯坦伊斯兰运动不会交出武器","content":"哈马斯一位高级领导人周日表示，巴勒斯坦伊斯兰运动不会交出武器，也不会接受外国干预加沙，以此回击美国和以色列的要求。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260208-%E5%93%88%E9%A9%AC%E6%96%AF%E9%AB%98%E7%BA%A7%E9%A2%86%E5%AF%BC%E4%BA%BA-%E5%B7%B4%E5%8B%92%E6%96%AF%E5%9D%A6%E4%BC%8A%E6%96%AF%E5%85%B0%E8%BF%90%E5%8A%A8%E4%B8%8D%E4%BC%9A%E4%BA%A4%E5%87%BA%E6%AD%A6%E5%99%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770550227000.webp","sourceId":"rfi"},{"id":1770549888000,"createdDate":"2026-02-08 11:24","name":"法国国际广播电台","title":"日本众院选举自民党单独过半数成定局 有望赢得300席","content":"据日本放送协会（NHK）的出口民调和形势分析，自民党有望在本次众议院选举中单独赢得300个席位，远超获得多数席位所需的233席，高市政权预计将继续执政。此外，自民党及其执政联盟伙伴日本维新会有望获得310个席位，占众议院总席位（465个议席）的三分之二。相比之下，反对党“中道改革联合”的席位数量预计将从选前的172席大幅下降至大约一半。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E6%97%A5%E6%9C%AC%E4%BC%97%E9%99%A2%E9%80%89%E4%B8%BE%E8%87%AA%E6%B0%91%E5%85%9A%E5%8D%95%E7%8B%AC%E8%BF%87%E5%8D%8A%E6%95%B0%E6%88%90%E5%AE%9A%E5%B1%80-%E6%9C%89%E6%9C%9B%E8%B5%A2%E5%BE%97300%E5%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770549888000.webp","sourceId":"rfi"},{"id":1770549228000,"createdDate":"2026-02-08 11:13","name":"法国国际广播电台","title":"调查记者刘虎获罪被捕，公权封杀民间监督引热议","content":"1月29日，中国著名调查记者刘虎与合作者巫英蛟在“法与情”公众号发布文章：《曾逼死教授的四川县委书记，如今又把招商企业逼向破产？》；文章依据当事人陈述与相关证据，还原了一位教授疑因强拆自杀、一家企业被逼至绝境的悲剧。三日后，刘虎被成都警方带走，巫英蛟在河北邯郸遭跨省拘捕。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%BE%AE%E8%A8%80%E5%BE%AE%E8%AF%AD/20260208-%E8%B0%83%E6%9F%A5%E8%AE%B0%E8%80%85%E5%88%98%E8%99%8E%E8%8E%B7%E7%BD%AA%E8%A2%AB%E6%8D%95%EF%BC%8C%E5%85%AC%E6%9D%83%E5%B0%81%E6%9D%80%E6%B0%91%E9%97%B4%E7%9B%91%E7%9D%A3%E5%BC%95%E7%83%AD%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770549228000.webp","sourceId":"rfi"},{"id":1770549045000,"createdDate":"2026-02-08 11:10","name":"法国国际广播电台","title":"泰国大选：能否打破恶性循环","content":"2026年泰国大选本周日如期举行。主要党派之间围绕亲他信阵营、改革派阵营以及保守派亲军方阵营展开博弈。大多数泰国选民期盼通过大选寻求高效清廉的政府带领国家走出经济困境，创造发展局面。外界则关注此次政治选举能否推动泰国摆脱政变频发、司法干预以及政府任期短促影响国家发展的恶性循环怪圈。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260208-%E6%B3%B0%E5%9B%BD%E5%A4%A7%E9%80%89-%E8%83%BD%E5%90%A6%E6%89%93%E7%A0%B4%E6%81%B6%E6%80%A7%E5%BE%AA%E7%8E%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770549045000.webp","sourceId":"rfi"},{"id":1770548766000,"createdDate":"2026-02-08 11:06","name":"法国国际广播电台","title":"日本大选遭逢大雪 执政党担忧影响其优势选情","content":"8日，是日本众议院选举的投票计票日，日本很多地方普降大雪，日本海一侧地区为出现暴雪，截至日本时间上午6时41分，青森县、富山县、栃木县、千叶县、长野县、京都府、兵库县、鸟取县、岛根县、冈山县已发布大雪警报。若全国范围内选民出门投票的积极性下降，可能会对投票率产生影响，尤其执政党担心，组织票比较强势的中道改革联合，会在某些选区显现出强势，尤其是在选情胶着的选区，甚至可能左右当选与否。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E6%97%A5%E6%9C%AC%E5%A4%A7%E9%80%89%E9%81%AD%E9%80%A2%E5%A4%A7%E9%9B%AA-%E6%89%A7%E6%94%BF%E5%85%9A%E6%8B%85%E5%BF%A7%E5%BD%B1%E5%93%8D%E5%85%B6%E4%BC%98%E5%8A%BF%E9%80%89%E6%83%85","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770548766000.webp","sourceId":"rfi"},{"id":1770546913000,"createdDate":"2026-02-08 10:35","name":"法国国际广播电台","title":"达赖喇嘛办公室：尊者从未见过爱泼斯坦或有任何接触","content":"达赖喇嘛办公室周日通过声明表示，“近期一些媒体报道和社交媒体帖子试图将达赖喇嘛尊者与爱泼斯坦（JeffreyEpstein）联系起来，这些报道和帖子涉及‘爱泼斯坦档案’。我们可以毫不含糊地确认，达赖喇嘛尊者从未见过爱泼斯坦，也从未授权任何人代表尊者与爱泼斯坦会面或接触”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260208-%E8%BE%BE%E8%B5%96%E5%96%87%E5%98%9B%E5%8A%9E%E5%85%AC%E5%AE%A4-%E5%B0%8A%E8%80%85%E4%BB%8E%E6%9C%AA%E8%A7%81%E8%BF%87%E7%88%B1%E6%B3%BC%E6%96%AF%E5%9D%A6%E6%88%96%E6%9C%89%E4%BB%BB%E4%BD%95%E6%8E%A5%E8%A7%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770546913000.webp","sourceId":"rfi"},{"id":1770545187000,"createdDate":"2026-02-08 10:06","name":"法国国际广播电台","title":"伊朗副外长会见中俄大使通报交流 内塔尼亚胡将提前访问华盛顿","content":"伊朗国际和法律事务副外长加里布阿巴迪周六通过社媒介绍称，其在结束北京之行和阿曼会谈后，当天在德黑兰会见了俄中两国驻伊朗大使。加里布阿巴迪称，三方就共同关心的问题进行了讨论和意见交流。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260208-%E4%BC%8A%E6%9C%97%E5%89%AF%E5%A4%96%E9%95%BF%E4%BC%9A%E8%A7%81%E4%B8%AD%E4%BF%84%E5%A4%A7%E4%BD%BF%E9%80%9A%E6%8A%A5%E4%BA%A4%E6%B5%81-%E5%86%85%E5%A1%94%E5%B0%BC%E4%BA%9A%E8%83%A1%E5%B0%86%E6%8F%90%E5%89%8D%E8%AE%BF%E9%97%AE%E5%8D%8E%E7%9B%9B%E9%A1%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770545187000.webp","sourceId":"rfi"},{"id":1770544217000,"createdDate":"2026-02-08 09:50","name":"法国国际广播电台","title":"马斯克封锁俄军前线星链终端，乌克兰实施“白名单”管控","content":"综合法媒、乌媒消息，近期，俄罗斯军队在前线使用的星链终端有被停用的迹象。这导致部分战线通信受到影响。这一变化尚未引发俄乌战场态势的整体逆转，但在局部地区造成了明显干扰。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260208-%E9%A9%AC%E6%96%AF%E5%85%8B%E5%B0%81%E9%94%81%E4%BF%84%E5%86%9B%E5%89%8D%E7%BA%BF%E6%98%9F%E9%93%BE%E7%BB%88%E7%AB%AF%EF%BC%8C%E4%B9%8C%E5%85%8B%E5%85%B0%E5%AE%9E%E6%96%BD-%E7%99%BD%E5%90%8D%E5%8D%95-%E7%AE%A1%E6%8E%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770544217000.webp","sourceId":"rfi"},{"id":1770595153000,"createdDate":"2026-02-08 23:59","name":"法国国际广播电台","title":"拉丁美洲：中美竞争的新舞台","content":"过去二十年来，中国在大多数拉丁美洲国家的影响力在不断的扩大，尤其是在巴西。现在，特朗普政府试图通过外交压力以及经济和军事威胁来遏制中国在该地区的影响力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%9B%BD%E9%99%85%E7%BA%B5%E6%A8%AA/20260208-%E6%8B%89%E4%B8%81%E7%BE%8E%E6%B4%B2-%E4%B8%AD%E7%BE%8E%E7%AB%9E%E4%BA%89%E7%9A%84%E6%96%B0%E8%88%9E%E5%8F%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770595153000.webp","sourceId":"rfi"},{"id":1770592470000,"createdDate":"2026-02-08 23:14","name":"法国国际广播电台","title":"特朗普称将于2026年底在白宫接待习近平","content":"美国总统特朗普在周日(2月9日)播出的一次采访中表示，他将于“今年年底左右”在白宫接待中国国家主席习近平，双方将讨论包括贸易在内的一系列问题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260208-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E5%B0%86%E4%BA%8E2026%E5%B9%B4%E5%BA%95%E5%9C%A8%E7%99%BD%E5%AE%AB%E6%8E%A5%E5%BE%85%E4%B9%A0%E8%BF%91%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770592470000.webp","sourceId":"rfi"},{"id":1770591496000,"createdDate":"2026-02-08 22:58","name":"法国国际广播电台","title":"刚果(金)将收其遭英国驱逐国民","content":"非洲国家刚果民主共和国（RDCongo）同意接收遭英国（Royaume-Uni）驱逐出境的本国非法居留者。这是本台法广（RFI）法文网今天（2026年02月08号星期日）刊出的最新非洲消息之一。来自非洲大陆的消息说，经过密集的磋商及在英国当局的强大压力下，伦敦和金沙萨最终达成了一项协议：刚果（金）承诺将接收遭英国驱逐的本国无证国民。对此，英国内政大臣谢巴娜·马哈茂德夫人（ShabanaMahmood）在社交媒体X平台上予以祝贺。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260208-%E5%88%9A%E6%9E%9C-%E9%87%91-%E5%B0%86%E6%94%B6%E5%85%B6%E9%81%AD%E8%8B%B1%E5%9B%BD%E9%A9%B1%E9%80%90%E5%9B%BD%E6%B0%91","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770591496000.webp","sourceId":"rfi"},{"id":1770591018000,"createdDate":"2026-02-08 22:50","name":"法国国际广播电台","title":"伊朗态度强硬：即便发生战争也不会放弃铀浓缩  并质疑美国谈判意愿是否真诚","content":"伊朗周日（2月8日）表示，在与美国的谈判中，伊朗不会放弃铀浓缩，“即便与美国发生战争”，同时质疑美国进行“真正谈判”的意愿。而在国内，伊朗也表现出强硬态度。三名改革派人物被逮捕，而2023年诺贝尔和平奖得主、人权活动家默罕默迪被判处六年监禁。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E4%BC%8A%E6%9C%97%E6%80%81%E5%BA%A6%E5%BC%BA%E7%A1%AC-%E5%8D%B3%E4%BE%BF%E5%8F%91%E7%94%9F%E6%88%98%E4%BA%89%E4%B9%9F%E4%B8%8D%E4%BC%9A%E6%94%BE%E5%BC%83%E9%93%80%E6%B5%93%E7%BC%A9-%E5%B9%B6%E8%B4%A8%E7%96%91%E7%BE%8E%E5%9B%BD%E8%B0%88%E5%88%A4%E6%84%8F%E6%84%BF%E6%98%AF%E5%90%A6%E7%9C%9F%E8%AF%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770591018000.webp","sourceId":"rfi"},{"id":1770590533000,"createdDate":"2026-02-08 22:42","name":"法国国际广播电台","title":"葡萄牙总统选举：温和派社会党人塞古罗大胜极右翼对手","content":"周日（2月8日），63岁的温和派社会党人安东尼奥·若泽·塞古罗（AntonioJoséSeguro）在葡萄牙总统选举第二轮投票中取得压倒性胜利，大幅领先极右翼候选人安德烈·文图拉（AndréVentura）。根据已统计95%选区的结果，塞古罗获得66%的选票，而43岁的议员、极右翼政党主席文图拉获得34%的支持率。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260208-%E8%91%A1%E8%90%84%E7%89%99%E6%80%BB%E7%BB%9F%E9%80%89%E4%B8%BE-%E6%B8%A9%E5%92%8C%E6%B4%BE%E7%A4%BE%E4%BC%9A%E5%85%9A%E4%BA%BA%E5%A1%9E%E5%8F%A4%E7%BD%97%E5%A4%A7%E8%83%9C%E6%9E%81%E5%8F%B3%E7%BF%BC%E5%AF%B9%E6%89%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770590533000.webp","sourceId":"rfi"},{"id":1770589073000,"createdDate":"2026-02-08 22:17","name":"法国国际广播电台","title":"非洲次区组织CEMAC暂停活动","content":"非洲次区组织[中部非洲国家经济与货币共同体]（CEMAC）的总部位于中非共和国（RCA-Centrafricaine）首都班吉（Bangui）。这一非洲区域性国际组织旗下有六个成员国，按照字母顺序依次为：喀麦隆（leCameroun）、中非共和国（RCA-Centrafricaine）、刚果共和国（Congo-Brazzaville）、加蓬（leGabon)、赤道几内亚（laGuinéeéquatoriale)及乍得（leTchad)。据本台法广非洲组（RFIAfrique）的法文报道，[中部非洲国家经济与货币共同体]（CEMAC）的委员会，由于资源匮乏而暂停活动。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260208-rfi-%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2%E6%AC%A1%E5%8C%BA%E7%BB%84%E7%BB%87cemac%E6%9A%82%E5%81%9C%E6%B4%BB%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770589073000.webp","sourceId":"rfi"},{"id":1770585463000,"createdDate":"2026-02-08 21:17","name":"法国国际广播电台","title":"高市“碾压式”大胜：自民党成战后首个获得众院三分之二以上议席的单一政党","content":"日本第51届众院选举8日进行投票，自民党的议席数取得压倒性的胜利，在众院465个额定议席中单独确保超过三分之二（310席）。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E9%AB%98%E5%B8%82-%E7%A2%BE%E5%8E%8B%E5%BC%8F-%E5%A4%A7%E8%83%9C-%E8%87%AA%E6%B0%91%E5%85%9A%E6%88%90%E6%88%98%E5%90%8E%E9%A6%96%E4%B8%AA%E8%8E%B7%E5%BE%97%E4%BC%97%E9%99%A2%E4%B8%89%E5%88%86%E4%B9%8B%E4%BA%8C%E4%BB%A5%E4%B8%8A%E8%AE%AE%E5%B8%AD%E7%9A%84%E5%8D%95%E4%B8%80%E6%94%BF%E5%85%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770585463000.webp","sourceId":"rfi"},{"id":1770585443000,"createdDate":"2026-02-08 21:17","name":"法国国际广播电台","title":"特朗普邀请多国领导人出席他的“和平理事会”  部分国家明确拒绝","content":"多位国家领导人已受邀参加美国总统特朗普设立的“和平理事会”首次会议，该会议计划于2月19日举行。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E7%89%B9%E6%9C%97%E6%99%AE%E9%82%80%E8%AF%B7%E5%A4%9A%E5%9B%BD%E9%A2%86%E5%AF%BC%E4%BA%BA%E5%87%BA%E5%B8%AD%E4%BB%96%E7%9A%84-%E5%92%8C%E5%B9%B3%E7%90%86%E4%BA%8B%E4%BC%9A-%E9%83%A8%E5%88%86%E5%9B%BD%E5%AE%B6%E6%98%8E%E7%A1%AE%E6%8B%92%E7%BB%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770585443000.webp","sourceId":"rfi"},{"id":1770584824000,"createdDate":"2026-02-08 21:07","name":"法国国际广播电台","title":"中国支持普京的战争机器——却同时帮助乌克兰","content":"据《柏林晨报》报道：尽管中国在乌克兰战争上对外展示出所谓的中立立场，但早已有充分证据表明，中国的工厂正在维持普京战争机器的运转。与此同时，中国却也在扶持乌克兰。中国领导层采取的双重战略背后，不仅仅是经济利益。北京还有其他目标。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260208-%E4%B8%AD%E5%9B%BD%E6%94%AF%E6%8C%81%E6%99%AE%E4%BA%AC%E7%9A%84%E6%88%98%E4%BA%89%E6%9C%BA%E5%99%A8-%E5%8D%B4%E5%90%8C%E6%97%B6%E5%B8%AE%E5%8A%A9%E4%B9%8C%E5%85%8B%E5%85%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770584824000.webp","sourceId":"rfi"},{"id":1770584298000,"createdDate":"2026-02-08 20:58","name":"法国国际广播电台","title":"印度总理莫迪到访全球第六大半导体出口国马来西亚","content":"印度总理莫迪正在马来西亚进行为期2天访问，他和马来西亚首相安华8日再次承诺加强经贸往来，并探索半导体、防务与其他领域的合作机会。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260208-%E5%8D%B0%E5%BA%A6%E6%80%BB%E7%90%86%E8%8E%AB%E8%BF%AA%E5%88%B0%E8%AE%BF%E5%85%A8%E7%90%83%E7%AC%AC%E5%85%AD%E5%A4%A7%E5%8D%8A%E5%AF%BC%E4%BD%93%E5%87%BA%E5%8F%A3%E5%9B%BD%E9%A9%AC%E6%9D%A5%E8%A5%BF%E4%BA%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770584298000.webp","sourceId":"rfi"},{"id":1770582899000,"createdDate":"2026-02-08 20:34","name":"法国国际广播电台","title":"“爱泼斯坦案”持续引发欧洲政坛震荡 斯塔默“右手”、关键幕僚长辞职","content":"随着美国司法部近期公布“爱泼斯坦案”相关文件，最新披露的内容令斯塔默政府陷入一场前所未有的危机。他的幕僚长摩根·麦克斯威尼（MorganMcSweeney）周日宣布辞职。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E7%88%B1%E6%B3%BC%E6%96%AF%E5%9D%A6%E6%A1%88-%E6%8C%81%E7%BB%AD%E5%BC%95%E5%8F%91%E6%AC%A7%E6%B4%B2%E6%94%BF%E5%9D%9B%E9%9C%87%E8%8D%A1-%E6%96%AF%E5%A1%94%E9%BB%98-%E5%8F%B3%E6%89%8B-%E5%B7%A5%E5%85%9A%E5%85%B3%E9%94%AE%E5%B9%95%E5%83%9A%E9%95%BF%E8%BE%9E%E8%81%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770582899000.webp","sourceId":"rfi"},{"id":1770582874000,"createdDate":"2026-02-08 20:34","name":"法国国际广播电台","title":"伊朗女权活动人士、诺贝尔和平奖得主穆罕默迪再次被判刑","content":"伊朗女权活动人士、诺贝尔和平奖得主纳尔格斯·穆罕默迪（NargesMohammadi）在为女性权利奋斗的三十年间曾多次入狱。她的律师周日（2月8日）对法新社表示，穆罕默迪因“集会并串谋实施犯罪”被判处六年监禁，同时还被禁止出境两年。律师补充说，在另一宗案件中，她还因“从事宣传活动”被判处一年半监禁，并被流放两年，前往南呼罗珊省东部的霍斯夫（Khosf）市服刑。但根据伊朗法律，多项监禁刑期不累计执行。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E4%BC%8A%E6%9C%97%E5%A5%B3%E6%9D%83%E6%B4%BB%E5%8A%A8%E4%BA%BA%E5%A3%AB-%E8%AF%BA%E8%B4%9D%E5%B0%94%E5%92%8C%E5%B9%B3%E5%A5%96%E5%BE%97%E4%B8%BB%E7%A9%86%E7%BD%95%E9%BB%98%E8%BF%AA%E5%86%8D%E6%AC%A1%E8%A2%AB%E5%88%A4%E5%85%AD%E5%B9%B4%E7%9B%91%E7%A6%81","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770582874000.webp","sourceId":"rfi"},{"id":1770582855000,"createdDate":"2026-02-08 20:34","name":"法国国际广播电台","title":"借民族主义情绪俘获选民 泰国总理阿努廷在大选中意外获胜","content":"泰国保守派总理阿努廷·春维拉库尔（AnutinCharnvirakul）周日（2月8日）宣布在立法选举中获胜。在民族主义情绪推波助澜下，他领导的政党自豪泰党出人意料地逆转预期局势，成为议会中最大的党团，选前民调原本预计该党位居第二。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E5%80%9F%E6%B0%91%E6%97%8F%E4%B8%BB%E4%B9%89%E6%83%85%E7%BB%AA%E4%BF%98%E8%8E%B7%E9%80%89%E6%B0%91-%E6%B3%B0%E5%9B%BD%E6%80%BB%E7%90%86%E9%98%BF%E5%8A%AA%E5%BB%B7%E5%9C%A8%E5%A4%A7%E9%80%89%E4%B8%AD%E6%84%8F%E5%A4%96%E8%8E%B7%E8%83%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770582855000.webp","sourceId":"rfi"},{"id":1770582824000,"createdDate":"2026-02-08 20:33","name":"法国国际广播电台","title":"委内瑞拉反对派人士、马查多的亲密盟友瓜尼帕获释 全面大赦法将于下周二通过","content":"委内瑞拉反对派领袖、诺贝尔和平奖得主玛丽亚·科里纳·马查多（MaríaCorinaMachado）的亲密盟友胡安·巴勃罗·瓜尼帕（JuanPabloGuanipa）周日（2月8日）获释出狱，并呼吁就国家的“现状”和“未来”展开讨论。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E5%8F%8D%E5%AF%B9%E6%B4%BE%E4%BA%BA%E5%A3%AB-%E9%A9%AC%E6%9F%A5%E5%A4%9A%E7%9A%84%E4%BA%B2%E5%AF%86%E7%9B%9F%E5%8F%8B%E7%93%9C%E5%B0%BC%E5%B8%95%E8%8E%B7%E9%87%8A-%E5%85%A8%E9%9D%A2%E5%A4%A7%E8%B5%A6%E6%B3%95%E5%B0%86%E4%BA%8E%E4%B8%8B%E5%91%A8%E4%BA%8C%E9%80%9A%E8%BF%87","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770582824000.webp","sourceId":"rfi"},{"id":1770581308000,"createdDate":"2026-02-08 20:08","name":"法国国际广播电台","title":"高市早苗力赌日本众院选举获亮眼成绩","content":"周日（2月8日）举行的日本众议院选举备受全球关注。从开票不久后确定单独过半，席次一路飙涨，最终来到自民党单独突破众议院2/3的313席，执政联盟则在众议院拿下了近四分之三的“超级多数”席位。这不仅是日本战后单一政党取得的最多议席，更是一场历史性的胜利","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260208-%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E5%8A%9B%E8%B5%8C%E6%97%A5%E6%9C%AC%E4%BC%97%E9%99%A2%E9%80%89%E4%B8%BE%E8%8E%B7%E4%BA%AE%E7%9C%BC%E6%88%90%E7%BB%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770581308000.webp","sourceId":"rfi"},{"id":1770572089000,"createdDate":"2026-02-08 17:34","name":"法国国际广播电台","title":"拦截通话未送国会引风暴 吹哨者控美情报总监加巴德直接送白宫","content":"美国国家安全体系近日卷入一场高度敏感的情报争议。一名情报界吹哨者指控，国家情报总监加巴德（TulsiGabbard）涉嫌不当处理一份极度机密的情报，该情报源自美国国家安全局（NSA）拦截的一通涉及外国情报人员、并提及一名“与美国总统特朗普（DonaldTrump）关系密切人士”的电话，引发华盛顿政坛震荡。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E6%8B%A6%E6%88%AA%E9%80%9A%E8%AF%9D%E6%9C%AA%E9%80%81%E5%9B%BD%E4%BC%9A%E5%BC%95%E9%A3%8E%E6%9A%B4-%E5%90%B9%E5%93%A8%E8%80%85%E6%8E%A7%E7%BE%8E%E6%83%85%E6%8A%A5%E6%80%BB%E7%9B%91%E5%8A%A0%E5%B7%B4%E5%BE%B7%E7%9B%B4%E6%8E%A5%E9%80%81%E7%99%BD%E5%AE%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770572089000.webp","sourceId":"rfi"},{"id":1770569119000,"createdDate":"2026-02-08 16:45","name":"法国国际广播电台","title":"日本众院选举自民党已独得313席 高市致谢特朗普：同盟潜力是无限的","content":"日本众议院选举开票接近尾声，日本放送协会（NHK）报导指，执政联盟已赢得345个议席，其中自民党313席，日本维新会32席。在野党共获得101个席位。仍有19个席位未开出。自民党总裁高市早苗向先前为她公开站台的美国总统特朗普表示感谢，并称“期待今年春天访问白宫，并继续与美国携手合作，进一步加强日美同盟”。高市续称，“我们同盟的潜力是无限的”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260208-%E6%97%A5%E6%9C%AC%E4%BC%97%E9%99%A2%E9%80%89%E4%B8%BE%E8%87%AA%E6%B0%91%E5%85%9A%E5%B7%B2%E7%8B%AC%E5%BE%97313%E5%B8%AD-%E9%AB%98%E5%B8%82%E8%87%B4%E8%B0%A2%E7%89%B9%E6%9C%97%E6%99%AE-%E5%90%8C%E7%9B%9F%E6%BD%9C%E5%8A%9B%E6%98%AF%E6%97%A0%E9%99%90%E7%9A%84","thumbnail":"","detailImage":"news/detail/rfi/2026/02/08/1770569119000.webp","sourceId":"rfi"}]