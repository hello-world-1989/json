[{"id":1771632341000,"createdDate":"2026-02-21 00:05","name":"法国国际广播电台","title":"安德鲁再遭搜查，英王室陷入前所未有的危机","content":"英国警方周五连续第二天对前英国王子安德鲁·蒙巴顿-温莎的前住所进行搜查。此前一天，安德鲁因爱泼斯坦案被短暂拘捕。此举使英国王室陷入前所未有的危机。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260221-%E5%AE%89%E5%BE%B7%E9%B2%81%E5%86%8D%E9%81%AD%E6%90%9C%E6%9F%A5%EF%BC%8C%E8%8B%B1%E7%8E%8B%E5%AE%A4%E9%99%B7%E5%85%A5%E5%89%8D%E6%89%80%E6%9C%AA%E6%9C%89%E7%9A%84%E5%8D%B1%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771632341000.webp","sourceId":"rfi"},{"id":1771632062000,"createdDate":"2026-02-21 00:01","name":"法国国际广播电台","title":"如何在中国面前拯救国际贸易体系？“志愿者联盟”？","content":"法国国际贸易领域的智库--出口促进组织的主席、国际贸易专家阿兰·邦泰雅克（AlainBentéjac），周五在法国《世界报》发表署名文章，呼吁发起一个“志愿者联盟”，以便在中国这一“超级强权”面前拯救国际贸易体系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260221-%E5%A6%82%E4%BD%95%E5%9C%A8%E4%B8%AD%E5%9B%BD%E9%9D%A2%E5%89%8D%E6%8B%AF%E6%95%91%E5%9B%BD%E9%99%85%E8%B4%B8%E6%98%93%E4%BD%93%E7%B3%BB%EF%BC%8C-%E5%BF%97%E6%84%BF%E8%80%85%E8%81%94%E7%9B%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771632062000.webp","sourceId":"rfi"},{"id":1771663623000,"createdDate":"2026-02-21 08:47","name":"法国国际广播电台","title":"欧洲五国启动边防新计划：利用乌克兰技术研发低成本无人机防御系统","content":"美联社周六（2月21日）消息称，五个欧洲国家宣布启动一项新计划，利用乌克兰在过去四年对俄战争中积累的实战经验，生产低成本防空系统和自主无人机。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260221-%E6%AC%A7%E6%B4%B2%E4%BA%94%E5%9B%BD%E5%90%AF%E5%8A%A8%E8%BE%B9%E9%98%B2%E6%96%B0%E8%AE%A1%E5%88%92-%E5%88%A9%E7%94%A8%E4%B9%8C%E5%85%8B%E5%85%B0%E6%8A%80%E6%9C%AF%E7%A0%94%E5%8F%91%E4%BD%8E%E6%88%90%E6%9C%AC%E6%97%A0%E4%BA%BA%E6%9C%BA%E9%98%B2%E5%BE%A1%E7%B3%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771663623000.webp","sourceId":"rfi"},{"id":1771689412000,"createdDate":"2026-02-21 15:56","name":"法国国际广播电台","title":"法国总统马克龙评美国最高法推翻特朗普总统对等关税：“在民主制度下拥有权力与制衡是件好事情”","content":"美国最高法院对特朗普的对等关税政策作出重大打击后，法国总统马克龙周六强调“民主国家存在权力与制衡”的重要性。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260221-%E6%B3%95%E5%9B%BD%E6%80%BB%E7%BB%9F%E9%A9%AC%E5%85%8B%E9%BE%99%E8%AF%84%E7%BE%8E%E5%9B%BD%E6%9C%80%E9%AB%98%E6%B3%95%E6%8E%A8%E7%BF%BB%E7%89%B9%E6%9C%97%E6%99%AE%E6%80%BB%E7%BB%9F%E5%AF%B9%E7%AD%89%E5%85%B3%E7%A8%8E-%E5%9C%A8%E6%B0%91%E4%B8%BB%E5%88%B6%E5%BA%A6%E4%B8%8B%E6%8B%A5%E6%9C%89%E6%9D%83%E5%8A%9B%E4%B8%8E%E5%88%B6%E8%A1%A1%E6%98%AF%E4%BB%B6%E5%A5%BD%E4%BA%8B%E6%83%85","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771689412000.webp","sourceId":"rfi"},{"id":1771685726000,"createdDate":"2026-02-21 14:55","name":"法国国际广播电台","title":"泽连斯基: 乌克兰绝对没输 刚刚趁星链封锁夺回300平方公里","content":"乌克兰总统沃洛季米尔·泽连斯基周五接受法新社独家采访时表示，在俄罗斯入侵即将四周年之际，乌克兰与俄罗斯的战争结果仍不明朗，但对乌克兰而言并非败局。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260221-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E4%B9%8C%E5%85%8B%E5%85%B0%E7%BB%9D%E5%AF%B9%E6%B2%A1%E8%BE%93-%E5%88%9A%E5%88%9A%E8%B6%81%E6%98%9F%E9%93%BE%E5%B0%81%E9%94%81%E5%A4%BA%E5%9B%9E300%E5%B9%B3%E6%96%B9%E5%85%AC%E9%87%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771685726000.webp","sourceId":"rfi"},{"id":1771679288000,"createdDate":"2026-02-21 13:08","name":"法国国际广播电台","title":"美国最高法院关税裁决：对特朗普的一记耳光","content":"周末出刊的左右两份大报《解放报》和《费加罗报》就国内事务主要围绕两大议题展开，首先是极右翼青年昆汀德朗科之死持续引发一周来政坛对立和社会紧张，周六极右翼团体计划举行多场悼念游行，在悲剧发生地的里昂或有三千人集会，警方担忧极左“反法西斯”团体发起对抗行动，可能导致暴力冲突，已部署大规模警力防止局势失控。报道也关注法国极右政党国民联盟主席巴尔德拉对昆廷遇害事件所采取的谨慎政治立场。面对多地悼念活动可能的极右翼与极左对抗风险，他明确要求其党内成员及议员不要参与相关集会，以避免与其它“极右小团体”产生关联。与此同时，他继续攻击左翼阵营应为昆汀之死负责。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260221-%E7%BE%8E%E5%9B%BD%E6%9C%80%E9%AB%98%E6%B3%95%E9%99%A2%E5%85%B3%E7%A8%8E%E8%A3%81%E5%86%B3-%E5%AF%B9%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84%E4%B8%80%E8%AE%B0%E8%80%B3%E5%85%89","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771679288000.webp","sourceId":"rfi"},{"id":1771677257000,"createdDate":"2026-02-21 12:34","name":"法国国际广播电台","title":"美国因中国电缆计划吊销智利三名官员及亲属签证","content":"美国周五宣布对三名智利政府官员实施签证限制，其中包括交通和电信部长。法新社说，此举是在华盛顿与即将离任的总统加布里埃尔·博里奇政府关系紧张的背景下做出的。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260221-%E7%BE%8E%E5%9B%BD%E5%9B%A0%E4%B8%AD%E5%9B%BD%E7%94%B5%E7%BC%86%E8%AE%A1%E5%88%92%E5%90%8A%E9%94%80%E6%99%BA%E5%88%A9%E4%B8%89%E5%90%8D%E5%AE%98%E5%91%98%E5%8F%8A%E4%BA%B2%E5%B1%9E%E7%AD%BE%E8%AF%81","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771677257000.webp","sourceId":"rfi"},{"id":1771673027000,"createdDate":"2026-02-21 11:23","name":"法国国际广播电台","title":"人工智能 ：美国反数据库抗议为何日益频繁？","content":"刚刚落幕的印度人工智能峰会再度将相关的讨论推向前台，人工智能，特别是生成式人工智能被认为是二十一世纪一场具有重大颠覆性的技术革命，评论普遍认为它将会重塑产业，提高生产力，推动全球经济的划时代的转型。不过，与此同时，人工智能的开发也带来了前所未有的风险与挑战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E5%A2%83%E4%B8%8E%E5%8F%91%E5%B1%95/20260221-%E4%BB%BB%E9%82%B5%E7%A3%8A-%E7%BE%8E%E5%9B%BD%E5%BB%BA%E6%95%B0%E6%8D%AE%E4%B8%AD%E5%BF%83%E9%9D%A2%E4%B8%B4%E4%B8%89%E5%A4%A7%E6%8C%91%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771673027000.webp","sourceId":"rfi"},{"id":1771671963000,"createdDate":"2026-02-21 11:06","name":"法国国际广播电台","title":"日本文科大臣反驳中国驻日使馆连续批判日本教科书","content":"中国驻日本大使馆近日在社交媒体上连续发文称，日本历史教科书的相关表述存在美化二战中的日本等问题。对此，日本文部科学大臣松本洋平在20日内阁会议后的记者会上反驳称：“我国的教科书审定，是根据当时客观的学术成果及适当资料来实施的。”","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260221-%E6%97%A5%E6%9C%AC%E6%96%87%E7%A7%91%E5%A4%A7%E8%87%A3%E5%8F%8D%E9%A9%B3%E4%B8%AD%E5%9B%BD%E9%A9%BB%E6%97%A5%E4%BD%BF%E9%A6%86%E8%BF%9E%E7%BB%AD%E6%89%B9%E5%88%A4%E6%97%A5%E6%9C%AC%E6%95%99%E7%A7%91%E4%B9%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771671963000.webp","sourceId":"rfi"},{"id":1771671009000,"createdDate":"2026-02-21 10:50","name":"法国国际广播电台","title":"深受法国民众喜爱的国际农业博览会开幕：今年的现场没有牛，并且马克龙不受欢迎","content":"周六（2月21日）上午，法国一年一度著名的巴黎国际农业博览会开幕，它是法国规模最大的农业盛会，也是欧洲同类展会中规模最大的盛会。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260221-%E6%B7%B1%E5%8F%97%E6%B3%95%E5%9B%BD%E6%B0%91%E4%BC%97%E5%96%9C%E7%88%B1%E7%9A%84%E5%9B%BD%E9%99%85%E5%86%9C%E4%B8%9A%E5%8D%9A%E8%A7%88%E4%BC%9A%E5%BC%80%E5%B9%95-%E4%BB%8A%E5%B9%B4%E6%B2%A1%E6%9C%89%E7%89%9B%EF%BC%8C%E5%B9%B6%E4%B8%94%E9%A9%AC%E5%85%8B%E9%BE%99%E4%B8%8D%E5%8F%97%E6%AC%A2%E8%BF%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771671009000.webp","sourceId":"rfi"},{"id":1771665776000,"createdDate":"2026-02-21 09:22","name":"法国国际广播电台","title":"委内瑞拉通过大赦法案后宣布释放数百名政治犯","content":"委内瑞拉在总统马杜罗被美国抓捕近两个月后，根据议会刚刚通过的一项有限特赦政治犯法案，司法机关周五（2月20日）晚间批准释放数百名政治犯。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260221-%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E9%80%9A%E8%BF%87%E5%A4%A7%E8%B5%A6%E6%B3%95%E6%A1%88%E5%90%8E%E5%AE%A3%E5%B8%83%E9%87%8A%E6%94%BE%E6%95%B0%E7%99%BE%E5%90%8D%E6%94%BF%E6%B2%BB%E7%8A%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771665776000.webp","sourceId":"rfi"},{"id":1771710862000,"createdDate":"2026-02-21 21:54","name":"法国国际广播电台","title":"印度减少对华依赖　携手巴西深化关键矿产与稀土合作","content":"印度与巴西周六(2月21日）在新德里签署协议，加强在关键矿产和稀土领域的合作。印度总理莫迪与巴西总统卢拉会谈后表示，此举是推动供应链多元化、减少对中国依赖的重要一步。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260221-%E5%8D%B0%E5%BA%A6%E5%87%8F%E5%B0%91%E5%AF%B9%E5%8D%8E%E4%BE%9D%E8%B5%96-%E6%90%BA%E6%89%8B%E5%B7%B4%E8%A5%BF%E6%B7%B1%E5%8C%96%E5%85%B3%E9%94%AE%E7%9F%BF%E4%BA%A7%E4%B8%8E%E7%A8%80%E5%9C%9F%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771710862000.webp","sourceId":"rfi"},{"id":1771710457000,"createdDate":"2026-02-21 21:47","name":"法国国际广播电台","title":"7名中国游客贝加尔湖遇难 目击者称司机无视冰裂","content":"俄罗斯贝加尔湖冰面周五(2月20日）发生汽车翻覆事故，造成8人死亡，包括司机及7名中国游客。目击者表示，俄罗斯司机发现冰面裂缝后没有停车绕行，反而试图加速通过，直接导致事故发生。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260221-7%E5%90%8D%E4%B8%AD%E5%9B%BD%E6%B8%B8%E5%AE%A2%E8%B4%9D%E5%8A%A0%E5%B0%94%E6%B9%96%E9%81%87%E9%9A%BE-%E7%9B%AE%E5%87%BB%E8%80%85%E7%A7%B0%E5%8F%B8%E6%9C%BA%E6%97%A0%E8%A7%86%E5%86%B0%E8%A3%82","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771710457000.webp","sourceId":"rfi"},{"id":1771710239000,"createdDate":"2026-02-21 21:43","name":"法国国际广播电台","title":"香港拟斥资40亿港元收购宏福苑物业 安置近两千受火灾影响家庭","content":"香港政府提出动用约40亿港元（约5.12亿美元），收购在去年11月致命大火中严重受损的高层住宅项目宏福苑（WangFukCourt）物业，以安置近2,000个受影响家庭。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260221-%E9%A6%99%E6%B8%AF%E6%8B%9F%E6%96%A5%E8%B5%8440%E4%BA%BF%E6%B8%AF%E5%85%83%E6%94%B6%E8%B4%AD%E5%AE%8F%E7%A6%8F%E8%8B%91%E5%8D%95%E4%BD%8D-%E5%AE%89%E7%BD%AE%E8%BF%91%E4%B8%A4%E5%8D%83%E5%8F%97%E7%81%AB%E7%81%BE%E5%BD%B1%E5%93%8D%E5%AE%B6%E5%BA%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771710239000.webp","sourceId":"rfi"},{"id":1771710008000,"createdDate":"2026-02-21 21:40","name":"法国国际广播电台","title":"特朗普下月访华 关税争议再成焦点","content":"美国总统特朗普将于3月31日至4月2日访问中国，与中国国家主席习近平举行备受瞩目的会晤。此行消息公布之际，美国最高法院刚刚推翻了特朗普政府此前实施的大规模进口关税措施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260221-%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%8B%E6%9C%88%E8%AE%BF%E5%8D%8E-%E5%85%B3%E7%A8%8E%E4%BA%89%E8%AE%AE%E5%86%8D%E6%88%90%E7%84%A6%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771710008000.webp","sourceId":"rfi"},{"id":1771710002000,"createdDate":"2026-02-21 21:40","name":"法国国际广播电台","title":"悼念一名极右翼活动人士昆汀·德朗克的活动在法国东南部举行， 总统马克龙敦促所有人保持冷静","content":"周六，数千人在法国东南部举行游行，悼念一名极右翼活动人士昆汀·德朗克。他的遇害被归咎于极左翼势力，令整个法国陷入紧张局势。这场活动被极端民族主义和极右翼团体在网上广泛宣传，法国政府部署了包括无人机在内的严密安保措施，以防此次活动再次发生冲突。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260221-%E6%82%BC%E5%BF%B5%E4%B8%80%E5%90%8D%E6%9E%81%E5%8F%B3%E7%BF%BC%E6%B4%BB%E5%8A%A8%E4%BA%BA%E5%A3%AB%E6%98%86%E6%B1%80%C2%B7%E5%BE%B7%E6%9C%97%E5%85%8B%E7%9A%84%E6%B4%BB%E5%8A%A8%E5%9C%A8%E6%B3%95%E5%9B%BD%E4%B8%9C%E5%8D%97%E9%83%A8%E4%B8%BE%E8%A1%8C%E6%B8%B8%E8%A1%8C%EF%BC%8C-%E6%80%BB%E7%BB%9F%E9%A9%AC%E5%85%8B%E9%BE%99%E6%95%A6%E4%BF%83%E6%89%80%E6%9C%89%E4%BA%BA%E4%BF%9D%E6%8C%81%E5%86%B7%E9%9D%99","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771710002000.webp","sourceId":"rfi"},{"id":1771709724000,"createdDate":"2026-02-21 21:35","name":"法国国际广播电台","title":"特朗普宣布：全球关税从10%上调至15%","content":"在美国最高法院裁定特朗普大规模关税违法后，美国总统特朗普周六(2月21日）宣布，将针对所有国家进口商品的临时统一关税税率从10%上调至15%，即现行法律允许的最高水平，并“立即生效”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260221-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AE%A3%E5%B8%83-%E5%85%A8%E7%90%83%E5%85%B3%E7%A8%8E%E4%BB%8E10-%E4%B8%8A%E8%B0%83%E8%87%B315","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771709724000.webp","sourceId":"rfi"},{"id":1771709690000,"createdDate":"2026-02-21 21:34","name":"法国国际广播电台","title":"特朗普昨天说将全球进口美国商品的关税提高到10%， 今天说提高到15%","content":"周六，美国总统特朗普说将美国进口商品的全球关税提高至15%。在美国最高法院以6比3的投票结果驳回特朗普根据1977年《经济紧急权力法》征收关税的权力，裁定特朗普大部分关税政策非法后不久，特朗普最初援引另一条法律途径宣布征收10%的全球关税。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260221-%E7%89%B9%E6%9C%97%E6%99%AE%E6%98%A8%E5%A4%A9%E8%AF%B4%E5%B0%86%E5%85%A8%E7%90%83%E8%BF%9B%E5%8F%A3%E7%BE%8E%E5%9B%BD%E5%95%86%E5%93%81%E7%9A%84%E5%85%B3%E7%A8%8E%E6%8F%90%E9%AB%98%E5%88%B010-%EF%BC%8C-%E4%BB%8A%E5%A4%A9%E8%AF%B4%E6%8F%90%E9%AB%98%E5%88%B015","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771709690000.webp","sourceId":"rfi"},{"id":1771699266000,"createdDate":"2026-02-21 18:41","name":"法国国际广播电台","title":"默茨访华前夕：德国经济界因中国问题敲响警钟","content":"据德国《商报》报道，德国总理默茨即将访华之际，德国经济界亚太委员会（APA）就来自中国的经济威胁发出警告。产能过剩和人民币问题被视为对市场的威胁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260221-%E9%BB%98%E8%8C%A8%E8%AE%BF%E5%8D%8E%E5%89%8D%E5%A4%95-%E5%BE%B7%E5%9B%BD%E7%BB%8F%E6%B5%8E%E7%95%8C%E5%9B%A0%E4%B8%AD%E5%9B%BD%E9%97%AE%E9%A2%98%E6%95%B2%E5%93%8D%E8%AD%A6%E9%92%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771699266000.webp","sourceId":"rfi"},{"id":1771699136000,"createdDate":"2026-02-21 18:38","name":"法国国际广播电台","title":"国会握关税生杀大权　特朗普受挫后两党路线分歧浮现","content":"美国最高法院裁定美国总统特朗普（DonaldTrump）依据《国际紧急经济权力法》（IEEPA）对全球多国加征的广泛性关税违宪后，贸易政策主导权迅速回到国会手中。两党如何回应，不仅牵动行政与立法权力分立，更将影响共和党内部团结与民主党的选举攻势。以下依共和党、民主党与背景脉络分述。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260221-%E5%9B%BD%E4%BC%9A%E6%8F%A1%E5%85%B3%E7%A8%8E%E7%94%9F%E6%9D%80%E5%A4%A7%E6%9D%83-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%97%E6%8C%AB%E5%90%8E%E4%B8%A4%E5%85%9A%E8%B7%AF%E7%BA%BF%E5%88%86%E6%AD%A7%E6%B5%AE%E7%8E%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771699136000.webp","sourceId":"rfi"},{"id":1771699057000,"createdDate":"2026-02-21 18:37","name":"法国国际广播电台","title":"美国正与印度谈判 促其购买更多委内瑞拉原油代替俄油","content":"美国正与印度进行“积极谈判，希望印度从委内瑞拉购买石油。后者正寻求减少对俄罗斯石油的依赖","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260221-%E7%BE%8E%E5%9B%BD%E6%AD%A3%E4%B8%8E%E5%8D%B0%E5%BA%A6%E8%B0%88%E5%88%A4-%E4%BF%83%E5%85%B6%E8%B4%AD%E4%B9%B0%E6%9B%B4%E5%A4%9A%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E5%8E%9F%E6%B2%B9%E4%BB%A3%E6%9B%BF%E4%BF%84%E6%B2%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771699057000.webp","sourceId":"rfi"},{"id":1771696706000,"createdDate":"2026-02-21 17:58","name":"法国国际广播电台","title":"乌克兰称打击了俄罗斯境内弹道导弹制造厂","content":"乌克兰总参谋部周六表示，乌克兰对俄罗斯乌德穆尔特共和国的一家弹道导弹制造厂实施了打击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260221-%E4%B9%8C%E5%85%8B%E5%85%B0%E7%A7%B0%E6%89%93%E5%87%BB%E4%BA%86%E4%BF%84%E7%BD%97%E6%96%AF%E5%A2%83%E5%86%85%E4%B8%80%E5%BC%B9%E9%81%93%E5%AF%BC%E5%BC%B9%E5%88%B6%E9%80%A0%E5%8E%82","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771696706000.webp","sourceId":"rfi"},{"id":1771695188000,"createdDate":"2026-02-21 17:33","name":"法国国际广播电台","title":"俄罗斯幽灵船队油轮中国籍船长面临法国司法审判","content":"俄罗斯幽灵舰队油轮长滩岛号（Boracay又名Phoenix）的船长拒不配合执法案下周一（2月23日）将在法国开庭。该油轮于2025年9月在法国布列塔尼海岸附近被扣押。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260221-%E4%BF%84%E7%BD%97%E6%96%AF%E5%B9%BD%E7%81%B5%E8%88%B9%E9%98%9F%E6%B2%B9%E8%BD%AE%E4%B8%AD%E5%9B%BD%E7%B1%8D%E8%88%B9%E9%95%BF%E9%9D%A2%E4%B8%B4%E6%B3%95%E5%9B%BD%E5%8F%B8%E6%B3%95%E5%AE%A1%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771695188000.webp","sourceId":"rfi"},{"id":1771692385000,"createdDate":"2026-02-21 16:46","name":"法国国际广播电台","title":"印度AI峰会联合声明出炉：美中等80多国呼吁打造“安全、可信、强大的人工智能”","content":"新德里AI峰会于周五闭幕后，周六一份由包括美国和中国在内的86国和两个国际组织签署的声明称：“推广安全、可信、强大的人工智能对于建立信任并最大限度发挥社会及经济效益至关重要。”","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260221-%E5%8D%B0%E5%BA%A6ai%E5%B3%B0%E4%BC%9A%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E%E5%87%BA%E7%82%89-%E6%95%B0%E5%8D%81%E5%9B%BD%E5%91%BC%E5%90%81%E6%89%93%E9%80%A0-%E5%AE%89%E5%85%A8-%E5%8F%AF%E4%BF%A1-%E5%BC%BA%E5%A4%A7%E7%9A%84%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771692385000.webp","sourceId":"rfi"}]