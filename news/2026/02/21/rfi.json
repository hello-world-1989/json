[{"id":1771632341000,"createdDate":"2026-02-21 00:05","name":"法国国际广播电台","title":"安德鲁再遭搜查，英王室陷入前所未有的危机","content":"英国警方周五连续第二天对前英国王子安德鲁·蒙巴顿-温莎的前住所进行搜查。此前一天，安德鲁因爱泼斯坦案被短暂拘捕。此举使英国王室陷入前所未有的危机。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260221-%E5%AE%89%E5%BE%B7%E9%B2%81%E5%86%8D%E9%81%AD%E6%90%9C%E6%9F%A5%EF%BC%8C%E8%8B%B1%E7%8E%8B%E5%AE%A4%E9%99%B7%E5%85%A5%E5%89%8D%E6%89%80%E6%9C%AA%E6%9C%89%E7%9A%84%E5%8D%B1%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771632341000.webp","sourceId":"rfi"},{"id":1771632062000,"createdDate":"2026-02-21 00:01","name":"法国国际广播电台","title":"如何在中国面前拯救国际贸易体系？“志愿者联盟”？","content":"法国国际贸易领域的智库--出口促进组织的主席、国际贸易专家阿兰·邦泰雅克（AlainBentéjac），周五在法国《世界报》发表署名文章，呼吁发起一个“志愿者联盟”，以便在中国这一“超级强权”面前拯救国际贸易体系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260221-%E5%A6%82%E4%BD%95%E5%9C%A8%E4%B8%AD%E5%9B%BD%E9%9D%A2%E5%89%8D%E6%8B%AF%E6%95%91%E5%9B%BD%E9%99%85%E8%B4%B8%E6%98%93%E4%BD%93%E7%B3%BB%EF%BC%8C-%E5%BF%97%E6%84%BF%E8%80%85%E8%81%94%E7%9B%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771632062000.webp","sourceId":"rfi"},{"id":1771663623000,"createdDate":"2026-02-21 08:47","name":"法国国际广播电台","title":"欧洲五国启动边防新计划：利用乌克兰技术研发低成本无人机防御系统","content":"美联社周六（2月21日）消息称，五个欧洲国家宣布启动一项新计划，利用乌克兰在过去四年对俄战争中积累的实战经验，生产低成本防空系统和自主无人机。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260221-%E6%AC%A7%E6%B4%B2%E4%BA%94%E5%9B%BD%E5%90%AF%E5%8A%A8%E8%BE%B9%E9%98%B2%E6%96%B0%E8%AE%A1%E5%88%92-%E5%88%A9%E7%94%A8%E4%B9%8C%E5%85%8B%E5%85%B0%E6%8A%80%E6%9C%AF%E7%A0%94%E5%8F%91%E4%BD%8E%E6%88%90%E6%9C%AC%E6%97%A0%E4%BA%BA%E6%9C%BA%E9%98%B2%E5%BE%A1%E7%B3%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771663623000.webp","sourceId":"rfi"},{"id":1771689412000,"createdDate":"2026-02-21 15:56","name":"法国国际广播电台","title":"法国总统马克龙评美国最高法推翻特朗普总统对等关税：“在民主制度下拥有权力与制衡是件好事情”","content":"美国最高法院对特朗普的对等关税政策作出重大打击后，法国总统马克龙周六强调“民主国家存在权力与制衡”的重要性。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260221-%E6%B3%95%E5%9B%BD%E6%80%BB%E7%BB%9F%E9%A9%AC%E5%85%8B%E9%BE%99%E8%AF%84%E7%BE%8E%E5%9B%BD%E6%9C%80%E9%AB%98%E6%B3%95%E6%8E%A8%E7%BF%BB%E7%89%B9%E6%9C%97%E6%99%AE%E6%80%BB%E7%BB%9F%E5%AF%B9%E7%AD%89%E5%85%B3%E7%A8%8E-%E5%9C%A8%E6%B0%91%E4%B8%BB%E5%88%B6%E5%BA%A6%E4%B8%8B%E6%8B%A5%E6%9C%89%E6%9D%83%E5%8A%9B%E4%B8%8E%E5%88%B6%E8%A1%A1%E6%98%AF%E4%BB%B6%E5%A5%BD%E4%BA%8B%E6%83%85","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771689412000.webp","sourceId":"rfi"},{"id":1771685726000,"createdDate":"2026-02-21 14:55","name":"法国国际广播电台","title":"泽连斯基: 乌克兰绝对没输 刚刚趁星链封锁夺回300平方公里","content":"乌克兰总统沃洛季米尔·泽连斯基周五接受法新社独家采访时表示，在俄罗斯入侵即将四周年之际，乌克兰与俄罗斯的战争结果仍不明朗，但对乌克兰而言并非败局。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260221-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E4%B9%8C%E5%85%8B%E5%85%B0%E7%BB%9D%E5%AF%B9%E6%B2%A1%E8%BE%93-%E5%88%9A%E5%88%9A%E8%B6%81%E6%98%9F%E9%93%BE%E5%B0%81%E9%94%81%E5%A4%BA%E5%9B%9E300%E5%B9%B3%E6%96%B9%E5%85%AC%E9%87%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771685726000.webp","sourceId":"rfi"},{"id":1771679288000,"createdDate":"2026-02-21 13:08","name":"法国国际广播电台","title":"美国最高法院关税裁决：对特朗普的一记耳光","content":"周末出刊的左右两份大报《解放报》和《费加罗报》就国内事务主要围绕两大议题展开，首先是极右翼青年昆汀德朗科之死持续引发一周来政坛对立和社会紧张，周六极右翼团体计划举行多场悼念游行，在悲剧发生地的里昂或有三千人集会，警方担忧极左“反法西斯”团体发起对抗行动，可能导致暴力冲突，已部署大规模警力防止局势失控。报道也关注法国极右政党国民联盟主席巴尔德拉对昆廷遇害事件所采取的谨慎政治立场。面对多地悼念活动可能的极右翼与极左对抗风险，他明确要求其党内成员及议员不要参与相关集会，以避免与其它“极右小团体”产生关联。与此同时，他继续攻击左翼阵营应为昆汀之死负责。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260221-%E7%BE%8E%E5%9B%BD%E6%9C%80%E9%AB%98%E6%B3%95%E9%99%A2%E5%85%B3%E7%A8%8E%E8%A3%81%E5%86%B3-%E5%AF%B9%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84%E4%B8%80%E8%AE%B0%E8%80%B3%E5%85%89","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771679288000.webp","sourceId":"rfi"},{"id":1771677257000,"createdDate":"2026-02-21 12:34","name":"法国国际广播电台","title":"美国因中国电缆计划吊销智利三名官员及亲属签证","content":"美国周五宣布对三名智利政府官员实施签证限制，其中包括交通和电信部长。法新社说，此举是在华盛顿与即将离任的总统加布里埃尔·博里奇政府关系紧张的背景下做出的。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260221-%E7%BE%8E%E5%9B%BD%E5%9B%A0%E4%B8%AD%E5%9B%BD%E7%94%B5%E7%BC%86%E8%AE%A1%E5%88%92%E5%90%8A%E9%94%80%E6%99%BA%E5%88%A9%E4%B8%89%E5%90%8D%E5%AE%98%E5%91%98%E5%8F%8A%E4%BA%B2%E5%B1%9E%E7%AD%BE%E8%AF%81","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771677257000.webp","sourceId":"rfi"},{"id":1771673027000,"createdDate":"2026-02-21 11:23","name":"法国国际广播电台","title":"人工智能 ：美国反数据库抗议为何日益频繁？","content":"刚刚落幕的印度人工智能峰会再度将相关的讨论推向前台，人工智能，特别是生成式人工智能被认为是二十一世纪一场具有重大颠覆性的技术革命，评论普遍认为它将会重塑产业，提高生产力，推动全球经济的划时代的转型。不过，与此同时，人工智能的开发也带来了前所未有的风险与挑战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E5%A2%83%E4%B8%8E%E5%8F%91%E5%B1%95/20260221-%E4%BB%BB%E9%82%B5%E7%A3%8A-%E7%BE%8E%E5%9B%BD%E5%BB%BA%E6%95%B0%E6%8D%AE%E4%B8%AD%E5%BF%83%E9%9D%A2%E4%B8%B4%E4%B8%89%E5%A4%A7%E6%8C%91%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771673027000.webp","sourceId":"rfi"},{"id":1771671963000,"createdDate":"2026-02-21 11:06","name":"法国国际广播电台","title":"日本文科大臣反驳中国驻日使馆连续批判日本教科书","content":"中国驻日本大使馆近日在社交媒体上连续发文称，日本历史教科书的相关表述存在美化二战中的日本等问题。对此，日本文部科学大臣松本洋平在20日内阁会议后的记者会上反驳称：“我国的教科书审定，是根据当时客观的学术成果及适当资料来实施的。”","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260221-%E6%97%A5%E6%9C%AC%E6%96%87%E7%A7%91%E5%A4%A7%E8%87%A3%E5%8F%8D%E9%A9%B3%E4%B8%AD%E5%9B%BD%E9%A9%BB%E6%97%A5%E4%BD%BF%E9%A6%86%E8%BF%9E%E7%BB%AD%E6%89%B9%E5%88%A4%E6%97%A5%E6%9C%AC%E6%95%99%E7%A7%91%E4%B9%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771671963000.webp","sourceId":"rfi"},{"id":1771671009000,"createdDate":"2026-02-21 10:50","name":"法国国际广播电台","title":"深受法国民众喜爱的国际农业博览会开幕：今年的现场没有牛，并且马克龙不受欢迎","content":"周六（2月21日）上午，法国一年一度著名的巴黎国际农业博览会开幕，它是法国规模最大的农业盛会，也是欧洲同类展会中规模最大的盛会。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260221-%E6%B7%B1%E5%8F%97%E6%B3%95%E5%9B%BD%E6%B0%91%E4%BC%97%E5%96%9C%E7%88%B1%E7%9A%84%E5%9B%BD%E9%99%85%E5%86%9C%E4%B8%9A%E5%8D%9A%E8%A7%88%E4%BC%9A%E5%BC%80%E5%B9%95-%E4%BB%8A%E5%B9%B4%E6%B2%A1%E6%9C%89%E7%89%9B%EF%BC%8C%E5%B9%B6%E4%B8%94%E9%A9%AC%E5%85%8B%E9%BE%99%E4%B8%8D%E5%8F%97%E6%AC%A2%E8%BF%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771671009000.webp","sourceId":"rfi"},{"id":1771665776000,"createdDate":"2026-02-21 09:22","name":"法国国际广播电台","title":"委内瑞拉通过大赦法案后宣布释放数百名政治犯","content":"委内瑞拉在总统马杜罗被美国抓捕近两个月后，根据议会刚刚通过的一项有限特赦政治犯法案，司法机关周五（2月20日）晚间批准释放数百名政治犯。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260221-%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E9%80%9A%E8%BF%87%E5%A4%A7%E8%B5%A6%E6%B3%95%E6%A1%88%E5%90%8E%E5%AE%A3%E5%B8%83%E9%87%8A%E6%94%BE%E6%95%B0%E7%99%BE%E5%90%8D%E6%94%BF%E6%B2%BB%E7%8A%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771665776000.webp","sourceId":"rfi"}]