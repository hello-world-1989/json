[{"id":1771632341000,"createdDate":"2026-02-21 00:05","name":"法国国际广播电台","title":"安德鲁再遭搜查，英王室陷入前所未有的危机","content":"英国警方周五连续第二天对前英国王子安德鲁·蒙巴顿-温莎的前住所进行搜查。此前一天，安德鲁因爱泼斯坦案被短暂拘捕。此举使英国王室陷入前所未有的危机。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260221-%E5%AE%89%E5%BE%B7%E9%B2%81%E5%86%8D%E9%81%AD%E6%90%9C%E6%9F%A5%EF%BC%8C%E8%8B%B1%E7%8E%8B%E5%AE%A4%E9%99%B7%E5%85%A5%E5%89%8D%E6%89%80%E6%9C%AA%E6%9C%89%E7%9A%84%E5%8D%B1%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771632341000.webp","sourceId":"rfi"},{"id":1771632062000,"createdDate":"2026-02-21 00:01","name":"法国国际广播电台","title":"如何在中国面前拯救国际贸易体系？“志愿者联盟”？","content":"法国国际贸易领域的智库--出口促进组织的主席、国际贸易专家阿兰·邦泰雅克（AlainBentéjac），周五在法国《世界报》发表署名文章，呼吁发起一个“志愿者联盟”，以便在中国这一“超级强权”面前拯救国际贸易体系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260221-%E5%A6%82%E4%BD%95%E5%9C%A8%E4%B8%AD%E5%9B%BD%E9%9D%A2%E5%89%8D%E6%8B%AF%E6%95%91%E5%9B%BD%E9%99%85%E8%B4%B8%E6%98%93%E4%BD%93%E7%B3%BB%EF%BC%8C-%E5%BF%97%E6%84%BF%E8%80%85%E8%81%94%E7%9B%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771632062000.webp","sourceId":"rfi"},{"id":1771663623000,"createdDate":"2026-02-21 08:47","name":"法国国际广播电台","title":"欧洲五国启动边防新计划：利用乌克兰技术研发低成本无人机防御系统","content":"美联社周六（2月21日）消息称，五个欧洲国家宣布启动一项新计划，利用乌克兰在过去四年对俄战争中积累的实战经验，生产低成本防空系统和自主无人机。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260221-%E6%AC%A7%E6%B4%B2%E4%BA%94%E5%9B%BD%E5%90%AF%E5%8A%A8%E8%BE%B9%E9%98%B2%E6%96%B0%E8%AE%A1%E5%88%92-%E5%88%A9%E7%94%A8%E4%B9%8C%E5%85%8B%E5%85%B0%E6%8A%80%E6%9C%AF%E7%A0%94%E5%8F%91%E4%BD%8E%E6%88%90%E6%9C%AC%E6%97%A0%E4%BA%BA%E6%9C%BA%E9%98%B2%E5%BE%A1%E7%B3%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/02/21/1771663623000.webp","sourceId":"rfi"}]