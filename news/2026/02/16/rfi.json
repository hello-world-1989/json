[{"id":1771231152000,"createdDate":"2026-02-16 08:39","name":"法国国际广播电台","title":"内塔尼亚胡：伊朗须彻底拆除核设施，若达不成协议支持空袭伊朗弹道导弹设施","content":"据路透社报道，以色列总理内塔亚胡称，他上周与美国总统特朗普会晤时说，任何美伊协议必须包括伊朗彻底拆除核设施，不仅是停止浓缩铀过程。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260216-%E5%86%85%E5%A1%94%E5%B0%BC%E4%BA%9A%E8%83%A1-%E4%BC%8A%E6%9C%97%E9%A1%BB%E5%BD%BB%E5%BA%95%E6%8B%86%E9%99%A4%E6%A0%B8%E8%AE%BE%E6%96%BD%EF%BC%8C%E8%8B%A5%E8%BE%BE%E4%B8%8D%E6%88%90%E5%8D%8F%E8%AE%AE%E6%94%AF%E6%8C%81%E7%A9%BA%E8%A2%AD%E4%BC%8A%E6%9C%97%E5%BC%B9%E9%81%93%E5%AF%BC%E5%BC%B9%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771231152000.webp","sourceId":"rfi"},{"id":1771229794000,"createdDate":"2026-02-16 08:16","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第24：浪漫主义群星之二 诺瓦利斯第三节：为诗与诗人辩护","content":"诺瓦利斯在吸收同时批判费希特的哲学后，提出自己的诗学理论。同时，通过创作实践，具体化了他的诗学理想。在他未及完成的诗化小说《奥夫特尔丁根》中，他描绘了一系列神奇人物，让他们各自发言，讲述自己的体悟和感受。在这些人物的现世经验与梦之幻想中，诺瓦利斯构建起诗的王国，在这个王国中，诗人主宰着世界。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260216-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%BA%8C-%E8%AF%BA%E7%93%A6%E5%88%A9%E6%96%AF%E7%AC%AC%E4%B8%89%E8%8A%82-%E4%B8%BA%E8%AF%97%E4%B8%8E%E8%AF%97%E4%BA%BA%E8%BE%A9%E6%8A%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771229794000.webp","sourceId":"rfi"},{"id":1771229410000,"createdDate":"2026-02-16 08:10","name":"法国国际广播电台","title":"核问题：伊朗外交部长抵达日内瓦，准备与华盛顿进行谈判","content":"法新社日内瓦消息，伊朗外交部长阿巴斯·阿拉格希（AbbasAraghchi）周一抵达日内瓦，伊朗国家电视台表示，新一轮伊朗核问题谈判将在这里展开。此次谈判是伊朗与美国之间的新一轮“间接”对话，预计于周二开始。此前，伊朗与美国于2月初在阿曼恢复了对话，当时美国威胁可能对伊朗采取军事行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260216-%E6%A0%B8%E9%97%AE%E9%A2%98-%E4%BC%8A%E6%9C%97%E5%A4%96%E4%BA%A4%E9%83%A8%E9%95%BF%E6%8A%B5%E8%BE%BE%E6%97%A5%E5%86%85%E7%93%A6%EF%BC%8C%E5%87%86%E5%A4%87%E4%B8%8E%E5%8D%8E%E7%9B%9B%E9%A1%BF%E8%BF%9B%E8%A1%8C%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771229410000.webp","sourceId":"rfi"},{"id":1771229388000,"createdDate":"2026-02-16 08:09","name":"法国国际广播电台","title":"香港受压 独立书店赴台参展「被看见」 移台港人办出版社保出版自由","content":"被视为世界第四大之国际级图书专业展览会於台北落幕，有58万人次入场，与疫情前丶2019年的参观人次看齐，讲者人数更突破新高，当中包括来自香港独立书店的。有香港经营者表明，当独立书店在香港被打压之际，赴台参展可让他们被看见，亦可让香港的时代纪录找到出路。事实上，销售额并非他们的追求，办讲座才是。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260216-%E9%A6%99%E6%B8%AF%E5%8F%97%E5%8E%8B-%E7%8B%AC%E7%AB%8B%E4%B9%A6%E5%BA%97%E8%B5%B4%E5%8F%B0%E5%8F%82%E5%B1%95-%E8%A2%AB%E7%9C%8B%E8%A7%81-%E7%A7%BB%E5%8F%B0%E6%B8%AF%E4%BA%BA%E5%8A%9E%E5%87%BA%E7%89%88%E7%A4%BE%E4%BF%9D%E5%87%BA%E7%89%88%E8%87%AA%E7%94%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771229388000.webp","sourceId":"rfi"}]