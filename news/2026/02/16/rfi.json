[{"id":1771231152000,"createdDate":"2026-02-16 08:39","name":"法国国际广播电台","title":"内塔尼亚胡：伊朗须彻底拆除核设施，若达不成协议支持空袭伊朗弹道导弹设施","content":"据路透社报道，以色列总理内塔亚胡称，他上周与美国总统特朗普会晤时说，任何美伊协议必须包括伊朗彻底拆除核设施，不仅是停止浓缩铀过程。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260216-%E5%86%85%E5%A1%94%E5%B0%BC%E4%BA%9A%E8%83%A1-%E4%BC%8A%E6%9C%97%E9%A1%BB%E5%BD%BB%E5%BA%95%E6%8B%86%E9%99%A4%E6%A0%B8%E8%AE%BE%E6%96%BD%EF%BC%8C%E8%8B%A5%E8%BE%BE%E4%B8%8D%E6%88%90%E5%8D%8F%E8%AE%AE%E6%94%AF%E6%8C%81%E7%A9%BA%E8%A2%AD%E4%BC%8A%E6%9C%97%E5%BC%B9%E9%81%93%E5%AF%BC%E5%BC%B9%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771231152000.webp","sourceId":"rfi"},{"id":1771229794000,"createdDate":"2026-02-16 08:16","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第24：浪漫主义群星之二 诺瓦利斯第三节：为诗与诗人辩护","content":"诺瓦利斯在吸收同时批判费希特的哲学后，提出自己的诗学理论。同时，通过创作实践，具体化了他的诗学理想。在他未及完成的诗化小说《奥夫特尔丁根》中，他描绘了一系列神奇人物，让他们各自发言，讲述自己的体悟和感受。在这些人物的现世经验与梦之幻想中，诺瓦利斯构建起诗的王国，在这个王国中，诗人主宰着世界。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260216-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%BA%8C-%E8%AF%BA%E7%93%A6%E5%88%A9%E6%96%AF%E7%AC%AC%E4%B8%89%E8%8A%82-%E4%B8%BA%E8%AF%97%E4%B8%8E%E8%AF%97%E4%BA%BA%E8%BE%A9%E6%8A%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771229794000.webp","sourceId":"rfi"},{"id":1771229410000,"createdDate":"2026-02-16 08:10","name":"法国国际广播电台","title":"核问题：伊朗外交部长抵达日内瓦，准备与华盛顿进行谈判","content":"法新社日内瓦消息，伊朗外交部长阿巴斯·阿拉格希（AbbasAraghchi）周一抵达日内瓦，伊朗国家电视台表示，新一轮伊朗核问题谈判将在这里展开。此次谈判是伊朗与美国之间的新一轮“间接”对话，预计于周二开始。此前，伊朗与美国于2月初在阿曼恢复了对话，当时美国威胁可能对伊朗采取军事行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260216-%E6%A0%B8%E9%97%AE%E9%A2%98-%E4%BC%8A%E6%9C%97%E5%A4%96%E4%BA%A4%E9%83%A8%E9%95%BF%E6%8A%B5%E8%BE%BE%E6%97%A5%E5%86%85%E7%93%A6%EF%BC%8C%E5%87%86%E5%A4%87%E4%B8%8E%E5%8D%8E%E7%9B%9B%E9%A1%BF%E8%BF%9B%E8%A1%8C%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771229410000.webp","sourceId":"rfi"},{"id":1771229388000,"createdDate":"2026-02-16 08:09","name":"法国国际广播电台","title":"香港受压 独立书店赴台参展「被看见」 移台港人办出版社保出版自由","content":"被视为世界第四大之国际级图书专业展览会於台北落幕，有58万人次入场，与疫情前丶2019年的参观人次看齐，讲者人数更突破新高，当中包括来自香港独立书店的。有香港经营者表明，当独立书店在香港被打压之际，赴台参展可让他们被看见，亦可让香港的时代纪录找到出路。事实上，销售额并非他们的追求，办讲座才是。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260216-%E9%A6%99%E6%B8%AF%E5%8F%97%E5%8E%8B-%E7%8B%AC%E7%AB%8B%E4%B9%A6%E5%BA%97%E8%B5%B4%E5%8F%B0%E5%8F%82%E5%B1%95-%E8%A2%AB%E7%9C%8B%E8%A7%81-%E7%A7%BB%E5%8F%B0%E6%B8%AF%E4%BA%BA%E5%8A%9E%E5%87%BA%E7%89%88%E7%A4%BE%E4%BF%9D%E5%87%BA%E7%89%88%E8%87%AA%E7%94%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771229388000.webp","sourceId":"rfi"},{"id":1771257076000,"createdDate":"2026-02-16 15:51","name":"法国国际广播电台","title":"乌克兰前能源部长涉国家核电一亿美元贪腐案，潜逃时被抓","content":"乌克兰反腐机构2月16日指控该国前能源部长加卢什琴科在腐败案中洗钱数百万美元回扣。该案件涉及乌克兰国家核能公司一项涉嫌一亿美元回扣的计划，震动了乌克兰政府，也引发乌克兰西方盟友的担忧。此前一天，加卢什琴科在试图离境时被抓。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260216-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%89%8D%E8%83%BD%E6%BA%90%E9%83%A8%E9%95%BF%E6%B6%89%E5%9B%BD%E5%AE%B6%E6%A0%B8%E7%94%B5%E4%B8%80%E4%BA%BF%E7%BE%8E%E5%85%83%E8%B4%AA%E8%85%90%E6%A1%88%EF%BC%8C%E6%BD%9C%E9%80%83%E6%97%B6%E8%A2%AB%E6%8A%93","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771257076000.webp","sourceId":"rfi"},{"id":1771256577000,"createdDate":"2026-02-16 15:42","name":"法国国际广播电台","title":"路透社：中国春运—全球规模最大的年度人口迁徙—马年特点","content":"路透社中国农历除夕专稿称，表示每年春节期间，数以亿计的人潮穿梭于中国各地，或返乡与家人团聚，或在延长的假期中外出旅游。这使得“春运”成为了全球规模最大的年度人口迁徙。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260216-%E8%B7%AF%E9%80%8F%E7%A4%BE-%E4%B8%AD%E5%9B%BD%E6%98%A5%E8%BF%90-%E5%85%A8%E7%90%83%E8%A7%84%E6%A8%A1%E6%9C%80%E5%A4%A7%E7%9A%84%E5%B9%B4%E5%BA%A6%E4%BA%BA%E5%8F%A3%E8%BF%81%E5%BE%99-%E9%A9%AC%E5%B9%B4%E7%89%B9%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771256577000.webp","sourceId":"rfi"},{"id":1771255573000,"createdDate":"2026-02-16 15:26","name":"法国国际广播电台","title":"迫于美国中国压力 法国葡萄酒烈酒转向非洲和印度市场","content":"在来自美国和中国的压力下，法国葡萄酒和烈酒出口在三年内暴跌了17%，不过法国的葡萄酒生产商并没有过于恐慌，而是转向非洲或印度市场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260216-%E8%BF%AB%E4%BA%8E%E7%BE%8E%E5%9B%BD%E4%B8%AD%E5%9B%BD%E5%8E%8B%E5%8A%9B-%E6%B3%95%E5%9B%BD%E8%91%A1%E8%90%84%E9%85%92%E7%83%88%E9%85%92%E8%BD%AC%E5%90%91%E9%9D%9E%E6%B4%B2%E5%92%8C%E5%8D%B0%E5%BA%A6%E5%B8%82%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771255573000.webp","sourceId":"rfi"},{"id":1771255052000,"createdDate":"2026-02-16 15:17","name":"法国国际广播电台","title":"欧盟：将出席特朗普“和平理事会”会议，但不会成其成员","content":"法新社布鲁塞尔消息，欧盟周一（2月16日）宣布，欧盟委员会的一名委员将出席美国总统特朗普“和平理事会”在华盛顿召开的首次会议，但欧盟不会加入该机构。此前，法国、意大利、挪威已明确拒绝出席。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260216-%E6%AC%A7%E7%9B%9F-%E5%B0%86%E5%87%BA%E5%B8%AD%E7%89%B9%E6%9C%97%E6%99%AE-%E5%92%8C%E5%B9%B3%E7%90%86%E4%BA%8B%E4%BC%9A-%E4%BC%9A%E8%AE%AE%EF%BC%8C%E4%BD%86%E4%B8%8D%E4%BC%9A%E6%88%90%E5%85%B6%E6%88%90%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771255052000.webp","sourceId":"rfi"},{"id":1771252226000,"createdDate":"2026-02-16 14:30","name":"法国国际广播电台","title":"赛场纪念遇难同胞，乌克兰运动员被取消奥运资格","content":"在2026年米兰科尔蒂纳冬奥会期间，乌克兰钢架雪车运动员、国家旗手弗拉迪斯拉夫·赫拉斯凯维奇因佩戴纪念在战争中遇难同胞的头盔，被国际奥委会取消参赛资格。围绕这一决定所引发的争议仍在持续发酵。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260216-%E8%B5%9B%E5%9C%BA%E7%BA%AA%E5%BF%B5%E9%81%87%E9%9A%BE%E5%90%8C%E8%83%9E%EF%BC%8C%E4%B9%8C%E5%85%8B%E5%85%B0%E8%BF%90%E5%8A%A8%E5%91%98%E8%A2%AB%E5%8F%96%E6%B6%88%E5%A5%A5%E8%BF%90%E8%B5%84%E6%A0%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771252226000.webp","sourceId":"rfi"},{"id":1771252198000,"createdDate":"2026-02-16 14:29","name":"法国国际广播电台","title":"非洲联盟第39届峰会加纳发言","content":"在埃塞俄比亚首都、非洲联盟（UnionAfricaine）总部所在地举行的为期两天的第39届非盟峰会已于2026年2月15日（星期日）按原定日程落下帷幕。加纳总统约翰·德拉马尼·马哈马（présidentghanéenJohnDramaniMahama）在闭幕式上的发言成为本届峰会的看点之一。阿克拉（Accra）政府宣布，希望联合国承认非洲奴隶贸易为[最严重的反人类罪行]（leplusgravecrimecontrel'humanité）。本台法广（RFI）法语特派记者(envoyéspécial)从现场发回了部分录音片段。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260216-%E6%B3%95%E5%B9%BF-rfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E9%9D%9E%E6%B4%B2%E8%81%94%E7%9B%9F%E7%AC%AC39%E5%B1%8A%E5%B3%B0%E4%BC%9A%E5%8A%A0%E7%BA%B3%E5%A3%B0%E6%98%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771252198000.webp","sourceId":"rfi"},{"id":1771251638000,"createdDate":"2026-02-16 14:20","name":"法国国际广播电台","title":"德国外长评法国国防开支的努力“不足”，吁“节省”社保开支","content":"据法新社报道，德国外长约翰·瓦德富尔（JohannWadephul）呼吁法国“节省开支”，特别是“在社会领域”，以“腾出必要的财政空间，实现欧洲防务核心能力的目标”。这一目标是到2035年将国内生产总值（GDP）的5%用于安全支出，这一目标由美国总统特朗普在北约内部推动。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260216-%E5%BE%B7%E5%9B%BD%E5%A4%96%E9%95%BF%E8%AF%84%E6%B3%95%E5%9B%BD%E5%9B%BD%E9%98%B2%E5%BC%80%E6%94%AF%E7%9A%84%E5%8A%AA%E5%8A%9B-%E4%B8%8D%E8%B6%B3-%EF%BC%8C%E5%90%81-%E8%8A%82%E7%9C%81-%E7%A4%BE%E4%BF%9D%E5%BC%80%E6%94%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771251638000.webp","sourceId":"rfi"},{"id":1771246756000,"createdDate":"2026-02-16 12:59","name":"法国国际广播电台","title":"台湾自行车的“传教士”、捷安特创始人刘金标逝世，享年91岁","content":"法新社台北消息，台湾自行车巨头捷安特（Giant）创始人、自喻为自行车文化“传教士”的刘金标（KingLiu）于本周一2月16日逝世，享年91岁。捷安特公司已正式发布讣告。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260216-%E5%8F%B0%E6%B9%BE%E8%87%AA%E8%A1%8C%E8%BD%A6%E7%9A%84-%E4%BC%A0%E6%95%99%E5%A3%AB-%E6%8D%B7%E5%AE%89%E7%89%B9%E5%88%9B%E5%A7%8B%E4%BA%BA%E5%88%98%E9%87%91%E6%A0%87%E9%80%9D%E4%B8%96%EF%BC%8C%E4%BA%AB%E5%B9%B491%E5%B2%81","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771246756000.webp","sourceId":"rfi"},{"id":1771246013000,"createdDate":"2026-02-16 12:46","name":"法国国际广播电台","title":"自民党大选大胜为改善日中关系提供新契机","content":"2月8日，日本第51届众议院选举举行投开票。计票结果显示，自民党大幅超过公示前的198个议席，获得316席，不仅单独超过能够自行主导国会运作的“绝对稳定多数”——261席，而且取得了超过2/3席位的历史性胜利，由自民党与日本维新会组成的执政阵营合计议席数达352席，在众议院465个议席中占据压倒性优势。高市早苗首相领导的执政党在大选中大胜，也为日中关系的改善提供了新的契机。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260216-%E8%87%AA%E6%B0%91%E5%85%9A%E5%A4%A7%E9%80%89%E5%A4%A7%E8%83%9C%E4%B8%BA%E6%94%B9%E5%96%84%E6%97%A5%E4%B8%AD%E5%85%B3%E7%B3%BB%E6%8F%90%E4%BE%9B%E6%96%B0%E5%A5%91%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771246013000.webp","sourceId":"rfi"},{"id":1771245608000,"createdDate":"2026-02-16 12:40","name":"法国国际广播电台","title":"纳瓦尔尼去世两周年其母要求为“被毒杀”的儿子伸张正义，克宫驳斥法德等欧洲五国指控","content":"据本台法语部报道，2024年2月16日，阿列克谢·纳瓦尔尼在俄罗斯北部服刑的监狱中被发现死亡，当时他正在服刑19年极端主义罪。他的死因至今仍然存在疑点。这位富有魅力的反腐败活动人士、俄罗斯反对派领袖，在2021年1月刚回到俄罗斯便被逮捕。两年后的今天，他的母亲为“被毒杀”的儿子要求“伸张正义”。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260216-%E7%BA%B3%E7%93%A6%E5%B0%94%E5%B0%BC%E5%8E%BB%E4%B8%96%E4%B8%A4%E5%91%A8%E5%B9%B4%E5%85%B6%E6%AF%8D%E8%A6%81%E6%B1%82%E4%B8%BA-%E8%A2%AB%E6%AF%92%E6%9D%80-%E7%9A%84%E5%84%BF%E5%AD%90%E4%BC%B8%E5%BC%A0%E6%AD%A3%E4%B9%89%EF%BC%8C%E5%85%8B%E5%AE%AB%E9%A9%B3%E6%96%A5%E6%B3%95%E5%BE%B7%E7%AD%89%E6%AC%A7%E6%B4%B2%E4%BA%94%E5%9B%BD%E6%8C%87%E6%8E%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771245608000.webp","sourceId":"rfi"},{"id":1771243764000,"createdDate":"2026-02-16 12:09","name":"法国国际广播电台","title":"欧美关系“缓和”背后：合作可以，但美国主导？","content":"各位好，本期法国世界报头版重点如下：法国年轻的极右翼运动成员昆丁死于和极左翼的一场对峙，引发法国政坛强烈反应，极左翼面对谴责浪潮、法国西南部紧急应对历史性洪灾、法国国民议会再次就安乐死草案进行讨论、法国打响2026年市政选举等；头版关注的国际话题包括加沙现状、欧美的跨大西洋关系等。本期法国世界报没有与中国相关的话题。因此在本期节目中，我们为您选取法国的国际相关话题做综述。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260216-%E6%AC%A7%E7%BE%8E%E5%85%B3%E7%B3%BB-%E7%BC%93%E5%92%8C-%E8%83%8C%E5%90%8E-%E5%90%88%E4%BD%9C%E5%8F%AF%E4%BB%A5%EF%BC%8C%E4%BD%86%E7%BE%8E%E5%9B%BD%E4%B8%BB%E5%AF%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771243764000.webp","sourceId":"rfi"},{"id":1771242868000,"createdDate":"2026-02-16 11:54","name":"法国国际广播电台","title":"全球人工智能峰会在印度开幕，担忧声不断","content":"法新社新德里消息，全球人工智能峰会周一（2月16日）在新德里开幕，与会者将探讨即将到来的人工智能革命对就业、儿童保护等领域的影响，但参会者对峰会能否产生具体措施表示怀疑。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260216-%E5%85%A8%E7%90%83%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E5%B3%B0%E4%BC%9A%E5%9C%A8%E5%8D%B0%E5%BA%A6%E5%BC%80%E5%B9%95%EF%BC%8C%E6%8B%85%E5%BF%A7%E5%A3%B0%E4%B8%8D%E6%96%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771242868000.webp","sourceId":"rfi"},{"id":1771242352000,"createdDate":"2026-02-16 11:45","name":"法国国际广播电台","title":"昆坦之死：在谴责与呼吁冷静之声中、法国政坛反应激烈","content":"上周四（2月12日），极左派“不屈法国党”（LFI）的欧洲议员丽玛·哈桑在里昂进行演讲活动时，23岁的极右翼支持者、法国大学生昆坦（Quentin）遭遇极左翼支持者的围攻，最终因伤势过重周六不治身亡。这起悲剧不仅震动法国社会，更让法国政坛陷入一场前所未有的舆论风暴，政坛各方人士纷纷表态，指责与反击相互交织，展现出法国政治生态中日益加剧的分裂与紧张。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E7%94%9F%E6%B4%BB/20260216-%E6%98%86%E5%9D%A6%E4%B9%8B%E6%AD%BB-%E5%9C%A8%E8%B0%B4%E8%B4%A3%E4%B8%8E%E5%91%BC%E5%90%81%E5%86%B7%E9%9D%99%E4%B9%8B%E5%A3%B0%E4%B8%AD-%E6%B3%95%E5%9B%BD%E6%94%BF%E5%9D%9B%E6%BF%80%E7%83%88%E5%8F%8D%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771242352000.webp","sourceId":"rfi"},{"id":1771241292000,"createdDate":"2026-02-16 11:28","name":"法国国际广播电台","title":"45亿烧春节 中国AI科技巨头掀“红包大战”争夺用户","content":"周一出版的法国主要报纸，国内议题聚焦于周末里昂发生的政治暴力事件导致悲剧，一名23岁的极右翼活动青年昆廷在一场围绕法国极左“不屈法兰西党”议员里玛·哈桑讲座的对峙后遭群殴重伤身亡。费加罗报、解放报等多份报纸纷纷以此开篇。报道指，事发地长期存在极右翼与极左活动团体的冲突。警方已展开立案调查，事件引发法国政坛震荡，左右翼相互指责，总统马克龙谴责暴力、要求对肇事者绳之以法的同时，也呼吁冷静和克制，而司法部长达尔马宁本周日已指责昆廷明显被“极左派杀害”。目前法国市政选举在即，在发生该事件后，里昂主要的候选人都暂停了周日的竞选活动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260216-45%E4%BA%BF%E7%83%A7%E6%98%A5%E8%8A%82-%E4%B8%AD%E5%9B%BDai%E7%A7%91%E6%8A%80%E5%B7%A8%E5%A4%B4%E6%8E%80-%E7%BA%A2%E5%8C%85%E5%A4%A7%E6%88%98-%E4%BA%89%E5%A4%BA%E7%94%A8%E6%88%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771241292000.webp","sourceId":"rfi"},{"id":1771241289000,"createdDate":"2026-02-16 11:28","name":"法国国际广播电台","title":"赖清德打破惯例！在高海拔、室外发表春节讲话意义有三","content":"与往年不同，台湾总统赖清德没有在台北总统府或台北宾馆录制春年讲话，而是在小年夜移师海拔3,020米、全台第一高的海军「小雪山雷达站」，顶著6度的低温在室外向全民发表春节讲话，并慰问部队官兵。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260216-%E8%B5%96%E6%B8%85%E5%BE%B7%E6%89%93%E7%A0%B4%E6%83%AF%E4%BE%8B-%E5%9C%A8%E9%AB%98%E6%B5%B7%E6%8B%94-%E5%AE%A4%E5%A4%96%E5%8F%91%E8%A1%A8%E6%98%A5%E8%8A%82%E8%AE%B2%E8%AF%9D%E6%84%8F%E4%B9%89%E6%9C%89%E4%B8%89","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771241289000.webp","sourceId":"rfi"},{"id":1771235726000,"createdDate":"2026-02-16 09:55","name":"法国国际广播电台","title":"回应37名美国议员关切军购 韩国瑜：开议后最优先审核国防特别预算","content":"美国37名跨党派议员致函台湾立院关切国防特别预算，据台媒三立新闻网报道，台湾立法院长韩国瑜、副院长江启臣除夕（2月16日）上午紧急发布声明回应，立法院开议后，国防特别预算相关议案将会是最优先审议的议案。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260216-%E5%9B%9E%E5%BA%9437%E5%90%8D%E7%BE%8E%E5%9B%BD%E8%AE%AE%E5%91%98%E5%85%B3%E5%88%87%E5%86%9B%E8%B4%AD-%E9%9F%A9%E5%9B%BD%E7%91%9C-%E5%BC%80%E8%AE%AE%E5%90%8E%E6%9C%80%E4%BC%98%E5%85%88%E5%AE%A1%E6%A0%B8%E5%9B%BD%E9%98%B2%E7%89%B9%E5%88%AB%E9%A2%84%E7%AE%97","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771235726000.webp","sourceId":"rfi"},{"id":1771235588000,"createdDate":"2026-02-16 09:53","name":"法国国际广播电台","title":"日本首相高市早苗除夕发表春节贺辞","content":"日本首相高市早苗星期一（2月16日）以日文、简体中文、繁体中文和英文发表春节贺词，希望新的一年世界和平，并称日本将致力于为国际社会的和平与繁荣发挥更大作用。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260216-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E9%99%A4%E5%A4%95%E5%8F%91%E8%A1%A8%E6%98%A5%E8%8A%82%E8%B4%BA%E8%BE%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771235588000.webp","sourceId":"rfi"},{"id":1771233791000,"createdDate":"2026-02-16 09:23","name":"法国国际广播电台","title":"王毅批日相高市涉台言论后  日本外务省发文反驳且提出交涉","content":"中国外交部长王毅上周出席慕尼黑安全会议时，强烈抨击日本首相高市早苗“台湾有事”的国会答询是“复活军国主义的阴魂不散”。日本外务省就此发文反驳，并表示透过外交管道严正交涉。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260216-%E7%8E%8B%E6%AF%85%E6%89%B9%E6%97%A5%E7%9B%B8%E9%AB%98%E5%B8%82%E6%B6%89%E5%8F%B0%E8%A8%80%E8%AE%BA-%E6%97%A5%E6%9C%AC%E5%A4%96%E5%8A%A1%E7%9C%81%E5%8F%91%E6%96%87%E5%8F%8D%E9%A9%B3%E4%B8%94%E6%8F%90%E5%87%BA%E4%BA%A4%E6%B6%89","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771233791000.webp","sourceId":"rfi"},{"id":1771233153000,"createdDate":"2026-02-16 09:12","name":"法国国际广播电台","title":"习近平2026春节讲话紧扣“稳中求进”，提到“设立台湾光复纪念日”","content":"中国国家主席习近平上周六（2月14日）在春节团拜会上说，2026年要坚持稳中求进，着力推动高质量发展，保持社会和谐稳定，推进全面从严治党，努力实现“十五五”良好开局。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260216-%E4%B9%A0%E8%BF%91%E5%B9%B32026%E6%98%A5%E8%8A%82%E8%AE%B2%E8%AF%9D%E7%B4%A7%E6%89%A3-%E7%A8%B3%E4%B8%AD%E6%B1%82%E8%BF%9B-%EF%BC%8C%E6%8F%90%E5%88%B0-%E8%AE%BE%E7%AB%8B%E5%8F%B0%E6%B9%BE%E5%85%89%E5%A4%8D%E7%BA%AA%E5%BF%B5%E6%97%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/02/16/1771233153000.webp","sourceId":"rfi"}]