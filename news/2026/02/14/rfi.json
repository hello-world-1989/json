[{"id":1771027360000,"createdDate":"2026-02-14 00:02","name":"法国国际广播电台","title":"欧盟谴责中国对欧盟乳制品加征关税","content":"欧盟周五谴责中国对部分欧洲乳制品加征新的关税，虽然北京已经大幅下调了相关税率。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260214-%E6%AC%A7%E7%9B%9F%E8%B0%B4%E8%B4%A3%E4%B8%AD%E5%9B%BD%E5%AF%B9%E6%AC%A7%E7%9B%9F%E4%B9%B3%E5%88%B6%E5%93%81%E5%8A%A0%E5%BE%81%E5%85%B3%E7%A8%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771027360000.webp","sourceId":"rfi"},{"id":1771086008000,"createdDate":"2026-02-14 16:20","name":"法国国际广播电台","title":"卢比奥：美国和西方与中国的关系存在根本性挑战 我们有责任妥善管理","content":"2月14日在慕尼黑，美国国务卿卢比奥表示，我们两国之间，以及西方与中国之间，确实存在一些“根本性的挑战”，出于多种原因，这些挑战在可预见的未来仍将持续存在。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260214-%E5%8D%A2%E6%AF%94%E5%A5%A5-%E7%BE%8E%E5%9B%BD%E5%92%8C%E8%A5%BF%E6%96%B9%E4%B8%8E%E4%B8%AD%E5%9B%BD%E7%9A%84%E5%85%B3%E7%B3%BB%E5%AD%98%E5%9C%A8%E6%A0%B9%E6%9C%AC%E6%80%A7%E6%8C%91%E6%88%98-%E6%88%91%E4%BB%AC%E6%9C%89%E8%B4%A3%E4%BB%BB%E5%A6%A5%E5%96%84%E7%AE%A1%E7%90%86","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771086008000.webp","sourceId":"rfi"},{"id":1771080406000,"createdDate":"2026-02-14 14:46","name":"法国国际广播电台","title":"特朗普对伊朗军事压力加码，不再排除政权更迭","content":"美国总统特朗普在两天前威胁伊朗政权：倘若双方谈判失败，伊朗将面对灾难性后果之后，13日证实美国将很快向波斯湾派出第二艘航空母舰。特朗普似乎也不再排除推翻伊朗现政权的选项。与此同时，流亡海外四十多年伊朗巴列维王朝最后一代君王之子礼萨-巴列维正在社交媒体上呼吁海外流亡伊朗人14日在慕尼黑、在多伦多和洛杉矶集会游行，声援伊朗国内民众的抗议活动，吸引国际社会关注伊朗。伊朗会通过外交谈判走出眼前僵局，还是在内外压力下发生质的改变引人关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260214-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%86%9B%E4%BA%8B%E5%8E%8B%E5%8A%9B%E5%8A%A0%E7%A0%81%EF%BC%8C%E4%B8%8D%E5%86%8D%E6%8E%92%E9%99%A4%E6%94%BF%E6%9D%83%E6%9B%B4%E8%BF%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771080406000.webp","sourceId":"rfi"},{"id":1771071097000,"createdDate":"2026-02-14 12:11","name":"法国国际广播电台","title":"慕尼黑：美国国务卿卢比奥吁欧洲支持特朗普的世界秩序愿景","content":"美国国务卿马可·卢比奥周六在慕尼黑安全会议上呼吁欧洲人支持唐纳德·特朗普对世界秩序的愿景，同时倡导美国与一个“强大的”欧洲重振关系。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260214-%E6%85%95%E5%B0%BC%E9%BB%91-%E7%BE%8E%E5%9B%BD%E5%9B%BD%E5%8A%A1%E5%8D%BF%E5%8D%A2%E6%AF%94%E5%A5%A5%E5%90%81%E6%AC%A7%E6%B4%B2%E6%94%AF%E6%8C%81%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84%E4%B8%96%E7%95%8C%E7%A7%A9%E5%BA%8F%E6%84%BF%E6%99%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771071097000.webp","sourceId":"rfi"},{"id":1771070902000,"createdDate":"2026-02-14 12:08","name":"法国国际广播电台","title":"移民局执法争议引朝野对立，美国土安全部身陷财政断崖","content":"美国移民和海关执法局在明尼亚波利斯的执法行动引发的民间抗议延烧至朝野两大党在国会的对立。国土安全部因预算案未能在参议院争得足够议员支持而搁浅，自2月14日起，进入预算断崖，而这种局面可能因议员休假而持续一段时间。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260214-%E7%A7%BB%E6%B0%91%E5%B1%80%E6%89%A7%E6%B3%95%E4%BA%89%E8%AE%AE%E5%BC%95%E6%9C%9D%E9%87%8E%E5%AF%B9%E7%AB%8B%EF%BC%8C%E7%BE%8E%E5%9B%BD%E5%9C%9F%E5%AE%89%E5%85%A8%E9%83%A8%E8%BA%AB%E9%99%B7%E8%B4%A2%E6%94%BF%E6%96%AD%E5%B4%96","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771070902000.webp","sourceId":"rfi"},{"id":1771066512000,"createdDate":"2026-02-14 10:55","name":"法国国际广播电台","title":"让独立出版的海内外华语书籍被看见 － 访问从中国丶香港丶台湾走向世界的张洁平","content":"台北举行的第34届国际书展刚刚落幕，在509个参与展出的出版社中，首次出现一个独立出版社的书摊，那就是已在台北立足四年的飞地书店。该书摊囊括了不少近年在美国丶日本丶德国等「外语」世界里出版的华语书籍，据旧金山壹嘉出版的创办人刘雁表示，自疫情起，不少中国人因为受不了「清零政策」而移民，与以往不同，当中不少是文科出身，令海外华语书籍市场得以扩大丶兴旺，今年更特地跑来台北，在飞地出版社的摊位售书和办讲座。而在日本出版简体书的张适之，则跑来书展谈版权，把他认为值得留存的繁体书以简体字版出版，希望藉此扫除中国大陆因为出书不自由而令简体字书被认为是垃圾的概念。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260214-%E8%AE%A9%E7%8B%AC%E7%AB%8B%E5%87%BA%E7%89%88%E7%9A%84%E6%B5%B7%E5%86%85%E5%A4%96%E5%8D%8E%E8%AF%AD%E4%B9%A6%E7%B1%8D%E8%A2%AB%E7%9C%8B%E8%A7%81-%EF%BC%8D-%E8%AE%BF%E9%97%AE%E4%BB%8E%E4%B8%AD%E5%9B%BD%E4%B8%B6%E9%A6%99%E6%B8%AF%E4%B8%B6%E5%8F%B0%E6%B9%BE%E8%B5%B0%E5%90%91%E4%B8%96%E7%95%8C%E7%9A%84%E5%BC%A0%E6%B4%81%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771066512000.webp","sourceId":"rfi"},{"id":1771061982000,"createdDate":"2026-02-14 09:39","name":"法国国际广播电台","title":"日本水产厅释放遭逮捕的中国船长","content":"日本水产厅13日宣布，已于日本时间当晚7点55分释放了2月12号逮捕的中国渔船“琼东渔11998号”船长。据称，船长将由水产厅的执法船送回停泊在日本专属经济区（EEZ）内的中国渔船“琼东渔11998号”。据说船长用书面形式表示支付担保金后，日本方面释放了该船长。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260214-%E6%97%A5%E6%9C%AC%E6%B0%B4%E4%BA%A7%E5%8E%85%E9%87%8A%E6%94%BE%E9%81%AD%E9%80%AE%E6%8D%95%E7%9A%84%E4%B8%AD%E5%9B%BD%E8%88%B9%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771061982000.webp","sourceId":"rfi"},{"id":1771061564000,"createdDate":"2026-02-14 09:32","name":"法国国际广播电台","title":"中国官媒：中国向纳米比亚移交卫星地面站","content":"据中国官方媒体报道，中国官员周四在纳米比亚首都温得和克郊外，向该国政府移交了一座援建的卫星地面站，路透社指出：这标志着中国在海外不断扩大的航天计划又向前迈进了一步。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260214-%E4%B8%AD%E5%9B%BD%E5%AE%98%E5%AA%92-%E4%B8%AD%E5%9B%BD%E5%90%91%E7%BA%B3%E7%B1%B3%E6%AF%94%E4%BA%9A%E7%A7%BB%E4%BA%A4%E5%8D%AB%E6%98%9F%E5%9C%B0%E9%9D%A2%E7%AB%99","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771061564000.webp","sourceId":"rfi"}]