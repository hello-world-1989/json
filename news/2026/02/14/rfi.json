[{"id":1771027360000,"createdDate":"2026-02-14 00:02","name":"法国国际广播电台","title":"欧盟谴责中国对欧盟乳制品加征关税","content":"欧盟周五谴责中国对部分欧洲乳制品加征新的关税，虽然北京已经大幅下调了相关税率。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260214-%E6%AC%A7%E7%9B%9F%E8%B0%B4%E8%B4%A3%E4%B8%AD%E5%9B%BD%E5%AF%B9%E6%AC%A7%E7%9B%9F%E4%B9%B3%E5%88%B6%E5%93%81%E5%8A%A0%E5%BE%81%E5%85%B3%E7%A8%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771027360000.webp","sourceId":"rfi"},{"id":1771086008000,"createdDate":"2026-02-14 16:20","name":"法国国际广播电台","title":"卢比奥：美国和西方与中国的关系存在根本性挑战 我们有责任妥善管理","content":"2月14日在慕尼黑，美国国务卿卢比奥表示，我们两国之间，以及西方与中国之间，确实存在一些“根本性的挑战”，出于多种原因，这些挑战在可预见的未来仍将持续存在。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260214-%E5%8D%A2%E6%AF%94%E5%A5%A5-%E7%BE%8E%E5%9B%BD%E5%92%8C%E8%A5%BF%E6%96%B9%E4%B8%8E%E4%B8%AD%E5%9B%BD%E7%9A%84%E5%85%B3%E7%B3%BB%E5%AD%98%E5%9C%A8%E6%A0%B9%E6%9C%AC%E6%80%A7%E6%8C%91%E6%88%98-%E6%88%91%E4%BB%AC%E6%9C%89%E8%B4%A3%E4%BB%BB%E5%A6%A5%E5%96%84%E7%AE%A1%E7%90%86","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771086008000.webp","sourceId":"rfi"},{"id":1771080406000,"createdDate":"2026-02-14 14:46","name":"法国国际广播电台","title":"特朗普对伊朗军事压力加码，不再排除政权更迭","content":"美国总统特朗普在两天前威胁伊朗政权：倘若双方谈判失败，伊朗将面对灾难性后果之后，13日证实美国将很快向波斯湾派出第二艘航空母舰。特朗普似乎也不再排除推翻伊朗现政权的选项。与此同时，流亡海外四十多年伊朗巴列维王朝最后一代君王之子礼萨-巴列维正在社交媒体上呼吁海外流亡伊朗人14日在慕尼黑、在多伦多和洛杉矶集会游行，声援伊朗国内民众的抗议活动，吸引国际社会关注伊朗。伊朗会通过外交谈判走出眼前僵局，还是在内外压力下发生质的改变引人关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260214-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%86%9B%E4%BA%8B%E5%8E%8B%E5%8A%9B%E5%8A%A0%E7%A0%81%EF%BC%8C%E4%B8%8D%E5%86%8D%E6%8E%92%E9%99%A4%E6%94%BF%E6%9D%83%E6%9B%B4%E8%BF%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771080406000.webp","sourceId":"rfi"},{"id":1771071097000,"createdDate":"2026-02-14 12:11","name":"法国国际广播电台","title":"慕尼黑：美国国务卿卢比奥吁欧洲支持特朗普的世界秩序愿景","content":"美国国务卿马可·卢比奥周六在慕尼黑安全会议上呼吁欧洲人支持唐纳德·特朗普对世界秩序的愿景，同时倡导美国与一个“强大的”欧洲重振关系。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260214-%E6%85%95%E5%B0%BC%E9%BB%91-%E7%BE%8E%E5%9B%BD%E5%9B%BD%E5%8A%A1%E5%8D%BF%E5%8D%A2%E6%AF%94%E5%A5%A5%E5%90%81%E6%AC%A7%E6%B4%B2%E6%94%AF%E6%8C%81%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84%E4%B8%96%E7%95%8C%E7%A7%A9%E5%BA%8F%E6%84%BF%E6%99%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771071097000.webp","sourceId":"rfi"},{"id":1771070902000,"createdDate":"2026-02-14 12:08","name":"法国国际广播电台","title":"移民局执法争议引朝野对立，美国土安全部身陷财政断崖","content":"美国移民和海关执法局在明尼亚波利斯的执法行动引发的民间抗议延烧至朝野两大党在国会的对立。国土安全部因预算案未能在参议院争得足够议员支持而搁浅，自2月14日起，进入预算断崖，而这种局面可能因议员休假而持续一段时间。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260214-%E7%A7%BB%E6%B0%91%E5%B1%80%E6%89%A7%E6%B3%95%E4%BA%89%E8%AE%AE%E5%BC%95%E6%9C%9D%E9%87%8E%E5%AF%B9%E7%AB%8B%EF%BC%8C%E7%BE%8E%E5%9B%BD%E5%9C%9F%E5%AE%89%E5%85%A8%E9%83%A8%E8%BA%AB%E9%99%B7%E8%B4%A2%E6%94%BF%E6%96%AD%E5%B4%96","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771070902000.webp","sourceId":"rfi"},{"id":1771066512000,"createdDate":"2026-02-14 10:55","name":"法国国际广播电台","title":"让独立出版的海内外华语书籍被看见 － 访问从中国丶香港丶台湾走向世界的张洁平","content":"台北举行的第34届国际书展刚刚落幕，在509个参与展出的出版社中，首次出现一个独立出版社的书摊，那就是已在台北立足四年的飞地书店。该书摊囊括了不少近年在美国丶日本丶德国等「外语」世界里出版的华语书籍，据旧金山壹嘉出版的创办人刘雁表示，自疫情起，不少中国人因为受不了「清零政策」而移民，与以往不同，当中不少是文科出身，令海外华语书籍市场得以扩大丶兴旺，今年更特地跑来台北，在飞地出版社的摊位售书和办讲座。而在日本出版简体书的张适之，则跑来书展谈版权，把他认为值得留存的繁体书以简体字版出版，希望藉此扫除中国大陆因为出书不自由而令简体字书被认为是垃圾的概念。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260214-%E8%AE%A9%E7%8B%AC%E7%AB%8B%E5%87%BA%E7%89%88%E7%9A%84%E6%B5%B7%E5%86%85%E5%A4%96%E5%8D%8E%E8%AF%AD%E4%B9%A6%E7%B1%8D%E8%A2%AB%E7%9C%8B%E8%A7%81-%EF%BC%8D-%E8%AE%BF%E9%97%AE%E4%BB%8E%E4%B8%AD%E5%9B%BD%E4%B8%B6%E9%A6%99%E6%B8%AF%E4%B8%B6%E5%8F%B0%E6%B9%BE%E8%B5%B0%E5%90%91%E4%B8%96%E7%95%8C%E7%9A%84%E5%BC%A0%E6%B4%81%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771066512000.webp","sourceId":"rfi"},{"id":1771061982000,"createdDate":"2026-02-14 09:39","name":"法国国际广播电台","title":"日本水产厅释放遭逮捕的中国船长","content":"日本水产厅13日宣布，已于日本时间当晚7点55分释放了2月12号逮捕的中国渔船“琼东渔11998号”船长。据称，船长将由水产厅的执法船送回停泊在日本专属经济区（EEZ）内的中国渔船“琼东渔11998号”。据说船长用书面形式表示支付担保金后，日本方面释放了该船长。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260214-%E6%97%A5%E6%9C%AC%E6%B0%B4%E4%BA%A7%E5%8E%85%E9%87%8A%E6%94%BE%E9%81%AD%E9%80%AE%E6%8D%95%E7%9A%84%E4%B8%AD%E5%9B%BD%E8%88%B9%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771061982000.webp","sourceId":"rfi"},{"id":1771061564000,"createdDate":"2026-02-14 09:32","name":"法国国际广播电台","title":"中国官媒：中国向纳米比亚移交卫星地面站","content":"据中国官方媒体报道，中国官员周四在纳米比亚首都温得和克郊外，向该国政府移交了一座援建的卫星地面站，路透社指出：这标志着中国在海外不断扩大的航天计划又向前迈进了一步。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260214-%E4%B8%AD%E5%9B%BD%E5%AE%98%E5%AA%92-%E4%B8%AD%E5%9B%BD%E5%90%91%E7%BA%B3%E7%B1%B3%E6%AF%94%E4%BA%9A%E7%A7%BB%E4%BA%A4%E5%8D%AB%E6%98%9F%E5%9C%B0%E9%9D%A2%E7%AB%99","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771061564000.webp","sourceId":"rfi"},{"id":1771112178000,"createdDate":"2026-02-14 23:36","name":"法国国际广播电台","title":"肯尼亚寻求俄军放归本国公民","content":"在非洲，肯尼亚外交部长宣布，预计将于下个月（2026年3月份）前往莫斯科，协调肯尼亚人被俄罗斯强征入伍一事。来自内罗毕的消息说，有数十名肯尼亚公民被强征加入俄罗斯军队前往乌克兰作战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260214-%E8%82%AF%E5%B0%BC%E4%BA%9A%E5%AF%BB%E6%B1%82%E4%BF%84%E5%86%9B%E6%94%BE%E5%BD%92%E6%9C%AC%E5%9B%BD%E5%85%AC%E6%B0%91","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771112178000.webp","sourceId":"rfi"},{"id":1771112101000,"createdDate":"2026-02-14 23:35","name":"法国国际广播电台","title":"默茨访华：自默克尔以来规模最大经济代表团将随行","content":"据德国《商报》报道，德国联邦总理弗里德里希·默茨（FriedrichMerz，基民盟）将于2月底首次访问中国，并将携由30名高级经济界代表组成的大型代表团同行。这是自默克尔时代以来最大的随总理访华团。多个达克斯企业掌门人都在其中。据《商报》报道，经济界对参与此次访问的兴趣明显高于可提供的名额。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260214-%E9%BB%98%E8%8C%A8%E8%AE%BF%E5%8D%8E-%E8%87%AA%E9%BB%98%E5%85%8B%E5%B0%94%E4%BB%A5%E6%9D%A5%E8%A7%84%E6%A8%A1%E6%9C%80%E5%A4%A7%E7%BB%8F%E6%B5%8E%E4%BB%A3%E8%A1%A8%E5%9B%A2%E5%B0%86%E9%9A%8F%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771112101000.webp","sourceId":"rfi"},{"id":1771111744000,"createdDate":"2026-02-14 23:29","name":"法国国际广播电台","title":"美参议员慕尼黑发声支持乌克兰 泽连斯基称会晤“非常成功”","content":"本周末举行的第62届慕尼黑安全会议上，多位美国跨党派参议员在不同论坛与媒体场合明确表态，强调俄罗斯总统普京（VladimirPutin）从未以诚意参与停战谈判，并主张唯有加大对莫斯科的经济与军事压力，才能改变战局与谈判条件。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260214-%E7%BE%8E%E5%8F%82%E8%AE%AE%E5%91%98%E6%85%95%E5%B0%BC%E9%BB%91%E5%8F%91%E5%A3%B0%E6%94%AF%E6%8C%81%E4%B9%8C%E5%85%8B%E5%85%B0-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E7%A7%B0%E4%BC%9A%E6%99%A4-%E9%9D%9E%E5%B8%B8%E6%88%90%E5%8A%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771111744000.webp","sourceId":"rfi"},{"id":1771111275000,"createdDate":"2026-02-14 23:21","name":"法国国际广播电台","title":"中国知名调查记者刘虎获保释","content":"中国知名调查记者刘虎因发表揭露地方官员腐败的文章被拘留，当地警方周六表示，他已获保释。刘虎十多年前因调查政界腐败而闻名。刘虎被拘捕后，引起海内外关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260214-%E4%B8%AD%E5%9B%BD%E7%9F%A5%E5%90%8D%E8%B0%83%E6%9F%A5%E8%AE%B0%E8%80%85%E5%88%98%E8%99%8E%E8%8E%B7%E4%BF%9D%E9%87%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771111275000.webp","sourceId":"rfi"},{"id":1771108534000,"createdDate":"2026-02-14 22:35","name":"法国国际广播电台","title":"纳瓦尼之死真相大白 欧洲五国指控普京","content":"普京头号政敌纳瓦尼2024年2月16日离奇死亡于看守极其严密的西伯利亚监狱，西方舆论当时几乎毫无例外，指责莫斯科谋杀了纳瓦尼，普京负有直接责任。但是克里姆林宫死不承认。两年后的今天，经科学鉴定，西方五国认定莫斯科使用“毒蟾毒素”“毒死”纳瓦尼。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260214-%E7%BA%B3%E7%93%A6%E5%B0%BC%E4%B9%8B%E6%AD%BB%E7%9C%9F%E7%9B%B8%E5%A4%A7%E7%99%BD-%E6%AC%A7%E6%B4%B2%E4%BA%94%E5%9B%BD%E6%8C%87%E6%8E%A7%E6%99%AE%E4%BA%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771108534000.webp","sourceId":"rfi"},{"id":1771108253000,"createdDate":"2026-02-14 22:30","name":"法国国际广播电台","title":"挪威情报部门：中国北极科研船活动增加引起关注","content":"挪威对外情报机构负责人周六(2月14日）在慕尼黑安全会议期间表示，中国近年来在北极地区的科研船数量明显增加，相关活动具有“军民两用”性质，值得持续关注。他同时指出，尽管俄罗斯因乌克兰战争以及在欧洲、波罗的海地区被西方指控从事破坏性“混合战”和干扰行动，但在北极方向，俄罗斯总体上采取克制策略，刻意避免推高地区紧张局势。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260214-%E6%8C%AA%E5%A8%81%E6%83%85%E6%8A%A5%E9%83%A8%E9%97%A8-%E4%B8%AD%E5%9B%BD%E5%8C%97%E6%9E%81%E7%A7%91%E7%A0%94%E8%88%B9%E6%B4%BB%E5%8A%A8%E5%A2%9E%E5%8A%A0%E5%BC%95%E8%B5%B7%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771108253000.webp","sourceId":"rfi"},{"id":1771107830000,"createdDate":"2026-02-14 22:23","name":"法国国际广播电台","title":"慕尼黑安全会议：英国宣布部署航母战斗群赴北大西洋威慑俄罗斯","content":"英国首相斯塔默周六(2月14日）在慕尼黑安全会议上宣布，英国将于今年向北大西洋及“高北地区”部署由“威尔士亲王”号领军的航空母舰打击群，以强化对俄罗斯的威慑并提升欧洲—大西洋方向的安全部署。法新社指出，法国也计划于2026年在相关海域部署其航母战斗群。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260214-%E6%85%95%E5%B0%BC%E9%BB%91%E5%AE%89%E5%85%A8%E4%BC%9A%E8%AE%AE-%E8%8B%B1%E5%9B%BD%E5%AE%A3%E5%B8%83%E9%83%A8%E7%BD%B2%E8%88%AA%E6%AF%8D%E6%88%98%E6%96%97%E7%BE%A4%E8%B5%B4%E5%8C%97%E5%A4%A7%E8%A5%BF%E6%B4%8B%E5%A8%81%E6%85%91%E4%BF%84%E7%BD%97%E6%96%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771107830000.webp","sourceId":"rfi"},{"id":1771107229000,"createdDate":"2026-02-14 22:13","name":"法国国际广播电台","title":"法国专家:高市早苗跟随安倍晋三 倡导“日本回归”战略","content":"2月8号公布的日本国会提前选举结果已决定性地重塑了日本的政治和战略走向。首相高市早苗领导的日本自民党获得316席，单独超过国会三分之二席次所需的310席。这一选举结果不仅确保了其政府在国内的政治稳定，也为其推行强硬的外交和安全政策提供了必要的政治资本。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%8D%B0%E5%A4%AA%E7%BA%B5%E8%A7%88/20260214-%E6%B3%95%E5%9B%BD%E4%B8%93%E5%AE%B6-%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E8%B7%9F%E9%9A%8F%E5%AE%89%E5%80%8D%E6%99%8B%E4%B8%89-%E5%80%A1%E5%AF%BC-%E6%97%A5%E6%9C%AC%E5%9B%9E%E5%BD%92-%E6%88%98%E7%95%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771107229000.webp","sourceId":"rfi"},{"id":1771106132000,"createdDate":"2026-02-14 21:55","name":"法国国际广播电台","title":"路透：美军为可能持续数周的对伊军事行动做准备","content":"两名美国官员周六（2月14日）向路透社披露，一旦总统特朗普下令打击伊朗，美军将启动一项可能持续数周的军事行动，其强度和规模都可能超过过去美伊之间的冲突。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260214-%E8%B7%AF%E9%80%8F-%E7%BE%8E%E5%86%9B%E4%B8%BA%E5%8F%AF%E8%83%BD%E6%8C%81%E7%BB%AD%E6%95%B0%E5%91%A8%E7%9A%84%E5%AF%B9%E4%BC%8A%E5%86%9B%E4%BA%8B%E8%A1%8C%E5%8A%A8%E5%81%9A%E5%87%86%E5%A4%87","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771106132000.webp","sourceId":"rfi"},{"id":1771105992000,"createdDate":"2026-02-14 21:53","name":"法国国际广播电台","title":"美伊下周将在日内瓦重启会谈","content":"瑞士政府周六(2月14日）宣布，美国与伊朗将于下周在日内瓦恢复谈判。在美国持续向伊朗施压、要求其就限制核计划达成协议的背景下，此举被视为外交渠道重新启动的重要信号。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260214-%E7%BE%8E%E4%BC%8A%E4%B8%8B%E5%91%A8%E5%B0%86%E5%9C%A8%E6%97%A5%E5%86%85%E7%93%A6%E9%87%8D%E5%90%AF%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771105992000.webp","sourceId":"rfi"},{"id":1771105538000,"createdDate":"2026-02-14 21:45","name":"法国国际广播电台","title":"鲁比奥：美中贸易动向影响全球 需管控分歧避免冲突","content":"美国总统特朗普预计将于4月访问中国，会晤中国国家主席习近平。美国国务卿鲁比奥周六(2月14日）在慕尼黑安全会议上表示，美中两国在贸易领域的任何动向都会对全球产生影响。鉴于双方国家利益存在结构性差异，必须通过对话管控分歧，避免冲突发生。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260214-%E9%B2%81%E6%AF%94%E5%A5%A5-%E7%BE%8E%E4%B8%AD%E8%B4%B8%E6%98%93%E5%8A%A8%E5%90%91%E5%BD%B1%E5%93%8D%E5%85%A8%E7%90%83-%E9%9C%80%E7%AE%A1%E6%8E%A7%E5%88%86%E6%AD%A7%E9%81%BF%E5%85%8D%E5%86%B2%E7%AA%81","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771105538000.webp","sourceId":"rfi"},{"id":1771095705000,"createdDate":"2026-02-14 19:01","name":"法国国际广播电台","title":"慕尼黑：20万人集会反伊朗当局 前国王之子承诺助伊朗转型民主","content":"周六下午，大约20万人在慕尼黑集会，抗议伊朗毛拉当局。前伊朗国王之子礼萨-巴列维在示威者面前承诺成为过渡领导者推动伊朗朝民主迈进。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260214-%E6%85%95%E5%B0%BC%E9%BB%91-20%E4%B8%87%E4%BA%BA%E9%9B%86%E4%BC%9A%E5%8F%8D%E4%BC%8A%E6%9C%97%E5%BD%93%E5%B1%80-%E5%89%8D%E5%9B%BD%E7%8E%8B%E4%B9%8B%E5%AD%90%E6%89%BF%E8%AF%BA%E5%8A%A9%E4%BC%8A%E6%9C%97%E8%BD%AC%E5%9E%8B%E6%B0%91%E4%B8%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771095705000.webp","sourceId":"rfi"},{"id":1771093271000,"createdDate":"2026-02-14 18:21","name":"法国国际广播电台","title":"习近平宣布对非洲53个邦交国实施“零关税”","content":"据中国官媒报道，中国国家主席习近平周六宣布，中国将从5月1日起全部取消非洲53个邦交国的进口关税。非邦交国斯威士兰（Eswatini）除外。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260214-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%AE%A3%E5%B8%83%E5%AF%B9%E9%9D%9E%E6%B4%B253%E4%B8%AA%E9%82%A6%E4%BA%A4%E5%9B%BD%E5%AE%9E%E6%96%BD-%E9%9B%B6%E5%85%B3%E7%A8%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771093271000.webp","sourceId":"rfi"},{"id":1771088865000,"createdDate":"2026-02-14 17:07","name":"法国国际广播电台","title":"王毅警告美国对台湾问题“搞阴谋”将招致“冲突”","content":"中国外交部长王毅周六在慕尼黑表示，美国任何欲“图谋”将台湾岛与大陆分离的行径“极可能”导致“对抗”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260214-%E7%8E%8B%E6%AF%85%E8%AD%A6%E5%91%8A%E7%BE%8E%E5%9B%BD%E5%AF%B9%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98-%E6%90%9E%E9%98%B4%E8%B0%8B-%E5%B0%86%E6%8B%9B%E8%87%B4-%E5%86%B2%E7%AA%81","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771088865000.webp","sourceId":"rfi"},{"id":1771088699000,"createdDate":"2026-02-14 17:04","name":"法国国际广播电台","title":"中国最高法院认定：在中国，自动驾驶汽车司机仍承担主要责任","content":"中国最高法院周五在一项确立全国性框架的裁决中认定，在中国，驾驶配备驾驶辅助系统的车辆时，驾驶员仍对车辆控制负有首要责任。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260214-%E4%B8%AD%E5%9B%BD%E6%9C%80%E9%AB%98%E6%B3%95%E9%99%A2%E8%AE%A4%E5%AE%9A-%E5%9C%A8%E4%B8%AD%E5%9B%BD%EF%BC%8C%E8%87%AA%E5%8A%A8%E9%A9%BE%E9%A9%B6%E6%B1%BD%E8%BD%A6%E5%8F%B8%E6%9C%BA%E4%BB%8D%E6%89%BF%E6%8B%85%E4%B8%BB%E8%A6%81%E8%B4%A3%E4%BB%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/02/14/1771088699000.webp","sourceId":"rfi"}]