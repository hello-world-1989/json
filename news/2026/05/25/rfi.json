[{"id":1779669589000,"createdDate":"2026-05-25 00:39","name":"法国国际广播电台","title":"法地缘政治学者：中国、美国和俄罗斯都将欧洲视为猎物","content":"《费加罗报》日前在「世界之声」栏目登出由RonanPlanchon采访FrançoisHeisbourg所整理出文章称，这位地缘政治学者在其新书中分析指出，欧洲精英阶层与民众已将\"新掠食者\"的论述内化，认为我们的大陆已退出历史舞台。下文是访谈摘要。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260525-%E6%B3%95%E5%9C%B0%E7%BC%98%E6%94%BF%E6%B2%BB%E5%AD%A6%E8%80%85-%E4%B8%AD%E5%9B%BD-%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%BF%84%E7%BD%97%E6%96%AF%E9%83%BD%E5%B0%86%E6%AC%A7%E6%B4%B2%E8%A7%86%E4%B8%BA%E7%8C%8E%E7%89%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779669589000.webp","sourceId":"rfi"},{"id":1779699380000,"createdDate":"2026-05-25 08:56","name":"法国国际广播电台","title":"法国罕见五月高温热浪，“热穹顶”叠加气候变暖加剧极端天气波动","content":"法国近日遭遇今年以来最明显的一轮高温天气。短短几天之内，法国迅速入夏，人们从穿毛衣一下子变成穿短袖。5月初，法国还持续受到低温和频繁扰动天气影响，而如今，全国大部分地区气温已经突破30摄氏度，西部地区尤为明显。这一异常天气过程既体现了气候失调背景下高温出现时间越来越早，也反映出天气转换正在变得愈发剧烈。法国国家科研中心气候学家达维德·法兰达解释说：“随着气候变化，高压与低压系统之间的切换正在加快，土壤更加干燥，积雪融化速度也更快。这些因素都在促进天气快速转换。总体而言，气候正变得更加不稳定，两种相反极端天气之间的转换速度越来越快。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E7%94%9F%E6%B4%BB/20260525-%E6%B3%95%E5%9B%BD%E7%BD%95%E8%A7%81%E4%BA%94%E6%9C%88%E9%AB%98%E6%B8%A9%E7%83%AD%E6%B5%AA%EF%BC%8C-%E7%83%AD%E7%A9%B9%E9%A1%B6-%E5%8F%A0%E5%8A%A0%E6%B0%94%E5%80%99%E5%8F%98%E6%9A%96%E5%8A%A0%E5%89%A7%E6%9E%81%E7%AB%AF%E5%A4%A9%E6%B0%94%E6%B3%A2%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779699380000.webp","sourceId":"rfi"},{"id":1779698897000,"createdDate":"2026-05-25 08:48","name":"法国国际广播电台","title":"台湾外长林佳龙：美国对台140亿美元军售依法进行且对台政策没有改变","content":"特习会后美国对台军售成焦点。特朗普表示会就140亿美元军售案尽快做出决定。台湾外交部长与国安局长25日表示，再次重申美国对台政策不变，对台军售则依法进行中。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260525-%E5%8F%B0%E6%B9%BE%E5%A4%96%E9%95%BF%E6%9E%97%E4%BD%B3%E9%BE%99-%E7%BE%8E%E5%9B%BD%E5%AF%B9%E5%8F%B0140%E4%BA%BF%E7%BE%8E%E5%85%83%E5%86%9B%E5%94%AE%E4%BE%9D%E6%B3%95%E8%BF%9B%E8%A1%8C%E4%B8%94%E5%AF%B9%E5%8F%B0%E6%94%BF%E7%AD%96%E6%B2%A1%E6%9C%89%E6%94%B9%E5%8F%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779698897000.webp","sourceId":"rfi"},{"id":1779698784000,"createdDate":"2026-05-25 08:46","name":"法国国际广播电台","title":"巴基斯坦陆军参谋长穆尼尔陪总理访华  将北京纳入美伊调解进程核心？","content":"法新社引述巴基斯坦国家电视台周一（5月25号）报道，美国与伊朗冲突首席调解人，巴基斯坦陆军参谋长阿西姆·穆尼尔（AsimMunir）已经抵达北京，与总理谢赫巴兹·谢里夫（ShehbazSharif）一同访问中国，与中国领导人举行会晤。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260525-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E9%99%86%E5%86%9B%E5%8F%82%E8%B0%8B%E9%95%BF%E7%A9%86%E5%B0%BC%E5%B0%94%E9%99%AA%E6%80%BB%E7%90%86%E8%AE%BF%E5%8D%8E-%E5%B0%86%E5%8C%97%E4%BA%AC%E7%BA%B3%E5%85%A5%E7%BE%8E%E4%BC%8A%E8%B0%83%E8%A7%A3%E8%BF%9B%E7%A8%8B%E6%A0%B8%E5%BF%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779698784000.webp","sourceId":"rfi"},{"id":1779698645000,"createdDate":"2026-05-25 08:44","name":"法国国际广播电台","title":"法广RFI推出亚美尼亚语社媒频道旨在对抗网络虚假信息","content":"法国国际广播电台（RFI）5月25日周一推出亚美尼亚语社交媒体资讯，主要面向年轻人，当务之急是在6月亚美尼亚议会选举前，对抗来自俄罗斯的受操纵和虚假信息”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260525-%E6%B3%95%E5%B9%BFrfi%E6%8E%A8%E5%87%BA%E4%BA%9A%E7%BE%8E%E5%B0%BC%E4%BA%9A%E8%AF%AD%E7%A4%BE%E5%AA%92%E9%A2%91%E9%81%93%E6%97%A8%E5%9C%A8%E5%AF%B9%E6%8A%97%E7%BD%91%E7%BB%9C%E8%99%9A%E5%81%87%E4%BF%A1%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779698645000.webp","sourceId":"rfi"},{"id":1779698562000,"createdDate":"2026-05-25 08:42","name":"法国国际广播电台","title":"日本官房长官反驳习近平在美中首脑会谈时批判日本","content":"日本内阁官房长官木原稔在日本时间25日上午的记者会上，就习近平在美中首脑会谈中以“新型军国主义”等措辞批评日本的报道表示，日本“专守防卫”的基本方针并未改变，“中方的主张完全不符合事实”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260525-%E6%97%A5%E6%9C%AC%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E5%8F%8D%E9%A9%B3%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%9C%A8%E7%BE%8E%E4%B8%AD%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88%E6%97%B6%E6%89%B9%E5%88%A4%E6%97%A5%E6%9C%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779698562000.webp","sourceId":"rfi"},{"id":1779698030000,"createdDate":"2026-05-25 08:33","name":"法国国际广播电台","title":"华为披露芯片设计突破性进展，寻求化解美国制裁","content":"路透社5月25日报道，华为日前在上海举行的一场半导体研讨会上表示，公司计划在未来五年内，通过一项全新的芯片技术路线，制造达到行业领先水平的半导体产品。这一表态也被外界视为中国在美国技术限制背景下，继续推进高端芯片自主研发的重要信号。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260525-%E5%8D%8E%E4%B8%BA%E6%8A%AB%E9%9C%B2%E8%8A%AF%E7%89%87%E8%AE%BE%E8%AE%A1%E7%AA%81%E7%A0%B4%E6%80%A7%E8%BF%9B%E5%B1%95%EF%BC%8C%E5%AF%BB%E6%B1%82%E5%8C%96%E8%A7%A3%E7%BE%8E%E5%9B%BD%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779698030000.webp","sourceId":"rfi"},{"id":1779694347000,"createdDate":"2026-05-25 07:32","name":"法国国际广播电台","title":"非洲疾控中心的埃博拉预警信息","content":"非洲疾病预防控制中心（AfricaCDC）表示，为应对刚果民主共和国（RDCongo）正在爆发的第17轮埃博拉(Ebola)疫情，需要近3亿2千万美元。目前仍有近三分之一的资金缺口没有着落。除了确症患者人数持续增加的刚果（金）和乌干达之外，还有十个非洲国家有疫情风险。本台法广非洲组（RFIAfrique）的多名法语通讯员分别从金沙萨（Kinshasa）和基加利（Kigali）发回相关报导。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260525-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779694347000.webp","sourceId":"rfi"},{"id":1779693133000,"createdDate":"2026-05-25 07:12","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第24:浪漫主义群星之五:海涅:第四节:乘着歌声的翅膀","content":"海涅是一位诗才卓绝的天才。他的创作数量巨大，体裁多样，情绪丰富多变。他的诗作可称为一座丰富的人类情感宝库。从缠绵爱情到同情苦难，从怒目反动政治势力到为劳动阶层仗义执言，从林间夜莺到出鞘的宝剑，在他的诗歌中都占有一席之地。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260525-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%BA%94-%E6%B5%B7%E6%B6%85-%E7%AC%AC%E5%9B%9B%E8%8A%82-%E4%B9%98%E7%9D%80%E6%AD%8C%E5%A3%B0%E7%9A%84%E7%BF%85%E8%86%80","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779693133000.webp","sourceId":"rfi"},{"id":1779693001000,"createdDate":"2026-05-25 07:10","name":"法国国际广播电台","title":"港产女太空人升空掀热潮 推广爱国和航天经济此其时","content":"首次有土生土长的港人升空，近日在香港引发热议，在中国日前宣布黎家盈是神舟二十三号航天乘组人员之後，港府官员和建制人士已纷纷祝贺，感谢国家支持；相关大学和部分街坊社团亦在「神23」升空当晚组团观赏直播；到了今早，全港主流报章社评有一半以航天梦圆为题，内容则大推中国「十五五」规划和香港须支持中国发展的爱国思想。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260525-%E6%B8%AF%E4%BA%A7%E5%A5%B3%E5%A4%AA%E7%A9%BA%E4%BA%BA%E5%8D%87%E7%A9%BA%E6%8E%80%E7%83%AD%E6%BD%AE-%E6%8E%A8%E5%B9%BF%E7%88%B1%E5%9B%BD%E5%92%8C%E8%88%AA%E5%A4%A9%E7%BB%8F%E6%B5%8E%E6%AD%A4%E5%85%B6%E6%97%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779693001000.webp","sourceId":"rfi"},{"id":1779692734000,"createdDate":"2026-05-25 07:05","name":"法国国际广播电台","title":"首位港产太空人黎家盈进驻「天宫」 操作港产发明监测碳排放","content":"即将突破中国航天员由在太空驻留一天到一年历史的神舟二十三号，为香港带来另一个突破，就是首次有港产女太空人升空，这位女警司黎家盈今(25日)早更顺利「太空会师」，成为首位进驻「天宫」太空站的香港航天员，日後将操作由香港首项登上国家太空站的科研载荷──「天韵相机」的在轨运行，展开温室气体排放源探测任务。有学者认为，这实现了「港产闭环」，将极大推动香港航天科技的发展。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260525-%E9%A6%96%E4%BD%8D%E6%B8%AF%E4%BA%A7%E5%A4%AA%E7%A9%BA%E4%BA%BA%E9%BB%8E%E5%AE%B6%E7%9B%88%E8%BF%9B%E9%A9%BB-%E5%A4%A9%E5%AE%AB-%E6%93%8D%E4%BD%9C%E6%B8%AF%E4%BA%A7%E5%8F%91%E6%98%8E%E7%9B%91%E6%B5%8B%E7%A2%B3%E6%8E%92%E6%94%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779692734000.webp","sourceId":"rfi"},{"id":1779727941000,"createdDate":"2026-05-25 16:52","name":"法国国际广播电台","title":"美伊谈判之际 全球超过一百万穆斯林开始朝觐之旅","content":"周一，约150万穆斯林开始遵循古老的朝觐仪式，前往麦加参加穆斯林的盛大朝觐活动，此时正值各方为寻求中东冲突的持久解决方案而进行外交磋商之际。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260525-%E7%BE%8E%E4%BC%8A%E8%B0%88%E5%88%A4%E4%B9%8B%E9%99%85-%E5%85%A8%E7%90%83%E8%B6%85%E8%BF%87%E4%B8%80%E7%99%BE%E4%B8%87%E7%A9%86%E6%96%AF%E6%9E%97%E5%BC%80%E5%A7%8B%E6%9C%9D%E8%A7%90%E4%B9%8B%E6%97%85","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779727941000.webp","sourceId":"rfi"},{"id":1779723898000,"createdDate":"2026-05-25 15:44","name":"法国国际广播电台","title":"乌克兰袭俄能源设施 据报俄境内两人死亡","content":"法新社25日莫斯科消息，周一，乌克兰对与其接壤的俄罗斯别尔哥罗德州和布良斯克州发动空袭，造成两人死亡。之前一天俄罗斯轰炸乌克兰造成4人死亡，100多人受伤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260525-%E4%B9%8C%E5%85%8B%E5%85%B0%E8%A2%AD%E4%BF%84%E8%83%BD%E6%BA%90%E8%AE%BE%E6%96%BD-%E6%8D%AE%E6%8A%A5%E4%BF%84%E5%A2%83%E5%86%85%E4%B8%A4%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779723898000.webp","sourceId":"rfi"},{"id":1779722429000,"createdDate":"2026-05-25 15:20","name":"法国国际广播电台","title":"伊朗称与美国谈判有进展 否认即将签署协议","content":"据伊朗发言人周一重申，最关键的伊朗核计划的细节并未纳入谈判框架，并说，该问题将在达成总体框架议后才会讨论。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260525-%E4%BC%8A%E6%9C%97%E7%A7%B0%E4%B8%8E%E7%BE%8E%E5%9B%BD%E8%B0%88%E5%88%A4%E6%9C%89%E8%BF%9B%E5%B1%95-%E5%90%A6%E8%AE%A4%E5%8D%B3%E5%B0%86%E7%AD%BE%E7%BD%B2%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779722429000.webp","sourceId":"rfi"},{"id":1779720702000,"createdDate":"2026-05-25 14:51","name":"法国国际广播电台","title":"东京银座一男喷洒某种物质造成约20人受伤","content":"日本警方和消防部门官员周一表示，一名男子在东京市中心银座购物中心喷洒某种物质，导致大约20人受伤。警方正在追查。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260525-%E4%B8%9C%E4%BA%AC%E9%93%B6%E5%BA%A7%E4%B8%80%E5%90%8D%E7%96%91%E4%BC%BC%E7%94%B7%E5%96%B7%E6%B4%92%E6%9F%90%E7%A7%8D%E7%89%A9%E8%B4%A8%E9%80%A0%E6%88%90%E7%BA%A620%E4%BA%BA%E5%8F%97%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779720702000.webp","sourceId":"rfi"},{"id":1779719098000,"createdDate":"2026-05-25 14:24","name":"法国国际广播电台","title":"特朗普要求沙特和卡塔尔在与伊朗潜在和平框架内签署《亚伯拉罕协议》","content":"美国总统唐纳德·特朗普周一要求以穆斯林为主的国家，尤其是沙特阿拉伯和卡塔尔，在关于伊朗的潜在和平协议框架内，与以色列实现关系正常化。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260525-%E7%89%B9%E6%9C%97%E6%99%AE%E8%A6%81%E6%B1%82%E6%B2%99%E7%89%B9%E5%92%8C%E5%8D%A1%E5%A1%94%E5%B0%94%E5%9C%A8%E4%B8%8E%E4%BC%8A%E6%9C%97%E6%BD%9C%E5%9C%A8%E5%92%8C%E5%B9%B3%E6%A1%86%E6%9E%B6%E5%86%85%E7%AD%BE%E7%BD%B2-%E4%BA%9A%E4%BC%AF%E6%8B%89%E7%BD%95%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779719098000.webp","sourceId":"rfi"},{"id":1779718896000,"createdDate":"2026-05-25 14:21","name":"法国国际广播电台","title":"特朗普称要么是一项伟大而有意义的协议，要么就根本不会有任何协议","content":"美国总统特朗普周一表示，与伊朗达成的协议，要么是一项伟大而有意义的协议，要么就根本不会有任何协议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260525-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E8%A6%81%E4%B9%88%E6%98%AF%E4%B8%80%E9%A1%B9%E4%BC%9F%E5%A4%A7%E8%80%8C%E6%9C%89%E6%84%8F%E4%B9%89%E7%9A%84%E5%8D%8F%E8%AE%AE%EF%BC%8C%E8%A6%81%E4%B9%88%E5%B0%B1%E6%A0%B9%E6%9C%AC%E4%B8%8D%E4%BC%9A%E6%9C%89%E4%BB%BB%E4%BD%95%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779718896000.webp","sourceId":"rfi"},{"id":1779717706000,"createdDate":"2026-05-25 14:01","name":"法国国际广播电台","title":"世卫组织：刚果(金)出现900多例疑似埃博拉病例","content":"世界卫生组织总干事谭德塞周日宣布，刚果(金)迄今已发现900多例埃博拉疑似病例，其中包括101例确诊病例。","newsLink":"https://www.rfi.fr/cn/%E7%94%9F%E6%80%81/20260525-%E4%B8%96%E5%8D%AB%E7%BB%84%E7%BB%87-%E5%88%9A%E6%9E%9C-%E8%BF%91-%E5%87%BA%E7%8E%B0900%E5%A4%9A%E4%BE%8B%E7%96%91%E4%BC%BC%E5%9F%83%E5%8D%9A%E6%8B%89%E7%97%85%E4%BE%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779717706000.webp","sourceId":"rfi"},{"id":1779715815000,"createdDate":"2026-05-25 13:30","name":"法国国际广播电台","title":"美伊协议“罗生门”：已知和未知的内容","content":"美国总统特朗普最近几天有关是否与伊朗接近达成协议发出前后不一致的表态令全球市场情绪犹如坐过山车。在周六曾断言华盛顿和德黑兰已为签署谅解备忘录奠定了基础，以结束这场由美国和以色列2月28日空袭伊朗引发的冲突。周日却又说：“已经指示代表不要仓促达成协议，因为时间对我们有利。”美国方面周一坚称，与伊朗达成“稳固”协议仍接近完成。伊朗外交部周一的回应是：我们已经就讨论的许多议题达成了共识，但这并不意味着我们即将签署协议。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260525-%E7%BE%8E%E4%BC%8A%E5%8D%8F%E8%AE%AE-%E7%BD%97%E7%94%9F%E9%97%A8-%E5%B7%B2%E7%9F%A5%E5%92%8C%E6%9C%AA%E7%9F%A5%E7%9A%84%E5%86%85%E5%AE%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779715815000.webp","sourceId":"rfi"},{"id":1779708821000,"createdDate":"2026-05-25 11:33","name":"法国国际广播电台","title":"自民党成立巨大政治联盟 为高市政权长期化铺路","content":"为了支持高市政权，日本自民党的议员联盟“国力研究会”于5月21日成立，并召开了首次会议，该组织意在形成由支持高市早苗首相（党总裁）的议员构成的“主流派”，加入者竟然趋之若鹜，超过了自民党国会议员总数的八成，达347人，形成了“高市一强”的政治局面。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260525-%E8%87%AA%E6%B0%91%E5%85%9A%E6%88%90%E7%AB%8B%E5%B7%A8%E5%A4%A7%E6%94%BF%E6%B2%BB%E8%81%94%E7%9B%9F-%E4%B8%BA%E9%AB%98%E5%B8%82%E6%94%BF%E6%9D%83%E9%95%BF%E6%9C%9F%E5%8C%96%E9%93%BA%E8%B7%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779708821000.webp","sourceId":"rfi"},{"id":1779703441000,"createdDate":"2026-05-25 10:04","name":"法国国际广播电台","title":"费加罗报：面对伊朗 特朗普是只“纸老虎” 回声报：中国黄金飙涨时 结婚随之提前","content":"大家好，欢迎收听法国报纸摘要。今天5月22日是基督教的圣神灵降临日（俗称为五旬节放假一天），法国上市的全国性日报仅有《费加罗报》，伊朗战争危机重回头版话题。该报表示：美国总统特朗普倾向于采取妥协路线，并指出特朗普在此上的态度反复无常，周六他曾暗示与伊朗的危机有望化解，但周日又对此提出了保留意见。该报社论更是直陈“面对伊朗，唐纳德·特朗普不过是只‘纸老虎’”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260525-%E8%B4%B9%E5%8A%A0%E7%BD%97%E6%8A%A5-%E9%9D%A2%E5%AF%B9%E4%BC%8A%E6%9C%97-%E7%89%B9%E6%9C%97%E6%99%AE%E6%98%AF%E5%8F%AA-%E7%BA%B8%E8%80%81%E8%99%8E-%E5%9B%9E%E5%A3%B0%E6%8A%A5-%E4%B8%AD%E5%9B%BD%E9%BB%84%E9%87%91%E9%A3%99%E6%B6%A8%E6%97%B6-%E7%BB%93%E5%A9%9A%E9%9A%8F%E4%B9%8B%E6%8F%90%E5%89%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/25/1779703441000.webp","sourceId":"rfi"}]