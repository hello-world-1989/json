[{"id":1778837538000,"createdDate":"2026-05-15 09:32","name":"法国国际广播电台","title":"特习峰会 美国内对华强硬声浪未歇","content":"美国总统特朗普(DonaldTrump)抵达北京，与中国国家主席习近平举行峰会，议题涵盖贸易、能源、台湾及伊朗战争。然而就在特朗普踏上中国土地之际，美国国内各方势力同步发力，国会议员立法阻截中资购买农地、推动禁售中国联网汽车，参议院领袖更批评特朗普向中国出售人工智能芯片，局面空前复杂。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260515-%E7%89%B9%E4%B9%A0%E5%B3%B0%E4%BC%9A-%E7%BE%8E%E5%9B%BD%E5%86%85%E5%AF%B9%E5%8D%8E%E5%BC%BA%E7%A1%AC%E5%A3%B0%E6%B5%AA%E6%9C%AA%E6%AD%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778837538000.webp","sourceId":"rfi"},{"id":1778833480000,"createdDate":"2026-05-15 08:24","name":"法国国际广播电台","title":"特朗普结束访华夸赞经济成果 台湾问题中美似仍“各表”","content":"周五，美国总统唐纳德·特朗普和中国国家主席习近平共进茶点和午餐，给两天的峰会画上句号。特朗普离开北京时夸赞他与中国达成了经济成果，避免回答台湾问题，但卢比奥向媒体表示：美国的对台政策“迄今未变”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260515-%E7%89%B9%E6%9C%97%E6%99%AE%E7%BB%93%E6%9D%9F%E8%AE%BF%E5%8D%8E%E5%A4%B8%E8%B5%9E%E7%BB%8F%E6%B5%8E%E6%88%90%E6%9E%9C-%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98%E4%B8%AD%E7%BE%8E%E4%BC%BC%E4%BB%8D-%E5%90%84%E8%A1%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778833480000.webp","sourceId":"rfi"},{"id":1778828347000,"createdDate":"2026-05-15 06:59","name":"法国国际广播电台","title":"日本大臣在高市首相有关“台湾有事”答辩后首次访华","content":"日本内阁府14日宣布，男女共同参画担当大臣黄川田仁志已确定于14日至15日访问中国上海，并已于14日晚出发前往上海，出席亚太经合组织（APEC）部长级会议。自高市早苗去年11月在国会就“台湾有事”作出国会答辩以来，这是日本阁僚首次访华。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260515-%E6%97%A5%E6%9C%AC%E5%A4%A7%E8%87%A3%E5%9C%A8%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E6%9C%89%E5%85%B3-%E5%8F%B0%E6%B9%BE%E6%9C%89%E4%BA%8B-%E7%AD%94%E8%BE%A9%E5%90%8E%E9%A6%96%E6%AC%A1%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778828347000.webp","sourceId":"rfi"},{"id":1778828026000,"createdDate":"2026-05-15 06:53","name":"法国国际广播电台","title":"盘点「特习会」：两国中途休战但不离擂台 为稳定冷处理台湾丶黎智英等敏感问题","content":"全球瞩目的「特习会」，中美元首表明有就重大问题交换意见，但会后双方未有发布共同声明，台湾问题似是各自表述，美方「提及」而并非要求释放黎智英等人则未见中方回应。学者和专家向法广分析指，这次中美元首会面最大的作用，是缓和两国一度紧张的关系，双方强调的稳定关系，更像是拳赛选手的中途休战，不代表中美竞争互斗的格局有重大改变。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260515-%E7%9B%98%E7%82%B9-%E7%89%B9%E4%B9%A0%E4%BC%9A-%E4%B8%A4%E5%9B%BD%E4%B8%AD%E9%80%94%E4%BC%91%E6%88%98%E4%BD%86%E4%B8%8D%E7%A6%BB%E6%93%82%E5%8F%B0-%E4%B8%BA%E7%A8%B3%E5%AE%9A%E5%86%B7%E5%A4%84%E7%90%86%E5%8F%B0%E6%B9%BE%E4%B8%B6%E9%BB%8E%E6%99%BA%E8%8B%B1%E7%AD%89%E6%95%8F%E6%84%9F%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778828026000.webp","sourceId":"rfi"},{"id":1778862042000,"createdDate":"2026-05-15 16:20","name":"法国国际广播电台","title":"台湾学者侍建宇：中方面对特朗普在台湾议题上绵里藏针","content":"美国总统特朗普15日结束对中国的访问，离开北京。北京当局为这次中美领导人时隔九年的北京会谈安排了高规格的接待，美国总统似乎对此也十分享受。随着中美两国全面战略竞争日益激烈，国际社会对两国领导人沟通协商、化解分歧多有期待。但中美双方各自对这次北京峰会的期待可能并不重合。特朗普高调宣称双方达成了一些“神奇”的贸易协议，但中国决定购买美国波音飞机的数量显然远低于此前外界的预期。在美方关注的伊朗战争议题上和中国特别关注的台湾议题上，从目前流露出的消息来看，双方并未达成实质性共识，显示这次峰会本身并不像外观那样祥和。台湾国防部下属智库，国防安全研究院副研究员侍建宇先生接受本台电话采访时，特别点出中方在台湾议题上绵里藏针式的安排。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260515-%E5%8F%B0%E6%B9%BE%E5%AD%A6%E8%80%85%E4%BE%8D%E5%BB%BA%E5%AE%87-%E4%B8%AD%E6%96%B9%E9%9D%A2%E5%AF%B9%E7%89%B9%E6%9C%97%E6%99%AE%E5%9C%A8%E5%8F%B0%E6%B9%BE%E8%AE%AE%E9%A2%98%E4%B8%8A%E7%BB%B5%E9%87%8C%E8%97%8F%E9%92%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778862042000.webp","sourceId":"rfi"},{"id":1778861233000,"createdDate":"2026-05-15 16:07","name":"法国国际广播电台","title":"特习会落幕“这些东西”一律不准带进空军一号","content":"美国总统特朗普15日结束对中国的访问，据台湾自由时报引述一名跟随特朗普的美国记者爆料，白宫官员在登上空军一号之前，收集中共官员分发的所有物品，并全数丢进垃圾桶，称这些东西“一律不准带上飞机”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260515-%E7%89%B9%E4%B9%A0%E4%BC%9A%E8%90%BD%E5%B9%95-%E8%BF%99%E4%BA%9B%E4%B8%9C%E8%A5%BF-%E4%B8%80%E5%BE%8B%E4%B8%8D%E5%87%86%E5%B8%A6%E8%BF%9B%E7%A9%BA%E5%86%9B%E4%B8%80%E5%8F%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778861233000.webp","sourceId":"rfi"},{"id":1778859872000,"createdDate":"2026-05-15 15:44","name":"法国国际广播电台","title":"美国会保卫台湾吗？特朗普说我回答习近平：“我不想谈这个”","content":"美国总统特朗普5月15日结束访华，在返程途中他告诉媒体，他拒绝直接回答中国国家主席习近平的问题：如果中国攻击台湾，美国是否会捍卫台湾。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260515-%E7%BE%8E%E5%9B%BD%E4%BC%9A%E4%BF%9D%E5%8D%AB%E5%8F%B0%E6%B9%BE%E5%90%97-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AF%B4%E6%88%91%E5%9B%9E%E7%AD%94%E4%B9%A0%E8%BF%91%E5%B9%B3-%E6%88%91%E4%B8%8D%E6%83%B3%E8%B0%88%E8%BF%99%E4%B8%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778859872000.webp","sourceId":"rfi"},{"id":1778855844000,"createdDate":"2026-05-15 14:37","name":"法国国际广播电台","title":"戛纳影节主竞赛单元 日本与西班牙平分秋色","content":"今年的戛纳电影节主竞赛单元的入选影片中，日本与西班牙可谓平分秋色——两国各有三部影片入围角逐金棕榈，成为本届影节最受关注的两大电影力量。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%89%B9%E5%88%AB%E8%8A%82%E7%9B%AE/20260515-%E6%88%9B%E7%BA%B3%E5%BD%B1%E8%8A%82%E4%B8%BB%E7%AB%9E%E8%B5%9B%E5%8D%95%E5%85%83-%E6%97%A5%E6%9C%AC%E4%B8%8E%E8%A5%BF%E7%8F%AD%E7%89%99%E5%B9%B3%E5%88%86%E7%A7%8B%E8%89%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778855844000.webp","sourceId":"rfi"},{"id":1778855767000,"createdDate":"2026-05-15 14:36","name":"法国国际广播电台","title":"标致再次尝试进军中国市场","content":"就在发布战略规划的前几天，法国车企斯特兰蒂斯集团发布了一系列公告。周五，斯特兰蒂斯和中国的合作伙伴——东风汽车宣布加强合作。双方的合资企业将为中国市场生产两款全新的法国标致车型。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260515-%E6%A0%87%E8%87%B4%E5%86%8D%E6%AC%A1%E5%B0%9D%E8%AF%95%E8%BF%9B%E5%86%9B%E4%B8%AD%E5%9B%BD%E5%B8%82%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778855767000.webp","sourceId":"rfi"},{"id":1778853578000,"createdDate":"2026-05-15 13:59","name":"法国国际广播电台","title":"乌克兰全国哀悼日：至少24人在前一夜轰炸中遇难","content":"周五是基辅举行的全国哀悼日，周三至周四夜间，俄罗斯对乌克兰首都发动了大规模轰炸，据仍在清理倒塌楼宇的救援人员最新统计，袭击造成24人死亡，其中包括3名儿童。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260515-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%85%A8%E5%9B%BD%E5%93%80%E6%82%BC%E6%97%A5-%E8%87%B3%E5%B0%9124%E4%BA%BA%E5%9C%A8%E5%89%8D%E4%B8%80%E5%A4%9C%E8%BD%B0%E7%82%B8%E4%B8%AD%E9%81%87%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778853578000.webp","sourceId":"rfi"},{"id":1778853460000,"createdDate":"2026-05-15 13:57","name":"法国国际广播电台","title":"古巴因美国封锁深陷能源危机之际，美中情局局长赴哈瓦那会谈","content":"古巴因特朗普政府加大封锁措施力度而不断恶化的能源危机正引爆社会不满之际，美国中情局局长约翰·拉特克里夫（JohnRatcliffe）14日在哈瓦那与古巴高层负责人举行会议。中情局没有披露这次会谈的具体内容，古巴当局则表示，会谈旨在推动政治对话。与此同时，有美国媒体报道称，美方有意起诉古巴前国家主席劳尔-卡斯特罗。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260515-%E5%8F%A4%E5%B7%B4%E5%9B%A0%E7%BE%8E%E5%9B%BD%E5%B0%81%E9%94%81%E6%B7%B1%E9%99%B7%E8%83%BD%E6%BA%90%E5%8D%B1%E6%9C%BA%E4%B9%8B%E9%99%85%EF%BC%8C%E7%BE%8E%E4%B8%AD%E6%83%85%E5%B1%80%E5%B1%80%E9%95%BF%E8%B5%B4%E5%93%88%E7%93%A6%E9%82%A3%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778853460000.webp","sourceId":"rfi"},{"id":1778851441000,"createdDate":"2026-05-15 13:24","name":"法国国际广播电台","title":"南华早报：俄罗斯总统普京5.20访华","content":"据《南华早报》引述匿名消息，俄罗斯总统普京将于5月20日周三访问北京。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260515-%E5%8D%97%E5%8D%8E%E6%97%A9%E6%8A%A5-%E4%BF%84%E7%BD%97%E6%96%AF%E6%80%BB%E7%BB%9F%E6%99%AE%E4%BA%AC5-20%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778851441000.webp","sourceId":"rfi"},{"id":1778847358000,"createdDate":"2026-05-15 12:15","name":"法国国际广播电台","title":"国际足联与中国谈妥2026年和2030年世界杯转播权","content":"中国官媒周五宣布，国际足联FIFA与中国国家媒体央广电总台CMG谈判达成协议，给予在中国转播2026年男足世界杯（将在不到一个月后开幕）和2030年男足世界杯的独家转播权。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260515-%E5%9B%BD%E9%99%85%E8%B6%B3%E8%81%94%E4%B8%8E%E4%B8%AD%E5%9B%BD%E8%B0%88%E5%A6%A52026%E5%B9%B4%E5%92%8C2030%E5%B9%B4%E4%B8%96%E7%95%8C%E6%9D%AF%E8%BD%AC%E6%92%AD%E6%9D%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778847358000.webp","sourceId":"rfi"},{"id":1778842700000,"createdDate":"2026-05-15 10:58","name":"法国国际广播电台","title":"费加罗报解析：为何中国是特朗普美洲地缘争夺战的间接目标","content":"美中元首北京峰会期间，《费加罗报》国际版登出伊莎贝尔·拉塞尔署名分析报道指出，从巴拿马到格陵兰，从委内瑞拉到伊朗，美国总统唐纳德·特朗普希望遏制其最大竞争对手—中国—的影响力。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260515-%E4%B8%BA%E4%BD%95%E4%B8%AD%E5%9B%BD%E6%98%AF%E7%89%B9%E6%9C%97%E6%99%AE%E7%BE%8E%E6%B4%B2%E5%9C%B0%E7%BC%98%E4%BA%89%E5%A4%BA%E6%88%98%E7%9A%84%E9%97%B4%E6%8E%A5%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778842700000.webp","sourceId":"rfi"},{"id":1778838328000,"createdDate":"2026-05-15 09:45","name":"法国国际广播电台","title":"“缓和有限”的特习会落幕《费加罗报》与《解放报》观察重点比较","content":"大家好，欢迎收听法国报纸摘要。美国总统特朗普周五离开北京，结束举世瞩目的「特习会」。今天5月15日《费加罗报》与《解放报》均将此次峰会视为近年来中美关系的重要节点，但两大日报的观察角度却有差异：前者更强调特朗普试图以“成果外交”展示政绩，后者则更关注中美矛盾的结构性本质以及中国在国际局势中的战略姿态。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260515-%E7%BC%93%E5%92%8C%E6%9C%89%E9%99%90-%E7%9A%84%E7%89%B9%E4%B9%A0%E4%BC%9A%E8%90%BD%E5%B9%95-%E6%AF%94%E8%BE%83-%E8%B4%B9%E5%8A%A0%E7%BD%97%E6%8A%A5-%E4%B8%8E-%E8%A7%A3%E6%94%BE%E6%8A%A5-%E8%A7%82%E5%AF%9F%E9%87%8D%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778838328000.webp","sourceId":"rfi"}]