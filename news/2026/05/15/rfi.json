[{"id":1778837538000,"createdDate":"2026-05-15 09:32","name":"法国国际广播电台","title":"特习峰会 美国内对华强硬声浪未歇","content":"美国总统特朗普(DonaldTrump)抵达北京，与中国国家主席习近平举行峰会，议题涵盖贸易、能源、台湾及伊朗战争。然而就在特朗普踏上中国土地之际，美国国内各方势力同步发力，国会议员立法阻截中资购买农地、推动禁售中国联网汽车，参议院领袖更批评特朗普向中国出售人工智能芯片，局面空前复杂。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260515-%E7%89%B9%E4%B9%A0%E5%B3%B0%E4%BC%9A-%E7%BE%8E%E5%9B%BD%E5%86%85%E5%AF%B9%E5%8D%8E%E5%BC%BA%E7%A1%AC%E5%A3%B0%E6%B5%AA%E6%9C%AA%E6%AD%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778837538000.webp","sourceId":"rfi"},{"id":1778833480000,"createdDate":"2026-05-15 08:24","name":"法国国际广播电台","title":"特朗普结束访华夸赞经济成果 台湾问题中美似仍“各表”","content":"周五，美国总统唐纳德·特朗普和中国国家主席习近平共进茶点和午餐，给两天的峰会画上句号。特朗普离开北京时夸赞他与中国达成了经济成果，避免回答台湾问题，但卢比奥向媒体表示：美国的对台政策“迄今未变”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260515-%E7%89%B9%E6%9C%97%E6%99%AE%E7%BB%93%E6%9D%9F%E8%AE%BF%E5%8D%8E%E5%A4%B8%E8%B5%9E%E7%BB%8F%E6%B5%8E%E6%88%90%E6%9E%9C-%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98%E4%B8%AD%E7%BE%8E%E4%BC%BC%E4%BB%8D-%E5%90%84%E8%A1%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778833480000.webp","sourceId":"rfi"},{"id":1778828347000,"createdDate":"2026-05-15 06:59","name":"法国国际广播电台","title":"日本大臣在高市首相有关“台湾有事”答辩后首次访华","content":"日本内阁府14日宣布，男女共同参画担当大臣黄川田仁志已确定于14日至15日访问中国上海，并已于14日晚出发前往上海，出席亚太经合组织（APEC）部长级会议。自高市早苗去年11月在国会就“台湾有事”作出国会答辩以来，这是日本阁僚首次访华。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260515-%E6%97%A5%E6%9C%AC%E5%A4%A7%E8%87%A3%E5%9C%A8%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E6%9C%89%E5%85%B3-%E5%8F%B0%E6%B9%BE%E6%9C%89%E4%BA%8B-%E7%AD%94%E8%BE%A9%E5%90%8E%E9%A6%96%E6%AC%A1%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778828347000.webp","sourceId":"rfi"},{"id":1778828026000,"createdDate":"2026-05-15 06:53","name":"法国国际广播电台","title":"盘点「特习会」：两国中途休战但不离擂台 为稳定冷处理台湾丶黎智英等敏感问题","content":"全球瞩目的「特习会」，中美元首表明有就重大问题交换意见，但会后双方未有发布共同声明，台湾问题似是各自表述，美方「提及」而并非要求释放黎智英等人则未见中方回应。学者和专家向法广分析指，这次中美元首会面最大的作用，是缓和两国一度紧张的关系，双方强调的稳定关系，更像是拳赛选手的中途休战，不代表中美竞争互斗的格局有重大改变。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260515-%E7%9B%98%E7%82%B9-%E7%89%B9%E4%B9%A0%E4%BC%9A-%E4%B8%A4%E5%9B%BD%E4%B8%AD%E9%80%94%E4%BC%91%E6%88%98%E4%BD%86%E4%B8%8D%E7%A6%BB%E6%93%82%E5%8F%B0-%E4%B8%BA%E7%A8%B3%E5%AE%9A%E5%86%B7%E5%A4%84%E7%90%86%E5%8F%B0%E6%B9%BE%E4%B8%B6%E9%BB%8E%E6%99%BA%E8%8B%B1%E7%AD%89%E6%95%8F%E6%84%9F%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/15/1778828026000.webp","sourceId":"rfi"}]