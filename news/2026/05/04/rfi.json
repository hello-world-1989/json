[{"id":1777880915000,"createdDate":"2026-05-04 07:48","name":"法国国际广播电台","title":"港记协：税局追税独立媒体并非正常抽查 有损新闻自由","content":"香港小型媒体体和独立记者被税务局查税的情况持续，该地工会认为，税局审查媒体显然并非随机抽查，因为被重新评核的独立媒体及记者数量不成比例地高，而收回的补交税款亦微不足道丶甚至是零，但该等小型机构已因此付出数以万元的行政费和承受巨大精神压力。工会指出，以行政手段对媒体造成过度负担的不良营运环境亦会实质伤害新闻自由。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260504-%E6%B8%AF%E8%AE%B0%E5%8D%8F-%E7%A8%8E%E5%B1%80%E8%BF%BD%E7%A8%8E%E7%8B%AC%E7%AB%8B%E5%AA%92%E4%BD%93%E5%B9%B6%E9%9D%9E%E6%AD%A3%E5%B8%B8%E6%8A%BD%E6%9F%A5-%E6%9C%89%E6%8D%9F%E6%96%B0%E9%97%BB%E8%87%AA%E7%94%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777880915000.webp","sourceId":"rfi"},{"id":1777878129000,"createdDate":"2026-05-04 07:02","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第24：浪漫主义群星之五：海涅第一节：浪漫派的叛逆","content":"在中国大陆，浪漫派群星中名声最响的人是海涅。他的诗《罗蕾莱》、《乘着歌声的翅膀》、《莲花》、《你好像一朵鲜花》等等，被门德尔松、舒曼、李斯特等大音乐家谱曲，不仅在世界传唱，甚至在中国文革前和文革中，就凭借《外国民歌二百首》这部歌曲集的流传为许多人熟悉，喜爱。但在浪漫派家族中，海涅的地位相当特殊，他是以一个叛逆者的身份出现的。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260504-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%BA%94-%E6%B5%B7%E6%B6%85%E7%AC%AC%E4%B8%80%E8%8A%82-%E6%B5%AA%E6%BC%AB%E6%B4%BE%E7%9A%84%E5%8F%9B%E9%80%86","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777878129000.webp","sourceId":"rfi"},{"id":1777912942000,"createdDate":"2026-05-04 16:42","name":"法国国际广播电台","title":"美财长促中国施压伊朗重开霍尔木兹海峡","content":"美国财政部长斯科特·贝森特（ScottBessent）4日公开呼吁中国加强外交斡旋，敦促伊朗重新开放全球能源运输要道霍尔木兹海峡，并表示相关议题，将在美国总统唐纳德·特朗普（DonaldTrump）与中国国家主席习近平下周会晤时，成为重点讨论内容。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260504-%E7%BE%8E%E8%B4%A2%E9%95%BF%E4%BF%83%E4%B8%AD%E5%9B%BD%E6%96%BD%E5%8E%8B%E4%BC%8A%E6%9C%97%E9%87%8D%E5%BC%80%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777912942000.webp","sourceId":"rfi"},{"id":1777907849000,"createdDate":"2026-05-04 15:17","name":"法国国际广播电台","title":"日本和印尼签署扩大防务合作协议 高市谈放宽武器出口：对地区和平至关重要","content":"印尼方面表示，印尼和日本两国防长周一签署了一项合作协议，强调在全球动荡的背景下，维护地区和平与稳定至关重要。此次协议签署正值日本防卫大臣小泉进次郎访问雅加达期间。此前，日本政府今年4月放宽了长达数十年的武器出口限制，允许企业向与日本签署防卫协定的17个国家中的任何一个出售致命性武器。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260504-%E6%97%A5%E6%9C%AC%E5%92%8C%E5%8D%B0%E5%B0%BC%E7%AD%BE%E7%BD%B2%E6%89%A9%E5%A4%A7%E9%98%B2%E5%8A%A1%E5%90%88%E4%BD%9C%E5%8D%8F%E8%AE%AE-%E9%AB%98%E5%B8%82%E8%B0%88%E6%94%BE%E5%AE%BD%E6%AD%A6%E5%99%A8%E5%87%BA%E5%8F%A3-%E5%AF%B9%E5%9C%B0%E5%8C%BA%E5%92%8C%E5%B9%B3%E8%87%B3%E5%85%B3%E9%87%8D%E8%A6%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777907849000.webp","sourceId":"rfi"},{"id":1777904310000,"createdDate":"2026-05-04 14:18","name":"法国国际广播电台","title":"两艘悬挂美国旗的商船穿过霍尔木兹海峡 美军被授权打击船只所面临直接威胁","content":"美国中央司令部周一通过声明表示，两艘悬挂美国国旗的商船在美国海军的协助下，驶出波斯湾，穿过霍尔木兹海峡。这是自美军于当天上午启动“自由行动”——旨在引导船只通过霍尔木兹海峡以来——首批通过该海峡的两艘船只。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260504-%E4%B8%A4%E8%89%98%E6%82%AC%E6%8C%82%E7%BE%8E%E5%9B%BD%E6%97%97%E7%9A%84%E5%95%86%E8%88%B9%E7%A9%BF%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E7%BE%8E%E5%86%9B%E8%A2%AB%E6%8E%88%E6%9D%83%E6%89%93%E5%87%BB%E8%88%B9%E5%8F%AA%E6%89%80%E9%9D%A2%E4%B8%B4%E7%9B%B4%E6%8E%A5%E5%A8%81%E8%83%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777904310000.webp","sourceId":"rfi"},{"id":1777904047000,"createdDate":"2026-05-04 14:14","name":"法国国际广播电台","title":"美军启动霍尔木兹海峡护航：打破封锁的开始还是战火重启的引线？","content":"美国总统特朗普日前通过其社交媒体平台宣布，美国海军自5月4日周一起，启动一项名为自由方案的行动，帮助因中东战争受困的第三国货船通过霍尔木兹海峡。伊朗方面随即发出警告，称美军对当前海峡通航现状的任何干预行动都将被视作违反停火协议的作为。如今陷于来自伊朗和美国的双向封锁的霍尔木兹海峡正迎来重新开启的希望？还是已经持续近四周的美伊停火可能因解锁海峡的行动而破产，令战火再起？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260504-%E7%BE%8E%E5%86%9B%E5%90%AF%E5%8A%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%8A%A4%E8%88%AA-%E6%89%93%E7%A0%B4%E5%B0%81%E9%94%81%E7%9A%84%E5%BC%80%E5%A7%8B%E8%BF%98%E6%98%AF%E6%88%98%E7%81%AB%E9%87%8D%E5%90%AF%E7%9A%84%E5%BC%95%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777904047000.webp","sourceId":"rfi"},{"id":1777903768000,"createdDate":"2026-05-04 14:09","name":"法国国际广播电台","title":"欧盟不再补贴如逆变器等中国技术生产的产品","content":"欧盟今天周一宣布将不再补贴某些能源项目，因为这些项目使用一些中国技术可能对欧洲电网运行构成风险。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260504-%E6%AC%A7%E7%9B%9F%E4%B8%8D%E5%86%8D%E8%A1%A5%E8%B4%B4%E5%A6%82%E9%80%86%E5%8F%98%E5%99%A8%E7%AD%89%E4%B8%AD%E5%9B%BD%E6%8A%80%E6%9C%AF%E7%94%9F%E4%BA%A7%E7%9A%84%E4%BA%A7%E5%93%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777903768000.webp","sourceId":"rfi"},{"id":1777901991000,"createdDate":"2026-05-04 13:39","name":"法国国际广播电台","title":"赖清德离开斯威士兰启程返台 消息人士：搭国王专机离开","content":"法新社报导指，据机场消息人士称，台湾总统赖清德周一离开斯威士兰（台称史瓦帝尼），结束了对台湾在非洲唯一邦交国的访问。一位不愿透露姓名的斯威士兰主要机场消息人士称，“他（赖清德）今天早上乘坐国王的专机离开”，并指“他离开期间的安排一直很低调”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260504-%E8%B5%96%E6%B8%85%E5%BE%B7%E7%A6%BB%E5%BC%80%E6%96%AF%E5%A8%81%E5%A3%AB%E5%85%B0%E5%90%AF%E7%A8%8B%E8%BF%94%E5%8F%B0-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB-%E6%90%AD%E5%9B%BD%E7%8E%8B%E4%B8%93%E6%9C%BA%E7%A6%BB%E5%BC%80","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777901991000.webp","sourceId":"rfi"},{"id":1777900224000,"createdDate":"2026-05-04 13:10","name":"法国国际广播电台","title":"高市首相访问越南和澳大利亚 加强稀土供应链是重要课题","content":"高市首相于5月1日起访问越南和澳大利亚，日本时间2日下午，高市首相在河内与越南总理黎明兴及越南国家主席苏林举行首脑会谈，关于关键矿产，双方一致同意，就强化包括越南稀土在内的重要矿产供应链开展合作。高市首相3日开始访问澳大利亚，配合这次访问，日澳两国政府已于5月1日决定，将稀土和镍等6个开发项目指定为优先项目，双方正加快推进对华依赖度较高的稀土等重要物资供应链的多元化。越南和澳大利亚两国均有扩大稀土生产的意向，同时两国均拥有世界领先的稀土储量。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260504-%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E8%AE%BF%E9%97%AE%E8%B6%8A%E5%8D%97%E5%92%8C%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A-%E5%8A%A0%E5%BC%BA%E7%A8%80%E5%9C%9F%E4%BE%9B%E5%BA%94%E9%93%BE%E6%98%AF%E9%87%8D%E8%A6%81%E8%AF%BE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777900224000.webp","sourceId":"rfi"},{"id":1777900059000,"createdDate":"2026-05-04 13:07","name":"法国国际广播电台","title":"约百艘中国渔船聚集韩国东部海域 韩海警加强监视力度","content":"据韩国江原道东海海洋警察署周一消息，截至本月，已确认约有100艘中国渔船在韩国东部北方界线（NLL）附近海域聚集，韩国海警已部署1艘大型舰艇以加强监视和管控力度。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260504-%E7%BA%A6%E7%99%BE%E8%89%98%E4%B8%AD%E5%9B%BD%E6%B8%94%E8%88%B9%E8%81%9A%E9%9B%86%E9%9F%A9%E5%9B%BD%E4%B8%9C%E9%83%A8%E6%B5%B7%E5%9F%9F-%E9%9F%A9%E6%B5%B7%E8%AD%A6%E5%8A%A0%E5%BC%BA%E7%9B%91%E8%A7%86%E5%8A%9B%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777900059000.webp","sourceId":"rfi"},{"id":1777896738000,"createdDate":"2026-05-04 12:12","name":"法国国际广播电台","title":"日本大学中国巡回教育展被延期 相关人士称因“受当局施压”","content":"据《朝日新闻》报导，原定于4月中旬在上海等中国城市举行的赴日留学推广活动在最后一刻被延期。多位消息人士证实，延期是由于“当局施压”。自日本首相高市早苗就潜在“台湾有事”在国会发表相关答询已接近半年，日中关系依旧严峻。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260504-%E6%97%A5%E6%9C%AC%E5%A4%A7%E5%AD%A6%E4%B8%AD%E5%9B%BD%E5%B7%A1%E5%9B%9E%E6%95%99%E8%82%B2%E5%B1%95%E8%A2%AB%E5%BB%B6%E6%9C%9F-%E7%9B%B8%E5%85%B3%E4%BA%BA%E5%A3%AB%E7%A7%B0%E5%9B%A0-%E5%8F%97%E5%BD%93%E5%B1%80%E6%96%BD%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777896738000.webp","sourceId":"rfi"},{"id":1777896136000,"createdDate":"2026-05-04 12:02","name":"法国国际广播电台","title":"欧洲数十国领导人齐聚亚美尼亚出席欧洲政治共同体峰会","content":"中亚国家亚美尼亚5月4日成为欧洲大陆在当今动荡国际关系格局中重建友邦关系的舞台。欧洲大陆数十个国家的领导人或代表今明两天在亚美尼亚首都出席第八届欧洲政治共同体峰会。无论是主办国的地理位置，还是地处北美的加拿大也应邀出席，都使得这次峰会具有不同寻常的意义。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260504-%E6%AC%A7%E6%B4%B2%E6%95%B0%E5%8D%81%E5%9B%BD%E9%A2%86%E5%AF%BC%E4%BA%BA%E9%BD%90%E8%81%9A%E4%BA%9A%E7%BE%8E%E5%B0%BC%E4%BA%9A%E5%87%BA%E5%B8%AD%E6%AC%A7%E6%B4%B2%E6%94%BF%E6%B2%BB%E5%85%B1%E5%90%8C%E4%BD%93%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777896136000.webp","sourceId":"rfi"},{"id":1777894669000,"createdDate":"2026-05-04 11:37","name":"法国国际广播电台","title":"欧委会建议成员国不要在电信基础设施中使用华为中兴设备","content":"欧盟委员会的一位发言人周一表示，欧盟委员会已建议成员国将华为和中兴的设备排除在当地电信运营商的连接基础设施之外。该发言人在布鲁塞尔举行的新闻发布会上告诉记者，正在审议通过的新网络安全规则将赋予欧盟禁止在欧盟市场使用“高风险”供应商设备的权力。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260504-%E6%AC%A7%E5%A7%94%E4%BC%9A%E5%BB%BA%E8%AE%AE%E6%88%90%E5%91%98%E5%9B%BD%E4%B8%8D%E8%A6%81%E5%9C%A8%E7%94%B5%E4%BF%A1%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD%E4%B8%AD%E4%BD%BF%E7%94%A8%E5%8D%8E%E4%B8%BA%E4%B8%AD%E5%85%B4%E8%AE%BE%E5%A4%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777894669000.webp","sourceId":"rfi"},{"id":1777891824000,"createdDate":"2026-05-04 10:50","name":"法国国际广播电台","title":"赖清德外交突围出访斯威士兰 竭力证明不会任凭北京封杀台湾国际能见度","content":"台湾总统赖清德5月2日表示已达斯威士兰进行国是访问。中国国台办回应，赖总统上演「偷渡式」外窜闹剧，如同过街老鼠必为国际社会所耻笑。民进党则表示，国际媒体多给予肯定报导。美国务院也强调，台湾出访友邦不应被政治化。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260504-%E8%B5%96%E6%B8%85%E5%BE%B7%E5%A4%96%E4%BA%A4%E7%AA%81%E5%9B%B4%E5%87%BA%E8%AE%BF%E6%96%AF%E5%A8%81%E5%A3%AB%E5%85%B0-%E7%AB%AD%E5%8A%9B%E8%AF%81%E6%98%8E%E4%B8%8D%E4%BC%9A%E4%BB%BB%E5%87%AD%E5%8C%97%E4%BA%AC%E5%B0%81%E6%9D%80%E5%8F%B0%E6%B9%BE%E5%9B%BD%E9%99%85%E8%83%BD%E8%A7%81%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777891824000.webp","sourceId":"rfi"},{"id":1777891227000,"createdDate":"2026-05-04 10:40","name":"法国国际广播电台","title":"涉嫌持伪造文件、违反适航法 瑞典逮捕一艘俄影子舰队油轮的中国籍船长","content":"瑞典一名检察官周一表示，一艘被扣押的油轮的中国籍船长已被逮捕，他涉嫌持有伪造文件并违反适航法。这艘油轮据信隶属于俄罗斯“影子舰队”。周日，瑞典海岸警卫队和警方在该国领海内登船检查了悬挂叙利亚国旗的“金辉”号（JinHui、音译）油轮。高级检察官孔比尔-霍格（AdrienCombier-Hogg）在声明中称，这位未被点名的中国籍船长将于周一接受讯问。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260504-%E6%B6%89%E5%AB%8C%E6%8C%81%E6%9C%89%E4%BC%AA%E9%80%A0%E6%96%87%E4%BB%B6-%E8%BF%9D%E5%8F%8D%E9%80%82%E8%88%AA%E6%B3%95-%E7%91%9E%E5%85%B8%E9%80%AE%E6%8D%95%E4%B8%80%E8%89%98%E4%BF%84%E5%BD%B1%E5%AD%90%E8%88%B0%E9%98%9F%E6%B2%B9%E8%BD%AE%E7%9A%84%E4%B8%AD%E5%9B%BD%E7%B1%8D%E8%88%B9%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777891227000.webp","sourceId":"rfi"},{"id":1777891225000,"createdDate":"2026-05-04 10:40","name":"法国国际广播电台","title":"日本首相与澳大利亚总理举行会谈并发表联合声明  强调共建稀土产业链","content":"当地时间5月4日上午11时15分（日本时间上午10时15分）起约1小时20分钟，正在访问澳大利亚堪培拉的日本首相高市早苗与澳大利亚联邦总理阿尔巴尼斯举行了日澳首脑会谈，随后举行了《关于经济安全保障合作的日澳联合宣言》签字仪式。此外，首脑会谈开始时约30分钟进行了小范围会谈，这次访问，两国首脑重点讨论了关键矿产与能源安全保障方面的合作。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260504-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E4%B8%8E%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E6%80%BB%E7%90%86%E4%B8%BE%E8%A1%8C%E4%BC%9A%E8%B0%88%E5%B9%B6%E5%8F%91%E8%A1%A8%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E-%E5%BC%BA%E8%B0%83%E5%85%B1%E5%BB%BA%E7%A8%80%E5%9C%9F%E4%BA%A7%E4%B8%9A%E9%93%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777891225000.webp","sourceId":"rfi"},{"id":1777889946000,"createdDate":"2026-05-04 10:19","name":"法国国际广播电台","title":"俄当局加强对普京及周围人安保措施 重点防范无人机暗杀企图","content":"由于俄总统普京日益孤立，且全身心投入乌克兰战争，俄罗斯当局加强了对他的安保措施，以防其遭到暗杀。近几个月来，负责保护高官的俄罗斯联邦警卫局（FSO）已大幅加强了对普京的安保。英国《金融时报》报导称，据莫斯科了解他的知情人士和一位接近欧洲情报机构的人透露，普京现在更多地待在地下掩体中，事无巨细地指挥战争，与民政事务的联系也越来越少。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260504-%E4%BF%84%E5%BD%93%E5%B1%80%E5%8A%A0%E5%BC%BA%E5%AF%B9%E6%99%AE%E4%BA%AC%E5%8F%8A%E5%91%A8%E5%9B%B4%E4%BA%BA%E5%AE%89%E4%BF%9D%E6%8E%AA%E6%96%BD-%E9%87%8D%E7%82%B9%E9%98%B2%E8%8C%83%E6%97%A0%E4%BA%BA%E6%9C%BA%E6%9A%97%E6%9D%80%E4%BC%81%E5%9B%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777889946000.webp","sourceId":"rfi"},{"id":1777887862000,"createdDate":"2026-05-04 09:44","name":"法国国际广播电台","title":"前纽约市长朱利安尼病重住院  特朗普称之为真正的斗士","content":"朱利安尼病重住院的消息是他的发言人是在X平台推文宣布的，据法新社报道，发言人的帖子称“朱利安尼市长不仅是一位斗士，他一生中面对每一个挑战都展现出坚定不移的韧性，此刻他正以同样的韧性与病魔抗争”。但发言人没有透露这位81岁的前政界人士具体患了什么病，以及在何处接受治疗或住院多久，但他呼吁大家“一起为‘美国市长’鲁迪·朱利安尼祈祷”。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260504-%E5%89%8D%E7%BA%BD%E7%BA%A6%E5%B8%82%E9%95%BF%E6%9C%B1%E5%88%A9%E5%AE%89%E5%B0%BC%E7%97%85%E9%87%8D%E4%BD%8F%E9%99%A2-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E4%B9%8B%E4%B8%BA%E7%9C%9F%E6%AD%A3%E7%9A%84%E6%96%97%E5%A3%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777887862000.webp","sourceId":"rfi"},{"id":1777887035000,"createdDate":"2026-05-04 09:30","name":"法国国际广播电台","title":"北京首发阻断禁令抗美制裁后 华盛顿是否会二级制裁银行等受关注","content":"中国商务部周六发布禁令，不得承认、不得执行、不得遵守美国以参与伊朗石油交易为由，对恒力石化（大连）炼化有限公司（以下简称恒力）等五家中企采取的列入“特别指定国民清单”、实施冻结资产和禁止交易等制裁措施。这一史无前例的对抗行为有可能使庞大的银行业陷入制裁战漩涡，而此时世界两大经济体之间的紧张局势正在加剧。北京经常抨击华盛顿的单边制裁，并称其不合法，但为了避免对自身经济造成冲击并维持与美国金融体系的联系，中方也一直悄悄允许其最大的企业遵守美方制裁。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260504-%E5%8C%97%E4%BA%AC%E9%A6%96%E5%8F%91%E9%98%BB%E6%96%AD%E7%A6%81%E4%BB%A4%E6%8A%97%E7%BE%8E%E5%88%B6%E8%A3%81%E5%90%8E-%E5%8D%8E%E7%9B%9B%E9%A1%BF%E6%98%AF%E5%90%A6%E4%BC%9A%E4%BA%8C%E7%BA%A7%E5%88%B6%E8%A3%81%E9%93%B6%E8%A1%8C%E7%AD%89%E5%8F%97%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777887035000.webp","sourceId":"rfi"},{"id":1777936372000,"createdDate":"2026-05-04 23:12","name":"法国国际广播电台","title":"疑似汉他病毒感染：邮轮或将在加那利群岛靠港","content":"一艘航行于大西洋的邮轮爆发汉他病毒感染，已造成3人死亡。根据法国媒体的报道，荷兰方面正在研究“对部分人员进行疏散以便送医治疗的可能性”，邮轮或将在加那利群岛靠港。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260504-%E7%96%91%E4%BC%BC%E6%B1%89%E4%BB%96%E7%97%85%E6%AF%92%E6%84%9F%E6%9F%93-%E9%82%AE%E8%BD%AE%E6%88%96%E5%B0%86%E5%9C%A8%E5%8A%A0%E9%82%A3%E5%88%A9%E7%BE%A4%E5%B2%9B%E9%9D%A0%E6%B8%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777936372000.webp","sourceId":"rfi"},{"id":1777936154000,"createdDate":"2026-05-04 23:09","name":"法国国际广播电台","title":"北京打压赖清德出访，在某种程度上反而“帮了台湾一把”","content":"法国世界报还指出，赖清德的此次访问如果最初没有被阻止的话，可能并不会引起太多的关注；此次风波反而凸显了北京如何持续压缩台湾的国际空间，从而在某种程度上“帮了台湾一把”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260504-%E5%8C%97%E4%BA%AC%E6%89%93%E5%8E%8B%E8%B5%96%E6%B8%85%E5%BE%B7%E5%87%BA%E8%AE%BF%EF%BC%8C%E5%9C%A8%E6%9F%90%E7%A7%8D%E7%A8%8B%E5%BA%A6%E4%B8%8A%E5%8F%8D%E8%80%8C-%E5%B8%AE%E4%BA%86%E5%8F%B0%E6%B9%BE%E4%B8%80%E6%8A%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777936154000.webp","sourceId":"rfi"},{"id":1777928682000,"createdDate":"2026-05-04 21:04","name":"法国国际广播电台","title":"美军说摧毁了六艘伊朗船只   伊朗矢口否认","content":"美国军方一位高级官员周一表示，美军摧毁了六艘伊朗船只，并拦截了伊朗向美国海军舰艇和商船发射的导弹和无人机。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260504-%E7%BE%8E%E5%86%9B%E8%AF%B4%E6%91%A7%E6%AF%81%E4%BA%86%E5%85%AD%E8%89%98%E4%BC%8A%E6%9C%97%E8%88%B9%E5%8F%AA-%E4%BC%8A%E6%9C%97%E7%9F%A2%E5%8F%A3%E5%90%A6%E8%AE%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777928682000.webp","sourceId":"rfi"},{"id":1777928332000,"createdDate":"2026-05-04 20:58","name":"法国国际广播电台","title":"俄乌在告知对方停火日期上唱对台戏","content":"俄罗斯国防部周一宣布，为纪念1945年苏联战胜纳粹德国，俄军将于5月8日至9日单方面与乌克兰停火。俄新社报道说，俄罗斯普京决定宣布在即将到来的卫国战争胜利日期间实施停火，停火将于5月8日至5月9日生效。而泽连斯基宣布，乌克兰将在5月5日和6日遵守与俄罗斯达成的停火协议。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260504-%E4%BF%84%E4%B9%8C%E5%9C%A8%E5%91%8A%E7%9F%A5%E5%AF%B9%E6%96%B9%E5%81%9C%E7%81%AB%E6%97%A5%E6%9C%9F%E4%B8%8A%E5%94%B1%E5%AF%B9%E5%8F%B0%E6%88%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777928332000.webp","sourceId":"rfi"},{"id":1777927923000,"createdDate":"2026-05-04 20:52","name":"法国国际广播电台","title":"华裔女导演赵婷入戛纳电影节评委会","content":"第79届戛纳国际电影节将于2026年5月12日-23日举行。评委中有美国女演员黛米·摩尔（DemiMoore）以及获得过奥斯卡最佳女导演奖的华裔女导演赵婷（ChloeZhao)。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260504-%E5%8D%8E%E8%A3%94%E5%A5%B3%E5%AF%BC%E6%BC%94%E8%B5%B5%E5%A9%B7%E5%85%A5%E6%88%9B%E7%BA%B3%E7%94%B5%E5%BD%B1%E8%8A%82%E8%AF%84%E5%A7%94%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777927923000.webp","sourceId":"rfi"},{"id":1777927048000,"createdDate":"2026-05-04 20:37","name":"法国国际广播电台","title":"“时尚界奥斯卡”年度盛会拉开帷幕","content":"“时尚是一门艺术”：这是电影、音乐、体育以及时尚界的明星们必须展现的，他们将参加周一在纽约举行的盛大年度MetGala（大都会艺术博物馆慈善晚宴）。美国女歌手、词曲作家、音乐制作人、舞者及演员碧昂丝（Beyoncé）尤其备受瞩目，她将时隔十年重返MetGala，与网球传奇人物维纳斯·威廉姆斯（VenusWilliams）和奥斯卡影后妮可·基德曼（NicoleKidman）共同担任联合主席。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260504-%E6%97%B6%E5%B0%9A%E7%95%8C%E5%A5%A5%E6%96%AF%E5%8D%A1-%E5%B9%B4%E5%BA%A6%E7%9B%9B%E4%BC%9A%E6%8B%89%E5%BC%80%E5%B8%B7%E5%B9%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777927048000.webp","sourceId":"rfi"},{"id":1777926772000,"createdDate":"2026-05-04 20:32","name":"法国国际广播电台","title":"阿联酋不停课   但采取远程教育方式","content":"阿拉伯联合酋长国宣布，该国遭到伊朗无人机和导弹袭击，富查伊拉的一处石油设施起火。为了应对这种极端情况，教育部表示，所有的学校都采取远程教育的方式。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260504-%E9%98%BF%E8%81%94%E9%85%8B%E4%B8%8D%E5%81%9C%E8%AF%BE-%E4%BD%86%E9%87%87%E5%8F%96%E8%BF%9C%E7%A8%8B%E6%95%99%E8%82%B2%E6%96%B9%E5%BC%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777926772000.webp","sourceId":"rfi"},{"id":1777926539000,"createdDate":"2026-05-04 20:28","name":"法国国际广播电台","title":"伊朗电视台：并未袭击阿联酋富查伊拉石油设施","content":"伊朗国家电视台周一援引一位不愿透露姓名的高级官员的话称，伊朗并没有袭击阿联酋富查伊拉重要石油设施的“计划”。这位官员将当天的袭击归咎于美国的“军事冒险主义”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260504-%E4%BC%8A%E6%9C%97%E7%94%B5%E8%A7%86%E5%8F%B0-%E5%B9%B6%E6%9C%AA%E8%A2%AD%E5%87%BB%E9%98%BF%E8%81%94%E9%85%8B%E5%AF%8C%E6%9F%A5%E4%BC%8A%E6%8B%89%E7%9F%B3%E6%B2%B9%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777926539000.webp","sourceId":"rfi"},{"id":1777926157000,"createdDate":"2026-05-04 20:22","name":"法国国际广播电台","title":"ArcelorMittal 为特朗普新宴会厅建设先提供“约600吨钢材”","content":"据法新社周一采访法一位知情人士透露，安赛乐米塔尔（ArcelorMittal）已为特朗普设想的白宫宴会厅建设提供了“约600吨钢材”，而该项目实际所需钢材量可能高达目前数量的五倍。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260504-arcelormittal-%E4%B8%BA%E7%89%B9%E6%9C%97%E6%99%AE%E6%96%B0%E5%AE%B4%E4%BC%9A%E5%8E%85%E5%BB%BA%E8%AE%BE%E5%85%88%E6%8F%90%E4%BE%9B-%E7%BA%A6600%E5%90%A8%E9%92%A2%E6%9D%90","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777926157000.webp","sourceId":"rfi"},{"id":1777922180000,"createdDate":"2026-05-04 19:16","name":"法国国际广播电台","title":"民调：61%受访美国人认为对伊朗用兵是个错误","content":"最新民调显示，美国总统特朗普发动伊朗战争的不受欢迎程度，已与越战到1970年代初期及2006年伊拉克战争最惨烈时期相当。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260504-%E6%9C%80%E6%96%B0%E6%B0%91%E8%B0%83-61-%E5%8F%97%E8%AE%BF%E7%BE%8E%E5%9B%BD%E4%BA%BA%E8%AE%A4%E4%B8%BA%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%94%A8%E5%85%B5%E6%98%AF%E4%B8%AA%E9%94%99%E8%AF%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777922180000.webp","sourceId":"rfi"},{"id":1777921503000,"createdDate":"2026-05-04 19:05","name":"法国国际广播电台","title":"非洲:UNICEF为苏丹儿童拉响警报","content":"在苏丹西部地区爆发首次致命冲突二十年后，在没有受到特别关注的大背景下，这个国家在过去三年里再次陷入战争，而且惨烈的程度更甚。尤其是儿童首当其冲，名列首要受害人。就此，联合国儿童基金会（UNICEF）刚刚拉响了红色警报。这是本台法广（RFI）非洲组2026年05月04日星期一上网的最新法文消息之一。联合国儿童基金会表示，苏丹达尔富尔地区有500万儿童处于物资的极度匮乏。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260504-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-unicef%E4%B8%BA%E8%8B%8F%E4%B8%B9%E5%84%BF%E7%AB%A5%E6%8B%89%E5%93%8D%E8%AD%A6%E6%8A%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777921503000.webp","sourceId":"rfi"},{"id":1777919551000,"createdDate":"2026-05-04 18:32","name":"法国国际广播电台","title":"美军要撤离？德国总理和北约秘书长如何阐释自己的立场","content":"北约组织（NATO）秘书长吕特（MarkRutte）5月4日表示，欧洲各国已“明白”美国总统特朗普传达的讯息，正在确保有关军事基地使用的协议得到落实。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260504-%E7%BE%8E%E5%86%9B%E8%A6%81%E6%92%A4%E7%A6%BB-%E5%BE%B7%E5%9B%BD%E6%80%BB%E7%90%86%E5%92%8C%E5%8C%97%E7%BA%A6%E7%A7%98%E4%B9%A6%E9%95%BF%E5%A6%82%E4%BD%95%E9%98%90%E9%87%8A%E8%87%AA%E5%B7%B1%E7%9A%84%E7%AB%8B%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777919551000.webp","sourceId":"rfi"},{"id":1777916396000,"createdDate":"2026-05-04 17:39","name":"法国国际广播电台","title":"德国：一辆汽车在莱比锡步行区冲入人群  2死   多人受伤","content":"5月4日，德国莱比锡市（Leipzig）中心发生一起车辆冲撞行人事件，造成两人死亡，多人受伤。警方宣布逮捕肇事司机，但并未解释他作案的动机。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260504-%E5%BE%B7%E5%9B%BD-%E4%B8%80%E8%BE%86%E6%B1%BD%E8%BD%A6%E5%9C%A8%E8%8E%B1%E6%AF%94%E9%94%A1%E6%AD%A5%E8%A1%8C%E5%8C%BA%E5%86%B2%E5%85%A5%E4%BA%BA%E7%BE%A4-2%E6%AD%BB-%E5%A4%9A%E4%BA%BA%E5%8F%97%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/04/1777916396000.webp","sourceId":"rfi"}]