[{"id":1778492575000,"createdDate":"2026-05-11 09:42","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第24：浪漫主义群星之五：海涅第二节：从浪漫派阵营内投出的匕首","content":"海涅是奥古斯特·施勒格尔的学生，实际上，作为浪漫派领军人物，是他教给了海涅浪漫主义的基本理念和诉求。但后来海涅对浪漫主义的分析批判竟多是对准施勒格尔的。这既有文学理念不同，也有政治上的原因。因为海涅是拿破仑的崇拜者，奥·施勒格尔则是斯塔尔夫人的忠实伴侣。斯塔尔夫人恰是拿破仑的死敌。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260511-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%BA%94-%E6%B5%B7%E6%B6%85%E7%AC%AC%E4%BA%8C%E8%8A%82-%E4%BB%8E%E6%B5%AA%E6%BC%AB%E6%B4%BE%E9%98%B5%E8%90%A5%E5%86%85%E6%8A%95%E5%87%BA%E7%9A%84%E5%8C%95%E9%A6%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778492575000.webp","sourceId":"rfi"},{"id":1778489675000,"createdDate":"2026-05-11 08:54","name":"法国国际广播电台","title":"特朗普访华行程披露 北京：双方将就中美关系及世界和平发展交换意见","content":"中国外交部发言人周一通过声明宣布，应国家主席习近平邀请，美国总统特朗普（DonaldTrump）将于5月13日至15日对中国进行国事访问。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260511-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E8%A1%8C%E7%A8%8B%E6%8A%AB%E9%9C%B2-%E5%8C%97%E4%BA%AC-%E5%8F%8C%E6%96%B9%E5%B0%86%E5%B0%B1%E4%B8%AD%E7%BE%8E%E5%85%B3%E7%B3%BB%E5%8F%8A%E4%B8%96%E7%95%8C%E5%92%8C%E5%B9%B3%E5%8F%91%E5%B1%95%E4%BA%A4%E6%8D%A2%E6%84%8F%E8%A7%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778489675000.webp","sourceId":"rfi"},{"id":1778488997000,"createdDate":"2026-05-11 08:43","name":"法国国际广播电台","title":"美方对台湾国防预算感到失望 在野蓝白砍掉关键军购战力无人机与AI辅助系统","content":"台湾通过国防特别条例7800亿新台币，与原先1.25兆元约有4700亿的差距。对此，美国高层官员表示感到失望。民进党则批评，关键军购战力，如无人机、AI辅助系统与台湾国防自主产业等都被排除在外。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260511-%E7%BE%8E%E6%96%B9%E5%AF%B9%E5%8F%B0%E6%B9%BE%E5%9B%BD%E9%98%B2%E9%A2%84%E7%AE%97%E6%84%9F%E5%88%B0%E5%A4%B1%E6%9C%9B-%E5%9C%A8%E9%87%8E%E8%93%9D%E7%99%BD%E7%A0%8D%E6%8E%89%E5%85%B3%E9%94%AE%E5%86%9B%E8%B4%AD%E6%88%98%E5%8A%9B%E6%97%A0%E4%BA%BA%E6%9C%BA%E4%B8%8Eai%E8%BE%85%E5%8A%A9%E7%B3%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778488997000.webp","sourceId":"rfi"},{"id":1778488394000,"createdDate":"2026-05-11 08:33","name":"法国国际广播电台","title":"从发生汉坦病毒感染的邮轮下船的日本公民到达英国","content":"5月11日（当地时间10日），在西班牙加那利群岛，一名从发生汉坦病毒感染的邮轮“洪迪乌斯号（Hondius）”下船的日本公民，获得英国政府安排的包机空余座位，已抵达英国。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260511-%E4%BB%8E%E5%8F%91%E7%94%9F%E6%B1%89%E5%9D%A6%E7%97%85%E6%AF%92%E6%84%9F%E6%9F%93%E7%9A%84%E9%82%AE%E8%BD%AE%E4%B8%8B%E8%88%B9%E7%9A%84%E6%97%A5%E6%9C%AC%E5%85%AC%E6%B0%91%E5%88%B0%E8%BE%BE%E8%8B%B1%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778488394000.webp","sourceId":"rfi"},{"id":1778487374000,"createdDate":"2026-05-11 08:16","name":"法国国际广播电台","title":"马克龙：欧洲和中国不一样，不是本世纪在非洲的掠夺者","content":"法国总统马克龙于周一（5月11日）在肯尼亚主持召开法非峰会。周日出发前，他在接受法国媒体JeuneAfrique和TheAfricaReport采访时为欧洲辩护，称“欧洲人并不是这个世纪在非洲的掠夺者”，他还特别将欧洲与中国作了一番对比。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260511-%E9%A9%AC%E5%85%8B%E9%BE%99-%E6%AC%A7%E6%B4%B2%E5%92%8C%E4%B8%AD%E5%9B%BD%E4%B8%8D%E4%B8%80%E6%A0%B7%EF%BC%8C%E4%B8%8D%E6%98%AF%E6%9C%AC%E4%B8%96%E7%BA%AA%E5%9C%A8%E9%9D%9E%E6%B4%B2%E7%9A%84%E6%8E%A0%E5%A4%BA%E8%80%85","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778487374000.webp","sourceId":"rfi"},{"id":1778485751000,"createdDate":"2026-05-11 07:49","name":"法国国际广播电台","title":"台湾军购案在国民党内部争议纷扰情况","content":"台湾军购案的争议目前在立法院可算是暂时平静下来。但前一段时间，在台湾立法院，因为对美国军火购买案在金额上的分歧，导致政坛炮火隆隆。除了民进党与在野的国民党大拼搏之外，近日，国民党内部，也因意见分歧及技术上操作问题，可说引爆了一场国民党的内战。因为国民党副主席季麟连将军，在近日的党中央中常会中在记者面前公开表示，如果立法院长韩国瑜真的“卖党求荣”，将建议把他开除党籍。这下可说在国民党内炸开了锅！","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%BE%AE%E8%A8%80%E5%BE%AE%E8%AF%AD/20260511-%E5%8F%B0%E6%B9%BE%E5%86%9B%E8%B4%AD%E6%A1%88%E5%9C%A8%E5%9B%BD%E6%B0%91%E5%85%9A%E5%86%85%E9%83%A8%E4%BA%89%E8%AE%AE%E7%BA%B7%E6%89%B0%E6%83%85%E5%86%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778485751000.webp","sourceId":"rfi"}]