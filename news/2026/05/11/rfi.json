[{"id":1778492575000,"createdDate":"2026-05-11 09:42","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第24：浪漫主义群星之五：海涅第二节：从浪漫派阵营内投出的匕首","content":"海涅是奥古斯特·施勒格尔的学生，实际上，作为浪漫派领军人物，是他教给了海涅浪漫主义的基本理念和诉求。但后来海涅对浪漫主义的分析批判竟多是对准施勒格尔的。这既有文学理念不同，也有政治上的原因。因为海涅是拿破仑的崇拜者，奥·施勒格尔则是斯塔尔夫人的忠实伴侣。斯塔尔夫人恰是拿破仑的死敌。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260511-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%BA%94-%E6%B5%B7%E6%B6%85%E7%AC%AC%E4%BA%8C%E8%8A%82-%E4%BB%8E%E6%B5%AA%E6%BC%AB%E6%B4%BE%E9%98%B5%E8%90%A5%E5%86%85%E6%8A%95%E5%87%BA%E7%9A%84%E5%8C%95%E9%A6%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778492575000.webp","sourceId":"rfi"},{"id":1778489675000,"createdDate":"2026-05-11 08:54","name":"法国国际广播电台","title":"特朗普访华行程披露 北京：双方将就中美关系及世界和平发展交换意见","content":"中国外交部发言人周一通过声明宣布，应国家主席习近平邀请，美国总统特朗普（DonaldTrump）将于5月13日至15日对中国进行国事访问。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260511-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E8%A1%8C%E7%A8%8B%E6%8A%AB%E9%9C%B2-%E5%8C%97%E4%BA%AC-%E5%8F%8C%E6%96%B9%E5%B0%86%E5%B0%B1%E4%B8%AD%E7%BE%8E%E5%85%B3%E7%B3%BB%E5%8F%8A%E4%B8%96%E7%95%8C%E5%92%8C%E5%B9%B3%E5%8F%91%E5%B1%95%E4%BA%A4%E6%8D%A2%E6%84%8F%E8%A7%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778489675000.webp","sourceId":"rfi"},{"id":1778488997000,"createdDate":"2026-05-11 08:43","name":"法国国际广播电台","title":"美方对台湾国防预算感到失望 在野蓝白砍掉关键军购战力无人机与AI辅助系统","content":"台湾通过国防特别条例7800亿新台币，与原先1.25兆元约有4700亿的差距。对此，美国高层官员表示感到失望。民进党则批评，关键军购战力，如无人机、AI辅助系统与台湾国防自主产业等都被排除在外。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260511-%E7%BE%8E%E6%96%B9%E5%AF%B9%E5%8F%B0%E6%B9%BE%E5%9B%BD%E9%98%B2%E9%A2%84%E7%AE%97%E6%84%9F%E5%88%B0%E5%A4%B1%E6%9C%9B-%E5%9C%A8%E9%87%8E%E8%93%9D%E7%99%BD%E7%A0%8D%E6%8E%89%E5%85%B3%E9%94%AE%E5%86%9B%E8%B4%AD%E6%88%98%E5%8A%9B%E6%97%A0%E4%BA%BA%E6%9C%BA%E4%B8%8Eai%E8%BE%85%E5%8A%A9%E7%B3%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778488997000.webp","sourceId":"rfi"},{"id":1778488394000,"createdDate":"2026-05-11 08:33","name":"法国国际广播电台","title":"从发生汉坦病毒感染的邮轮下船的日本公民到达英国","content":"5月11日（当地时间10日），在西班牙加那利群岛，一名从发生汉坦病毒感染的邮轮“洪迪乌斯号（Hondius）”下船的日本公民，获得英国政府安排的包机空余座位，已抵达英国。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260511-%E4%BB%8E%E5%8F%91%E7%94%9F%E6%B1%89%E5%9D%A6%E7%97%85%E6%AF%92%E6%84%9F%E6%9F%93%E7%9A%84%E9%82%AE%E8%BD%AE%E4%B8%8B%E8%88%B9%E7%9A%84%E6%97%A5%E6%9C%AC%E5%85%AC%E6%B0%91%E5%88%B0%E8%BE%BE%E8%8B%B1%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778488394000.webp","sourceId":"rfi"},{"id":1778487374000,"createdDate":"2026-05-11 08:16","name":"法国国际广播电台","title":"马克龙：欧洲和中国不一样，不是本世纪在非洲的掠夺者","content":"法国总统马克龙于周一（5月11日）在肯尼亚主持召开法非峰会。周日出发前，他在接受法国媒体JeuneAfrique和TheAfricaReport采访时为欧洲辩护，称“欧洲人并不是这个世纪在非洲的掠夺者”，他还特别将欧洲与中国作了一番对比。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260511-%E9%A9%AC%E5%85%8B%E9%BE%99-%E6%AC%A7%E6%B4%B2%E5%92%8C%E4%B8%AD%E5%9B%BD%E4%B8%8D%E4%B8%80%E6%A0%B7%EF%BC%8C%E4%B8%8D%E6%98%AF%E6%9C%AC%E4%B8%96%E7%BA%AA%E5%9C%A8%E9%9D%9E%E6%B4%B2%E7%9A%84%E6%8E%A0%E5%A4%BA%E8%80%85","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778487374000.webp","sourceId":"rfi"},{"id":1778485751000,"createdDate":"2026-05-11 07:49","name":"法国国际广播电台","title":"台湾军购案在国民党内部争议纷扰情况","content":"台湾军购案的争议目前在立法院可算是暂时平静下来。但前一段时间，在台湾立法院，因为对美国军火购买案在金额上的分歧，导致政坛炮火隆隆。除了民进党与在野的国民党大拼搏之外，近日，国民党内部，也因意见分歧及技术上操作问题，可说引爆了一场国民党的内战。因为国民党副主席季麟连将军，在近日的党中央中常会中在记者面前公开表示，如果立法院长韩国瑜真的“卖党求荣”，将建议把他开除党籍。这下可说在国民党内炸开了锅！","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%BE%AE%E8%A8%80%E5%BE%AE%E8%AF%AD/20260511-%E5%8F%B0%E6%B9%BE%E5%86%9B%E8%B4%AD%E6%A1%88%E5%9C%A8%E5%9B%BD%E6%B0%91%E5%85%9A%E5%86%85%E9%83%A8%E4%BA%89%E8%AE%AE%E7%BA%B7%E6%89%B0%E6%83%85%E5%86%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778485751000.webp","sourceId":"rfi"},{"id":1778516435000,"createdDate":"2026-05-11 16:20","name":"法国国际广播电台","title":"推进对台军售、不让中国汽车进入 美国会两党议员就一众议题向特朗普施压","content":"一个由两党美国联邦参议员组成的小组敦促特朗普总统推进一项价值140亿美元的对台军售计划，并在本周于北京举行的峰会上向中国领导人习近平发出信号，即美国对台湾的支持不容谈判。这封由八位联邦参议员于5月8日联名签署、并于周一公布的信函强调，美国国会于2025年1月批准的对台军售方案“对我们的国家利益至关重要”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260511-%E6%8E%A8%E8%BF%9B%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE-%E4%B8%8D%E8%AE%A9%E4%B8%AD%E5%9B%BD%E6%B1%BD%E8%BD%A6%E8%BF%9B%E5%85%A5-%E7%BE%8E%E5%9B%BD%E4%BC%9A%E4%B8%A4%E5%85%9A%E8%AE%AE%E5%91%98%E5%B0%B1%E4%B8%80%E4%BC%97%E8%AE%AE%E9%A2%98%E5%90%91%E7%89%B9%E6%9C%97%E6%99%AE%E6%96%BD%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778516435000.webp","sourceId":"rfi"},{"id":1778515641000,"createdDate":"2026-05-11 16:07","name":"法国国际广播电台","title":"“特习会”前台湾民间的强化防卫训练","content":"路透社报道，在美国总统特朗普与中国国家主席习近平即将举行会晤之际，台湾社会对台海安全局势的不确定感升高，民众更多地自发参与民间组织的防卫训练。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260511-%E7%89%B9%E4%B9%A0%E4%BC%9A-%E5%89%8D%E5%8F%B0%E6%B9%BE%E6%B0%91%E9%97%B4%E7%9A%84%E5%BC%BA%E5%8C%96%E9%98%B2%E5%8D%AB%E8%AE%AD%E7%BB%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778515641000.webp","sourceId":"rfi"},{"id":1778514060000,"createdDate":"2026-05-11 15:41","name":"法国国际广播电台","title":"港人在英参选及胜选率大升 至少六人当选 蔡嘉源信可鼓励更多港人参选","content":"在刚结束的英国地方选举，改革党(ReformUK)可以说是大赢家，但对流散当地的港人来说，自由民主党(自民党)成绩更是可喜可贺，因为代表该党出选的十名有港人背景的候选人中，有一半胜出，较选前增加三个议席；再加上代表绿党出战的谭巧瑜，令今次有港人背景的当选议员至少有六人，胜选率达到三成二。成功连任的蔡嘉源表示，结果突显港人与过往移英华人不同，他们不光是客人，而是愿意成为「当地人」。他预期，港人参选会日渐增加，但就希望各人循不同政党参选，让港人议题在不同政党被看见，甚至吸纳。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260511-%E6%B8%AF%E4%BA%BA%E5%9C%A8%E8%8B%B1%E5%8F%82%E9%80%89%E5%8F%8A%E8%83%9C%E9%80%89%E7%8E%87%E5%A4%A7%E5%8D%87-%E8%87%B3%E5%B0%91%E5%85%AD%E4%BA%BA%E5%BD%93%E9%80%89-%E8%94%A1%E5%98%89%E6%BA%90%E4%BF%A1%E5%8F%AF%E9%BC%93%E5%8A%B1%E6%9B%B4%E5%A4%9A%E6%B8%AF%E4%BA%BA%E5%8F%82%E9%80%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778514060000.webp","sourceId":"rfi"},{"id":1778513250000,"createdDate":"2026-05-11 15:27","name":"法国国际广播电台","title":"邹幸彤母亲节狱中发文 感谢「天安门母亲」坚守六四真相","content":"已解散的支联会及其前正副主席李卓人丶何俊仁和邹幸彤，被控「煽动颠覆国家政权罪」一案，将于下周一(18日)作结案陈词。仍在还柙的邹幸彤，在距离「六四事件」周年不足一个月的母亲节，向坚守六四真相丶为死难者抗争的「天安门母亲」群体送上母亲节祝福，感谢她们亲身向港人示范，如何在专制下仍可不卑不亢。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260511-%E9%82%B9%E5%B9%B8%E5%BD%A4%E6%AF%8D%E4%BA%B2%E8%8A%82%E7%8B%B1%E4%B8%AD%E5%8F%91%E6%96%87-%E6%84%9F%E8%B0%A2-%E5%A4%A9%E5%AE%89%E9%97%A8%E6%AF%8D%E4%BA%B2-%E5%9D%9A%E5%AE%88%E5%85%AD%E5%9B%9B%E7%9C%9F%E7%9B%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778513250000.webp","sourceId":"rfi"},{"id":1778512857000,"createdDate":"2026-05-11 15:20","name":"法国国际广播电台","title":"逾百美国会议员促「特习会」要求释放黎智英　黎崇恩再吁特朗普助救其父","content":"美国总统特朗普将于本周三至五出访中国，是近十年来首度有在任美国总统访华。在特朗普访华前夕，逾百名美国国会跨党派议员去信白宫，促请特朗普与中国国家主席习近平会面时，促请北京释放被港府重判20年的前《苹果日报》创办人黎智英。黎之子黎崇恩亦在特朗普访华前夕，再次呼吁特朗普协助其父离开监狱。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260511-%E9%80%BE%E7%99%BE%E7%BE%8E%E5%9B%BD%E4%BC%9A%E8%AE%AE%E5%91%98%E4%BF%83-%E7%89%B9%E4%B9%A0%E4%BC%9A-%E8%A6%81%E6%B1%82%E9%87%8A%E6%94%BE%E9%BB%8E%E6%99%BA%E8%8B%B1-%E9%BB%8E%E5%B4%87%E6%81%A9%E5%86%8D%E5%90%81%E7%89%B9%E6%9C%97%E6%99%AE%E5%8A%A9%E6%95%91%E5%85%B6%E7%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778512857000.webp","sourceId":"rfi"},{"id":1778512290000,"createdDate":"2026-05-11 15:11","name":"法国国际广播电台","title":"黄仁勋据报未受邀随特朗普访华 马斯克、库克等美企高管受邀随行","content":"据路透社报导，一位知情人士周一透露，英伟达首席执行官黄仁勋不会随美国总统特朗普本周访华前往北京。该消息人士称，黄仁勋并未受邀，白宫将此次访问的重点更多地放在农业和商业航空事务上，例如波音飞机的订单。白宫尚未立即对此置评。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260511-%E9%BB%84%E4%BB%81%E5%8B%8B%E6%8D%AE%E6%8A%A5%E6%9C%AA%E5%8F%97%E9%82%80%E9%9A%8F%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778512290000.webp","sourceId":"rfi"},{"id":1778511188000,"createdDate":"2026-05-11 14:53","name":"法国国际广播电台","title":"受美制裁的恒力石化（大连）于新加坡的前子公司将停止运营","content":"据路透社报导，四位业内人士周一透露，受美国制裁的恒力石化（大连）炼化有限公司的前新加坡贸易子公司恒力石化国际（HengliPetrochemicalInternationalPteLtd.）计划停止运营。其中三位消息人士称，恒力石化国际的运营可能在5月底‌逐渐终止。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260511-%E5%8F%97%E7%BE%8E%E5%88%B6%E8%A3%81%E7%9A%84%E6%81%92%E5%8A%9B%E7%9F%B3%E5%8C%96-%E5%A4%A7%E8%BF%9E-%E4%BA%8E%E6%96%B0%E5%8A%A0%E5%9D%A1%E7%9A%84%E5%89%8D%E5%AD%90%E5%85%AC%E5%8F%B8%E5%B0%86%E5%81%9C%E6%AD%A2%E8%BF%90%E8%90%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778511188000.webp","sourceId":"rfi"},{"id":1778508277000,"createdDate":"2026-05-11 14:04","name":"法国国际广播电台","title":"泰国中国男子藏匿军火案五人被起诉 柬埔寨警方否认案件与洪森警卫队有关","content":"五名嫌疑人，包括泰国海军军官和平民，被指控参与一个与一名在芭堤雅被捕的中国公民有关的非法武器供应网络，并被以非法持有和出售战争武器罪名起诉。泰国外府警察第二警区副指挥官乔猜（ChokchaiNgamwong）周一表示，这些嫌疑人否认所有指控，并表示将在法庭上证明自己的清白。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260511-%E6%B3%B0%E5%9B%BD%E4%B8%AD%E5%9B%BD%E7%94%B7%E5%AD%90%E8%97%8F%E5%8C%BF%E5%86%9B%E7%81%AB%E6%A1%88%E4%BA%94%E4%BA%BA%E8%A2%AB%E8%B5%B7%E8%AF%89-%E6%9F%AC%E5%9F%94%E5%AF%A8%E8%AD%A6%E6%96%B9%E5%90%A6%E8%AE%A4%E5%85%B6%E4%B8%8E%E6%B4%AA%E6%A3%AE%E8%AD%A6%E5%8D%AB%E9%98%9F%E6%9C%89%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778508277000.webp","sourceId":"rfi"},{"id":1778506988000,"createdDate":"2026-05-11 13:43","name":"法国国际广播电台","title":"欧盟规划高级专员博纳呼吁加快发展自动驾驶 不愿落后于中国和美国","content":"欧盟战略与规划高级专员克莱蒙·博纳（ClémentBeaune）于5月11日星期一指出目前所有自动驾驶车型都只有美国或中国制造，并呼吁欧洲层面采取应对措施进行改变，“以免错过这场技术革命”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260511-%E6%AC%A7%E7%9B%9F%E8%A7%84%E5%88%92%E9%AB%98%E7%BA%A7%E4%B8%93%E5%91%98%E5%8D%9A%E7%BA%B3%E5%91%BC%E5%90%81%E5%8A%A0%E5%BF%AB%E5%8F%91%E5%B1%95%E8%87%AA%E5%8A%A8%E9%A9%BE%E9%A9%B6-%E4%B8%8D%E6%84%BF%E8%90%BD%E5%90%8E%E4%BA%8E%E4%B8%AD%E5%9B%BD%E5%92%8C%E7%BE%8E%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778506988000.webp","sourceId":"rfi"},{"id":1778501185000,"createdDate":"2026-05-11 12:06","name":"法国国际广播电台","title":"受中东战争影响——中国生产者价格指数涨幅创2022年以来新高","content":"中国周一公布的数据显示，4月份的生产者价格指数涨幅超出预期，达到2022年以来的最高水平，主要原因是中东战争导致成本飙升。法新社指出，全球约五分之一的油气供应通常是经由霍尔木兹海峡运输的，但目前该海峡实际上被德黑兰方面阻断，同时又受到美国封锁的影响，这导致国际油价格的飙升，并扰乱了全球能源供应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260511-%E5%8F%97%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E5%BD%B1%E5%93%8D-%E4%B8%AD%E5%9B%BD%E7%94%9F%E4%BA%A7%E8%80%85%E4%BB%B7%E6%A0%BC%E6%8C%87%E6%95%B0%E6%B6%A8%E5%B9%85%E5%88%9B2022%E5%B9%B4%E4%BB%A5%E6%9D%A5%E6%96%B0%E9%AB%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778501185000.webp","sourceId":"rfi"},{"id":1778499086000,"createdDate":"2026-05-11 11:31","name":"法国国际广播电台","title":"泰国前总理他信假释出狱","content":"泰国前总理他信·钦那瓦（ThaksinShinawatra）于5月11日正式获释。这位76岁的政治强人，在服刑8个月后提前假释回家。随着他的回归，外界再次关注：钦那瓦家族，是否将重新扩大在泰国政坛的影响力。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260511-%E6%B3%B0%E5%9B%BD%E5%89%8D%E6%80%BB%E7%90%86%E4%BB%96%E4%BF%A1%E5%81%87%E9%87%8A%E5%87%BA%E7%8B%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778499086000.webp","sourceId":"rfi"},{"id":1778497968000,"createdDate":"2026-05-11 11:12","name":"法国国际广播电台","title":"法国出现首例感染病例：汉坦病毒疫情和新冠一样可怕吗？","content":"关于汉坦病毒疫情，周一（5月11日）的最新消息是，周日从“洪迪乌斯号”（MVHondius）邮轮撤离的乘客已相继回国，其中，一名美国乘客检测结果呈阳性，而一名法国乘客则在返程航班上出现了感染症状。截至目前，已有3人死亡，另有5名此前离船人员确认感染汉坦病毒。目前这种病毒既没有疫苗，也没有特效治疗方法，并可能引发严重急性呼吸综合征。这次的疫情真的和2020年的新冠一样可怕吗?本期的要闻解说将向您介绍关于汉坦病毒的重要的基本常识。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260511-%E6%B3%95%E5%9B%BD%E9%A6%96%E6%AC%A1%E5%87%BA%E7%8E%B0%E6%84%9F%E6%9F%93%E7%97%85%E4%BE%8B-%E6%B1%89%E5%9D%A6%E7%97%85%E6%AF%92%E7%96%AB%E6%83%85%E5%92%8C%E6%96%B0%E5%86%A0%E4%B8%80%E6%A0%B7%E5%8F%AF%E6%80%95%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778497968000.webp","sourceId":"rfi"},{"id":1778496377000,"createdDate":"2026-05-11 10:46","name":"法国国际广播电台","title":"美国商会报告警告中国正扩大其工业主导地位：有效应对的窗口期正在缩小","content":"美国商会警告称，各国应对中国新产业政策的时间窗口“有限”，这些政策正在加深对中国供应链的依赖，并损害全球经济。这家总部位于华盛顿的游说团体表示，北京正在“加倍”国家干预制造业、服务业和前沿技术。美国商会称，中国正开启“全球影响新阶段”，其特征是贸易依赖度上升和中国企业在全球范围内的快速扩张。中国还利用出口管制等手段巩固其在全球供应链中的地位，并抵制他国的多元化战略。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260511-%E7%BE%8E%E5%9B%BD%E5%95%86%E4%BC%9A%E6%8A%A5%E5%91%8A%E8%AD%A6%E5%91%8A%E4%B8%AD%E5%9B%BD%E6%AD%A3%E6%89%A9%E5%A4%A7%E5%85%B6%E5%B7%A5%E4%B8%9A%E4%B8%BB%E5%AF%BC%E5%9C%B0%E4%BD%8D-%E6%9C%89%E6%95%88%E5%BA%94%E5%AF%B9%E7%9A%84%E7%AA%97%E5%8F%A3%E6%9C%9F%E6%AD%A3%E5%9C%A8%E7%BC%A9%E5%B0%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778496377000.webp","sourceId":"rfi"},{"id":1778493345000,"createdDate":"2026-05-11 09:55","name":"法国国际广播电台","title":"特朗普访华在即 传下榻酒店外警车聚集","content":"据韩联社记者报导，当地时间周一上午，距美国总统特朗普（DonaldTrump）访华仅剩两天之际，位于北京的美国驻华大使馆周边一片繁忙景象。一长串公安巡逻车停在美国大使馆附近一家五星级豪华酒店前的路边。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260511-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E5%9C%A8%E5%8D%B3-%E4%BC%A0%E4%B8%8B%E6%A6%BB%E9%85%92%E5%BA%97%E5%A4%96%E8%AD%A6%E8%BD%A6%E8%81%9A%E9%9B%86","thumbnail":"","detailImage":"news/detail/rfi/2026/05/11/1778493345000.webp","sourceId":"rfi"}]