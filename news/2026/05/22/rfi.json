[{"id":1779408267000,"createdDate":"2026-05-22 00:04","name":"法国国际广播电台","title":"Katàbasis荣获第79届戛纳电影节最佳沉浸式作品奖","content":"在第79届戛纳影节沉浸式单元中，由法国导演乌果·阿尔萨克（UgoArsac）创作的互动纪录片《卡塔巴西斯（Katàbasis）》荣获“最佳沉浸式作品奖”。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260522-kat%C3%A0basis%E8%8D%A3%E8%8E%B7%E7%AC%AC79%E5%B1%8A%E6%88%9B%E7%BA%B3%E7%94%B5%E5%BD%B1%E8%8A%82%E6%9C%80%E4%BD%B3%E6%B2%89%E6%B5%B8%E5%BC%8F%E4%BD%9C%E5%93%81%E5%A5%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779408267000.webp","sourceId":"rfi"},{"id":1779439017000,"createdDate":"2026-05-22 08:36","name":"法国国际广播电台","title":"回归以来首次 香港全体立法会议员7月到北京研修考察","content":"香港立法会主席李慧琼周四通过社交媒体宣布，“全体议员将于今年7月19日至25日，到北京参加国家事务研修考察”，并指“这将是香港自回归祖国以来，首次全体议员到北京研修考察，历史意义重大”。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260522-%E5%9B%9E%E5%BD%92%E4%BB%A5%E6%9D%A5%E9%A6%96%E6%AC%A1-%E9%A6%99%E6%B8%AF%E5%85%A8%E4%BD%93%E7%AB%8B%E6%B3%95%E4%BC%9A%E8%AE%AE%E5%91%987%E6%9C%88%E5%88%B0%E5%8C%97%E4%BA%AC%E7%A0%94%E4%BF%AE%E8%80%83%E5%AF%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779439017000.webp","sourceId":"rfi"},{"id":1779438533000,"createdDate":"2026-05-22 08:28","name":"法国国际广播电台","title":"涉嫌向中国走私英伟达芯片 三名台湾人被拘留调查","content":"台湾检察机关周五（5月22日）表示，三名台湾人因违反出口限制，走私英伟达人工智能芯片至中国而被起诉。中国外交部发言人当天就相关提问回应表示，“这不是一个外交问题，不了解相关情况”。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260522-%E6%B6%89%E5%AB%8C%E5%90%91%E4%B8%AD%E5%9B%BD%E8%B5%B0%E7%A7%81%E5%86%85%E7%BD%AE%E8%8B%B1%E4%BC%9F%E8%BE%BE%E8%8A%AF%E7%89%87%E7%9A%84ai%E4%BC%BA%E6%9C%8D%E5%99%A8-%E4%B8%89%E5%90%8D%E5%8F%B0%E6%B9%BE%E4%BA%BA%E8%A2%AB%E5%8F%B8%E6%B3%95%E5%A3%B0%E6%8A%BC%E8%B5%B7%E8%AF%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779438533000.webp","sourceId":"rfi"},{"id":1779437957000,"createdDate":"2026-05-22 08:19","name":"法国国际广播电台","title":"《台湾：面对中国的民主》：一本终结刻板印象的著作","content":"法国天主教媒体《十字架报》周四在国际版登出卡米耶·里希尔撰写的书评称，在《台湾：面对中国的民主》一书中，汉学家让-皮埃尔·卡贝斯坦回顾了这座被北京声索主权的岛屿的历史及其独特的政治体制。他为我们提供了一部非常详尽的导论，以帮助读者理解围绕这一年轻民主政体的各种辩论与挑战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260522-%E5%8F%B0%E6%B9%BE%E9%9D%A2%E5%AF%B9%E4%B8%AD%E5%9B%BD-%E4%B8%80%E6%9C%AC%E7%BB%88%E7%BB%93%E5%88%BB%E6%9D%BF%E5%8D%B0%E8%B1%A1%E7%9A%84%E8%91%97%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779437957000.webp","sourceId":"rfi"},{"id":1779435309000,"createdDate":"2026-05-22 07:35","name":"法国国际广播电台","title":"《黑色珠子》—— 角逐金棕榈的三部西班牙影片中最后一部亮相戛纳","content":"戛纳影节第九天，主竞赛单元放映了西班牙电影《黑色珠子》。这是入围角逐金棕榈的三部西班牙影片中最后亮相影节的一部。影片的导演是此前并不为国际影坛熟知的西班牙年轻导演组合哈维尔·安布罗西与哈维尔·卡尔沃。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260522-%E9%BB%91%E8%89%B2%E7%8F%A0%E5%AD%90-%E8%A7%92%E9%80%90%E9%87%91%E6%A3%95%E6%A6%88%E7%9A%84%E4%B8%89%E9%83%A8%E8%A5%BF%E7%8F%AD%E7%89%99%E5%BD%B1%E7%89%87%E4%B8%AD%E6%9C%80%E5%90%8E%E4%B8%80%E9%83%A8%E4%BA%AE%E7%9B%B8%E6%88%9B%E7%BA%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779435309000.webp","sourceId":"rfi"},{"id":1779432998000,"createdDate":"2026-05-22 06:56","name":"法国国际广播电台","title":"香港反恐首案两主脑资产遭充公 同案脱罪者被指助众筹同遭殃","content":"2019年反修例运动期间组成的示威者组织「屠龙小队」，因涉及策划杀警等行动，港府首次引用可判囚终身的《反恐条例》提出检控，案中两名主脑于2024年分别被法庭重判。港府近日再向法庭申请充公二人财产，并以曾协助众筹为由，要求充公经审讯的同案脱罪者名下资产，同样获批。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260522-%E9%A6%99%E6%B8%AF%E5%8F%8D%E6%81%90%E9%A6%96%E6%A1%88%E4%B8%A4%E4%B8%BB%E8%84%91%E8%B5%84%E4%BA%A7%E9%81%AD%E5%85%85%E5%85%AC-%E5%90%8C%E6%A1%88%E8%84%B1%E7%BD%AA%E8%80%85%E8%A2%AB%E6%8C%87%E5%8A%A9%E4%BC%97%E7%AD%B9%E5%90%8C%E9%81%AD%E6%AE%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779432998000.webp","sourceId":"rfi"},{"id":1779465417000,"createdDate":"2026-05-22 15:56","name":"法国国际广播电台","title":"马克龙促欧洲大规模投资量子技术和半导体 提出欧版301条款防御机制","content":"法国总统马克龙周五宣布追加15.5亿欧元公共投资，用于量子和半导体技术的发展。他呼吁欧洲加大投资力度，以应对美中两国在这些关键技术领域的“加速发展”，从而保持欧洲“主权”。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260522-%E9%A9%AC%E5%85%8B%E9%BE%99%E4%BF%83%E6%AC%A7%E6%B4%B2%E5%A4%A7%E8%A7%84%E6%A8%A1%E6%8A%95%E8%B5%84%E9%87%8F%E5%AD%90%E6%8A%80%E6%9C%AF%E5%92%8C%E5%8D%8A%E5%AF%BC%E4%BD%93-%E6%8F%90%E5%87%BA%E6%AC%A7%E7%89%88301%E6%9D%A1%E6%AC%BE%E9%98%B2%E5%BE%A1%E6%9C%BA%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779465417000.webp","sourceId":"rfi"},{"id":1779460363000,"createdDate":"2026-05-22 14:32","name":"法国国际广播电台","title":"SpaceX计划上市：1.75万亿美元天价估值引争议，马斯克或成全球首位“万亿美元富豪”","content":"刚刚过去的特习会上，除了中美两国元首，还有一位美国企业家成为媒体关注的焦点。这位带着6岁的小儿子走进人民大会堂开会，在阅兵式上拿手机疯狂拍照，以及在国宴上无所顾忌频频对媒体镜头做鬼脸的企业家就是马斯克，同时也是社交平台X和特斯拉等众多知名企业的老板 。周三（5月20日），他宣布了一个新消息，称计划推动他的太空公司SpaceX上市。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E7%BB%8F%E6%B5%8E/20260522-spacex%E8%AE%A1%E5%88%92%E4%B8%8A%E5%B8%82-1-75%E4%B8%87%E4%BA%BF%E7%BE%8E%E5%85%83%E5%A4%A9%E4%BB%B7%E4%BC%B0%E5%80%BC%E5%BC%95%E4%BA%89%E8%AE%AE%EF%BC%8C%E9%A9%AC%E6%96%AF%E5%85%8B%E6%88%96%E6%88%90%E5%85%A8%E7%90%83%E9%A6%96%E4%BD%8D-%E4%B8%87%E4%BA%BF%E7%BE%8E%E5%85%83%E5%AF%8C%E8%B1%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779460363000.webp","sourceId":"rfi"},{"id":1779459946000,"createdDate":"2026-05-22 14:25","name":"法国国际广播电台","title":"回声报：特朗普返回白宫后就台湾问题给中美关系泼了盆冷水","content":"大家好，欢迎收听法国报纸摘要。今天是5月22日，法国全国性日报头版焦点以国内事务为主。美国、台湾与中国近期就“独立”和军售两大议题的错综复杂关系，则成为《费加罗报》驻台记者与《回声报》驻华记者报道的主题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260522-%E5%9B%9E%E5%A3%B0%E6%8A%A5-%E7%89%B9%E6%9C%97%E6%99%AE%E8%BF%94%E5%9B%9E%E7%99%BD%E5%AE%AB%E5%90%8E%E5%B0%B1%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98%E7%BB%99%E4%B8%AD%E7%BE%8E%E5%85%B3%E7%B3%BB%E6%B3%BC%E4%BA%86%E7%9B%86%E5%86%B7%E6%B0%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779459946000.webp","sourceId":"rfi"},{"id":1779459856000,"createdDate":"2026-05-22 14:24","name":"法国国际广播电台","title":"中国证监会等八部门联合出手 整治非法跨境证券期货基金经营","content":"中国证券监督管理委员会（以下简称证监会）周五通过新闻稿表示，“近日，证监会依法对Tiger Brokers (NZ) Limited（以下简称老虎）、富途证券国际（香港）有限公司（以下简称富途）、长桥证券（香港）有限公司（以下简称长桥）境内外相关主体在境内非法经营证券业务等行为立案调查并作出行政处罚事先告知”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260522-%E4%B8%AD%E5%9B%BD%E8%AF%81%E7%9B%91%E4%BC%9A%E7%AD%89%E5%85%AB%E9%83%A8%E9%97%A8%E8%81%94%E5%90%88%E5%87%BA%E6%89%8B-%E6%95%B4%E6%B2%BB%E9%9D%9E%E6%B3%95%E8%B7%A8%E5%A2%83%E8%AF%81%E5%88%B8%E6%9C%9F%E8%B4%A7%E5%9F%BA%E9%87%91%E7%BB%8F%E8%90%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779459856000.webp","sourceId":"rfi"},{"id":1779459266000,"createdDate":"2026-05-22 14:14","name":"法国国际广播电台","title":"北约外长会：美国驻欧派兵部署接连反转令欧洲困惑","content":"北约32国外长会议周五（5月22日）开始在瑞典南部城市赫尔辛堡召开，两天的会议原本主要为7月初将在土耳其安卡拉举行的北约峰会做准备，但随着美以联合打击伊朗之后中东局势持续升级，美欧围绕对战争支持以及北约未来分歧加剧。面对华盛顿近期有关驻欧美军问题接连释放不同的信号，感到困惑的欧洲北约国家希望借此次会议之际获得美方若干解释并缓和对美国的紧张关系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260522-%E5%8C%97%E7%BA%A6%E5%A4%96%E9%95%BF%E4%BC%9A-%E7%BE%8E%E5%9B%BD%E9%A9%BB%E6%AC%A7%E6%B4%BE%E5%85%B5%E9%83%A8%E7%BD%B2%E6%8E%A5%E8%BF%9E%E5%8F%8D%E8%BD%AC%E4%BB%A4%E6%AC%A7%E6%B4%B2%E5%9B%B0%E6%83%91","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779459266000.webp","sourceId":"rfi"},{"id":1779458261000,"createdDate":"2026-05-22 13:57","name":"法国国际广播电台","title":"中国政府发文将全面取消社保户籍限制 北京上海等大城市如何落实仍未知","content":"周五（5月22日），据中国官方媒体报道，中国政府当天发布指导意见，要求各城市保障公民无论户籍身份如何，都能公平享有公共服务。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260522-%E4%B8%AD%E5%9B%BD%E6%94%BF%E5%BA%9C%E5%8F%91%E6%96%87%E5%B0%86%E5%85%A8%E9%9D%A2%E5%8F%96%E6%B6%88%E7%A4%BE%E4%BF%9D%E6%88%B7%E7%B1%8D%E9%99%90%E5%88%B6-%E5%8C%97%E4%BA%AC%E4%B8%8A%E6%B5%B7%E7%AD%89%E5%A4%A7%E5%9F%8E%E5%B8%82%E5%A6%82%E4%BD%95%E8%90%BD%E5%AE%9E%E4%BB%8D%E6%9C%AA%E7%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779458261000.webp","sourceId":"rfi"},{"id":1779458066000,"createdDate":"2026-05-22 13:54","name":"法国国际广播电台","title":"特朗普对台军售两难？考验美国对中政策","content":"美国总统特朗普考虑是否批准总值140亿美元对台军售，并表示可能与台湾总统赖清德通话，使对台军售再次成为华盛顿处理中国、台湾与印太安全政策的核心考题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260522-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E4%B8%A4%E9%9A%BE-%E8%80%83%E9%AA%8C%E7%BE%8E%E5%9B%BD%E5%AF%B9%E4%B8%AD%E6%94%BF%E7%AD%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779458066000.webp","sourceId":"rfi"},{"id":1779454346000,"createdDate":"2026-05-22 12:52","name":"法国国际广播电台","title":"闻泰科技就控制权纠纷起诉安世半导体 索赔80亿元人民币","content":"闻泰科技周五表示，该公司及其子公司已对安世半导体及相关实体和个人提起诉讼，初步索赔80亿元人民币（约合11.8亿美元），以弥补经济损失。闻泰科技在提交给上海证券交易所的“重大诉讼公告”中称，广东省东莞市中级人民法院已受理此案，尚未正式开庭。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260522-%E9%97%BB%E6%B3%B0%E7%A7%91%E6%8A%80%E5%B0%B1%E6%8E%A7%E5%88%B6%E6%9D%83%E7%BA%A0%E7%BA%B7%E8%B5%B7%E8%AF%89%E5%AE%89%E4%B8%96%E5%8D%8A%E5%AF%BC%E4%BD%93-%E7%B4%A2%E8%B5%9480%E4%BA%BF%E5%85%83%E4%BA%BA%E6%B0%91%E5%B8%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779454346000.webp","sourceId":"rfi"},{"id":1779451796000,"createdDate":"2026-05-22 12:09","name":"法国国际广播电台","title":"日菲将启动《军事情报保护协定》正式谈判 小马科斯将被授予大勋位菊花大绶章","content":"据《日经亚洲》获悉，日本和菲律宾将正式启动信息安全协议谈判，该协议将允许双方交换机密安全数据。报导指，出于应对北京考虑，东京和马尼拉这两个美国在亚洲的盟友，希望建立一个共享敏感情报的框架，并促进与华盛顿更紧密的合作。如果最终达成协议，这将是日本与东南亚国家之间签署的首个此类协议。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260522-%E6%97%A5%E8%8F%B2%E5%B0%86%E5%90%AF%E5%8A%A8-%E5%86%9B%E4%BA%8B%E6%83%85%E6%8A%A5%E4%BF%9D%E6%8A%A4%E5%8D%8F%E5%AE%9A-%E6%AD%A3%E5%BC%8F%E8%B0%88%E5%88%A4-%E5%B0%8F%E9%A9%AC%E7%A7%91%E6%96%AF%E5%B0%86%E8%A2%AB%E6%8E%88%E4%BA%88%E5%A4%A7%E5%8B%8B%E4%BD%8D%E8%8F%8A%E8%8A%B1%E5%A4%A7%E7%BB%B6%E7%AB%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779451796000.webp","sourceId":"rfi"},{"id":1779449970000,"createdDate":"2026-05-22 11:39","name":"法国国际广播电台","title":"美日印澳四方安全对话外长会下周二在新德里举行：推进优先领域合作交换意见","content":"日本外务省周五表示，美国、日本、澳大利亚和印度将于5月26日在新德里举行四方安全对话（Quad）外长会议。日本外务大臣茂木敏充将于下周一开始访问印度三天，出席此次会议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260522-%E7%BE%8E%E6%97%A5%E5%8D%B0%E6%BE%B3%E5%9B%9B%E6%96%B9%E5%AE%89%E5%85%A8%E5%AF%B9%E8%AF%9D%E5%A4%96%E9%95%BF%E4%BC%9A%E4%B8%8B%E5%91%A8%E4%BA%8C%E5%9C%A8%E6%96%B0%E5%BE%B7%E9%87%8C%E4%B8%BE%E8%A1%8C-%E6%8E%A8%E8%BF%9B%E4%BC%98%E5%85%88%E9%A2%86%E5%9F%9F%E5%90%88%E4%BD%9C%E4%BA%A4%E6%8D%A2%E6%84%8F%E8%A7%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779449970000.webp","sourceId":"rfi"},{"id":1779446255000,"createdDate":"2026-05-22 10:37","name":"法国国际广播电台","title":"欧中贸易紧张局势或进一步升级 王文涛6月底访问布鲁塞尔","content":"随着双方贸易紧张局势一触即发，中国商务部长王文涛预计将于6月29日至30日赴布鲁塞尔，与欧盟委员会贸易和经济安全委员谢夫乔维奇（MarosSefcovic）举行关键会谈。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260522-%E6%AC%A7%E4%B8%AD%E8%B4%B8%E6%98%93%E7%B4%A7%E5%BC%A0%E5%B1%80%E5%8A%BF%E6%88%96%E8%BF%9B%E4%B8%80%E6%AD%A5%E5%8D%87%E7%BA%A7-%E7%8E%8B%E6%96%87%E6%B6%9B6%E6%9C%88%E5%BA%95%E8%AE%BF%E9%97%AE%E5%B8%83%E9%B2%81%E5%A1%9E%E5%B0%94","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779446255000.webp","sourceId":"rfi"},{"id":1779444350000,"createdDate":"2026-05-22 10:05","name":"法国国际广播电台","title":"被美英欧盟等多方制裁的俄储蓄银行CEO获清华大学杰出访问教授称号","content":"俄罗斯储蓄银行首席执行官兼执行委员会主席格列夫（GermanGref）获清华大学杰出访问教授称号。格列夫是陪同俄总统普京访问北京，与中国领导人进行为期两天国事访问的代表团成员之一。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260522-%E8%A2%AB%E7%BE%8E%E8%8B%B1%E6%AC%A7%E7%9B%9F%E7%AD%89%E5%A4%9A%E6%96%B9%E5%88%B6%E8%A3%81%E7%9A%84%E4%BF%84%E5%82%A8%E8%93%84%E9%93%B6%E8%A1%8Cceo%E8%8E%B7%E6%B8%85%E5%8D%8E%E5%A4%A7%E5%AD%A6%E6%9D%B0%E5%87%BA%E8%AE%BF%E9%97%AE%E6%95%99%E6%8E%88%E7%A7%B0%E5%8F%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779444350000.webp","sourceId":"rfi"},{"id":1779443915000,"createdDate":"2026-05-22 09:58","name":"法国国际广播电台","title":"日本经产业大臣在中国访问 能不能实现日中关系突破引人注目","content":"日本经济产业大臣赤泽亮正为出席国际会议，正在访问中国。在日本首相高市早苗就“台湾有事”发表相关言论后，日中之间的交流陷入停滞，因此此次是否能够实现与中方接触备受关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260522-%E6%97%A5%E6%9C%AC%E7%BB%8F%E4%BA%A7%E4%B8%9A%E5%A4%A7%E8%87%A3%E5%9C%A8%E4%B8%AD%E5%9B%BD%E8%AE%BF%E9%97%AE-%E8%83%BD%E4%B8%8D%E8%83%BD%E5%AE%9E%E7%8E%B0%E6%97%A5%E4%B8%AD%E5%85%B3%E7%B3%BB%E7%AA%81%E7%A0%B4%E5%BC%95%E4%BA%BA%E6%B3%A8%E7%9B%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779443915000.webp","sourceId":"rfi"},{"id":1779441687000,"createdDate":"2026-05-22 09:21","name":"法国国际广播电台","title":"美代理海军部长称因伊朗战争已暂停对台军售 台北：无美对台军售暂停讯息","content":"美国代理海军部长高雄周四表示，已“暂停”向台湾出售武器，以确保美军有足够的弹药用于其在伊朗的行动。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260522-%E7%BE%8E%E4%BB%A3%E7%90%86%E6%B5%B7%E5%86%9B%E9%83%A8%E9%95%BF%E7%A7%B0%E5%9B%A0%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E5%B7%B2%E6%9A%82%E5%81%9C%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE-%E5%8F%B0%E5%8C%97-%E6%97%A0%E7%BE%8E%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E6%9A%82%E5%81%9C%E8%AE%AF%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779441687000.webp","sourceId":"rfi"},{"id":1779432496000,"createdDate":"2026-05-22 06:48","name":"法国国际广播电台","title":"谁来决定 台湾未来 ？","content":"在特朗普5月中访华后的外交语境中，台湾是否正从一个“战略资产”被重构为“谈判筹码”？据《费加罗报》驻台北记者的报道分析，在结束中国之行后，特朗普这位共和党籍总统一言否定了四十多年来的美国外交政策。在这个一直依赖美国保护的岛屿上，主张民主自治的派别与主张与北京靠拢的派别正展开激烈对抗。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260522-%E8%B0%81%E6%9D%A5%E5%86%B3%E5%AE%9A-%E5%8F%B0%E6%B9%BE%E6%9C%AA%E6%9D%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779432496000.webp","sourceId":"rfi"},{"id":1779491804000,"createdDate":"2026-05-22 23:16","name":"法国国际广播电台","title":"中东：伊朗与美国之间的分歧依然“深刻”，核谈判仍处于停滞状态","content":"巴基斯坦军方最高领导人阿西姆·穆尼尔周五抵达德黑兰，继续寻求解决美伊冲突的方案。但伊朗对近期达成协议的预期有所降低。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260522-%E4%B8%AD%E4%B8%9C-%E4%BC%8A%E6%9C%97%E4%B8%8E%E7%BE%8E%E5%9B%BD%E4%B9%8B%E9%97%B4%E7%9A%84%E5%88%86%E6%AD%A7%E4%BE%9D%E7%84%B6-%E6%B7%B1%E5%88%BB-%EF%BC%8C%E6%A0%B8%E8%B0%88%E5%88%A4%E4%BB%8D%E5%A4%84%E4%BA%8E%E5%81%9C%E6%BB%9E%E7%8A%B6%E6%80%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779491804000.webp","sourceId":"rfi"},{"id":1779491582000,"createdDate":"2026-05-22 23:13","name":"法国国际广播电台","title":"巴基斯坦“第一强人”：阿西姆·穆尼尔是谁？","content":"根据伊朗媒体的报道，巴基斯坦军方最高领导人阿西姆·穆尼尔（AsimMunir）周五抵达伊朗首都德黑兰，以便继续推动美伊冲突的和平斡旋工作。美国国务卿鲁比奥周四曾表示，希望穆尼尔此行能够“推动局势取得进展”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260522-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6-%E7%AC%AC%E4%B8%80%E5%BC%BA%E4%BA%BA-%E9%98%BF%E8%A5%BF%E5%A7%86%C2%B7%E7%A9%86%E5%B0%BC%E5%B0%94%E6%98%AF%E8%B0%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779491582000.webp","sourceId":"rfi"},{"id":1779489221000,"createdDate":"2026-05-22 22:33","name":"法国国际广播电台","title":"戛纳影节进入尾声 各竞赛单元获奖名单陆续出台","content":"戛纳影节已经进入尾声，在主竞赛单元获奖名单宣布前两天，影节官方单元陆续宣布了各自的获奖名单，周五晚间“一种关注”单元颁奖典礼在戛纳电影宫的德彪西礼堂举行。此前一天，专门奖励短片和学生电影作品的“电影基石”单元则在布努埃尔礼堂举行了颁奖礼。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260522-%E6%88%9B%E7%BA%B3%E5%BD%B1%E8%8A%82%E8%BF%9B%E5%85%A5%E5%B0%BE%E5%A3%B0-%E5%90%84%E7%AB%9E%E8%B5%9B%E5%8D%95%E5%85%83%E8%8E%B7%E5%A5%96%E5%90%8D%E5%8D%95%E9%99%86%E7%BB%AD%E5%87%BA%E5%8F%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779489221000.webp","sourceId":"rfi"},{"id":1779485496000,"createdDate":"2026-05-22 21:31","name":"法国国际广播电台","title":"[法语世界]与2026年戛纳电影节","content":"法国国际广播电台（RadioFranceInternationale）中文节目[法语世界]（Chroniquefrancophonie）专栏2026年05月22日星期五第156集。今天是一次特别节目，简介入选2026年第79届戛纳电影节（FestivaldeCannes）[一种关注]单元（Uncertainregard）的三部获[法语国家及地区国际组织]（OIF）赞助影片，尤其是讲述刚果难民故事的中非共和国（Républiquecentrafricaine）影片[刚果男孩]（CongoBoy）。本台法广（RFI）法语记者采访了这部非洲影片的导演，出生于刚果民主共和国基伍地区（Kivu）的拉飞奇·法里亚拉（RafikiFariala）。在非洲斯瓦西里语（Swahili）中，拉飞奇（Rafiki）是[朋友]的意思。另外，还有对这部影片青年男主角BradelyFiomona的采访录音片段。这集节目由尼古拉编译和播报，感谢收听。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C/20260522-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C-%E7%AC%AC156%E9%9B%86-2026%E5%B9%B4%E6%88%9B%E7%BA%B3%E7%94%B5%E5%BD%B1%E8%8A%82%E7%89%B9%E5%88%AB%E8%8A%82%E7%9B%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779485496000.webp","sourceId":"rfi"},{"id":1779477385000,"createdDate":"2026-05-22 19:16","name":"法国国际广播电台","title":"亲特朗普、涉以色列“黑立方”风波，争议“推特元帅”第四次出任斯洛文尼亚总理引震动","content":"斯洛文尼亚议会5月22日批准右翼政治人物扬沙出任候任总理。这位67岁的政坛老将由此第四次担任该国政府首脑，也意味着这个巴尔干国家在内政与外交方向上即将迎来明显变化。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260522-%E4%BA%B2%E7%89%B9%E6%9C%97%E6%99%AE-%E6%B6%89%E4%BB%A5%E8%89%B2%E5%88%97-%E9%BB%91%E7%AB%8B%E6%96%B9-%E9%A3%8E%E6%B3%A2%EF%BC%8C%E4%BA%89%E8%AE%AE-%E6%8E%A8%E7%89%B9%E5%85%83%E5%B8%85-%E7%AC%AC%E5%9B%9B%E6%AC%A1%E5%87%BA%E4%BB%BB%E6%96%AF%E6%B4%9B%E6%96%87%E5%B0%BC%E4%BA%9A%E6%80%BB%E7%90%86%E5%BC%95%E9%9C%87%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779477385000.webp","sourceId":"rfi"},{"id":1779476536000,"createdDate":"2026-05-22 19:02","name":"法国国际广播电台","title":"鲁比奥敦促北约盟国正视美国在欧洲削减驻军的现实","content":"美国国务卿鲁比奥周五敦促北约盟国正视美国在欧洲削减驻军的现实。法新社说，鲁比奥暗示，华盛顿很快还将宣布削减其在紧急情况下向北约派遣的部队数量。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260522-%E9%B2%81%E6%AF%94%E5%A5%A5%E6%95%A6%E4%BF%83%E5%8C%97%E7%BA%A6%E7%9B%9F%E5%9B%BD%E6%AD%A3%E8%A7%86%E7%BE%8E%E5%9B%BD%E5%9C%A8%E6%AC%A7%E6%B4%B2%E5%89%8A%E5%87%8F%E9%A9%BB%E5%86%9B%E7%9A%84%E7%8E%B0%E5%AE%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779476536000.webp","sourceId":"rfi"},{"id":1779476520000,"createdDate":"2026-05-22 19:02","name":"法国国际广播电台","title":"欧盟各国正着手对封锁霍尔木兹海峡的伊朗官员及其他相关人员实施制裁","content":"欧盟周五表示，欧盟各国正着手对封锁霍尔木兹海峡的伊朗官员及其他相关人员实施制裁。德黑兰实际上关闭了这条全球天然气和石油运输的关键航道，以报复美国和以色列2月份发动的空袭。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260522-%E6%AC%A7%E7%9B%9F%E5%90%84%E5%9B%BD%E6%AD%A3%E7%9D%80%E6%89%8B%E5%AF%B9%E5%B0%81%E9%94%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%9A%84%E4%BC%8A%E6%9C%97%E5%AE%98%E5%91%98%E5%8F%8A%E5%85%B6%E4%BB%96%E7%9B%B8%E5%85%B3%E4%BA%BA%E5%91%98%E5%AE%9E%E6%96%BD%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779476520000.webp","sourceId":"rfi"},{"id":1779476459000,"createdDate":"2026-05-22 19:00","name":"法国国际广播电台","title":"几千抗议者聚集在哈瓦那美国大使馆前，声援被美国起诉的前总统劳尔·卡斯特罗","content":"法新社报道，周五，数千名挥舞着古巴国旗的抗议者聚集在哈瓦那美国大使馆前，声援被美国起诉的前总统劳尔·卡斯特罗。“劳尔万岁！”人群高呼口号，其中包括身着军装的古巴现任总统和其他高级官员。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260522-%E5%87%A0%E5%8D%83%E6%8A%97%E8%AE%AE%E8%80%85%E8%81%9A%E9%9B%86%E5%9C%A8%E5%93%88%E7%93%A6%E9%82%A3%E7%BE%8E%E5%9B%BD%E5%A4%A7%E4%BD%BF%E9%A6%86%E5%89%8D%EF%BC%8C%E5%A3%B0%E6%8F%B4%E8%A2%AB%E7%BE%8E%E5%9B%BD%E8%B5%B7%E8%AF%89%E7%9A%84%E5%89%8D%E6%80%BB%E7%BB%9F%E5%8A%B3%E5%B0%94%C2%B7%E5%8D%A1%E6%96%AF%E7%89%B9%E7%BD%97","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779476459000.webp","sourceId":"rfi"},{"id":1779474740000,"createdDate":"2026-05-22 18:32","name":"法国国际广播电台","title":"特朗普政府新规 临时签证持有人须返国申请绿卡","content":"美国总统特朗普（DonaldTrump）政府再度收紧移民政策。美国公民及移民服务局（USCIS）22日宣布，未来大多数持临时签证、并已在美国合法居留的人士，若希望申请永久居留权“绿卡”，必须返回原籍国，透过美国驻外领事馆办理申请，而不能再像过去数十年般，直接在美国境内调整身份。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260522-%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E6%96%B0%E8%A7%84-%E4%B8%B4%E6%97%B6%E7%AD%BE%E8%AF%81%E6%8C%81%E6%9C%89%E4%BA%BA%E9%A1%BB%E8%BF%94%E5%9B%BD%E7%94%B3%E8%AF%B7%E7%BB%BF%E5%8D%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779474740000.webp","sourceId":"rfi"},{"id":1779474562000,"createdDate":"2026-05-22 18:29","name":"法国国际广播电台","title":"卢比奥：美国已暂时中止俄乌美三边谈判机制","content":"美国国务卿卢比奥5月22日在瑞典出席北约外长会议期间表示，围绕乌克兰问题展开的相关和平谈判目前已陷入停滞，美国暂时中止了与乌克兰和俄罗斯之间的三边谈判机制。不过，他同时表示，如果未来出现“建设性且富有成果”的对话机会，华盛顿仍愿继续充当调解方。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260522-%E5%8D%A2%E6%AF%94%E5%A5%A5-%E7%BE%8E%E5%9B%BD%E5%B7%B2%E6%9A%82%E6%97%B6%E4%B8%AD%E6%AD%A2%E4%BF%84%E4%B9%8C%E7%BE%8E%E4%B8%89%E8%BE%B9%E8%B0%88%E5%88%A4%E6%9C%BA%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779474562000.webp","sourceId":"rfi"}]