[{"id":1779408267000,"createdDate":"2026-05-22 00:04","name":"法国国际广播电台","title":"Katàbasis荣获第79届戛纳电影节最佳沉浸式作品奖","content":"在第79届戛纳影节沉浸式单元中，由法国导演乌果·阿尔萨克（UgoArsac）创作的互动纪录片《卡塔巴西斯（Katàbasis）》荣获“最佳沉浸式作品奖”。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260522-kat%C3%A0basis%E8%8D%A3%E8%8E%B7%E7%AC%AC79%E5%B1%8A%E6%88%9B%E7%BA%B3%E7%94%B5%E5%BD%B1%E8%8A%82%E6%9C%80%E4%BD%B3%E6%B2%89%E6%B5%B8%E5%BC%8F%E4%BD%9C%E5%93%81%E5%A5%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779408267000.webp","sourceId":"rfi"},{"id":1779439017000,"createdDate":"2026-05-22 08:36","name":"法国国际广播电台","title":"回归以来首次 香港全体立法会议员7月到北京研修考察","content":"香港立法会主席李慧琼周四通过社交媒体宣布，“全体议员将于今年7月19日至25日，到北京参加国家事务研修考察”，并指“这将是香港自回归祖国以来，首次全体议员到北京研修考察，历史意义重大”。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260522-%E5%9B%9E%E5%BD%92%E4%BB%A5%E6%9D%A5%E9%A6%96%E6%AC%A1-%E9%A6%99%E6%B8%AF%E5%85%A8%E4%BD%93%E7%AB%8B%E6%B3%95%E4%BC%9A%E8%AE%AE%E5%91%987%E6%9C%88%E5%88%B0%E5%8C%97%E4%BA%AC%E7%A0%94%E4%BF%AE%E8%80%83%E5%AF%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779439017000.webp","sourceId":"rfi"},{"id":1779438533000,"createdDate":"2026-05-22 08:28","name":"法国国际广播电台","title":"涉嫌向中国走私英伟达芯片 三名台湾人被拘留调查","content":"台湾检察机关周五（5月22日）表示，三名台湾人因违反出口限制，走私英伟达人工智能芯片至中国而被起诉。中国外交部发言人当天就相关提问回应表示，“这不是一个外交问题，不了解相关情况”。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260522-%E6%B6%89%E5%AB%8C%E5%90%91%E4%B8%AD%E5%9B%BD%E8%B5%B0%E7%A7%81%E5%86%85%E7%BD%AE%E8%8B%B1%E4%BC%9F%E8%BE%BE%E8%8A%AF%E7%89%87%E7%9A%84ai%E4%BC%BA%E6%9C%8D%E5%99%A8-%E4%B8%89%E5%90%8D%E5%8F%B0%E6%B9%BE%E4%BA%BA%E8%A2%AB%E5%8F%B8%E6%B3%95%E5%A3%B0%E6%8A%BC%E8%B5%B7%E8%AF%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779438533000.webp","sourceId":"rfi"},{"id":1779437957000,"createdDate":"2026-05-22 08:19","name":"法国国际广播电台","title":"《台湾：面对中国的民主》：一本终结刻板印象的著作","content":"法国天主教媒体《十字架报》周四在国际版登出卡米耶·里希尔撰写的书评称，在《台湾：面对中国的民主》一书中，汉学家让-皮埃尔·卡贝斯坦回顾了这座被北京声索主权的岛屿的历史及其独特的政治体制。他为我们提供了一部非常详尽的导论，以帮助读者理解围绕这一年轻民主政体的各种辩论与挑战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260522-%E5%8F%B0%E6%B9%BE%E9%9D%A2%E5%AF%B9%E4%B8%AD%E5%9B%BD-%E4%B8%80%E6%9C%AC%E7%BB%88%E7%BB%93%E5%88%BB%E6%9D%BF%E5%8D%B0%E8%B1%A1%E7%9A%84%E8%91%97%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779437957000.webp","sourceId":"rfi"},{"id":1779435309000,"createdDate":"2026-05-22 07:35","name":"法国国际广播电台","title":"《黑色珠子》—— 角逐金棕榈的三部西班牙影片中最后一部亮相戛纳","content":"戛纳影节第九天，主竞赛单元放映了西班牙电影《黑色珠子》。这是入围角逐金棕榈的三部西班牙影片中最后亮相影节的一部。影片的导演是此前并不为国际影坛熟知的西班牙年轻导演组合哈维尔·安布罗西与哈维尔·卡尔沃。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260522-%E9%BB%91%E8%89%B2%E7%8F%A0%E5%AD%90-%E8%A7%92%E9%80%90%E9%87%91%E6%A3%95%E6%A6%88%E7%9A%84%E4%B8%89%E9%83%A8%E8%A5%BF%E7%8F%AD%E7%89%99%E5%BD%B1%E7%89%87%E4%B8%AD%E6%9C%80%E5%90%8E%E4%B8%80%E9%83%A8%E4%BA%AE%E7%9B%B8%E6%88%9B%E7%BA%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779435309000.webp","sourceId":"rfi"},{"id":1779432998000,"createdDate":"2026-05-22 06:56","name":"法国国际广播电台","title":"香港反恐首案两主脑资产遭充公 同案脱罪者被指助众筹同遭殃","content":"2019年反修例运动期间组成的示威者组织「屠龙小队」，因涉及策划杀警等行动，港府首次引用可判囚终身的《反恐条例》提出检控，案中两名主脑于2024年分别被法庭重判。港府近日再向法庭申请充公二人财产，并以曾协助众筹为由，要求充公经审讯的同案脱罪者名下资产，同样获批。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260522-%E9%A6%99%E6%B8%AF%E5%8F%8D%E6%81%90%E9%A6%96%E6%A1%88%E4%B8%A4%E4%B8%BB%E8%84%91%E8%B5%84%E4%BA%A7%E9%81%AD%E5%85%85%E5%85%AC-%E5%90%8C%E6%A1%88%E8%84%B1%E7%BD%AA%E8%80%85%E8%A2%AB%E6%8C%87%E5%8A%A9%E4%BC%97%E7%AD%B9%E5%90%8C%E9%81%AD%E6%AE%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/22/1779432998000.webp","sourceId":"rfi"}]