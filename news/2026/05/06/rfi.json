[{"id":1778057938000,"createdDate":"2026-05-06 08:58","name":"法国国际广播电台","title":"基辅：乌克兰宣布停火期间 俄罗斯发动新一轮攻击","content":"乌克兰谴责俄罗斯在基辅单方面宣布停火后，在周二夜至周三凌晨动用“108架无人机和3枚导弹”对乌克兰多地发动新一轮袭击，导致至少1人死亡，3人受伤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260506-%E5%9F%BA%E8%BE%85-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%AE%A3%E5%B8%83%E5%81%9C%E7%81%AB%E6%9C%9F%E9%97%B4-%E4%BF%84%E7%BD%97%E6%96%AF%E5%8F%91%E5%8A%A8%E6%96%B0%E4%B8%80%E8%BD%AE%E6%94%BB%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778057938000.webp","sourceId":"rfi"},{"id":1778056442000,"createdDate":"2026-05-06 08:34","name":"法国国际广播电台","title":"印度瞄准半导体产业发力：批准超4亿美元新项目  计划到2030年国内市场规模达1100亿美元","content":"印度正加大力度发展半导体产业，力图成为全球强国。法新社周三（5月6日）消息称，印度政府宣布，已批准两个总价值超过390亿卢比（约合3.5亿欧元，4.1亿美元）的半导体项目。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260506-%E5%8D%B0%E5%BA%A6%E7%9E%84%E5%87%86%E5%8D%8A%E5%AF%BC%E4%BD%93%E4%BA%A7%E4%B8%9A%E5%8F%91%E5%8A%9B-%E6%89%B9%E5%87%86%E8%B6%854%E4%BA%BF%E7%BE%8E%E5%85%83%E6%96%B0%E9%A1%B9%E7%9B%AE-%E8%AE%A1%E5%88%92%E5%88%B02030%E5%B9%B4%E5%9B%BD%E5%86%85%E5%B8%82%E5%9C%BA%E8%A7%84%E6%A8%A1%E8%BE%BE1100%E4%BA%BF%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778056442000.webp","sourceId":"rfi"},{"id":1778052344000,"createdDate":"2026-05-06 07:25","name":"法国国际广播电台","title":"香港首季GDP增5.9% 五年高位 惟料中东冲突影响将现","content":"面对中东局势紧张，香港首季本地生产总值(GDP）预估按年增长5.9%，远高於市场预期，并创下2021年第二季以来的季度最高增幅。对此，港府发言人表示，香港经济增长前景正面，但中东局势持续紧张构成下行风险；综合分析师和学者评论，中东局势对通胀和外贸等方面造成的负面影响，或会在未来一丶两个季度浮现，但首季的良好表现，如无意外可带来财富效应，改善消费，部分银行更上调全年GDP目标，朝着港府预期目标2.5%至3.5%的上限靠拢。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260506-%E9%A6%99%E6%B8%AF%E9%A6%96%E5%AD%A3gdp%E5%A2%9E5-9-%E4%BA%94%E5%B9%B4%E9%AB%98%E4%BD%8D-%E6%83%9F%E6%96%99%E4%B8%AD%E4%B8%9C%E5%86%B2%E7%AA%81%E5%BD%B1%E5%93%8D%E5%B0%86%E7%8E%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778052344000.webp","sourceId":"rfi"},{"id":1778052109000,"createdDate":"2026-05-06 07:21","name":"法国国际广播电台","title":"五一黄金周逾100万陆客涌港 业界称丁财两旺 惟生态破坏未息","content":"人中国内地一连五日的五一黄金周假期结束，官方数据颢示，共有101.1万人次内地旅客入境香港，较去年同期升约一成，是连续三年上升。酒店及旅游业因此受惠，期间房价虽较平日上升一成至一成半，仍能有九成的入住率。不过，内地游客「穷游」和对海岸公园生态的破坏，却引来不少怨怼。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260506-%E4%BA%94%E4%B8%80%E9%BB%84%E9%87%91%E5%91%A8%E9%80%BE100%E4%B8%87%E9%99%86%E5%AE%A2%E6%B6%8C%E6%B8%AF-%E4%B8%9A%E7%95%8C%E7%A7%B0%E4%B8%81%E8%B4%A2%E4%B8%A4%E6%97%BA-%E6%83%9F%E7%94%9F%E6%80%81%E7%A0%B4%E5%9D%8F%E6%9C%AA%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778052109000.webp","sourceId":"rfi"},{"id":1778051321000,"createdDate":"2026-05-06 07:08","name":"法国国际广播电台","title":"朝鲜放弃祖国统一 修宪删除与韩国统一条款","content":"据法新社周三获得的一份文件显示，朝鲜已将其宪法中关于与韩国统一的表述删除，这反映出其对首尔采取了更具敌意的立场。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260506-%E6%9C%9D%E9%B2%9C%E6%94%BE%E5%BC%83%E7%BB%9F%E4%B8%80%EF%BC%8C%E4%BF%AE%E5%AE%AA%E5%88%A0%E9%99%A4%E4%B8%8E%E9%9F%A9%E5%9B%BD%E7%BB%9F%E4%B8%80%E6%9D%A1%E6%AC%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778051321000.webp","sourceId":"rfi"}]