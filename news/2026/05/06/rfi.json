[{"id":1778057938000,"createdDate":"2026-05-06 08:58","name":"法国国际广播电台","title":"基辅：乌克兰宣布停火期间 俄罗斯发动新一轮攻击","content":"乌克兰谴责俄罗斯在基辅单方面宣布停火后，在周二夜至周三凌晨动用“108架无人机和3枚导弹”对乌克兰多地发动新一轮袭击，导致至少1人死亡，3人受伤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260506-%E5%9F%BA%E8%BE%85-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%AE%A3%E5%B8%83%E5%81%9C%E7%81%AB%E6%9C%9F%E9%97%B4-%E4%BF%84%E7%BD%97%E6%96%AF%E5%8F%91%E5%8A%A8%E6%96%B0%E4%B8%80%E8%BD%AE%E6%94%BB%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778057938000.webp","sourceId":"rfi"},{"id":1778056442000,"createdDate":"2026-05-06 08:34","name":"法国国际广播电台","title":"印度瞄准半导体产业发力：批准超4亿美元新项目  计划到2030年国内市场规模达1100亿美元","content":"印度正加大力度发展半导体产业，力图成为全球强国。法新社周三（5月6日）消息称，印度政府宣布，已批准两个总价值超过390亿卢比（约合3.5亿欧元，4.1亿美元）的半导体项目。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260506-%E5%8D%B0%E5%BA%A6%E7%9E%84%E5%87%86%E5%8D%8A%E5%AF%BC%E4%BD%93%E4%BA%A7%E4%B8%9A%E5%8F%91%E5%8A%9B-%E6%89%B9%E5%87%86%E8%B6%854%E4%BA%BF%E7%BE%8E%E5%85%83%E6%96%B0%E9%A1%B9%E7%9B%AE-%E8%AE%A1%E5%88%92%E5%88%B02030%E5%B9%B4%E5%9B%BD%E5%86%85%E5%B8%82%E5%9C%BA%E8%A7%84%E6%A8%A1%E8%BE%BE1100%E4%BA%BF%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778056442000.webp","sourceId":"rfi"},{"id":1778052344000,"createdDate":"2026-05-06 07:25","name":"法国国际广播电台","title":"香港首季GDP增5.9% 五年高位 惟料中东冲突影响将现","content":"面对中东局势紧张，香港首季本地生产总值(GDP）预估按年增长5.9%，远高於市场预期，并创下2021年第二季以来的季度最高增幅。对此，港府发言人表示，香港经济增长前景正面，但中东局势持续紧张构成下行风险；综合分析师和学者评论，中东局势对通胀和外贸等方面造成的负面影响，或会在未来一丶两个季度浮现，但首季的良好表现，如无意外可带来财富效应，改善消费，部分银行更上调全年GDP目标，朝着港府预期目标2.5%至3.5%的上限靠拢。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260506-%E9%A6%99%E6%B8%AF%E9%A6%96%E5%AD%A3gdp%E5%A2%9E5-9-%E4%BA%94%E5%B9%B4%E9%AB%98%E4%BD%8D-%E6%83%9F%E6%96%99%E4%B8%AD%E4%B8%9C%E5%86%B2%E7%AA%81%E5%BD%B1%E5%93%8D%E5%B0%86%E7%8E%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778052344000.webp","sourceId":"rfi"},{"id":1778052109000,"createdDate":"2026-05-06 07:21","name":"法国国际广播电台","title":"五一黄金周逾100万陆客涌港 业界称丁财两旺 惟生态破坏未息","content":"人中国内地一连五日的五一黄金周假期结束，官方数据颢示，共有101.1万人次内地旅客入境香港，较去年同期升约一成，是连续三年上升。酒店及旅游业因此受惠，期间房价虽较平日上升一成至一成半，仍能有九成的入住率。不过，内地游客「穷游」和对海岸公园生态的破坏，却引来不少怨怼。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260506-%E4%BA%94%E4%B8%80%E9%BB%84%E9%87%91%E5%91%A8%E9%80%BE100%E4%B8%87%E9%99%86%E5%AE%A2%E6%B6%8C%E6%B8%AF-%E4%B8%9A%E7%95%8C%E7%A7%B0%E4%B8%81%E8%B4%A2%E4%B8%A4%E6%97%BA-%E6%83%9F%E7%94%9F%E6%80%81%E7%A0%B4%E5%9D%8F%E6%9C%AA%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778052109000.webp","sourceId":"rfi"},{"id":1778051321000,"createdDate":"2026-05-06 07:08","name":"法国国际广播电台","title":"朝鲜放弃祖国统一 修宪删除与韩国统一条款","content":"据法新社周三获得的一份文件显示，朝鲜已将其宪法中关于与韩国统一的表述删除，这反映出其对首尔采取了更具敌意的立场。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260506-%E6%9C%9D%E9%B2%9C%E6%94%BE%E5%BC%83%E7%BB%9F%E4%B8%80%EF%BC%8C%E4%BF%AE%E5%AE%AA%E5%88%A0%E9%99%A4%E4%B8%8E%E9%9F%A9%E5%9B%BD%E7%BB%9F%E4%B8%80%E6%9D%A1%E6%AC%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778051321000.webp","sourceId":"rfi"},{"id":1778084803000,"createdDate":"2026-05-06 16:26","name":"法国国际广播电台","title":"法国货船在霍尔木兹海峡遭袭 戴高乐航母驶向亚丁湾 巴黎要求美伊单独处理海峡问题","content":"法国一艘集装箱船周二在霍尔木兹海峡受到袭击，法国戴高乐航母战斗群目前正驶向亚丁湾。同时巴黎呼吁美伊双方在谈判中将霍尔木兹海峡与其他问题分开处理。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260506-%E6%B3%95%E5%9B%BD%E8%B4%A7%E8%88%B9%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%81%AD%E8%A2%AD-%E6%88%B4%E9%AB%98%E4%B9%90%E8%88%AA%E6%AF%8D%E9%A9%B6%E5%90%91%E4%BA%9A%E4%B8%81%E6%B9%BE-%E5%B7%B4%E9%BB%8E%E8%A6%81%E6%B1%82%E7%BE%8E%E4%BC%8A%E5%8D%95%E7%8B%AC%E5%A4%84%E7%90%86%E6%B5%B7%E5%B3%A1%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778084803000.webp","sourceId":"rfi"},{"id":1778081819000,"createdDate":"2026-05-06 15:36","name":"法国国际广播电台","title":"G7贸易部长对稀土等经济胁迫深感担忧 同意采取更有力应对措施","content":"七国集团（G7）贸易部长周三对“经济胁迫”表示深切担忧，这种胁迫主要表现为对稀土出口的“任意限制”，并一致同意针对当前全球失衡问题采取更强有力的应对措施。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260506-g7%E8%B4%B8%E6%98%93%E9%83%A8%E9%95%BF%E5%AF%B9%E7%A8%80%E5%9C%9F%E7%AD%89%E7%BB%8F%E6%B5%8E%E8%83%81%E8%BF%AB%E6%B7%B1%E6%84%9F%E6%8B%85%E5%BF%A7-%E5%90%8C%E6%84%8F%E9%87%87%E5%8F%96%E6%9B%B4%E6%9C%89%E5%8A%9B%E5%BA%94%E5%AF%B9%E6%8E%AA%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778081819000.webp","sourceId":"rfi"},{"id":1778079076000,"createdDate":"2026-05-06 14:51","name":"法国国际广播电台","title":"一艘游轮出现汉坦病毒 已知8人感染3人死亡","content":"从阿根廷前往非洲西海岸佛得角的一艘游轮爆发致命汉坦病毒（hantavirus）感染，据介绍这种病毒可引起严重的肺部疾病。据世卫组织总干事表示，当前局势与新冠疫情初期并不“相似”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260506-%E4%B8%80%E8%89%98%E6%B8%B8%E8%BD%AE%E5%87%BA%E7%8E%B0%E6%B1%89%E5%9D%A6%E7%97%85%E6%AF%92-%E5%B7%B2%E7%9F%A58%E4%BA%BA%E6%84%9F%E6%9F%933%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778079076000.webp","sourceId":"rfi"},{"id":1778078791000,"createdDate":"2026-05-06 14:46","name":"法国国际广播电台","title":"中东危机对亚洲能源供给冲击将是菲律宾东盟峰会重要话题","content":"第48届东南亚国家联盟领导人峰会5月7日-8日在菲律宾城市宿务市举行。主办国自6日起已明显提升了警力部署。宿务市国际媒体中心附近主要街道和公共街区都有保安人员巡逻、盘查。鉴于持续两月有余的中东危机对亚洲地区能源供给带来的冲击，预计能源供给安全会是此次会议的重要议题。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260506-%E4%B8%AD%E4%B8%9C%E5%8D%B1%E6%9C%BA%E5%AF%B9%E4%BA%9A%E6%B4%B2%E8%83%BD%E6%BA%90%E4%BE%9B%E7%BB%99%E5%86%B2%E5%87%BB%E5%B0%86%E6%98%AF%E8%8F%B2%E5%BE%8B%E5%AE%BE%E4%B8%9C%E7%9B%9F%E5%B3%B0%E4%BC%9A%E9%87%8D%E8%A6%81%E8%AF%9D%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778078791000.webp","sourceId":"rfi"},{"id":1778077941000,"createdDate":"2026-05-06 14:32","name":"法国国际广播电台","title":"视频 俄罗斯回归  威尼斯双年展在紧张的气氛中开幕","content":"自2022年以来缺席威尼斯双年展的俄罗斯，今年首次重返，不过莫斯科馆不对公众开放，其展览仅在预展期间对媒体开放，请看France24报道。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260506-%E8%A7%86%E9%A2%91-%E4%BF%84%E7%BD%97%E6%96%AF%E5%9B%9E%E5%BD%92-%E5%A8%81%E5%B0%BC%E6%96%AF%E5%8F%8C%E5%B9%B4%E5%B1%95%E5%9C%A8%E7%B4%A7%E5%BC%A0%E7%9A%84%E6%B0%94%E6%B0%9B%E4%B8%AD%E5%BC%80%E5%B9%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778077941000.webp","sourceId":"rfi"},{"id":1778075985000,"createdDate":"2026-05-06 13:59","name":"法国国际广播电台","title":"特朗普访华：北京仍缄其口","content":"中央社北京6日电：北京至今尚未正式宣布美国总统川普（特朗普）来访事宜，中国外交部发言人林剑今天说，中美双方就此事保持沟通，并指中方会对推动荷莫兹海峡（霍尔木兹海峡）局势降温努力。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260506-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E-%E5%8C%97%E4%BA%AC%E4%BB%8D%E7%BC%84%E5%85%B6%E5%8F%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778075985000.webp","sourceId":"rfi"},{"id":1778072429000,"createdDate":"2026-05-06 13:00","name":"法国国际广播电台","title":"特朗普宣布“重大进展” 周三油价下跌 欧股飙涨","content":"唐纳德-特朗普周二在其“真相社交”平台写道：“鉴于巨大的军事成功”，以及“在与伊朗领导人达成最终全面协议方面取得的重大进展”，“护航的自由计划……将暂停一段时间，以观察协议能否最终敲定并签署”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260506-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AE%A3%E5%B8%83-%E9%87%8D%E5%A4%A7%E8%BF%9B%E5%B1%95-%E5%91%A8%E4%B8%89%E6%B2%B9%E4%BB%B7%E4%B8%8B%E8%B7%8C-%E6%AC%A7%E8%82%A1%E9%A3%99%E6%B6%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778072429000.webp","sourceId":"rfi"},{"id":1778071303000,"createdDate":"2026-05-06 12:41","name":"法国国际广播电台","title":"法国国家稀土计划有何内容？","content":"俄乌战争早已使欧洲各国意识到必须在能源领域减低对他国的依赖，伊朗战争尤其是弗尔姆兹海峡的封锁更使能源以及原材料自主成为各国政府的当务之急。除了石油天然气之外，遭到中国垄断的稀土早已成为西方国家的一大隐患。在这样的背景下，法国政府的经济与工业部长5月5日在访问法国西南部的比利牛斯大区时宣布了法国的“国家稀土计划”，并参观了正在建设中的凯尔马格工厂。该工厂将是欧洲首家稀土回收商。那么，法国的国家稀土计划有何具体内容？是否能够缓解对中国的稀土进口依赖？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260506-%E6%B3%95%E5%9B%BD%E5%9B%BD%E5%AE%B6%E7%A8%80%E5%9C%9F%E8%AE%A1%E5%88%92%E6%9C%89%E4%BD%95%E5%86%85%E5%AE%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778071303000.webp","sourceId":"rfi"},{"id":1778070935000,"createdDate":"2026-05-06 12:35","name":"法国国际广播电台","title":"视频 伊朗外长赶在“特习会”前到访北京","content":"“美国不断加强对德黑兰的制裁，这必然会影响到中国，最近有五家中国公司被列入交易禁令和资产冻结的黑名单。”在“特习会”前伊朗外长阿拉格齐本周抢先访问北京，请看法国24电视台驻北京记者李艺娜YenaLee报道解释道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260506-%E8%A7%86%E9%A2%91-%E4%BC%8A%E6%9C%97%E5%A4%96%E9%95%BF%E8%B5%B6%E5%9C%A8-%E7%89%B9%E4%B9%A0%E4%BC%9A-%E5%89%8D%E5%88%B0%E8%AE%BF%E5%8C%97%E4%BA%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778070935000.webp","sourceId":"rfi"},{"id":1778068860000,"createdDate":"2026-05-06 12:01","name":"法国国际广播电台","title":"Axios: 官员称美国和伊朗即将达成一页14点备忘录以结束战争","content":"Axios周三援引两名美国官员和另外两名知情人士透露，白宫认为，与伊朗就一份旨在结束冲突并为更详细的核谈判奠定框架的一页谅解备忘录，已接近达成协议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260506-axios-%E5%AE%98%E5%91%98%E7%A7%B0%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%BC%8A%E6%9C%97%E5%8D%B3%E5%B0%86%E8%BE%BE%E6%88%90%E4%B8%80%E9%A1%B514%E7%82%B9%E5%A4%87%E5%BF%98%E5%BD%95%E4%BB%A5%E7%BB%93%E6%9D%9F%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778068860000.webp","sourceId":"rfi"},{"id":1778066860000,"createdDate":"2026-05-06 11:27","name":"法国国际广播电台","title":"法媒指伊战迎来转折点：为结束冲突，中国采取行动了","content":"伊朗外长阿巴斯·阿拉格奇自战争爆发以来首次访问北京，并于周三6日与中国外长举行了会晤。据《回声报》驻上海记者拉斐尔·巴莱尼耶里发来报道说，中国正敦促伊朗尽快结束冲突。报道还提及，新华社网站同一天的标题是“习近平春季外交为动荡的世界注入稳定”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260506-%E6%B3%95%E5%AA%92%E6%8C%87%E4%BC%8A%E6%88%98%E8%BF%8E%E6%9D%A5%E8%BD%AC%E6%8A%98%E7%82%B9-%E4%B8%BA%E7%BB%93%E6%9D%9F%E5%86%B2%E7%AA%81%EF%BC%8C%E4%B8%AD%E5%9B%BD%E9%87%87%E5%8F%96%E8%A1%8C%E5%8A%A8%E4%BA%86","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778066860000.webp","sourceId":"rfi"},{"id":1778065194000,"createdDate":"2026-05-06 10:59","name":"法国国际广播电台","title":"伊朗外长阿拉格奇访华，美国施压中国推动重新开放霍尔木兹海峡？","content":"伊朗外交部长阿拉格奇周三（5月6日）在北京会见了中国外长王毅，中国官方媒体消息显示，这是自美以对伊朗发动战争以来，阿拉格奇首次访问中国。一直以来，中国与伊朗保持着密切的经济和政治关系，因此在中东局势中拥有独特的影响力。那么中国的介入，是否会推动美伊谈判取得实质性进展呢？值得注意的是，特朗普预计于5月14日至15日访华，届时他将与中国国家主席习近平会晤。因此，今天中伊外长的会面又会对即将到来的特习会有什么影响呢？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260506-%E4%BC%8A%E6%9C%97%E5%A4%96%E9%95%BF%E9%98%BF%E6%8B%89%E6%A0%BC%E5%A5%87%E8%AE%BF%E5%8D%8E%EF%BC%8C%E7%BE%8E%E5%9B%BD%E6%96%BD%E5%8E%8B%E4%B8%AD%E5%9B%BD%E6%8E%A8%E5%8A%A8%E7%BE%8E%E4%BC%8A%E8%B0%88%E5%88%A4%E5%8F%96%E5%BE%97%E5%AE%9E%E8%B4%A8%E6%80%A7%E8%BF%9B%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778065194000.webp","sourceId":"rfi"},{"id":1778062074000,"createdDate":"2026-05-06 10:07","name":"法国国际广播电台","title":"梅朗雄媚华言论背后：受苦的永远是台湾","content":"大家好，今天5月6日法国全国性日报头版各有不同的关注焦点。右翼《费加罗报》重心摆在总统大选竞选资金筹措的难题，表示无论在政治领域还是其他领域，资金都是关键所在，一场总统竞选活动的开销至少需要1000万欧元。左翼《解放报》推出餐饮禽肉热潮的封面故事说，法国人从未像现在这样大量食用鸡肉。这一趋势得益于鸡肉价格亲民，并受到“MasterPoulet”和“TastyCrousty”等快餐连锁品牌蓬勃发展的推动。此外《解放报》亚太资深记者阿尔诺·沃勒兰在其专栏指出，日前在接受《Brut》杂志采访时，梅朗雄这位“法兰西不屈服”党的总统候选人针对台湾海峡两岸的关系，接连抛出无谓的类比和牵强的臆断，其言论无非是照搬北京方面的说辞。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260506-%E6%A2%85%E6%9C%97%E9%9B%84%E5%AA%9A%E5%8D%8E%E8%A8%80%E8%AE%BA%E8%83%8C%E5%90%8E-%E5%8F%97%E8%8B%A6%E7%9A%84%E6%B0%B8%E8%BF%9C%E6%98%AF%E5%8F%B0%E6%B9%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778062074000.webp","sourceId":"rfi"},{"id":1778061047000,"createdDate":"2026-05-06 09:50","name":"法国国际广播电台","title":"台湾外交在中国压力下持续突围 赖清德亲访非洲友邦的重要性","content":"出访友邦斯威士兰本是一个台湾总统例行行程，却因出奇制胜的外交手段突破中共封锁而突然得到不少国际媒体关注，并称「两岸在非洲小国比拼意志力，台湾智取中国」。但这样所谓的秘密抵达事后宣布ATA模式将成台湾外交新常态？赖总统为何坚持非得亲访非洲友邦斯威士兰？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260506-%E5%8F%B0%E6%B9%BE%E5%A4%96%E4%BA%A4%E5%9C%A8%E4%B8%AD%E5%9B%BD%E5%8E%8B%E5%8A%9B%E4%B8%8B%E6%8C%81%E7%BB%AD%E7%AA%81%E5%9B%B4-%E8%B5%96%E6%B8%85%E5%BE%B7%E4%BA%B2%E8%AE%BF%E9%9D%9E%E6%B4%B2%E5%8F%8B%E9%82%A6%E7%9A%84%E9%87%8D%E8%A6%81%E6%80%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778061047000.webp","sourceId":"rfi"},{"id":1778060955000,"createdDate":"2026-05-06 09:49","name":"法国国际广播电台","title":"日本经产大臣访问中东谋求原油  日本称进口俄罗斯原油已与美方磋商","content":"日本经济产业大臣赤泽亮正，在中东局势日趋紧张的背景下，访问了沙特阿拉伯和阿联酋（UAE），于5日确认了与两国在稳定原油供应方面展开合作。另据报道，5月5日，装载俄罗斯原油的油轮“航行者号”（Voyager）停靠在日本爱媛县今治市的一处石油设施，并开始卸货。这是霍尔木兹海峡封锁后，日本首次进口俄罗斯原油。日本经济产业省相关负责人表示：进口俄罗斯原油“已与美方协调，并确认不存在制裁风险。”","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260506-%E6%97%A5%E6%9C%AC%E7%BB%8F%E4%BA%A7%E5%A4%A7%E8%87%A3%E8%AE%BF%E9%97%AE%E4%B8%AD%E4%B8%9C%E8%B0%8B%E6%B1%82%E5%8E%9F%E6%B2%B9-%E6%97%A5%E6%9C%AC%E7%A7%B0%E8%BF%9B%E5%8F%A3%E4%BF%84%E7%BD%97%E6%96%AF%E5%8E%9F%E6%B2%B9%E5%B7%B2%E4%B8%8E%E7%BE%8E%E6%96%B9%E7%A3%8B%E5%95%86","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778060955000.webp","sourceId":"rfi"},{"id":1778108030000,"createdDate":"2026-05-06 22:53","name":"法国国际广播电台","title":"转播权谈不拢 中国球迷担心错过美加墨世界杯","content":"距离美加墨世界杯开赛只剩一月，中国央视仍未与国际足联关于世界杯转播权达成共识。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260506-%E8%BD%AC%E6%92%AD%E6%9D%83%E8%B0%88%E4%B8%8D%E6%8B%A2-%E4%B8%AD%E5%9B%BD%E7%90%83%E8%BF%B7%E6%8B%85%E5%BF%83%E9%94%99%E8%BF%87%E7%BE%8E%E5%8A%A0%E5%A2%A8%E4%B8%96%E7%95%8C%E6%9D%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778108030000.webp","sourceId":"rfi"},{"id":1778106594000,"createdDate":"2026-05-06 22:29","name":"法国国际广播电台","title":"特朗普访华前伊朗战事能终结吗","content":"美国总统特朗普访华行程逼近，虽然中方尚未官宣，美军4架运输机已提早飞赴北京，卸下先遣物资，这似乎显示此行不可逆了 !","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260506-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E5%89%8D%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%8B%E8%83%BD%E7%BB%88%E7%BB%93%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778106594000.webp","sourceId":"rfi"},{"id":1778103875000,"createdDate":"2026-05-06 21:44","name":"法国国际广播电台","title":"特朗普称伊朗战事可能在他访华前结束","content":"美国总统唐纳德·特朗普（DonaldTrump）6日表示，美国与伊朗达成协议“机会非常大”，甚至可能在他下周出访中国前敲定协议。不过他同时警告，若谈判破裂，美方将恢复大规模军事打击，显示外交与军事压力并行的策略仍在持续。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260506-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%8B%E5%8F%AF%E8%83%BD%E5%9C%A8%E4%BB%96%E8%AE%BF%E5%8D%8E%E5%89%8D%E7%BB%93%E6%9D%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778103875000.webp","sourceId":"rfi"},{"id":1778103820000,"createdDate":"2026-05-06 21:43","name":"法国国际广播电台","title":"中国商会：欧盟禁用中企电信设备或面临3678亿欧元损失","content":"代表中国企业在欧洲利益的中国欧盟商会周三(5月6日）公布的一项研究称，如果欧盟按照布鲁塞尔提出的方案，将中国电信设备供应商排除出欧洲市场，欧盟27国到2030年可能面临高达3678亿欧元的累计经济损失。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260506-%E4%B8%AD%E5%9B%BD%E5%95%86%E4%BC%9A-%E6%AC%A7%E7%9B%9F%E7%A6%81%E7%94%A8%E4%B8%AD%E4%BC%81%E7%94%B5%E4%BF%A1%E8%AE%BE%E5%A4%87%E6%88%96%E6%8D%9F%E5%A4%B13678%E4%BA%BF%E6%AC%A7%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778103820000.webp","sourceId":"rfi"},{"id":1778103605000,"createdDate":"2026-05-06 21:40","name":"法国国际广播电台","title":"汉坦病毒：载有患者的医疗专机抵达荷兰 欧洲疾控中心：疫情仍存“诸多不确定性”","content":"一架载有汉坦病毒感染乘客的医疗专机周三（5月6日）晚抵达荷兰阿姆斯特丹。此前，荷兰籍极地探险邮轮“洪迪厄斯”号（MVHondius）在佛得角附近海域暴发汉坦病毒疫情，并展开紧急医疗转运行动。欧洲疾病预防与控制中心（ECDC）当天警告称，此次疫情仍存在“诸多不确定性”，但强调汉坦病毒对欧洲普通民众构成的整体风险“仍然非常低”，现阶段预计不会出现大范围传播。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260506-%E6%B1%89%E5%9D%A6%E7%97%85%E6%AF%92-%E8%BD%BD%E6%9C%89%E6%82%A3%E8%80%85%E7%9A%84%E5%8C%BB%E7%96%97%E4%B8%93%E6%9C%BA%E6%8A%B5%E8%BE%BE%E8%8D%B7%E5%85%B0-%E6%AC%A7%E6%B4%B2%E7%96%BE%E6%8E%A7%E4%B8%AD%E5%BF%83-%E7%96%AB%E6%83%85%E4%BB%8D%E5%AD%98-%E8%AF%B8%E5%A4%9A%E4%B8%8D%E7%A1%AE%E5%AE%9A%E6%80%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778103605000.webp","sourceId":"rfi"},{"id":1778103357000,"createdDate":"2026-05-06 21:35","name":"法国国际广播电台","title":"法国派遣“戴高乐”号航母前往红海 马克龙呼吁伊朗把握“机会窗口”","content":"法国军方周三(5月6日）宣布，法国海军“戴高乐”号航空母舰战斗群已穿越苏伊士运河，正驶往亚丁湾，为法国与英国推动的霍尔木兹海峡多国安全倡议进行预部署。法国总统马克龙呼吁伊朗把握霍尔木兹海峡“机会窗口”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260506-%E6%B3%95%E5%9B%BD%E6%B4%BE%E9%81%A3-%E6%88%B4%E9%AB%98%E4%B9%90-%E5%8F%B7%E8%88%AA%E6%AF%8D%E5%89%8D%E5%BE%80%E7%BA%A2%E6%B5%B7-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%91%BC%E5%90%81%E4%BC%8A%E6%9C%97%E6%8A%8A%E6%8F%A1-%E6%9C%BA%E4%BC%9A%E7%AA%97%E5%8F%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778103357000.webp","sourceId":"rfi"},{"id":1778102991000,"createdDate":"2026-05-06 21:29","name":"法国国际广播电台","title":"特朗普：与伊朗“非常可能”达成协议 伊朗评估美国新提案","content":"美国总统特朗普周三(5月6日）表示，与伊朗达成和平协议“非常可能”，但同时继续以恢复轰炸相威胁。伊朗称，正研究美国提出的新方案。路透社援引多名消息人士透露，华盛顿与德黑兰正接近达成一份“一页纸”备忘录，以结束当前海湾地区冲突，而包括伊朗核计划在内的棘手问题将留待后续谈判处理。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260506-%E7%89%B9%E6%9C%97%E6%99%AE-%E4%B8%8E%E4%BC%8A%E6%9C%97-%E9%9D%9E%E5%B8%B8%E5%8F%AF%E8%83%BD-%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE-%E4%BC%8A%E6%9C%97%E8%AF%84%E4%BC%B0%E7%BE%8E%E5%9B%BD%E6%96%B0%E6%8F%90%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778102991000.webp","sourceId":"rfi"},{"id":1778094570000,"createdDate":"2026-05-06 19:09","name":"法国国际广播电台","title":"法国二战胜利日：印度支那士兵与法国本土女性的混血后代口述历史","content":"各位好，本期出刊的法国世界报头版关注点如下：法国总理勒科尔尼调整政策，应对中东战争对法国经济与政府预算造成的影响、特朗普暂停霍尔木兹海峡“自由航行”任务、法国政府调查委员会对法国公营广电集团的调查报告结果引发法国电视集团主席的谴责、卢浮宫新任负责人介绍其上任后的主要目标、俄罗斯指责人权捍卫者玛丽亚·伯恩茨勒为叛徒、法国政界不同派别为2027年总统选举做准备等。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260506-%E6%B3%95%E5%9B%BD%E4%BA%8C%E6%88%98%E8%83%9C%E5%88%A9%E6%97%A5-%E5%8D%B0%E5%BA%A6%E6%94%AF%E9%82%A3%E5%A3%AB%E5%85%B5%E4%B8%8E%E6%B3%95%E5%9B%BD%E6%9C%AC%E5%9C%9F%E5%A5%B3%E6%80%A7%E7%9A%84%E6%B7%B7%E8%A1%80%E5%90%8E%E4%BB%A3%E5%8F%A3%E8%BF%B0%E5%8E%86%E5%8F%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778094570000.webp","sourceId":"rfi"},{"id":1778093384000,"createdDate":"2026-05-06 18:49","name":"法国国际广播电台","title":"西班牙政府同意爆发汉坦病毒的邮轮停靠，居民忧类似新冠情景再现","content":"西班牙加那利群岛正面临一起引发关注的公共卫生事件。“洪迪乌斯号”（MVHondius）豪华邮轮因暴发汉坦病毒疫情，自周日起滞留在佛得角附近海域。在疫情已造成3人死亡、多人感染或疑似感染的背景下，这艘船预计将于本周内驶达西班牙特内里费岛。此前，尽管当地政府提出抗议，但西班牙中央政府方面同意了世界卫生组织的请求，允许该船停靠。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260506-%E8%A5%BF%E7%8F%AD%E7%89%99%E6%94%BF%E5%BA%9C%E5%90%8C%E6%84%8F%E7%88%86%E5%8F%91%E6%B1%89%E5%A1%94%E7%97%85%E6%AF%92%E7%9A%84%E9%82%AE%E8%BD%AE%E5%81%9C%E9%9D%A0%EF%BC%8C%E5%B1%85%E6%B0%91%E5%BF%A7%E7%B1%BB%E4%BC%BC%E6%96%B0%E5%86%A0%E6%83%85%E6%99%AF%E5%86%8D%E7%8E%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/06/1778093384000.webp","sourceId":"rfi"}]