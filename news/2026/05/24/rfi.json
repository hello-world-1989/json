[{"id":1779583805000,"createdDate":"2026-05-24 00:50","name":"法国国际广播电台","title":"白宫检查站发生枪击，特朗普在白宫工作，枪手被击毙","content":"法新社报道，周六晚间，白宫附近发生枪击事件，警方和安保人员迅速包围了事发区域。当时美国总统特朗普正在白宫忙着准备与伊朗的谈判的事。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260524-%E7%99%BD%E5%AE%AB%E6%A3%80%E6%9F%A5%E7%AB%99%E5%8F%91%E7%94%9F%E6%9E%AA%E5%87%BB%EF%BC%8C%E7%89%B9%E6%9C%97%E6%99%AE%E5%9C%A8%E7%99%BD%E5%AE%AB%E5%B7%A5%E4%BD%9C%EF%BC%8C%E6%9E%AA%E6%89%8B%E8%A2%AB%E5%87%BB%E6%AF%99","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779583805000.webp","sourceId":"rfi"},{"id":1779581494000,"createdDate":"2026-05-24 00:11","name":"法国国际广播电台","title":"美国和伊朗高级官员表示：双方的协议草案的谈判接近取得突破","content":"美国和伊朗高级官员周六表示，双方的协议草案的谈判接近取得突破，但同时对结束中东战争的可能性仍持谨慎态度。美国总统特朗普周六还告诉美国媒体Axios，达成协议的可能性“五五开”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260524-%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%BC%8A%E6%9C%97%E9%AB%98%E7%BA%A7%E5%AE%98%E5%91%98%E8%A1%A8%E7%A4%BA-%E5%8F%8C%E6%96%B9%E7%9A%84%E5%8D%8F%E8%AE%AE%E8%8D%89%E6%A1%88%E7%9A%84%E8%B0%88%E5%88%A4%E6%8E%A5%E8%BF%91%E5%8F%96%E5%BE%97%E7%AA%81%E7%A0%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779581494000.webp","sourceId":"rfi"},{"id":1779613068000,"createdDate":"2026-05-24 08:57","name":"法国国际广播电台","title":"乌克兰：俄罗斯对基辅发动大规模袭击  含一超音速导弹","content":"周六（5月23日）至周日夜间，乌克兰首都及其周边地区遭到俄罗斯导弹和无人机的大规模协同攻击，其中包括一架超音速“奥列什尼克”中程导弹。初步统计死亡人数至少为4人，另有数十人受伤。早在周六晚间，乌克兰总统泽连斯基就曾警告称，俄罗斯即将发动大规模袭击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260524-%E4%B9%8C%E5%85%8B%E5%85%B0-%E4%BF%84%E7%BD%97%E6%96%AF%E5%AF%B9%E5%9F%BA%E8%BE%85%E5%8F%91%E5%8A%A8%E5%A4%A7%E8%A7%84%E6%A8%A1%E5%AF%BC%E5%BC%B9%E5%92%8C%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779613068000.webp","sourceId":"rfi"},{"id":1779609986000,"createdDate":"2026-05-24 08:06","name":"法国国际广播电台","title":"日媒披露：习近平在美中首脑会谈时批判高市早苗  特朗普反而赞扬高市","content":"据日本《读卖新闻》与日本电视台等媒体24日报道，在14日于北京举行的美中首脑会谈中，日中关系恶化成为议题之一。对于习近平主席点名批评高市首相，特朗普总统则对高市首相的领导能力给予肯定并加以维护。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260524-%E6%97%A5%E5%AA%92%E6%8A%AB%E9%9C%B2-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%9C%A8%E7%BE%8E%E4%B8%AD%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88%E6%97%B6%E6%89%B9%E5%88%A4%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%8D%E8%80%8C%E8%B5%9E%E6%89%AC%E9%AB%98%E5%B8%82","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779609986000.webp","sourceId":"rfi"},{"id":1779609818000,"createdDate":"2026-05-24 08:03","name":"法国国际广播电台","title":"中国如何用“网红外交”重塑全球年轻人认知","content":"世界报本期以大篇幅刊登了一则关于中国形象与国际网红的报道，题为“那些为中国政权服务的外国网红”。当中指出，为了改善在年轻人中的形象，中国正吸引那些在社交网络上颇具影响力的外国人物。而重庆已经成为这一高度组织化“流量热潮”的中心。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260524-%E4%B8%AD%E5%9B%BD%E5%A6%82%E4%BD%95%E7%94%A8-%E7%BD%91%E7%BA%A2%E5%A4%96%E4%BA%A4-%E9%87%8D%E5%A1%91%E5%85%A8%E7%90%83%E5%B9%B4%E8%BD%BB%E4%BA%BA%E8%AE%A4%E7%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779609818000.webp","sourceId":"rfi"},{"id":1779587978000,"createdDate":"2026-05-24 01:59","name":"法国国际广播电台","title":"《美国（和欧洲）如何将非洲拱手让给了中国》；美大学地缘政治教授点评","content":"各位听众，尽管中国正在取消对所有非洲国家的关税，但非洲大陆在美国人眼中似乎已无关紧要。至于欧洲，如今它只不过是非洲的一个金融门户。这是美国杜克大学非洲研究荣誉退休教授斯蒂芬·史密斯（StephenSmith）向法国快讯周刊专文点评指出的。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260524-%E7%BE%8E%E5%9B%BD-%E5%92%8C%E6%AC%A7%E6%B4%B2-%E5%A6%82%E4%BD%95%E5%B0%86%E9%9D%9E%E6%B4%B2%E6%8B%B1%E6%89%8B%E8%AE%A9%E7%BB%99%E4%BA%86%E4%B8%AD%E5%9B%BD-%E7%BE%8E%E5%A4%A7%E5%AD%A6%E5%9C%B0%E7%BC%98%E6%94%BF%E6%B2%BB%E6%95%99%E6%8E%88%E6%8C%87%E5%87%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779587978000.webp","sourceId":"rfi"},{"id":1779634786000,"createdDate":"2026-05-24 14:59","name":"法国国际广播电台","title":"特朗普：已指示代表不要仓促达成协议，时间在我们这边，封锁保持全面有效","content":"美国总统特朗普（DonaldTrump）周日通过其社媒平台表示，已指示他的外交代表不要仓促与伊朗达成协议，因为“时间在我们这边”。而就在不到一天前，特朗普刚宣称与德黑兰当局的协议已基本达成。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260524-%E7%89%B9%E6%9C%97%E6%99%AE-%E5%B7%B2%E6%8C%87%E7%A4%BA%E4%BB%A3%E8%A1%A8%E4%B8%8D%E8%A6%81%E4%BB%93%E4%BF%83%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE%EF%BC%8C%E6%97%B6%E9%97%B4%E7%AB%99%E5%9C%A8%E6%88%91%E4%BB%AC%E8%BF%99%E8%BE%B9%EF%BC%8C%E5%B0%81%E9%94%81%E4%BF%9D%E6%8C%81%E5%85%A8%E9%9D%A2%E6%9C%89%E6%95%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779634786000.webp","sourceId":"rfi"},{"id":1779633144000,"createdDate":"2026-05-24 14:32","name":"法国国际广播电台","title":"法西意荷立欧洲五国联合发布文件 促对中国产能过剩采取强硬贸易措施","content":"面对中国出口激增的局面，欧盟四大经济体正敦促采取更强硬的贸易措施，以保护欧洲产业免受“不公平贸易行为抬头”的冲击。西班牙、法国、意大利和荷兰这四个国家历来在贸易政策上存在分歧，此次它们与立陶宛联合发布了一份文件，提交给即将于周五召开的欧盟委员会关键会议，讨论如何应对中国问题。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260524-%E6%B3%95%E8%A5%BF%E6%84%8F%E8%8D%B7%E7%AB%8B%E6%AC%A7%E6%B4%B2%E4%BA%94%E5%9B%BD%E8%81%94%E5%90%88%E5%8F%91%E5%B8%83%E6%96%87%E4%BB%B6-%E4%BF%83%E5%AF%B9%E4%B8%AD%E5%9B%BD%E4%BA%A7%E8%83%BD%E8%BF%87%E5%89%A9%E9%87%87%E5%8F%96%E5%BC%BA%E7%A1%AC%E8%B4%B8%E6%98%93%E6%8E%AA%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779633144000.webp","sourceId":"rfi"},{"id":1779630636000,"createdDate":"2026-05-24 13:50","name":"法国国际广播电台","title":"教宗良十四世为中国教会祈祷 亦求山西矿难罹难者永远安息","content":"天主教教宗良十四世周日邀请信徒们为中国天主教会的团结祈祷。中国天主教会目前分为官方教会和一直忠于罗马的地下教会。5月24日是为在中国的教会祈祷的日子，这个祈祷日是教宗本笃十六世2007年写给中国天主教徒的信函中钦定的。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260524-%E6%95%99%E5%AE%97%E8%89%AF%E5%8D%81%E5%9B%9B%E4%B8%96%E4%B8%BA%E4%B8%AD%E5%9B%BD%E6%95%99%E4%BC%9A%E7%A5%88%E7%A5%B7-%E4%BA%A6%E6%B1%82%E5%B1%B1%E8%A5%BF%E7%9F%BF%E9%9A%BE%E7%BD%B9%E9%9A%BE%E8%80%85%E6%B0%B8%E8%BF%9C%E5%AE%89%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779630636000.webp","sourceId":"rfi"},{"id":1779628921000,"createdDate":"2026-05-24 13:22","name":"法国国际广播电台","title":"边巴次仁受邀参加在新德里举行的美独立250周年招待会 鲁比奥同出席","content":"美国已向藏人行政中央司政边巴次仁发出邀请，请他出席在新德里举行的庆祝美国独立250周年的招待会。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260524-%E8%BE%B9%E5%B7%B4%E6%AC%A1%E4%BB%81%E5%8F%97%E9%82%80%E5%8F%82%E5%8A%A0%E5%9C%A8%E6%96%B0%E5%BE%B7%E9%87%8C%E4%B8%BE%E8%A1%8C%E7%9A%84%E7%BE%8E%E7%8B%AC%E7%AB%8B250%E5%91%A8%E5%B9%B4%E6%8B%9B%E5%BE%85%E4%BC%9A-%E9%B2%81%E6%AF%94%E5%A5%A5%E5%90%8C%E5%87%BA%E5%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779628921000.webp","sourceId":"rfi"},{"id":1779624936000,"createdDate":"2026-05-24 12:15","name":"法国国际广播电台","title":"美伊据报正接近达成停战协议  关键核议题悬而未决","content":"种种迹象显示，美国和伊朗正寻求最终达成一项解决持续了近三个月战争的协议。正在印度访问的美国国务卿马可·鲁比奥周日（5月24号）甚至暗示，霍尔木兹海峡局势可能会传来“好消息”。但这一协议不太可能解决伊朗核计划这一棘手问题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260524-%E7%BE%8E%E4%BC%8A%E6%8D%AE%E6%8A%A5%E6%AD%A3%E6%8E%A5%E8%BF%91%E8%BE%BE%E6%88%90%E5%81%9C%E6%88%98%E5%8D%8F%E8%AE%AE-%E5%85%B3%E9%94%AE%E6%A0%B8%E8%AE%AE%E9%A2%98%E6%82%AC%E8%80%8C%E6%9C%AA%E5%86%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779624936000.webp","sourceId":"rfi"},{"id":1779623487000,"createdDate":"2026-05-24 11:51","name":"法国国际广播电台","title":"赫格塞思已告知日防相400枚战斧导弹的交付将出现延误 或达两年","content":"美国已告知日方，由于五角大楼优先重建在对伊朗军事行动中大量损耗的武器库存，对日本的400枚“战斧”巡航导弹的交付将出现严重延误。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260524-%E8%B5%AB%E6%A0%BC%E5%A1%9E%E6%80%9D%E5%B7%B2%E5%91%8A%E7%9F%A5%E6%97%A5%E9%98%B2%E7%9B%B8400%E6%9E%9A%E6%88%98%E6%96%A7%E5%AF%BC%E5%BC%B9%E7%9A%84%E4%BA%A4%E4%BB%98%E5%B0%86%E5%87%BA%E7%8E%B0%E5%BB%B6%E8%AF%AF-%E6%88%96%E8%BE%BE%E4%B8%A4%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779623487000.webp","sourceId":"rfi"},{"id":1779618290000,"createdDate":"2026-05-24 10:24","name":"法国国际广播电台","title":"特朗普称美伊协议将“很快”公布 据报停火延长60天海峡重新开放、谈判核计划","content":"美国总统特朗普（DonaldTrump）周六表示，结束与伊朗战争的协议将“很快”公布，目前正在就“最后层面”进行谈判。据悉，特朗普发表上述言论前，分别与阿拉伯和穆斯林领导人，以及以色列总理内塔尼亚胡通了电话。这是特朗普迄今为止最坚定的表态，表明他准备同意与伊朗正在谈判的谅解备忘录。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260524-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E7%BE%8E%E4%BC%8A%E5%8D%8F%E8%AE%AE%E5%B0%86-%E5%BE%88%E5%BF%AB-%E5%85%AC%E5%B8%83-%E6%8D%AE%E6%8A%A5%E5%81%9C%E7%81%AB%E5%BB%B6%E9%95%BF60%E5%A4%A9%E6%B5%B7%E5%B3%A1%E9%87%8D%E6%96%B0%E5%BC%80%E6%94%BE-%E8%B0%88%E5%88%A4%E6%A0%B8%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779618290000.webp","sourceId":"rfi"},{"id":1779615334000,"createdDate":"2026-05-24 09:35","name":"法国国际广播电台","title":"伊朗伊斯兰革命卫队据报利用阿联酋购买运输中制军用级卫星天线","content":"据英国《金融时报》看到的记录显示，伊朗伊斯兰革命卫队（以下简称革命卫队）利用一家位于阿联酋的采购网络，购买了与其无人机项目相关的中国先进卫星设备。这笔交易高度敏感，因为其表明，在阿联酋曾有一家向革命卫队分支机构提供通信设备的公司，而正是该分支机构在美以联军对伊朗发动袭击后，向阿联酋发射了导弹。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260524-%E4%BC%8A%E6%9C%97%E4%BC%8A%E6%96%AF%E5%85%B0%E9%9D%A9%E5%91%BD%E5%8D%AB%E9%98%9F%E6%8D%AE%E6%8A%A5%E5%88%A9%E7%94%A8%E9%98%BF%E8%81%94%E9%85%8B%E8%B4%AD%E4%B9%B0%E8%BF%90%E8%BE%93%E4%B8%AD%E5%9B%BD%E5%86%9B%E7%94%A8%E7%BA%A7%E5%8D%AB%E6%98%9F%E5%A4%A9%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779615334000.webp","sourceId":"rfi"}]