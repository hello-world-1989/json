[{"id":1779583805000,"createdDate":"2026-05-24 00:50","name":"法国国际广播电台","title":"白宫检查站发生枪击，特朗普在白宫工作，枪手被击毙","content":"法新社报道，周六晚间，白宫附近发生枪击事件，警方和安保人员迅速包围了事发区域。当时美国总统特朗普正在白宫忙着准备与伊朗的谈判的事。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260524-%E7%99%BD%E5%AE%AB%E6%A3%80%E6%9F%A5%E7%AB%99%E5%8F%91%E7%94%9F%E6%9E%AA%E5%87%BB%EF%BC%8C%E7%89%B9%E6%9C%97%E6%99%AE%E5%9C%A8%E7%99%BD%E5%AE%AB%E5%B7%A5%E4%BD%9C%EF%BC%8C%E6%9E%AA%E6%89%8B%E8%A2%AB%E5%87%BB%E6%AF%99","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779583805000.webp","sourceId":"rfi"},{"id":1779581494000,"createdDate":"2026-05-24 00:11","name":"法国国际广播电台","title":"美国和伊朗高级官员表示：双方的协议草案的谈判接近取得突破","content":"美国和伊朗高级官员周六表示，双方的协议草案的谈判接近取得突破，但同时对结束中东战争的可能性仍持谨慎态度。美国总统特朗普周六还告诉美国媒体Axios，达成协议的可能性“五五开”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260524-%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%BC%8A%E6%9C%97%E9%AB%98%E7%BA%A7%E5%AE%98%E5%91%98%E8%A1%A8%E7%A4%BA-%E5%8F%8C%E6%96%B9%E7%9A%84%E5%8D%8F%E8%AE%AE%E8%8D%89%E6%A1%88%E7%9A%84%E8%B0%88%E5%88%A4%E6%8E%A5%E8%BF%91%E5%8F%96%E5%BE%97%E7%AA%81%E7%A0%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779581494000.webp","sourceId":"rfi"},{"id":1779613068000,"createdDate":"2026-05-24 08:57","name":"法国国际广播电台","title":"乌克兰：俄罗斯对基辅发动大规模袭击  含一超音速导弹","content":"周六（5月23日）至周日夜间，乌克兰首都及其周边地区遭到俄罗斯导弹和无人机的大规模协同攻击，其中包括一架超音速“奥列什尼克”中程导弹。初步统计死亡人数至少为4人，另有数十人受伤。早在周六晚间，乌克兰总统泽连斯基就曾警告称，俄罗斯即将发动大规模袭击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260524-%E4%B9%8C%E5%85%8B%E5%85%B0-%E4%BF%84%E7%BD%97%E6%96%AF%E5%AF%B9%E5%9F%BA%E8%BE%85%E5%8F%91%E5%8A%A8%E5%A4%A7%E8%A7%84%E6%A8%A1%E5%AF%BC%E5%BC%B9%E5%92%8C%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779613068000.webp","sourceId":"rfi"},{"id":1779609986000,"createdDate":"2026-05-24 08:06","name":"法国国际广播电台","title":"日媒披露：习近平在美中首脑会谈时批判高市早苗  特朗普反而赞扬高市","content":"据日本《读卖新闻》与日本电视台等媒体24日报道，在14日于北京举行的美中首脑会谈中，日中关系恶化成为议题之一。对于习近平主席点名批评高市首相，特朗普总统则对高市首相的领导能力给予肯定并加以维护。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260524-%E6%97%A5%E5%AA%92%E6%8A%AB%E9%9C%B2-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%9C%A8%E7%BE%8E%E4%B8%AD%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88%E6%97%B6%E6%89%B9%E5%88%A4%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%8D%E8%80%8C%E8%B5%9E%E6%89%AC%E9%AB%98%E5%B8%82","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779609986000.webp","sourceId":"rfi"},{"id":1779609818000,"createdDate":"2026-05-24 08:03","name":"法国国际广播电台","title":"中国如何用“网红外交”重塑全球年轻人认知","content":"世界报本期以大篇幅刊登了一则关于中国形象与国际网红的报道，题为“那些为中国政权服务的外国网红”。当中指出，为了改善在年轻人中的形象，中国正吸引那些在社交网络上颇具影响力的外国人物。而重庆已经成为这一高度组织化“流量热潮”的中心。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260524-%E4%B8%AD%E5%9B%BD%E5%A6%82%E4%BD%95%E7%94%A8-%E7%BD%91%E7%BA%A2%E5%A4%96%E4%BA%A4-%E9%87%8D%E5%A1%91%E5%85%A8%E7%90%83%E5%B9%B4%E8%BD%BB%E4%BA%BA%E8%AE%A4%E7%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779609818000.webp","sourceId":"rfi"},{"id":1779587978000,"createdDate":"2026-05-24 01:59","name":"法国国际广播电台","title":"《美国（和欧洲）如何将非洲拱手让给了中国》；美大学地缘政治教授点评","content":"各位听众，尽管中国正在取消对所有非洲国家的关税，但非洲大陆在美国人眼中似乎已无关紧要。至于欧洲，如今它只不过是非洲的一个金融门户。这是美国杜克大学非洲研究荣誉退休教授斯蒂芬·史密斯（StephenSmith）向法国快讯周刊专文点评指出的。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260524-%E7%BE%8E%E5%9B%BD-%E5%92%8C%E6%AC%A7%E6%B4%B2-%E5%A6%82%E4%BD%95%E5%B0%86%E9%9D%9E%E6%B4%B2%E6%8B%B1%E6%89%8B%E8%AE%A9%E7%BB%99%E4%BA%86%E4%B8%AD%E5%9B%BD-%E7%BE%8E%E5%A4%A7%E5%AD%A6%E5%9C%B0%E7%BC%98%E6%94%BF%E6%B2%BB%E6%95%99%E6%8E%88%E6%8C%87%E5%87%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/24/1779587978000.webp","sourceId":"rfi"}]