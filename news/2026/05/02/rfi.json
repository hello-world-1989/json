[{"id":1777710704000,"createdDate":"2026-05-02 08:31","name":"法国国际广播电台","title":"美国警告将制裁向伊朗交“过路费”的航运公司  中国：霍尔木兹海峡或成为特习会重要议题","content":"美国警告航运公司，如果为安全通过霍尔木兹海峡向伊朗支付费用，可能会面临制裁。这份美国财政部海外资产控制办公室（OFAC）周五（5月1日）发布的警示，为美伊围绕霍尔木兹海峡控制权的对峙白热化又增添了一层压力。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260502-%E7%BE%8E%E5%9B%BD%E8%AD%A6%E5%91%8A%E5%B0%86%E5%88%B6%E8%A3%81%E5%90%91%E4%BC%8A%E6%9C%97%E4%BA%A4-%E8%BF%87%E8%B7%AF%E8%B4%B9-%E7%9A%84%E8%88%AA%E8%BF%90%E5%85%AC%E5%8F%B8-%E4%B8%AD%E5%9B%BD-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%88%96%E6%88%90%E4%B8%BA%E7%89%B9%E4%B9%A0%E4%BC%9A%E9%87%8D%E8%A6%81%E8%AE%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777710704000.webp","sourceId":"rfi"},{"id":1777710226000,"createdDate":"2026-05-02 08:23","name":"法国国际广播电台","title":"日本首相访问越南 与越南总理黎明兴等举行会谈","content":"日本首相高市早苗于日本时间5月1日夜抵达越南首都河内，日本时间2日下午，高市首相在河内与越南总理黎明兴举行会谈。双方确认将在人工智能（AI）、半导体等经济安全保障领域，以及围绕重要矿产供应链强化等方面展开合作。高市首相还在河内与越共总书记、越南国家主席苏林举行首脑会谈，并就日本新的外交构想在河内的大学发表演讲。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260502-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E8%AE%BF%E9%97%AE%E8%B6%8A%E5%8D%97-%E4%B8%8E%E8%B6%8A%E5%8D%97%E6%80%BB%E7%90%86%E9%BB%8E%E6%98%8E%E5%85%B4%E7%AD%89%E4%B8%BE%E8%A1%8C%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777710226000.webp","sourceId":"rfi"}]