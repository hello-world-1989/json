[{"id":1777710704000,"createdDate":"2026-05-02 08:31","name":"法国国际广播电台","title":"美国警告将制裁向伊朗交“过路费”的航运公司  中国：霍尔木兹海峡或成为特习会重要议题","content":"美国警告航运公司，如果为安全通过霍尔木兹海峡向伊朗支付费用，可能会面临制裁。这份美国财政部海外资产控制办公室（OFAC）周五（5月1日）发布的警示，为美伊围绕霍尔木兹海峡控制权的对峙白热化又增添了一层压力。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260502-%E7%BE%8E%E5%9B%BD%E8%AD%A6%E5%91%8A%E5%B0%86%E5%88%B6%E8%A3%81%E5%90%91%E4%BC%8A%E6%9C%97%E4%BA%A4-%E8%BF%87%E8%B7%AF%E8%B4%B9-%E7%9A%84%E8%88%AA%E8%BF%90%E5%85%AC%E5%8F%B8-%E4%B8%AD%E5%9B%BD-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%88%96%E6%88%90%E4%B8%BA%E7%89%B9%E4%B9%A0%E4%BC%9A%E9%87%8D%E8%A6%81%E8%AE%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777710704000.webp","sourceId":"rfi"},{"id":1777710226000,"createdDate":"2026-05-02 08:23","name":"法国国际广播电台","title":"日本首相访问越南 与越南总理黎明兴等举行会谈","content":"日本首相高市早苗于日本时间5月1日夜抵达越南首都河内，日本时间2日下午，高市首相在河内与越南总理黎明兴举行会谈。双方确认将在人工智能（AI）、半导体等经济安全保障领域，以及围绕重要矿产供应链强化等方面展开合作。高市首相还在河内与越共总书记、越南国家主席苏林举行首脑会谈，并就日本新的外交构想在河内的大学发表演讲。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260502-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E8%AE%BF%E9%97%AE%E8%B6%8A%E5%8D%97-%E4%B8%8E%E8%B6%8A%E5%8D%97%E6%80%BB%E7%90%86%E9%BB%8E%E6%98%8E%E5%85%B4%E7%AD%89%E4%B8%BE%E8%A1%8C%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777710226000.webp","sourceId":"rfi"},{"id":1777733955000,"createdDate":"2026-05-02 14:59","name":"法国国际广播电台","title":"“自由开放的印度-太平洋”愿景十周年 高市在河内发表外交政策演讲","content":"日本首相高市早苗周六发表了一篇具有里程碑意义的讲话，阐述了她对深化日本与印太地区经济和安全联系的愿景，旨在增强该地区应对地缘政治挑战的韧性。高市在与越共中央总书记、国家主席苏林举行双边峰会后在河内国家大学发表讲话，强调了加强供应链、海事安全、太空开发以及可靠的通信基础设施对于大量数据交换的重要性。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260502-%E8%87%AA%E7%94%B1%E5%BC%80%E6%94%BE%E7%9A%84%E5%8D%B0%E5%BA%A6-%E5%A4%AA%E5%B9%B3%E6%B4%8B-%E6%84%BF%E6%99%AF10%E5%91%A8%E5%B9%B4-%E9%AB%98%E5%B8%82%E5%9C%A8%E6%B2%B3%E5%86%85%E5%8F%91%E8%A1%A8%E5%A4%96%E4%BA%A4%E6%94%BF%E7%AD%96%E6%BC%94%E8%AE%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777733955000.webp","sourceId":"rfi"},{"id":1777729892000,"createdDate":"2026-05-02 13:51","name":"法国国际广播电台","title":"祭出新全面制裁 特朗普称美军将从伊朗返回路上去接管古巴","content":"据路透社报导，两名白宫官员透露，美国总统特朗普周五签署了一项行政命令，扩大了美国对古巴政府的制裁范围。这两名白宫官员表示，新的制裁措施针对的是支持古巴政府安全机构或参与腐败或严重侵犯人权行为的个人、实体和附属机构，以及古巴政府的代理人、官员或支持者。目前尚不清楚究竟有哪些人受到了该行政命令的制裁。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260502-%E7%A5%AD%E5%87%BA%E6%96%B0%E5%85%A8%E9%9D%A2%E5%88%B6%E8%A3%81-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E7%BE%8E%E5%86%9B%E5%B0%86%E4%BB%8E%E4%BC%8A%E6%9C%97%E8%BF%94%E5%9B%9E%E8%B7%AF%E4%B8%8A%E5%8E%BB%E6%8E%A5%E7%AE%A1%E5%8F%A4%E5%B7%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777729892000.webp","sourceId":"rfi"},{"id":1777726201000,"createdDate":"2026-05-02 12:50","name":"法国国际广播电台","title":"美制裁五涉伊朗石油交易中企 中国商务部发布阻断禁令：不得承认执行遵守","content":"中国商务部周六发布禁令，阻断美国以参与涉及伊朗石油交易为由，制裁五间中国企业的措施。中国商务部的禁令指，不得承认、不得执行、不得遵守美国以参与伊朗石油交易为由，对恒力石化（大连）炼化有限公司、山东寿光鲁清石化有限公司、山东金诚石化集团有限公司、河北鑫海化工集团有限公司和山东胜星化工有限公司采取的列入“特别指定国民清单”、实施冻结资产和禁止交易等制裁措施。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260502-%E7%BE%8E%E5%88%B6%E8%A3%81%E4%BA%94%E6%B6%89%E4%BC%8A%E6%9C%97%E7%9F%B3%E6%B2%B9%E4%BA%A4%E6%98%93%E4%B8%AD%E4%BC%81-%E4%B8%AD%E5%9B%BD%E5%95%86%E5%8A%A1%E9%83%A8%E5%8F%91%E5%B8%83%E9%98%BB%E6%96%AD%E7%A6%81%E4%BB%A4-%E4%B8%8D%E5%BE%97%E6%89%BF%E8%AE%A4%E6%89%A7%E8%A1%8C%E9%81%B5%E5%AE%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777726201000.webp","sourceId":"rfi"},{"id":1777721299000,"createdDate":"2026-05-02 11:28","name":"法国国际广播电台","title":"赖清德突访斯威士兰 强调面对打压坚持公义理性应对","content":"台湾总统赖清德周六抵达友邦斯威士兰（台方称史瓦帝尼）访问，他表示，走向世界和每一分良善的力量互助互惠，是台湾人不可剥夺的权利，也是对世界的许诺；面对挑战，台湾以决心和努力克服一切，面对打压不公，坚持公义理性应对。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260502-%E8%B5%96%E6%B8%85%E5%BE%B7%E7%AA%81%E8%AE%BF%E6%96%AF%E5%A8%81%E5%A3%AB%E5%85%B0-%E5%BC%BA%E8%B0%83%E9%9D%A2%E5%AF%B9%E6%89%93%E5%8E%8B%E5%9D%9A%E6%8C%81%E5%85%AC%E4%B9%89%E7%90%86%E6%80%A7%E5%BA%94%E5%AF%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777721299000.webp","sourceId":"rfi"},{"id":1777718308000,"createdDate":"2026-05-02 10:38","name":"法国国际广播电台","title":"美菲“肩并肩”军演NMESIS反舰导弹进驻巴丹群岛 距台160公里","content":"菲美两国军队周六在靠近台湾的菲律宾北部巴丹群岛省举行年度军事演习期间，展示了“海军-海军陆战队远征舰船拦截系统”（NMESIS）反舰导弹系统。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260502-%E7%BE%8E%E8%8F%B2-%E8%82%A9%E5%B9%B6%E8%82%A9-%E5%86%9B%E6%BC%94nmesis%E5%8F%8D%E8%88%B0%E5%AF%BC%E5%BC%B9%E8%BF%9B%E9%A9%BB%E5%B7%B4%E4%B8%B9%E7%BE%A4%E5%B2%9B-%E8%B7%9D%E5%8F%B0160%E5%85%AC%E9%87%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777718308000.webp","sourceId":"rfi"},{"id":1777714411000,"createdDate":"2026-05-02 09:33","name":"法国国际广播电台","title":"因涉间谍罪回国时被判囚的旅日学者袁克勤获释","content":"据日本放送协会（NHK）通过对相关人士的采访获知，在中国被拘捕和判刑的一名日本北海道教育大学的前教授已获得释放。这名前教授7年前短期回到中国时，因被控涉嫌从事间谍活动而被捕，之后被当地法院判处有期徒刑6年。共同社消息指，当事人袁克勤目前居住在吉林省长春市，这一消息是由袁克勤的朋友组成的“解救袁克勤老师之会”透露的。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260502-%E5%9B%A0%E6%B6%89%E5%AB%8C%E9%97%B4%E8%B0%8D%E7%BD%AA%E5%9B%9E%E5%9B%BD%E6%97%B6%E8%A2%AB%E5%88%A4%E5%9B%9A%E7%9A%84%E6%97%85%E6%97%A5%E5%AD%A6%E8%80%85%E8%A2%81%E5%85%8B%E5%8B%A4%E8%8E%B7%E9%87%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777714411000.webp","sourceId":"rfi"},{"id":1777714046000,"createdDate":"2026-05-02 09:27","name":"法国国际广播电台","title":"特朗普批评德国涉伊朗言论，美国拟从德撤军5000人","content":"德国国防部长鲍里斯·皮斯托留斯5月2日表示，欧洲人必须承担更多自身安全责任。此番表态是对美国宣布计划从驻德部队中撤出5000名士兵的回应。北约发言人哈特对此表示，正与美国合作，了解其关于驻德兵力部署的决定细节。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260502-%E7%89%B9%E6%9C%97%E6%99%AE%E6%89%B9%E8%AF%84%E5%BE%B7%E5%9B%BD%E6%B6%89%E4%BC%8A%E6%9C%97%E8%A8%80%E8%AE%BA%EF%BC%8C%E7%BE%8E%E5%9B%BD%E6%8B%9F%E4%BB%8E%E5%BE%B7%E6%92%A4%E5%86%9B5000%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777714046000.webp","sourceId":"rfi"},{"id":1777712569000,"createdDate":"2026-05-02 09:02","name":"法国国际广播电台","title":"美经济狂怒行动继续打击伊中石油贸易 制裁码头运营商、外汇兑换机构","content":"美国政府周五对三家伊朗外汇兑换机构和一家中国石油码头等实施制裁，此举正值华盛顿加大对德黑兰当局的压力，要求其结束战争并重新开放霍尔木兹海峡。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260502-%E7%BE%8E%E7%BB%8F%E6%B5%8E%E7%8B%82%E6%80%92%E8%A1%8C%E5%8A%A8%E7%BB%A7%E7%BB%AD%E6%89%93%E5%87%BB%E4%BC%8A%E4%B8%AD%E7%9F%B3%E6%B2%B9%E8%B4%B8%E6%98%93-%E5%88%B6%E8%A3%81%E7%9F%B3%E6%B2%B9%E7%A0%81%E5%A4%B4%E8%BF%90%E8%90%A5%E5%95%86-%E5%A4%96%E6%B1%87%E5%85%91%E6%8D%A2%E6%9C%BA%E6%9E%84","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777712569000.webp","sourceId":"rfi"}]