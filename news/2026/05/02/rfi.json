[{"id":1777710704000,"createdDate":"2026-05-02 08:31","name":"法国国际广播电台","title":"美国警告将制裁向伊朗交“过路费”的航运公司  中国：霍尔木兹海峡或成为特习会重要议题","content":"美国警告航运公司，如果为安全通过霍尔木兹海峡向伊朗支付费用，可能会面临制裁。这份美国财政部海外资产控制办公室（OFAC）周五（5月1日）发布的警示，为美伊围绕霍尔木兹海峡控制权的对峙白热化又增添了一层压力。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260502-%E7%BE%8E%E5%9B%BD%E8%AD%A6%E5%91%8A%E5%B0%86%E5%88%B6%E8%A3%81%E5%90%91%E4%BC%8A%E6%9C%97%E4%BA%A4-%E8%BF%87%E8%B7%AF%E8%B4%B9-%E7%9A%84%E8%88%AA%E8%BF%90%E5%85%AC%E5%8F%B8-%E4%B8%AD%E5%9B%BD-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%88%96%E6%88%90%E4%B8%BA%E7%89%B9%E4%B9%A0%E4%BC%9A%E9%87%8D%E8%A6%81%E8%AE%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777710704000.webp","sourceId":"rfi"},{"id":1777710226000,"createdDate":"2026-05-02 08:23","name":"法国国际广播电台","title":"日本首相访问越南 与越南总理黎明兴等举行会谈","content":"日本首相高市早苗于日本时间5月1日夜抵达越南首都河内，日本时间2日下午，高市首相在河内与越南总理黎明兴举行会谈。双方确认将在人工智能（AI）、半导体等经济安全保障领域，以及围绕重要矿产供应链强化等方面展开合作。高市首相还在河内与越共总书记、越南国家主席苏林举行首脑会谈，并就日本新的外交构想在河内的大学发表演讲。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260502-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E8%AE%BF%E9%97%AE%E8%B6%8A%E5%8D%97-%E4%B8%8E%E8%B6%8A%E5%8D%97%E6%80%BB%E7%90%86%E9%BB%8E%E6%98%8E%E5%85%B4%E7%AD%89%E4%B8%BE%E8%A1%8C%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777710226000.webp","sourceId":"rfi"},{"id":1777733955000,"createdDate":"2026-05-02 14:59","name":"法国国际广播电台","title":"“自由开放的印度-太平洋”愿景十周年 高市在河内发表外交政策演讲","content":"日本首相高市早苗周六发表了一篇具有里程碑意义的讲话，阐述了她对深化日本与印太地区经济和安全联系的愿景，旨在增强该地区应对地缘政治挑战的韧性。高市在与越共中央总书记、国家主席苏林举行双边峰会后在河内国家大学发表讲话，强调了加强供应链、海事安全、太空开发以及可靠的通信基础设施对于大量数据交换的重要性。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260502-%E8%87%AA%E7%94%B1%E5%BC%80%E6%94%BE%E7%9A%84%E5%8D%B0%E5%BA%A6-%E5%A4%AA%E5%B9%B3%E6%B4%8B-%E6%84%BF%E6%99%AF10%E5%91%A8%E5%B9%B4-%E9%AB%98%E5%B8%82%E5%9C%A8%E6%B2%B3%E5%86%85%E5%8F%91%E8%A1%A8%E5%A4%96%E4%BA%A4%E6%94%BF%E7%AD%96%E6%BC%94%E8%AE%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777733955000.webp","sourceId":"rfi"},{"id":1777729892000,"createdDate":"2026-05-02 13:51","name":"法国国际广播电台","title":"祭出新全面制裁 特朗普称美军将从伊朗返回路上去接管古巴","content":"据路透社报导，两名白宫官员透露，美国总统特朗普周五签署了一项行政命令，扩大了美国对古巴政府的制裁范围。这两名白宫官员表示，新的制裁措施针对的是支持古巴政府安全机构或参与腐败或严重侵犯人权行为的个人、实体和附属机构，以及古巴政府的代理人、官员或支持者。目前尚不清楚究竟有哪些人受到了该行政命令的制裁。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260502-%E7%A5%AD%E5%87%BA%E6%96%B0%E5%85%A8%E9%9D%A2%E5%88%B6%E8%A3%81-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E7%BE%8E%E5%86%9B%E5%B0%86%E4%BB%8E%E4%BC%8A%E6%9C%97%E8%BF%94%E5%9B%9E%E8%B7%AF%E4%B8%8A%E5%8E%BB%E6%8E%A5%E7%AE%A1%E5%8F%A4%E5%B7%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777729892000.webp","sourceId":"rfi"},{"id":1777726201000,"createdDate":"2026-05-02 12:50","name":"法国国际广播电台","title":"美制裁五涉伊朗石油交易中企 中国商务部发布阻断禁令：不得承认执行遵守","content":"中国商务部周六发布禁令，阻断美国以参与涉及伊朗石油交易为由，制裁五间中国企业的措施。中国商务部的禁令指，不得承认、不得执行、不得遵守美国以参与伊朗石油交易为由，对恒力石化（大连）炼化有限公司、山东寿光鲁清石化有限公司、山东金诚石化集团有限公司、河北鑫海化工集团有限公司和山东胜星化工有限公司采取的列入“特别指定国民清单”、实施冻结资产和禁止交易等制裁措施。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260502-%E7%BE%8E%E5%88%B6%E8%A3%81%E4%BA%94%E6%B6%89%E4%BC%8A%E6%9C%97%E7%9F%B3%E6%B2%B9%E4%BA%A4%E6%98%93%E4%B8%AD%E4%BC%81-%E4%B8%AD%E5%9B%BD%E5%95%86%E5%8A%A1%E9%83%A8%E5%8F%91%E5%B8%83%E9%98%BB%E6%96%AD%E7%A6%81%E4%BB%A4-%E4%B8%8D%E5%BE%97%E6%89%BF%E8%AE%A4%E6%89%A7%E8%A1%8C%E9%81%B5%E5%AE%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777726201000.webp","sourceId":"rfi"},{"id":1777721299000,"createdDate":"2026-05-02 11:28","name":"法国国际广播电台","title":"赖清德突访斯威士兰 强调面对打压坚持公义理性应对","content":"台湾总统赖清德周六抵达友邦斯威士兰（台方称史瓦帝尼）访问，他表示，走向世界和每一分良善的力量互助互惠，是台湾人不可剥夺的权利，也是对世界的许诺；面对挑战，台湾以决心和努力克服一切，面对打压不公，坚持公义理性应对。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260502-%E8%B5%96%E6%B8%85%E5%BE%B7%E7%AA%81%E8%AE%BF%E6%96%AF%E5%A8%81%E5%A3%AB%E5%85%B0-%E5%BC%BA%E8%B0%83%E9%9D%A2%E5%AF%B9%E6%89%93%E5%8E%8B%E5%9D%9A%E6%8C%81%E5%85%AC%E4%B9%89%E7%90%86%E6%80%A7%E5%BA%94%E5%AF%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777721299000.webp","sourceId":"rfi"},{"id":1777718308000,"createdDate":"2026-05-02 10:38","name":"法国国际广播电台","title":"美菲“肩并肩”军演NMESIS反舰导弹进驻巴丹群岛 距台160公里","content":"菲美两国军队周六在靠近台湾的菲律宾北部巴丹群岛省举行年度军事演习期间，展示了“海军-海军陆战队远征舰船拦截系统”（NMESIS）反舰导弹系统。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260502-%E7%BE%8E%E8%8F%B2-%E8%82%A9%E5%B9%B6%E8%82%A9-%E5%86%9B%E6%BC%94nmesis%E5%8F%8D%E8%88%B0%E5%AF%BC%E5%BC%B9%E8%BF%9B%E9%A9%BB%E5%B7%B4%E4%B8%B9%E7%BE%A4%E5%B2%9B-%E8%B7%9D%E5%8F%B0160%E5%85%AC%E9%87%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777718308000.webp","sourceId":"rfi"},{"id":1777714411000,"createdDate":"2026-05-02 09:33","name":"法国国际广播电台","title":"因涉间谍罪回国时被判囚的旅日学者袁克勤获释","content":"据日本放送协会（NHK）通过对相关人士的采访获知，在中国被拘捕和判刑的一名日本北海道教育大学的前教授已获得释放。这名前教授7年前短期回到中国时，因被控涉嫌从事间谍活动而被捕，之后被当地法院判处有期徒刑6年。共同社消息指，当事人袁克勤目前居住在吉林省长春市，这一消息是由袁克勤的朋友组成的“解救袁克勤老师之会”透露的。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260502-%E5%9B%A0%E6%B6%89%E5%AB%8C%E9%97%B4%E8%B0%8D%E7%BD%AA%E5%9B%9E%E5%9B%BD%E6%97%B6%E8%A2%AB%E5%88%A4%E5%9B%9A%E7%9A%84%E6%97%85%E6%97%A5%E5%AD%A6%E8%80%85%E8%A2%81%E5%85%8B%E5%8B%A4%E8%8E%B7%E9%87%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777714411000.webp","sourceId":"rfi"},{"id":1777714046000,"createdDate":"2026-05-02 09:27","name":"法国国际广播电台","title":"特朗普批评德国涉伊朗言论，美国拟从德撤军5000人","content":"德国国防部长鲍里斯·皮斯托留斯5月2日表示，欧洲人必须承担更多自身安全责任。此番表态是对美国宣布计划从驻德部队中撤出5000名士兵的回应。北约发言人哈特对此表示，正与美国合作，了解其关于驻德兵力部署的决定细节。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260502-%E7%89%B9%E6%9C%97%E6%99%AE%E6%89%B9%E8%AF%84%E5%BE%B7%E5%9B%BD%E6%B6%89%E4%BC%8A%E6%9C%97%E8%A8%80%E8%AE%BA%EF%BC%8C%E7%BE%8E%E5%9B%BD%E6%8B%9F%E4%BB%8E%E5%BE%B7%E6%92%A4%E5%86%9B5000%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777714046000.webp","sourceId":"rfi"},{"id":1777712569000,"createdDate":"2026-05-02 09:02","name":"法国国际广播电台","title":"美经济狂怒行动继续打击伊中石油贸易 制裁码头运营商、外汇兑换机构","content":"美国政府周五对三家伊朗外汇兑换机构和一家中国石油码头等实施制裁，此举正值华盛顿加大对德黑兰当局的压力，要求其结束战争并重新开放霍尔木兹海峡。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260502-%E7%BE%8E%E7%BB%8F%E6%B5%8E%E7%8B%82%E6%80%92%E8%A1%8C%E5%8A%A8%E7%BB%A7%E7%BB%AD%E6%89%93%E5%87%BB%E4%BC%8A%E4%B8%AD%E7%9F%B3%E6%B2%B9%E8%B4%B8%E6%98%93-%E5%88%B6%E8%A3%81%E7%9F%B3%E6%B2%B9%E7%A0%81%E5%A4%B4%E8%BF%90%E8%90%A5%E5%95%86-%E5%A4%96%E6%B1%87%E5%85%91%E6%8D%A2%E6%9C%BA%E6%9E%84","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777712569000.webp","sourceId":"rfi"},{"id":1777756073000,"createdDate":"2026-05-02 21:07","name":"法国国际广播电台","title":"伊朗：不谈就打  反正球在美国那一边","content":"德黑兰周六宣布，伊朗已做好“准备”，无论选择恢复战争还是优先通过外交途径结束与华盛顿的冲突，都已做好准备，并表示“反正球在美国那边”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260502-%E4%BC%8A%E6%9C%97-%E4%B8%8D%E8%B0%88%E5%B0%B1%E6%89%93-%E5%8F%8D%E6%AD%A3%E7%90%83%E5%9C%A8%E7%BE%8E%E5%9B%BD%E9%82%A3%E4%B8%80%E8%BE%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777756073000.webp","sourceId":"rfi"},{"id":1777755807000,"createdDate":"2026-05-02 21:03","name":"法国国际广播电台","title":"古巴总统谴责特朗普的威胁已达“前所未有的程度”","content":"古巴总统米格尔·迪亚斯-卡内尔周六谴责·特朗普对古巴的军事侵略威胁已达到“危险且前所未有的程度”，并呼吁国际社会做出回应。美国总统周五在佛罗里达州的一次演讲中重申了“控制”古巴的威胁，暗示美国航母“从伊朗返回途中”可能会在古巴停留。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260502-%E5%8F%A4%E5%B7%B4%E6%80%BB%E7%BB%9F%E8%B0%B4%E8%B4%A3%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84%E5%A8%81%E8%83%81%E5%B7%B2%E8%BE%BE-%E5%89%8D%E6%89%80%E6%9C%AA%E6%9C%89%E7%9A%84%E7%A8%8B%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777755807000.webp","sourceId":"rfi"},{"id":1777755360000,"createdDate":"2026-05-02 20:56","name":"法国国际广播电台","title":"法“阵风”战斗机拦截两架俄苏-24战机","content":"作为北约任务的一部分，部署在立陶宛的法国战斗机在两架俄罗斯战机未经许可擅自闯入波罗的海空域后进行了拦截。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260502-%E6%B3%95-%E9%98%B5%E9%A3%8E-%E6%88%98%E6%96%97%E6%9C%BA%E6%8B%A6%E6%88%AA%E4%B8%A4%E6%9E%B6%E4%BF%84%E8%8B%8F-24%E6%88%98%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777755360000.webp","sourceId":"rfi"},{"id":1777755170000,"createdDate":"2026-05-02 20:52","name":"法国国际广播电台","title":"首家因伊朗战争而破产的航空公司   “精神航空”倒闭","content":"全美廉价航空公司“精神航空”（SpiritAirlines）5月2日宣布停止运营，成为首家因伊朗战争而破产的航空公司。此前，该公司与债权人就美国政府救助方案的谈判破裂。自两个月前冲突爆发以来，航空燃油价格翻了一番，这直接导致了精神航空的倒闭，预计将造成数千人失业。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260502-%E9%A6%96%E5%AE%B6%E5%9B%A0%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E8%80%8C%E7%A0%B4%E4%BA%A7%E7%9A%84%E8%88%AA%E7%A9%BA%E5%85%AC%E5%8F%B8-%E7%B2%BE%E7%A5%9E%E8%88%AA%E7%A9%BA-%E5%80%92%E9%97%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777755170000.webp","sourceId":"rfi"},{"id":1777754895000,"createdDate":"2026-05-02 20:48","name":"法国国际广播电台","title":"大众汽车2026年在华推出多款新能源车型   却是一笔单向支出","content":"由于比亚迪的衰落，大众汽车重夺中国市场第一的宝座，并正携一系列全新电动车型在中国市场发起攻势。业内人士表示，这种策略或许显得有些孤注一掷。所有这些车型都将面向中国市场，不会进入欧洲市场。这是一笔单向支出，无助于这些制造商抵御来自中国在欧洲、亚洲、澳大利亚和南美洲日益激烈的竞争。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260502-%E5%A4%A7%E4%BC%97%E6%B1%BD%E8%BD%A62026%E5%B9%B4%E5%9C%A8%E5%8D%8E%E6%8E%A8%E5%87%BA%E5%A4%9A%E6%AC%BE%E6%96%B0%E8%83%BD%E6%BA%90%E8%BD%A6%E5%9E%8B-%E5%8D%B4%E6%98%AF%E4%B8%80%E7%AC%94%E5%8D%95%E5%90%91%E6%94%AF%E5%87%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777754895000.webp","sourceId":"rfi"},{"id":1777754642000,"createdDate":"2026-05-02 20:44","name":"法国国际广播电台","title":"德蒂森克虏伯（Thyssenkrupp）与印度金达尔钢铁公司（Jindal Steel）不再合并","content":"德国蒂森克虏伯（Thyssenkrupp）集团周六宣布，已暂停与印度金达尔（JindalSteelInternational）钢铁国际公司就出售其钢铁部门TKSE进行的谈判。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260502-%E5%BE%B7%E8%92%82%E6%A3%AE%E5%85%8B%E8%99%8F%E4%BC%AF-thyssenkrupp-%E4%B8%8E%E5%8D%B0%E5%BA%A6%E9%87%91%E8%BE%BE%E5%B0%94%E9%92%A2%E9%93%81%E5%85%AC%E5%8F%B8-jindal-steel-%E4%B8%8D%E5%86%8D%E5%90%88%E5%B9%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777754642000.webp","sourceId":"rfi"},{"id":1777754361000,"createdDate":"2026-05-02 20:39","name":"法国国际广播电台","title":"运钞专机坠毁     飞行员和副驾驶员被抓","content":"据媒体周六报道，负责此案的检察官透露，今年2月在玻利维亚坠毁的一架载有数千张钞票的军用飞机的飞行员和副驾驶已被逮捕拘留。这起坠机事故造成22人死亡。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260502-%E8%BF%90%E9%92%9E%E4%B8%93%E6%9C%BA%E5%9D%A0%E6%AF%81-%E9%A3%9E%E8%A1%8C%E5%91%98%E5%92%8C%E5%89%AF%E9%A9%BE%E9%A9%B6%E5%91%98%E8%A2%AB%E6%8A%93","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777754361000.webp","sourceId":"rfi"},{"id":1777754152000,"createdDate":"2026-05-02 20:35","name":"法国国际广播电台","title":"伊朗诺贝尔和平奖得主从狱中被送入医院","content":"伊朗诺贝尔和平奖得主纳尔吉斯·穆罕默迪（NargesMohammadi）自去年12月以来一直被伊朗当局拘留。她的支持者宣布，穆罕默迪的健康状况急剧恶化，已被紧急送往医院。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260502-%E4%BC%8A%E6%9C%97%E8%AF%BA%E8%B4%9D%E5%B0%94%E5%92%8C%E5%B9%B3%E5%A5%96%E5%BE%97%E4%B8%BB%E4%BB%8E%E7%8B%B1%E4%B8%AD%E8%A2%AB%E9%80%81%E5%85%A5%E5%8C%BB%E9%99%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777754152000.webp","sourceId":"rfi"},{"id":1777753638000,"createdDate":"2026-05-02 20:27","name":"法国国际广播电台","title":"北欧-波罗的海8国外长会 续挺乌克兰","content":"北欧-波罗的海8国外长日前会晤并发表联合声明强调：俄罗斯仍是对欧洲-大西洋安全最直接且长期的威胁，呼吁国际社会持续并全面支持乌克兰，并强调乌克兰加入欧盟与北约的进程应持续推进。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260502-%E5%8C%97%E6%AC%A7-%E6%B3%A2%E7%BD%97%E7%9A%84%E6%B5%B78%E5%9B%BD%E5%A4%96%E9%95%BF%E4%BC%9A%E7%BB%AD%E6%8C%BA%E4%B9%8C%E5%85%8B%E5%85%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777753638000.webp","sourceId":"rfi"},{"id":1777749736000,"createdDate":"2026-05-02 19:22","name":"法国国际广播电台","title":"最新民调显示乌克兰人对美国和欧洲的信任期望值有不同程度降低","content":"俄乌战事迈入第5年，乌克兰最新民调显示，乌克兰人对欧美信任度持续下降，近6成受访者认为，一旦俄罗斯再次发动攻击，美国不会提供援助。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260502-%E6%9C%80%E6%96%B0%E6%B0%91%E8%B0%83%E6%98%BE%E7%A4%BA%E4%B9%8C%E5%85%8B%E5%85%B0%E4%BA%BA%E5%AF%B9%E7%BE%8E%E5%9B%BD%E5%92%8C%E6%AC%A7%E6%B4%B2%E7%9A%84%E4%BF%A1%E4%BB%BB%E6%9C%9F%E6%9C%9B%E5%80%BC%E6%9C%89%E4%B8%8D%E5%90%8C%E7%A8%8B%E5%BA%A6%E9%99%8D%E4%BD%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777749736000.webp","sourceId":"rfi"},{"id":1777748974000,"createdDate":"2026-05-02 19:09","name":"法国国际广播电台","title":"专家看美国计划从德国撤兵5000：“这不是针对弗里德里希·默茨的惩罚行动”","content":"据《莱茵邮报》报道，美国计划从德国撤出5000名士兵。这是否是总理弗里德里希·默茨与美国总统唐纳德·特朗普之间争执的后果？专家表示：这不是针对德国总理默茨的惩罚行动。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260502-%E4%B8%93%E5%AE%B6%E7%9C%8B%E7%BE%8E%E5%9B%BD%E8%AE%A1%E5%88%92%E4%BB%8E%E5%BE%B7%E5%9B%BD%E6%92%A4%E5%85%B55000-%E8%BF%99%E4%B8%8D%E6%98%AF%E9%92%88%E5%AF%B9%E5%BC%97%E9%87%8C%E5%BE%B7%E9%87%8C%E5%B8%8C%C2%B7%E9%BB%98%E8%8C%A8%E7%9A%84%E6%83%A9%E7%BD%9A%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/02/1777748974000.webp","sourceId":"rfi"}]