[{"id":1777798083000,"createdDate":"2026-05-03 08:48","name":"法国国际广播电台","title":"高市首相前往澳大利亚访问 聚焦能源与矿产供应链","content":"日本首相高市早苗于日本时间3日上午10点50分左右，乘坐政府专机从越南河内出发前往澳大利亚，预计3日晚抵达澳大利亚堪培拉，并将于4日与澳大利亚总理阿尔巴尼斯举行首脑会谈。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260503-%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E5%89%8D%E5%BE%80%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E8%AE%BF%E9%97%AE-%E8%81%9A%E7%84%A6%E8%83%BD%E6%BA%90%E4%B8%8E%E7%9F%BF%E4%BA%A7%E4%BE%9B%E5%BA%94%E9%93%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777798083000.webp","sourceId":"rfi"},{"id":1777796969000,"createdDate":"2026-05-03 08:29","name":"法国国际广播电台","title":"斯里兰卡警方逮捕37名涉嫌网络诈骗的中国公民","content":"斯里兰卡警方周日（5月3日）宣布，在打击此类犯罪网络的行动中，已在科伦坡逮捕37名涉嫌运营网络诈骗中心的中国公民。警方表示，这些嫌疑人年龄在23至44岁之间，其中包括一名女性。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260503-%E6%96%AF%E9%87%8C%E5%85%B0%E5%8D%A1%E8%AD%A6%E6%96%B9%E9%80%AE%E6%8D%9537%E5%90%8D%E6%B6%89%E5%AB%8C%E7%BD%91%E7%BB%9C%E8%AF%88%E9%AA%97%E7%9A%84%E4%B8%AD%E5%9B%BD%E5%85%AC%E6%B0%91","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777796969000.webp","sourceId":"rfi"}]