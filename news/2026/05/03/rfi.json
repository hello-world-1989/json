[{"id":1777798083000,"createdDate":"2026-05-03 08:48","name":"法国国际广播电台","title":"高市首相前往澳大利亚访问 聚焦能源与矿产供应链","content":"日本首相高市早苗于日本时间3日上午10点50分左右，乘坐政府专机从越南河内出发前往澳大利亚，预计3日晚抵达澳大利亚堪培拉，并将于4日与澳大利亚总理阿尔巴尼斯举行首脑会谈。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260503-%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E5%89%8D%E5%BE%80%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E8%AE%BF%E9%97%AE-%E8%81%9A%E7%84%A6%E8%83%BD%E6%BA%90%E4%B8%8E%E7%9F%BF%E4%BA%A7%E4%BE%9B%E5%BA%94%E9%93%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777798083000.webp","sourceId":"rfi"},{"id":1777796969000,"createdDate":"2026-05-03 08:29","name":"法国国际广播电台","title":"斯里兰卡警方逮捕37名涉嫌网络诈骗的中国公民","content":"斯里兰卡警方周日（5月3日）宣布，在打击此类犯罪网络的行动中，已在科伦坡逮捕37名涉嫌运营网络诈骗中心的中国公民。警方表示，这些嫌疑人年龄在23至44岁之间，其中包括一名女性。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260503-%E6%96%AF%E9%87%8C%E5%85%B0%E5%8D%A1%E8%AD%A6%E6%96%B9%E9%80%AE%E6%8D%9537%E5%90%8D%E6%B6%89%E5%AB%8C%E7%BD%91%E7%BB%9C%E8%AF%88%E9%AA%97%E7%9A%84%E4%B8%AD%E5%9B%BD%E5%85%AC%E6%B0%91","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777796969000.webp","sourceId":"rfi"},{"id":1777820859000,"createdDate":"2026-05-03 15:07","name":"法国国际广播电台","title":"地中海航运推出新航线绕过霍尔木兹海峡 德外长：作为美国亲密盟友，我们拥有共同目标","content":"全球最大的集装箱航运公司计划开通一条连接欧洲与中东偏远港口的新航线，该航线将采用陆路运输穿越沙特阿拉伯，并使用波斯湾的小型船舶，而非穿越被封锁的霍尔木兹海峡。地中海航运公司（MSC）周六发布的公告称，“欧洲-红海-中东快线”首航将于5月10日从比利时安特卫普出发，该航线将环线停靠德国、意大利、立陶宛和西班牙。船舶将穿过苏伊士运河进入红海，并访问沙特西海岸的两个港口——吉达和阿卜杜拉国王港。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260503-%E5%9C%B0%E4%B8%AD%E6%B5%B7%E8%88%AA%E8%BF%90%E6%8E%A8%E5%87%BA%E6%96%B0%E8%88%AA%E7%BA%BF%E7%BB%95%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E5%BE%B7%E5%A4%96%E9%95%BF-%E4%BD%9C%E4%B8%BA%E7%BE%8E%E5%9B%BD%E4%BA%B2%E5%AF%86%E7%9B%9F%E5%8F%8B%EF%BC%8C%E6%88%91%E4%BB%AC%E6%8B%A5%E6%9C%89%E5%85%B1%E5%90%8C%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777820859000.webp","sourceId":"rfi"},{"id":1777818695000,"createdDate":"2026-05-03 14:31","name":"法国国际广播电台","title":"特习会将至 美军C-17运输机接连抵达北京","content":"两架美国军用运输机近日被发现降落在中国首都北京——这显然又是一个迹象，表明美国总统特朗普本月的访华之行的准备工作正在进行中。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260503-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%B0%86%E8%87%B3-%E7%BE%8E%E5%86%9Bc-17%E8%BF%90%E8%BE%93%E6%9C%BA%E6%8E%A5%E8%BF%9E%E6%8A%B5%E8%BE%BE%E5%8C%97%E4%BA%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777818695000.webp","sourceId":"rfi"},{"id":1777814279000,"createdDate":"2026-05-03 13:17","name":"法国国际广播电台","title":"中方指5名菲人员登上铁线礁活动遭处置 菲海警称监测驱离中国科考船","content":"周日，中国海警指责菲律宾派遣人员登陆南中国海争议岛礁。同日，菲律宾海岸警卫队称，发现四艘中国科考船在菲水域附近活动，并认定这些科考船未经菲方许可进行“非法海洋科学研究”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260503-%E4%B8%AD%E6%96%B9%E6%8C%875%E5%90%8D%E8%8F%B2%E4%BA%BA%E5%91%98%E7%99%BB%E4%B8%8A%E9%93%81%E7%BA%BF%E7%A4%81%E6%B4%BB%E5%8A%A8%E9%81%AD%E5%A4%84%E7%BD%AE-%E8%8F%B2%E6%B5%B7%E8%AD%A6%E7%A7%B0%E7%9B%91%E6%B5%8B%E9%A9%B1%E7%A6%BB%E4%B8%AD%E5%9B%BD%E7%A7%91%E8%80%83%E8%88%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777814279000.webp","sourceId":"rfi"},{"id":1777809635000,"createdDate":"2026-05-03 12:00","name":"法国国际广播电台","title":"台湾学者张文扬谈“赖清德突访非洲”：台湾需要一些创意的方式应对目前的外交困境，但恐难成常态","content":"台湾总统赖清德周六（5月3日）表示，他已抵达非洲国家斯威士兰。此前数日，由于多个国家在据称来自中国的压力下撤回飞越领空许可，他的访问行程被迫推迟。斯威士兰是台湾在非洲唯一的邦交国。赖清德在社交平台上发文称，他此行是为了“重申我们长久以来的友谊”。他表示，作为一个实行自治的民主政体，台湾“绝不会因外部压力而退缩”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260503-%E5%8F%B0%E6%B9%BE%E5%AD%A6%E8%80%85%E5%BC%A0%E6%96%87%E6%89%AC%E8%B0%88-%E8%B5%96%E6%B8%85%E5%BE%B7%E7%AA%81%E8%AE%BF%E9%9D%9E%E6%B4%B2-%E5%8F%B0%E6%B9%BE%E5%9C%A8%E7%9B%AE%E5%89%8D%E7%9A%84%E5%A4%96%E4%BA%A4%E5%9B%B0%E5%A2%83%E4%B8%AD%EF%BC%8C%E7%A1%AE%E5%AE%9E%E9%9C%80%E8%A6%81%E4%B8%80%E4%BA%9B%E5%88%9B%E6%84%8F%E7%9A%84%E5%BA%94%E5%AF%B9%E6%96%B9%E5%BC%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777809635000.webp","sourceId":"rfi"},{"id":1777809440000,"createdDate":"2026-05-03 11:57","name":"法国国际广播电台","title":"赖清德：任何国家没权利也不应阻挡台湾为世界做贡献","content":"台湾总统赖清德周六抵达非洲唯一邦交国斯威士兰（台方称史瓦帝尼）访问，中国外交部发言人批评他“上演‘偷渡式’外窜闹剧”；国务院台办发言人亦称“其不甘失败，竟然不顾颜面，以偷鸡摸狗的方式外窜至斯”。而赖清德周日在社媒平台脸书发文指，“任何国家都没有权利、也不该阻挡台湾为世界做出贡献”。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260503-%E8%B5%96%E6%B8%85%E5%BE%B7-%E4%BB%BB%E4%BD%95%E5%9B%BD%E5%AE%B6%E6%B2%A1%E6%9D%83%E5%88%A9%E4%B9%9F%E4%B8%8D%E5%BA%94%E9%98%BB%E6%8C%A1%E5%8F%B0%E6%B9%BE%E4%B8%BA%E4%B8%96%E7%95%8C%E5%81%9A%E8%B4%A1%E7%8C%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777809440000.webp","sourceId":"rfi"},{"id":1777804877000,"createdDate":"2026-05-03 10:41","name":"法国国际广播电台","title":"东盟峰会将登场 缅甸局势仍混乱","content":"中东局势因美以伊战争对峙而动荡加剧，全球能源供应安全进一步受到威胁。面对日益严峻的能源危机和经济困境，东南亚国家领导人5月7日将齐聚菲律宾联合欧盟企业共同寻求应对策略，秉持增强经济韧性推动可持续增长。时值地区安全局势紧张之际，日本国家领导人积极访问东南亚，强化东南亚盟友合作并推广新版“印太战略”同样引发关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260503-%E4%B8%9C%E7%9B%9F%E5%B3%B0%E4%BC%9A%E5%B0%86%E7%99%BB%E5%9C%BA-%E7%BC%85%E7%94%B8%E5%B1%80%E5%8A%BF%E4%BB%8D%E6%B7%B7%E4%B9%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777804877000.webp","sourceId":"rfi"},{"id":1777803371000,"createdDate":"2026-05-03 10:16","name":"法国国际广播电台","title":"特朗普：无法想象伊朗的提案是可接受的 以批准购买两个中队的F-35I和F-15IA战机","content":"美国总统特朗普（DonaldTrump）周六向媒体表示，如果伊朗当局“行为不端”，他可能会下令对伊朗采取新的军事行动。尽管美伊双方仍在就结束战争的框架协议草案进行磋商，但特朗普也在认真考虑下令对伊朗采取新的军事行动，以打破目前的谈判僵局。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260503-%E7%89%B9%E6%9C%97%E6%99%AE-%E6%97%A0%E6%B3%95%E6%83%B3%E8%B1%A1%E4%BC%8A%E6%9C%97%E7%9A%84%E6%8F%90%E6%A1%88%E4%BC%9A%E5%BE%97%E5%88%B0%E6%8E%A5%E5%8F%97-%E4%BB%A5%E6%89%B9%E5%87%86%E8%B4%AD%E4%B9%B0%E4%B8%A4%E4%B8%AA%E4%B8%AD%E9%98%9F%E7%9A%84f-35i%E5%92%8Cf-15ia%E6%88%98%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777803371000.webp","sourceId":"rfi"},{"id":1777800580000,"createdDate":"2026-05-03 09:29","name":"法国国际广播电台","title":"高市重申将推动修宪以适应时代需求：将在国会推进旨在作出决策的讨论","content":"日本首相、自民党总裁高市早苗周日向在东京举行的支持修宪集会发表视频讲话，重申了她对修宪的诉求。高市表示：“正因为宪法是国家的基石，才应当根据时代的需求进行定期修订”。她指出，如今的安全环境、科技创新的速度以及人口结构都与79年前《日本国宪法》制定之时截然不同。但她并未提及何时向日本国会提交修宪提案，也未透露具体修改内容。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260503-%E9%AB%98%E5%B8%82%E9%87%8D%E7%94%B3%E5%B0%86%E6%8E%A8%E5%8A%A8%E4%BF%AE%E5%AE%AA%E4%BB%A5%E9%80%82%E5%BA%94%E6%97%B6%E4%BB%A3%E9%9C%80%E6%B1%82-%E5%B0%86%E5%9C%A8%E5%9B%BD%E4%BC%9A%E6%8E%A8%E8%BF%9B%E6%97%A8%E5%9C%A8%E4%BD%9C%E5%87%BA%E5%86%B3%E7%AD%96%E7%9A%84%E8%AE%A8%E8%AE%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777800580000.webp","sourceId":"rfi"},{"id":1777798782000,"createdDate":"2026-05-03 08:59","name":"法国国际广播电台","title":"王毅据报在访问缅甸期间会见了被软禁的昂山素季","content":"据共同社援引多家缅甸媒体周六的报道称，中国外交部长王毅在缅甸首都内比都会见了仍被软禁的缅甸民主领袖、前国务资政昂山素季。缅甸军政府此前宣布昂山素季被软禁在指定住所，据信此次会晤正是在该住所进行的。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260503-%E7%8E%8B%E6%AF%85%E6%8D%AE%E6%8A%A5%E5%9C%A8%E8%AE%BF%E9%97%AE%E7%BC%85%E7%94%B8%E6%9C%9F%E9%97%B4%E4%BC%9A%E8%A7%81%E4%BA%86%E8%A2%AB%E8%BD%AF%E7%A6%81%E7%9A%84%E6%98%82%E5%B1%B1%E7%B4%A0%E5%AD%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777798782000.webp","sourceId":"rfi"}]