[{"id":1777798083000,"createdDate":"2026-05-03 08:48","name":"法国国际广播电台","title":"高市首相前往澳大利亚访问 聚焦能源与矿产供应链","content":"日本首相高市早苗于日本时间3日上午10点50分左右，乘坐政府专机从越南河内出发前往澳大利亚，预计3日晚抵达澳大利亚堪培拉，并将于4日与澳大利亚总理阿尔巴尼斯举行首脑会谈。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260503-%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E5%89%8D%E5%BE%80%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E8%AE%BF%E9%97%AE-%E8%81%9A%E7%84%A6%E8%83%BD%E6%BA%90%E4%B8%8E%E7%9F%BF%E4%BA%A7%E4%BE%9B%E5%BA%94%E9%93%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777798083000.webp","sourceId":"rfi"},{"id":1777796969000,"createdDate":"2026-05-03 08:29","name":"法国国际广播电台","title":"斯里兰卡警方逮捕37名涉嫌网络诈骗的中国公民","content":"斯里兰卡警方周日（5月3日）宣布，在打击此类犯罪网络的行动中，已在科伦坡逮捕37名涉嫌运营网络诈骗中心的中国公民。警方表示，这些嫌疑人年龄在23至44岁之间，其中包括一名女性。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260503-%E6%96%AF%E9%87%8C%E5%85%B0%E5%8D%A1%E8%AD%A6%E6%96%B9%E9%80%AE%E6%8D%9537%E5%90%8D%E6%B6%89%E5%AB%8C%E7%BD%91%E7%BB%9C%E8%AF%88%E9%AA%97%E7%9A%84%E4%B8%AD%E5%9B%BD%E5%85%AC%E6%B0%91","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777796969000.webp","sourceId":"rfi"},{"id":1777820859000,"createdDate":"2026-05-03 15:07","name":"法国国际广播电台","title":"地中海航运推出新航线绕过霍尔木兹海峡 德外长：作为美国亲密盟友，我们拥有共同目标","content":"全球最大的集装箱航运公司计划开通一条连接欧洲与中东偏远港口的新航线，该航线将采用陆路运输穿越沙特阿拉伯，并使用波斯湾的小型船舶，而非穿越被封锁的霍尔木兹海峡。地中海航运公司（MSC）周六发布的公告称，“欧洲-红海-中东快线”首航将于5月10日从比利时安特卫普出发，该航线将环线停靠德国、意大利、立陶宛和西班牙。船舶将穿过苏伊士运河进入红海，并访问沙特西海岸的两个港口——吉达和阿卜杜拉国王港。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260503-%E5%9C%B0%E4%B8%AD%E6%B5%B7%E8%88%AA%E8%BF%90%E6%8E%A8%E5%87%BA%E6%96%B0%E8%88%AA%E7%BA%BF%E7%BB%95%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E5%BE%B7%E5%A4%96%E9%95%BF-%E4%BD%9C%E4%B8%BA%E7%BE%8E%E5%9B%BD%E4%BA%B2%E5%AF%86%E7%9B%9F%E5%8F%8B%EF%BC%8C%E6%88%91%E4%BB%AC%E6%8B%A5%E6%9C%89%E5%85%B1%E5%90%8C%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777820859000.webp","sourceId":"rfi"},{"id":1777818695000,"createdDate":"2026-05-03 14:31","name":"法国国际广播电台","title":"特习会将至 美军C-17运输机接连抵达北京","content":"两架美国军用运输机近日被发现降落在中国首都北京——这显然又是一个迹象，表明美国总统特朗普本月的访华之行的准备工作正在进行中。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260503-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%B0%86%E8%87%B3-%E7%BE%8E%E5%86%9Bc-17%E8%BF%90%E8%BE%93%E6%9C%BA%E6%8E%A5%E8%BF%9E%E6%8A%B5%E8%BE%BE%E5%8C%97%E4%BA%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777818695000.webp","sourceId":"rfi"},{"id":1777814279000,"createdDate":"2026-05-03 13:17","name":"法国国际广播电台","title":"中方指5名菲人员登上铁线礁活动遭处置 菲海警称监测驱离中国科考船","content":"周日，中国海警指责菲律宾派遣人员登陆南中国海争议岛礁。同日，菲律宾海岸警卫队称，发现四艘中国科考船在菲水域附近活动，并认定这些科考船未经菲方许可进行“非法海洋科学研究”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260503-%E4%B8%AD%E6%96%B9%E6%8C%875%E5%90%8D%E8%8F%B2%E4%BA%BA%E5%91%98%E7%99%BB%E4%B8%8A%E9%93%81%E7%BA%BF%E7%A4%81%E6%B4%BB%E5%8A%A8%E9%81%AD%E5%A4%84%E7%BD%AE-%E8%8F%B2%E6%B5%B7%E8%AD%A6%E7%A7%B0%E7%9B%91%E6%B5%8B%E9%A9%B1%E7%A6%BB%E4%B8%AD%E5%9B%BD%E7%A7%91%E8%80%83%E8%88%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777814279000.webp","sourceId":"rfi"},{"id":1777809635000,"createdDate":"2026-05-03 12:00","name":"法国国际广播电台","title":"台湾学者张文扬谈“赖清德突访非洲”：台湾需要一些创意的方式应对目前的外交困境，但恐难成常态","content":"台湾总统赖清德周六（5月3日）表示，他已抵达非洲国家斯威士兰。此前数日，由于多个国家在据称来自中国的压力下撤回飞越领空许可，他的访问行程被迫推迟。斯威士兰是台湾在非洲唯一的邦交国。赖清德在社交平台上发文称，他此行是为了“重申我们长久以来的友谊”。他表示，作为一个实行自治的民主政体，台湾“绝不会因外部压力而退缩”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260503-%E5%8F%B0%E6%B9%BE%E5%AD%A6%E8%80%85%E5%BC%A0%E6%96%87%E6%89%AC%E8%B0%88-%E8%B5%96%E6%B8%85%E5%BE%B7%E7%AA%81%E8%AE%BF%E9%9D%9E%E6%B4%B2-%E5%8F%B0%E6%B9%BE%E5%9C%A8%E7%9B%AE%E5%89%8D%E7%9A%84%E5%A4%96%E4%BA%A4%E5%9B%B0%E5%A2%83%E4%B8%AD%EF%BC%8C%E7%A1%AE%E5%AE%9E%E9%9C%80%E8%A6%81%E4%B8%80%E4%BA%9B%E5%88%9B%E6%84%8F%E7%9A%84%E5%BA%94%E5%AF%B9%E6%96%B9%E5%BC%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777809635000.webp","sourceId":"rfi"},{"id":1777809440000,"createdDate":"2026-05-03 11:57","name":"法国国际广播电台","title":"赖清德：任何国家没权利也不应阻挡台湾为世界做贡献","content":"台湾总统赖清德周六抵达非洲唯一邦交国斯威士兰（台方称史瓦帝尼）访问，中国外交部发言人批评他“上演‘偷渡式’外窜闹剧”；国务院台办发言人亦称“其不甘失败，竟然不顾颜面，以偷鸡摸狗的方式外窜至斯”。而赖清德周日在社媒平台脸书发文指，“任何国家都没有权利、也不该阻挡台湾为世界做出贡献”。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260503-%E8%B5%96%E6%B8%85%E5%BE%B7-%E4%BB%BB%E4%BD%95%E5%9B%BD%E5%AE%B6%E6%B2%A1%E6%9D%83%E5%88%A9%E4%B9%9F%E4%B8%8D%E5%BA%94%E9%98%BB%E6%8C%A1%E5%8F%B0%E6%B9%BE%E4%B8%BA%E4%B8%96%E7%95%8C%E5%81%9A%E8%B4%A1%E7%8C%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777809440000.webp","sourceId":"rfi"},{"id":1777804877000,"createdDate":"2026-05-03 10:41","name":"法国国际广播电台","title":"东盟峰会将登场 缅甸局势仍混乱","content":"中东局势因美以伊战争对峙而动荡加剧，全球能源供应安全进一步受到威胁。面对日益严峻的能源危机和经济困境，东南亚国家领导人5月7日将齐聚菲律宾联合欧盟企业共同寻求应对策略，秉持增强经济韧性推动可持续增长。时值地区安全局势紧张之际，日本国家领导人积极访问东南亚，强化东南亚盟友合作并推广新版“印太战略”同样引发关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260503-%E4%B8%9C%E7%9B%9F%E5%B3%B0%E4%BC%9A%E5%B0%86%E7%99%BB%E5%9C%BA-%E7%BC%85%E7%94%B8%E5%B1%80%E5%8A%BF%E4%BB%8D%E6%B7%B7%E4%B9%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777804877000.webp","sourceId":"rfi"},{"id":1777803371000,"createdDate":"2026-05-03 10:16","name":"法国国际广播电台","title":"特朗普：无法想象伊朗的提案是可接受的 以批准购买两个中队的F-35I和F-15IA战机","content":"美国总统特朗普（DonaldTrump）周六向媒体表示，如果伊朗当局“行为不端”，他可能会下令对伊朗采取新的军事行动。尽管美伊双方仍在就结束战争的框架协议草案进行磋商，但特朗普也在认真考虑下令对伊朗采取新的军事行动，以打破目前的谈判僵局。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260503-%E7%89%B9%E6%9C%97%E6%99%AE-%E6%97%A0%E6%B3%95%E6%83%B3%E8%B1%A1%E4%BC%8A%E6%9C%97%E7%9A%84%E6%8F%90%E6%A1%88%E4%BC%9A%E5%BE%97%E5%88%B0%E6%8E%A5%E5%8F%97-%E4%BB%A5%E6%89%B9%E5%87%86%E8%B4%AD%E4%B9%B0%E4%B8%A4%E4%B8%AA%E4%B8%AD%E9%98%9F%E7%9A%84f-35i%E5%92%8Cf-15ia%E6%88%98%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777803371000.webp","sourceId":"rfi"},{"id":1777800580000,"createdDate":"2026-05-03 09:29","name":"法国国际广播电台","title":"高市重申将推动修宪以适应时代需求：将在国会推进旨在作出决策的讨论","content":"日本首相、自民党总裁高市早苗周日向在东京举行的支持修宪集会发表视频讲话，重申了她对修宪的诉求。高市表示：“正因为宪法是国家的基石，才应当根据时代的需求进行定期修订”。她指出，如今的安全环境、科技创新的速度以及人口结构都与79年前《日本国宪法》制定之时截然不同。但她并未提及何时向日本国会提交修宪提案，也未透露具体修改内容。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260503-%E9%AB%98%E5%B8%82%E9%87%8D%E7%94%B3%E5%B0%86%E6%8E%A8%E5%8A%A8%E4%BF%AE%E5%AE%AA%E4%BB%A5%E9%80%82%E5%BA%94%E6%97%B6%E4%BB%A3%E9%9C%80%E6%B1%82-%E5%B0%86%E5%9C%A8%E5%9B%BD%E4%BC%9A%E6%8E%A8%E8%BF%9B%E6%97%A8%E5%9C%A8%E4%BD%9C%E5%87%BA%E5%86%B3%E7%AD%96%E7%9A%84%E8%AE%A8%E8%AE%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777800580000.webp","sourceId":"rfi"},{"id":1777798782000,"createdDate":"2026-05-03 08:59","name":"法国国际广播电台","title":"王毅据报在访问缅甸期间会见了被软禁的昂山素季","content":"据共同社援引多家缅甸媒体周六的报道称，中国外交部长王毅在缅甸首都内比都会见了仍被软禁的缅甸民主领袖、前国务资政昂山素季。缅甸军政府此前宣布昂山素季被软禁在指定住所，据信此次会晤正是在该住所进行的。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260503-%E7%8E%8B%E6%AF%85%E6%8D%AE%E6%8A%A5%E5%9C%A8%E8%AE%BF%E9%97%AE%E7%BC%85%E7%94%B8%E6%9C%9F%E9%97%B4%E4%BC%9A%E8%A7%81%E4%BA%86%E8%A2%AB%E8%BD%AF%E7%A6%81%E7%9A%84%E6%98%82%E5%B1%B1%E7%B4%A0%E5%AD%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777798782000.webp","sourceId":"rfi"},{"id":1777849210000,"createdDate":"2026-05-03 23:00","name":"法国国际广播电台","title":"“美国和中国可能因过度自信而走向战争”","content":"在乌克兰战争进入第五个年头，伊朗战争也不知将怎样结束的背景下，本次国际纵横的主题是：美国和中国会不会走向战争？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%9B%BD%E9%99%85%E7%BA%B5%E6%A8%AA/20260503-%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%B8%AD%E5%9B%BD%E5%8F%AF%E8%83%BD%E5%9B%A0%E8%BF%87%E5%BA%A6%E8%87%AA%E4%BF%A1%E8%80%8C%E8%B5%B0%E5%90%91%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777849210000.webp","sourceId":"rfi"},{"id":1777843169000,"createdDate":"2026-05-03 21:19","name":"法国国际广播电台","title":"特朗普：美开启霍尔木兹海峡船只通行自由行动将于周一启动","content":"特朗普5月3日表示：美国开启霍尔木兹海峡船只通行自由行动将于中东时间周一上午启动。美国总统特朗普在社交媒体发文称，世界各国——其中绝大多数并未卷入当前这场公开且激烈、人尽皆知的中东争端—都向美国求助，希望协助解救被困在霍尔木兹海峡的本国船只。美方将引导其船只安全驶出这片受限水道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260503-%E7%89%B9%E6%9C%97%E6%99%AE-%E7%BE%8E%E5%BC%80%E5%90%AF%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E8%88%B9%E5%8F%AA%E9%80%9A%E8%A1%8C%E8%87%AA%E7%94%B1%E8%A1%8C%E5%8A%A8%E5%B0%86%E4%BA%8E%E5%91%A8%E4%B8%80%E5%90%AF%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777843169000.webp","sourceId":"rfi"},{"id":1777843122000,"createdDate":"2026-05-03 21:18","name":"法国国际广播电台","title":"伊朗外交部表示已收到美国对结束战争新提案的回应","content":"伊朗外交部周日（5月3日）表示，已经收到美国对伊朗有关结束战争新提案的回应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260503-%E4%BC%8A%E6%9C%97%E5%A4%96%E4%BA%A4%E9%83%A8%E8%A1%A8%E7%A4%BA%E5%B7%B2%E6%94%B6%E5%88%B0%E7%BE%8E%E5%9B%BD%E5%AF%B9%E7%BB%93%E6%9D%9F%E6%88%98%E4%BA%89%E6%96%B0%E6%8F%90%E6%A1%88%E7%9A%84%E5%9B%9E%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777843122000.webp","sourceId":"rfi"},{"id":1777842671000,"createdDate":"2026-05-03 21:11","name":"法国国际广播电台","title":"法媒：减少驻欧美军    特朗普在削弱北约","content":"在美国总统特朗普宣布有可能从德国撤走5000名美国驻军之后，人们担忧是否可能削减驻意大利和西班牙美军部队。西班牙境内的美国驻军人数约为3814人；意大利为12662。法国《十字架报》认为，减少驻欧美军：特朗普此种做法是在削弱北约。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260503-%E6%B3%95%E5%AA%92-%E5%87%8F%E5%B0%91%E9%A9%BB%E6%AC%A7%E7%BE%8E%E5%86%9B-%E7%89%B9%E6%9C%97%E6%99%AE%E5%9C%A8%E5%89%8A%E5%BC%B1%E5%8C%97%E7%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777842671000.webp","sourceId":"rfi"},{"id":1777842325000,"createdDate":"2026-05-03 21:05","name":"法国国际广播电台","title":"卢比奥将在未来几天与教皇会面","content":"美国国务卿马可·卢比奥将在未来几天前往罗马和梵蒂冈与教皇会面，特朗普曾对教皇良十四世进行了严厉批评。一位梵蒂冈消息人士周日证实了有关此次会晤的媒体报道。据意大利媒体报道，会晤定于周四举行，旨在缓和双边关系。此次会晤距离美国总统对教皇发表尖锐批评仅数周，特朗普对教皇的和平主义言论表示不满。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260503-%E5%8D%A2%E6%AF%94%E5%A5%A5%E5%B0%86%E5%9C%A8%E6%9C%AA%E6%9D%A5%E5%87%A0%E5%A4%A9%E4%B8%8E%E6%95%99%E7%9A%87%E4%BC%9A%E9%9D%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777842325000.webp","sourceId":"rfi"},{"id":1777842143000,"createdDate":"2026-05-03 21:02","name":"法国国际广播电台","title":"加沙的救援船队遭劫    西班牙和巴西活动人士被拘","content":"5月3日，以色列一家法院下令将两名“加沙船队”成员——一名西班牙人和一名巴西人——的拘留期限延长两天。这两名成员此前在希腊海岸附近被以色列逮捕。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260503-%E5%8A%A0%E6%B2%99%E7%9A%84%E6%95%91%E6%8F%B4%E8%88%B9%E9%98%9F%E9%81%AD%E5%8A%AB-%E8%A5%BF%E7%8F%AD%E7%89%99%E5%92%8C%E5%B7%B4%E8%A5%BF%E6%B4%BB%E5%8A%A8%E4%BA%BA%E5%A3%AB%E8%A2%AB%E6%8B%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777842143000.webp","sourceId":"rfi"},{"id":1777841735000,"createdDate":"2026-05-03 20:55","name":"法国国际广播电台","title":"乌无人机袭击俄波罗奈斯克港和船只","content":"周日，乌克兰无人机袭击了位于波罗的海的俄罗斯波罗奈斯克（Primorsk）港，这是基辅在全国范围内发动的一系列袭击的一部分。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260503-%E4%B9%8C%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB%E4%BF%84%E6%B3%A2%E7%BD%97%E5%A5%88%E6%96%AF%E5%85%8B%E6%B8%AF%E5%92%8C%E8%88%B9%E5%8F%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777841735000.webp","sourceId":"rfi"},{"id":1777841701000,"createdDate":"2026-05-03 20:55","name":"法国国际广播电台","title":"专家：中国汽车品牌在德国市场只有少数能存活","content":"据德国t-online.de网站报道：德国汽车市场竞争异常激烈。一些中国品牌正在取得成功，但另一些已被淘汰。那么，谁能在这场筛选中存活下来？行业专家施特凡·赖因德尔(StefanReindl)给出了一个数字，认为只有少数品牌能存活下来。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260503-%E4%B8%93%E5%AE%B6-%E4%B8%AD%E5%9B%BD%E6%B1%BD%E8%BD%A6%E5%93%81%E7%89%8C%E5%9C%A8%E5%BE%B7%E5%9B%BD%E5%B8%82%E5%9C%BA%E5%8F%AA%E6%9C%89%E5%B0%91%E6%95%B0%E8%83%BD%E5%AD%98%E6%B4%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777841701000.webp","sourceId":"rfi"},{"id":1777841225000,"createdDate":"2026-05-03 20:47","name":"法国国际广播电台","title":"美国国会军委会主席：裁减北约在德国驻军恐向普京传递错误信号","content":"美国五角大厦日前宣布，将从北约组织盟国德国裁减5000名驻军，对此，美国联邦参议院及众议院共和党籍军事委员会主席5月2日表示担忧。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260503-%E7%BE%8E%E5%9B%BD%E5%9B%BD%E4%BC%9A%E5%86%9B%E5%A7%94%E4%BC%9A%E4%B8%BB%E5%B8%AD-%E8%A3%81%E5%87%8F%E5%8C%97%E7%BA%A6%E5%9C%A8%E5%BE%B7%E5%9B%BD%E9%A9%BB%E5%86%9B%E6%81%90%E5%90%91%E6%99%AE%E4%BA%AC%E4%BC%A0%E9%80%92%E9%94%99%E8%AF%AF%E4%BF%A1%E5%8F%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777841225000.webp","sourceId":"rfi"},{"id":1777841198000,"createdDate":"2026-05-03 20:46","name":"法国国际广播电台","title":"中国玩具商受塑料价格冲击","content":"霍尔木兹海峡的封锁推高了石油价格，也推高了塑料价格。在中国玩具工厂，成本上涨导致工厂倒闭，并加速了价值链的重组。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260503-%E4%B8%AD%E5%9B%BD%E7%8E%A9%E5%85%B7%E5%95%86%E5%8F%97%E5%A1%91%E6%96%99%E4%BB%B7%E6%A0%BC%E5%86%B2%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777841198000.webp","sourceId":"rfi"},{"id":1777841014000,"createdDate":"2026-05-03 20:43","name":"法国国际广播电台","title":"法总统选举：让-吕克·梅朗雄正式宣布参选","content":"让-吕克·梅朗雄于周日在TF1电视台宣布，他将参加2027年法国总统大选竞争。这将是他继2012年、2017年和2022年之后，第四次竞选总统。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260503-%E6%B3%95%E6%80%BB%E7%BB%9F%E9%80%89%E4%B8%BE-%E8%AE%A9-%E5%90%95%E5%85%8B%C2%B7%E6%A2%85%E6%9C%97%E9%9B%84%E6%AD%A3%E5%BC%8F%E5%AE%A3%E5%B8%83%E5%8F%82%E9%80%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777841014000.webp","sourceId":"rfi"},{"id":1777840465000,"createdDate":"2026-05-03 20:34","name":"法国国际广播电台","title":"法牙胶婴儿玩具苏菲小鹿（Sophie la girafe）陷商业欺骗","content":"法国牙胶婴儿玩具苏菲小鹿（Sophielagirafe）一直都是家长们购买法国制造的一个国产货。5月3日，调查媒体Mediapart刊出报道说，苏菲小鹿（Sophielagirafe）一直在搞商业欺骗，玩具绝大部分产自中国，而不是像标签上写到“法国制造”。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260503-%E6%B3%95%E7%89%99%E8%83%B6%E5%A9%B4%E5%84%BF%E7%8E%A9%E5%85%B7%E8%8B%8F%E8%8F%B2%E5%B0%8F%E9%B9%BF-sophie-la-girafe-%E9%99%B7%E5%95%86%E4%B8%9A%E6%AC%BA%E9%AA%97","thumbnail":"","detailImage":"news/detail/rfi/2026/05/03/1777840465000.webp","sourceId":"rfi"}]