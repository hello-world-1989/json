[{"id":1778577462000,"createdDate":"2026-05-12 09:17","name":"法国国际广播电台","title":"汉坦病毒疫情管理进入新的阶段: 洪迪乌斯号邮轮上最后一批乘客撤离回国","content":"经过几个星期的的隔离，洪迪乌斯号邮轮上最后一批乘客在5月11日星期一被撤离回国，对这次汉坦病毒疫情管理进入新的阶段。27名船员必须留在船上，通过海路返回荷兰。而来自19个不同国家的121名乘客在不到48小时内（周日和周一）先乘船，后乘飞机撤离。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260512-%E6%B1%89%E5%9D%A6%E7%97%85%E6%AF%92%E7%96%AB%E6%83%85%E7%AE%A1%E7%90%86%E8%BF%9B%E5%85%A5%E6%96%B0%E7%9A%84%E9%98%B6%E6%AE%B5-%E6%B4%AA%E8%BF%AA%E4%B9%8C%E6%96%AF%E5%8F%B7%E9%82%AE%E8%BD%AE%E4%B8%8A%E6%9C%80%E5%90%8E%E4%B8%80%E6%89%B9%E4%B9%98%E5%AE%A2%E6%92%A4%E7%A6%BB%E5%9B%9E%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778577462000.webp","sourceId":"rfi"},{"id":1778575814000,"createdDate":"2026-05-12 08:50","name":"法国国际广播电台","title":"美制裁4香港公司指助伊朗对华出售和运输石油 北京：坚决反对","content":"美国周一宣布对12名个人和实体实施制裁，指责他们协助伊朗伊斯兰革命卫队向中国出售和运输伊朗石油。这一消息的宣布正值美国总统特朗普即将访问北京之际。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260512-%E7%BE%8E%E5%88%B6%E8%A3%814%E9%A6%99%E6%B8%AF%E5%85%AC%E5%8F%B8%E6%8C%87%E5%8A%A9%E4%BC%8A%E6%9C%97%E5%AF%B9%E5%8D%8E%E5%87%BA%E5%94%AE%E5%92%8C%E8%BF%90%E8%BE%93%E7%9F%B3%E6%B2%B9-%E5%8C%97%E4%BA%AC-%E5%9D%9A%E5%86%B3%E5%8F%8D%E5%AF%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778575814000.webp","sourceId":"rfi"},{"id":1778574577000,"createdDate":"2026-05-12 08:29","name":"法国国际广播电台","title":"被控充当“中国代理人”加州华裔市长认罪辞职，最高可判10年！","content":"法新社洛杉矶消息，美国司法部周一11日宣布，加州洛杉矶华人聚集的亚凯迪亚（Arcadia）华裔市长王爱琳（EileenWang），被联邦法院指控充当中华人民共和国的非法代理人。联邦检察官表示，王爱琳已同意认罪，最高可判刑10年。此外，她已辞去市长职务。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260512-%E8%A2%AB%E6%8E%A7%E5%85%85%E5%BD%93-%E4%B8%AD%E5%9B%BD%E4%BB%A3%E7%90%86%E4%BA%BA-%E5%8A%A0%E5%B7%9E%E5%8D%8E%E8%A3%94%E5%B8%82%E9%95%BF%E8%AE%A4%E7%BD%AA%E8%BE%9E%E8%81%8C%EF%BC%8C%E6%9C%80%E9%AB%98%E5%8F%AF%E5%88%A410%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778574577000.webp","sourceId":"rfi"},{"id":1778564495000,"createdDate":"2026-05-12 05:41","name":"法国国际广播电台","title":"不忘汶川地震  遇难学童家长18年来坚持维权 誓要官方彻查豆腐渣工程","content":"今年是汶川大地震18周年，地震导致大批学校教学楼倒塌，数以千百计的学生被活埋在瓦砾之下，都江堰聚源中学是其中的重灾区。逾百名聚源中学遇难学童家长，除了每年在地震纪念日返回中学旧址悼念遇难子女外，至今仍有家长坚持追究教学楼豆腐渣工程责任，因而成为当局长期监控的对象，被剥夺出行自由，变成社会边缘化的人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260512-%E4%B8%8D%E5%BF%98%E6%B1%B6%E5%B7%9D%E5%9C%B0%E9%9C%87-%E9%81%87%E9%9A%BE%E5%AD%A6%E7%AB%A5%E5%AE%B6%E9%95%BF18%E5%B9%B4%E6%9D%A5%E5%9D%9A%E6%8C%81%E7%BB%B4%E6%9D%83-%E8%AA%93%E8%A6%81%E5%AE%98%E6%96%B9%E5%BD%BB%E6%9F%A5%E8%B1%86%E8%85%90%E6%B8%A3%E5%B7%A5%E7%A8%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778564495000.webp","sourceId":"rfi"},{"id":1778599240000,"createdDate":"2026-05-12 15:20","name":"法国国际广播电台","title":"是否缩短中国游客停留期限 泰国外长指不针对任何特定国家，旅游签证不应超过30天","content":"泰国副总理兼外长西哈萨（SihasakPhuangketkeow）周二表示，预计将外国游客在泰国的免签停留期限减半至30天的提议不会遭到太多反对。他指出，当局也在审查整体签证框架，以确定是否仍有必要设立如此多的签证类别，以及是否可以合并部分类别。几个月来，当局几乎每天都在呼吁修改免签政策，因为自2024年7月扩大免签范围以来，该政策产生了一些意想不到的后果。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260512-%E6%98%AF%E5%90%A6%E7%BC%A9%E7%9F%AD%E4%B8%AD%E5%9B%BD%E6%B8%B8%E5%AE%A2%E5%81%9C%E7%95%99%E6%9C%9F%E9%99%90-%E6%B3%B0%E5%9B%BD%E5%A4%96%E9%95%BF%E6%8C%87%E4%B8%8D%E9%92%88%E5%AF%B9%E4%BB%BB%E4%BD%95%E7%89%B9%E5%AE%9A%E5%9B%BD%E5%AE%B6%EF%BC%8C%E6%97%85%E6%B8%B8%E7%AD%BE%E8%AF%81%E4%B8%8D%E5%BA%94%E8%B6%85%E8%BF%8730%E5%A4%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778599240000.webp","sourceId":"rfi"},{"id":1778597463000,"createdDate":"2026-05-12 14:51","name":"法国国际广播电台","title":"【视频】2026戛纳电影节：开幕前夕滨海大道一片沸腾","content":"距离第79届戛纳电影节开幕仅剩几个小时了，戛纳的滨海大道已是一片沸腾：最后的准备工作正在进行，红毯已经铺设完毕，明星们陆续抵达。组委会观看了2541部剧情长片，最终选出21部影片入围主竞赛单元。和法广同属法国世界媒体集团的法国24电视台的同仁奥利维耶·费索尔进行了报道。","newsLink":"https://www.rfi.fr/cn/%E9%AD%85%E5%8A%9B%E6%B3%95%E5%85%B0%E8%A5%BF/20260512-%E8%A7%86%E9%A2%91-2026%E6%88%9B%E7%BA%B3%E7%94%B5%E5%BD%B1%E8%8A%82-%E5%BC%80%E5%B9%95%E5%89%8D%E5%A4%95%E6%BB%A8%E6%B5%B7%E5%A4%A7%E9%81%93%E4%B8%80%E7%89%87%E6%B2%B8%E8%85%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778597463000.webp","sourceId":"rfi"},{"id":1778597200000,"createdDate":"2026-05-12 14:46","name":"法国国际广播电台","title":"美乌两国政府已起草备忘录 向达成无人机协议迈进","content":"据哥伦比亚广播公司（CBS）援引三位知情人士报导称，美国和乌克兰政府已起草一份备忘录，概述了两国间潜在的新防务协议条款。这份由美国国务院和乌克兰驻美大使斯特凡尼什娜（OlhaStefanishyna）共同敲定的草案，是朝着达成防务协议迈出的第一步。该协议将允许乌克兰向美国出口军事技术，并与美企合资生产无人机。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260512-%E7%BE%8E%E4%B9%8C%E4%B8%A4%E5%9B%BD%E6%94%BF%E5%BA%9C%E5%B7%B2%E8%B5%B7%E8%8D%89%E5%A4%87%E5%BF%98%E5%BD%95-%E5%90%91%E8%BE%BE%E6%88%90%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%8D%8F%E8%AE%AE%E8%BF%88%E8%BF%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778597200000.webp","sourceId":"rfi"},{"id":1778595313000,"createdDate":"2026-05-12 14:15","name":"法国国际广播电台","title":"法电拟出售在华可再生能源资产 为欧洲核能项目筹资","content":"据彭博社援引知情人士报导称，法国电力集团（EDF）正与顾问合作，出售其在中国的可再生能源资产，这家法国国有公用事业公司正将重心重新放在欧洲的核电项目上。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260512-%E6%B3%95%E7%94%B5%E6%8B%9F%E5%87%BA%E5%94%AE%E5%9C%A8%E5%8D%8E%E5%8F%AF%E5%86%8D%E7%94%9F%E8%83%BD%E6%BA%90%E8%B5%84%E4%BA%A7-%E4%B8%BA%E6%AC%A7%E6%B4%B2%E6%A0%B8%E8%83%BD%E9%A1%B9%E7%9B%AE%E7%AD%B9%E8%B5%84","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778595313000.webp","sourceId":"rfi"},{"id":1778594817000,"createdDate":"2026-05-12 14:06","name":"法国国际广播电台","title":"瓦努阿图政府批准与澳大利亚签署的新《纳卡马尔协议》","content":"瓦努阿图政府近日已批准与澳大利亚签署具有里程碑意义的新版《纳卡马尔协议》，显示该太平洋岛国在中国和澳大利亚之间寻求平衡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260512-%E7%93%A6%E5%8A%AA%E9%98%BF%E5%9B%BE%E6%94%BF%E5%BA%9C%E6%89%B9%E5%87%86%E4%B8%8E%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E7%AD%BE%E7%BD%B2%E7%9A%84%E6%96%B0-%E7%BA%B3%E5%8D%A1%E9%A9%AC%E5%B0%94%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778594817000.webp","sourceId":"rfi"},{"id":1778593674000,"createdDate":"2026-05-12 13:47","name":"法国国际广播电台","title":"科威特指控伊斯兰革命卫队月初曾派小分队袭击有中企港口项目的岛屿","content":"科威特周二指责伊朗曾派遣武装准军事部队——伊斯兰革命卫队——于本月初对该国一座岛屿发动袭击，该岛屿上有一个由中国资助的港口项目。科威特指控伊朗与此次事件有关，正值美国总统特朗普即将前往北京与中国国家主席习近平会晤之际。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260512-%E7%A7%91%E5%A8%81%E7%89%B9%E6%8C%87%E6%8E%A7%E4%BC%8A%E6%96%AF%E5%85%B0%E9%9D%A9%E5%91%BD%E5%8D%AB%E9%98%9F%E6%9C%88%E5%88%9D%E6%9B%BE%E6%B4%BE%E5%B0%8F%E5%88%86%E9%98%9F%E8%A2%AD%E5%87%BB%E6%9C%89%E4%B8%AD%E4%BC%81%E6%B8%AF%E5%8F%A3%E9%A1%B9%E7%9B%AE%E7%9A%84%E5%B2%9B%E5%B1%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778593674000.webp","sourceId":"rfi"},{"id":1778590832000,"createdDate":"2026-05-12 13:00","name":"法国国际广播电台","title":"印俄据报接近签署关键矿产协议，包含勘探、加工和技术合作","content":"据路透社援引两位知情人士报导称，印度和俄罗斯正就关键矿产的勘探、加工和技术合作进行深入磋商，以期签署一项初步协议。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260512-%E5%8D%B0%E4%BF%84%E6%8D%AE%E6%8A%A5%E6%8E%A5%E8%BF%91%E7%AD%BE%E7%BD%B2%E5%85%B3%E9%94%AE%E7%9F%BF%E4%BA%A7%E5%8D%8F%E8%AE%AE%EF%BC%8C%E5%8C%85%E5%90%AB%E5%8B%98%E6%8E%A2-%E5%8A%A0%E5%B7%A5%E5%92%8C%E6%8A%80%E6%9C%AF%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778590832000.webp","sourceId":"rfi"},{"id":1778588028000,"createdDate":"2026-05-12 12:13","name":"法国国际广播电台","title":"欧盟将推出新规针对平台上瘾有害设计 德部长称应效仿美国将TikTok交到欧洲人手中","content":"欧盟委员会主席冯德莱恩（UrsulavonderLeyen）周二表示，欧盟正在制定新规，以保护境内儿童免受TikTok、Meta和X等社交媒体平台的成瘾性影响。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260512-%E6%AC%A7%E7%9B%9F%E5%B0%86%E6%8E%A8%E5%87%BA%E6%96%B0%E8%A7%84%E9%92%88%E5%AF%B9%E5%B9%B3%E5%8F%B0%E4%B8%8A%E7%98%BE%E6%9C%89%E5%AE%B3%E8%AE%BE%E8%AE%A1-%E5%BE%B7%E9%83%A8%E9%95%BF%E7%A7%B0%E5%BA%94%E6%95%88%E4%BB%BF%E7%BE%8E%E5%9B%BD%E5%B0%86tiktok%E4%BA%A4%E5%88%B0%E6%AC%A7%E6%B4%B2%E4%BA%BA%E6%89%8B%E4%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778588028000.webp","sourceId":"rfi"},{"id":1778582887000,"createdDate":"2026-05-12 10:48","name":"法国国际广播电台","title":"特习会在即 “卖台不卖台” 炒作难消停","content":"美国总统特朗普周三（13日）即将开始访问中国之行，与中国国家主席习近平进行「特习会」。中国已经示意台湾问题将是中美首脑峰会的核心议题，中国外交部周二12日表示，中国一贯反对销售任何武器给台湾。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260512-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%9C%A8%E5%8D%B3-%E5%8D%96%E5%8F%B0%E4%B8%8D%E5%8D%96%E5%8F%B0-%E7%82%92%E4%BD%9C%E9%9A%BE%E6%B6%88%E5%81%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778582887000.webp","sourceId":"rfi"},{"id":1778582140000,"createdDate":"2026-05-12 10:35","name":"法国国际广播电台","title":"《关键药物法案》：欧盟内部达成临时协议，力求使关键药物供应链多元化","content":"欧洲议会和欧盟成员国周二达成一项临时协议，通过提高欧洲产量和减少对进口的依赖来加强欧盟基本药物的供应。欧盟轮值主席国塞浦路斯已与欧洲议会就一项新法规达成临时协议，该法规旨在增强欧盟应对欧洲关键药物供应安全方面持续挑战的韧性。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260512-%E5%85%B3%E9%94%AE%E8%8D%AF%E7%89%A9%E6%B3%95%E6%A1%88-%E6%AC%A7%E7%9B%9F%E5%86%85%E9%83%A8%E8%BE%BE%E6%88%90%E4%B8%B4%E6%97%B6%E5%8D%8F%E8%AE%AE%EF%BC%8C%E5%8A%9B%E6%B1%82%E4%BD%BF%E5%85%B3%E9%94%AE%E8%8D%AF%E7%89%A9%E4%BE%9B%E5%BA%94%E9%93%BE%E5%A4%9A%E5%85%83%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778582140000.webp","sourceId":"rfi"},{"id":1778580935000,"createdDate":"2026-05-12 10:15","name":"法国国际广播电台","title":"美财长贝森特访日与首相及多名阁僚会谈","content":"11日至13日，美国财政部长贝森特在访华前访问日本，日本时间12日下午与高市早苗首相举行了会谈。5月11日及12日与日本财务大臣片山皋月举行会谈，12日，与经济产业大臣赤泽亮正会谈。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260512-%E7%BE%8E%E8%B4%A2%E9%95%BF%E8%B4%9D%E6%A3%AE%E7%89%B9%E8%AE%BF%E6%97%A5%E4%B8%8E%E9%A6%96%E7%9B%B8%E5%8F%8A%E5%A4%9A%E5%90%8D%E9%98%81%E5%83%9A%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778580935000.webp","sourceId":"rfi"},{"id":1778580765000,"createdDate":"2026-05-12 10:12","name":"法国国际广播电台","title":"克宫：普京访华准备工作已进入最后阶段 预计访问内容丰富","content":"俄罗斯总统新闻秘书佩斯科夫周二在新闻发布会上表示，俄总统普京访华的准备工作已进入最后阶段。他并指，莫斯科和北京将同时宣布具体访问日期。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260512-%E5%85%8B%E5%AE%AB-%E6%99%AE%E4%BA%AC%E8%AE%BF%E5%8D%8E%E5%87%86%E5%A4%87%E5%B7%A5%E4%BD%9C%E5%B7%B2%E8%BF%9B%E5%85%A5%E6%9C%80%E5%90%8E%E9%98%B6%E6%AE%B5-%E9%A2%84%E8%AE%A1%E8%AE%BF%E9%97%AE%E5%86%85%E5%AE%B9%E4%B8%B0%E5%AF%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778580765000.webp","sourceId":"rfi"},{"id":1778579764000,"createdDate":"2026-05-12 09:56","name":"法国国际广播电台","title":"内塔尼亚胡称中国向伊朗提供支持，包括导弹零部件 北京：反对无端指责","content":"以色列总理内塔尼亚胡（BenjaminNetanyahu）上周六在接受美国哥伦比亚广播公司（CBS）《60分钟》节目专访时表示，中国向伊朗提供了一定的支持，包括导弹零部件，他对此并不喜欢。这是内塔尼亚胡自2月底伊朗战争爆发以来首次接受美国电视采访。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260512-%E5%86%85%E5%A1%94%E5%B0%BC%E4%BA%9A%E8%83%A1%E7%A7%B0%E4%B8%AD%E5%9B%BD%E5%90%91%E4%BC%8A%E6%9C%97%E6%8F%90%E4%BE%9B%E6%94%AF%E6%8C%81%EF%BC%8C%E5%8C%85%E6%8B%AC%E5%AF%BC%E5%BC%B9%E9%9B%B6%E9%83%A8%E4%BB%B6-%E5%8C%97%E4%BA%AC-%E5%8F%8D%E5%AF%B9%E6%97%A0%E7%AB%AF%E6%8C%87%E8%B4%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778579764000.webp","sourceId":"rfi"},{"id":1778578136000,"createdDate":"2026-05-12 09:28","name":"法国国际广播电台","title":"特朗普称将与习近平讨论对台军售、黎智英案和金明日牧师案等议题","content":"美国总统特朗普（DonaldTrump）周一向媒体表示，他将于本周在北京与中国国家主席习近平会谈时，讨论美对台军售以及被监禁的香港传媒大亨黎智英案等一系列问题。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260512-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E5%B0%86%E4%B8%8E%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%A8%E8%AE%BA%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE-%E9%BB%8E%E6%99%BA%E8%8B%B1%E6%A1%88%E5%92%8C%E9%87%91%E6%98%8E%E6%97%A5%E7%89%A7%E5%B8%88%E6%A1%88%E7%AD%89%E8%AE%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778578136000.webp","sourceId":"rfi"},{"id":1778629686000,"createdDate":"2026-05-12 23:48","name":"法国国际广播电台","title":"中国加强对网络宗教活动的管控","content":"法国天主教网站中国领域的报道指出，中国国家宗教事务局2025年9月15日已发布一项新的《宗教人员网络行为准则》。该新准则除其他内容外，还禁止向未成年人播放任何宗教节目以及直播宗教仪式。同样地，这些规定也适用于香港、澳门和台湾的居民，","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%BE%AE%E8%A8%80%E5%BE%AE%E8%AF%AD/20260512-%E4%B8%AD%E5%9B%BD%E5%8A%A0%E5%BC%BA%E5%AF%B9%E7%BD%91%E7%BB%9C%E5%AE%97%E6%95%99%E6%B4%BB%E5%8A%A8%E7%9A%84%E7%AE%A1%E6%8E%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778629686000.webp","sourceId":"rfi"},{"id":1778627304000,"createdDate":"2026-05-12 23:08","name":"法国国际广播电台","title":"马克龙：非洲一定会成功，我们将与非洲一起成功","content":"“非洲前进”峰会周二落下帷幕。法国总统马克龙会后接受了法国国际广播电台（RFI）、France24和TV5Monde的联合采访。他表示：“非洲一定会成功，我们将与非洲一起成功。”","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260512-%E9%A9%AC%E5%85%8B%E9%BE%99-%E9%9D%9E%E6%B4%B2%E4%B8%80%E5%AE%9A%E4%BC%9A%E6%88%90%E5%8A%9F%EF%BC%8C%E6%88%91%E4%BB%AC%E5%B0%86%E4%B8%8E%E9%9D%9E%E6%B4%B2%E4%B8%80%E8%B5%B7%E6%88%90%E5%8A%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778627304000.webp","sourceId":"rfi"},{"id":1778627107000,"createdDate":"2026-05-12 23:05","name":"法国国际广播电台","title":"在非洲，法国是否已经变成一个普普通通的国家？","content":"在法国与肯尼亚共同主办的“非洲前进”峰会在内罗毕落幕之际，法国世界报发表文章，回顾了马克龙自2017年上台以来推动法非关系转型的历程。该报指出，总体上，呈现出的是理想与现实之间的巨大落差，是法国在非洲影响力逐渐被重塑的复杂局面。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260512-%E5%9C%A8%E9%9D%9E%E6%B4%B2%EF%BC%8C%E6%B3%95%E5%9B%BD%E6%98%AF%E5%90%A6%E5%B7%B2%E7%BB%8F%E5%8F%98%E6%88%90%E4%B8%80%E4%B8%AA%E6%99%AE%E6%99%AE%E9%80%9A%E9%80%9A%E7%9A%84%E5%9B%BD%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778627107000.webp","sourceId":"rfi"},{"id":1778626831000,"createdDate":"2026-05-12 23:00","name":"法国国际广播电台","title":"在中国，生产者价格通胀率已达到 2022 年以来的最高水平，这是中东战争造成的后果","content":"中国4月份出厂价格涨幅超出预期，创下2022年夏季以来的最高纪录。中国于5月11日（周一）宣布，4月份出厂价格涨幅超出预期，达到2022年以来的最高水平，主要原因是中东战争导致成本飙升。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260512-%E5%9C%A8%E4%B8%AD%E5%9B%BD%EF%BC%8C%E7%94%9F%E4%BA%A7%E8%80%85%E4%BB%B7%E6%A0%BC%E9%80%9A%E8%83%80%E7%8E%87%E5%B7%B2%E8%BE%BE%E5%88%B0-2022-%E5%B9%B4%E4%BB%A5%E6%9D%A5%E7%9A%84%E6%9C%80%E9%AB%98%E6%B0%B4%E5%B9%B3%EF%BC%8C%E8%BF%99%E6%98%AF%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E9%80%A0%E6%88%90%E7%9A%84%E5%90%8E%E6%9E%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778626831000.webp","sourceId":"rfi"},{"id":1778620661000,"createdDate":"2026-05-12 21:17","name":"法国国际广播电台","title":"普京宣称：俄国将于今年底部署世界最强大导弹","content":"俄罗斯12日宣称成功试射了可搭载核弹头的新型洲际弹道导弹（ICBM）“萨尔马特”（Sarmat），总统普京表示，俄国将于今年底部署，并形容这是“世界最强大的导弹”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260512-%E6%99%AE%E4%BA%AC%E5%AE%A3%E7%A7%B0-%E4%BF%84%E5%9B%BD%E5%B0%86%E4%BA%8E%E4%BB%8A%E5%B9%B4%E5%BA%95%E9%83%A8%E7%BD%B2%E4%B8%96%E7%95%8C%E6%9C%80%E5%BC%BA%E5%A4%A7%E5%AF%BC%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778620661000.webp","sourceId":"rfi"},{"id":1778618688000,"createdDate":"2026-05-12 20:44","name":"法国国际广播电台","title":"法国首次在英语国家举行非洲峰会","content":"法国总统马克龙于5月12日在内罗毕接​​受法国国际广播电台（RFI）、法国24电视台和TV5MONDE电视台记者的联合采访。马克龙在此次采访中讲述了法国与非洲大陆的关系如何？未来面临哪些挑战？","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260512-%E6%B3%95%E5%9B%BD%E9%A6%96%E6%AC%A1%E5%9C%A8%E8%8B%B1%E8%AF%AD%E5%9B%BD%E5%AE%B6%E4%B8%BE%E8%A1%8C%E9%9D%9E%E6%B4%B2%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778618688000.webp","sourceId":"rfi"},{"id":1778618491000,"createdDate":"2026-05-12 20:41","name":"法国国际广播电台","title":"特朗普携强大的商界领袖访华","content":"特朗普周二启程前往中国前表示，他将与中国国家主席习近平就伊朗核协议进行“长时间的对话”。特朗普在回答记者关于伊朗核协议的提问时说道：“我们将就此进行长时间的对话。我认为他表现得相当不错”，并补充说，他不认为中国国家主席会帮助美国结束中东冲突。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260512-%E7%89%B9%E6%9C%97%E6%99%AE%E6%90%BA%E5%BC%BA%E5%A4%A7%E7%9A%84%E5%95%86%E7%95%8C%E9%A2%86%E8%A2%96%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778618491000.webp","sourceId":"rfi"},{"id":1778618336000,"createdDate":"2026-05-12 20:38","name":"法国国际广播电台","title":"马克龙：法汉坦病毒疫情“在掌控之中”","content":"正在肯尼亚参加法国-非洲峰会的法国总统马克龙关注了控制疫情采取的一系列措施。法国总统马克龙12日表示，法国的汉坦病毒疫情“已得到控制”，政府已与“最优秀的专家”协商，实施了“极其严格的防控措施”。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260512-%E9%A9%AC%E5%85%8B%E9%BE%99-%E6%B3%95%E6%B1%89%E5%9D%A6%E7%97%85%E6%AF%92%E7%96%AB%E6%83%85-%E5%9C%A8%E6%8E%8C%E6%8E%A7%E4%B9%8B%E4%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778618336000.webp","sourceId":"rfi"},{"id":1778618163000,"createdDate":"2026-05-12 20:36","name":"法国国际广播电台","title":"欧盟：“盾牌”（Aspides）护航行动可转往霍尔木兹","content":"欧盟外交与安全政策高级代表兼欧盟委员会副主席卡娅·卡拉斯（KajaKallas）5月12日表示，欧盟可能会决定将其在红海的军事行动扩展至霍尔木兹海峡，但前提是中东战争必须结束。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260512-%E6%AC%A7%E7%9B%9F-%E7%9B%BE%E7%89%8C-aspides-%E6%8A%A4%E8%88%AA%E8%A1%8C%E5%8A%A8%E5%8F%AF%E8%BD%AC%E5%BE%80%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778618163000.webp","sourceId":"rfi"},{"id":1778618041000,"createdDate":"2026-05-12 20:34","name":"法国国际广播电台","title":"让斯塔默辞职的呼声迭起","content":"英国工党于上周的地方选举中惨败后，基尔·斯塔默正面临着他任期内最严重的危机。据英国多家媒体11日报道，多名英国内阁成员要求首相斯塔默设定辞职时间表，其中包括外交大臣库珀、内政大臣马哈茂德。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260512-%E8%AE%A9%E6%96%AF%E5%A1%94%E9%BB%98%E8%BE%9E%E8%81%8C%E7%9A%84%E5%91%BC%E5%A3%B0%E8%BF%AD%E8%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778618041000.webp","sourceId":"rfi"},{"id":1778617998000,"createdDate":"2026-05-12 20:33","name":"法国国际广播电台","title":"“非洲正在成功”：法国总统马克龙宣布230亿欧元投资","content":"法国总统马克龙于周一在肯尼亚首都内罗毕举行的非洲-法国峰会上宣布：将对非洲投资230亿欧元，而非公共援助。显示巴黎在新的时代，寻求在非洲大陆重塑自身形象的意愿。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260512-%E9%9D%9E%E6%B4%B2%E6%AD%A3%E5%9C%A8%E6%88%90%E5%8A%9F-%E6%B3%95%E5%9B%BD%E6%80%BB%E7%BB%9F%E9%A9%AC%E5%85%8B%E9%BE%99%E5%AE%A3%E5%B8%83230%E4%BA%BF%E6%AC%A7%E5%85%83%E6%8A%95%E8%B5%84","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778617998000.webp","sourceId":"rfi"},{"id":1778617924000,"createdDate":"2026-05-12 20:32","name":"法国国际广播电台","title":"美起诉集装箱船撞击致桥塌的两家公司","content":"美国司法部周二宣布，一家总部位于新加坡的公司和一家印度公司因2024年发生在巴尔的摩的集装箱船撞毁高速公路桥梁、造成6人死亡的事故而被美国政府起诉。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260512-%E7%BE%8E%E8%B5%B7%E8%AF%89%E9%9B%86%E8%A3%85%E7%AE%B1%E8%88%B9%E6%92%9E%E5%87%BB%E8%87%B4%E6%A1%A5%E5%A1%8C%E7%9A%84%E4%B8%A4%E5%AE%B6%E5%85%AC%E5%8F%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778617924000.webp","sourceId":"rfi"},{"id":1778617639000,"createdDate":"2026-05-12 20:27","name":"法国国际广播电台","title":"法传染病专家讲述确诊者情况","content":"法国将对汉坦病毒感染病例的所有密切接触者加强隔离。政府发言人12日表示，在欧洲法国采取了最严格的防控措施，包括42天的隔离期。法国公共卫生风险预测委员会（Covars）成员、传染病专家莱斯库尔（XavierLescure）12日召开了记者会。他介绍了法国本土确诊的首例汉坦病毒感染者一些情况。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260512-%E6%B3%95%E4%BC%A0%E6%9F%93%E7%97%85%E4%B8%93%E5%AE%B6%E8%AE%B2%E8%BF%B0%E7%A1%AE%E8%AF%8A%E8%80%85%E6%83%85%E5%86%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778617639000.webp","sourceId":"rfi"},{"id":1778617390000,"createdDate":"2026-05-12 20:23","name":"法国国际广播电台","title":"马克龙在肯尼亚学做主食“乌伽黎”（ugali）","content":"一段10几秒的视频让法国总统非洲之行增添了轻松的氛围。视频上马克龙身着白衣，卷起袖子，和肯尼亚著名“厨师”丹尼斯·奥姆巴希（DennisOmbachi）一起烹饪，马克龙在学做非洲经典主食“乌伽黎”（ugali），丹尼斯·奥姆巴希在一旁给总统提些建议。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260512-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%9C%A8%E8%82%AF%E5%B0%BC%E4%BA%9A%E5%AD%A6%E5%81%9A%E4%B8%BB%E9%A3%9F-%E4%B9%8C%E4%BC%BD%E9%BB%8E-ugali","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778617390000.webp","sourceId":"rfi"},{"id":1778617141000,"createdDate":"2026-05-12 20:19","name":"法国国际广播电台","title":"马克龙：忽略非洲本身就是一种“道德、政治上的失败”","content":"法国总统马克龙周二在内罗毕举行的法非峰会闭幕式上表示，试图在不让非洲参与的情况下解决国际危机是一个“道德和政治错误”。他已邀请肯尼亚总统威廉·鲁托（WilliamRuto）参加即将在法国举行的七国集团峰会。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260512-%E9%A9%AC%E5%85%8B%E9%BE%99-%E5%BF%BD%E7%95%A5%E9%9D%9E%E6%B4%B2%E6%9C%AC%E8%BA%AB%E5%B0%B1%E6%98%AF%E4%B8%80%E7%A7%8D-%E9%81%93%E5%BE%B7-%E6%94%BF%E6%B2%BB%E4%B8%8A%E7%9A%84%E5%A4%B1%E8%B4%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778617141000.webp","sourceId":"rfi"},{"id":1778612261000,"createdDate":"2026-05-12 18:57","name":"法国国际广播电台","title":"巩俐嘎纳开幕式黑礼服光芒四射","content":"2026年嘎纳国际电影节2月12日拉开帷幕，这一届由艾海达拉（EyeHaïdara）担任2026年戛纳电影节的主持人；本届电影节向新西兰男导演、编剧、制作人彼得·杰克逊（PeterJackson）颁发了荣誉金棕榈奖。中国女演员巩俐和美国女演员简·方达（JaneFonda）共同宣布第79届戛纳电影节开幕。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260512-%E5%B7%A9%E4%BF%90%E5%98%8E%E7%BA%B3%E5%BC%80%E5%B9%95%E5%BC%8F%E9%BB%91%E7%A4%BC%E6%9C%8D%E5%85%89%E8%8A%92%E5%9B%9B%E5%B0%84","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778612261000.webp","sourceId":"rfi"},{"id":1778612204000,"createdDate":"2026-05-12 18:56","name":"法国国际广播电台","title":"【视频】戛纳影节：冷战曾席卷戛纳滨海大道","content":"1946年，戛纳电影节是旨在成为和平的象征。但当时美苏之间的紧张关系已显而易见。他们的目的是什么呢？双方都想在彼此面前出刷存在感、出风头。和法广同属法国世界媒体集团的法国电视24台的文化专栏对此进行了报道。","newsLink":"https://www.rfi.fr/cn/%E8%A7%86%E9%A2%91-%E6%88%9B%E7%BA%B3%E5%BD%B1%E8%8A%82-%E5%86%B7%E6%88%98%E6%9B%BE%E5%B8%AD%E5%8D%B7%E6%88%9B%E7%BA%B3%E6%BB%A8%E6%B5%B7%E5%A4%A7%E9%81%93","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778612204000.webp","sourceId":"rfi"},{"id":1778606951000,"createdDate":"2026-05-12 17:29","name":"法国国际广播电台","title":"伊朗阴影笼罩特朗普的访华","content":"美国总统特朗普（DonaldTrump）周二晚间将启程前往北京，与中国国家主席习近平举行高峰会谈。这场原本被白宫视为重塑美中关系、展示特朗普外交影响力的重要国事访问，如今却被伊朗战争与全球能源危机全面笼罩。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260512-%E4%BC%8A%E6%9C%97%E9%98%B4%E5%BD%B1%E7%AC%BC%E7%BD%A9%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778606951000.webp","sourceId":"rfi"}]