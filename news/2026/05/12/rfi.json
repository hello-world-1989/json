[{"id":1778577462000,"createdDate":"2026-05-12 09:17","name":"法国国际广播电台","title":"汉坦病毒疫情管理进入新的阶段: 洪迪乌斯号邮轮上最后一批乘客撤离回国","content":"经过几个星期的的隔离，洪迪乌斯号邮轮上最后一批乘客在5月11日星期一被撤离回国，对这次汉坦病毒疫情管理进入新的阶段。27名船员必须留在船上，通过海路返回荷兰。而来自19个不同国家的121名乘客在不到48小时内（周日和周一）先乘船，后乘飞机撤离。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260512-%E6%B1%89%E5%9D%A6%E7%97%85%E6%AF%92%E7%96%AB%E6%83%85%E7%AE%A1%E7%90%86%E8%BF%9B%E5%85%A5%E6%96%B0%E7%9A%84%E9%98%B6%E6%AE%B5-%E6%B4%AA%E8%BF%AA%E4%B9%8C%E6%96%AF%E5%8F%B7%E9%82%AE%E8%BD%AE%E4%B8%8A%E6%9C%80%E5%90%8E%E4%B8%80%E6%89%B9%E4%B9%98%E5%AE%A2%E6%92%A4%E7%A6%BB%E5%9B%9E%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778577462000.webp","sourceId":"rfi"},{"id":1778575814000,"createdDate":"2026-05-12 08:50","name":"法国国际广播电台","title":"美制裁4香港公司指助伊朗对华出售和运输石油 北京：坚决反对","content":"美国周一宣布对12名个人和实体实施制裁，指责他们协助伊朗伊斯兰革命卫队向中国出售和运输伊朗石油。这一消息的宣布正值美国总统特朗普即将访问北京之际。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260512-%E7%BE%8E%E5%88%B6%E8%A3%814%E9%A6%99%E6%B8%AF%E5%85%AC%E5%8F%B8%E6%8C%87%E5%8A%A9%E4%BC%8A%E6%9C%97%E5%AF%B9%E5%8D%8E%E5%87%BA%E5%94%AE%E5%92%8C%E8%BF%90%E8%BE%93%E7%9F%B3%E6%B2%B9-%E5%8C%97%E4%BA%AC-%E5%9D%9A%E5%86%B3%E5%8F%8D%E5%AF%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778575814000.webp","sourceId":"rfi"},{"id":1778574577000,"createdDate":"2026-05-12 08:29","name":"法国国际广播电台","title":"被控充当“中国代理人”加州华裔市长认罪辞职，最高可判10年！","content":"法新社洛杉矶消息，美国司法部周一11日宣布，加州洛杉矶华人聚集的亚凯迪亚（Arcadia）华裔市长王爱琳（EileenWang），被联邦法院指控充当中华人民共和国的非法代理人。联邦检察官表示，王爱琳已同意认罪，最高可判刑10年。此外，她已辞去市长职务。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260512-%E8%A2%AB%E6%8E%A7%E5%85%85%E5%BD%93-%E4%B8%AD%E5%9B%BD%E4%BB%A3%E7%90%86%E4%BA%BA-%E5%8A%A0%E5%B7%9E%E5%8D%8E%E8%A3%94%E5%B8%82%E9%95%BF%E8%AE%A4%E7%BD%AA%E8%BE%9E%E8%81%8C%EF%BC%8C%E6%9C%80%E9%AB%98%E5%8F%AF%E5%88%A410%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778574577000.webp","sourceId":"rfi"},{"id":1778564495000,"createdDate":"2026-05-12 05:41","name":"法国国际广播电台","title":"不忘汶川地震  遇难学童家长18年来坚持维权 誓要官方彻查豆腐渣工程","content":"今年是汶川大地震18周年，地震导致大批学校教学楼倒塌，数以千百计的学生被活埋在瓦砾之下，都江堰聚源中学是其中的重灾区。逾百名聚源中学遇难学童家长，除了每年在地震纪念日返回中学旧址悼念遇难子女外，至今仍有家长坚持追究教学楼豆腐渣工程责任，因而成为当局长期监控的对象，被剥夺出行自由，变成社会边缘化的人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260512-%E4%B8%8D%E5%BF%98%E6%B1%B6%E5%B7%9D%E5%9C%B0%E9%9C%87-%E9%81%87%E9%9A%BE%E5%AD%A6%E7%AB%A5%E5%AE%B6%E9%95%BF18%E5%B9%B4%E6%9D%A5%E5%9D%9A%E6%8C%81%E7%BB%B4%E6%9D%83-%E8%AA%93%E8%A6%81%E5%AE%98%E6%96%B9%E5%BD%BB%E6%9F%A5%E8%B1%86%E8%85%90%E6%B8%A3%E5%B7%A5%E7%A8%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/12/1778564495000.webp","sourceId":"rfi"}]