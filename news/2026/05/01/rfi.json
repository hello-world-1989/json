[{"id":1777625852000,"createdDate":"2026-05-01 08:57","name":"法国国际广播电台","title":"乌大使：日本放宽武器出口限制让乌日能就合作对话，是巨大进步","content":"乌克兰驻日本大使卢托维诺夫（YuriiLutovinov）向路透社表示，日本政府放宽武器出口限制为潜在谈判铺平了道路，未来东京或许会对乌提供军事装备，帮助其抵御俄罗斯的入侵。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260501-%E4%B9%8C%E5%A4%A7%E4%BD%BF-%E6%97%A5%E6%9C%AC%E6%94%BE%E5%AE%BD%E6%AD%A6%E5%99%A8%E5%87%BA%E5%8F%A3%E9%99%90%E5%88%B6%E8%AE%A9%E4%B9%8C%E6%97%A5%E8%83%BD%E5%B0%B1%E5%90%88%E4%BD%9C%E5%B1%95%E5%BC%80%E5%AF%B9%E8%AF%9D%EF%BC%8C%E6%98%AF%E5%B7%A8%E5%A4%A7%E8%BF%9B%E6%AD%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777625852000.webp","sourceId":"rfi"},{"id":1777620239000,"createdDate":"2026-05-01 07:23","name":"法国国际广播电台","title":"日本与伊朗举行首脑电话会谈","content":"日本时间4月30日下午6点25分起约，日本首相高市早苗与伊朗总统佩泽希齐扬举行了电话会谈。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260501-%E6%97%A5%E6%9C%AC%E4%B8%8E%E4%BC%8A%E6%9C%97%E4%B8%BE%E8%A1%8C%E9%A6%96%E8%84%91%E7%94%B5%E8%AF%9D%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777620239000.webp","sourceId":"rfi"},{"id":1777618223000,"createdDate":"2026-05-01 06:50","name":"法国国际广播电台","title":"特习会前王毅致电卢比奥称台湾为首要议题 学者：不排除中美可能私订「台湾密约」","content":"王毅30日致电鲁比奥，强调台湾问题事关中国的核心利益，将是特习会议程焦点。台湾外交部政务次长表示，担心台湾成中美交易菜单。日本学者分析，台湾议题正是最具战略价值的谈判筹码之一，不排除特习会将私订「台湾密约」。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260501-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%89%8D%E7%8E%8B%E6%AF%85%E8%87%B4%E7%94%B5%E5%8D%A2%E6%AF%94%E5%A5%A5%E7%A7%B0%E5%8F%B0%E6%B9%BE%E4%B8%BA%E9%A6%96%E8%A6%81%E8%AE%AE%E9%A2%98-%E5%AD%A6%E8%80%85-%E4%B8%8D%E6%8E%92%E9%99%A4%E4%B8%AD%E7%BE%8E%E5%8F%AF%E8%83%BD%E7%A7%81%E8%AE%A2-%E5%8F%B0%E6%B9%BE%E5%AF%86%E7%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777618223000.webp","sourceId":"rfi"},{"id":1777617767000,"createdDate":"2026-05-01 06:42","name":"法国国际广播电台","title":"黎智英狱中获德国颁言论自由奖 港府续骂","content":"被以言入罪而判囚20年的香港传媒大亨黎智英，获德国公共广播机构颁发今年的言论自由奖，以表彰他甘冒巨大的个人风险以捍卫香港的新闻自由，是他因国安罪服刑後首次获奖，但却是他被捕後的第七个相关奖项。黎的儿子表示，父亲获颁奖项，反映自由捍卫者绝不孤单。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260501-%E9%BB%8E%E6%99%BA%E8%8B%B1%E7%8B%B1%E4%B8%AD%E8%8E%B7%E5%BE%B7%E5%9B%BD%E9%A2%81%E8%A8%80%E8%AE%BA%E8%87%AA%E7%94%B1%E5%A5%96-%E6%B8%AF%E5%BA%9C%E7%BB%AD%E9%AA%82","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777617767000.webp","sourceId":"rfi"}]