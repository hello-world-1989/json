[{"id":1777625852000,"createdDate":"2026-05-01 08:57","name":"法国国际广播电台","title":"乌大使：日本放宽武器出口限制让乌日能就合作对话，是巨大进步","content":"乌克兰驻日本大使卢托维诺夫（YuriiLutovinov）向路透社表示，日本政府放宽武器出口限制为潜在谈判铺平了道路，未来东京或许会对乌提供军事装备，帮助其抵御俄罗斯的入侵。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260501-%E4%B9%8C%E5%A4%A7%E4%BD%BF-%E6%97%A5%E6%9C%AC%E6%94%BE%E5%AE%BD%E6%AD%A6%E5%99%A8%E5%87%BA%E5%8F%A3%E9%99%90%E5%88%B6%E8%AE%A9%E4%B9%8C%E6%97%A5%E8%83%BD%E5%B0%B1%E5%90%88%E4%BD%9C%E5%B1%95%E5%BC%80%E5%AF%B9%E8%AF%9D%EF%BC%8C%E6%98%AF%E5%B7%A8%E5%A4%A7%E8%BF%9B%E6%AD%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777625852000.webp","sourceId":"rfi"},{"id":1777620239000,"createdDate":"2026-05-01 07:23","name":"法国国际广播电台","title":"日本与伊朗举行首脑电话会谈","content":"日本时间4月30日下午6点25分起约，日本首相高市早苗与伊朗总统佩泽希齐扬举行了电话会谈。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260501-%E6%97%A5%E6%9C%AC%E4%B8%8E%E4%BC%8A%E6%9C%97%E4%B8%BE%E8%A1%8C%E9%A6%96%E8%84%91%E7%94%B5%E8%AF%9D%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777620239000.webp","sourceId":"rfi"},{"id":1777618223000,"createdDate":"2026-05-01 06:50","name":"法国国际广播电台","title":"特习会前王毅致电卢比奥称台湾为首要议题 学者：不排除中美可能私订「台湾密约」","content":"王毅30日致电鲁比奥，强调台湾问题事关中国的核心利益，将是特习会议程焦点。台湾外交部政务次长表示，担心台湾成中美交易菜单。日本学者分析，台湾议题正是最具战略价值的谈判筹码之一，不排除特习会将私订「台湾密约」。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260501-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%89%8D%E7%8E%8B%E6%AF%85%E8%87%B4%E7%94%B5%E5%8D%A2%E6%AF%94%E5%A5%A5%E7%A7%B0%E5%8F%B0%E6%B9%BE%E4%B8%BA%E9%A6%96%E8%A6%81%E8%AE%AE%E9%A2%98-%E5%AD%A6%E8%80%85-%E4%B8%8D%E6%8E%92%E9%99%A4%E4%B8%AD%E7%BE%8E%E5%8F%AF%E8%83%BD%E7%A7%81%E8%AE%A2-%E5%8F%B0%E6%B9%BE%E5%AF%86%E7%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777618223000.webp","sourceId":"rfi"},{"id":1777617767000,"createdDate":"2026-05-01 06:42","name":"法国国际广播电台","title":"黎智英狱中获德国颁言论自由奖 港府续骂","content":"被以言入罪而判囚20年的香港传媒大亨黎智英，获德国公共广播机构颁发今年的言论自由奖，以表彰他甘冒巨大的个人风险以捍卫香港的新闻自由，是他因国安罪服刑後首次获奖，但却是他被捕後的第七个相关奖项。黎的儿子表示，父亲获颁奖项，反映自由捍卫者绝不孤单。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260501-%E9%BB%8E%E6%99%BA%E8%8B%B1%E7%8B%B1%E4%B8%AD%E8%8E%B7%E5%BE%B7%E5%9B%BD%E9%A2%81%E8%A8%80%E8%AE%BA%E8%87%AA%E7%94%B1%E5%A5%96-%E6%B8%AF%E5%BA%9C%E7%BB%AD%E9%AA%82","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777617767000.webp","sourceId":"rfi"},{"id":1777649946000,"createdDate":"2026-05-01 15:39","name":"法国国际广播电台","title":"赞比亚尾矿坝溃决事故 美众院调查指政府助中企掩盖污染","content":"据《华尔街日报》报导，美国众议院美国与中共战略竞争特设委员会的一项调查显示，由于背负着数十亿美元的巨额债务，赞比亚政府帮助一家中国控股的矿业巨头掩盖了一起该国历史上严重的矿业污染事件。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260501-%E8%B5%9E%E6%AF%94%E4%BA%9A%E5%B0%BE%E7%9F%BF%E5%9D%9D%E6%BA%83%E5%86%B3%E4%BA%8B%E6%95%85-%E7%BE%8E%E4%BC%97%E9%99%A2%E8%B0%83%E6%9F%A5%E6%8C%87%E6%94%BF%E5%BA%9C%E5%8A%A9%E4%B8%AD%E4%BC%81%E6%8E%A9%E7%9B%96%E6%B1%A1%E6%9F%93","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777649946000.webp","sourceId":"rfi"},{"id":1777645892000,"createdDate":"2026-05-01 14:31","name":"法国国际广播电台","title":"澳总理承诺收回、为保达尔文港控制权 岚桥提起国际诉讼","content":"控制达尔文港的中国公司对澳大利亚发起了一场国际法律诉讼，这是该公司为维持对这一具有重要战略意义资产的长期租赁权而进行的斗争的戏剧性升级。澳大利亚工党和联盟党在去年的大选中都曾承诺剥夺岚桥集团对港口99年的租约，并将港口归还给澳方，理由是此举对于保护澳大利亚的国家安全至关重要。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260501-%E6%BE%B3%E6%80%BB%E7%90%86%E6%89%BF%E8%AF%BA%E6%94%B6%E5%9B%9E-%E4%B8%BA%E4%BF%9D%E4%BD%8F%E5%AF%B9%E8%BE%BE%E5%B0%94%E6%96%87%E6%B8%AF%E6%8E%A7%E5%88%B6%E6%9D%83-%E5%B2%9A%E6%A1%A5%E6%8F%90%E8%B5%B7%E5%9B%BD%E9%99%85%E8%AF%89%E8%AE%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777645892000.webp","sourceId":"rfi"},{"id":1777644480000,"createdDate":"2026-05-01 14:08","name":"法国国际广播电台","title":"中美巴拿马运河争端 穆利诺总统叫苦不迭","content":"巴拿马总统穆利诺今天表示，尽管中国和美国在巴拿马运河问题上有争端，但巴拿马仍与中国保持积极关系，并为巴拿马接管香港长江和记实业有限公司持有的港口合同辩解。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260501-%E4%B8%AD%E7%BE%8E%E5%B7%B4%E6%8B%BF%E9%A9%AC%E8%BF%90%E6%B2%B3%E4%BA%89%E7%AB%AF-%E7%A9%86%E5%88%A9%E8%AF%BA%E6%80%BB%E7%BB%9F%E5%8F%AB%E8%8B%A6%E4%B8%8D%E8%BF%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777644480000.webp","sourceId":"rfi"},{"id":1777643346000,"createdDate":"2026-05-01 13:49","name":"法国国际广播电台","title":"欧洲议会通过决议谴责《民族团结进步促进法》中方提交涉","content":"中国全国人大3月12日通过《民族团结进步促进法》，该法将于2026年7月1日起施行。周四（30日），欧洲议会通过了三项关于海地、中国和委内瑞拉人权状况的决议。通过上述决议，欧洲议会议员们呼吁中国政府废除《民族团结进步促进法》，并“谴责该法对来自西藏、新疆和内蒙古地区的人口造成严重后果”。该决议当天以439票赞成、52票反对、71票弃权获得通过。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260501-%E6%AC%A7%E6%B4%B2%E8%AE%AE%E4%BC%9A%E9%80%9A%E8%BF%87%E5%86%B3%E8%AE%AE%E8%B0%B4%E8%B4%A3-%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E8%BF%9B%E6%AD%A5%E4%BF%83%E8%BF%9B%E6%B3%95-%E4%B8%AD%E6%96%B9%E6%8F%90%E4%BA%A4%E6%B6%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777643346000.webp","sourceId":"rfi"},{"id":1777638145000,"createdDate":"2026-05-01 12:22","name":"法国国际广播电台","title":"欧尔班下台前 匈牙利公布2024年10亿欧元中国贷款细节","content":"据匈牙利新闻网站444.hu周五报导，即将发生权力交接的匈牙利公布了此前未公开的，有关即将卸任的总理欧尔班（ViktorOrban）领导的政府于2024年春季从中国获得的10亿欧元贷款的细节。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260501-%E6%AC%A7%E5%B0%94%E7%8F%AD%E4%B8%8B%E5%8F%B0%E5%89%8D-%E5%8C%88%E7%89%99%E5%88%A9%E5%85%AC%E5%B8%832024%E5%B9%B410%E4%BA%BF%E6%AC%A7%E5%85%83%E4%B8%AD%E5%9B%BD%E8%B4%B7%E6%AC%BE%E7%BB%86%E8%8A%82","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777638145000.webp","sourceId":"rfi"},{"id":1777632976000,"createdDate":"2026-05-01 10:56","name":"法国国际广播电台","title":"五一：当全球劳动者不愿再为战争承担代价","content":"5月1日，众多国家迎来国际劳动节。来自不同国家的活动人士走上街头，通过集会和游行表达诉求，核心议题集中在和平、提高工资以及改善劳动条件等方面。与此同时，许多劳动者正面临现实压力：与伊朗战争相关的能源价格上涨，正不断侵蚀他们的购买力与生活水平。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260501-%E4%BA%94%E4%B8%80-%E5%BD%93%E5%85%A8%E7%90%83%E5%8A%B3%E5%8A%A8%E8%80%85%E4%B8%8D%E6%84%BF%E5%86%8D%E4%B8%BA%E6%88%98%E4%BA%89%E6%89%BF%E6%8B%85%E4%BB%A3%E4%BB%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777632976000.webp","sourceId":"rfi"},{"id":1777632029000,"createdDate":"2026-05-01 10:40","name":"法国国际广播电台","title":"北京威胁将采取反制 欧盟高官誓言拼尽全力捍卫欧洲工业企业","content":"在中国威胁要对欧盟加强产业政策的计划采取报复措施后，欧盟委员会贸易和经济安全委员谢夫乔维奇（MarošŠefčovič）在受访时表示，欧方将坚持其立场。在中方表示将对欧盟加强工业基础的新计划采取反制措施后，谢夫乔维奇发出严厉警告，称欧盟将毫不犹豫地捍卫其产业。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260501-%E5%8C%97%E4%BA%AC%E5%A8%81%E8%83%81%E5%B0%86%E9%87%87%E5%8F%96%E5%8F%8D%E5%88%B6-%E6%AC%A7%E7%9B%9F%E9%AB%98%E5%AE%98%E8%AA%93%E8%A8%80%E5%B0%86%E6%8B%BC%E5%B0%BD%E5%85%A8%E5%8A%9B%E6%8D%8D%E5%8D%AB%E6%AC%A7%E6%B4%B2%E5%B7%A5%E4%B8%9A%E4%BC%81%E4%B8%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777632029000.webp","sourceId":"rfi"},{"id":1777631933000,"createdDate":"2026-05-01 10:38","name":"法国国际广播电台","title":"“强者定的法则”：广州非洲商人冷看中国免关税“礼包”，真正拦路虎还在别处...","content":"大家好欢迎收听法国报纸摘要，今天是五一劳动节，法国报纸纸版休刊，电子版的头条重点关注法国近期围绕5月1日延长工作时间的争论：面包店、花店、餐厅究竟谁有资格今天开业呢？同在今天，除与台北建交的斯威士兰（台称：史瓦帝尼）外，所有非洲国家都可以免关税向中国出口。对此《回声报》广州特派记者拉斐尔·巴勒尼耶发回报道说，凭借这份新的外交礼物，北京将自己定位为非洲大陆的合作伙伴，与美国和欧盟的贸易保护主义相对抗。但在广州，非洲商人们却表示怀疑：因为“关税不是问题，真正的门槛还在别处。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260501-%E5%BC%BA%E8%80%85%E5%AE%9A%E7%9A%84%E6%B3%95%E5%88%99-%E5%B9%BF%E5%B7%9E%E7%9A%84%E9%9D%9E%E6%B4%B2%E5%95%86%E4%BA%BA%E5%86%B7%E7%9C%8B%E4%B8%AD%E5%9B%BD%E5%85%8D%E5%85%B3%E7%A8%8E-%E7%A4%BC%E5%8C%85-%EF%BC%8C%E7%9C%9F%E6%AD%A3%E6%8B%A6%E8%B7%AF%E8%99%8E%E8%BF%98%E5%9C%A8%E5%88%AB%E5%A4%84","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777631933000.webp","sourceId":"rfi"},{"id":1777630884000,"createdDate":"2026-05-01 10:21","name":"法国国际广播电台","title":"中国企业的战略深耕：津巴布韦成为首个出口硫酸锂的非洲国家","content":"作为非洲最大的锂生产国，津巴布韦多年来一直致力于在锂产业中获取更多价值，因为目前的加工环节仍主要在非洲大陆以外完成。随着全球电池金属竞争的加剧，津巴布韦在这一战略中迈出了关键一步。据《论坛报》周四报道，中国企业华友钴业（ZhejiangHuayouCobalt）本周宣布，已从其在津巴布韦的业务基地发运了首批硫酸锂。津巴布韦由此成为非洲大陆首个向国际市场销售这种中间产品的国家。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260501-%E4%B8%AD%E5%9B%BD%E4%BC%81%E4%B8%9A%E7%9A%84%E6%88%98%E7%95%A5%E6%B7%B1%E8%80%95-%E6%B4%A5%E5%B7%B4%E5%B8%83%E9%9F%A6%E6%88%90%E4%B8%BA%E9%A6%96%E4%B8%AA%E5%87%BA%E5%8F%A3%E7%A1%AB%E9%85%B8%E9%94%82%E7%9A%84%E9%9D%9E%E6%B4%B2%E5%9B%BD%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777630884000.webp","sourceId":"rfi"},{"id":1777628944000,"createdDate":"2026-05-01 09:49","name":"法国国际广播电台","title":"今日起，中国对所有非洲国家实施零关税，一国除外","content":"自5月1日起，除未与中国建交的台湾邦交国斯威士兰之外，所有非洲国家都可以向中国在无需缴纳关税的情况下出口商品。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260501-%E4%BB%8A%E6%97%A5%E8%B5%B7%EF%BC%8C%E4%B8%AD%E5%9B%BD%E5%AF%B9%E6%89%80%E6%9C%89%E9%9D%9E%E6%B4%B2%E5%9B%BD%E5%AE%B6%E5%AE%9E%E6%96%BD%E9%9B%B6%E5%85%B3%E7%A8%8E%EF%BC%8C%E4%B8%80%E5%9B%BD%E9%99%A4%E5%A4%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777628944000.webp","sourceId":"rfi"},{"id":1777628643000,"createdDate":"2026-05-01 09:44","name":"法国国际广播电台","title":"美伊战争60天宪制关口 赫格塞斯\"停火暂停计时\"论引爆国会风暴","content":"美伊战争即将跨越法定60天授权期限，美国国防部长赫格塞斯（PeteHegseth）周四在参议院军事委员会听证时抛出争议性论据，声称现行停火协议令《战争权力决议》的60天倒计时\"暂停\"，政府毋须向国会寻求继续作战授权。这一说法旋即遭法律学者和民主党议员强烈批驳，一场围绕总统战争权力的宪制风暴，在最敏感的时间节点上骤然爆发。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260501-%E7%BE%8E%E4%BC%8A%E6%88%98%E4%BA%8960%E5%A4%A9%E5%AE%AA%E5%88%B6%E5%85%B3%E5%8F%A3-%E8%B5%AB%E6%A0%BC%E5%A1%9E%E6%96%AF-%E5%81%9C%E7%81%AB%E6%9A%82%E5%81%9C%E8%AE%A1%E6%97%B6-%E8%AE%BA%E5%BC%95%E7%88%86%E5%9B%BD%E4%BC%9A%E9%A3%8E%E6%9A%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777628643000.webp","sourceId":"rfi"},{"id":1777627849000,"createdDate":"2026-05-01 09:30","name":"法国国际广播电台","title":"俄罗斯逾90%受制裁技术通过中国进口 据报较去年有所上升","content":"俄罗斯超过90%的受制裁技术都是通过中国进口的，这表明随着俄总统普京对乌克兰战争的持续，莫斯科对北京的依赖日益加深。据彭博社援引知情人士报导称，这一比例较去年的约80%有所上升，该现象正值欧盟正严厉打击俄罗斯获取受限商品的渠道。虽然上述知情人士没有透露进口量的变化，但俄罗斯一直依靠中方支持来提高包括导弹和无人机在内的多种武器系统的产量。中国在布鲁塞尔大使馆未回应有关这些数据的置评请求。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260501-%E4%BF%84%E7%BD%97%E6%96%AF%E9%80%BE90-%E5%8F%97%E5%88%B6%E8%A3%81%E6%8A%80%E6%9C%AF%E9%80%9A%E8%BF%87%E4%B8%AD%E5%9B%BD%E8%BF%9B%E5%8F%A3-%E6%8D%AE%E6%8A%A5%E8%BE%83%E5%8E%BB%E5%B9%B4%E6%9C%89%E6%89%80%E4%B8%8A%E5%8D%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/01/1777627849000.webp","sourceId":"rfi"}]