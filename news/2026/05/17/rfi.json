[{"id":1779008300000,"createdDate":"2026-05-17 08:58","name":"法国国际广播电台","title":"日本参加向霍尔木兹海峡派遣多国籍部队计划的联合声明","content":"日本防卫大臣小泉进次郎在15日的记者会上表示，日本已参加英国公布的有关向霍尔木兹海峡派遣多国籍部队计划的联合声明，但他指出：这并不意味着日本预先决定参加多国籍军事任务。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260517-%E6%97%A5%E6%9C%AC%E5%8F%82%E5%8A%A0%E5%90%91%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%B4%BE%E9%81%A3%E5%A4%9A%E5%9B%BD%E7%B1%8D%E9%83%A8%E9%98%9F%E8%AE%A1%E5%88%92%E7%9A%84%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779008300000.webp","sourceId":"rfi"},{"id":1779006390000,"createdDate":"2026-05-17 08:26","name":"法国国际广播电台","title":"朝韩关系紧张背景下 朝鲜女足俱乐部抵韩参赛 8年来首次","content":"在朝韩关系紧张背景下，朝鲜职业女子足球俱乐部“我故乡FC”周日（5月17日）抵达韩国，参加亚足联女子冠军联赛半决赛。这是朝鲜运动员8年来首次访问韩国。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260517-%E6%9C%9D%E9%9F%A9%E5%85%B3%E7%B3%BB%E7%B4%A7%E5%BC%A0%E8%83%8C%E6%99%AF%E4%B8%8B-%E6%9C%9D%E9%B2%9C%E5%A5%B3%E8%B6%B3%E4%BF%B1%E4%B9%90%E9%83%A8%E6%8A%B5%E9%9F%A9%E5%8F%82%E8%B5%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779006390000.webp","sourceId":"rfi"},{"id":1779004823000,"createdDate":"2026-05-17 08:00","name":"法国国际广播电台","title":"俄罗斯遭大规模无人机袭击至少四人死亡","content":"俄罗斯当局周日表示，乌克兰对俄罗斯发动的大规模无人机袭击造成至少四人死亡。一家炼油厂附近建筑工地多名工人受伤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260517-%E4%BF%84%E7%BD%97%E6%96%AF%E9%81%AD%E5%A4%A7%E8%A7%84%E6%A8%A1%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB%E8%87%B3%E5%B0%91%E5%9B%9B%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779004823000.webp","sourceId":"rfi"},{"id":1779034172000,"createdDate":"2026-05-17 16:09","name":"法国国际广播电台","title":"法广2026年5月17日第二次播音 北京时间19至20点","content":"","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%AC%AC%E4%BA%8C%E6%AC%A1%E6%92%AD%E9%9F%B3-19-00-20-00-%E5%8C%97%E4%BA%AC%E6%97%B6%E9%97%B4/20260517-%E6%B3%95%E5%B9%BF2026%E5%B9%B45%E6%9C%8817%E6%97%A5%E7%AC%AC%E4%BA%8C%E6%AC%A1%E6%92%AD%E9%9F%B3-%E5%8C%97%E4%BA%AC%E6%97%B6%E9%97%B419%E8%87%B320%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779034172000.webp","sourceId":"rfi"},{"id":1779034152000,"createdDate":"2026-05-17 16:09","name":"法国国际广播电台","title":"台湾总统：捍卫中华民国现状没有「台独」问题","content":"中央社台北17日电：台湾总统赖清德今天听取国安团队就最新情势进行完整了解与讨论后，向国人说明，台湾是台海及区域和平稳定现状的维护者；中国才是区域不稳定及改变现状的根源；捍卫中华民国现状，没有「台独」问题；台海和平稳定绝不会被牺牲或交易等5个要点。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260517-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F-%E6%8D%8D%E5%8D%AB%E4%B8%AD%E5%8D%8E%E6%B0%91%E5%9B%BD%E7%8E%B0%E7%8A%B6%E6%B2%A1%E6%9C%89-%E5%8F%B0%E7%8B%AC-%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779034152000.webp","sourceId":"rfi"},{"id":1779031129000,"createdDate":"2026-05-17 15:18","name":"法国国际广播电台","title":"以色列击毙策划10.7袭击的哈马斯最后一名领导人","content":"以色列周五空袭加沙城一栋居民楼后，以色列军方和哈马斯官员周六证实了埃兹丁·哈达德的死亡。以军一名官员称，此人被描述为最后一名“参与策划10.7屠杀并仍留在加沙地带的哈马斯领导人”。据哈马斯人士说，他六次逃脱追杀。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260517-%E4%BB%A5%E8%89%B2%E5%88%97%E5%87%BB%E6%AF%99%E7%AD%96%E5%88%9210-7%E8%A2%AD%E5%87%BB%E7%9A%84%E5%93%88%E9%A9%AC%E6%96%AF%E6%9C%80%E5%90%8E%E4%B8%80%E5%90%8D%E9%A2%86%E5%AF%BC%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779031129000.webp","sourceId":"rfi"},{"id":1779021755000,"createdDate":"2026-05-17 12:42","name":"法国国际广播电台","title":"伊朗首席谈判代表加利巴夫被任命负责中国事务","content":"伊朗媒体周日报道，伊朗议会议长兼该国与美国谈判的主要代表穆罕默德·加利巴夫被委任负责对华事务。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260517-%E4%BC%8A%E6%9C%97%E9%A6%96%E5%B8%AD%E8%B0%88%E5%88%A4%E4%BB%A3%E8%A1%A8%E5%8A%A0%E5%88%A9%E5%B7%B4%E5%A4%AB%E8%A2%AB%E4%BB%BB%E5%91%BD%E8%B4%9F%E8%B4%A3%E4%B8%AD%E5%9B%BD%E4%BA%8B%E5%8A%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779021755000.webp","sourceId":"rfi"},{"id":1779020663000,"createdDate":"2026-05-17 12:24","name":"法国国际广播电台","title":"刚果（金）埃博拉疫情蔓延至邻国 世卫组织宣布“国际关注突发公共卫生事件”","content":"中非国家刚果民主共和国（ 简称刚果（金））新一波埃博拉疫情已蔓延至邻国，在乌干达发生一起感染死亡后，南苏丹进入警戒状态，肯尼亚正加紧国家级应对。世卫组织周日（5月17日）宣布，该疫情已构成“国际关注的突发公共卫生事件（PHEIC）”，这是世卫组织目前第二高级别的国际卫生警报。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260517-%E5%88%9A%E6%9E%9C-%E9%87%91-%E5%9F%83%E5%8D%9A%E6%8B%89%E7%96%AB%E6%83%85%E8%94%93%E5%BB%B6%E8%87%B3%E9%82%BB%E5%9B%BD-%E4%B8%96%E5%8D%AB%E7%BB%84%E7%BB%87%E5%AE%A3%E5%B8%83%E6%9E%84%E6%88%90-%E5%9B%BD%E9%99%85%E5%85%B3%E6%B3%A8%E7%AA%81%E5%8F%91%E5%85%AC%E5%85%B1%E5%8D%AB%E7%94%9F%E4%BA%8B%E4%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779020663000.webp","sourceId":"rfi"},{"id":1779019357000,"createdDate":"2026-05-17 12:02","name":"法国国际广播电台","title":"台湾总统重申台湾独立于北京","content":"路透社17日台北消息，台湾总统赖清德周日重申了台湾的独立地位，他认为台湾不属于北京，也不从属于北京，只有台湾人民才能决定台湾的未来。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260517-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E9%87%8D%E7%94%B3%E5%8F%B0%E6%B9%BE%E7%8B%AC%E7%AB%8B%E4%BA%8E%E5%8C%97%E4%BA%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779019357000.webp","sourceId":"rfi"},{"id":1779014499000,"createdDate":"2026-05-17 10:41","name":"法国国际广播电台","title":"美加芬三国破冰船合作计划","content":"5月5日至7日，美加芬三国破冰船合作计划（ICEPact）在赫尔辛基举办了工作组会议和国家协调员会议，讨论协议的实际进展，并参观了赫尔辛基造船厂和“北极星”号破冰船。2025年11月，加拿大、芬兰和美国正式签署了破冰船合作计划，三国将在未来几年合作建造11艘新型破冰船，以对抗俄罗斯和中国在北极地区日益增长的影响力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%8C%97%E7%BE%8E%E6%9D%A5%E9%B8%BF/20260517-%E7%BE%8E%E5%8A%A0%E8%8A%AC%E4%B8%89%E5%9B%BD%E7%A0%B4%E5%86%B0%E8%88%B9%E5%90%88%E4%BD%9C%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779014499000.webp","sourceId":"rfi"},{"id":1779011900000,"createdDate":"2026-05-17 09:58","name":"法国国际广播电台","title":"“中国小包裹税”受害者：法国瓦特里机场","content":"各位好，今天是2026年5月17日星期日。由于本台订阅的法国主流日刊周末大多不出刊，我们在出刊的法国世界报当中为您提取与中国相关的文章做综述。本期出刊的世界报有关中国的报道有两则。第一则题为“特朗普在北京热情但收效甚微的访问”。世界报在另外一篇报道中关注了法国的瓦特里机场，正在成为中国小包裹税的受害者。文中指出，自3月1日法国开始实施针对来自中国的小包裹的相关政策的以来，马恩省机场的运输量下降了70%，物流被重新导向其他欧洲国家。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260517-%E4%B8%AD%E5%9B%BD%E5%B0%8F%E5%8C%85%E8%A3%B9%E7%A8%8E-%E5%8F%97%E5%AE%B3%E8%80%85-%E6%B3%95%E5%9B%BD%E7%93%A6%E7%89%B9%E9%87%8C%E6%9C%BA%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779011900000.webp","sourceId":"rfi"},{"id":1779011532000,"createdDate":"2026-05-17 09:52","name":"法国国际广播电台","title":"当AI闯入戛纳：索德伯格“重现”列侬最后采访引争议","content":"2026年戛纳电影节期间，关于人工智能是否应该进入电影工业的争论，再次成为行业焦点。从编剧、演员到后期制作，人工智能技术正在快速渗透电影制作流程，但与此同时，关于版权、创作伦理与艺术真实性的担忧也在持续扩大。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260517-%E5%BD%93ai%E9%97%AF%E5%85%A5%E6%88%9B%E7%BA%B3-%E7%B4%A2%E5%BE%B7%E4%BC%AF%E6%A0%BC-%E9%87%8D%E7%8E%B0-%E5%88%97%E4%BE%AC%E6%9C%80%E5%90%8E%E9%87%87%E8%AE%BF%E5%BC%95%E4%BA%89%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779011532000.webp","sourceId":"rfi"}]