[{"id":1779008300000,"createdDate":"2026-05-17 08:58","name":"法国国际广播电台","title":"日本参加向霍尔木兹海峡派遣多国籍部队计划的联合声明","content":"日本防卫大臣小泉进次郎在15日的记者会上表示，日本已参加英国公布的有关向霍尔木兹海峡派遣多国籍部队计划的联合声明，但他指出：这并不意味着日本预先决定参加多国籍军事任务。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260517-%E6%97%A5%E6%9C%AC%E5%8F%82%E5%8A%A0%E5%90%91%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%B4%BE%E9%81%A3%E5%A4%9A%E5%9B%BD%E7%B1%8D%E9%83%A8%E9%98%9F%E8%AE%A1%E5%88%92%E7%9A%84%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779008300000.webp","sourceId":"rfi"},{"id":1779006390000,"createdDate":"2026-05-17 08:26","name":"法国国际广播电台","title":"朝韩关系紧张背景下 朝鲜女足俱乐部抵韩参赛 8年来首次","content":"在朝韩关系紧张背景下，朝鲜职业女子足球俱乐部“我故乡FC”周日（5月17日）抵达韩国，参加亚足联女子冠军联赛半决赛。这是朝鲜运动员8年来首次访问韩国。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260517-%E6%9C%9D%E9%9F%A9%E5%85%B3%E7%B3%BB%E7%B4%A7%E5%BC%A0%E8%83%8C%E6%99%AF%E4%B8%8B-%E6%9C%9D%E9%B2%9C%E5%A5%B3%E8%B6%B3%E4%BF%B1%E4%B9%90%E9%83%A8%E6%8A%B5%E9%9F%A9%E5%8F%82%E8%B5%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779006390000.webp","sourceId":"rfi"},{"id":1779004823000,"createdDate":"2026-05-17 08:00","name":"法国国际广播电台","title":"俄罗斯遭大规模无人机袭击至少四人死亡","content":"俄罗斯当局周日表示，乌克兰对俄罗斯发动的大规模无人机袭击造成至少四人死亡。一家炼油厂附近建筑工地多名工人受伤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260517-%E4%BF%84%E7%BD%97%E6%96%AF%E9%81%AD%E5%A4%A7%E8%A7%84%E6%A8%A1%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB%E8%87%B3%E5%B0%91%E5%9B%9B%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779004823000.webp","sourceId":"rfi"},{"id":1779034172000,"createdDate":"2026-05-17 16:09","name":"法国国际广播电台","title":"法广2026年5月17日第二次播音 北京时间19至20点","content":"","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%AC%AC%E4%BA%8C%E6%AC%A1%E6%92%AD%E9%9F%B3-19-00-20-00-%E5%8C%97%E4%BA%AC%E6%97%B6%E9%97%B4/20260517-%E6%B3%95%E5%B9%BF2026%E5%B9%B45%E6%9C%8817%E6%97%A5%E7%AC%AC%E4%BA%8C%E6%AC%A1%E6%92%AD%E9%9F%B3-%E5%8C%97%E4%BA%AC%E6%97%B6%E9%97%B419%E8%87%B320%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779034172000.webp","sourceId":"rfi"},{"id":1779034152000,"createdDate":"2026-05-17 16:09","name":"法国国际广播电台","title":"台湾总统：捍卫中华民国现状没有「台独」问题","content":"中央社台北17日电：台湾总统赖清德今天听取国安团队就最新情势进行完整了解与讨论后，向国人说明，台湾是台海及区域和平稳定现状的维护者；中国才是区域不稳定及改变现状的根源；捍卫中华民国现状，没有「台独」问题；台海和平稳定绝不会被牺牲或交易等5个要点。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260517-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F-%E6%8D%8D%E5%8D%AB%E4%B8%AD%E5%8D%8E%E6%B0%91%E5%9B%BD%E7%8E%B0%E7%8A%B6%E6%B2%A1%E6%9C%89-%E5%8F%B0%E7%8B%AC-%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779034152000.webp","sourceId":"rfi"},{"id":1779031129000,"createdDate":"2026-05-17 15:18","name":"法国国际广播电台","title":"以色列击毙策划10.7袭击的哈马斯最后一名领导人","content":"以色列周五空袭加沙城一栋居民楼后，以色列军方和哈马斯官员周六证实了埃兹丁·哈达德的死亡。以军一名官员称，此人被描述为最后一名“参与策划10.7屠杀并仍留在加沙地带的哈马斯领导人”。据哈马斯人士说，他六次逃脱追杀。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260517-%E4%BB%A5%E8%89%B2%E5%88%97%E5%87%BB%E6%AF%99%E7%AD%96%E5%88%9210-7%E8%A2%AD%E5%87%BB%E7%9A%84%E5%93%88%E9%A9%AC%E6%96%AF%E6%9C%80%E5%90%8E%E4%B8%80%E5%90%8D%E9%A2%86%E5%AF%BC%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779031129000.webp","sourceId":"rfi"},{"id":1779021755000,"createdDate":"2026-05-17 12:42","name":"法国国际广播电台","title":"伊朗首席谈判代表加利巴夫被任命负责中国事务","content":"伊朗媒体周日报道，伊朗议会议长兼该国与美国谈判的主要代表穆罕默德·加利巴夫被委任负责对华事务。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260517-%E4%BC%8A%E6%9C%97%E9%A6%96%E5%B8%AD%E8%B0%88%E5%88%A4%E4%BB%A3%E8%A1%A8%E5%8A%A0%E5%88%A9%E5%B7%B4%E5%A4%AB%E8%A2%AB%E4%BB%BB%E5%91%BD%E8%B4%9F%E8%B4%A3%E4%B8%AD%E5%9B%BD%E4%BA%8B%E5%8A%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779021755000.webp","sourceId":"rfi"},{"id":1779020663000,"createdDate":"2026-05-17 12:24","name":"法国国际广播电台","title":"刚果（金）埃博拉疫情蔓延至邻国 世卫组织宣布“国际关注突发公共卫生事件”","content":"中非国家刚果民主共和国（ 简称刚果（金））新一波埃博拉疫情已蔓延至邻国，在乌干达发生一起感染死亡后，南苏丹进入警戒状态，肯尼亚正加紧国家级应对。世卫组织周日（5月17日）宣布，该疫情已构成“国际关注的突发公共卫生事件（PHEIC）”，这是世卫组织目前第二高级别的国际卫生警报。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260517-%E5%88%9A%E6%9E%9C-%E9%87%91-%E5%9F%83%E5%8D%9A%E6%8B%89%E7%96%AB%E6%83%85%E8%94%93%E5%BB%B6%E8%87%B3%E9%82%BB%E5%9B%BD-%E4%B8%96%E5%8D%AB%E7%BB%84%E7%BB%87%E5%AE%A3%E5%B8%83%E6%9E%84%E6%88%90-%E5%9B%BD%E9%99%85%E5%85%B3%E6%B3%A8%E7%AA%81%E5%8F%91%E5%85%AC%E5%85%B1%E5%8D%AB%E7%94%9F%E4%BA%8B%E4%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779020663000.webp","sourceId":"rfi"},{"id":1779019357000,"createdDate":"2026-05-17 12:02","name":"法国国际广播电台","title":"台湾总统重申台湾独立于北京","content":"路透社17日台北消息，台湾总统赖清德周日重申了台湾的独立地位，他认为台湾不属于北京，也不从属于北京，只有台湾人民才能决定台湾的未来。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260517-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E9%87%8D%E7%94%B3%E5%8F%B0%E6%B9%BE%E7%8B%AC%E7%AB%8B%E4%BA%8E%E5%8C%97%E4%BA%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779019357000.webp","sourceId":"rfi"},{"id":1779014499000,"createdDate":"2026-05-17 10:41","name":"法国国际广播电台","title":"美加芬三国破冰船合作计划","content":"5月5日至7日，美加芬三国破冰船合作计划（ICEPact）在赫尔辛基举办了工作组会议和国家协调员会议，讨论协议的实际进展，并参观了赫尔辛基造船厂和“北极星”号破冰船。2025年11月，加拿大、芬兰和美国正式签署了破冰船合作计划，三国将在未来几年合作建造11艘新型破冰船，以对抗俄罗斯和中国在北极地区日益增长的影响力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%8C%97%E7%BE%8E%E6%9D%A5%E9%B8%BF/20260517-%E7%BE%8E%E5%8A%A0%E8%8A%AC%E4%B8%89%E5%9B%BD%E7%A0%B4%E5%86%B0%E8%88%B9%E5%90%88%E4%BD%9C%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779014499000.webp","sourceId":"rfi"},{"id":1779011900000,"createdDate":"2026-05-17 09:58","name":"法国国际广播电台","title":"“中国小包裹税”受害者：法国瓦特里机场","content":"各位好，今天是2026年5月17日星期日。由于本台订阅的法国主流日刊周末大多不出刊，我们在出刊的法国世界报当中为您提取与中国相关的文章做综述。本期出刊的世界报有关中国的报道有两则。第一则题为“特朗普在北京热情但收效甚微的访问”。世界报在另外一篇报道中关注了法国的瓦特里机场，正在成为中国小包裹税的受害者。文中指出，自3月1日法国开始实施针对来自中国的小包裹的相关政策的以来，马恩省机场的运输量下降了70%，物流被重新导向其他欧洲国家。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260517-%E4%B8%AD%E5%9B%BD%E5%B0%8F%E5%8C%85%E8%A3%B9%E7%A8%8E-%E5%8F%97%E5%AE%B3%E8%80%85-%E6%B3%95%E5%9B%BD%E7%93%A6%E7%89%B9%E9%87%8C%E6%9C%BA%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779011900000.webp","sourceId":"rfi"},{"id":1779011532000,"createdDate":"2026-05-17 09:52","name":"法国国际广播电台","title":"当AI闯入戛纳：索德伯格“重现”列侬最后采访引争议","content":"2026年戛纳电影节期间，关于人工智能是否应该进入电影工业的争论，再次成为行业焦点。从编剧、演员到后期制作，人工智能技术正在快速渗透电影制作流程，但与此同时，关于版权、创作伦理与艺术真实性的担忧也在持续扩大。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260517-%E5%BD%93ai%E9%97%AF%E5%85%A5%E6%88%9B%E7%BA%B3-%E7%B4%A2%E5%BE%B7%E4%BC%AF%E6%A0%BC-%E9%87%8D%E7%8E%B0-%E5%88%97%E4%BE%AC%E6%9C%80%E5%90%8E%E9%87%87%E8%AE%BF%E5%BC%95%E4%BA%89%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779011532000.webp","sourceId":"rfi"},{"id":1779055573000,"createdDate":"2026-05-17 22:06","name":"法国国际广播电台","title":"“台独”成陷阱？ 赖清德回应特朗普","content":"台湾总统赖清德周日晚间透过脸书发表文章，台湾致力于捍卫中华民国现状，没有“台独”问题。台海和平稳定绝不会被牺牲或交易。此前，美国总统特朗普曾暗示，可能利用对台军售作为与中方谈判的筹码。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260517-%E5%8F%B0%E7%8B%AC-%E6%88%90%E9%99%B7%E9%98%B1-%E8%B5%96%E6%B8%85%E5%BE%B7%E5%9B%9E%E5%BA%94%E7%89%B9%E6%9C%97%E6%99%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779055573000.webp","sourceId":"rfi"},{"id":1779054563000,"createdDate":"2026-05-17 21:49","name":"法国国际广播电台","title":"“中美两国体制正在逐渐趋同并相互混合”","content":"美国总统特朗普访问北京，在欧洲（包括法国）引发了一波评论潮。法国政治学家、中国问题专家斯蒂芬妮·巴尔默（StéphanieBalme）在发表于法国《世界报》的一篇评论文章中指出，对欧洲来说，真正的风险并不在于华盛顿与北京展开对抗，而在于这两个既相互竞争、又越来越遵循相似逻辑的大国，最终形成一种“共处的模式”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%9B%BD%E9%99%85%E7%BA%B5%E6%A8%AA/20260517-%E4%B8%AD%E7%BE%8E%E4%B8%A4%E5%9B%BD%E7%9A%84%E4%BD%93%E5%88%B6%E6%AD%A3%E5%9C%A8%E9%80%90%E6%B8%90%E8%B6%8B%E5%90%8C%E5%B9%B6%E7%9B%B8%E4%BA%92%E6%B7%B7%E5%90%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779054563000.webp","sourceId":"rfi"},{"id":1779053621000,"createdDate":"2026-05-17 21:33","name":"法国国际广播电台","title":"韩美领导人通话 特朗普向李在明通报美中峰会结果","content":"韩国总统李在明周日(5月17日）与美国总统特朗普通电话，韩国总统府称，双方讨论了近期美中峰会成果。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260517-%E9%9F%A9%E7%BE%8E%E9%A2%86%E5%AF%BC%E4%BA%BA%E9%80%9A%E8%AF%9D-%E7%89%B9%E6%9C%97%E6%99%AE%E5%90%91%E6%9D%8E%E5%9C%A8%E6%98%8E%E9%80%9A%E6%8A%A5%E7%BE%8E%E4%B8%AD%E5%B3%B0%E4%BC%9A%E7%BB%93%E6%9E%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779053621000.webp","sourceId":"rfi"},{"id":1779053443000,"createdDate":"2026-05-17 21:30","name":"法国国际广播电台","title":"白宫：中国承诺未来三年每年至少采购170亿美元美国农产品","content":"美国白宫周日(5月17日）公布的一份文件显示，中国承诺将在2026年至2028年期间，每年至少采购170亿美元美国农产品。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260517-%E7%99%BD%E5%AE%AB-%E4%B8%AD%E5%9B%BD%E6%89%BF%E8%AF%BA%E6%9C%AA%E6%9D%A5%E4%B8%89%E5%B9%B4%E6%AF%8F%E5%B9%B4%E8%87%B3%E5%B0%91%E9%87%87%E8%B4%AD170%E4%BA%BF%E7%BE%8E%E5%85%83%E7%BE%8E%E5%9B%BD%E5%86%9C%E4%BA%A7%E5%93%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779053443000.webp","sourceId":"rfi"},{"id":1779053338000,"createdDate":"2026-05-17 21:28","name":"法国国际广播电台","title":"刚果(金)爆发第17轮埃博拉疫情","content":"世界卫生组织（OMS）总干事谭德塞博士（Dr.TedrosAdhanomGhebreyesus）于2026年05月17日星期天宣布，刚果民主共和国(RDCongo)爆发的最新一轮埃博拉疫情（Ebola），也就是该国的第十七次埃博拉疫情现已被定性为“国际关注的突发公共卫生事件”（USPPI-uneUrgencedeSantéPubliquedePortéeInternationale）。这是本台法广非洲组（RFIAfrique）今天2026年05月17号星期日的焦点新闻之一。受到新一轮埃博拉疫情（Ebola）的影响，刚果（金）已记录到300宗疑似病例和近90宗可能与此病毒相关的死亡病例。刚果（金）的邻国乌干达（l'Ouganda）也传出有一名患者死亡。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260517-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%88%9A%E6%9E%9C-%E9%87%91-%E7%88%86%E5%8F%91%E7%AC%AC17%E8%BD%AE%E5%9F%83%E5%8D%9A%E6%8B%89%E7%96%AB%E6%83%85","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779053338000.webp","sourceId":"rfi"},{"id":1779053223000,"createdDate":"2026-05-17 21:27","name":"法国国际广播电台","title":"挪威：一名中国人因间谍罪被捕","content":"挪威国内安全局周日宣布，在该国北部逮捕了一名涉嫌从事间谍活动的中国公民，此前仅数周，一名涉嫌窃取卫星数据的中国女子已被捕。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260517-%E6%8C%AA%E5%A8%81-%E4%B8%80%E5%90%8D%E4%B8%AD%E5%9B%BD%E4%BA%BA%E5%9B%A0%E9%97%B4%E8%B0%8D%E7%BD%AA%E8%A2%AB%E6%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779053223000.webp","sourceId":"rfi"},{"id":1779053184000,"createdDate":"2026-05-17 21:26","name":"法国国际广播电台","title":"美贸易代表格里尔：特朗普权衡对台军售 美中关系成关键因素","content":"美国贸易代表格里尔周日（5月17日）在一档政论节目中表示，美国总统特朗普正在权衡如何推进对台军售，同时强调维持美中关系稳定“至关重要”。他指出，美国去年对华贸易逆差减少约30%，而美国维持对华关税与中国扩大开放美国农产品市场之间“存在相互影响”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260517-%E7%BE%8E%E8%B4%B8%E6%98%93%E4%BB%A3%E8%A1%A8%E6%A0%BC%E9%87%8C%E5%B0%94-%E7%89%B9%E6%9C%97%E6%99%AE%E6%9D%83%E8%A1%A1%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE-%E7%BE%8E%E4%B8%AD%E5%85%B3%E7%B3%BB%E6%88%90%E5%85%B3%E9%94%AE%E5%9B%A0%E7%B4%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779053184000.webp","sourceId":"rfi"},{"id":1779052909000,"createdDate":"2026-05-17 21:21","name":"法国国际广播电台","title":"阿联酋核电站附近遭无人机袭击 阿布扎比谴责“危险升级”","content":"阿联酋当局周日(5月17日）表示，位于该国西部的巴拉卡（Barakah）核电站附近当天遭无人机袭击并引发火灾，事件未造成人员伤亡，也没有导致辐射水平上升。阿布扎比谴责此次事件是“危险升级”，总统外交顾问暗示伊朗可能牵涉其中。沙特也谴责针对阿联酋核设施附近的袭击，称袭击\"危及地区稳定\"。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260517-%E9%98%BF%E8%81%94%E9%85%8B%E6%A0%B8%E7%94%B5%E7%AB%99%E9%99%84%E8%BF%91%E9%81%AD%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB-%E9%98%BF%E5%B8%83%E6%89%8E%E6%AF%94%E8%B0%B4%E8%B4%A3-%E5%8D%B1%E9%99%A9%E5%8D%87%E7%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779052909000.webp","sourceId":"rfi"},{"id":1779052604000,"createdDate":"2026-05-17 21:16","name":"法国国际广播电台","title":"特朗普再次向伊朗发警告 Axios：白宫将讨论对伊军事选项","content":"美伊之间的谈判持续陷入僵局。美国总统特朗普周日(5月17日）在其真实社交平台(TruthSocial）上警告称，如果德黑兰拒绝与华盛顿达成协议，“伊朗将荡然无存”。美国新闻网Axios称：特朗普将召集安全团队讨论对伊军事选项。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260517-%E7%89%B9%E6%9C%97%E6%99%AE%E5%86%8D%E6%AC%A1%E5%90%91%E4%BC%8A%E6%9C%97%E5%8F%91%E8%AD%A6%E5%91%8A-axios-%E7%99%BD%E5%AE%AB%E5%B0%86%E8%AE%A8%E8%AE%BA%E5%AF%B9%E4%BC%8A%E5%86%9B%E4%BA%8B%E9%80%89%E9%A1%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779052604000.webp","sourceId":"rfi"},{"id":1779052557000,"createdDate":"2026-05-17 21:15","name":"法国国际广播电台","title":"《奥格斯堡汇报》：美国正在枯萎","content":"德国媒体对美国总统特朗普访华表示了多方关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260517-%E5%A5%A5%E6%A0%BC%E6%96%AF%E5%A0%A1%E6%B1%87%E6%8A%A5-%E7%BE%8E%E5%9B%BD%E6%AD%A3%E5%9C%A8%E6%9E%AF%E8%90%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779052557000.webp","sourceId":"rfi"},{"id":1779052207000,"createdDate":"2026-05-17 21:10","name":"法国国际广播电台","title":"美贸易代表：中国同意不对伊朗提供实质支持","content":"美国贸易代表格里尔（JamiesonGreer）17日接受美国广播公司（ABCNews）政论节目“本周”（ThisWeek）访问时表示，美国总统特朗普（DonaldTrump）日前在北京与中国国家主席习近平会谈时，并未要求中国直接协助重开霍尔木兹海峡，而是要求北京不要向伊朗提供“实质支持”，并称中方已作出相关承诺。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260517-%E7%BE%8E%E8%B4%B8%E6%98%93%E4%BB%A3%E8%A1%A8-%E4%B8%AD%E5%9B%BD%E5%90%8C%E6%84%8F%E4%B8%8D%E5%AF%B9%E4%BC%8A%E6%9C%97%E6%8F%90%E4%BE%9B%E5%AE%9E%E8%B4%A8%E6%94%AF%E6%8C%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779052207000.webp","sourceId":"rfi"},{"id":1779043678000,"createdDate":"2026-05-17 18:47","name":"法国国际广播电台","title":"非洲大陆LGBTQ+刑律松紧各异","content":"每年的5月17日为国际不再恐惧同性恋、跨性别与双性恋日，即世界不再恐同日（Journéemondialecontrel'homophobie,latransphobieetlabiphobie）。选择这一日期是为了纪念1990年5月17日，世界卫生组织（世卫组织）将同性恋从精神疾病列表中移除。2026年05月17日是个星期天。本台法广非洲组（RFIAfrique）的法文报导介绍说，虽然博茨瓦纳刚刚完成非刑事化进程，但非洲大陆的情况远非靓丽。一些国家的新法律如今惩处同性恋。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260517-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2%E5%A4%A7%E9%99%86lgbtq-%E5%88%91%E5%BE%8B%E6%9D%BE%E7%B4%A7%E5%90%84%E5%BC%82","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779043678000.webp","sourceId":"rfi"},{"id":1779040697000,"createdDate":"2026-05-17 17:58","name":"法国国际广播电台","title":"有称特朗普与习近平谍对谍！","content":"美国总统特朗普15日结束访中打道回府。随团记者爆料白宫官员在登上空军一号前收集中共官员分发的所有物品全数丢进垃圾桶，称这些东西“一律不准带上飞机”。还传川普在访中期间没有吃任何中方准备的食物，​据说，是为严防食物被植入微型奈米技术，有人说这是活脱一场“谍对谍”情报战。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260517-%E6%9C%89%E7%A7%B0-%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%8E%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%B0%8D%E5%AF%B9%E8%B0%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779040697000.webp","sourceId":"rfi"},{"id":1779037473000,"createdDate":"2026-05-17 17:04","name":"法国国际广播电台","title":"蒋万安：中华民国本来就是主权独立国家","content":"中央社台北17日电：台北市长蒋万安今天说，中华民国本来就是主权独立国家，应该要问民进党是否删除台独党纲。之前一天，民进党台北市长参选人沈伯洋表示，「台独就是台湾是主权独立的国家，这也是现状」。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260517-%E8%92%8B%E4%B8%87%E5%AE%89-%E4%B8%AD%E5%8D%8E%E6%B0%91%E5%9B%BD%E6%9C%AC%E6%9D%A5%E5%B0%B1%E6%98%AF%E4%B8%BB%E6%9D%83%E7%8B%AC%E7%AB%8B%E5%9B%BD%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/17/1779037473000.webp","sourceId":"rfi"}]