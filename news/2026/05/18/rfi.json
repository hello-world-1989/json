[{"id":1779097479000,"createdDate":"2026-05-18 09:44","name":"法国国际广播电台","title":"韩国影史最烧钱巨制《希望》亮相戛纳  朴赞郁：很高兴韩国成为“世界电影的重要中心之一”","content":"截至周一（5月18日），22部金棕榈奖竞赛片中已有13部在戛纳电影节完成放映。虽然其中部分作品获得评论界好评，但尚未出现真正意义上的“全场沸腾”之作。不过，在本届电影节好莱坞缺席的情况下，韩国电影的商业巨制成为焦点。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260518-%E9%9F%A9%E5%9B%BD%E5%BD%B1%E5%8F%B2%E6%9C%80%E7%83%A7%E9%92%B1%E5%B7%A8%E5%88%B6-%E5%B8%8C%E6%9C%9B-%E4%BA%AE%E7%9B%B8%E6%88%9B%E7%BA%B3-%E6%9C%B4%E8%B5%9E%E9%83%81-%E5%BE%88%E9%AB%98%E5%85%B4%E9%9F%A9%E5%9B%BD%E6%88%90%E4%B8%BA-%E4%B8%96%E7%95%8C%E7%94%B5%E5%BD%B1%E7%9A%84%E9%87%8D%E8%A6%81%E4%B8%AD%E5%BF%83%E4%B9%8B%E4%B8%80","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779097479000.webp","sourceId":"rfi"},{"id":1779094688000,"createdDate":"2026-05-18 08:58","name":"法国国际广播电台","title":"日本首相高市早苗19日至20日访韩前往李在明故乡","content":"韩国总统府17日宣布，将以“准国宾待遇”欢迎高市早苗于19日至20日访问韩国。19日，双方将在安东——韩国总统李在明的故乡举行首脑会谈。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260518-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%9719%E6%97%A5%E8%87%B320%E6%97%A5%E8%AE%BF%E9%9F%A9%E5%89%8D%E5%BE%80%E6%9D%8E%E5%9C%A8%E6%98%8E%E6%95%85%E4%B9%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779094688000.webp","sourceId":"rfi"},{"id":1779094362000,"createdDate":"2026-05-18 08:52","name":"法国国际广播电台","title":"特习会后掀「台独问题」风波 国民党质疑赖清德用中华民国偷渡台独","content":"特习会后台湾总统赖清德以「没有台独问题」来回应特朗铺普会后受访的涉台言论。这引起在野批评民进党是否封存台独，更质疑其模糊真正的国家定位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260518-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%90%8E%E6%8E%80-%E5%8F%B0%E7%8B%AC%E9%97%AE%E9%A2%98-%E9%A3%8E%E6%B3%A2-%E5%9B%BD%E6%B0%91%E5%85%9A%E8%B4%A8%E7%96%91%E8%B5%96%E6%B8%85%E5%BE%B7%E7%94%A8%E4%B8%AD%E5%8D%8E%E6%B0%91%E5%9B%BD%E5%81%B7%E6%B8%A1%E5%8F%B0%E7%8B%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779094362000.webp","sourceId":"rfi"},{"id":1779094054000,"createdDate":"2026-05-18 08:47","name":"法国国际广播电台","title":"至少第六名为宏福苑火灾发声者遭拘控 争取开业主会的推手涉嫌诈骗被捕","content":"在中国高官警戒有人借导致168人死亡的宏福苑大火「以灾乱港」後，香港警方拘捕发起业主联署丶要求召开业主大会的前法团管委会成员江祥发，指他涉嫌在2020年虚报三个月公司收入，有诈骗政府疫情纾困拍施之一的担保特惠贷款之嫌，成为至少第六名有为火灾发声纪录而以不同罪名被捕甚至被起诉的市民。有评论忧灾民会因此噤声，惟有接受政府安排。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260518-%E8%87%B3%E5%B0%91%E7%AC%AC%E5%85%AD%E5%90%8D%E4%B8%BA%E5%AE%8F%E7%A6%8F%E8%8B%91%E7%81%AB%E7%81%BE%E5%8F%91%E5%A3%B0%E8%80%85%E9%81%AD%E6%8B%98%E6%8E%A7-%E4%BA%89%E5%8F%96%E5%BC%80%E4%B8%9A%E4%B8%BB%E4%BC%9A%E7%9A%84%E6%8E%A8%E6%89%8B%E6%B6%89%E5%AB%8C%E8%AF%88%E9%AA%97%E8%A2%AB%E6%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779094054000.webp","sourceId":"rfi"},{"id":1779093921000,"createdDate":"2026-05-18 08:45","name":"法国国际广播电台","title":"黄之锋涉「勾外」案将在可判较高刑罚的法庭开审 多国领事旁听","content":"前香港众志秘书长黄之锋在狱中被港府加控「串谋勾结外国势力」罪一案，经历两次提堂及四次提讯后，已完成交付高等法院审理的程序，正等候法院公布正式开审日期。包括法国在内的多个欧美国家驻港领事馆人员有到场旁听，而黄之锋手持中共前在港最高负责人许家屯的回忆录更惹来关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260518-%E9%BB%84%E4%B9%8B%E9%94%8B%E6%B6%89-%E5%8B%BE%E5%A4%96-%E6%A1%88%E5%B0%86%E5%9C%A8%E5%8F%AF%E5%88%A4%E8%BE%83%E9%AB%98%E5%88%91%E7%BD%9A%E7%9A%84%E6%B3%95%E5%BA%AD%E5%BC%80%E5%AE%A1-%E5%A4%9A%E5%9B%BD%E9%A2%86%E4%BA%8B%E6%97%81%E5%90%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779093921000.webp","sourceId":"rfi"},{"id":1779092731000,"createdDate":"2026-05-18 08:25","name":"法国国际广播电台","title":"稀土：堪培拉下令与中国有关联投资者出售所持澳公司股份","content":"澳大利亚政府周一（5月18日）下令多个与中国有关联的股东，出售其所持有的澳大利亚稀土生产商北方矿业公司（NorthernMinerals）的股份。这是堪培拉两年来第二次采取类似干预措施，旨在保护该战略性行业免受外部势力影响。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260518-%E7%A8%80%E5%9C%9F-%E5%A0%AA%E5%9F%B9%E6%8B%89%E4%B8%8B%E4%BB%A4%E4%B8%8E%E4%B8%AD%E5%9B%BD%E6%9C%89%E5%85%B3%E8%81%94%E6%8A%95%E8%B5%84%E8%80%85%E5%87%BA%E5%94%AE%E6%89%80%E6%8C%81%E6%BE%B3%E5%85%AC%E5%8F%B8%E8%82%A1%E4%BB%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779092731000.webp","sourceId":"rfi"},{"id":1779123232000,"createdDate":"2026-05-18 16:53","name":"法国国际广播电台","title":"世界卫生组织79届年会登场 美国和阿根廷要求退出 台湾寻求加入","content":"世界卫生组织第79届年度大会5月18日周一在日内瓦登场，埃博拉疫情与汉坦病毒突发事件都未列入议程，但受到全球关注。此外，该组织还面临改革，选举，美国和阿根廷的退出，以及台湾继续寻求加入。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260518-%E4%B8%96%E7%95%8C%E5%8D%AB%E7%94%9F%E7%BB%84%E7%BB%8779%E5%B1%8A%E5%B9%B4%E4%BC%9A%E7%99%BB%E5%9C%BA-%E7%BE%8E%E5%9B%BD%E5%92%8C%E9%98%BF%E6%A0%B9%E5%BB%B7%E8%A6%81%E6%B1%82%E9%80%80%E5%87%BA-%E5%8F%B0%E6%B9%BE%E5%AF%BB%E6%B1%82%E5%8A%A0%E5%85%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779123232000.webp","sourceId":"rfi"},{"id":1779117998000,"createdDate":"2026-05-18 15:26","name":"法国国际广播电台","title":"法广2026年5月18日第二次中文播音 北京时间19-20点","content":"","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%AC%AC%E4%BA%8C%E6%AC%A1%E6%92%AD%E9%9F%B3-19-00-20-00-%E5%8C%97%E4%BA%AC%E6%97%B6%E9%97%B4/20260518-%E6%B3%95%E5%B9%BF2026%E5%B9%B45%E6%9C%8818%E6%97%A5%E7%AC%AC%E4%BA%8C%E6%AC%A1%E4%B8%AD%E6%96%87%E6%92%AD%E9%9F%B3-%E5%8C%97%E4%BA%AC%E6%97%B6%E9%97%B419-20%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779117998000.webp","sourceId":"rfi"},{"id":1779113517000,"createdDate":"2026-05-18 14:11","name":"法国国际广播电台","title":"刚果(金)埃博拉疫情扩散风险很高","content":"世界卫生组织（OMS）总干事谭德塞博士（Dr.TedrosAdhanomGhebreyesus）于2026年05月17日星期天宣布，刚果民主共和国(RDCongo)爆发的最新一轮埃博拉疫情（Ebola），也就是该国的第17次埃博拉疫情现已被定性为“国际关注的突发公共卫生事件”（USPPI-uneUrgencedeSantéPubliquedePortéeInternationale）。这是本台法广非洲组（RFIAfrique）连续两天关注的焦点新闻之一。自周日以来，已有多位国际知名的病毒学家分别接受了本台法广（RFI）不同法语专栏的采访，其中有刚果著名病毒学教授Pr.Jean-JacquesMuyembe和法国巴斯德研究院（InstitutPasteur）病毒学博士Dr.SylvainBlaize。受到新一轮埃博拉疫情（Ebola）的影响，刚果（金）已记录到200多宗疑似病例和近90宗可能与这一病毒相关的死亡病例。刚果（金）的邻国乌干达（l'Ouganda）也传出有一名患者死亡。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260518-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%88%9A%E6%9E%9C-%E9%87%91-%E5%9F%83%E5%8D%9A%E6%8B%89%E7%96%AB%E6%83%85%E6%89%A9%E6%95%A3%E9%A3%8E%E9%99%A9%E5%BE%88%E9%AB%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779113517000.webp","sourceId":"rfi"},{"id":1779112846000,"createdDate":"2026-05-18 14:00","name":"法国国际广播电台","title":"香港：天安门纪念活动人士审判进入最后陈述阶段","content":"据法新社5月18日香港消息，两名被控危害国家安全的香港民主活动人士及天安门事件烛光纪念活动组织者李卓人和邹幸彤，周一在香港一家法庭开始进行最后陈述。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260518-%E9%A6%99%E6%B8%AF-%E5%A4%A9%E5%AE%89%E9%97%A8%E7%BA%AA%E5%BF%B5%E6%B4%BB%E5%8A%A8%E4%BA%BA%E5%A3%AB%E5%AE%A1%E5%88%A4%E8%BF%9B%E5%85%A5%E6%9C%80%E5%90%8E%E9%99%88%E8%BF%B0%E9%98%B6%E6%AE%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779112846000.webp","sourceId":"rfi"},{"id":1779110576000,"createdDate":"2026-05-18 13:22","name":"法国国际广播电台","title":"中东冲突引发的能源危机重挫印度的大国雄心","content":"如果说严重依赖石油进口的亚洲国家深受当前中东冲突引发的能源危机影响的话，这场危机显然也正重挫印度总理莫迪的大国雄心。继2025年自称已经超越日本成为世界第四达经济体后，莫迪的目标是让印度是位居中美之后的第三把交椅。但国际货币基金组织近日重新将这个人口大国列为排在英国之后的第六大经济体。主要原因是印度货币卢比持续贬值。自美国和以色列2月28日联手向伊朗发动大规模军事行动以来，卢比对美元比价已经下跌超过5%。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E7%BB%8F%E6%B5%8E/20260518-%E4%B8%AD%E4%B8%9C%E5%86%B2%E7%AA%81%E5%BC%95%E5%8F%91%E7%9A%84%E8%83%BD%E6%BA%90%E5%8D%B1%E6%9C%BA%E9%87%8D%E6%8C%AB%E5%8D%B0%E5%BA%A6%E7%9A%84%E5%A4%A7%E5%9B%BD%E9%9B%84%E5%BF%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779110576000.webp","sourceId":"rfi"},{"id":1779106849000,"createdDate":"2026-05-18 12:20","name":"法国国际广播电台","title":"中国汽车攻入欧洲？斯特兰蒂斯为何协助中企绕开欧盟壁垒","content":"各位好，今日出刊的十字架报连登两篇与中国相关的报道，分析中国汽车是否真的正在“入侵”欧洲。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260518-%E4%B8%AD%E5%9B%BD%E6%B1%BD%E8%BD%A6%E6%94%BB%E5%85%A5%E6%AC%A7%E6%B4%B2-%E6%96%AF%E7%89%B9%E5%85%B0%E8%92%82%E6%96%AF%E4%B8%BA%E4%BD%95%E5%8D%8F%E5%8A%A9%E4%B8%AD%E4%BC%81%E7%BB%95%E5%BC%80%E6%AC%A7%E7%9B%9F%E5%A3%81%E5%9E%92","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779106849000.webp","sourceId":"rfi"},{"id":1779106356000,"createdDate":"2026-05-18 12:12","name":"法国国际广播电台","title":"特朗普访华：日本期待什么？担心什么?","content":"美国总统特朗普于2026年5月13日开始访问中国北京，并于次日14日及15日与中国国家主席习近平举行首脑会谈。双方就应对伊朗局势、台湾问题以及美中经济与贸易关系等进行了讨论，虽然也存在意见对立，但通过两国领导人的对话，美中关系仍出现了一定程度的进展。特朗普与习近平在北京举行会谈后，中方说明称，双方确认将构建“具有建设性的战略稳定关系”，而美中关系的变化直接影响日本的安全保障和外交，日本时间15日晚，日本首相高市早苗迫不及待地在特朗普访华后返回美国的途中，正在处于飞行中的空军一号中的特朗普进行了15分钟的电话会谈，询问访华的细节等。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260518-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E-%E6%97%A5%E6%9C%AC%E6%9C%9F%E5%BE%85%E4%BB%80%E4%B9%88-%E6%8B%85%E5%BF%83%E4%BB%80%E4%B9%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779106356000.webp","sourceId":"rfi"},{"id":1779106224000,"createdDate":"2026-05-18 12:10","name":"法国国际广播电台","title":"特朗普再次威胁要将伊朗夷为平地","content":"在与伊朗爆发冲突两个半月后，唐纳德·特朗普再次威胁要将伊朗夷为平地；与此同时，一架无人机在阿联酋一处核设施附近袭击引发火灾，导致周一油价再度上涨。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260518-%E7%89%B9%E6%9C%97%E6%99%AE%E5%86%8D%E6%AC%A1%E5%A8%81%E8%83%81%E8%A6%81%E5%B0%86%E4%BC%8A%E6%9C%97%E5%A4%B7%E4%B8%BA%E5%B9%B3%E5%9C%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779106224000.webp","sourceId":"rfi"},{"id":1779106071000,"createdDate":"2026-05-18 12:07","name":"法国国际广播电台","title":"G7财长会议在巴黎举行 聚焦中东冲突冲击与关键矿产供应安全","content":"七国集团财长和央行代表会议周一（5月18日）在巴黎召开，为期两天的会议重点是讨论应对中东冲突带来的经济影响，并就降低对中国稀土及关键矿产资源的依赖协调立场，东道主法国希望会议展示多边主义，而由于地緣政治的分歧，G7成员间的凝聚力正日益经受考验。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260518-g7%E8%B4%A2%E9%95%BF%E4%BC%9A%E8%AE%AE%E5%9C%A8%E5%B7%B4%E9%BB%8E%E4%B8%BE%E8%A1%8C-%E8%81%9A%E7%84%A6%E4%B8%AD%E4%B8%9C%E5%86%B2%E7%AA%81%E5%86%B2%E5%87%BB%E4%B8%8E%E5%85%B3%E9%94%AE%E7%9F%BF%E4%BA%A7%E4%BE%9B%E5%BA%94%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779106071000.webp","sourceId":"rfi"},{"id":1779105079000,"createdDate":"2026-05-18 11:51","name":"法国国际广播电台","title":"一架俄罗斯无人机在黑海击中一艘中国货轮","content":"乌克兰海军一名发言人向法新社透露，周日深夜至周一凌晨，一架俄罗斯无人机在黑海乌克兰敖德萨港外海击中了一艘中国货轮。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260518-%E4%B8%80%E6%9E%B6%E4%BF%84%E7%BD%97%E6%96%AF%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%9C%A8%E9%BB%91%E6%B5%B7%E5%87%BB%E4%B8%AD%E4%B8%80%E8%89%98%E4%B8%AD%E5%9B%BD%E8%B4%A7%E8%BD%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779105079000.webp","sourceId":"rfi"},{"id":1779101492000,"createdDate":"2026-05-18 10:51","name":"法国国际广播电台","title":"法国电影业最大投资方遭抵制  Canal+在戛纳宣布：约600位明星导演等将被列入合作黑名单","content":"5月的坎城，阳光明媚，海风和煦。一年一度的戛纳电影节于上周盛大开幕，目前进程已过半。而在戛纳现场，一场艺术与政治之争再次扰动整个电影界，引发争议。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%89%B9%E5%88%AB%E8%8A%82%E7%9B%AE/20260518-%E6%B3%95%E5%9B%BD%E7%94%B5%E5%BD%B1%E4%B8%9A%E9%87%8D%E8%A6%81%E6%8A%95%E8%B5%84%E6%96%B9%E9%81%AD%E6%8A%B5%E5%88%B6-canal-%E5%9C%A8%E6%88%9B%E7%BA%B3%E5%AE%A3%E5%B8%83-%E7%BA%A6600%E4%BD%8D%E6%98%8E%E6%98%9F%E5%AF%BC%E6%BC%94%E7%AD%89%E4%BB%8E%E4%B8%9A%E8%80%85%E5%B0%86%E8%A2%AB%E5%88%97%E5%85%A5%E5%90%88%E4%BD%9C%E9%BB%91%E5%90%8D%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779101492000.webp","sourceId":"rfi"},{"id":1779144653000,"createdDate":"2026-05-18 22:50","name":"法国国际广播电台","title":"中东战争背景下，G7财长齐聚巴黎，商讨全球经济问题","content":"七国集团（G7）财政部长正在巴黎举行为期两天的会议，希望就中东冲突带来的经济影响协调立场，同时减少对中国关键矿产资源的依赖。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260518-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E8%83%8C%E6%99%AF%E4%B8%8B%EF%BC%8Cg7%E8%B4%A2%E9%95%BF%E9%BD%90%E8%81%9A%E5%B7%B4%E9%BB%8E%EF%BC%8C%E5%95%86%E8%AE%A8%E5%85%A8%E7%90%83%E7%BB%8F%E6%B5%8E%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779144653000.webp","sourceId":"rfi"},{"id":1779144456000,"createdDate":"2026-05-18 22:47","name":"法国国际广播电台","title":"美称伊朗新方案缺乏实质让步 白宫拟讨论对伊军事选项","content":"美国政府近日对伊朗最新核谈判提案态度转趋强硬。美方官员表示，伊朗透过巴基斯坦转交的新方案缺乏“实质改善”，不足以促成协议。美国总统特朗普（DonaldTrump）则警告，若德黑兰拒绝展现弹性，伊朗“将遭到更猛烈打击”，并暗示美方可能很快采取进一步行动。随着外交进展有限，白宫已重新评估军事选项，中东局势再度升温。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260518-%E7%BE%8E%E7%A7%B0%E4%BC%8A%E6%9C%97%E6%96%B0%E6%96%B9%E6%A1%88%E7%BC%BA%E4%B9%8F%E5%AE%9E%E8%B4%A8%E8%AE%A9%E6%AD%A5-%E7%99%BD%E5%AE%AB%E6%8B%9F%E8%AE%A8%E8%AE%BA%E5%AF%B9%E4%BC%8A%E5%86%9B%E4%BA%8B%E9%80%89%E9%A1%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779144456000.webp","sourceId":"rfi"},{"id":1779144207000,"createdDate":"2026-05-18 22:43","name":"法国国际广播电台","title":"特朗普掉进了中国在对台军售问题上的“谈判陷阱”","content":"特朗普上周对中国的访问继续是法国世界报评论的主题。该报18日周一刊出的一篇文章表示：特朗普掉进了中国在对台军售问题上的“谈判陷阱”。相关的文章首先指出，特朗普希望把台湾军售问题作为中美谈判的“筹码”。这样，特朗普实际上碰触了美国近五十年来外交政策的一条重要底线：这就是，美国不仅有义务向台湾提供武器，而且还承诺不会在对台军售问题上听取中国的意见。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260518-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8E%89%E8%BF%9B%E4%BA%86%E4%B8%AD%E5%9B%BD%E5%9C%A8%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E9%97%AE%E9%A2%98%E4%B8%8A%E7%9A%84-%E8%B0%88%E5%88%A4%E9%99%B7%E9%98%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779144207000.webp","sourceId":"rfi"},{"id":1779142976000,"createdDate":"2026-05-18 22:22","name":"法国国际广播电台","title":"特朗普与赖清德通话的可能性有多大","content":"特习会之后特朗普有关言论引发台湾担忧，台湾方面周一表示，欢迎美国总统特朗普与台湾总统赖清德直接通话，并正就此事与美方接洽。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260518-%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%8E%E8%B5%96%E6%B8%85%E5%BE%B7%E9%80%9A%E8%AF%9D%E7%9A%84%E5%8F%AF%E8%83%BD%E6%80%A7%E6%9C%89%E5%A4%9A%E5%A4%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779142976000.webp","sourceId":"rfi"},{"id":1779140087000,"createdDate":"2026-05-18 21:34","name":"法国国际广播电台","title":"马斯克败诉：加州法院驳回针对OpenAI诉讼","content":"美国亿万富豪埃隆·马斯克（ElonMusk）周一(5月19日）在加州针对OpenAI的高调诉讼中败诉。美国联邦法院认为，马斯克起诉已超过法定时限，因此驳回其关于OpenAI\"背离非营利初心、转向商业化发展\"的指控。马斯克律师称将提出上诉。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260518-%E9%A9%AC%E6%96%AF%E5%85%8B%E8%B4%A5%E8%AF%89-%E5%8A%A0%E5%B7%9E%E6%B3%95%E9%99%A2%E9%A9%B3%E5%9B%9E%E9%92%88%E5%AF%B9openai%E8%AF%89%E8%AE%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779140087000.webp","sourceId":"rfi"},{"id":1779139823000,"createdDate":"2026-05-18 21:30","name":"法国国际广播电台","title":"美国公民在刚果（金）感染埃博拉　华盛顿加强入境卫生管控","content":"美国政府周一(5月18日）宣布，将加强针对埃博拉病毒的边境卫生检查，并收紧部分签证措施。此前，一名美国公民在刚果（金）工作期间感染埃博拉病毒，检测结果呈阳性。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260518-%E7%BE%8E%E5%9B%BD%E5%85%AC%E6%B0%91%E5%9C%A8%E5%88%9A%E6%9E%9C-%E9%87%91-%E6%84%9F%E6%9F%93%E5%9F%83%E5%8D%9A%E6%8B%89-%E5%8D%8E%E7%9B%9B%E9%A1%BF%E5%8A%A0%E5%BC%BA%E5%85%A5%E5%A2%83%E5%8D%AB%E7%94%9F%E7%AE%A1%E6%8E%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779139823000.webp","sourceId":"rfi"},{"id":1779139553000,"createdDate":"2026-05-18 21:25","name":"法国国际广播电台","title":"中美北京峰会后稀土争议未解 白宫称中方将回应供应关切","content":"中美领导人上周在北京达成的一系列协议中，美国虽在稀土供应问题上获得部分进展，但白宫最新表态显示，中国针对关键矿产的出口管制体系恐将长期存在。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260518-%E4%B8%AD%E7%BE%8E%E5%8C%97%E4%BA%AC%E5%B3%B0%E4%BC%9A%E5%90%8E%E7%A8%80%E5%9C%9F%E4%BA%89%E8%AE%AE%E6%9C%AA%E8%A7%A3-%E7%99%BD%E5%AE%AB%E7%A7%B0%E4%B8%AD%E6%96%B9%E5%B0%86%E5%9B%9E%E5%BA%94%E4%BE%9B%E5%BA%94%E5%85%B3%E5%88%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779139553000.webp","sourceId":"rfi"},{"id":1779139339000,"createdDate":"2026-05-18 21:22","name":"法国国际广播电台","title":"特朗普称已\"叫停\"对伊空袭计划 警告若谈判失败将发动“全面攻击”","content":"美国总统特朗普周一(5月19日）表示，他已放弃原定于周二针对伊朗发动的军事打击行动，原因是海湾国家领导人请求美方暂缓行动，并认为与德黑兰达成协议“仍有可能”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260518-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E5%B7%B2-%E5%8F%AB%E5%81%9C-%E5%AF%B9%E4%BC%8A%E7%A9%BA%E8%A2%AD%E8%AE%A1%E5%88%92-%E8%AD%A6%E5%91%8A%E8%8B%A5%E8%B0%88%E5%88%A4%E5%A4%B1%E8%B4%A5%E5%B0%86%E5%8F%91%E5%8A%A8-%E5%85%A8%E9%9D%A2%E6%94%BB%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779139339000.webp","sourceId":"rfi"},{"id":1779135619000,"createdDate":"2026-05-18 20:20","name":"法国国际广播电台","title":"特朗普中国之行是否取得胜利？法国智库专家给答案","content":"美国总统特朗普甫结束中国之行的三天访问，受到习近平给足面子的高规格迎宾礼。法国智库蒙田研究所亚洲与美国事务特别顾问，弗朗索瓦·戈德蒙(FrançoisGodement)应邀做客法国欧洲一台广播电台（Europe1）周末早间节目的专访，对特朗普的此次访华之行进行了评估。他认为，就许多方面而言，此次会晤对华盛顿来说取得了“部分成功”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260518-%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%AD%E5%9B%BD%E4%B9%8B%E8%A1%8C%E6%98%AF%E5%90%A6%E5%8F%96%E5%BE%97%E8%83%9C%E5%88%A9-%E6%B3%95%E5%9B%BD%E6%99%BA%E5%BA%93%E4%B8%93%E5%AE%B6%E7%BB%99%E7%AD%94%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779135619000.webp","sourceId":"rfi"},{"id":1779135419000,"createdDate":"2026-05-18 20:16","name":"法国国际广播电台","title":"欧盟鼓励投资非洲的埃塞俄比亚","content":"在强劲经济增长的推动下，欧洲在2025年对埃塞俄比亚这个非洲之角国家的投资金额大约为5亿欧元，创下自2021年以来的最高水平。然而，尽管埃塞俄比亚是一个前景被看好的市场，但依然被困于动荡和冲突之中。在此背景下，欧盟如何鼓励对埃塞俄比亚展开经济投资？这是本台法广（RFI）法语[非洲经济]专栏（AfriqueEconomie）近日在节目里的探讨话题之一。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260518-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E6%AC%A7%E7%9B%9F%E9%BC%93%E5%8A%B1%E6%8A%95%E8%B5%84%E5%9F%83%E5%A1%9E%E4%BF%84%E6%AF%94%E4%BA%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779135419000.webp","sourceId":"rfi"},{"id":1779125188000,"createdDate":"2026-05-18 17:26","name":"法国国际广播电台","title":"中国乒乓球爱好者愤怒了 要求国际乒联道歉：国旗上多了一颗星","content":"法新社5月18日北京消息，中国乒乓球爱好者愤怒了，要求国际乒联就其官方周边产品上中国国旗的错误作出道歉。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260518-%E4%B8%AD%E5%9B%BD%E4%B9%92%E4%B9%93%E7%90%83%E7%88%B1%E5%A5%BD%E8%80%85%E6%84%A4%E6%80%92%E4%BA%86-%E8%A6%81%E6%B1%82%E5%9B%BD%E9%99%85%E4%B9%92%E8%81%94%E9%81%93%E6%AD%89-%E5%9B%BD%E6%97%97%E4%B8%8A%E5%A4%9A%E4%BA%86%E4%B8%80%E9%A2%97%E6%98%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779125188000.webp","sourceId":"rfi"}]