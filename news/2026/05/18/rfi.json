[{"id":1779097479000,"createdDate":"2026-05-18 09:44","name":"法国国际广播电台","title":"韩国影史最烧钱巨制《希望》亮相戛纳  朴赞郁：很高兴韩国成为“世界电影的重要中心之一”","content":"截至周一（5月18日），22部金棕榈奖竞赛片中已有13部在戛纳电影节完成放映。虽然其中部分作品获得评论界好评，但尚未出现真正意义上的“全场沸腾”之作。不过，在本届电影节好莱坞缺席的情况下，韩国电影的商业巨制成为焦点。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260518-%E9%9F%A9%E5%9B%BD%E5%BD%B1%E5%8F%B2%E6%9C%80%E7%83%A7%E9%92%B1%E5%B7%A8%E5%88%B6-%E5%B8%8C%E6%9C%9B-%E4%BA%AE%E7%9B%B8%E6%88%9B%E7%BA%B3-%E6%9C%B4%E8%B5%9E%E9%83%81-%E5%BE%88%E9%AB%98%E5%85%B4%E9%9F%A9%E5%9B%BD%E6%88%90%E4%B8%BA-%E4%B8%96%E7%95%8C%E7%94%B5%E5%BD%B1%E7%9A%84%E9%87%8D%E8%A6%81%E4%B8%AD%E5%BF%83%E4%B9%8B%E4%B8%80","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779097479000.webp","sourceId":"rfi"},{"id":1779094688000,"createdDate":"2026-05-18 08:58","name":"法国国际广播电台","title":"日本首相高市早苗19日至20日访韩前往李在明故乡","content":"韩国总统府17日宣布，将以“准国宾待遇”欢迎高市早苗于19日至20日访问韩国。19日，双方将在安东——韩国总统李在明的故乡举行首脑会谈。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260518-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%9719%E6%97%A5%E8%87%B320%E6%97%A5%E8%AE%BF%E9%9F%A9%E5%89%8D%E5%BE%80%E6%9D%8E%E5%9C%A8%E6%98%8E%E6%95%85%E4%B9%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779094688000.webp","sourceId":"rfi"},{"id":1779094362000,"createdDate":"2026-05-18 08:52","name":"法国国际广播电台","title":"特习会后掀「台独问题」风波 国民党质疑赖清德用中华民国偷渡台独","content":"特习会后台湾总统赖清德以「没有台独问题」来回应特朗铺普会后受访的涉台言论。这引起在野批评民进党是否封存台独，更质疑其模糊真正的国家定位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260518-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%90%8E%E6%8E%80-%E5%8F%B0%E7%8B%AC%E9%97%AE%E9%A2%98-%E9%A3%8E%E6%B3%A2-%E5%9B%BD%E6%B0%91%E5%85%9A%E8%B4%A8%E7%96%91%E8%B5%96%E6%B8%85%E5%BE%B7%E7%94%A8%E4%B8%AD%E5%8D%8E%E6%B0%91%E5%9B%BD%E5%81%B7%E6%B8%A1%E5%8F%B0%E7%8B%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779094362000.webp","sourceId":"rfi"},{"id":1779094054000,"createdDate":"2026-05-18 08:47","name":"法国国际广播电台","title":"至少第六名为宏福苑火灾发声者遭拘控 争取开业主会的推手涉嫌诈骗被捕","content":"在中国高官警戒有人借导致168人死亡的宏福苑大火「以灾乱港」後，香港警方拘捕发起业主联署丶要求召开业主大会的前法团管委会成员江祥发，指他涉嫌在2020年虚报三个月公司收入，有诈骗政府疫情纾困拍施之一的担保特惠贷款之嫌，成为至少第六名有为火灾发声纪录而以不同罪名被捕甚至被起诉的市民。有评论忧灾民会因此噤声，惟有接受政府安排。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260518-%E8%87%B3%E5%B0%91%E7%AC%AC%E5%85%AD%E5%90%8D%E4%B8%BA%E5%AE%8F%E7%A6%8F%E8%8B%91%E7%81%AB%E7%81%BE%E5%8F%91%E5%A3%B0%E8%80%85%E9%81%AD%E6%8B%98%E6%8E%A7-%E4%BA%89%E5%8F%96%E5%BC%80%E4%B8%9A%E4%B8%BB%E4%BC%9A%E7%9A%84%E6%8E%A8%E6%89%8B%E6%B6%89%E5%AB%8C%E8%AF%88%E9%AA%97%E8%A2%AB%E6%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779094054000.webp","sourceId":"rfi"},{"id":1779093921000,"createdDate":"2026-05-18 08:45","name":"法国国际广播电台","title":"黄之锋涉「勾外」案将在可判较高刑罚的法庭开审 多国领事旁听","content":"前香港众志秘书长黄之锋在狱中被港府加控「串谋勾结外国势力」罪一案，经历两次提堂及四次提讯后，已完成交付高等法院审理的程序，正等候法院公布正式开审日期。包括法国在内的多个欧美国家驻港领事馆人员有到场旁听，而黄之锋手持中共前在港最高负责人许家屯的回忆录更惹来关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260518-%E9%BB%84%E4%B9%8B%E9%94%8B%E6%B6%89-%E5%8B%BE%E5%A4%96-%E6%A1%88%E5%B0%86%E5%9C%A8%E5%8F%AF%E5%88%A4%E8%BE%83%E9%AB%98%E5%88%91%E7%BD%9A%E7%9A%84%E6%B3%95%E5%BA%AD%E5%BC%80%E5%AE%A1-%E5%A4%9A%E5%9B%BD%E9%A2%86%E4%BA%8B%E6%97%81%E5%90%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779093921000.webp","sourceId":"rfi"},{"id":1779092731000,"createdDate":"2026-05-18 08:25","name":"法国国际广播电台","title":"稀土：堪培拉下令与中国有关联投资者出售所持澳公司股份","content":"澳大利亚政府周一（5月18日）下令多个与中国有关联的股东，出售其所持有的澳大利亚稀土生产商北方矿业公司（NorthernMinerals）的股份。这是堪培拉两年来第二次采取类似干预措施，旨在保护该战略性行业免受外部势力影响。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260518-%E7%A8%80%E5%9C%9F-%E5%A0%AA%E5%9F%B9%E6%8B%89%E4%B8%8B%E4%BB%A4%E4%B8%8E%E4%B8%AD%E5%9B%BD%E6%9C%89%E5%85%B3%E8%81%94%E6%8A%95%E8%B5%84%E8%80%85%E5%87%BA%E5%94%AE%E6%89%80%E6%8C%81%E6%BE%B3%E5%85%AC%E5%8F%B8%E8%82%A1%E4%BB%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/18/1779092731000.webp","sourceId":"rfi"}]