[{"id":1778146293000,"createdDate":"2026-05-07 09:31","name":"法国国际广播电台","title":"美财长将在访华前访日协调共同对付中国限制稀土出口等","content":"日美两国政府正在协调美国财政部长贝森特于下周访问日本，并朝着与高市早苗首相等会面的方向进行调整。预计双方将讨论持续出现日元贬值、美元升值趋势的外汇市场动向，并就应对投机性抛售日元的对策展开讨论，此外，贝森特将与美国总统特朗普一起访华，美中定于14日或15日举行的美中首脑会谈。贝森特在此之前访日，双方还可能就中国实施稀土出口限制等问题展开讨论。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260507-%E7%BE%8E%E8%B4%A2%E9%95%BF%E5%B0%86%E5%9C%A8%E8%AE%BF%E5%8D%8E%E5%89%8D%E8%AE%BF%E6%97%A5%E5%8D%8F%E8%B0%83%E5%85%B1%E5%90%8C%E5%AF%B9%E4%BB%98%E4%B8%AD%E5%9B%BD%E9%99%90%E5%88%B6%E7%A8%80%E5%9C%9F%E5%87%BA%E5%8F%A3%E7%AD%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778146293000.webp","sourceId":"rfi"},{"id":1778143694000,"createdDate":"2026-05-07 08:48","name":"法国国际广播电台","title":"特朗普多次失言后，卢比奥到访梵蒂冈与教皇会面缓和紧张关系","content":"美国国务卿卢比奥于周四（5月7日）访问梵蒂冈和意大利，试图缓和与教皇之间的紧张关系，此前总统特朗普曾猛烈抨击教皇利奥十四世。周五（5月8日）卢比奥还将与意大利总理梅洛尼以及外长塔亚尼举行会谈，但两人都曾公开为教皇辩护，并批评对伊朗的战争是非法的，因此也招致了特朗普的不满。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260507-%E5%8D%A2%E6%AF%94%E5%A5%A5%E5%88%B0%E8%AE%BF%E6%A2%B5%E8%92%82%E5%86%88%E4%B8%8E%E6%95%99%E7%9A%87%E4%BC%9A%E9%9D%A2%E7%BC%93%E5%92%8C%E7%B4%A7%E5%BC%A0%E5%85%B3%E7%B3%BB-%E6%9C%89%E5%88%86%E6%9E%90%E7%A7%B0-%E4%B8%8D%E6%98%AF%E5%9C%A8%E4%B8%BA%E7%89%B9%E6%9C%97%E6%99%AE%E5%85%85%E5%BD%93%E8%B0%83%E8%A7%A3%E4%BA%BA%E8%80%8C%E6%98%AF%E6%9C%8D%E5%8A%A1%E6%9C%AC%E4%BA%BA%E6%94%BF%E6%B2%BB%E5%89%8D%E9%80%94","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778143694000.webp","sourceId":"rfi"},{"id":1778142036000,"createdDate":"2026-05-07 08:20","name":"法国国际广播电台","title":"法国外长：只要霍尔木兹海峡仍被封锁就“不可能”解除对伊朗的“任何制裁”","content":"法国外交部长让-诺埃尔·巴罗周四表示，只要霍尔木兹海峡仍处于封锁状态，就不可能解除针对伊朗的“任何一项”国际制裁。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260507-%E6%B3%95%E5%9B%BD%E5%A4%96%E9%95%BF-%E5%8F%AA%E8%A6%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E4%BB%8D%E8%A2%AB%E5%B0%81%E9%94%81%E5%B0%B1-%E4%B8%8D%E5%8F%AF%E8%83%BD-%E8%A7%A3%E9%99%A4%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%9A%84-%E4%BB%BB%E4%BD%95%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778142036000.webp","sourceId":"rfi"},{"id":1778141789000,"createdDate":"2026-05-07 08:16","name":"法国国际广播电台","title":"中非共和国女性迈向自主、被认可之路：先培养一技能","content":"各位听众， 在中非共和国，女性对自身处境的认识日益增强，并积极组织起来，争取解放。各种倡议层出不穷，其共同的愿望是：实现持久的经济独立，并在社会中确立自身地位。长期以来被视为弱势群体的这些女性们，如今她们决心掌握自己的命运。搞创收活动、小本生意、农业、手工艺：尽管面临诸多挑战，这种集体行动正在逐步重塑当地的经济格局。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E9%9D%9E%E6%B4%B2/20260507-%E4%B8%AD%E9%9D%9E%E5%85%B1%E5%92%8C%E5%9B%BD%E5%A5%B3%E6%80%A7%E8%BF%88%E5%90%91%E8%87%AA%E4%B8%BB-%E8%A2%AB%E8%AE%A4%E5%8F%AF%E4%B9%8B%E8%B7%AF-%E5%85%88%E5%9F%B9%E5%85%BB%E4%B8%80%E6%8A%80%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778141789000.webp","sourceId":"rfi"},{"id":1778140774000,"createdDate":"2026-05-07 07:59","name":"法国国际广播电台","title":"安琪巴黎「自由谈」沙龙纪要与述评:――法国戏剧导演 Jérôme Méla谈「舞台的诞生与在场」","content":"2026年4月18日周六，樱花缤纷，满园瑰丽。我非常荣幸地邀请法国戏剧导演杰JérômeMéla先生莅临巴黎「自由谈」沙龙古道且闲庄演讲，题目是「舞台的诞生与在场」（«Lanaissanceetlaprésencedelascène»）。学者、学人、艺术家、音乐家、媒体人等各界人士出席了本次活动。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260507-%E5%AE%89%E7%90%AA%E5%B7%B4%E9%BB%8E-%E8%87%AA%E7%94%B1%E8%B0%88-%E6%B2%99%E9%BE%99%E7%BA%AA%E8%A6%81%E4%B8%8E%E8%BF%B0%E8%AF%84-%E2%80%95%E2%80%95%E6%B3%95%E5%9B%BD%E6%88%8F%E5%89%A7%E5%AF%BC%E6%BC%94-j%C3%A9r%C3%B4me-m%C3%A9la%E8%B0%88-%E8%88%9E%E5%8F%B0%E7%9A%84%E8%AF%9E%E7%94%9F%E4%B8%8E%E5%9C%A8%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778140774000.webp","sourceId":"rfi"},{"id":1778140080000,"createdDate":"2026-05-07 07:48","name":"法国国际广播电台","title":"香港大火灾民不满：政府委任管理人拒开业主会 仅允召开限制多多的简介会","content":"虽经香港四分三世纪最严重火灾的灾民两次联署要求，由政府委任为相关屋苑管理人的合安管理有限公司(下称「合安」)至今仍未有按法例召开可就屋苑事宜作决定的业主大会，仅允举行网上简介会与居民交流，议程既未满足业主联署要求，且限定每户只有两人可以参加，参与者亦不可抄写或覆印资料，再度引起灾民不满；亦有评论员质疑港府的回避状态，只会令居民疑团难解。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260507-%E9%A6%99%E6%B8%AF%E5%A4%A7%E7%81%AB%E7%81%BE%E6%B0%91%E4%B8%8D%E6%BB%A1-%E6%94%BF%E5%BA%9C%E5%A7%94%E4%BB%BB%E7%AE%A1%E7%90%86%E4%BA%BA%E6%8B%92%E5%BC%80%E4%B8%9A%E4%B8%BB%E4%BC%9A-%E4%BB%85%E5%85%81%E5%8F%AC%E5%BC%80%E9%99%90%E5%88%B6%E5%A4%9A%E5%A4%9A%E7%9A%84%E7%AE%80%E4%BB%8B%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778140080000.webp","sourceId":"rfi"},{"id":1778135406000,"createdDate":"2026-05-07 06:30","name":"法国国际广播电台","title":"法国报税 向慈善机构的捐款可以享受哪些税收减免","content":"各位听众，在法国，申报所得税时不要忘记，您向慈善机构的捐款或可享受税收减免。但捐赠就是捐赠，而且你可能会因此被扣分：因为如果捐赠金额不超过一定数额，那么你所捐赠的慈善款金额可以享受所得税减免的优惠，且可能高达金额的75%。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260507-%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%A8%8E-%E5%90%91%E6%85%88%E5%96%84%E6%9C%BA%E6%9E%84%E7%9A%84%E6%8D%90%E6%AC%BE%E5%8F%AF%E4%BB%A5%E4%BA%AB%E5%8F%97%E5%93%AA%E4%BA%9B%E7%A8%8E%E6%94%B6%E5%87%8F%E5%85%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778135406000.webp","sourceId":"rfi"}]