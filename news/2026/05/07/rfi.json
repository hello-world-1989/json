[{"id":1778146293000,"createdDate":"2026-05-07 09:31","name":"法国国际广播电台","title":"美财长将在访华前访日协调共同对付中国限制稀土出口等","content":"日美两国政府正在协调美国财政部长贝森特于下周访问日本，并朝着与高市早苗首相等会面的方向进行调整。预计双方将讨论持续出现日元贬值、美元升值趋势的外汇市场动向，并就应对投机性抛售日元的对策展开讨论，此外，贝森特将与美国总统特朗普一起访华，美中定于14日或15日举行的美中首脑会谈。贝森特在此之前访日，双方还可能就中国实施稀土出口限制等问题展开讨论。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260507-%E7%BE%8E%E8%B4%A2%E9%95%BF%E5%B0%86%E5%9C%A8%E8%AE%BF%E5%8D%8E%E5%89%8D%E8%AE%BF%E6%97%A5%E5%8D%8F%E8%B0%83%E5%85%B1%E5%90%8C%E5%AF%B9%E4%BB%98%E4%B8%AD%E5%9B%BD%E9%99%90%E5%88%B6%E7%A8%80%E5%9C%9F%E5%87%BA%E5%8F%A3%E7%AD%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778146293000.webp","sourceId":"rfi"},{"id":1778143694000,"createdDate":"2026-05-07 08:48","name":"法国国际广播电台","title":"特朗普多次失言后，卢比奥到访梵蒂冈与教皇会面缓和紧张关系","content":"美国国务卿卢比奥于周四（5月7日）访问梵蒂冈和意大利，试图缓和与教皇之间的紧张关系，此前总统特朗普曾猛烈抨击教皇利奥十四世。周五（5月8日）卢比奥还将与意大利总理梅洛尼以及外长塔亚尼举行会谈，但两人都曾公开为教皇辩护，并批评对伊朗的战争是非法的，因此也招致了特朗普的不满。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260507-%E5%8D%A2%E6%AF%94%E5%A5%A5%E5%88%B0%E8%AE%BF%E6%A2%B5%E8%92%82%E5%86%88%E4%B8%8E%E6%95%99%E7%9A%87%E4%BC%9A%E9%9D%A2%E7%BC%93%E5%92%8C%E7%B4%A7%E5%BC%A0%E5%85%B3%E7%B3%BB-%E6%9C%89%E5%88%86%E6%9E%90%E7%A7%B0-%E4%B8%8D%E6%98%AF%E5%9C%A8%E4%B8%BA%E7%89%B9%E6%9C%97%E6%99%AE%E5%85%85%E5%BD%93%E8%B0%83%E8%A7%A3%E4%BA%BA%E8%80%8C%E6%98%AF%E6%9C%8D%E5%8A%A1%E6%9C%AC%E4%BA%BA%E6%94%BF%E6%B2%BB%E5%89%8D%E9%80%94","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778143694000.webp","sourceId":"rfi"},{"id":1778142036000,"createdDate":"2026-05-07 08:20","name":"法国国际广播电台","title":"法国外长：只要霍尔木兹海峡仍被封锁就“不可能”解除对伊朗的“任何制裁”","content":"法国外交部长让-诺埃尔·巴罗周四表示，只要霍尔木兹海峡仍处于封锁状态，就不可能解除针对伊朗的“任何一项”国际制裁。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260507-%E6%B3%95%E5%9B%BD%E5%A4%96%E9%95%BF-%E5%8F%AA%E8%A6%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E4%BB%8D%E8%A2%AB%E5%B0%81%E9%94%81%E5%B0%B1-%E4%B8%8D%E5%8F%AF%E8%83%BD-%E8%A7%A3%E9%99%A4%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%9A%84-%E4%BB%BB%E4%BD%95%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778142036000.webp","sourceId":"rfi"},{"id":1778141789000,"createdDate":"2026-05-07 08:16","name":"法国国际广播电台","title":"中非共和国女性迈向自主、被认可之路：先培养一技能","content":"各位听众， 在中非共和国，女性对自身处境的认识日益增强，并积极组织起来，争取解放。各种倡议层出不穷，其共同的愿望是：实现持久的经济独立，并在社会中确立自身地位。长期以来被视为弱势群体的这些女性们，如今她们决心掌握自己的命运。搞创收活动、小本生意、农业、手工艺：尽管面临诸多挑战，这种集体行动正在逐步重塑当地的经济格局。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E9%9D%9E%E6%B4%B2/20260507-%E4%B8%AD%E9%9D%9E%E5%85%B1%E5%92%8C%E5%9B%BD%E5%A5%B3%E6%80%A7%E8%BF%88%E5%90%91%E8%87%AA%E4%B8%BB-%E8%A2%AB%E8%AE%A4%E5%8F%AF%E4%B9%8B%E8%B7%AF-%E5%85%88%E5%9F%B9%E5%85%BB%E4%B8%80%E6%8A%80%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778141789000.webp","sourceId":"rfi"},{"id":1778140774000,"createdDate":"2026-05-07 07:59","name":"法国国际广播电台","title":"安琪巴黎「自由谈」沙龙纪要与述评:――法国戏剧导演 Jérôme Méla谈「舞台的诞生与在场」","content":"2026年4月18日周六，樱花缤纷，满园瑰丽。我非常荣幸地邀请法国戏剧导演杰JérômeMéla先生莅临巴黎「自由谈」沙龙古道且闲庄演讲，题目是「舞台的诞生与在场」（«Lanaissanceetlaprésencedelascène»）。学者、学人、艺术家、音乐家、媒体人等各界人士出席了本次活动。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260507-%E5%AE%89%E7%90%AA%E5%B7%B4%E9%BB%8E-%E8%87%AA%E7%94%B1%E8%B0%88-%E6%B2%99%E9%BE%99%E7%BA%AA%E8%A6%81%E4%B8%8E%E8%BF%B0%E8%AF%84-%E2%80%95%E2%80%95%E6%B3%95%E5%9B%BD%E6%88%8F%E5%89%A7%E5%AF%BC%E6%BC%94-j%C3%A9r%C3%B4me-m%C3%A9la%E8%B0%88-%E8%88%9E%E5%8F%B0%E7%9A%84%E8%AF%9E%E7%94%9F%E4%B8%8E%E5%9C%A8%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778140774000.webp","sourceId":"rfi"},{"id":1778140080000,"createdDate":"2026-05-07 07:48","name":"法国国际广播电台","title":"香港大火灾民不满：政府委任管理人拒开业主会 仅允召开限制多多的简介会","content":"虽经香港四分三世纪最严重火灾的灾民两次联署要求，由政府委任为相关屋苑管理人的合安管理有限公司(下称「合安」)至今仍未有按法例召开可就屋苑事宜作决定的业主大会，仅允举行网上简介会与居民交流，议程既未满足业主联署要求，且限定每户只有两人可以参加，参与者亦不可抄写或覆印资料，再度引起灾民不满；亦有评论员质疑港府的回避状态，只会令居民疑团难解。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260507-%E9%A6%99%E6%B8%AF%E5%A4%A7%E7%81%AB%E7%81%BE%E6%B0%91%E4%B8%8D%E6%BB%A1-%E6%94%BF%E5%BA%9C%E5%A7%94%E4%BB%BB%E7%AE%A1%E7%90%86%E4%BA%BA%E6%8B%92%E5%BC%80%E4%B8%9A%E4%B8%BB%E4%BC%9A-%E4%BB%85%E5%85%81%E5%8F%AC%E5%BC%80%E9%99%90%E5%88%B6%E5%A4%9A%E5%A4%9A%E7%9A%84%E7%AE%80%E4%BB%8B%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778140080000.webp","sourceId":"rfi"},{"id":1778135406000,"createdDate":"2026-05-07 06:30","name":"法国国际广播电台","title":"法国报税 向慈善机构的捐款可以享受哪些税收减免","content":"各位听众，在法国，申报所得税时不要忘记，您向慈善机构的捐款或可享受税收减免。但捐赠就是捐赠，而且你可能会因此被扣分：因为如果捐赠金额不超过一定数额，那么你所捐赠的慈善款金额可以享受所得税减免的优惠，且可能高达金额的75%。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260507-%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%A8%8E-%E5%90%91%E6%85%88%E5%96%84%E6%9C%BA%E6%9E%84%E7%9A%84%E6%8D%90%E6%AC%BE%E5%8F%AF%E4%BB%A5%E4%BA%AB%E5%8F%97%E5%93%AA%E4%BA%9B%E7%A8%8E%E6%94%B6%E5%87%8F%E5%85%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778135406000.webp","sourceId":"rfi"},{"id":1778171590000,"createdDate":"2026-05-07 16:33","name":"法国国际广播电台","title":"日韩人口危机根源：社会运作模式异化下的男女疏离与互弃","content":"世界报在一篇题为“追溯日韩两国人口危机根源”的文章中指出，在这两国，男女之间的疏离是深层人口危机的根源。世界报报道称，日本和韩国的人口多年来一直在下降。没有任何迹象表明这一趋势可能逆转，因为组建家庭的困难根植于一些并不仅仅是经济层面的问题，也涉及社会运作方式。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260507-%E6%97%A5%E9%9F%A9%E4%BA%BA%E5%8F%A3%E5%8D%B1%E6%9C%BA%E6%A0%B9%E6%BA%90-%E7%A4%BE%E4%BC%9A%E8%BF%90%E4%BD%9C%E6%A8%A1%E5%BC%8F%E5%BC%82%E5%8C%96%E4%B8%8B%E7%9A%84%E7%94%B7%E5%A5%B3%E7%96%8F%E7%A6%BB%E4%B8%8E%E4%BA%92%E5%BC%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778171590000.webp","sourceId":"rfi"},{"id":1778170844000,"createdDate":"2026-05-07 16:20","name":"法国国际广播电台","title":"国际奥委会取消俄乌战争初期对白俄罗斯实施的全部参赛限制","content":"路透社5月7日报道，国际奥林匹克委员会当天宣布，正式取消对白俄罗斯运动员的全部参赛限制。这意味着白俄罗斯运动员将重新获得完整的国际赛事参赛资格，包括参加2028年洛杉矶奥运会的各项资格赛。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260507-%E5%9B%BD%E9%99%85%E5%A5%A5%E5%A7%94%E4%BC%9A%E5%8F%96%E6%B6%88%E4%BF%84%E4%B9%8C%E6%88%98%E4%BA%89%E5%88%9D%E6%9C%9F%E5%AF%B9%E7%99%BD%E4%BF%84%E7%BD%97%E6%96%AF%E5%AE%9E%E6%96%BD%E7%9A%84%E5%85%A8%E9%83%A8%E5%8F%82%E8%B5%9B%E9%99%90%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778170844000.webp","sourceId":"rfi"},{"id":1778162346000,"createdDate":"2026-05-07 13:59","name":"法国国际广播电台","title":"俄罗斯呼吁各国使馆人员在5月9日纪念活动前撤离基辅","content":"在5月9日“卫国战争胜利日”纪念活动前夕，俄罗斯向各国驻使馆发出安全警告，要求各国尽快撤离驻基辅的外交人员和本国公民。并同时警告说，如果乌克兰试图干扰9日在莫斯科举行的纪念活动，俄罗斯将实施“不可避免的报复性打击”，甚至可能针对乌克兰的“决策中心”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260507-%E4%BF%84%E7%BD%97%E6%96%AF%E5%91%BC%E5%90%81%E5%90%84%E5%9B%BD%E4%BD%BF%E9%A6%86%E4%BA%BA%E5%91%98%E5%9C%A85%E6%9C%889%E6%97%A5%E7%BA%AA%E5%BF%B5%E6%B4%BB%E5%8A%A8%E5%89%8D%E6%92%A4%E7%A6%BB%E5%9F%BA%E8%BE%85","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778162346000.webp","sourceId":"rfi"},{"id":1778159644000,"createdDate":"2026-05-07 13:14","name":"法国国际广播电台","title":"特朗普称与伊朗达成和平“非常可能” 油价跌 股市涨","content":"法新社华盛顿消息，唐纳德·特朗普周三表示，与伊朗达成和平协议“非常有可能”，此言引发油价下跌和股市飙升，尽管他再次扬言可能重启对伊朗的空袭。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260507-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E4%B8%8E%E4%BC%8A%E6%9C%97%E8%BE%BE%E6%88%90%E5%92%8C%E5%B9%B3-%E9%9D%9E%E5%B8%B8%E5%8F%AF%E8%83%BD-%E6%B2%B9%E4%BB%B7%E8%B7%8C-%E8%82%A1%E5%B8%82%E6%B6%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778159644000.webp","sourceId":"rfi"},{"id":1778158526000,"createdDate":"2026-05-07 12:55","name":"法国国际广播电台","title":"中国要求各大银行暂停放贷给美国制裁的炼油厂","content":"彭博社5月7日引述知情人透露，中国金融监管机构建议该国最大的几家银行暂停向五家炼油企业发放新贷款，这五家炼油企业最近因与伊朗石油有关联而受到美国的制裁。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260507-%E4%B8%AD%E5%9B%BD%E8%A6%81%E6%B1%82%E5%90%84%E5%A4%A7%E9%93%B6%E8%A1%8C%E6%9A%82%E5%81%9C%E6%94%BE%E8%B4%B7%E7%BB%99%E7%BE%8E%E5%9B%BD%E5%88%B6%E8%A3%81%E7%9A%84%E7%82%BC%E6%B2%B9%E5%8E%82","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778158526000.webp","sourceId":"rfi"},{"id":1778155413000,"createdDate":"2026-05-07 12:03","name":"法国国际广播电台","title":"法新社：中国两防长“主动贪贿”获死缓","content":"据官方媒体报道，中国一家军事法庭周四以贪腐罪判处曾于2018年至2023年间担任国防部长的魏凤和、李尚福两人死刑缓期执行。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260507-%E6%B3%95%E6%96%B0%E7%A4%BE-%E4%B8%AD%E5%9B%BD%E4%B8%A4%E9%98%B2%E9%95%BF-%E4%B8%BB%E5%8A%A8%E8%B4%AA%E8%B4%BF-%E8%8E%B7%E6%AD%BB%E7%BC%93","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778155413000.webp","sourceId":"rfi"},{"id":1778154831000,"createdDate":"2026-05-07 11:53","name":"法国国际广播电台","title":"法国是科特迪瓦青年首选留学地","content":"在位于西非国家科特迪瓦（Côted'Ivoire）西南部的圣佩德罗（SanPedro），法国高等教育署（CampusFrance）设在当地综合理工大学（UniversitépolytechniquedeSanPedro）校园内的一个新办公室于昨天2026年05月06日星期三剪彩。科特迪瓦的中文国名也有译作象牙海岸（Côted'Ivoire）。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260507-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E6%B3%95%E5%9B%BD%E6%98%AF%E7%A7%91%E7%89%B9%E8%BF%AA%E7%93%A6%E9%9D%92%E5%B9%B4%E9%A6%96%E9%80%89%E7%95%99%E5%AD%A6%E5%9C%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778154831000.webp","sourceId":"rfi"},{"id":1778151246000,"createdDate":"2026-05-07 10:54","name":"法国国际广播电台","title":"英国地方选举：工党面临反移民政党和绿党的压力，或结束“传统两党制”格局","content":"英国民众周四（5月7日）开始参加地方选举，这场“中期选举”很可能重塑英国政坛格局，并对深陷困境的首相斯塔默造成沉重打击。此次选举将决定英格兰约5000名地方议员（总计约有1.6万个席位）以及少数市长职位的归属，同时还将改选拥有一定自治权的苏格兰议会和威尔士议会。投票站于当地时间早上7点开放，并将在晚上10点关闭。部分地方政府将在夜间开始计票，但大部分结果预计将于周五下午公布。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260507-%E8%8B%B1%E5%9B%BD%E5%9C%B0%E6%96%B9%E9%80%89%E4%B8%BE-%E6%B0%91%E8%B0%83%E9%A2%84%E6%B5%8B%E6%9E%81%E5%8F%B3%E7%BF%BC%E6%9C%89%E6%9C%9B%E5%8F%96%E8%83%9C%EF%BC%8C%E6%88%96%E7%BB%93%E6%9D%9F-%E4%BC%A0%E7%BB%9F%E4%B8%A4%E5%85%9A%E5%88%B6-%E6%A0%BC%E5%B1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778151246000.webp","sourceId":"rfi"},{"id":1778150407000,"createdDate":"2026-05-07 10:40","name":"法国国际广播电台","title":"魏凤和与李尚福一审被判死缓","content":"中国两位前中共中央军委原委员，前国防部长魏凤和与李尚福一审被判死缓。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260507-%E9%AD%8F%E5%87%A4%E5%92%8C%E4%B8%8E%E6%9D%8E%E5%B0%9A%E7%A6%8F%E4%B8%80%E5%AE%A1%E8%A2%AB%E5%88%A4%E6%AD%BB%E7%BC%93","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778150407000.webp","sourceId":"rfi"},{"id":1778193128000,"createdDate":"2026-05-07 22:32","name":"法国国际广播电台","title":"两名中国前国防部长为何遭判死缓 杀鸡给猴看？","content":"尘埃落定!中国两名前国防部长、军委委员魏凤和与李尚福被判处死刑、缓期两年执行。这是习近平发动的两波反腐运动以来，截至目前，对解放军高级将领量刑最重的一次判决。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260507-%E4%B8%A4%E5%90%8D%E4%B8%AD%E5%9B%BD%E5%89%8D%E5%9B%BD%E9%98%B2%E9%83%A8%E9%95%BF%E4%B8%BA%E4%BD%95%E9%81%AD%E5%88%A4%E6%AD%BB%E7%BC%93-%E6%9D%80%E9%B8%A1%E7%BB%99%E7%8C%B4%E7%9C%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778193128000.webp","sourceId":"rfi"},{"id":1778192506000,"createdDate":"2026-05-07 22:21","name":"法国国际广播电台","title":"法国立法为归还掠夺文物提供便利 中国期待合作","content":"法国议会周四终审通过一项框架性法案，旨在促进归还法国殖民时期掠夺的艺术品。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260507-%E6%B3%95%E5%9B%BD%E7%AB%8B%E6%B3%95%E4%B8%BA%E5%BD%92%E8%BF%98%E6%8E%A0%E5%A4%BA%E6%96%87%E7%89%A9%E6%8F%90%E4%BE%9B%E4%BE%BF%E5%88%A9-%E4%B8%AD%E5%9B%BD%E6%9C%9F%E5%BE%85%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778192506000.webp","sourceId":"rfi"},{"id":1778190244000,"createdDate":"2026-05-07 21:44","name":"法国国际广播电台","title":"喀麦隆:首都一家华人超市遭暂停","content":"喀麦隆社交媒体上流传的一段华人超市视频惊动该国劳工部长。喀麦隆当局现已下令暂时关闭这家位于首都雅温得（Yaoundé）的超市。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260507-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E5%96%80%E9%BA%A6%E9%9A%86-%E9%A6%96%E9%83%BD%E4%B8%80%E5%AE%B6%E5%8D%8E%E4%BA%BA%E8%B6%85%E5%B8%82%E9%81%AD%E6%9A%82%E5%81%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778190244000.webp","sourceId":"rfi"},{"id":1778188917000,"createdDate":"2026-05-07 21:21","name":"法国国际广播电台","title":"中国科研船南沙群岛附近海域作业 菲律宾发无线电警告","content":"菲律宾海岸警卫队周四(5月7日）表示，菲律宾周四派遣飞机，对一艘在南海争议海域活动的中国科研船发出无线电警告。中国则反驳称，菲律宾飞机对中国船只进行“骚扰”，并指责菲方“歪曲事实”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260507-%E4%B8%AD%E5%9B%BD%E7%A7%91%E7%A0%94%E8%88%B9%E5%8D%97%E6%B2%99%E7%BE%A4%E5%B2%9B%E9%99%84%E8%BF%91%E6%B5%B7%E5%9F%9F%E4%BD%9C%E4%B8%9A-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%8F%91%E6%97%A0%E7%BA%BF%E7%94%B5%E8%AD%A6%E5%91%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778188917000.webp","sourceId":"rfi"},{"id":1778188691000,"createdDate":"2026-05-07 21:18","name":"法国国际广播电台","title":"特朗普向欧盟施压 要求7月4日前落实美欧贸易协议","content":"美国总统特朗普周四(5月7日）表示，他已要求欧盟必须在7月4日前正式落实与美国达成的贸易协议，否则华盛顿将立即大幅提高针对欧洲商品的关税。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260507-%E7%89%B9%E6%9C%97%E6%99%AE%E5%90%91%E6%AC%A7%E7%9B%9F%E6%96%BD%E5%8E%8B-%E8%A6%81%E6%B1%827%E6%9C%884%E6%97%A5%E5%89%8D%E8%90%BD%E5%AE%9E%E7%BE%8E%E6%AC%A7%E8%B4%B8%E6%98%93%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778188691000.webp","sourceId":"rfi"},{"id":1778188413000,"createdDate":"2026-05-07 21:13","name":"法国国际广播电台","title":"美国政府邀英伟达等多间大型企业CEO随同特朗普访华","content":"美国总统特朗普预计将于下周访问中国。美媒披露，特朗普政府计划邀请多家美国大型企业高层陪同访华，其中包括英伟达（NVIDIA）、苹果（Apple）、波音（Boeing）及埃克森美孚（ExxonMobil）等企业CEO。外界普遍认为，此举显示华盛顿希望借此次中美元首会晤推动经贸合作，并为一系列潜在大型商业协议铺路。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260507-%E7%BE%8E%E5%9B%BD%E6%94%BF%E5%BA%9C%E9%82%80%E8%8B%B1%E4%BC%9F%E8%BE%BE%E7%AD%89%E5%A4%9A%E9%97%B4%E5%A4%A7%E5%9E%8B%E4%BC%81%E4%B8%9Aceo%E9%9A%8F%E5%90%8C%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/07/1778188413000.webp","sourceId":"rfi"},{"id":1778188212000,"createdDate":"2026-05-07 21:10","name":"法国国际广播电台","title":"英国裁定两名英籍华人为中国从事情报活动罪名成立 召见中国大使抗议","content":"英国伦敦刑事法院周四(5月7日）裁定，两名英籍华人\"协助中国及香港情报机构在英国开展秘密行动\"罪名成立。英国政府随即宣布召见中国驻英大使郑泽光，谴责有关行为“侵犯英国主权”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260507-%E8%8B%B1%E5%9B%BD%E8%A3%81%E5%AE%9A%E4%B8%A4%E5%90%8D%E8%8B%B1%E7%B1%8D%E5%8D%8E%E4%BA%BA%E4%B8%BA%E4%B8%AD%E5%9B%BD%E4%BB%8E%E4%BA%8B%E6%83%85%E6%8A%A5%E6%B4%BB%E5%8A%A