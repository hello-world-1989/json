[{"id":1779182716000,"createdDate":"2026-05-19 09:25","name":"法国国际广播电台","title":"普京访华前夕 俄罗斯袭乌克兰多瑙河港口 乌克兰向莫斯科发射无人机","content":"路透社消息，在普京到访北京前夕，周二凌晨，俄罗斯空袭破坏了乌克兰伊兹梅尔市的港口基础设施。与此同时，俄罗斯当局表示，他们击落了乌克兰发射的四架飞往莫斯科的无人机。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260519-%E6%99%AE%E4%BA%AC%E8%AE%BF%E5%8D%8E%E5%89%8D%E5%A4%95-%E4%BF%84%E7%BD%97%E6%96%AF%E8%A2%AD%E4%B9%8C%E5%85%8B%E5%85%B0%E5%A4%9A%E7%91%99%E6%B2%B3%E6%B8%AF%E5%8F%A3-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%90%91%E8%8E%AB%E6%96%AF%E7%A7%91%E5%8F%91%E5%B0%84%E6%97%A0%E4%BA%BA%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779182716000.webp","sourceId":"rfi"},{"id":1779182534000,"createdDate":"2026-05-19 09:22","name":"法国国际广播电台","title":"《费加罗报》：普京因中美之间的“暧昧互动”感到不安 担心G2格局会将俄罗斯边缘化","content":"周二（5月19日）出刊的法国各大报纸关注点各不相同。《解放报》头条聚焦戛纳电影节的反博洛雷事件，《费加罗报》头条则聚焦法国笑气（一氧化二氮）的禁令问题，《十字架报》头条讲述该报记者探访乌克兰FirePoint公司的经历，这家公司是乌克兰无人机生产的标杆企业。至于中国方面的新闻，法国报纸主要聚焦普京访华。此前，特习会结束还不到24小时，克里姆林宫便确认，俄罗斯总统普京将于5月19日至20日访问中国，以加强与中国的战略伙伴关系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260519-%E8%B4%B9%E5%8A%A0%E7%BD%97%E6%8A%A5-%E6%99%AE%E4%BA%AC%E5%9B%A0%E4%B8%AD%E7%BE%8E%E4%B9%8B%E9%97%B4%E7%9A%84-%E6%9A%A7%E6%98%A7%E4%BA%92%E5%8A%A8-%E6%84%9F%E5%88%B0%E4%B8%8D%E5%AE%89-%E6%8B%85%E5%BF%83g2%E6%A0%BC%E5%B1%80%E4%BC%9A%E5%B0%86%E4%BF%84%E7%BD%97%E6%96%AF%E8%BE%B9%E7%BC%98%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779182534000.webp","sourceId":"rfi"},{"id":1779181358000,"createdDate":"2026-05-19 09:02","name":"法国国际广播电台","title":"日韩首脑在李在明总统故乡安东举行会谈","content":"高市早苗首相日本时间19日上午乘坐政府专机从羽田机场出发，前往韩国庆尚北道安东，与李在明总统举行会谈。19日下午，李在明总统与高市早苗首相在李总统故乡——庆尚北道安东举行了首脑会谈。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260519-%E6%97%A5%E9%9F%A9%E9%A6%96%E8%84%91%E5%9C%A8%E6%9D%8E%E5%9C%A8%E6%98%8E%E6%80%BB%E7%BB%9F%E6%95%85%E4%B9%A1%E5%AE%89%E4%B8%9C%E4%B8%BE%E8%A1%8C%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779181358000.webp","sourceId":"rfi"},{"id":1779180783000,"createdDate":"2026-05-19 08:53","name":"法国国际广播电台","title":"俄罗斯国防部宣布从今天起举行三天核军演","content":"俄罗斯国防部宣布俄军于今天周二19日开始进行为期三天的核武器军演和训练，届时有数千名士兵在全国范围内参与，就在本次俄军核武军演开始几个小时后，俄罗斯总统普京将抵达中国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260519-%E4%BF%84%E7%BD%97%E6%96%AF%E5%9B%BD%E9%98%B2%E9%83%A8%E5%AE%A3%E5%B8%83%E4%BB%8E%E4%BB%8A%E5%A4%A9%E8%B5%B7%E4%B8%BE%E8%A1%8C%E4%B8%89%E5%A4%A9%E6%A0%B8%E5%86%9B%E6%BC%94","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779180783000.webp","sourceId":"rfi"},{"id":1779179537000,"createdDate":"2026-05-19 08:32","name":"法国国际广播电台","title":"普京周二晚将抵达北京：俄中准备在主权等问题上相互支持","content":"俄罗斯总统弗拉基米尔·普京将于周二晚间抵达北京，周三将与中国国家主席习近平会面，距离美国总统特朗普访华还不到一周。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260519-%E6%99%AE%E4%BA%AC%E5%91%A8%E4%BA%8C%E6%99%9A%E5%B0%86%E6%8A%B5%E8%BE%BE%E5%8C%97%E4%BA%AC-%E4%BF%84%E4%B8%AD%E5%87%86%E5%A4%87%E5%9C%A8%E4%B8%BB%E6%9D%83%E7%AD%89%E9%97%AE%E9%A2%98%E4%B8%8A%E7%9B%B8%E4%BA%92%E6%94%AF%E6%8C%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779179537000.webp","sourceId":"rfi"},{"id":1779177707000,"createdDate":"2026-05-19 08:01","name":"法国国际广播电台","title":"恒大向原核数师罗兵咸相关公司索赔天价570亿人民币","content":"因「债可敌国」已被法庭颁令清盘的中国恒大，其清盘人以审计恒大过往财务报表工作存在疏忽及失实陈述为理由，向曾为恒大核数的罗兵咸永道中国及香港追讨巨额赔偿，同时将未有直接参与核数工作的罗兵咸永道国际也列为追讨对象，据外电报道，索赔额达到570亿元人民币(下同，折算约73亿欧元)，成为香港有史以来企业遭索赔最高金额的个案之一。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260519-%E6%81%92%E5%A4%A7%E5%90%91%E5%8E%9F%E6%A0%B8%E6%95%B0%E5%B8%88%E7%BD%97%E5%85%B5%E5%92%B8%E7%9B%B8%E5%85%B3%E5%85%AC%E5%8F%B8%E7%B4%A2%E8%B5%94%E5%A4%A9%E4%BB%B7570%E4%BA%BF%E4%BA%BA%E6%B0%91%E5%B8%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779177707000.webp","sourceId":"rfi"},{"id":1779177531000,"createdDate":"2026-05-19 07:58","name":"法国国际广播电台","title":"台湾立法院表决总统赖清德弹劾案未通过 蓝白联手仍未达法定门槛","content":"总统弹劾案投票结果出炉，以56票赞成、50票反对作结，另外有7位立委未领票。由于弹劾门槛高，外界预料仅属政治操作，意在520总统就职纪念前表达蓝白「反赖」态度。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260519-%E5%8F%B0%E6%B9%BE%E7%AB%8B%E6%B3%95%E9%99%A2%E8%A1%A8%E5%86%B3%E6%80%BB%E7%BB%9F%E8%B5%96%E6%B8%85%E5%BE%B7%E5%BC%B9%E5%8A%BE%E6%A1%88%E6%9C%AA%E9%80%9A%E8%BF%87-%E8%93%9D%E7%99%BD%E8%81%94%E6%89%8B%E4%BB%8D%E6%9C%AA%E8%BE%BE%E6%B3%95%E5%AE%9A%E9%97%A8%E6%A7%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779177531000.webp","sourceId":"rfi"},{"id":1779177284000,"createdDate":"2026-05-19 07:54","name":"法国国际广播电台","title":"埃博拉病毒：一公民确诊后，美国对部分中非旅客实施入境限制","content":"美国周一（5月18日）宣布，将加强针对埃博拉病毒的边境防疫检查。此前，一名美国公民在刚果民主共和国（金）感染了该病毒。美国疾病控制与预防中心（CDC）宣布，将对来自非洲受疫情影响地区的外国公民实施入境限制。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260519-%E5%9F%83%E5%8D%9A%E6%8B%89%E7%97%85%E6%AF%92-%E4%B8%80%E5%85%AC%E6%B0%91%E7%A1%AE%E8%AF%8A%E5%90%8E%EF%BC%8C%E7%BE%8E%E5%9B%BD%E5%AF%B9%E9%83%A8%E5%88%86%E4%B8%AD%E9%9D%9E%E6%97%85%E5%AE%A2%E5%AE%9E%E6%96%BD%E5%85%A5%E5%A2%83%E9%99%90%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779177284000.webp","sourceId":"rfi"},{"id":1779210803000,"createdDate":"2026-05-19 17:13","name":"法国国际广播电台","title":"俄罗斯总统普京抵达北京中国外长王毅到机场迎接","content":"2026年5月19日，俄罗斯总统普京抵达北京，中国外交部长王毅在北京机场迎接，参加欢迎仪式，走过仪仗队。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260519-%E4%BF%84%E7%BD%97%E6%96%AF%E6%80%BB%E7%BB%9F%E6%99%AE%E4%BA%AC%E6%8A%B5%E8%BE%BE%E5%8C%97%E4%BA%AC%E4%B8%AD%E5%9B%BD%E5%A4%96%E9%95%BF%E7%8E%8B%E6%AF%85%E5%88%B0%E6%9C%BA%E5%9C%BA%E8%BF%8E%E6%8E%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779210803000.webp","sourceId":"rfi"},{"id":1779209805000,"createdDate":"2026-05-19 16:56","name":"法国国际广播电台","title":"普京“后悔”入侵乌克兰？专家指习不会施压普京","content":"据金融时报透露，习近平上周与特朗普会谈时曾表示，普京最终可能“后悔”入侵乌克兰。外界因此联想习近平或在此次峰会上，施压普京，推动尽快结束这场超过四年的战争。但路透社引述专家指出：不会的，他们二人会告知世界：“美国挑拨离间的任何尝试会失败”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260519-%E6%99%AE%E4%BA%AC-%E5%90%8E%E6%82%94-%E5%85%A5%E4%BE%B5%E4%B9%8C%E5%85%8B%E5%85%B0-%E4%B8%93%E5%AE%B6%E6%8C%87%E4%B9%A0%E4%B8%8D%E4%BC%9A%E6%96%BD%E5%8E%8B%E6%99%AE%E4%BA%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779209805000.webp","sourceId":"rfi"},{"id":1779204945000,"createdDate":"2026-05-19 15:35","name":"法国国际广播电台","title":"上海日料店持刀伤人案：两名日本人受伤","content":"共同社消息：上海日本料理店发生持刀伤人案，致3人受伤，其中两名日本人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260519-%E4%B8%8A%E6%B5%B7%E6%97%A5%E6%96%99%E5%BA%97%E6%8C%81%E5%88%80%E4%BC%A4%E4%BA%BA%E6%A1%88-%E4%B8%A4%E5%90%8D%E6%97%A5%E6%9C%AC%E4%BA%BA%E5%8F%97%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779204945000.webp","sourceId":"rfi"},{"id":1779203713000,"createdDate":"2026-05-19 15:15","name":"法国国际广播电台","title":"马科斯总统称菲律宾将不得不卷入任何台湾冲突","content":"菲律宾总统费迪南德·马科斯二世在访问日本之前告诉日媒：由于地理位置毗邻台湾，且很多菲律宾公民在那里工作，一旦台湾发生任何冲突，菲律宾将不得不卷入其中，虽然菲律宾继续坚持“一个中国”政策。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260519-%E9%A9%AC%E7%A7%91%E6%96%AF%E6%80%BB%E7%BB%9F%E7%A7%B0%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%B0%86%E4%B8%8D%E5%BE%97%E4%B8%8D%E5%8D%B7%E5%85%A5%E4%BB%BB%E4%BD%95%E5%8F%B0%E6%B9%BE%E5%86%B2%E7%AA%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779203713000.webp","sourceId":"rfi"},{"id":1779201952000,"createdDate":"2026-05-19 14:45","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第24：浪漫主义群星之五：海涅：第三节：政治的浪漫派遭遇马克思","content":"海涅从浪漫派内部对浪漫主义的批评涉及了浪漫主义在美学、诗学方面的某些观念，但他同时攻击施勒格尔兄弟的政治态度。这表明海涅代表了浪漫派中倾向于政治革命的力量。这支力量的大本营在法兰西。1830年7月革命后，海涅到了法国，在这片政治自由带来艺术自由的土地上，他纵情歌唱并埋骨此乡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260519-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%BA%94-%E6%B5%B7%E6%B6%85-%E7%AC%AC%E4%B8%89%E8%8A%82-%E6%94%BF%E6%B2%BB%E7%9A%84%E6%B5%AA%E6%BC%AB%E6%B4%BE%E9%81%AD%E9%81%87%E9%A9%AC%E5%85%8B%E6%80%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779201952000.webp","sourceId":"rfi"},{"id":1779199615000,"createdDate":"2026-05-19 14:06","name":"法国国际广播电台","title":"英伟达首席执行官预计中国市场将向其AI芯片敞开大门","content":"法新社5月19日发自东京的电稿说，英伟达首席执行官黄仁勋预计，中国最终将向能训练和运行人工智能（AI）系统的美国高端芯片开放市场。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260519-%E8%8B%B1%E4%BC%9F%E8%BE%BE%E9%A6%96%E5%B8%AD%E6%89%A7%E8%A1%8C%E5%AE%98%E9%A2%84%E8%AE%A1%E4%B8%AD%E5%9B%BD%E5%B8%82%E5%9C%BA%E5%B0%86%E5%90%91%E5%85%B6ai%E8%8A%AF%E7%89%87%E6%95%9E%E5%BC%80%E5%A4%A7%E9%97%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779199615000.webp","sourceId":"rfi"},{"id":1779198310000,"createdDate":"2026-05-19 13:45","name":"法国国际广播电台","title":"特朗普取消原定周二对伊朗新一轮打击 称很可能达成协议","content":"美国总统特朗普周一宣布，他已在最后一刻取消了原定于周二对伊朗发动的新一轮袭击，并表示，与德黑兰达成协议的“可能性非常大”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260519-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%96%E6%B6%88%E5%8E%9F%E5%AE%9A%E5%91%A8%E4%BA%8C%E5%AF%B9%E4%BC%8A%E6%9C%97%E6%96%B0%E4%B8%80%E8%BD%AE%E6%89%93%E5%87%BB-%E7%A7%B0%E5%BE%88%E5%8F%AF%E8%83%BD%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779198310000.webp","sourceId":"rfi"},{"id":1779191518000,"createdDate":"2026-05-19 11:51","name":"法国国际广播电台","title":"特朗普前脚走 普京后脚来 巩固与北京牢不可破的友谊","content":"法新社19日北京报道：俄罗斯总统弗拉基米尔·普京定于周二晚抵达中国，会见他的“老朋友”习近平，并重申中俄关系的牢固。此前几天，北京刚刚以盛大的礼遇欢迎了唐纳德·特朗普。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260519-%E7%89%B9%E6%9C%97%E6%99%AE%E5%89%8D%E8%84%9A%E8%B5%B0-%E6%99%AE%E4%BA%AC%E5%90%8E%E8%84%9A%E6%9D%A5-%E5%B7%A9%E5%9B%BA%E4%B8%8E%E5%8C%97%E4%BA%AC%E7%89%A2%E4%B8%8D%E5%8F%AF%E7%A0%B4%E7%9A%84%E5%8F%8B%E8%B0%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779191518000.webp","sourceId":"rfi"},{"id":1779189917000,"createdDate":"2026-05-19 11:25","name":"法国国际广播电台","title":"支联会被控「煽颠」案完成争辩 法官七月底裁决","content":"为悼念六四事件死难者举办烛光晚会三十年的香港市民支援爱国民主运动联合会(简称支联会)，与其前正副主席李卓人丶何俊仁及邹幸彤一同被控煽动颠覆国家政权罪的案件，经历24日审讯后，控辩双方完成争辩，控方在结案陈词中重申，支联会纲领中包括「结束一党专政」，已超越法律对言论自由等保障的界线；但李卓人一方指，控方的案件是凭空捏造；而邹幸彤更指，控方的指控等於是抹黑宪法为专政工具。法官最後将案件押后至七月底裁决，所有被告均需继续还押候判。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260519-%E6%94%AF%E8%81%94%E4%BC%9A%E8%A2%AB%E6%8E%A7-%E7%85%BD%E9%A2%A0-%E6%A1%88%E5%AE%8C%E6%88%90%E4%BA%89%E8%BE%A9-%E6%B3%95%E5%AE%98%E4%B8%83%E6%9C%88%E5%BA%95%E8%A3%81%E5%86%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779189917000.webp","sourceId":"rfi"},{"id":1779188957000,"createdDate":"2026-05-19 11:09","name":"法国国际广播电台","title":"老佛爷百货北京店将关门 重申中国业务不受影响","content":"法新社北京消息，老佛爷百货北京门店将于5月27日关闭，原因是该店“规模过大”，“需要大量投资进行现代化改造”。老佛爷百货管理层周二向法新社证实了美国媒体（JingDaily）的报道。此外，据中国媒体表示，这也意味着，这家拥有12年历史的老牌地标性商场即将退出西单商圈。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260519-%E8%80%81%E4%BD%9B%E7%88%B7%E7%99%BE%E8%B4%A7%E5%8C%97%E4%BA%AC%E9%97%A8%E5%BA%97%E5%B0%86%E5%85%B3%E9%97%AD-%E9%87%8D%E7%94%B3%E4%B8%AD%E5%9B%BD%E4%B8%9A%E5%8A%A1%E4%B8%8D%E5%8F%97%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779188957000.webp","sourceId":"rfi"},{"id":1779188853000,"createdDate":"2026-05-19 11:07","name":"法国国际广播电台","title":"沉浸式竞赛单元《海贼女王》讲述古老的中国故事","content":"戛纳影节官方竞赛单元中最年轻的沉浸式竞赛单元为新一代国际艺术家提供了一个新平台，rang们展示如何通过沉浸式艺术重新定义叙事的方式.","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260519-%E6%B2%89%E6%B5%B8%E5%BC%8F%E7%AB%9E%E8%B5%9B%E5%8D%95%E5%85%83-%E6%B5%B7%E8%B4%BC%E5%A5%B3%E7%8E%8B-%E8%AE%B2%E8%BF%B0%E5%8F%A4%E8%80%81%E7%9A%84%E4%B8%AD%E5%9B%BD%E6%95%85%E4%BA%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779188853000.webp","sourceId":"rfi"},{"id":1779187520000,"createdDate":"2026-05-19 10:45","name":"法国国际广播电台","title":"习近平对特朗普说：普京“后悔入侵乌克兰”? 或成中俄峰会变数","content":"俄罗斯总统普京周二19日启程前往北京，周三20日将与中国国家主席习近平举行峰会，旨在深化两国“磐石般坚固”的战略伙伴关系。然而，在中俄领导人会晤前夕，据《金融时报》报道，中国国家主席习近平上周向美国总统特朗普透露，普京“可能后悔入侵乌克兰”，从而引发国际传媒讨论。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260519-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%AF%B9%E7%89%B9%E6%9C%97%E6%99%AE%E8%AF%B4-%E6%99%AE%E4%BA%AC-%E5%90%8E%E6%82%94%E5%85%A5%E4%BE%B5%E4%B9%8C%E5%85%8B%E5%85%B0-%E6%88%96%E6%88%90%E4%B8%AD%E4%BF%84%E5%B3%B0%E4%BC%9A%E5%8F%98%E6%95%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779187520000.webp","sourceId":"rfi"},{"id":1779186054000,"createdDate":"2026-05-19 10:20","name":"法国国际广播电台","title":"乌克兰俘获的2名朝鲜军人正式被认可为战争俘虏","content":"国际红十字会韩国代表处主任大卫·肯恩5月18日表示，被乌克兰俘获的2名朝鲜军人正式被认可为战争俘虏，国际红十字会方面保持与俄乌两国的定期接触并讨论战俘问题。·","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260519-%E4%B9%8C%E5%85%8B%E5%85%B0%E4%BF%98%E8%8E%B7%E7%9A%842%E5%90%8D%E6%9C%9D%E9%B2%9C%E5%86%9B%E4%BA%BA%E6%AD%A3%E5%BC%8F%E8%A2%AB%E8%AE%A4%E5%8F%AF%E4%B8%BA%E6%88%98%E4%BA%89%E4%BF%98%E8%99%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779186054000.webp","sourceId":"rfi"}]