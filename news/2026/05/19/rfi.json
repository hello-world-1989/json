[{"id":1779182716000,"createdDate":"2026-05-19 09:25","name":"法国国际广播电台","title":"普京访华前夕 俄罗斯袭乌克兰多瑙河港口 乌克兰向莫斯科发射无人机","content":"路透社消息，在普京到访北京前夕，周二凌晨，俄罗斯空袭破坏了乌克兰伊兹梅尔市的港口基础设施。与此同时，俄罗斯当局表示，他们击落了乌克兰发射的四架飞往莫斯科的无人机。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260519-%E6%99%AE%E4%BA%AC%E8%AE%BF%E5%8D%8E%E5%89%8D%E5%A4%95-%E4%BF%84%E7%BD%97%E6%96%AF%E8%A2%AD%E4%B9%8C%E5%85%8B%E5%85%B0%E5%A4%9A%E7%91%99%E6%B2%B3%E6%B8%AF%E5%8F%A3-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%90%91%E8%8E%AB%E6%96%AF%E7%A7%91%E5%8F%91%E5%B0%84%E6%97%A0%E4%BA%BA%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779182716000.webp","sourceId":"rfi"},{"id":1779182534000,"createdDate":"2026-05-19 09:22","name":"法国国际广播电台","title":"《费加罗报》：普京因中美之间的“暧昧互动”感到不安 担心G2格局会将俄罗斯边缘化","content":"周二（5月19日）出刊的法国各大报纸关注点各不相同。《解放报》头条聚焦戛纳电影节的反博洛雷事件，《费加罗报》头条则聚焦法国笑气（一氧化二氮）的禁令问题，《十字架报》头条讲述该报记者探访乌克兰FirePoint公司的经历，这家公司是乌克兰无人机生产的标杆企业。至于中国方面的新闻，法国报纸主要聚焦普京访华。此前，特习会结束还不到24小时，克里姆林宫便确认，俄罗斯总统普京将于5月19日至20日访问中国，以加强与中国的战略伙伴关系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260519-%E8%B4%B9%E5%8A%A0%E7%BD%97%E6%8A%A5-%E6%99%AE%E4%BA%AC%E5%9B%A0%E4%B8%AD%E7%BE%8E%E4%B9%8B%E9%97%B4%E7%9A%84-%E6%9A%A7%E6%98%A7%E4%BA%92%E5%8A%A8-%E6%84%9F%E5%88%B0%E4%B8%8D%E5%AE%89-%E6%8B%85%E5%BF%83g2%E6%A0%BC%E5%B1%80%E4%BC%9A%E5%B0%86%E4%BF%84%E7%BD%97%E6%96%AF%E8%BE%B9%E7%BC%98%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779182534000.webp","sourceId":"rfi"},{"id":1779181358000,"createdDate":"2026-05-19 09:02","name":"法国国际广播电台","title":"日韩首脑在李在明总统故乡安东举行会谈","content":"高市早苗首相日本时间19日上午乘坐政府专机从羽田机场出发，前往韩国庆尚北道安东，与李在明总统举行会谈。19日下午，李在明总统与高市早苗首相在李总统故乡——庆尚北道安东举行了首脑会谈。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260519-%E6%97%A5%E9%9F%A9%E9%A6%96%E8%84%91%E5%9C%A8%E6%9D%8E%E5%9C%A8%E6%98%8E%E6%80%BB%E7%BB%9F%E6%95%85%E4%B9%A1%E5%AE%89%E4%B8%9C%E4%B8%BE%E8%A1%8C%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779181358000.webp","sourceId":"rfi"},{"id":1779180783000,"createdDate":"2026-05-19 08:53","name":"法国国际广播电台","title":"俄罗斯国防部宣布从今天起举行三天核军演","content":"俄罗斯国防部宣布俄军于今天周二19日开始进行为期三天的核武器军演和训练，届时有数千名士兵在全国范围内参与，就在本次俄军核武军演开始几个小时后，俄罗斯总统普京将抵达中国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260519-%E4%BF%84%E7%BD%97%E6%96%AF%E5%9B%BD%E9%98%B2%E9%83%A8%E5%AE%A3%E5%B8%83%E4%BB%8E%E4%BB%8A%E5%A4%A9%E8%B5%B7%E4%B8%BE%E8%A1%8C%E4%B8%89%E5%A4%A9%E6%A0%B8%E5%86%9B%E6%BC%94","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779180783000.webp","sourceId":"rfi"},{"id":1779179537000,"createdDate":"2026-05-19 08:32","name":"法国国际广播电台","title":"普京周二晚将抵达北京：俄中准备在主权等问题上相互支持","content":"俄罗斯总统弗拉基米尔·普京将于周二晚间抵达北京，周三将与中国国家主席习近平会面，距离美国总统特朗普访华还不到一周。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260519-%E6%99%AE%E4%BA%AC%E5%91%A8%E4%BA%8C%E6%99%9A%E5%B0%86%E6%8A%B5%E8%BE%BE%E5%8C%97%E4%BA%AC-%E4%BF%84%E4%B8%AD%E5%87%86%E5%A4%87%E5%9C%A8%E4%B8%BB%E6%9D%83%E7%AD%89%E9%97%AE%E9%A2%98%E4%B8%8A%E7%9B%B8%E4%BA%92%E6%94%AF%E6%8C%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779179537000.webp","sourceId":"rfi"},{"id":1779177707000,"createdDate":"2026-05-19 08:01","name":"法国国际广播电台","title":"恒大向原核数师罗兵咸相关公司索赔天价570亿人民币","content":"因「债可敌国」已被法庭颁令清盘的中国恒大，其清盘人以审计恒大过往财务报表工作存在疏忽及失实陈述为理由，向曾为恒大核数的罗兵咸永道中国及香港追讨巨额赔偿，同时将未有直接参与核数工作的罗兵咸永道国际也列为追讨对象，据外电报道，索赔额达到570亿元人民币(下同，折算约73亿欧元)，成为香港有史以来企业遭索赔最高金额的个案之一。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260519-%E6%81%92%E5%A4%A7%E5%90%91%E5%8E%9F%E6%A0%B8%E6%95%B0%E5%B8%88%E7%BD%97%E5%85%B5%E5%92%B8%E7%9B%B8%E5%85%B3%E5%85%AC%E5%8F%B8%E7%B4%A2%E8%B5%94%E5%A4%A9%E4%BB%B7570%E4%BA%BF%E4%BA%BA%E6%B0%91%E5%B8%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779177707000.webp","sourceId":"rfi"},{"id":1779177531000,"createdDate":"2026-05-19 07:58","name":"法国国际广播电台","title":"台湾立法院表决总统赖清德弹劾案未通过 蓝白联手仍未达法定门槛","content":"总统弹劾案投票结果出炉，以56票赞成、50票反对作结，另外有7位立委未领票。由于弹劾门槛高，外界预料仅属政治操作，意在520总统就职纪念前表达蓝白「反赖」态度。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260519-%E5%8F%B0%E6%B9%BE%E7%AB%8B%E6%B3%95%E9%99%A2%E8%A1%A8%E5%86%B3%E6%80%BB%E7%BB%9F%E8%B5%96%E6%B8%85%E5%BE%B7%E5%BC%B9%E5%8A%BE%E6%A1%88%E6%9C%AA%E9%80%9A%E8%BF%87-%E8%93%9D%E7%99%BD%E8%81%94%E6%89%8B%E4%BB%8D%E6%9C%AA%E8%BE%BE%E6%B3%95%E5%AE%9A%E9%97%A8%E6%A7%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779177531000.webp","sourceId":"rfi"},{"id":1779177284000,"createdDate":"2026-05-19 07:54","name":"法国国际广播电台","title":"埃博拉病毒：一公民确诊后，美国对部分中非旅客实施入境限制","content":"美国周一（5月18日）宣布，将加强针对埃博拉病毒的边境防疫检查。此前，一名美国公民在刚果民主共和国（金）感染了该病毒。美国疾病控制与预防中心（CDC）宣布，将对来自非洲受疫情影响地区的外国公民实施入境限制。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260519-%E5%9F%83%E5%8D%9A%E6%8B%89%E7%97%85%E6%AF%92-%E4%B8%80%E5%85%AC%E6%B0%91%E7%A1%AE%E8%AF%8A%E5%90%8E%EF%BC%8C%E7%BE%8E%E5%9B%BD%E5%AF%B9%E9%83%A8%E5%88%86%E4%B8%AD%E9%9D%9E%E6%97%85%E5%AE%A2%E5%AE%9E%E6%96%BD%E5%85%A5%E5%A2%83%E9%99%90%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/19/1779177284000.webp","sourceId":"rfi"}]