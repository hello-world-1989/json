[{"id":1778226736000,"createdDate":"2026-05-08 07:52","name":"法国国际广播电台","title":"港国安通缉的「议员」张信燕 获发难民证仍在泰国被捕 面临遣返中国危机","content":"被香港警方通缉丶拥有联合国驻曼谷难民专员公署签发证件的国安疑犯张信燕，昨(7日)天被泰国警方以逾期滞留及无证工作为名扣押，今天会在法庭提堂，以便遣返中国。她所属的民间组织「香港议会」发表声明，指这是中共政权对异见人士实施跨国镇压的另一「恶劣例证」，予以强烈谴责和抗议，促泰国拒绝遣返张信燕回中国大陆。该会「议长」忧虑，张一旦被遣返，会有人身安全问题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260508-%E6%B8%AF%E5%9B%BD%E5%AE%89%E9%80%9A%E7%BC%89%E7%9A%84-%E8%AE%AE%E5%91%98-%E5%BC%A0%E4%BF%A1%E7%87%95-%E8%8E%B7%E5%8F%91%E9%9A%BE%E6%B0%91%E8%AF%81%E4%BB%8D%E5%9C%A8%E6%B3%B0%E5%9B%BD%E8%A2%AB%E6%8D%95-%E9%9D%A2%E4%B8%B4%E9%81%A3%E8%BF%94%E4%B8%AD%E5%9B%BD%E5%8D%B1%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778226736000.webp","sourceId":"rfi"},{"id":1778226621000,"createdDate":"2026-05-08 07:50","name":"法国国际广播电台","title":"日韩首次副部长级外交防卫“2+2”对话在首尔举行","content":"5月7日，在韩国首尔举行了第14届日韩安全保障对话，也是首次举行日本和韩国由外交、防卫部门副部长级官员参加的“2+2”磋商，对话确认将在朝鲜及中东局势等背景下，加强安全保障领域的合作。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260508-%E6%97%A5%E9%9F%A9%E9%A6%96%E6%AC%A1%E5%89%AF%E9%83%A8%E9%95%BF%E7%BA%A7%E5%A4%96%E4%BA%A4%E9%98%B2%E5%8D%AB-2-2-%E5%AF%B9%E8%AF%9D%E5%9C%A8%E9%A6%96%E5%B0%94%E4%B8%BE%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778226621000.webp","sourceId":"rfi"},{"id":1778257385000,"createdDate":"2026-05-08 16:23","name":"法国国际广播电台","title":"英国法庭裁决涉港间谍案两被告罪成：中国谴责“政治操弄”","content":"法新社5月8日北京消息，中国周五谴责伦敦法院周四对两名英籍华裔公民作出的判决是政治“操纵”，这两名被告被判定协助中国和香港情报机构罪名成立。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260508-%E8%8B%B1%E5%9B%BD%E6%B3%95%E5%BA%AD%E5%AE%A3%E5%88%A4%E6%B6%89%E6%B8%AF%E9%97%B4%E8%B0%8D%E6%A1%88-%E4%B8%AD%E5%9B%BD%E8%B0%B4%E8%B4%A3-%E6%94%BF%E6%B2%BB%E6%93%8D%E5%BC%84","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778257385000.webp","sourceId":"rfi"},{"id":1778255270000,"createdDate":"2026-05-08 15:47","name":"法国国际广播电台","title":"台湾立法院通过7800亿元国防特别条例 绿营：预算打六折恐让台美合作停摆","content":"台湾反对党占多数的立法院今天8日三读通过国防特别条例，预算上限为新台币7800亿元。执政党民进党担心这个打六折的预算版本恐让台美合作停摆。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260508-%E5%8F%B0%E6%B9%BE%E7%AB%8B%E6%B3%95%E9%99%A2%E9%80%9A%E8%BF%877800%E4%BA%BF%E5%85%83%E5%9B%BD%E9%98%B2%E7%89%B9%E5%88%AB%E6%9D%A1%E4%BE%8B-%E7%BB%BF%E8%90%A5-%E9%A2%84%E7%AE%97%E6%89%93%E5%85%AD%E6%8A%98%E6%81%90%E8%AE%A9%E5%8F%B0%E7%BE%8E%E5%90%88%E4%BD%9C%E5%81%9C%E6%91%86","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778255270000.webp","sourceId":"rfi"},{"id":1778252867000,"createdDate":"2026-05-08 15:07","name":"法国国际广播电台","title":"美国怀疑英伟达芯片经泰国走私到阿里巴巴","content":"彭博社8日引述知情人透露，泰国国家人工智能计划背后的一家关键公司涉嫌帮助走私价值数十亿美元的超微电脑公司服务器到中国，这些服务器内装有英伟达公司的先进芯片，而阿里巴巴集团是众多最终客户之一。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260508-%E7%BE%8E%E5%9B%BD%E6%80%80%E7%96%91%E8%8B%B1%E4%BC%9F%E8%BE%BE%E8%8A%AF%E7%89%87%E7%BB%8F%E6%B3%B0%E5%9B%BD%E8%B5%B0%E7%A7%81%E5%88%B0%E9%98%BF%E9%87%8C%E5%B7%B4%E5%B7%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778252867000.webp","sourceId":"rfi"},{"id":1778250767000,"createdDate":"2026-05-08 14:32","name":"法国国际广播电台","title":"5月9日前夕 俄乌继续互相发动无人机袭击 尽管俄单方宣布停火","content":"在莫斯科为迎接5月9日二战纪念活动（该活动将在严密安保下举行）而宣布的单方停火于午夜生效后，俄罗斯和乌克兰周五继续相互发动无人机袭击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260508-5%E6%9C%889%E6%97%A5%E5%89%8D%E5%A4%95-%E4%BF%84%E4%B9%8C%E7%BB%A7%E7%BB%AD%E4%BA%92%E7%9B%B8%E5%8F%91%E5%8A%A8%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB-%E5%B0%BD%E7%AE%A1%E4%BF%84%E5%8D%95%E6%96%B9%E5%AE%A3%E5%B8%83%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778250767000.webp","sourceId":"rfi"},{"id":1778249413000,"createdDate":"2026-05-08 14:10","name":"法国国际广播电台","title":"特朗普全球征收10%关税政策 再次被美国法院裁定无效","content":"美国联邦国际贸易法院5月7日裁定，特朗普政府实施全球10%关税政策无效。法院责令美国政府向三家原告公司偿还过去两个月被不公正征收的关税并支付利息。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260508-%E7%89%B9%E6%9C%97%E6%99%AE%E5%85%A8%E7%90%83%E5%BE%81%E6%94%B610-%E5%85%B3%E7%A8%8E%E6%94%BF%E7%AD%96-%E5%86%8D%E6%AC%A1%E8%A2%AB%E7%BE%8E%E5%9B%BD%E6%B3%95%E9%99%A2%E8%A3%81%E5%AE%9A%E6%97%A0%E6%95%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778249413000.webp","sourceId":"rfi"},{"id":1778249312000,"createdDate":"2026-05-08 14:08","name":"法国国际广播电台","title":"非洲专家评中美赞比亚矿业开采之争","content":"位于南部非洲的小国赞比亚近日成为国际舆论的一大关注点，这一方面是由于赞比亚政府突然决定取消原定于本周在首都卢萨卡举行的国际数字人权大会，据赞比亚媒体披露，此举或与有台湾参与者以及北京施压有关；另一方面是由于经过数个月的斟酌，赞比亚政府本周宣布拒绝美国政府将医疗援助与矿业开采权挂钩的提案，美国特朗普政府今年年初冻结了美国的对外援助之后，向非洲多个国家递交了有条件的援助计划，这些交换条件包括数据开放，以及给与美国企业优先的能源以及矿产开发权。赞比亚是全球主要的铜矿以及钴矿拥有国，而铜与钴都是今天开发新能源所不可或缺的原材料，在该邻域中国企业在全球占据遥遥领先的地位，这就是为什么美国政府对赞比亚以及刚果民主共和国等资源丰富的国家提出了美国企业享受矿产资源开采优先权的要求，不过，与刚果金有所不同的是，赞比亚却拒绝了美国的要求，赞比亚政府为何向特朗普政府说不？尤其是赞比亚政府今年三月刚刚提出欢迎来自各国的投资以便达到将铜产量从2025年的近一百万吨提高至2031年的三百万吨的目标。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E5%A2%83%E4%B8%8E%E5%8F%91%E5%B1%95/20260508-%E9%9D%9E%E6%B4%B2%E4%B8%93%E5%AE%B6%E8%AF%84%E4%B8%AD%E7%BE%8E%E8%B5%9E%E6%AF%94%E4%BA%9A%E7%9F%BF%E4%B8%9A%E5%BC%80%E9%87%87%E4%B9%8B%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778249312000.webp","sourceId":"rfi"},{"id":1778247664000,"createdDate":"2026-05-08 13:41","name":"法国国际广播电台","title":"美伊在霍尔木兹海峡交火 特朗普坚称“停火协议仍有效”","content":"法新社8日华盛顿消息：唐纳德·特朗普周四坚称停火协议依然有效，而德黑兰方面谴责华盛顿违反了该协议，且海湾地区再度爆发敌对行动。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260508-%E7%BE%8E%E4%BC%8A%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E4%BA%A4%E7%81%AB-%E7%89%B9%E6%9C%97%E6%99%AE%E5%9D%9A%E7%A7%B0-%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E4%BB%8D%E6%9C%89%E6%95%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778247664000.webp","sourceId":"rfi"},{"id":1778246263000,"createdDate":"2026-05-08 13:17","name":"法国国际广播电台","title":"中国证实“有中国公民”的油轮在霍尔木兹海峡遇袭 暂无人员伤亡报告","content":"路透社5月8日北京消息，中国外交部周五证实，一艘载有中国船员的成品油轮在霍尔木兹海峡遭到袭击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260508-%E4%B8%AD%E5%9B%BD%E8%AF%81%E5%AE%9E-%E6%9C%89%E4%B8%AD%E5%9B%BD%E5%85%AC%E6%B0%91-%E7%9A%84%E6%B2%B9%E8%BD%AE%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%81%87%E8%A2%AD-%E6%9A%82%E6%97%A0%E4%BA%BA%E5%91%98%E4%BC%A4%E4%BA%A1%E6%8A%A5%E5%91%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778246263000.webp","sourceId":"rfi"},{"id":1778244009000,"createdDate":"2026-05-08 12:40","name":"法国国际广播电台","title":"美国数据显示中国东航客机坠毁前 驾驶舱内发生过搏斗","content":"美国国家运输安全委员会（NTSB）的数据显示，2022年中国飞机坠毁事故发生前，两台发动机均已关闭，驾驶舱内发生了搏斗。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260508-%E7%BE%8E%E5%9B%BD%E6%95%B0%E6%8D%AE%E6%98%BE%E7%A4%BA%E4%B8%AD%E5%9B%BD%E4%B8%9C%E8%88%AA%E5%AE%A2%E6%9C%BA%E5%9D%A0%E6%AF%81%E5%89%8D-%E9%A9%BE%E9%A9%B6%E8%88%B1%E5%86%85%E5%8F%91%E7%94%9F%E8%BF%87%E6%90%8F%E6%96%97","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778244009000.webp","sourceId":"rfi"},{"id":1778242642000,"createdDate":"2026-05-08 12:17","name":"法国国际广播电台","title":"应对中东战事冲击 东盟峰会聚焦能源粮食与协作","content":"第48届东盟峰会5月8日在菲律宾中部宿务举行，在中东局势持续升级之际，此次峰会聚焦能源安全、粮食供应稳定以及区域协调合作等议题，希望通过加强合作，减轻伊朗战争及霍尔木兹海峡运输受阻对东南亚经济造成的冲击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260508-%E5%BA%94%E5%AF%B9%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%8B%E5%86%B2%E5%87%BB-%E4%B8%9C%E7%9B%9F%E5%B3%B0%E4%BC%9A%E8%81%9A%E7%84%A6%E8%83%BD%E6%BA%90%E7%B2%AE%E9%A3%9F%E4%B8%8E%E5%8D%8F%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778242642000.webp","sourceId":"rfi"},{"id":1778231958000,"createdDate":"2026-05-08 09:19","name":"法国国际广播电台","title":"港府称与英国谍报案无关 团体指是跨国镇压 港人更联署废经贸办","content":"香港驻伦敦经济贸易办事处行政经理袁松彪和英国边防人员卫志梁被法庭裁定协助中国和香港情报机构罪名成立，是英国首宗审讯并罪成的国安法案件。为被告袁松彪支付所有律师费用的香港政府强调，事件与港府和经贸办「绝无关连」；但人权团体认为，事件反映中港政府在各地实施「系统性压迫」，亦证明外国政府代理人利用英国机构监允和恐吓移英港人是真实存在的；而离散港人亦随即发起联署，呼吁撤销经贸办。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260508-%E6%B8%AF%E5%BA%9C%E7%A7%B0%E4%B8%8E%E8%8B%B1%E5%9B%BD%E8%B0%8D%E6%8A%A5%E6%A1%88%E6%97%A0%E5%85%B3-%E5%9B%A2%E4%BD%93%E6%8C%87%E6%98%AF%E8%B7%A8%E5%9B%BD%E9%95%87%E5%8E%8B-%E6%B8%AF%E4%BA%BA%E6%9B%B4%E8%81%94%E7%BD%B2%E5%BA%9F%E7%BB%8F%E8%B4%B8%E5%8A%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778231958000.webp","sourceId":"rfi"},{"id":1778231339000,"createdDate":"2026-05-08 09:08","name":"法国国际广播电台","title":"台湾立法院将表决国防特别条例 绿营担心在野提打折版本军购案造成防御漏洞","content":"台湾国防特别条例第四次朝野协商破局，立法院8日将处理此案并表决。再也提出新台币7800亿打折版本的军购案。民进党则表示，1.25兆元的军购案才是100分版本。国安人士警告，台湾的防卫窗口已在缩小。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260508-%E5%8F%B0%E6%B9%BE%E7%AB%8B%E6%B3%95%E9%99%A2%E5%B0%86%E8%A1%A8%E5%86%B3%E5%9B%BD%E9%98%B2%E7%89%B9%E5%88%AB%E6%9D%A1%E4%BE%8B-%E7%BB%BF%E8%90%A5%E6%8B%85%E5%BF%83%E5%9C%A8%E9%87%8E%E6%8F%90%E6%89%93%E6%8A%98%E7%89%88%E6%9C%AC%E5%86%9B%E8%B4%AD%E6%A1%88%E9%80%A0%E6%88%90%E9%98%B2%E5%BE%A1%E6%BC%8F%E6%B4%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778231339000.webp","sourceId":"rfi"},{"id":1778230305000,"createdDate":"2026-05-08 08:51","name":"法国国际广播电台","title":"巴拉圭总统访台：台北以军礼迎接 培尼亚重申伙伴关系 继续挺台","content":"台湾总统赖清德周五（5月8日）以隆重军礼仪式欢迎巴拉圭总统圣地亚哥·培尼亚到访，希望在北京持续施压的背景下，进一步巩固与这一台湾在南美洲唯一邦交国的关系。中国回应巴总统“窜访台湾”，敦促巴拉圭“早日站到历史正确一边”，与台湾断交。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260508-%E5%B7%B4%E6%8B%89%E5%9C%AD%E6%80%BB%E7%BB%9F%E8%AE%BF%E5%8F%B0-%E5%8F%B0%E5%8C%97%E4%BB%A5%E5%86%9B%E7%A4%BC%E8%BF%8E%E6%8E%A5-%E5%9F%B9%E5%B0%BC%E4%BA%9A%E9%87%8D%E7%94%B3%E4%BC%99%E4%BC%B4%E5%85%B3%E7%B3%BB-%E7%BB%A7%E7%BB%AD%E6%8C%BA%E5%8F%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778230305000.webp","sourceId":"rfi"},{"id":1778228686000,"createdDate":"2026-05-08 08:24","name":"法国国际广播电台","title":"法新社关注台湾立法院军购预算案继续讨价还价","content":"台湾反对党周五宣布，他们已达成共识，将用于采购美国武器的预算提高至近250亿美元，但仍远不及总统赖清德提议的近400亿美元。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260508-%E6%B3%95%E6%96%B0%E7%A4%BE%E5%85%B3%E6%B3%A8%E5%8F%B0%E6%B9%BE%E7%AB%8B%E6%B3%95%E9%99%A2%E5%86%9B%E8%B4%AD%E9%A2%84%E7%AE%97%E6%A1%88%E7%BB%A7%E7%BB%AD%E8%AE%A8%E4%BB%B7%E8%BF%98%E4%BB%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/08/1778228686000.webp","sourceId":"rfi"}]