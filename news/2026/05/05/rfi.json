[{"id":1777972334000,"createdDate":"2026-05-05 09:12","name":"法国国际广播电台","title":"特朗普：期待两周后会见习主席，会再提黎智英","content":"美国总统特朗普（DonaldTrump）周一在受访时表示，将在与中国国家主席习近平即将到来的峰会上再次提出香港前传媒大亨黎智英的案件。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260505-%E7%89%B9%E6%9C%97%E6%99%AE-%E6%9C%9F%E5%BE%85%E4%B8%A4%E5%91%A8%E5%90%8E%E4%BC%9A%E8%A7%81%E4%B9%A0%E4%B8%BB%E5%B8%AD%EF%BC%8C%E4%BC%9A%E5%86%8D%E6%8F%90%E9%BB%8E%E6%99%BA%E8%8B%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777972334000.webp","sourceId":"rfi"},{"id":1777968792000,"createdDate":"2026-05-05 08:13","name":"法国国际广播电台","title":"中国指日本要在其领土部署盟国核武器  日本反驳","content":"正在纽约联合国总部举行的《不扩散核武器条约》（NPT）审议大会于5月4日进入实质性讨论阶段，三个主要委员会全部开始展开讨论。在当天启动的、以核不扩散为主题的第二委员会上，中国再次主张“日本正在探求将同盟国核武器部署到本国领土”。对此，日本方面反驳称“毫无根据”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260505-%E4%B8%AD%E5%9B%BD%E6%8C%87%E6%97%A5%E6%9C%AC%E8%A6%81%E5%9C%A8%E5%85%B6%E9%A2%86%E5%9C%9F%E9%83%A8%E7%BD%B2%E7%9B%9F%E5%9B%BD%E6%A0%B8%E6%AD%A6%E5%99%A8-%E6%97%A5%E6%9C%AC%E5%8F%8D%E9%A9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777968792000.webp","sourceId":"rfi"},{"id":1777968466000,"createdDate":"2026-05-05 08:07","name":"法国国际广播电台","title":"赖清德总统结束84小时出访非洲友邦斯威士兰 圆满完成台湾外交任务","content":"赖清德总统在5日低调搭乘斯威士兰国王专机顺利返台，他在返国演说中提到，这一次出访行程一度受到中共阻挠，反而让世界看到台湾人民走向世界的坚定决心和意志。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260505-%E8%B5%96%E6%B8%85%E5%BE%B7%E6%80%BB%E7%BB%9F%E7%BB%93%E6%9D%9F84%E5%B0%8F%E6%97%B6%E5%87%BA%E8%AE%BF%E9%9D%9E%E6%B4%B2%E5%8F%8B%E9%82%A6%E6%96%AF%E5%A8%81%E5%A3%AB%E5%85%B0-%E5%9C%86%E6%BB%A1%E5%AE%8C%E6%88%90%E5%8F%B0%E6%B9%BE%E5%A4%96%E4%BA%A4%E4%BB%BB%E5%8A%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777968466000.webp","sourceId":"rfi"},{"id":1777968279000,"createdDate":"2026-05-05 08:04","name":"法国国际广播电台","title":"武官谢振中掌新闻处 评论料角色由宣传变舆论战斗机器","content":"香港政府公布，政府新闻处长将由警队出身的谢振中接掌，是香港回归後首次由非政务官统领该处，亦是首次由警务人员主管这个宣传政府政策的部门。情况令人回想上世纪七十年代中期由军旅出身的霍德(DaividFord)空降出任新闻处长，以处理後香港暴动年代的宣传事宜。另有评论员刘锐绍向本台指出，估计新闻处会由现时的政策宣传，改为在舆论上主动出击，成为战斗机器，亦难免让传媒忧虑港府会收紧对传媒的管控。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260505-%E6%AD%A6%E5%AE%98%E8%B0%A2%E6%8C%AF%E4%B8%AD%E6%8E%8C%E6%96%B0%E9%97%BB%E5%A4%84-%E8%AF%84%E8%AE%BA%E6%96%99%E8%A7%92%E8%89%B2%E7%94%B1%E5%AE%A3%E4%BC%A0%E5%8F%98%E8%88%86%E8%AE%BA%E6%88%98%E6%96%97%E6%9C%BA%E5%99%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777968279000.webp","sourceId":"rfi"},{"id":1777967774000,"createdDate":"2026-05-05 07:56","name":"法国国际广播电台","title":"路透独家：美官员称美国准备就移民问题对中国实施签证制裁","content":"华盛顿消息，特朗普政府一名高级官员告诉路透社，中国正在放缓遣返在美国非法居留的中国公民的努力。该官员警告称，如果北京不改变立场，华盛顿准备对中国加强旅行限制。美国对中国的这一新威胁发出之际，正值美国总统特朗普计划于5月14日至15日访问北京。外界预计他将与中国国家主席习近平提出遣返问题等议题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260505-%E8%B7%AF%E9%80%8F%E7%8B%AC%E5%AE%B6-%E7%BE%8E%E5%AE%98%E5%91%98%E7%A7%B0%E7%BE%8E%E5%9B%BD%E5%87%86%E5%A4%87%E5%B0%B1%E7%A7%BB%E6%B0%91%E9%97%AE%E9%A2%98%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%AE%9E%E6%96%BD%E7%AD%BE%E8%AF%81%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777967774000.webp","sourceId":"rfi"},{"id":1777945318000,"createdDate":"2026-05-05 01:41","name":"法国国际广播电台","title":"丝绸之路扩展 法媒：中国是否正趁势占领乌克兰领土？","content":"乌克兰战火已持续四年多。俄罗斯在其邻国推行入侵政策，据多方消息来源称，俄罗斯似乎正将中国纳入其战略。这种非正式合作将有助于北京实现更广泛的目标。由于新丝绸之路的扩展，法国媒体质疑：中国是否正在占领乌克兰领土？","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260505-%E6%96%B0%E4%B8%9D%E7%BB%B8%E4%B9%8B%E8%B7%AF%E6%89%A9%E5%B1%95-%E4%B8%AD%E5%9B%BD%E6%98%AF%E5%90%A6%E6%AD%A3%E5%9C%A8%E5%8D%A0%E9%A2%86%E4%B9%8C%E5%85%8B%E5%85%B0%E9%A2%86%E5%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777945318000.webp","sourceId":"rfi"},{"id":1777995258000,"createdDate":"2026-05-05 15:34","name":"法国国际广播电台","title":"红场阅兵式在即 莫斯科切断移动互联网连接","content":"周二，俄罗斯切断了首都莫斯科的移动互联网连接，以应对二战胜利纪念活动可能引发的乌克兰无人机报复性袭击。法新社记者报导称，周二上午，俄罗斯首都中心城区的移动互联网服务中断。网络运营商警告称，网络中断将持续到5月9日，届时俄罗斯将在红场举行卫国战争胜利日阅兵式。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260505-%E7%BA%A2%E5%9C%BA%E9%98%85%E5%85%B5%E5%BC%8F%E5%9C%A8%E5%8D%B3-%E8%8E%AB%E6%96%AF%E7%A7%91%E5%88%87%E6%96%AD%E7%A7%BB%E5%8A%A8%E4%BA%92%E8%81%94%E7%BD%91%E8%BF%9E%E6%8E%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777995258000.webp","sourceId":"rfi"},{"id":1777993200000,"createdDate":"2026-05-05 15:00","name":"法国国际广播电台","title":"推出国家稀土和永磁体韧性计划 法经财部长：重塑具有竞争力产业","content":"法国政府周二宣布了一系列旨在减少对中国稀土供应依赖的新措施，以保护包括消费电子、电动汽车和海上风电在内的各行各业。法方此举反映出全球正加大力度确保能源转型所需原材料的供应。此前，长期主导稀土市场的中国曾于2025年将稀土出口管制作为贸易武器。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260505-%E6%8E%A8%E5%87%BA%E5%9B%BD%E5%AE%B6%E7%A8%80%E5%9C%9F%E5%92%8C%E6%B0%B8%E7%A3%81%E4%BD%93%E9%9F%A7%E6%80%A7%E8%AE%A1%E5%88%92-%E6%B3%95%E7%BB%8F%E8%B4%A2%E9%83%A8%E9%95%BF-%E9%87%8D%E5%A1%91%E5%85%B7%E6%9C%89%E7%AB%9E%E4%BA%89%E5%8A%9B%E4%BA%A7%E4%B8%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777993200000.webp","sourceId":"rfi"},{"id":1777992590000,"createdDate":"2026-05-05 14:49","name":"法国国际广播电台","title":"法国法院重判中国鳗鱼苗走私犯","content":"法国西南部的波尔多法院5月4日宣布对17名鳗鱼苗走私犯的判决结果，这17人均被裁定有罪，并且被判处1年至5年的监禁以及数十万欧元的罚款。从这些走私犯的名字来判断，他们绝大多数是中国人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260505-%E6%B3%95%E5%9B%BD%E6%B3%95%E9%99%A2%E9%87%8D%E5%88%A4%E4%B8%AD%E5%9B%BD%E9%B3%97%E9%B1%BC%E8%8B%97%E8%B5%B0%E7%A7%81%E7%8A%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777992590000.webp","sourceId":"rfi"},{"id":1777991068000,"createdDate":"2026-05-05 14:24","name":"法国国际广播电台","title":"与北京在太平洋地区的影响力竞争加剧 澳洲拟与斐济签署安全和经济协议","content":"澳大利亚似乎即将与斐济签署一项具有里程碑意义的安全和经济协议，这是阿尔巴尼亚政府遏制中国在太平洋地区日益增长的影响力的举措之一。但来自北京的阻力破坏了澳大利亚与瓦努阿图政府达成的另一项协议，导致旨在巩固澳方作为该国主要安全伙伴地位的协议规模缩减。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260505-%E4%B8%8E%E5%8C%97%E4%BA%AC%E5%9C%A8%E5%A4%AA%E5%B9%B3%E6%B4%8B%E5%9C%B0%E5%8C%BA%E7%9A%84%E5%BD%B1%E5%93%8D%E5%8A%9B%E7%AB%9E%E4%BA%89%E5%8A%A0%E5%89%A7-%E6%BE%B3%E6%B4%B2%E6%8B%9F%E4%B8%8E%E6%96%90%E6%B5%8E%E7%AD%BE%E7%BD%B2%E5%AE%89%E5%85%A8%E5%92%8C%E7%BB%8F%E6%B5%8E%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777991068000.webp","sourceId":"rfi"},{"id":1777987316000,"createdDate":"2026-05-05 13:21","name":"法国国际广播电台","title":"特朗普扩大对古巴政府制裁力道 北京促华盛顿立即终止封锁制裁","content":"美国总统特朗普于上周五签署了一项行政命令，扩大了对古巴政府的制裁范围。两名白宫官员表示，新的制裁措施针对的是支持古巴政府安全机构或参与腐败或严重侵犯人权行为的个人、实体和附属机构，以及古巴政府的代理人、官员或支持者。北京方面，中国外交部发言人周二以答记者问方式表示，敦促美方立即终止对古巴的封锁制裁和任何形式的胁迫施压。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260505-%E7%89%B9%E6%9C%97%E6%99%AE%E6%89%A9%E5%A4%A7%E5%AF%B9%E5%8F%A4%E5%B7%B4%E6%94%BF%E5%BA%9C%E5%88%B6%E8%A3%81%E5%8A%9B%E9%81%93-%E5%8C%97%E4%BA%AC%E4%BF%83%E5%8D%8E%E7%9B%9B%E9%A1%BF%E7%AB%8B%E5%8D%B3%E7%BB%88%E6%AD%A2%E5%B0%81%E9%94%81%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777987316000.webp","sourceId":"rfi"},{"id":1777987315000,"createdDate":"2026-05-05 13:21","name":"法国国际广播电台","title":"泽连斯基谴责俄罗斯的休战提议“无耻”","content":"俄罗斯4日宣布，为纪念二战胜利81周年，在5月8日至9日单方面停火，并发出威胁，倘若乌克兰无法停火，莫斯科将对基辅发动大规模导弹袭击。乌克兰同天宣布，乌克兰将自5日子夜零时起至6日停止攻击行动。乌克兰外长瑟比加表示，5月6日将可以看到俄罗斯到底想要什么，是和平还是阅兵。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260505-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E8%B0%B4%E8%B4%A3%E4%BF%84%E7%BD%97%E6%96%AF%E7%9A%84%E4%BC%91%E6%88%98%E6%8F%90%E8%AE%AE-%E6%97%A0%E8%80%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777987315000.webp","sourceId":"rfi"},{"id":1777985542000,"createdDate":"2026-05-05 12:52","name":"法国国际广播电台","title":"日防相：考虑尽早向菲律宾转让二手护卫舰和TC-90教练机","content":"日本和菲律宾周二同意建立一个工作层面的会谈框架，就向菲律宾转让二手护卫舰问题进行磋商。两国都对中国在海上日益强硬的姿态表示担忧。该协议是在日本防卫大臣小泉进次郎和菲律宾国防部长特奥多罗（GilbertoTeodoro）当天在马尼拉会晤时达成的。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260505-%E6%97%A5%E9%98%B2%E7%9B%B8-%E8%80%83%E8%99%91%E5%B0%BD%E6%97%A9%E5%90%91%E8%8F%B2%E5%BE%8B%E5%AE%BE%E8%BD%AC%E8%AE%A9%E4%BA%8C%E6%89%8B%E6%8A%A4%E5%8D%AB%E8%88%B0%E5%92%8Ctc-90%E6%95%99%E7%BB%83%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777985542000.webp","sourceId":"rfi"},{"id":1777982673000,"createdDate":"2026-05-05 12:04","name":"法国国际广播电台","title":"就向中国传输欧盟个人数据合规问题 数据保护委员会调查希音爱尔兰","content":"爱尔兰数据保护委员会（DPC）周二宣布对快时尚电商公司‌希音爱尔兰（SheinIreland）展开调查，调查内容涉及该公司将欧盟境内用户的个人数据传输至中国的行为。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260505-%E5%B0%B1%E5%90%91%E4%B8%AD%E5%9B%BD%E4%BC%A0%E8%BE%93%E6%AC%A7%E7%9B%9F%E4%B8%AA%E4%BA%BA%E6%95%B0%E6%8D%AE%E5%90%88%E8%A7%84%E9%97%AE%E9%A2%98-%E7%88%B1%E6%95%B0%E6%8D%AE%E4%BF%9D%E6%8A%A4%E5%A7%94%E5%91%98%E4%BC%9A%E8%B0%83%E6%9F%A5%E5%B8%8C%E9%9F%B3%E7%88%B1%E5%B0%94%E5%85%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777982673000.webp","sourceId":"rfi"},{"id":1777982540000,"createdDate":"2026-05-05 12:02","name":"法国国际广播电台","title":"“大卫对战歌利亚”：赖清德南线突围返台捍卫“与世界建立联系的权利”","content":"台湾总统赖清德周二结束对非洲友邦斯威士兰（台称史瓦帝尼）的访问返台。他在桃园国际机场向媒体表示：“台湾人是世界公民，台湾有权与世界建立联系，我们不会在压力面前退缩。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260505-%E5%A4%A7%E5%8D%AB%E5%AF%B9%E6%88%98%E6%AD%8C%E5%88%A9%E4%BA%9A-%E8%B5%96%E6%B8%85%E5%BE%B7%E5%8D%97%E7%BA%BF%E7%AA%81%E5%9B%B4%E8%BF%94%E5%8F%B0%E6%8D%8D%E5%8D%AB-%E4%B8%8E%E4%B8%96%E7%95%8C%E5%BB%BA%E7%AB%8B%E8%81%94%E7%B3%BB%E7%9A%84%E6%9D%83%E5%88%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777982540000.webp","sourceId":"rfi"},{"id":1777976874000,"createdDate":"2026-05-05 10:27","name":"法国国际广播电台","title":"伊朗外长出访北京 将会见王毅探讨双边关系及地区国际形势发展","content":"伊朗外交部在其社媒平台“电报”账号上表示，伊朗外交部长阿拉格齐将于周二前往北京，与中国外交部长王毅就双边关系以及地区和国际形势举行会谈。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260505-%E4%BC%8A%E6%9C%97%E5%A4%96%E9%95%BF%E5%87%BA%E8%AE%BF%E5%8C%97%E4%BA%AC-%E5%B0%86%E4%BC%9A%E8%A7%81%E7%8E%8B%E6%AF%85%E6%8E%A2%E8%AE%A8%E5%8F%8C%E8%BE%B9%E5%85%B3%E7%B3%BB%E5%8F%8A%E5%9C%B0%E5%8C%BA%E5%9B%BD%E9%99%85%E5%BD%A2%E5%8A%BF%E5%8F%91%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777976874000.webp","sourceId":"rfi"},{"id":1777975818000,"createdDate":"2026-05-05 10:10","name":"法国国际广播电台","title":"欧委会正秘密筹备应对中国产能过剩新工具 有望年内面世","content":"布鲁塞尔方面正积极争取欧盟各行业团体支持一项旨在应对中国产能过剩的贸易武器，欧盟委员会也正加紧在今年夏天提出一项影响深远的新工具。尽管这项新工具的具体内容仍处于严格保密状态，但预计将于5月29日提交给欧盟委员会主席冯德莱恩（UrsulavonderLeyen）。届时，欧盟委员会27位委员将就中国问题举行重新安排的辩论。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260505-%E6%AC%A7%E5%A7%94%E4%BC%9A%E6%AD%A3%E7%A7%98%E5%AF%86%E7%AD%B9%E5%A4%87%E5%BA%94%E5%AF%B9%E4%B8%AD%E5%9B%BD%E4%BA%A7%E8%83%BD%E8%BF%87%E5%89%A9%E7%9A%84%E6%96%B0%E5%B7%A5%E5%85%B7-%E6%9C%89%E6%9C%9B%E5%B9%B4%E5%86%85%E9%9D%A2%E4%B8%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777975818000.webp","sourceId":"rfi"},{"id":1777973732000,"createdDate":"2026-05-05 09:35","name":"法国国际广播电台","title":"纽时 : 白宫计划建立审批人工智能模型机制","content":"特朗普政府正在考虑签署一项行政命令，成立一个人工智能工作组并进行模型测试 ,也是加强对这项新技术监管的系列举措之一。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260505-%E7%BA%BD%E6%97%B6-%E7%99%BD%E5%AE%AB%E8%AE%A1%E5%88%92%E5%BB%BA%E7%AB%8B%E5%AE%A1%E6%89%B9%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E6%A8%A1%E5%9E%8B%E6%9C%BA%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777973732000.webp","sourceId":"rfi"}]