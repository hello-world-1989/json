[{"id":1777972334000,"createdDate":"2026-05-05 09:12","name":"法国国际广播电台","title":"特朗普：期待两周后会见习主席，会再提黎智英","content":"美国总统特朗普（DonaldTrump）周一在受访时表示，将在与中国国家主席习近平即将到来的峰会上再次提出香港前传媒大亨黎智英的案件。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260505-%E7%89%B9%E6%9C%97%E6%99%AE-%E6%9C%9F%E5%BE%85%E4%B8%A4%E5%91%A8%E5%90%8E%E4%BC%9A%E8%A7%81%E4%B9%A0%E4%B8%BB%E5%B8%AD%EF%BC%8C%E4%BC%9A%E5%86%8D%E6%8F%90%E9%BB%8E%E6%99%BA%E8%8B%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777972334000.webp","sourceId":"rfi"},{"id":1777968792000,"createdDate":"2026-05-05 08:13","name":"法国国际广播电台","title":"中国指日本要在其领土部署盟国核武器  日本反驳","content":"正在纽约联合国总部举行的《不扩散核武器条约》（NPT）审议大会于5月4日进入实质性讨论阶段，三个主要委员会全部开始展开讨论。在当天启动的、以核不扩散为主题的第二委员会上，中国再次主张“日本正在探求将同盟国核武器部署到本国领土”。对此，日本方面反驳称“毫无根据”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260505-%E4%B8%AD%E5%9B%BD%E6%8C%87%E6%97%A5%E6%9C%AC%E8%A6%81%E5%9C%A8%E5%85%B6%E9%A2%86%E5%9C%9F%E9%83%A8%E7%BD%B2%E7%9B%9F%E5%9B%BD%E6%A0%B8%E6%AD%A6%E5%99%A8-%E6%97%A5%E6%9C%AC%E5%8F%8D%E9%A9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777968792000.webp","sourceId":"rfi"},{"id":1777968466000,"createdDate":"2026-05-05 08:07","name":"法国国际广播电台","title":"赖清德总统结束84小时出访非洲友邦斯威士兰 圆满完成台湾外交任务","content":"赖清德总统在5日低调搭乘斯威士兰国王专机顺利返台，他在返国演说中提到，这一次出访行程一度受到中共阻挠，反而让世界看到台湾人民走向世界的坚定决心和意志。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260505-%E8%B5%96%E6%B8%85%E5%BE%B7%E6%80%BB%E7%BB%9F%E7%BB%93%E6%9D%9F84%E5%B0%8F%E6%97%B6%E5%87%BA%E8%AE%BF%E9%9D%9E%E6%B4%B2%E5%8F%8B%E9%82%A6%E6%96%AF%E5%A8%81%E5%A3%AB%E5%85%B0-%E5%9C%86%E6%BB%A1%E5%AE%8C%E6%88%90%E5%8F%B0%E6%B9%BE%E5%A4%96%E4%BA%A4%E4%BB%BB%E5%8A%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777968466000.webp","sourceId":"rfi"},{"id":1777968279000,"createdDate":"2026-05-05 08:04","name":"法国国际广播电台","title":"武官谢振中掌新闻处 评论料角色由宣传变舆论战斗机器","content":"香港政府公布，政府新闻处长将由警队出身的谢振中接掌，是香港回归後首次由非政务官统领该处，亦是首次由警务人员主管这个宣传政府政策的部门。情况令人回想上世纪七十年代中期由军旅出身的霍德(DaividFord)空降出任新闻处长，以处理後香港暴动年代的宣传事宜。另有评论员刘锐绍向本台指出，估计新闻处会由现时的政策宣传，改为在舆论上主动出击，成为战斗机器，亦难免让传媒忧虑港府会收紧对传媒的管控。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260505-%E6%AD%A6%E5%AE%98%E8%B0%A2%E6%8C%AF%E4%B8%AD%E6%8E%8C%E6%96%B0%E9%97%BB%E5%A4%84-%E8%AF%84%E8%AE%BA%E6%96%99%E8%A7%92%E8%89%B2%E7%94%B1%E5%AE%A3%E4%BC%A0%E5%8F%98%E8%88%86%E8%AE%BA%E6%88%98%E6%96%97%E6%9C%BA%E5%99%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777968279000.webp","sourceId":"rfi"},{"id":1777967774000,"createdDate":"2026-05-05 07:56","name":"法国国际广播电台","title":"路透独家：美官员称美国准备就移民问题对中国实施签证制裁","content":"华盛顿消息，特朗普政府一名高级官员告诉路透社，中国正在放缓遣返在美国非法居留的中国公民的努力。该官员警告称，如果北京不改变立场，华盛顿准备对中国加强旅行限制。美国对中国的这一新威胁发出之际，正值美国总统特朗普计划于5月14日至15日访问北京。外界预计他将与中国国家主席习近平提出遣返问题等议题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260505-%E8%B7%AF%E9%80%8F%E7%8B%AC%E5%AE%B6-%E7%BE%8E%E5%AE%98%E5%91%98%E7%A7%B0%E7%BE%8E%E5%9B%BD%E5%87%86%E5%A4%87%E5%B0%B1%E7%A7%BB%E6%B0%91%E9%97%AE%E9%A2%98%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%AE%9E%E6%96%BD%E7%AD%BE%E8%AF%81%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777967774000.webp","sourceId":"rfi"},{"id":1777945318000,"createdDate":"2026-05-05 01:41","name":"法国国际广播电台","title":"丝绸之路扩展 法媒：中国是否正趁势占领乌克兰领土？","content":"乌克兰战火已持续四年多。俄罗斯在其邻国推行入侵政策，据多方消息来源称，俄罗斯似乎正将中国纳入其战略。这种非正式合作将有助于北京实现更广泛的目标。由于新丝绸之路的扩展，法国媒体质疑：中国是否正在占领乌克兰领土？","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260505-%E6%96%B0%E4%B8%9D%E7%BB%B8%E4%B9%8B%E8%B7%AF%E6%89%A9%E5%B1%95-%E4%B8%AD%E5%9B%BD%E6%98%AF%E5%90%A6%E6%AD%A3%E5%9C%A8%E5%8D%A0%E9%A2%86%E4%B9%8C%E5%85%8B%E5%85%B0%E9%A2%86%E5%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/05/1777945318000.webp","sourceId":"rfi"}]