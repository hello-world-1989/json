[{"id":1779496067000,"createdDate":"2026-05-23 00:27","name":"法国国际广播电台","title":"金棕榈揭晓前夕 资深台湾影评人预测榜单","content":"再过几个小时，戛纳影节主竞赛单元的获奖名单就要宣布了，谁又会摘得包括金棕榈大奖在内的奖项呢，本台特派记者艾娃在戛纳采访了旅法台湾影评人梁志远先生，预测今晚有望获得各项大奖的热门人选。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260523-%E9%87%91%E6%A3%95%E6%A6%88%E6%8F%AD%E6%99%93%E5%89%8D%E5%A4%95-%E8%B5%84%E6%B7%B1%E5%8F%B0%E6%B9%BE%E5%BD%B1%E8%AF%84%E4%BA%BA%E9%A2%84%E6%B5%8B%E6%A6%9C%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779496067000.webp","sourceId":"rfi"},{"id":1779526167000,"createdDate":"2026-05-23 08:49","name":"法国国际广播电台","title":"消息人士称对台军售与伊朗战争无关 白宫官员：特朗普将在不久后作出决定","content":"据路透社援引一位知情人士报导称，美国对台军售流程需要数年才能完成，而且与今年2月爆发的美以伊战争无关。此前，一位五角大楼高官暗示，“暂停”对台军售是因为需要为伊朗冲突储备足够的武器。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260523-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB%E7%A7%B0%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E4%B8%8E%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%97%A0%E5%85%B3-%E7%99%BD%E5%AE%AB%E5%AE%98%E5%91%98-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B0%86%E5%BE%88%E5%BF%AB%E4%BD%9C%E5%87%BA%E5%86%B3%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779526167000.webp","sourceId":"rfi"},{"id":1779525337000,"createdDate":"2026-05-23 08:35","name":"法国国际广播电台","title":"泽连斯基反对德国涉乌提议：参与欧盟却无投票权“不公平”","content":"路透社5月23日报道，乌克兰总统泽连斯基近日致信欧洲多位领导人，对德国方面提出的给予乌克兰欧盟“联系成员”地位的设想表示反对。他在信中指出，如果乌克兰只能参与欧盟事务、却无法拥有投票权，这样的安排对乌克兰而言并不公平。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260523-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%8F%8D%E5%AF%B9%E5%BE%B7%E5%9B%BD%E6%B6%89%E4%B9%8C%E6%8F%90%E8%AE%AE-%E5%8F%82%E4%B8%8E%E6%AC%A7%E7%9B%9F%E5%8D%B4%E6%97%A0%E6%8A%95%E7%A5%A8%E6%9D%83-%E4%B8%8D%E5%85%AC%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779525337000.webp","sourceId":"rfi"},{"id":1779525310000,"createdDate":"2026-05-23 08:35","name":"法国国际广播电台","title":"欧盟希望重新平衡与中国的贸易关系：减少贸易逆差  供应多元化","content":"欧盟委员会副主席，负责产业政策的执行副主席斯特凡·塞茹尔内周五（5月22号）表示，欧盟必须重新平衡与中国的关系，以减少其天文数字般的贸易逆差并实现供应多元化。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260523-%E6%AC%A7%E7%9B%9F%E5%B8%8C%E6%9C%9B%E9%87%8D%E6%96%B0%E5%B9%B3%E8%A1%A1%E4%B8%8E%E4%B8%AD%E5%9B%BD%E7%9A%84%E8%B4%B8%E6%98%93%E5%85%B3%E7%B3%BB-%E5%87%8F%E5%B0%91%E8%B4%B8%E6%98%93%E9%80%86%E5%B7%AE-%E4%BE%9B%E5%BA%94%E5%A4%9A%E5%85%83%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779525310000.webp","sourceId":"rfi"},{"id":1779522528000,"createdDate":"2026-05-23 07:48","name":"法国国际广播电台","title":"山西煤矿瓦斯爆炸 已致90人遇难","content":"据中国官方媒体报道，山西省北部沁源县一座煤矿5月22日晚间发生瓦斯爆炸，已知造成90人遇难。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260523-%E5%B1%B1%E8%A5%BF%E7%85%A4%E7%9F%BF%E7%93%A6%E6%96%AF%E7%88%86%E7%82%B8-%E5%B7%B2%E8%87%B490%E4%BA%BA%E9%81%87%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779522528000.webp","sourceId":"rfi"}]