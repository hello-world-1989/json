[{"id":1779496067000,"createdDate":"2026-05-23 00:27","name":"法国国际广播电台","title":"金棕榈揭晓前夕 资深台湾影评人预测榜单","content":"再过几个小时，戛纳影节主竞赛单元的获奖名单就要宣布了，谁又会摘得包括金棕榈大奖在内的奖项呢，本台特派记者艾娃在戛纳采访了旅法台湾影评人梁志远先生，预测今晚有望获得各项大奖的热门人选。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260523-%E9%87%91%E6%A3%95%E6%A6%88%E6%8F%AD%E6%99%93%E5%89%8D%E5%A4%95-%E8%B5%84%E6%B7%B1%E5%8F%B0%E6%B9%BE%E5%BD%B1%E8%AF%84%E4%BA%BA%E9%A2%84%E6%B5%8B%E6%A6%9C%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779496067000.webp","sourceId":"rfi"},{"id":1779526167000,"createdDate":"2026-05-23 08:49","name":"法国国际广播电台","title":"消息人士称对台军售与伊朗战争无关 白宫官员：特朗普将在不久后作出决定","content":"据路透社援引一位知情人士报导称，美国对台军售流程需要数年才能完成，而且与今年2月爆发的美以伊战争无关。此前，一位五角大楼高官暗示，“暂停”对台军售是因为需要为伊朗冲突储备足够的武器。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260523-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB%E7%A7%B0%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E4%B8%8E%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%97%A0%E5%85%B3-%E7%99%BD%E5%AE%AB%E5%AE%98%E5%91%98-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B0%86%E5%BE%88%E5%BF%AB%E4%BD%9C%E5%87%BA%E5%86%B3%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779526167000.webp","sourceId":"rfi"},{"id":1779525337000,"createdDate":"2026-05-23 08:35","name":"法国国际广播电台","title":"泽连斯基反对德国涉乌提议：参与欧盟却无投票权“不公平”","content":"路透社5月23日报道，乌克兰总统泽连斯基近日致信欧洲多位领导人，对德国方面提出的给予乌克兰欧盟“联系成员”地位的设想表示反对。他在信中指出，如果乌克兰只能参与欧盟事务、却无法拥有投票权，这样的安排对乌克兰而言并不公平。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260523-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%8F%8D%E5%AF%B9%E5%BE%B7%E5%9B%BD%E6%B6%89%E4%B9%8C%E6%8F%90%E8%AE%AE-%E5%8F%82%E4%B8%8E%E6%AC%A7%E7%9B%9F%E5%8D%B4%E6%97%A0%E6%8A%95%E7%A5%A8%E6%9D%83-%E4%B8%8D%E5%85%AC%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779525337000.webp","sourceId":"rfi"},{"id":1779525310000,"createdDate":"2026-05-23 08:35","name":"法国国际广播电台","title":"欧盟希望重新平衡与中国的贸易关系：减少贸易逆差  供应多元化","content":"欧盟委员会副主席，负责产业政策的执行副主席斯特凡·塞茹尔内周五（5月22号）表示，欧盟必须重新平衡与中国的关系，以减少其天文数字般的贸易逆差并实现供应多元化。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260523-%E6%AC%A7%E7%9B%9F%E5%B8%8C%E6%9C%9B%E9%87%8D%E6%96%B0%E5%B9%B3%E8%A1%A1%E4%B8%8E%E4%B8%AD%E5%9B%BD%E7%9A%84%E8%B4%B8%E6%98%93%E5%85%B3%E7%B3%BB-%E5%87%8F%E5%B0%91%E8%B4%B8%E6%98%93%E9%80%86%E5%B7%AE-%E4%BE%9B%E5%BA%94%E5%A4%9A%E5%85%83%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779525310000.webp","sourceId":"rfi"},{"id":1779522528000,"createdDate":"2026-05-23 07:48","name":"法国国际广播电台","title":"山西煤矿瓦斯爆炸 已致90人遇难","content":"据中国官方媒体报道，山西省北部沁源县一座煤矿5月22日晚间发生瓦斯爆炸，已知造成90人遇难。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260523-%E5%B1%B1%E8%A5%BF%E7%85%A4%E7%9F%BF%E7%93%A6%E6%96%AF%E7%88%86%E7%82%B8-%E5%B7%B2%E8%87%B490%E4%BA%BA%E9%81%87%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779522528000.webp","sourceId":"rfi"},{"id":1779547565000,"createdDate":"2026-05-23 14:46","name":"法国国际广播电台","title":"日本防卫省16年前曾评估过中国统一台湾后对日军事影响","content":"据《产经新闻》报导称，日本防卫省过去曾就中国统一台湾可能对日本产生的军事影响进行过探讨。2010年制定《防卫计划大纲》时，该部门内曾就此展开讨论。据悉，当时正值解放军致力于航母等现代化建设并加强在日本周边活动之际，日本防卫省设想了安全保障环境进一步恶化的情景。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260523-%E6%97%A5%E6%9C%AC%E9%98%B2%E5%8D%AB%E7%9C%8116%E5%B9%B4%E5%89%8D%E6%9B%BE%E8%AF%84%E4%BC%B0%E8%BF%87%E4%B8%AD%E5%9B%BD%E7%BB%9F%E4%B8%80%E5%8F%B0%E6%B9%BE%E5%90%8E%E5%AF%B9%E6%97%A5%E5%86%9B%E4%BA%8B%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779547565000.webp","sourceId":"rfi"},{"id":1779545685000,"createdDate":"2026-05-23 14:14","name":"法国国际广播电台","title":"鲁比奥到访显示美国需要修复与印度的关系？","content":"美国国务卿马可·鲁比奥周六（5月23号）抵达印度展开对这个南亚大国的首次访问，四天行程旨在巩固因特朗普总统加征关税以及华盛顿重新加强与新德里竞争对手巴基斯坦和中国的接触而遭受重创的美印伙伴关系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260523-%E9%B2%81%E6%AF%94%E5%A5%A5%E8%AE%BF%E5%8D%B0%E6%98%BE%E7%A4%BA%E7%BE%8E%E5%9B%BD%E9%9C%80%E8%A6%81%E4%BF%AE%E5%A4%8D%E4%B8%8E%E5%8D%B0%E5%BA%A6%E7%9A%84%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779545685000.webp","sourceId":"rfi"},{"id":1779544470000,"createdDate":"2026-05-23 13:54","name":"法国国际广播电台","title":"美评估指中俄近年已扩大在古巴情报活动 古巴国家主席等在美使馆前声援卡斯特罗","content":"据《华尔街日报》报导，熟悉美国情报评估的官员称，近年来，中国和俄罗斯扩大了在古巴的情报活动，投资建设了用于监视美国在佛罗里达州军事基地的电子窃听设施，且自2023年以来，为这些设施配备的情报人员数量大约增加了两倍。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260523-%E7%BE%8E%E8%AF%84%E4%BC%B0%E6%8C%87%E4%B8%AD%E4%BF%84%E8%BF%91%E5%B9%B4%E5%B7%B2%E6%89%A9%E5%A4%A7%E5%9C%A8%E5%8F%A4%E5%B7%B4%E6%83%85%E6%8A%A5%E6%B4%BB%E5%8A%A8-%E5%8F%A4%E5%B7%B4%E5%9B%BD%E5%AE%B6%E4%B8%BB%E5%B8%AD%E7%AD%89%E5%9C%A8%E7%BE%8E%E4%BD%BF%E9%A6%86%E5%89%8D%E5%A3%B0%E6%8F%B4%E5%8D%A1%E6%96%AF%E7%89%B9%E7%BD%97","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779544470000.webp","sourceId":"rfi"},{"id":1779539339000,"createdDate":"2026-05-23 12:28","name":"法国国际广播电台","title":"山西煤矿事故已致90人死亡 高市：深感悲痛，向遇难者家属致以哀思","content":"当地时间5月22日19时35分，山西省沁源县通洲集团留神峪煤矿发生瓦斯爆炸事故。截至5月23日14时，事故已造成90人死亡，现场搜救仍在进行。企业实际控制人、负责人已被依法采取控制措施。日本首相高市早苗23日通过社媒平台X用日英中三语作出回应，其中用中文写道，“惊悉贵国山西省发生煤矿爆炸事故，造成重大灾害，对此深感悲痛。谨对遇难者致以深切哀悼，并向遇难者家属致以哀思。同时，向受灾人民致以衷心慰问”。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260523-%E5%B1%B1%E8%A5%BF%E7%85%A4%E7%9F%BF%E4%BA%8B%E6%95%85%E5%B7%B2%E8%87%B490%E4%BA%BA%E6%AD%BB%E4%BA%A1-%E9%AB%98%E5%B8%82-%E6%B7%B1%E6%84%9F%E6%82%B2%E7%97%9B%EF%BC%8C%E5%90%91%E9%81%87%E9%9A%BE%E8%80%85%E5%AE%B6%E5%B1%9E%E8%87%B4%E4%BB%A5%E5%93%80%E6%80%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779539339000.webp","sourceId":"rfi"},{"id":1779537360000,"createdDate":"2026-05-23 11:56","name":"法国国际广播电台","title":"中国兵器装备前总经理徐留平被查","content":"中央纪委国家监委网站周六通报指，中华全国总工会党组书记、副主席、书记处第一书记徐留平涉嫌严重违纪违法，目前正接受中央纪委国家监委纪律审查和监察调查。据悉，现年61岁的徐留平是正部级干部，曾长期在军工央企担任高管。他是第二十届中共中央候补委员，曾任中国兵器装备集团公司董事、总经理、党组副书记等职，2017年任中国第一汽车集团公司董事长、党委书记。2023年2月，出任中华全国总工会党组书记，后担任公会副主席、书记处第一书记，直至此番被查。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260523-%E4%B8%AD%E5%9B%BD%E5%85%B5%E5%99%A8%E8%A3%85%E5%A4%87%E5%89%8D%E6%80%BB%E7%BB%8F%E7%90%86%E5%BE%90%E7%95%99%E5%B9%B3%E8%A2%AB%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779537360000.webp","sourceId":"rfi"},{"id":1779536162000,"createdDate":"2026-05-23 11:36","name":"法国国际广播电台","title":"日经产相与王文涛接触 外务副大臣促中方确保在华日本公民安全","content":"日本经济产业大臣赤泽亮正周六表示，他在苏州举行的亚太经合组织（APEC）贸易部长会议期间与中国商务部长王文涛进行了简短交流，这是自去年日本首相高市早苗在国会答辩中称“台湾有事”可能构成“存亡危机事态”，中日关系再度紧张后，两国部长级官员的首次接触。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260523-%E6%97%A5%E7%BB%8F%E4%BA%A7%E7%9B%B8%E4%B8%8E%E7%8E%8B%E6%96%87%E6%B6%9B%E6%8E%A5%E8%A7%A6-%E5%A4%96%E5%8A%A1%E5%89%AF%E5%A4%A7%E8%87%A3%E4%BF%83%E4%B8%AD%E6%96%B9%E7%A1%AE%E4%BF%9D%E5%9C%A8%E5%8D%8E%E6%97%A5%E6%9C%AC%E5%85%AC%E6%B0%91%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779536162000.webp","sourceId":"rfi"},{"id":1779531071000,"createdDate":"2026-05-23 10:11","name":"法国国际广播电台","title":"法贸易高官：中方须明白，若摧毁欧洲工业和市场，终将一无所获","content":"法国对外贸易和吸引力部长级代表福里西耶（NicolasForissier）在受访时表示，欧盟必须停止“天真”，转变其在解决贸易失衡问题上的思维方式，并指该方法应涵盖所有将对外贸易武器化的国家。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260523-%E6%B3%95%E8%B4%B8%E6%98%93%E9%AB%98%E5%AE%98-%E4%B8%AD%E6%96%B9%E9%A1%BB%E6%98%8E%E7%99%BD%EF%BC%8C%E8%8B%A5%E6%91%A7%E6%AF%81%E6%AC%A7%E6%B4%B2%E5%B7%A5%E4%B8%9A%E5%92%8C%E5%B8%82%E5%9C%BA%EF%BC%8C%E7%BB%88%E5%B0%86%E4%B8%80%E6%97%A0%E6%89%80%E8%8E%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779531071000.webp","sourceId":"rfi"},{"id":1779529277000,"createdDate":"2026-05-23 09:41","name":"法国国际广播电台","title":"斯特兰蒂斯借中国车企“消化”欧洲过剩产能，以减少在欧关厂压力","content":"各位好，2026年5月23日出刊的法国主流日刊中，经济类回声报刊登了两则有关中国的报道。我们在本期法国报纸摘要节目当中为您综述相关报道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260523-%E6%96%AF%E7%89%B9%E5%85%B0%E8%92%82%E6%96%AF%E5%80%9F%E4%B8%AD%E5%9B%BD%E8%BD%A6%E4%BC%81-%E6%B6%88%E5%8C%96-%E6%AC%A7%E6%B4%B2%E8%BF%87%E5%89%A9%E4%BA%A7%E8%83%BD%EF%BC%8C%E4%BB%A5%E5%87%8F%E5%B0%91%E5%9C%A8%E6%AC%A7%E5%85%B3%E5%8E%82%E5%8E%8B%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779529277000.webp","sourceId":"rfi"},{"id":1779528853000,"createdDate":"2026-05-23 09:34","name":"法国国际广播电台","title":"日本外相与伊朗外长举行电话会谈","content":"5月22日下午6点起20分钟内，日本外务大臣茂木敏充与伊朗外交部长阿拉格齐举行了电话会谈。自美以发动军事行动后，这是两人第6次通话，而日本经济产业省22日表示，由出光兴产子公司负责运营管理的原油油轮“出光丸”预计将于25日抵达日本，这将是中东局势恶化后，首艘通过霍尔木兹海峡并抵达日本的原油油轮。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260523-%E6%97%A5%E6%9C%AC%E5%A4%96%E7%9B%B8%E4%B8%8E%E4%BC%8A%E6%9C%97%E5%A4%96%E9%95%BF%E4%B8%BE%E8%A1%8C%E7%94%B5%E8%AF%9D%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779528853000.webp","sourceId":"rfi"},{"id":1779528485000,"createdDate":"2026-05-23 09:28","name":"法国国际广播电台","title":"消息人士称美台就潜在特赖通话有接触但无具体计划 鲁比奥怎么说？","content":"据路透社援引四位知情人士报导称，尽管美国总统特朗普（DonaldTrump）说，其可能很快会与台湾总统赖清德就对台军售问题通话，但美台尚未就双方领导人通话制定具体计划。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260523-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB%E7%A7%B0%E7%BE%8E%E5%8F%B0%E5%B0%B1%E6%BD%9C%E5%9C%A8%E7%89%B9%E8%B5%96%E9%80%9A%E8%AF%9D%E6%9C%89%E6%8E%A5%E8%A7%A6%E4%BD%86%E6%97%A0%E5%85%B7%E4%BD%93%E8%AE%A1%E5%88%92-%E9%B2%81%E6%AF%94%E5%A5%A5%E6%80%8E%E4%B9%88%E8%AF%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/23/1779528485000.webp","sourceId":"rfi"}]