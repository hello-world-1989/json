[{"id":1778922402000,"createdDate":"2026-05-16 09:06","name":"法国国际广播电台","title":"以黎同意延长停火45天 以军对黎南部空袭仍持续","content":"在美国主导下进行两天的新一轮谈判后，以色列和黎巴嫩周五（5月15日）达成协议，将原定本周日到期的停火协议延长45天，双方同意在未来几周内将举行进一步会谈。而在停火延长消息公布之际，以色列仍在持续对黎巴嫩南部发动空袭。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260516-%E4%BB%A5%E9%BB%8E%E5%90%8C%E6%84%8F%E5%BB%B6%E9%95%BF%E5%81%9C%E7%81%AB45%E5%A4%A9-%E4%BB%A5%E5%86%9B%E5%AF%B9%E9%BB%8E%E5%8D%97%E9%83%A8%E7%A9%BA%E8%A2%AD%E4%BB%8D%E6%8C%81%E7%BB%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778922402000.webp","sourceId":"rfi"},{"id":1778920621000,"createdDate":"2026-05-16 08:37","name":"法国国际广播电台","title":"2026戛纳电影节：周六主竞赛单元影片受瞩目，是枝裕和等三位导演携新片亮相","content":"电影节开幕三天后，周六（5月16日），戛纳主竞赛单元进一步升温。三部角逐金棕榈奖的影片将在蔚蓝海岸亮相，大批国际明星将踏上红毯，多部备受期待的影片也将在平行单元放映。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260516-2026%E6%88%9B%E7%BA%B3%E7%94%B5%E5%BD%B1%E8%8A%82-%E5%91%A8%E5%85%AD%E4%B8%BB%E7%AB%9E%E8%B5%9B%E5%8D%95%E5%85%83%E8%A7%92%E9%80%90%E5%8D%87%E6%B8%A9%EF%BC%8C%E6%98%AF%E6%9E%9D%E8%A3%95%E5%92%8C%E7%AD%89%E4%B8%89%E4%BD%8D%E5%AF%BC%E6%BC%94%E6%90%BA%E6%96%B0%E7%89%87%E4%BA%AE%E7%9B%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778920621000.webp","sourceId":"rfi"},{"id":1778904409000,"createdDate":"2026-05-16 04:06","name":"法国国际广播电台","title":"美战略预测专家：“未来的世界既不会被中国主导，也不会被美国主导”","content":"根据战略预测学家帕拉格·卡纳(ParagKhanna)指出：“未来的世界既不会被中国主导，也不会被美国主导”这概念：与主流观点相反，这位也是CNN全球撰稿人的预测未来战略畅销书作者质疑美国和中国在世界某些战略区域的影响力。他将这一时期描述为“新中世纪”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260516-%E7%BE%8E%E6%88%98%E7%95%A5%E9%A2%84%E6%B5%8B%E4%B8%93%E5%AE%B6-%E6%9C%AA%E6%9D%A5%E7%9A%84%E4%B8%96%E7%95%8C%E6%97%A2%E4%B8%8D%E4%BC%9A%E8%A2%AB%E4%B8%AD%E5%9B%BD%E4%B8%BB%E5%AF%BC%EF%BC%8C%E4%B9%9F%E4%B8%8D%E4%BC%9A%E8%A2%AB%E7%BE%8E%E5%9B%BD%E4%B8%BB%E5%AF%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778904409000.webp","sourceId":"rfi"},{"id":1778950455000,"createdDate":"2026-05-16 16:54","name":"法国国际广播电台","title":"中国商务部谴责欧盟调查同方威视 要求单位或个人不得协助","content":"中国商务部周六发布声明，要求任何组织和个人都不要配合欧盟针对中国安检设备制造商同方威视发起的反补贴调查。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260516-%E4%B8%AD%E5%9B%BD%E5%95%86%E5%8A%A1%E9%83%A8%E8%B0%B4%E8%B4%A3%E6%AC%A7%E7%9B%9F%E8%B0%83%E6%9F%A5%E5%90%8C%E6%96%B9%E5%A8%81%E8%A7%86-%E8%A6%81%E6%B1%82%E5%8D%95%E4%BD%8D%E6%88%96%E4%B8%AA%E4%BA%BA%E4%B8%8D%E5%BE%97%E5%8D%8F%E5%8A%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778950455000.webp","sourceId":"rfi"},{"id":1778947175000,"createdDate":"2026-05-16 15:59","name":"法国国际广播电台","title":"特朗普发出警告后 台湾呼吁美国履行对台军售承诺","content":"据法新社5月16日台北报道，针对美国总统唐纳德·特朗普在结束北京之行后发出的严厉警告，台湾政府周六重申该岛已是“独立”的国家，并呼吁美国履行其对台军售承诺。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260516-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%91%E5%87%BA%E8%AD%A6%E5%91%8A%E5%90%8E-%E5%8F%B0%E6%B9%BE%E5%91%BC%E5%90%81%E7%BE%8E%E5%9B%BD%E5%B1%A5%E8%A1%8C%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E6%89%BF%E8%AF%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778947175000.webp","sourceId":"rfi"},{"id":1778941559000,"createdDate":"2026-05-16 14:25","name":"法国国际广播电台","title":"纪念文革60周年 重温潘鸣啸撰写《失落的一代——中国的上山下乡运动》","content":"文革开始六十周年纪念之际,法广专访了著名法国汉学家、法国社会科学院高等学院中国语言与文化学历史学博士潘鸣啸教授。潘鸣啸教授是当代中国问题和文化大革命问题历史研究专家,并用中文和法文出版了其著作《失落的一代——中国的上山下乡运动》，该书反思知青上山下乡和其影响。下面请听法广采访潘鸣啸先生，请他谈谈从学者和亲身经历的双重角度，对上个世纪60年代发生的文化大革命的一些反思。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%89%B9%E5%88%AB%E8%8A%82%E7%9B%AE/20260516-%E7%BA%AA%E5%BF%B5%E6%96%87%E9%9D%A960%E5%91%A8%E5%B9%B4-%E9%87%8D%E6%B8%A9%E6%BD%98%E9%B8%A3%E5%95%B8%E6%92%B0%E5%86%99-%E5%A4%B1%E8%90%BD%E7%9A%84%E4%B8%80%E4%BB%A3-%E4%B8%AD%E5%9B%BD%E7%9A%84%E4%B8%8A%E5%B1%B1%E4%B8%8B%E4%B9%A1%E8%BF%90%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778941559000.webp","sourceId":"rfi"},{"id":1778940136000,"createdDate":"2026-05-16 14:02","name":"法国国际广播电台","title":"法广2026年5月16日第二次播音 北京时间19-20点","content":"","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%AC%AC%E4%BA%8C%E6%AC%A1%E6%92%AD%E9%9F%B3-19-00-20-00-%E5%8C%97%E4%BA%AC%E6%97%B6%E9%97%B4/20260516-%E6%B3%95%E5%B9%BF2026%E5%B9%B45%E6%9C%8816%E6%97%A5%E7%AC%AC%E4%BA%8C%E6%AC%A1%E6%92%AD%E9%9F%B3-%E5%8C%97%E4%BA%AC%E6%97%B6%E9%97%B419-20%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778940136000.webp","sourceId":"rfi"},{"id":1778939960000,"createdDate":"2026-05-16 13:59","name":"法国国际广播电台","title":"特朗普访中：“没有比预期更糟，但也没有比预期更好”","content":"特朗普对中国为期两天的访问周五落幕，相关评析继续是今天左右两份大报《解放报》和《费加罗报》国际版面的重点。《解放报》分析指，尽管此次访问并未达成重大协议，但面对伊朗战争、台湾问题及双方间持续的经济竞争，中美共同确认了一种脆弱和而有限的“战略稳定”。《费加罗报》分析则更突出习近平借访问展现自身实力，访问凸显了双方间的竞争关系，也勾勒出一个中美主导“G2世界“的轮廓格局。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260516-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E4%B8%AD-%E6%B2%A1%E6%9C%89%E6%AF%94%E9%A2%84%E6%9C%9F%E6%9B%B4%E7%B3%9F%EF%BC%8C%E4%BD%86%E4%B9%9F%E6%B2%A1%E6%9C%89%E6%AF%94%E9%A2%84%E6%9C%9F%E6%9B%B4%E5%A5%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778939960000.webp","sourceId":"rfi"},{"id":1778934038000,"createdDate":"2026-05-16 12:20","name":"法国国际广播电台","title":"中国文革发动60周年祭 墙内悄无声息 墙外讨论分析","content":"今天5月16日是中国文化大革命发动60周年。这场后来被中共当局自己定性为“十年浩劫”的文化大革命，对中国的社会，政治，经济和人心都造成巨大冲击和深刻改变，延续几代人至今，甚至影响到全世界。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260516-%E4%B8%AD%E5%9B%BD%E6%96%87%E9%9D%A9%E5%8F%91%E5%8A%A860%E5%91%A8%E5%B9%B4%E7%A5%AD-%E5%A2%99%E5%86%85%E6%82%84%E6%97%A0%E5%A3%B0%E6%81%AF-%E5%A2%99%E5%A4%96%E8%AE%A8%E8%AE%BA%E5%88%86%E6%9E%90","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778934038000.webp","sourceId":"rfi"},{"id":1778931365000,"createdDate":"2026-05-16 11:36","name":"法国国际广播电台","title":"特习会结束未到24小时，俄罗斯确认普京将于19日至20日访华","content":"特习会结束还不到24小时，克里姆林宫周六（5月16日）一早便宣布，俄罗斯总统普京将于5月19日至20日访问中国，以加强与中国的战略伙伴关系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260516-%E7%89%B9%E4%B9%A0%E4%BC%9A%E7%BB%93%E6%9D%9F%E6%9C%AA%E5%88%B024%E5%B0%8F%E6%97%B6%EF%BC%8C%E4%BF%84%E7%BD%97%E6%96%AF%E7%A1%AE%E8%AE%A4%E6%99%AE%E4%BA%AC%E5%B0%86%E4%BA%8E19%E6%97%A5%E8%87%B320%E6%97%A5%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778931365000.webp","sourceId":"rfi"},{"id":1778923782000,"createdDate":"2026-05-16 09:29","name":"法国国际广播电台","title":"特朗普访华后在回国专机上与高市通电话  高市表示无法透露细节","content":"日本时间15日晚，日本首相高市早苗与美国总统特朗普进行了15分钟的电话会谈。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260516-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E5%90%8E%E5%9C%A8%E5%9B%9E%E5%9B%BD%E4%B8%93%E6%9C%BA%E4%B8%8A%E4%B8%8E%E9%AB%98%E5%B8%82%E9%80%9A%E7%94%B5%E8%AF%9D-%E9%AB%98%E5%B8%82%E8%A1%A8%E7%A4%BA%E6%97%A0%E6%B3%95%E9%80%8F%E9%9C%B2%E7%BB%86%E8%8A%82","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778923782000.webp","sourceId":"rfi"},{"id":1778969950000,"createdDate":"2026-05-16 22:19","name":"法国国际广播电台","title":"特朗普对习近平的恭敬远超出想象","content":"“欢迎欢迎，热烈欢迎”! “欢送欢送，热烈欢送”!","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260516-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AF%B9%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%9A%84%E6%81%AD%E6%95%AC%E8%BF%9C%E8%B6%85%E5%87%BA%E6%83%B3%E8%B1%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778969950000.webp","sourceId":"rfi"},{"id":1778968427000,"createdDate":"2026-05-16 21:53","name":"法国国际广播电台","title":"普京紧接着特朗普访华 莫斯科称中俄关系更深厚","content":"美国总统特朗普刚离开北京，中俄双方周六同时宣布，俄罗斯总统普京将于本月19-20日访问中国，旨在强化中俄战略合作伙伴关系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260516-%E6%99%AE%E4%BA%AC%E7%B4%A7%E6%8E%A5%E7%9D%80%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E-%E8%8E%AB%E6%96%AF%E7%A7%91%E7%A7%B0%E4%B8%AD%E4%BF%84%E5%85%B3%E7%B3%BB%E6%9B%B4%E6%B7%B1%E5%8E%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778968427000.webp","sourceId":"rfi"},{"id":1778967292000,"createdDate":"2026-05-16 21:34","name":"法国国际广播电台","title":"默茨评论美国的言论引发风波","content":"据德国广播电台报道，德国总理默茨最近多次对美国提出批评，引发政界担忧和媒体评论。德国联邦议院社民党议会党团事务主任维泽（DirkWiese）警告说，德美关系可能再次恶化。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260516-%E9%BB%98%E8%8C%A8%E8%AF%84%E8%AE%BA%E7%BE%8E%E5%9B%BD%E7%9A%84%E8%A8%80%E8%AE%BA%E5%BC%95%E5%8F%91%E9%A3%8E%E6%B3%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778967292000.webp","sourceId":"rfi"},{"id":1778967237000,"createdDate":"2026-05-16 21:33","name":"法国国际广播电台","title":"英国前卫生大臣将竞选工党党首 斯塔默再遭党内施压","content":"英国前卫生大臣韦斯·斯特里廷周六(5月16日）表示，他将“参选”工党党首，以接替首相斯塔默，并争取入主唐宁街。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260516-%E8%8B%B1%E5%9B%BD%E5%89%8D%E5%8D%AB%E7%94%9F%E5%A4%A7%E8%87%A3%E7%A7%B0%E5%B0%86%E7%AB%9E%E9%80%89%E5%B7%A5%E5%85%9A%E5%85%9A%E9%A6%96-%E6%96%AF%E5%A1%94%E9%BB%98%E5%86%8D%E9%81%AD%E5%85%9A%E5%86%85%E6%96%BD%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778967237000.webp","sourceId":"rfi"},{"id":1778967067000,"createdDate":"2026-05-16 21:31","name":"法国国际广播电台","title":"荷兰阿斯麦与印度塔塔电子签署半导体协议 莫迪推动印度芯片制造布局","content":"荷兰光刻机巨头阿斯麦(ASML）周六(5月16日）与印度塔塔电子(TataElectronics）签署协议，将协助印度建设半导体工厂。正在荷兰访问的印度总理莫迪出席了签约仪式。印度近年来积极发展本土芯片产业，而欧盟则将印度视为重要增长市场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260516-%E8%8D%B7%E5%85%B0%E9%98%BF%E6%96%AF%E9%BA%A6%E4%B8%8E%E5%8D%B0%E5%BA%A6%E5%A1%94%E5%A1%94%E7%94%B5%E5%AD%90%E7%AD%BE%E7%BD%B2%E5%8D%8A%E5%AF%BC%E4%BD%93%E5%8D%8F%E8%AE%AE-%E8%8E%AB%E8%BF%AA%E6%8E%A8%E5%8A%A8%E5%8D%B0%E5%BA%A6%E8%8A%AF%E7%89%87%E5%88%B6%E9%80%A0%E5%B8%83%E5%B1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778967067000.webp","sourceId":"rfi"},{"id":1778967026000,"createdDate":"2026-05-16 21:30","name":"法国国际广播电台","title":"特朗普对台军售未表态　美国会两党促白宫尽快放行","content":"美国总统特朗普在北京与中国国家主席习近平举行高峰会后，对是否批准总额140亿美元对台军售案态度保留，引发美国国会两党强烈反应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260516-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E6%9C%AA%E8%A1%A8%E6%80%81-%E7%BE%8E%E5%9B%BD%E4%BC%9A%E4%B8%A4%E5%85%9A%E4%BF%83%E7%99%BD%E5%AE%AB%E5%B0%BD%E5%BF%AB%E6%94%BE%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778967026000.webp","sourceId":"rfi"},{"id":1778966815000,"createdDate":"2026-05-16 21:26","name":"法国国际广播电台","title":"18年来首次：教皇良十四世9月将正式访问法国","content":"梵蒂冈5月16日宣布，教皇良十四世将于今年9月25日至28日对法国展开国事访问。这将是18年来首位天主教教皇正式访问法国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260516-18%E5%B9%B4%E6%9D%A5%E9%A6%96%E6%AC%A1-%E6%95%99%E7%9A%87%E8%89%AF%E5%8D%81%E5%9B%9B%E4%B8%969%E6%9C%88%E5%B0%86%E6%AD%A3%E5%BC%8F%E8%AE%BF%E9%97%AE%E6%B3%95%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778966815000.webp","sourceId":"rfi"},{"id":1778966594000,"createdDate":"2026-05-16 21:23","name":"法国国际广播电台","title":"\"特习会\"后 中美部分产品降税 农产品贸易释放缓和迹象","content":"中国商务部周六(5月16日）表示，在本周北京举行的中美元首会晤后，中美双方已就扩大农产品贸易、推进部分产品相互降税，以及解决部分非关税壁垒和市场准入问题达成初步共识。美国贸易代表格里尔称，美方预计未来三年中国将采购价值“数百亿美元”的美国农产品。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260516-%E7%89%B9%E4%B9%A0%E4%BC%9A-%E5%90%8E-%E4%B8%AD%E7%BE%8E%E9%83%A8%E5%88%86%E4%BA%A7%E5%93%81%E9%99%8D%E7%A8%8E-%E5%86%9C%E4%BA%A7%E5%93%81%E8%B4%B8%E6%98%93%E9%87%8A%E6%94%BE%E7%BC%93%E5%92%8C%E8%BF%B9%E8%B1%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778966594000.webp","sourceId":"rfi"},{"id":1778953206000,"createdDate":"2026-05-16 17:40","name":"法国国际广播电台","title":"美国-尼日利亚联合行动 伊斯兰国二号头目被击毙","content":"美国总统特朗普宣布，一名伊斯兰国头目在美军与尼日利亚军队在该国发起的联合行动中被击毙。尼日利亚总统周六证实了这个消息，并说该头目的几名副手同时丧生。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260516-%E7%BE%8E%E5%9B%BD-%E5%B0%BC%E6%97%A5%E5%88%A9%E4%BA%9A%E8%81%94%E5%90%88%E8%A1%8C%E5%8A%A8-%E4%BC%8A%E6%96%AF%E5%85%B0%E5%9B%BD%E4%BA%8C%E5%8F%B7%E5%A4%B4%E7%9B%AE%E8%A2%AB%E5%87%BB%E6%AF%99","thumbnail":"","detailImage":"news/detail/rfi/2026/05/16/1778953206000.webp","sourceId":"rfi"}]