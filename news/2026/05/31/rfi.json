[{"id":1780219686000,"createdDate":"2026-05-31 09:28","name":"法国国际广播电台","title":"日中在香格里拉安全对话会上相互攻讦、谴责","content":"由英国国际战略研究所（IISS）以及新加坡国防部亚洲安全峰会办公室携手组织的年度论坛“第23届香格里拉安全对话会”（通常称为“香格里拉论坛”)于5月29日在新加坡开幕。来自亚太地区等各国和地区的国防部长、军方高层等齐聚一堂，举行演讲、讨论及双边会谈，中国国防部长连续第二年缺席，由国防大学教授孟祥青少将率团出席会议。这是中国自2007年以来，参与该论坛代表层级最低的一次。去年中方派出了国防大学副校长胡刚锋少将与会，日本防卫大臣小泉进次郎出席，日中两国在论坛上相互攻讦、谴责。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260531-%E6%97%A5%E4%B8%AD%E5%9C%A8%E9%A6%99%E6%A0%BC%E9%87%8C%E6%8B%89%E5%AE%89%E5%85%A8%E5%AF%B9%E8%AF%9D%E4%BC%9A%E4%B8%8A%E7%9B%B8%E4%BA%92%E6%94%BB%E8%AE%A6-%E8%B0%B4%E8%B4%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/31/1780219686000.webp","sourceId":"rfi"},{"id":1780219617000,"createdDate":"2026-05-31 09:26","name":"法国国际广播电台","title":"澳改购三艘二手弗吉尼亚级核潜艇 澳英美无人水下载具拟明年交付","content":"澳大利亚副总理兼国防部长马尔斯（RichardMarles）表示，根据对澳英美三边安全伙伴关系（AUKUS），即奥库斯的调整，澳政府将只从美国购买二手弗吉尼亚级攻击核潜艇，这将为澳方节省“大量”开支。根据2021年达成的奥库斯协议，澳方原预计将接收至少两艘二手和一艘新的弗吉尼亚级攻击核潜艇。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260531-%E6%BE%B3%E6%94%B9%E8%B4%AD%E4%B8%89%E8%89%98%E4%BA%8C%E6%89%8B%E5%BC%97%E5%90%89%E5%B0%BC%E4%BA%9A%E7%BA%A7%E6%A0%B8%E6%BD%9C%E8%89%87-%E6%BE%B3%E8%8B%B1%E7%BE%8E%E6%97%A0%E4%BA%BA%E6%B0%B4%E4%B8%8B%E8%BD%BD%E5%85%B7%E6%8B%9F%E6%98%8E%E5%B9%B4%E4%BA%A4%E4%BB%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/31/1780219617000.webp","sourceId":"rfi"},{"id":1780244729000,"createdDate":"2026-05-31 16:25","name":"法国国际广播电台","title":"小泉提开设美日印澳四方安全对话防长会：望为迈向下一步增添能量","content":"日本防卫大臣小泉进次郎周日提议，在美日印澳四方安全对话（Quad）机制下开设防长会议，此举表明东京有意将该机制的安全议程拓展至外长和领导人层面之外。他表示愿借着四方安全对话防长会的机会访问今年的该机制轮值主席国印度。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260531-%E6%97%A5%E9%98%B2%E7%9B%B8%E6%8F%90%E5%BC%80%E8%AE%BE%E7%BE%8E%E6%97%A5%E5%8D%B0%E6%BE%B3%E5%9B%9B%E6%96%B9%E5%AE%89%E5%85%A8%E5%AF%B9%E8%AF%9D%E9%98%B2%E9%95%BF%E4%BC%9A-%E6%9C%9B%E4%B8%BA%E8%BF%88%E5%90%91%E4%B8%8B%E4%B8%80%E6%AD%A5%E5%A2%9E%E6%B7%BB%E8%83%BD%E9%87%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/31/1780244729000.webp","sourceId":"rfi"},{"id":1780242050000,"createdDate":"2026-05-31 15:40","name":"法国国际广播电台","title":"中企加大在摩洛哥投资设厂 欧盟高官忧成补贴商品输欧跳板：正成为大大的问题","content":"在摩洛哥港口城市丹吉尔郊外的灌木丛生的山丘上，中国汽车制造业的最新力作正在一片500公顷的农田上迅速崛起。羊群依然在摩洛哥穆罕默德六世丹吉尔科技城（以下称丹吉尔科技城）的高墙边悠闲地吃草。这里聚集着众多中国汽车零部件制造商，从刹车片到电池组件，希望助力欧洲的电动汽车革命。然而，欧盟方面日益担忧，中企计划在摩洛哥投资数十亿美元，这可能会使这个北非国家变成大量享受巨额补贴商品的出口平台，从而威胁到欧洲的工业。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260531-%E4%B8%AD%E4%BC%81%E5%8A%A0%E5%A4%A7%E5%9C%A8%E6%91%A9%E6%B4%9B%E5%93%A5%E6%8A%95%E8%B5%84%E8%AE%BE%E5%8E%82-%E6%AC%A7%E7%9B%9F%E9%AB%98%E5%AE%98%E5%BF%A7%E6%88%90%E8%A1%A5%E8%B4%B4%E5%95%86%E5%93%81%E8%BE%93%E6%AC%A7%E8%B7%B3%E6%9D%BF-%E6%AD%A3%E6%88%90%E4%B8%BA%E5%A4%A7%E5%A4%A7%E7%9A%84%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/31/1780242050000.webp","sourceId":"rfi"},{"id":1780235776000,"createdDate":"2026-05-31 13:56","name":"法国国际广播电台","title":"美药企对中国生物技术公司依赖加深 议员致信美财长表关切","content":"一些美国国会议员和投资者警告称，美国制药公司对中国的依赖日益加深，这使得华盛顿针对对华生物技术投资实施国家安全限制的可能性增加。辉瑞公司成为最新一家宣布与中国生物技术公司达成药物合作协议的美国制药巨头。辉瑞周四表示，将向信达生物支付6.5亿美元，用于开发多种抗癌药物。如果商业和监管目标得以实现，信达生物最终可能获得高达105亿美元的收益。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260531-%E7%BE%8E%E8%8D%AF%E4%BC%81%E5%AF%B9%E4%B8%AD%E5%9B%BD%E7%94%9F%E7%89%A9%E6%8A%80%E6%9C%AF%E5%85%AC%E5%8F%B8%E4%BE%9D%E8%B5%96%E5%8A%A0%E6%B7%B1-%E8%AE%AE%E5%91%98%E8%87%B4%E4%BF%A1%E7%BE%8E%E8%B4%A2%E9%95%BF%E8%A1%A8%E5%85%B3%E5%88%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/31/1780235776000.webp","sourceId":"rfi"},{"id":1780229340000,"createdDate":"2026-05-31 12:09","name":"法国国际广播电台","title":"日菲防长确认早日实现阿武隈级护卫舰转让 小泉欢迎新西兰考虑最上级护卫舰","content":"日本防卫大臣小泉进次郎周日在新加坡与菲律宾国防部长特奥多罗（GilbertoTeodoro）举行会谈。双方确认将在日本海上自卫队阿武隈级护卫舰退役后迅速出口，并于2027财年内向菲方移交一架TC-90海自教练机。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260531-%E6%97%A5%E8%8F%B2%E9%98%B2%E9%95%BF%E7%A1%AE%E8%AE%A4%E6%97%A9%E6%97%A5%E5%AE%9E%E7%8E%B0%E9%98%BF%E6%AD%A6%E9%9A%88%E7%BA%A7%E6%8A%A4%E5%8D%AB%E8%88%B0%E8%BD%AC%E8%AE%A9-%E5%B0%8F%E6%B3%89%E6%AC%A2%E8%BF%8E%E6%96%B0%E8%A5%BF%E5%85%B0%E8%80%83%E8%99%91%E6%9C%80%E4%B8%8A%E7%BA%A7%E6%8A%A4%E5%8D%AB%E8%88%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/31/1780229340000.webp","sourceId":"rfi"},{"id":1780225606000,"createdDate":"2026-05-31 11:06","name":"法国国际广播电台","title":"香格里拉对话上，美国战争部长回避了台湾和伊朗问题","content":"在亚洲最重要的安全论坛——香格里拉对话上，美国战争部长皮特·赫格塞斯在焦虑不安的亚洲各国面前，回避了台湾和伊朗问题。这是今天法国费加罗报国际版里的一个重点内容。报纸说，霍尔木兹海峡到马六甲海峡，距离很近。但在新加坡举行的香格里拉对话上，面对因所谓“史诗狂怒行动”引发的能源危机而焦头烂额的亚洲国家，赫格塞斯部长却避谈中东冲突。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260531-%E9%A6%99%E6%A0%BC%E9%87%8C%E6%8B%89%E5%AF%B9%E8%AF%9D%E4%B8%8A%EF%BC%8C%E7%BE%8E%E5%9B%BD%E6%88%98%E4%BA%89%E9%83%A8%E9%95%BF%E5%9B%9E%E9%81%BF%E4%BA%86%E5%8F%B0%E6%B9%BE%E5%92%8C%E4%BC%8A%E6%9C%97%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/31/1780225606000.webp","sourceId":"rfi"},{"id":1780224923000,"createdDate":"2026-05-31 10:55","name":"法国国际广播电台","title":"国际货币基金组织发放贷款后施压，斯里兰卡周日将燃油价格上调到6%","content":"斯里兰卡周日将燃油价格上调到6%，这次提价发生在国际货币基金组织发放29亿美元救助贷款中的6.95亿美元几天之后。这符合国际货币基金组织（IMF）旨在收回能源成本并逐步取消补贴以稳定经济的计划。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260531-%E5%9B%BD%E9%99%85%E8%B4%A7%E5%B8%81%E5%9F%BA%E9%87%91%E7%BB%84%E7%BB%87%E5%8F%91%E6%94%BE%E8%B4%B7%E6%AC%BE%E5%90%8E%E6%96%BD%E5%8E%8B%EF%BC%8C%E6%96%AF%E9%87%8C%E5%85%B0%E5%8D%A1%E5%91%A8%E6%97%A5%E5%B0%86%E7%87%83%E6%B2%B9%E4%BB%B7%E6%A0%BC%E4%B8%8A%E8%B0%83%E5%88%B06","thumbnail":"","detailImage":"news/detail/rfi/2026/05/31/1780224923000.webp","sourceId":"rfi"},{"id":1780224609000,"createdDate":"2026-05-31 10:50","name":"法国国际广播电台","title":"赫格塞斯强调“硬实力支撑规则”，美盟友重申规则体系的重要性","content":"在新加坡举行的香格里拉对话会及相关国际表态中，美国国防部长皮特·赫格塞斯成为多方关注的焦点。他在会议期间及前后多次强调，美国将在可能范围内继续支持乌克兰防务，同时希望欧洲盟友在防务上承担更多责任。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260531-%E8%B5%AB%E6%A0%BC%E5%A1%9E%E6%96%AF%E5%BC%BA%E8%B0%83-%E7%A1%AC%E5%AE%9E%E5%8A%9B%E6%94%AF%E6%92%91%E8%A7%84%E5%88%99-%EF%BC%8C%E7%BE%8E%E7%9B%9F%E5%8F%8B%E9%87%8D%E7%94%B3%E8%A7%84%E5%88%99%E4%BD%93%E7%B3%BB%E7%9A%84%E9%87%8D%E8%A6%81%E6%80%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/31/1780224609000.webp","sourceId":"rfi"},{"id":1780224115000,"createdDate":"2026-05-31 10:41","name":"法国国际广播电台","title":"美海警与菲海军海警在菲专属经济区内训练 解放军和中国海警巡逻黄岩岛区域","content":"中国军方和海警分别宣布，周日在南中国海争议水域斯卡伯勒浅滩（中方称黄岩岛）附近进行了巡逻。此前一天，菲律宾国防部长特奥多罗（GilbertoTeodoro）告诉媒体称，尽管本月中旬美中领导人在北京举行峰会后，两国关系有所缓和，但菲律宾仍面临来自中方的“严重威胁”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260531-%E7%BE%8E%E6%B5%B7%E8%AD%A6%E4%B8%8E%E8%8F%B2%E6%B5%B7%E5%86%9B-%E6%B5%B7%E8%AD%A6%E5%9C%A8%E8%8F%B2%E4%B8%93%E5%B1%9E%E7%BB%8F%E6%B5%8E%E5%8C%BA%E5%86%85%E8%AE%AD%E7%BB%83-%E8%A7%A3%E6%94%BE%E5%86%9B%E5%92%8C%E4%B8%AD%E5%9B%BD%E6%B5%B7%E8%AD%A6%E5%B7%A1%E9%80%BB%E9%BB%84%E5%B2%A9%E5%B2%9B%E5%8C%BA%E5%9F%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/31/1780224115000.webp","sourceId":"rfi"},{"id":1780222195000,"createdDate":"2026-05-31 10:09","name":"法国国际广播电台","title":"韩日防长讨论了双边军事后勤支援协定 时隔9年将重启人道主义搜救演习","content":"自新加坡消息，韩国国防部长官安圭伯介绍称，韩日两国防长在周六举行的会谈上就《物资劳务相互提供协定》（ACSA）交换了意见。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260531-%E9%9F%A9%E6%97%A5%E9%98%B2%E9%95%BF%E8%AE%A8%E8%AE%BA%E4%BA%86%E5%8F%8C%E8%BE%B9%E5%86%9B%E4%BA%8B%E5%90%8E%E5%8B%A4%E6%94%AF%E6%8F%B4%E5%8D%8F%E5%AE%9A-%E6%97%B6%E9%9A%949%E5%B9%B4%E5%B0%86%E9%87%8D%E5%90%AF%E4%BA%BA%E9%81%93%E4%B8%BB%E4%B9%89%E6%90%9C%E6%95%91%E6%BC%94%E4%B9%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/31/1780222195000.webp","sourceId":"rfi"},{"id":1780222078000,"createdDate":"2026-05-31 10:07","name":"法国国际广播电台","title":"以军攻占黎巴嫩中世纪古堡并升旗，黎南战线持续扩大","content":"5月31日，以色列军方宣布其部队已夺取位于黎巴嫩南部纳巴提耶附近的博福特城堡及周边山脊地区。这座建于约900年前、由十字军时期修建的中世纪要塞，坐落于当地战略高地。以军称，这是近期针对黎巴嫩真主党行动中的一项重要进展，也是以色列25年多来在黎巴嫩境内最深入的一次推进。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260531-%EF%BC%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/31/1780222078000.webp","sourceId":"rfi"}]