[{"id":1779270282000,"createdDate":"2026-05-20 09:44","name":"法国国际广播电台","title":"因涉嫌非法操控价格，美国起诉七名中国企业高管及多家集装箱制造巨头","content":"美国周二（5月19日）宣布，已起诉七名中国企业高管以及全球四大集装箱制造商，这些企业被怀疑合谋限制集装箱产量并操纵价格。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260520-%E5%9B%A0%E6%B6%89%E5%AB%8C%E9%9D%9E%E6%B3%95%E6%93%8D%E6%8E%A7%E4%BB%B7%E6%A0%BC%EF%BC%8C%E7%BE%8E%E5%9B%BD%E8%B5%B7%E8%AF%89%E4%B8%83%E5%90%8D%E4%B8%AD%E5%9B%BD%E4%BC%81%E4%B8%9A%E9%AB%98%E7%AE%A1%E5%8F%8A%E5%A4%9A%E5%AE%B6%E9%9B%86%E8%A3%85%E7%AE%B1%E5%88%B6%E9%80%A0%E5%B7%A8%E5%A4%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779270282000.webp","sourceId":"rfi"},{"id":1779268562000,"createdDate":"2026-05-20 09:16","name":"法国国际广播电台","title":"在特朗普的压力下，欧盟各国终于就关税问题达成协议","content":"在美国总统特朗普的压力下，欧盟周三（5月20日）终于就去年与美国达成的贸易协议取得一项临时妥协方案。这一妥协方案由轮值欧盟主席国塞浦路斯政府于周三凌晨宣布。此前，欧洲议会代表与欧盟成员国代表在法国斯特拉斯堡进行了一整夜紧张的谈判。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260520-%E5%9C%A8%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84%E5%8E%8B%E5%8A%9B%E4%B8%8B%EF%BC%8C%E6%AC%A7%E7%9B%9F%E5%90%84%E5%9B%BD%E7%BB%88%E4%BA%8E%E5%B0%B1%E5%85%B3%E7%A8%8E%E9%97%AE%E9%A2%98%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779268562000.webp","sourceId":"rfi"},{"id":1779268040000,"createdDate":"2026-05-20 09:07","name":"法国国际广播电台","title":"西班牙名导作品《苦涩的圣诞节》亮相戛纳 其法文名《自传体小说》更为直白","content":"戛纳影节第七天，主竞赛单元放映的影片之一是本届影节的热门影片《苦涩的圣诞节》，由西班牙著名导演阿尔多莫瓦执导。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260520-%E8%A5%BF%E7%8F%AD%E7%89%99%E5%90%8D%E5%AF%BC%E4%BD%9C%E5%93%81-%E8%8B%A6%E6%B6%A9%E7%9A%84%E5%9C%A3%E8%AF%9E%E8%8A%82-%E4%BA%AE%E7%9B%B8%E6%88%9B%E7%BA%B3-%E5%85%B6%E6%B3%95%E6%96%87%E5%90%8D-%E8%87%AA%E4%BC%A0%E4%BD%93%E5%B0%8F%E8%AF%B4-%E6%9B%B4%E4%B8%BA%E7%9B%B4%E7%99%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779268040000.webp","sourceId":"rfi"},{"id":1779267904000,"createdDate":"2026-05-20 09:05","name":"法国国际广播电台","title":"中国中南地区多地暴雨洪灾，死亡人数升至22人，20人失踪","content":"据中国官方媒体周三（5月20日）报道，近日中国中南地区多地遭遇强降雨，引发灾情，已导致22人死亡，20人失踪。气象部门预测，未来几天，中国多地仍将有持续大范围降雨。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260520-%E4%B8%AD%E5%9B%BD%E4%B8%AD%E5%8D%97%E5%9C%B0%E5%8C%BA%E5%A4%9A%E5%9C%B0%E6%9A%B4%E9%9B%A8%E6%B4%AA%E7%81%BE%EF%BC%8C%E6%AD%BB%E4%BA%A1%E4%BA%BA%E6%95%B0%E5%8D%87%E8%87%B322%E4%BA%BA%EF%BC%8C20%E4%BA%BA%E5%A4%B1%E8%B8%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779267904000.webp","sourceId":"rfi"},{"id":1779267780000,"createdDate":"2026-05-20 09:03","name":"法国国际广播电台","title":"中国正式确认采购200架波音飞机，并要求延长与美国的贸易休战","content":"中国周三（5月20日）宣布，有意购买200架波音客机，并寻求延长与美国达成的贸易休战协议，该协议将于今年11月到期。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260520-%E4%B8%AD%E5%9B%BD%E6%AD%A3%E5%BC%8F%E7%A1%AE%E8%AE%A4%E9%87%87%E8%B4%AD200%E6%9E%B6%E6%B3%A2%E9%9F%B3%E9%A3%9E%E6%9C%BA%EF%BC%8C%E5%B9%B6%E8%A6%81%E6%B1%82%E5%BB%B6%E9%95%BF%E4%B8%8E%E7%BE%8E%E5%9B%BD%E7%9A%84%E8%B4%B8%E6%98%93%E4%BC%91%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779267780000.webp","sourceId":"rfi"},{"id":1779267289000,"createdDate":"2026-05-20 08:54","name":"法国国际广播电台","title":"习近平与普京称中俄关系牢不可破，普京已邀请习近平明年访俄","content":"中国国家主席习近平与俄罗斯总统普京周三（5月20日）表示，尽管国际局势动荡，两国关系依然牢固。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260520-%E4%B9%A0%E8%BF%91%E5%B9%B3%E4%B8%8E%E6%99%AE%E4%BA%AC%E7%A7%B0%E4%B8%AD%E4%BF%84%E5%85%B3%E7%B3%BB%E7%89%A2%E4%B8%8D%E5%8F%AF%E7%A0%B4%EF%BC%8C%E6%99%AE%E4%BA%AC%E5%B7%B2%E9%82%80%E8%AF%B7%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%98%8E%E5%B9%B4%E8%AE%BF%E4%BF%84","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779267289000.webp","sourceId":"rfi"},{"id":1779261211000,"createdDate":"2026-05-20 07:13","name":"法国国际广播电台","title":"赖清德总统520执政两周年谈话 两岸论述成焦点拒绝以「和平包装统一」","content":"赖清德总统发表520就职两周年谈话，表示维持台海和平稳定是国家战略目标。愿意在对等原则下与中国交流，但坚定拒绝「以和平包装统一」的统战作为。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260520-%E8%B5%96%E6%B8%85%E5%BE%B7%E6%80%BB%E7%BB%9F520%E6%89%A7%E6%94%BF%E4%B8%A4%E5%91%A8%E5%B9%B4%E8%B0%88%E8%AF%9D-%E4%B8%A4%E5%B2%B8%E8%AE%BA%E8%BF%B0%E6%88%90%E7%84%A6%E7%82%B9%E6%8B%92%E7%BB%9D%E4%BB%A5-%E5%92%8C%E5%B9%B3%E5%8C%85%E8%A3%85%E7%BB%9F%E4%B8%80","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779261211000.webp","sourceId":"rfi"},{"id":1779260888000,"createdDate":"2026-05-20 07:08","name":"法国国际广播电台","title":"两名日本人在上海凶杀事件中受伤  日本官房长官要求查明真相","content":"当地时间19日下午，中国上海市一家日本料理店发生一名男子闯入行凶事件，造成3人受伤，其中2人为日本人。日本内阁官房长官木原稔在20日的记者会上表示，日方已向中方提出查明真相以及确保日本人安全等要求。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260520-%E4%B8%A4%E5%90%8D%E6%97%A5%E6%9C%AC%E4%BA%BA%E5%9C%A8%E4%B8%8A%E6%B5%B7%E5%87%B6%E6%9D%80%E4%BA%8B%E4%BB%B6%E4%B8%AD%E5%8F%97%E4%BC%A4-%E6%97%A5%E6%9C%AC%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E8%A6%81%E6%B1%82%E6%9F%A5%E6%98%8E%E7%9C%9F%E7%9B%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779260888000.webp","sourceId":"rfi"},{"id":1779260574000,"createdDate":"2026-05-20 07:02","name":"法国国际广播电台","title":"港府再拨50亿作国安开支 黑箱中六年共耗180亿元","content":"港府再次在无预告下，以专门拨款方式，从库房调拨50亿港元(下同，折算约5.5亿欧元)公帑作维护国家安全开支，并继续拒绝交代细节。此次已是港府在六年内，第三次增拨国安资源，累计拨款合共180亿。评论认为，港府为国安作巨额拨款，与北京及港府对外宣称香港已「由治及兴」的说法，有自相矛盾之嫌；更有人质疑拨款是否与跨境镇压有关。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260520-%E6%B8%AF%E5%BA%9C%E5%86%8D%E6%8B%A850%E4%BA%BF%E4%BD%9C%E5%9B%BD%E5%AE%89%E5%BC%80%E6%94%AF-%E9%BB%91%E7%AE%B1%E4%B8%AD%E5%85%AD%E5%B9%B4%E5%85%B1%E8%80%97180%E4%BA%BF%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779260574000.webp","sourceId":"rfi"},{"id":1779247729000,"createdDate":"2026-05-20 03:28","name":"法国国际广播电台","title":"降低对中国的依赖 七国集团财长准备合作生产提炼“稀土”","content":"为了降低对中国的稀土依赖程度，七国集团财长会议协商准备合作生产和提炼“稀土”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260520-%E9%99%8D%E4%BD%8E%E5%AF%B9%E4%B8%AD%E5%9B%BD%E4%BE%9D%E8%B5%96-%E4%B8%83%E5%9B%BD%E9%9B%86%E5%9B%A2%E8%B4%A2%E9%95%BF%E5%87%86%E5%A4%87%E5%90%88%E4%BD%9C%E7%94%9F%E4%BA%A7%E6%8F%90%E7%82%BC-%E7%A8%80%E5%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779247729000.webp","sourceId":"rfi"},{"id":1779289526000,"createdDate":"2026-05-20 15:05","name":"法国国际广播电台","title":"中俄继续肯定双边友谊但西伯利亚力量2号输气管道仍未有实质进展","content":"中国国家主席习近平20日上午在北京与来访的俄罗斯总统普京会谈。普京在北京似乎也获得了与几天前刚刚离开的美国总统特朗普同等的高规格迎接。虽然普京与习近平的会谈中显然被几天前的中美会谈更多了几分热情，双方同意继续延长已经25年的《中俄睦邻友好合作条约》，强调中俄友谊坚定不移。但是，在这份热情背后，已经谈判多年的俄罗斯天然气输往中国的“西伯利亚力量2号管道显然还是没能列入普京此次北京之行的成果清单。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260520-%E4%B8%AD%E4%BF%84%E7%BB%A7%E7%BB%AD%E8%82%AF%E5%AE%9A%E5%8F%8C%E8%BE%B9%E5%8F%8B%E8%B0%8A%E4%BD%86%E8%A5%BF%E4%BC%AF%E5%88%A9%E4%BA%9A%E5%8A%9B%E9%87%8F2%E5%8F%B7%E8%BE%93%E6%B0%94%E7%AE%A1%E9%81%93%E4%BB%8D%E6%9C%AA%E6%9C%89%E5%AE%9E%E8%B4%A8%E8%BF%9B%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779289526000.webp","sourceId":"rfi"},{"id":1779288778000,"createdDate":"2026-05-20 14:52","name":"法国国际广播电台","title":"特朗普称将与赖清德通话","content":"路透社消息称，美国总统特朗普周三（5月20日）表示，他将与台湾总统赖清德进行通话。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260520-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B0%86%E4%B8%8E%E8%B5%96%E6%B8%85%E5%BE%B7%E9%80%9A%E8%AF%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779288778000.webp","sourceId":"rfi"},{"id":1779288165000,"createdDate":"2026-05-20 14:42","name":"法国国际广播电台","title":"中美将就同等规模产品对等降税框架安排展开讨论","content":"美国总统特朗普结束对北京的访问四天之后，中国商务部20日以问答形式，介绍中美会谈就经贸议题达成的初步成果。从这份问答内容来看，中美双方尤其是就关税问题的后续磋商达成了原则共识，更具体的成果似乎主要是关于解除对美国牛肉进口企业注册的限制和中国将购买200架波音飞机。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260520-%E4%B8%AD%E7%BE%8E%E5%B0%86%E5%B0%B1%E5%90%8C%E7%AD%89%E8%A7%84%E6%A8%A1%E4%BA%A7%E5%93%81%E5%AF%B9%E7%AD%89%E9%99%8D%E7%A8%8E%E6%A1%86%E6%9E%B6%E5%AE%89%E6%8E%92%E5%B1%95%E5%BC%80%E8%AE%A8%E8%AE%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779288165000.webp","sourceId":"rfi"},{"id":1779287923000,"createdDate":"2026-05-20 14:38","name":"法国国际广播电台","title":"特朗普访华后仍无迹象表明英伟达能够进入中国市场，阿里巴巴值此之际发布新款人工智能芯片","content":"中国电商巨头阿里巴巴周三（5月20日）发布了一款新的人工智能芯片，并表示性能较上一代产品提升了三倍。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260520-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E5%90%8E%E4%BB%8D%E6%97%A0%E8%BF%B9%E8%B1%A1%E8%A1%A8%E6%98%8E%E8%8B%B1%E4%BC%9F%E8%BE%BE%E8%83%BD%E5%A4%9F%E8%BF%9B%E5%85%A5%E4%B8%AD%E5%9B%BD%E5%B8%82%E5%9C%BA%EF%BC%8C%E9%98%BF%E9%87%8C%E5%B7%B4%E5%B7%B4%E5%8D%B4%E5%8F%91%E5%B8%83%E6%96%B0%E6%AC%BE%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E8%8A%AF%E7%89%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779287923000.webp","sourceId":"rfi"},{"id":1779277644000,"createdDate":"2026-05-20 11:47","name":"法国国际广播电台","title":"加拿大一名议员以“声援台湾”为由访台并与赖清德会面","content":"法新社消息称，加拿大保守党议员迈克尔·庄（MichaelChong）本周访问台湾，北京方面已对此表示不满。他周三（5月20日）对法新社表示，此行是为了表达对台湾的声援。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260520-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E4%B8%80%E5%90%8D%E8%AE%AE%E5%91%98%E4%BB%A5-%E5%A3%B0%E6%8F%B4%E5%8F%B0%E6%B9%BE-%E4%B8%BA%E7%94%B1%E8%AE%BF%E5%8F%B0%E5%B9%B6%E4%B8%8E%E8%B5%96%E6%B8%85%E5%BE%B7%E4%BC%9A%E9%9D%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779277644000.webp","sourceId":"rfi"},{"id":1779277174000,"createdDate":"2026-05-20 11:39","name":"法国国际广播电台","title":"在快节奏的戛纳，滨口龙介用三小时新片《突如其来》讲“慢下来”","content":"法国戛纳电影节向来以高强度节奏著称。电影放映之间，人们匆忙穿梭；红毯活动按秒推进；连观众起立鼓掌的时间，也会被媒体记录和比较。在这样一个强调效率与曝光度的场合，一部节奏缓慢、时长三小时的电影，却成为本届电影节最受关注的作品之一。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%96%87%E5%8C%96%E8%89%BA%E6%9C%AF/20260520-%E5%9C%A8%E5%BF%AB%E8%8A%82%E5%A5%8F%E7%9A%84%E6%88%9B%E7%BA%B3%EF%BC%8C%E6%BB%A8%E5%8F%A3%E9%BE%99%E4%BB%8B%E7%94%A8%E4%B8%89%E5%B0%8F%E6%97%B6%E6%96%B0%E7%89%87-%E7%AA%81%E5%A6%82%E5%85%B6%E6%9D%A5-%E8%AE%B2-%E6%85%A2%E4%B8%8B%E6%9D%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779277174000.webp","sourceId":"rfi"},{"id":1779276120000,"createdDate":"2026-05-20 11:22","name":"法国国际广播电台","title":"俄舆论评普京访华：俄中仍有兄弟情，只不过如今的大哥是北京","content":"普京此次会晤习近平，并未出现外界此前关注的可能出现的重大突破。相比官方表态，俄罗斯媒体和网络舆论对普京此次访华的解读更为辛辣。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260520-%E4%BF%84%E8%88%86%E8%AE%BA%E8%AF%84%E6%99%AE%E4%BA%AC%E8%AE%BF%E5%8D%8E-%E4%BF%84%E4%B8%AD%E4%BB%8D%E6%9C%89%E5%85%84%E5%BC%9F%E6%83%85%EF%BC%8C%E5%8F%AA%E4%B8%8D%E8%BF%87%E5%A6%82%E4%BB%8A%E7%9A%84%E5%A4%A7%E5%93%A5%E6%98%AF%E5%8C%97%E4%BA%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779276120000.webp","sourceId":"rfi"},{"id":1779274359000,"createdDate":"2026-05-20 10:52","name":"法国国际广播电台","title":"解放报：人工智能领域中国为何盼与美国合作，能落实吗？","content":"大家好，欢迎收听法国报纸摘要。今天5月20日《费加罗报》与《解放报》头版话题关注法国持续增长的移民潮和越来越多的15至29岁年轻人处于无业状态等问题。普京昨晚抵达北京后，今早与习近平会晤，中俄元首在会上重申两国关系“坚定不移”则成为《十字架报》国际版报道重点。此外，《解放报》经济版还指出，在人工智能领域，中国外交部周二向华盛顿伸出了橄榄枝。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260520-%E8%A7%A3%E6%94%BE%E6%8A%A5-%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E9%A2%86%E5%9F%9F%E4%B8%AD%E5%9B%BD%E4%B8%BA%E4%BD%95%E7%9B%BC%E4%B8%8E%E7%BE%8E%E5%9B%BD%E5%90%88%E4%BD%9C%EF%BC%8C%E8%83%BD%E8%90%BD%E5%AE%9E%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779274359000.webp","sourceId":"rfi"},{"id":1779272149000,"createdDate":"2026-05-20 10:15","name":"法国国际广播电台","title":"赖清德在特朗普的「不乐见走向独立」发言后澄清没有台独问题 究竟「台湾独立」是什么？","content":"特朗普在特习会后表示，不想有人因为美国支持他们，而说要独立，并强调维持现状。赖清德总统则以五大声明重新定调台独与「不存在台独问题」回应。然而，美国在特习会后真的改变了对台政策吗？台湾独立究竟是否已成立，在法理上可行吗？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260520-%E8%B5%96%E6%B8%85%E5%BE%B7%E5%9C%A8%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84-%E4%B8%8D%E4%B9%90%E8%A7%81%E8%B5%B0%E5%90%91%E7%8B%AC%E7%AB%8B-%E5%8F%91%E8%A8%80%E5%90%8E%E6%BE%84%E6%B8%85%E6%B2%A1%E6%9C%89%E5%8F%B0%E7%8B%AC%E9%97%AE%E9%A2%98-%E7%A9%B6%E7%AB%9F-%E5%8F%B0%E6%B9%BE%E7%8B%AC%E7%AB%8B-%E6%98%AF%E4%BB%80%E4%B9%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779272149000.webp","sourceId":"rfi"},{"id":1779271013000,"createdDate":"2026-05-20 09:56","name":"法国国际广播电台","title":"一艘韩国油轮在伊朗协助下通过霍尔木兹海峡","content":"韩国政府周三（5月20日）表示，一艘韩国油轮当天已通过霍尔木兹海峡，此次通行是在伊朗方面协助下完成的。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260520-%E4%B8%80%E8%89%98%E9%9F%A9%E5%9B%BD%E6%B2%B9%E8%BD%AE%E5%9C%A8%E4%BC%8A%E6%9C%97%E5%8D%8F%E5%8A%A9%E4%B8%8B%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779271013000.webp","sourceId":"rfi"},{"id":1779270796000,"createdDate":"2026-05-20 09:53","name":"法国国际广播电台","title":"俄罗斯称在大规模演习中测试核导弹","content":"俄罗斯周三（5月20日）公布了一段视频，画面显示士兵正在将核弹头装载到“伊斯坎德尔-M”机动导弹发射系统中。俄方称，这是一次大规模核威慑演习的一部分。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260520-%E4%BF%84%E7%BD%97%E6%96%AF%E7%A7%B0%E5%9C%A8%E5%A4%A7%E8%A7%84%E6%A8%A1%E6%BC%94%E4%B9%A0%E4%B8%AD%E6%B5%8B%E8%AF%95%E6%A0%B8%E5%AF%BC%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779270796000.webp","sourceId":"rfi"},{"id":1779318423000,"createdDate":"2026-05-20 23:07","name":"法国国际广播电台","title":"中国女导演邹静凭借《无名女孩》再次摘得影评人周单元的奖项","content":"和戛纳影节主竞赛等单元平行的影评人周（SemainedelaCritique）周三傍晚宣布了2026年的获奖名单，中国女导演邹静凭借执导的影片《无名女孩》再次摘得这一单元的一个奖项。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260520-%E4%B8%AD%E5%9B%BD%E5%A5%B3%E5%AF%BC%E6%BC%94%E9%82%B9%E9%9D%99%E5%87%AD%E5%80%9F-%E6%97%A0%E5%90%8D%E5%A5%B3%E5%AD%A9-%E5%86%8D%E6%AC%A1%E6%91%98%E5%BE%97%E5%BD%B1%E8%AF%84%E4%BA%BA%E5%91%A8%E5%8D%95%E5%85%83%E7%9A%84%E5%A5%96%E9%A1%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779318423000.webp","sourceId":"rfi"},{"id":1779315690000,"createdDate":"2026-05-20 22:21","name":"法国国际广播电台","title":"法新社专访：美国认为“还要在格陵兰岛留下印记”！","content":"美国驻格陵兰特使杰夫·兰德里（JeffLandry）5月20日告诉法新社，美国必须加强在格陵兰这个丹麦自治领地的存在。兰德里说：“我认为美国是时候在格陵兰重新树立自己的形象了。我认为总统一直在谈论加强国家安全行动，并将人员重新部署到格陵兰的某些基地”。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260520-%E6%B3%95%E6%96%B0%E7%A4%BE%E4%B8%93%E8%AE%BF-%E7%BE%8E%E5%9B%BD%E8%AE%A4%E4%B8%BA-%E8%BF%98%E8%A6%81%E5%9C%A8%E6%A0%BC%E9%99%B5%E5%85%B0%E5%B2%9B%E7%95%99%E4%B8%8B%E5%8D%B0%E8%AE%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779315690000.webp","sourceId":"rfi"},{"id":1779314998000,"createdDate":"2026-05-20 22:09","name":"法国国际广播电台","title":"联合国投票通过一项决议   加强损害赔偿责任制","content":"联合国大会5月20日通过一项决议，加强各国的气候义务。尽管主要温室气体排放国已做出让步，但环保人士仍认为该决议至关重要。瓦努阿图常驻联合国代表奥多·特维在投票前指出：“我们知道，有些人希望大会少说点什么，或者干脆什么都不说。”","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260520-%E8%81%94%E5%90%88%E5%9B%BD%E6%8A%95%E7%A5%A8%E9%80%9A%E8%BF%87%E4%B8%80%E9%A1%B9%E5%86%B3%E8%AE%AE-%E5%8A%A0%E5%BC%BA%E6%8D%9F%E5%AE%B3%E8%B5%94%E5%81%BF%E8%B4%A3%E4%BB%BB%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779314998000.webp","sourceId":"rfi"},{"id":1779313566000,"createdDate":"2026-05-20 21:46","name":"法国国际广播电台","title":"美伊谈判进最后阶段　特朗普称内塔尼亚胡“会照我意思做”","content":"美国总统特朗普（DonaldTrump）周三表示，美国与伊朗核问题谈判已进入“最后阶段”，但若伊朗拒绝达成协议，美方不排除再度对伊朗采取军事行动，甚至可能发动更大规模攻击。他并强调，美国“不会让伊朗拥有核武器”。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260520-%E7%BE%8E%E4%BC%8A%E8%B0%88%E5%88%A4%E8%BF%9B%E6%9C%80%E5%90%8E%E9%98%B6%E6%AE%B5-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E5%86%85%E5%A1%94%E5%B0%BC%E4%BA%9A%E8%83%A1-%E4%BC%9A%E7%85%A7%E6%88%91%E6%84%8F%E6%80%9D%E5%81%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779313566000.webp","sourceId":"rfi"},{"id":1779312933000,"createdDate":"2026-05-20 21:35","name":"法国国际广播电台","title":"《南德意志报》：特朗普和普京的错误正成为习近平的机会","content":"德国媒体对北京普习会表示了密切关注《商报》认为：中国正在将自己塑造成新世界秩序的权力中心——一个无论是华盛顿、莫斯科还是许多其他国家都要前来拜访的国家。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260520-%E5%8D%97%E5%BE%B7%E6%84%8F%E5%BF%97%E6%8A%A5-%E7%89%B9%E6%9C%97%E6%99%AE%E5%92%8C%E6%99%AE%E4%BA%AC%E7%9A%84%E9%94%99%E8%AF%AF%E6%AD%A3%E6%88%90%E4%B8%BA%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%9A%84%E6%9C%BA%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779312933000.webp","sourceId":"rfi"},{"id":1779310093000,"createdDate":"2026-05-20 20:48","name":"法国国际广播电台","title":"一家英地方电台错误宣布英国君主查理三世的死讯","content":"一家英国地方电台于5月20日星期三向英国国王查理三世及其听众致歉。几天前，这家位于英格兰东南部埃塞克斯郡的电台错误地宣布了国王的死讯。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260520-%E4%B8%80%E5%AE%B6%E8%8B%B1%E5%9C%B0%E6%96%B9%E7%94%B5%E5%8F%B0%E9%94%99%E8%AF%AF%E5%AE%A3%E5%B8%83%E8%8B%B1%E5%9B%BD%E5%90%9B%E4%B8%BB%E6%9F%A5%E7%90%86%E4%B8%89%E4%B8%96%E7%9A%84%E6%AD%BB%E8%AE%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779310093000.webp","sourceId":"rfi"},{"id":1779309960000,"createdDate":"2026-05-20 20:46","name":"法国国际广播电台","title":"一对有德国籍的夫妇被抓    被控为中国搜集先进军事技术信息","content":"德国检察官周三宣布逮捕了一对拥有德国国籍的夫妇，他们被控为中国搜集先进军事技术信息。联邦检察官办公室在慕尼黑逮捕和搜查行动后表示：“薛军（音译）和华（音译）为中国情报机构工作”。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260520-%E4%B8%80%E5%AF%B9%E6%9C%89%E5%BE%B7%E5%9B%BD%E7%B1%8D%E7%9A%84%E5%A4%AB%E5%A6%87%E8%A2%AB%E6%8A%93-%E8%A2%AB%E6%8E%A7%E4%B8%BA%E4%B8%AD%E5%9B%BD%E6%90%9C%E9%9B%86%E5%85%88%E8%BF%9B%E5%86%9B%E4%BA%8B%E6%8A%80%E6%9C%AF%E4%BF%A1%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779309960000.webp","sourceId":"rfi"},{"id":1779309814000,"createdDate":"2026-05-20 20:43","name":"法国国际广播电台","title":"欧洲多国谴责以对驶往加沙船队声援者的粗暴方式","content":"就以色列国家安全部长本-格维尔针对“全球坚韧船队”被扣押者的言行，法国、西班牙、比利时、荷兰召见以大使以示抗议。这段名为“欢迎来到以色列”的视频显示，数十名活动人士跪在一艘军舰的甲板上，双手被绑，额头贴地，伴随着以色列国歌的旋律。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260520-%E6%AC%A7%E6%B4%B2%E5%A4%9A%E5%9B%BD%E8%B0%B4%E8%B4%A3%E4%BB%A5%E5%AF%B9%E9%A9%B6%E5%BE%80%E5%8A%A0%E6%B2%99%E8%88%B9%E9%98%9F%E5%A3%B0%E6%8F%B4%E8%80%85%E7%9A%84%E7%B2%97%E6%9A%B4%E6%96%B9%E5%BC%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779309814000.webp","sourceId":"rfi"},{"id":1779309423000,"createdDate":"2026-05-20 20:37","name":"法国国际广播电台","title":"游完5000公里    促请关注亚马逊河塑料污染","content":"一位哥伦比亚环保人士被昵称为“鱼人”，但他身上没有鱼鳞，只有一套氯丁橡胶潜水服。45岁的威尔伯·奥诺里奥·穆尼奥斯（WilberHonorioMuñoz）正在亚马逊河上游泳，旨在提高人们对这条塑料污染严重河流的意识。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260520-%E6%B8%B8%E5%AE%8C5000%E5%85%AC%E9%87%8C-%E4%BF%83%E8%AF%B7%E5%85%B3%E6%B3%A8%E4%BA%9A%E9%A9%AC%E9%80%8A%E6%B2%B3%E5%A1%91%E6%96%99%E6%B1%A1%E6%9F%93","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779309423000.webp","sourceId":"rfi"},{"id":1779308733000,"createdDate":"2026-05-20 20:25","name":"法国国际广播电台","title":"嘎纳棕榈滩酒店(Hotel Palm Beach)一块价值70万欧元手表被盗","content":"据法新社周三从警方消息人士处获悉，一块价值在70万至100万欧元之间的理查米尔（RichardMille）名表在棕榈滩酒店(HotelPalmBeach)被盗。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260520-%E5%98%8E%E7%BA%B3%E6%A3%95%E6%A6%88%E6%BB%A9%E9%85%92%E5%BA%97-hotel-palm-beach-%E4%B8%80%E5%9D%97%E4%BB%B7%E5%80%BC70%E4%B8%87%E6%AC%A7%E5%85%83%E6%89%8B%E8%A1%A8%E8%A2%AB%E7%9B%97","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779308733000.webp","sourceId":"rfi"},{"id":1779308544000,"createdDate":"2026-05-20 20:22","name":"法国国际广播电台","title":"特朗普：并不急于与伊朗达成协议；伊朗：美国“试图发动另一场战争”","content":"伊朗外交部发言人伊斯梅尔·巴盖伊表示，在巴基斯坦调解员周三访问伊朗后，伊朗正在“研究”美国提出的新方案。美国总统特朗普表示，他并不急于与伊朗达成协议，但谈判已进入“最后阶段”。美特朗普周三表示：“要么我们达成协议，要么采取更强硬的措施。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260520-%E7%89%B9%E6%9C%97%E6%99%AE-%E5%B9%B6%E4%B8%8D%E6%80%A5%E4%BA%8E%E4%B8%8E%E4%BC%8A%E6%9C%97%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE-%E4%BC%8A%E6%9C%97-%E7%BE%8E%E5%9B%BD-%E8%AF%95%E5%9B%BE%E5%8F%91%E5%8A%A8%E5%8F%A6%E4%B8%80%E5%9C%BA%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779308544000.webp","sourceId":"rfi"},{"id":1779302097000,"createdDate":"2026-05-20 18:34","name":"法国国际广播电台","title":"特朗普：起诉劳尔·卡斯特罗   “非常棒的一天”","content":"劳尔·卡斯特罗周三被美国司法部起诉，该案可追溯至1996年。美国总统特朗普20日在结束对康涅狄格州（东北部）的访问返回后告诉记者：司法部对古巴前总统劳尔·卡斯特罗的起诉是“非常棒的一天”。他还表示，没有必要让古巴的局势升级，因为这个地方正在分崩离析。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260520-%E7%BE%8E%E5%9B%BD%E8%B5%B7%E8%AF%89%E5%8A%B3%E5%B0%94%C2%B7%E5%8D%A1%E6%96%AF%E7%89%B9%E7%BD%97-%E6%9E%81%E9%99%90%E5%8E%8B%E5%8A%9B%E5%86%8D%E5%8D%87%E4%B8%80%E7%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779302097000.webp","sourceId":"rfi"},{"id":1779301491000,"createdDate":"2026-05-20 18:24","name":"法国国际广播电台","title":"为何普京访华的重要性对于莫斯科来说比对北京更重要？法媒点出一种“极度不对称”关系","content":"中国主席习近平在接待美国总统唐纳德·特朗普三天后，习近平继续接待欢迎俄罗斯总统普京访问北京，以加强中俄两国之间的“战略合作”。为什么普京访华的重要性对于莫斯科来说比对北京更重要？法媒提问之际，也点出因他们之间的一种“极度不对称”关系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260520-%E4%B8%BA%E4%BD%95%E6%99%AE%E4%BA%AC%E8%AE%BF%E5%8D%8E%E7%9A%84%E9%87%8D%E8%A6%81%E6%80%A7%E5%AF%B9%E4%BA%8E%E8%8E%AB%E6%96%AF%E7%A7%91%E6%9D%A5%E8%AF%B4%E6%AF%94%E5%AF%B9%E5%8C%97%E4%BA%AC%E6%9B%B4%E9%87%8D%E8%A6%81-%E6%B3%95%E5%AA%92%E7%82%B9%E5%87%BA%E4%B8%80%E7%A7%8D-%E6%9E%81%E5%BA%A6%E4%B8%8D%E5%AF%B9%E7%A7%B0-%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779301491000.webp","sourceId":"rfi"}]