[{"id":1779270282000,"createdDate":"2026-05-20 09:44","name":"法国国际广播电台","title":"因涉嫌非法操控价格，美国起诉七名中国企业高管及多家集装箱制造巨头","content":"美国周二（5月19日）宣布，已起诉七名中国企业高管以及全球四大集装箱制造商，这些企业被怀疑合谋限制集装箱产量并操纵价格。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260520-%E5%9B%A0%E6%B6%89%E5%AB%8C%E9%9D%9E%E6%B3%95%E6%93%8D%E6%8E%A7%E4%BB%B7%E6%A0%BC%EF%BC%8C%E7%BE%8E%E5%9B%BD%E8%B5%B7%E8%AF%89%E4%B8%83%E5%90%8D%E4%B8%AD%E5%9B%BD%E4%BC%81%E4%B8%9A%E9%AB%98%E7%AE%A1%E5%8F%8A%E5%A4%9A%E5%AE%B6%E9%9B%86%E8%A3%85%E7%AE%B1%E5%88%B6%E9%80%A0%E5%B7%A8%E5%A4%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779270282000.webp","sourceId":"rfi"},{"id":1779268562000,"createdDate":"2026-05-20 09:16","name":"法国国际广播电台","title":"在特朗普的压力下，欧盟各国终于就关税问题达成协议","content":"在美国总统特朗普的压力下，欧盟周三（5月20日）终于就去年与美国达成的贸易协议取得一项临时妥协方案。这一妥协方案由轮值欧盟主席国塞浦路斯政府于周三凌晨宣布。此前，欧洲议会代表与欧盟成员国代表在法国斯特拉斯堡进行了一整夜紧张的谈判。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260520-%E5%9C%A8%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84%E5%8E%8B%E5%8A%9B%E4%B8%8B%EF%BC%8C%E6%AC%A7%E7%9B%9F%E5%90%84%E5%9B%BD%E7%BB%88%E4%BA%8E%E5%B0%B1%E5%85%B3%E7%A8%8E%E9%97%AE%E9%A2%98%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779268562000.webp","sourceId":"rfi"},{"id":1779268040000,"createdDate":"2026-05-20 09:07","name":"法国国际广播电台","title":"西班牙名导作品《苦涩的圣诞节》亮相戛纳 其法文名《自传体小说》更为直白","content":"戛纳影节第七天，主竞赛单元放映的影片之一是本届影节的热门影片《苦涩的圣诞节》，由西班牙著名导演阿尔多莫瓦执导。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260520-%E8%A5%BF%E7%8F%AD%E7%89%99%E5%90%8D%E5%AF%BC%E4%BD%9C%E5%93%81-%E8%8B%A6%E6%B6%A9%E7%9A%84%E5%9C%A3%E8%AF%9E%E8%8A%82-%E4%BA%AE%E7%9B%B8%E6%88%9B%E7%BA%B3-%E5%85%B6%E6%B3%95%E6%96%87%E5%90%8D-%E8%87%AA%E4%BC%A0%E4%BD%93%E5%B0%8F%E8%AF%B4-%E6%9B%B4%E4%B8%BA%E7%9B%B4%E7%99%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779268040000.webp","sourceId":"rfi"},{"id":1779267904000,"createdDate":"2026-05-20 09:05","name":"法国国际广播电台","title":"中国中南地区多地暴雨洪灾，死亡人数升至22人，20人失踪","content":"据中国官方媒体周三（5月20日）报道，近日中国中南地区多地遭遇强降雨，引发灾情，已导致22人死亡，20人失踪。气象部门预测，未来几天，中国多地仍将有持续大范围降雨。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260520-%E4%B8%AD%E5%9B%BD%E4%B8%AD%E5%8D%97%E5%9C%B0%E5%8C%BA%E5%A4%9A%E5%9C%B0%E6%9A%B4%E9%9B%A8%E6%B4%AA%E7%81%BE%EF%BC%8C%E6%AD%BB%E4%BA%A1%E4%BA%BA%E6%95%B0%E5%8D%87%E8%87%B322%E4%BA%BA%EF%BC%8C20%E4%BA%BA%E5%A4%B1%E8%B8%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779267904000.webp","sourceId":"rfi"},{"id":1779267780000,"createdDate":"2026-05-20 09:03","name":"法国国际广播电台","title":"中国正式确认采购200架波音飞机，并要求延长与美国的贸易休战","content":"中国周三（5月20日）宣布，有意购买200架波音客机，并寻求延长与美国达成的贸易休战协议，该协议将于今年11月到期。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260520-%E4%B8%AD%E5%9B%BD%E6%AD%A3%E5%BC%8F%E7%A1%AE%E8%AE%A4%E9%87%87%E8%B4%AD200%E6%9E%B6%E6%B3%A2%E9%9F%B3%E9%A3%9E%E6%9C%BA%EF%BC%8C%E5%B9%B6%E8%A6%81%E6%B1%82%E5%BB%B6%E9%95%BF%E4%B8%8E%E7%BE%8E%E5%9B%BD%E7%9A%84%E8%B4%B8%E6%98%93%E4%BC%91%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779267780000.webp","sourceId":"rfi"},{"id":1779267289000,"createdDate":"2026-05-20 08:54","name":"法国国际广播电台","title":"习近平与普京称中俄关系牢不可破，普京已邀请习近平明年访俄","content":"中国国家主席习近平与俄罗斯总统普京周三（5月20日）表示，尽管国际局势动荡，两国关系依然牢固。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260520-%E4%B9%A0%E8%BF%91%E5%B9%B3%E4%B8%8E%E6%99%AE%E4%BA%AC%E7%A7%B0%E4%B8%AD%E4%BF%84%E5%85%B3%E7%B3%BB%E7%89%A2%E4%B8%8D%E5%8F%AF%E7%A0%B4%EF%BC%8C%E6%99%AE%E4%BA%AC%E5%B7%B2%E9%82%80%E8%AF%B7%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%98%8E%E5%B9%B4%E8%AE%BF%E4%BF%84","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779267289000.webp","sourceId":"rfi"},{"id":1779261211000,"createdDate":"2026-05-20 07:13","name":"法国国际广播电台","title":"赖清德总统520执政两周年谈话 两岸论述成焦点拒绝以「和平包装统一」","content":"赖清德总统发表520就职两周年谈话，表示维持台海和平稳定是国家战略目标。愿意在对等原则下与中国交流，但坚定拒绝「以和平包装统一」的统战作为。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260520-%E8%B5%96%E6%B8%85%E5%BE%B7%E6%80%BB%E7%BB%9F520%E6%89%A7%E6%94%BF%E4%B8%A4%E5%91%A8%E5%B9%B4%E8%B0%88%E8%AF%9D-%E4%B8%A4%E5%B2%B8%E8%AE%BA%E8%BF%B0%E6%88%90%E7%84%A6%E7%82%B9%E6%8B%92%E7%BB%9D%E4%BB%A5-%E5%92%8C%E5%B9%B3%E5%8C%85%E8%A3%85%E7%BB%9F%E4%B8%80","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779261211000.webp","sourceId":"rfi"},{"id":1779260888000,"createdDate":"2026-05-20 07:08","name":"法国国际广播电台","title":"两名日本人在上海凶杀事件中受伤  日本官房长官要求查明真相","content":"当地时间19日下午，中国上海市一家日本料理店发生一名男子闯入行凶事件，造成3人受伤，其中2人为日本人。日本内阁官房长官木原稔在20日的记者会上表示，日方已向中方提出查明真相以及确保日本人安全等要求。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260520-%E4%B8%A4%E5%90%8D%E6%97%A5%E6%9C%AC%E4%BA%BA%E5%9C%A8%E4%B8%8A%E6%B5%B7%E5%87%B6%E6%9D%80%E4%BA%8B%E4%BB%B6%E4%B8%AD%E5%8F%97%E4%BC%A4-%E6%97%A5%E6%9C%AC%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E8%A6%81%E6%B1%82%E6%9F%A5%E6%98%8E%E7%9C%9F%E7%9B%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779260888000.webp","sourceId":"rfi"},{"id":1779260574000,"createdDate":"2026-05-20 07:02","name":"法国国际广播电台","title":"港府再拨50亿作国安开支 黑箱中六年共耗180亿元","content":"港府再次在无预告下，以专门拨款方式，从库房调拨50亿港元(下同，折算约5.5亿欧元)公帑作维护国家安全开支，并继续拒绝交代细节。此次已是港府在六年内，第三次增拨国安资源，累计拨款合共180亿。评论认为，港府为国安作巨额拨款，与北京及港府对外宣称香港已「由治及兴」的说法，有自相矛盾之嫌；更有人质疑拨款是否与跨境镇压有关。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260520-%E6%B8%AF%E5%BA%9C%E5%86%8D%E6%8B%A850%E4%BA%BF%E4%BD%9C%E5%9B%BD%E5%AE%89%E5%BC%80%E6%94%AF-%E9%BB%91%E7%AE%B1%E4%B8%AD%E5%85%AD%E5%B9%B4%E5%85%B1%E8%80%97180%E4%BA%BF%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779260574000.webp","sourceId":"rfi"},{"id":1779247729000,"createdDate":"2026-05-20 03:28","name":"法国国际广播电台","title":"降低对中国的依赖 七国集团财长准备合作生产提炼“稀土”","content":"为了降低对中国的稀土依赖程度，七国集团财长会议协商准备合作生产和提炼“稀土”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260520-%E9%99%8D%E4%BD%8E%E5%AF%B9%E4%B8%AD%E5%9B%BD%E4%BE%9D%E8%B5%96-%E4%B8%83%E5%9B%BD%E9%9B%86%E5%9B%A2%E8%B4%A2%E9%95%BF%E5%87%86%E5%A4%87%E5%90%88%E4%BD%9C%E7%94%9F%E4%BA%A7%E6%8F%90%E7%82%BC-%E7%A8%80%E5%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/20/1779247729000.webp","sourceId":"rfi"}]