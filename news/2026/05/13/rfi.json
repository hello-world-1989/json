[{"id":1778663909000,"createdDate":"2026-05-13 09:18","name":"法国国际广播电台","title":"黄仁勋在阿拉斯加登上专机随行访华 特朗普透露将向习近平提出的首个请求","content":"美国总统特朗普（DonaldTrump）周三在前往北京参加美中峰会途中表示，他将敦促中国国家主席习近平向美国企业“开放”市场。特朗普的专机途中在阿拉斯加停留时，英伟达首席执行官黄仁勋加入了随行美企高管队伍。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260513-%E9%BB%84%E4%BB%81%E5%8B%8B%E5%9C%A8%E9%98%BF%E6%8B%89%E6%96%AF%E5%8A%A0%E7%99%BB%E4%B8%8A%E4%B8%93%E6%9C%BA%E9%9A%8F%E8%A1%8C%E8%AE%BF%E5%8D%8E-%E7%89%B9%E6%9C%97%E6%99%AE%E9%80%8F%E9%9C%B2%E5%B0%86%E5%90%91%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%8F%90%E5%87%BA%E7%9A%84%E9%A6%96%E4%B8%AA%E8%AF%B7%E6%B1%82","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778663909000.webp","sourceId":"rfi"},{"id":1778660963000,"createdDate":"2026-05-13 08:29","name":"法国国际广播电台","title":"特朗普称伊朗问题不需要中方帮助 德黑兰扩大其对霍尔木兹海峡的定义范围","content":"美国总统特朗普（DonaldTrump）周二表示，自己不需要中国的帮助就能结束与伊朗的战争。与此同时，美伊双方达成持久和平协议的希望日益渺茫，德黑兰当局也加强了其对霍尔木兹海峡的要求。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260513-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E4%BC%8A%E6%9C%97%E9%97%AE%E9%A2%98%E4%B8%8D%E9%9C%80%E8%A6%81%E4%B8%AD%E6%96%B9%E5%B8%AE%E5%8A%A9-%E5%BE%B7%E9%BB%91%E5%85%B0%E6%89%A9%E5%A4%A7%E5%85%B6%E5%AF%B9%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%9A%84%E5%AE%9A%E4%B9%89%E8%8C%83%E5%9B%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778660963000.webp","sourceId":"rfi"},{"id":1778655814000,"createdDate":"2026-05-13 07:03","name":"法国国际广播电台","title":"日本防卫大臣：出席有关霍尔木兹海峡防长会议不意味日本将派兵","content":"为确保霍尔木兹海峡航行安全，由英国和法国主办的各国国防部长会议于日本时间13日在线举行，40多个国家出席。日本方面由防卫大臣小泉进次郎出席。小泉大臣强调，要派遣多国籍部队参加军事任务，“需要美国与伊朗达成停火协议，以及与伊朗进行沟通协调”。小泉大臣还表示：自己出席此次会议，“并不意味着预先已决定自卫队将参加军事任务”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260513-%E6%97%A5%E6%9C%AC%E9%98%B2%E5%8D%AB%E5%A4%A7%E8%87%A3-%E5%87%BA%E5%B8%AD%E6%9C%89%E5%85%B3%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%98%B2%E9%95%BF%E4%BC%9A%E8%AE%AE%E4%B8%8D%E6%84%8F%E5%91%B3%E6%97%A5%E6%9C%AC%E5%B0%86%E6%B4%BE%E5%85%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778655814000.webp","sourceId":"rfi"},{"id":1778655569000,"createdDate":"2026-05-13 06:59","name":"法国国际广播电台","title":"特朗普预告习近平年底访美 遭中方制裁卢比奥首度访华成焦点","content":"美国总统特朗普今(13日)天率团访问中国，他在出发前预告，中国国家主席习近平将于年底访美。另外，被中国制裁的美国国务卿卢比奥（MarcoRubio）随特朗普访华亦成为讨论焦点。中国方面，其驻美大使谢锋在特朗普抵埗前重申中方立场，强调中方在伊朗战争中的角色，望两国元首会面能为中美关系校正航向，引领两国关系实现总体稳定。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260513-%E7%89%B9%E6%9C%97%E6%99%AE%E9%A2%84%E5%91%8A%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%B9%B4%E5%BA%95%E8%AE%BF%E7%BE%8E-%E9%81%AD%E4%B8%AD%E6%96%B9%E5%88%B6%E8%A3%81%E5%8D%A2%E6%AF%94%E5%A5%A5%E9%A6%96%E5%BA%A6%E8%AE%BF%E5%8D%8E%E6%88%90%E7%84%A6%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778655569000.webp","sourceId":"rfi"},{"id":1778692690000,"createdDate":"2026-05-13 17:18","name":"法国国际广播电台","title":"中国外交官称对欧洲拟限制中国投资“非常失望”，并警告这会促使中国对“对欧洲关上大门”","content":"中国驻西班牙大使馆商务代表屈浔周三（5月13日）在马德里一场会议上表示，北京方面对欧洲计划限制中国投资“非常失望”，并警告称，此类措施将促使中国“对欧洲关上大门”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260513-%E4%B8%AD%E5%9B%BD%E5%A4%96%E4%BA%A4%E5%AE%98%E7%A7%B0%E5%AF%B9%E6%AC%A7%E6%B4%B2%E6%8B%9F%E9%99%90%E5%88%B6%E4%B8%AD%E5%9B%BD%E6%8A%95%E8%B5%84-%E9%9D%9E%E5%B8%B8%E5%A4%B1%E6%9C%9B-%EF%BC%8C%E5%B9%B6%E8%AD%A6%E5%91%8A%E8%BF%99%E4%BC%9A%E4%BF%83%E4%BD%BF%E4%B8%AD%E5%9B%BD%E5%AF%B9-%E5%AF%B9%E6%AC%A7%E6%B4%B2%E5%85%B3%E4%B8%8A%E5%A4%A7%E9%97%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778692690000.webp","sourceId":"rfi"},{"id":1778688566000,"createdDate":"2026-05-13 16:09","name":"法国国际广播电台","title":"荷兰已向美方表达反对进一步限制阿斯麦在华运营相关法案","content":"荷兰政府已表达反对美国国会的一项拟议法案，该法案将进一步限制半导体设备巨头阿斯麦（ASML）向中国销售产品并为中国客户提供服务。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260513-%E8%8D%B7%E5%85%B0%E5%B7%B2%E5%90%91%E7%BE%8E%E6%96%B9%E8%A1%A8%E8%BE%BE%E5%8F%8D%E5%AF%B9%E8%BF%9B%E4%B8%80%E6%AD%A5%E9%99%90%E5%88%B6%E9%98%BF%E6%96%AF%E9%BA%A6%E5%9C%A8%E5%8D%8E%E8%BF%90%E8%90%A5%E7%9B%B8%E5%85%B3%E6%B3%95%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778688566000.webp","sourceId":"rfi"},{"id":1778684144000,"createdDate":"2026-05-13 14:55","name":"法国国际广播电台","title":"特习会前 一艘中国超级油轮驶出霍尔木兹海峡 未缴通行费","content":"伊朗和美国双重封锁导致霍尔木兹海峡局势升级后，首艘中国超级油轮成功驶出海峡。当地时间周三上午，中国籍31万吨级超大型油轮“远花湖”号成功从波斯湾驶出了霍尔木兹海峡，其通过海峡时满载从伊拉克阿巴克港装运的原油。据悉，与其一同驶出海峡的还有一艘大型汽车运输船“湘江口”号。这两艘船舶均属于中国航运央企中远海运集团。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260513-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%89%8D-%E4%B8%80%E8%89%98%E4%B8%AD%E5%9B%BD%E8%B6%85%E7%BA%A7%E6%B2%B9%E8%BD%AE%E9%A9%B6%E5%87%BA%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E6%9C%AA%E7%BC%B4%E9%80%9A%E8%A1%8C%E8%B4%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778684144000.webp","sourceId":"rfi"},{"id":1778681065000,"createdDate":"2026-05-13 14:04","name":"法国国际广播电台","title":"泽连斯基：望特朗普访华期间提及结束俄对乌战争问题","content":"乌克兰总统泽连斯基（VolodymyrZelenskyy）周三敦促美国总统特朗普（DonaldTrump）在本周与中国国家主席习近平的会晤中讨论结束俄罗斯对乌克兰的入侵。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260513-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E6%9C%9B%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E6%9C%9F%E9%97%B4%E6%8F%90%E5%8F%8A%E7%BB%93%E6%9D%9F%E4%BF%84%E5%AF%B9%E4%B9%8C%E6%88%98%E4%BA%89%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778681065000.webp","sourceId":"rfi"},{"id":1778679105000,"createdDate":"2026-05-13 13:31","name":"法国国际广播电台","title":"不再试图改变中国经济？美贸易代表口中的“贸易委员会”现端倪","content":"据路透社报导，预计本周美中两国将就非敏感商品的贸易管理机制取得进展，双方可能各自确定价值约300亿美元的商品，以便在不触及国家安全红线的前提下降低关税并相互销售。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260513-%E4%B8%8D%E5%86%8D%E8%AF%95%E5%9B%BE%E6%94%B9%E5%8F%98%E4%B8%AD%E5%9B%BD%E7%BB%8F%E6%B5%8E-%E7%BE%8E%E8%B4%B8%E6%98%93%E4%BB%A3%E8%A1%A8%E5%8F%A3%E4%B8%AD%E7%9A%84-%E8%B4%B8%E6%98%93%E5%A7%94%E5%91%98%E4%BC%9A-%E7%8E%B0%E7%AB%AF%E5%80%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778679105000.webp","sourceId":"rfi"},{"id":1778674314000,"createdDate":"2026-05-13 12:11","name":"法国国际广播电台","title":"特习会前夕台湾为何通过减缩版国防预算","content":"特习会将在13至15日登场，会前中国就已强调台湾将会是中方关切焦点。另一方面，台湾立院赶在会前8日三读通过在野版本的国防军购预算，这是否能强化美方对台立场？台湾国内又是如何看待台湾恐成此次特习会上的核心议题之一？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260513-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%89%8D%E5%A4%95%E5%8F%B0%E6%B9%BE%E4%B8%BA%E4%BD%95%E9%80%9A%E8%BF%87%E5%87%8F%E7%BC%A9%E7%89%88%E5%9B%BD%E9%98%B2%E9%A2%84%E7%AE%97","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778674314000.webp","sourceId":"rfi"},{"id":1778673705000,"createdDate":"2026-05-13 12:01","name":"法国国际广播电台","title":"特朗普专机抵达北京 韩正等在机场迎接","content":"美国总统特朗普（DonaldTrump）及其随行代表团将入住的北京酒店安保严密。据塔斯社记者报导，沿途高速公路已部署大量警察和特警警戒。官媒新华社消息指，应国家主席习近平邀请，美国总统特朗普5月13日晚乘专机抵达北京，开始对中国进行国事访问。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260513-%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%93%E6%9C%BA%E6%8A%B5%E8%BE%BE%E5%8C%97%E4%BA%AC-%E9%9F%A9%E6%AD%A3%E7%AD%89%E5%9C%A8%E6%9C%BA%E5%9C%BA%E8%BF%8E%E6%8E%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778673705000.webp","sourceId":"rfi"},{"id":1778672495000,"createdDate":"2026-05-13 11:41","name":"法国国际广播电台","title":"沙特、阿联酋曾对伊朗发动秘密报复袭击 两国策略并不完全相同","content":"据路透社援引两名知情西方官员和两名伊朗官员报导称，沙特阿拉伯对伊朗发动了多次未公开的袭击，以报复中东战争期间伊朗在沙特境内发动的袭击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260513-%E6%B2%99%E7%89%B9-%E9%98%BF%E8%81%94%E9%85%8B%E6%9B%BE%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%8F%91%E5%8A%A8%E7%A7%98%E5%AF%86%E6%8A%A5%E5%A4%8D%E8%A2%AD%E5%87%BB-%E4%B8%A4%E5%9B%BD%E7%AD%96%E7%95%A5%E5%B9%B6%E4%B8%8D%E5%AE%8C%E5%85%A8%E7%9B%B8%E5%90%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778672495000.webp","sourceId":"rfi"},{"id":1778669332000,"createdDate":"2026-05-13 10:48","name":"法国国际广播电台","title":"法媒纷纷关注：习近平和特朗普在北京一较高下","content":"大家好，欢迎收听法国报纸摘要，今天是5月13日，全球拭目以待的美国总统特朗普将于今晚抵达北京成为《回声报》与《解放报》等各大日报关注焦点。《十字架报》台北通讯员报道侧重在台湾对于特习会的焦虑，因为今年2月，特朗普承认在与习近平的通话中讨论了美国对台军售问题”，据国际危机组织中国外交政策分析师杨伟文（WilliamYang）回溯指出，“这加剧了人们对美台关系稳固性的怀疑”。《费加罗报》则在美国总统代表团抵华前，提及中美两国代表团在韩国启动经贸磋商。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260513-%E6%B3%95%E5%AA%92%E7%BA%B7%E7%BA%B7%E5%85%B3%E6%B3%A8-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%92%8C%E7%89%B9%E6%9C%97%E6%99%AE%E5%9C%A8%E5%8C%97%E4%BA%AC%E4%B8%80%E8%BE%83%E9%AB%98%E4%B8%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778669332000.webp","sourceId":"rfi"},{"id":1778667870000,"createdDate":"2026-05-13 10:24","name":"法国国际广播电台","title":"特习会上台湾问题成中方关注焦点 特朗普是否会改口称「反对台独」？","content":"台海议题随着特朗普的北京行变得紧张，外界盛传习近平将施压特朗普从「不支持台独」的官方用词更改为「反对台独」。虽然白宫表示，美国对台政策并未改变，但拒绝评论特朗普计画如何处理台湾议题。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260513-%E7%89%B9%E4%B9%A0%E4%BC%9A%E4%B8%8A%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98%E6%88%90%E4%B8%AD%E6%96%B9%E5%85%B3%E6%B3%A8%E7%84%A6%E7%82%B9-%E7%89%B9%E6%9C%97%E6%99%AE%E6%98%AF%E5%90%A6%E4%BC%9A%E6%94%B9%E5%8F%A3%E7%A7%B0-%E5%8F%8D%E5%AF%B9%E5%8F%B0%E7%8B%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778667870000.webp","sourceId":"rfi"},{"id":1778666965000,"createdDate":"2026-05-13 10:09","name":"法国国际广播电台","title":"刘特佐向特朗普寻求特赦 大马通讯部长：下周内阁一定会谈到这个问题","content":"被美国政府指控为史上最大金融诈骗案之一主谋的马来西亚金融家刘特佐，在逃亡期间已向美国司法部申请总统赦免。刘特佐于2018年被起诉，但一直逃避逮捕。据美国司法部网站的通知显示，他已于今年向该部门提交了赦免申请。刘特佐被控策划了一项从马来西亚主权财富基金——一个马来西亚发展有限公司（1MDB）——挪用至少45亿美元的计划。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260513-%E5%88%98%E7%89%B9%E4%BD%90%E5%90%91%E7%89%B9%E6%9C%97%E6%99%AE%E5%AF%BB%E6%B1%82%E7%89%B9%E8%B5%A6-%E5%A4%A7%E9%A9%AC%E9%80%9A%E8%AE%AF%E9%83%A8%E9%95%BF-%E4%B8%8B%E5%91%A8%E5%86%85%E9%98%81%E4%B8%80%E5%AE%9A%E4%BC%9A%E8%B0%88%E5%88%B0%E8%BF%99%E4%B8%AA%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778666965000.webp","sourceId":"rfi"},{"id":1778666932000,"createdDate":"2026-05-13 10:08","name":"法国国际广播电台","title":"俄罗斯与乌克兰高度关注特朗普中国行","content":"俄乌两国各自媒体正高度关注特朗普即将开启的中国之行。在俄媒看来，这不仅是一次普通的双边访问，更可能成为影响未来全球格局的重要节点。乌克兰方面则认为，此次访问的议程涵盖当前全球政治与经济中最尖锐的问题，而对于俄乌战争本身，此次中美会谈不会进行深入讨论。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260513-%E4%BF%84%E7%BD%97%E6%96%AF%E4%B8%8E%E4%B9%8C%E5%85%8B%E5%85%B0%E9%AB%98%E5%BA%A6%E5%85%B3%E6%B3%A8%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%AD%E5%9B%BD%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778666932000.webp","sourceId":"rfi"},{"id":1778666192000,"createdDate":"2026-05-13 09:56","name":"法国国际广播电台","title":"特习会启动前，中美在韩国首尔举行贸易磋商","content":"美国总统特朗普启程前往北京之际，中国政府负责贸易事务的副总理何立峰和美国财政部长贝森特13日在韩国首都附近的仁川国际机场举行了会谈，显示贸易议题在这次中美高峰会谈中的重要性。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260513-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%90%AF%E5%8A%A8%E5%89%8D%EF%BC%8C%E4%B8%AD%E7%BE%8E%E5%9C%A8%E9%9F%A9%E5%9B%BD%E9%A6%96%E5%B0%94%E4%B8%BE%E8%A1%8C%E8%B4%B8%E6%98%93%E7%A3%8B%E5%95%86","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778666192000.webp","sourceId":"rfi"},{"id":1778665909000,"createdDate":"2026-05-13 09:51","name":"法国国际广播电台","title":"美国国务院称 : 美中两国共同反对伊朗在霍尔木兹海峡收费","content":"美国国务院表示美中两国高级官员一致认为，任何国家都不能被允许在霍尔木兹海峡征收航运通行费，这表明美中两国寻求共同立场并试图在向伊朗施压，迫使其放弃对这条全球重要水道的控制权。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260513-%E7%BE%8E%E5%9B%BD%E5%9B%BD%E5%8A%A1%E9%99%A2%E7%A7%B0-%E7%BE%8E%E4%B8%AD%E4%B8%A4%E5%9B%BD%E5%85%B1%E5%90%8C%E5%8F%8D%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%94%B6%E8%B4%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/13/1778665909000.webp","sourceId":"rfi"}]