[{"id":1778748637000,"createdDate":"2026-05-14 08:50","name":"法国国际广播电台","title":"中方安保拒绝美特勤局特工携武器进入天坛 白宫记者团被延误近30分钟","content":"据白宫随行记者报导，由于中国安全官员拒绝一名陪同记者的美国特勤局特工携带武器进入天坛，特朗普的记者团行程被耽搁了近30分钟。经过美中官员的激烈磋商，双方最终达成妥协，之后白宫记者团进入了天坛。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260514-%E4%B8%AD%E6%96%B9%E5%AE%89%E4%BF%9D%E6%8B%92%E7%BB%9D%E7%BE%8E%E7%89%B9%E5%8B%A4%E5%B1%80%E7%89%B9%E5%B7%A5%E6%90%BA%E5%B8%A6%E6%AD%A6%E5%99%A8%E8%BF%9B%E5%85%A5%E5%A4%A9%E5%9D%9B-%E7%99%BD%E5%AE%AB%E8%AE%B0%E8%80%85%E5%9B%A2%E8%A2%AB%E5%BB%B6%E8%AF%AF%E8%BF%9130%E5%88%86%E9%92%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778748637000.webp","sourceId":"rfi"},{"id":1778748273000,"createdDate":"2026-05-14 08:44","name":"法国国际广播电台","title":"美中举行首脑会谈  日本高度关注台湾问题","content":"美国总统特朗普14日与中国国家主席席近平在北京举行会谈，对此日本内阁官房长官木原稔14日上午在记者会上表示：“美中关系能够有助于包括日本在内的国际社会稳定是非常重要的。”并称将高度关注相关动向。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260514-%E7%BE%8E%E4%B8%AD%E4%B8%BE%E8%A1%8C%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88-%E6%97%A5%E6%9C%AC%E9%AB%98%E5%BA%A6%E5%85%B3%E6%B3%A8%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778748273000.webp","sourceId":"rfi"},{"id":1778748229000,"createdDate":"2026-05-14 08:43","name":"法国国际广播电台","title":"特习会台湾聚焦：习近平称台湾问题处理不当恐导致中美冲突 但至此没有任何消息称特朗普提反对台独","content":"特习会在14日北京时间早上十点登场，历时两小时多，根据中国央社的会谈内容，仅习近平提到台湾问题，但特朗普并未提及台湾，也为正面回答媒体追问。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260514-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%8F%B0%E6%B9%BE%E8%81%9A%E7%84%A6-%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%A7%B0%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98%E5%A4%84%E7%90%86%E4%B8%8D%E5%BD%93%E6%81%90%E5%AF%BC%E8%87%B4%E4%B8%AD%E7%BE%8E%E5%86%B2%E7%AA%81-%E4%BD%86%E8%87%B3%E6%AD%A4%E6%B2%A1%E6%9C%89%E4%BB%BB%E4%BD%95%E6%B6%88%E6%81%AF%E7%A7%B0%E7%89%B9%E6%9C%97%E6%99%AE%E6%8F%90%E5%8F%8D%E5%AF%B9%E5%8F%B0%E7%8B%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778748229000.webp","sourceId":"rfi"},{"id":1778747681000,"createdDate":"2026-05-14 08:34","name":"法国国际广播电台","title":"美批准向10家中企出售H200芯片至今未有交付 黄仁勋在华寻突破","content":"据路透社援引三位知情人士报导称，美国已批准约10家中国公司购买英伟达第二强大的人工智能（AI）芯片H200，但迄今为止尚未有任何交付，这使得一项重要的技术交易陷入僵局，而英伟达首席执行官黄仁勋本周正寻求在中国取得突破。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260514-%E7%BE%8E%E6%89%B9%E5%87%86%E5%90%9110%E5%AE%B6%E4%B8%AD%E4%BC%81%E5%87%BA%E5%94%AEh200%E8%8A%AF%E7%89%87%E8%87%B3%E4%BB%8A%E6%9C%AA%E6%9C%89%E4%BA%A4%E4%BB%98-%E9%BB%84%E4%BB%81%E5%8B%8B%E5%9C%A8%E5%8D%8E%E5%AF%BB%E7%AA%81%E7%A0%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778747681000.webp","sourceId":"rfi"},{"id":1778742631000,"createdDate":"2026-05-14 07:10","name":"法国国际广播电台","title":"中国高规格接待特朗普 习近平与被制裁者卢比奥握手成热话","content":"尽管中方在「特习会」前透过建制KOL制造美国总统是来华「乞求」中方协助解决伊朗问题的舆论，但中国以国家副主席韩正前往机场迎迓已说明一切；而国家主席习近平更在今(14日)早的欢迎仪式上，与两度被中方制裁的美国国务卿卢比奥握手，更成为特朗普访华的热话。多家媒体都以图文并茂方式，报道二人握手的一刻，被形容为「制裁者与被制裁者」同台的戏码。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260514-%E4%B8%AD%E5%9B%BD%E9%AB%98%E8%A7%84%E6%A0%BC%E6%8E%A5%E5%BE%85%E7%89%B9%E6%9C%97%E6%99%AE-%E4%B9%A0%E8%BF%91%E5%B9%B3%E4%B8%8E%E8%A2%AB%E5%88%B6%E8%A3%81%E8%80%85%E5%8D%A2%E6%AF%94%E5%A5%A5%E6%8F%A1%E6%89%8B%E6%88%90%E7%83%AD%E8%AF%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778742631000.webp","sourceId":"rfi"},{"id":1778742294000,"createdDate":"2026-05-14 07:04","name":"法国国际广播电台","title":"「特习会」登场：习近平称中美经贸团队达总体平衡成果 特朗普指两国关系会很好","content":"全球瞩目的「特习会」今(14日)早在北京人民大会堂举行，中国国家主席习近平强调，台湾问题是中美关系中最重要的问题，又说中美应是伙伴而非对手，并透露双方经贸团队昨天达成了总体平衡积极的成果。美国总统特朗普则表示，期待与中国开展贸易合作，相信两国关系会前所未有地好。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260514-%E7%89%B9%E4%B9%A0%E4%BC%9A-%E7%99%BB%E5%9C%BA-%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%A7%B0%E4%B8%AD%E7%BE%8E%E7%BB%8F%E8%B4%B8%E5%9B%A2%E9%98%9F%E8%BE%BE%E6%80%BB%E4%BD%93%E5%B9%B3%E8%A1%A1%E6%88%90%E6%9E%9C-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8C%87%E4%B8%A4%E5%9B%BD%E5%85%B3%E7%B3%BB%E4%BC%9A%E5%BE%88%E5%A5%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778742294000.webp","sourceId":"rfi"}]