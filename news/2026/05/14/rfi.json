[{"id":1778748637000,"createdDate":"2026-05-14 08:50","name":"法国国际广播电台","title":"中方安保拒绝美特勤局特工携武器进入天坛 白宫记者团被延误近30分钟","content":"据白宫随行记者报导，由于中国安全官员拒绝一名陪同记者的美国特勤局特工携带武器进入天坛，特朗普的记者团行程被耽搁了近30分钟。经过美中官员的激烈磋商，双方最终达成妥协，之后白宫记者团进入了天坛。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260514-%E4%B8%AD%E6%96%B9%E5%AE%89%E4%BF%9D%E6%8B%92%E7%BB%9D%E7%BE%8E%E7%89%B9%E5%8B%A4%E5%B1%80%E7%89%B9%E5%B7%A5%E6%90%BA%E5%B8%A6%E6%AD%A6%E5%99%A8%E8%BF%9B%E5%85%A5%E5%A4%A9%E5%9D%9B-%E7%99%BD%E5%AE%AB%E8%AE%B0%E8%80%85%E5%9B%A2%E8%A2%AB%E5%BB%B6%E8%AF%AF%E8%BF%9130%E5%88%86%E9%92%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778748637000.webp","sourceId":"rfi"},{"id":1778748273000,"createdDate":"2026-05-14 08:44","name":"法国国际广播电台","title":"美中举行首脑会谈  日本高度关注台湾问题","content":"美国总统特朗普14日与中国国家主席席近平在北京举行会谈，对此日本内阁官房长官木原稔14日上午在记者会上表示：“美中关系能够有助于包括日本在内的国际社会稳定是非常重要的。”并称将高度关注相关动向。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260514-%E7%BE%8E%E4%B8%AD%E4%B8%BE%E8%A1%8C%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88-%E6%97%A5%E6%9C%AC%E9%AB%98%E5%BA%A6%E5%85%B3%E6%B3%A8%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778748273000.webp","sourceId":"rfi"},{"id":1778748229000,"createdDate":"2026-05-14 08:43","name":"法国国际广播电台","title":"特习会台湾聚焦：习近平称台湾问题处理不当恐导致中美冲突 但至此没有任何消息称特朗普提反对台独","content":"特习会在14日北京时间早上十点登场，历时两小时多，根据中国央社的会谈内容，仅习近平提到台湾问题，但特朗普并未提及台湾，也为正面回答媒体追问。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260514-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%8F%B0%E6%B9%BE%E8%81%9A%E7%84%A6-%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%A7%B0%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98%E5%A4%84%E7%90%86%E4%B8%8D%E5%BD%93%E6%81%90%E5%AF%BC%E8%87%B4%E4%B8%AD%E7%BE%8E%E5%86%B2%E7%AA%81-%E4%BD%86%E8%87%B3%E6%AD%A4%E6%B2%A1%E6%9C%89%E4%BB%BB%E4%BD%95%E6%B6%88%E6%81%AF%E7%A7%B0%E7%89%B9%E6%9C%97%E6%99%AE%E6%8F%90%E5%8F%8D%E5%AF%B9%E5%8F%B0%E7%8B%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778748229000.webp","sourceId":"rfi"},{"id":1778747681000,"createdDate":"2026-05-14 08:34","name":"法国国际广播电台","title":"美批准向10家中企出售H200芯片至今未有交付 黄仁勋在华寻突破","content":"据路透社援引三位知情人士报导称，美国已批准约10家中国公司购买英伟达第二强大的人工智能（AI）芯片H200，但迄今为止尚未有任何交付，这使得一项重要的技术交易陷入僵局，而英伟达首席执行官黄仁勋本周正寻求在中国取得突破。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260514-%E7%BE%8E%E6%89%B9%E5%87%86%E5%90%9110%E5%AE%B6%E4%B8%AD%E4%BC%81%E5%87%BA%E5%94%AEh200%E8%8A%AF%E7%89%87%E8%87%B3%E4%BB%8A%E6%9C%AA%E6%9C%89%E4%BA%A4%E4%BB%98-%E9%BB%84%E4%BB%81%E5%8B%8B%E5%9C%A8%E5%8D%8E%E5%AF%BB%E7%AA%81%E7%A0%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778747681000.webp","sourceId":"rfi"},{"id":1778742631000,"createdDate":"2026-05-14 07:10","name":"法国国际广播电台","title":"中国高规格接待特朗普 习近平与被制裁者卢比奥握手成热话","content":"尽管中方在「特习会」前透过建制KOL制造美国总统是来华「乞求」中方协助解决伊朗问题的舆论，但中国以国家副主席韩正前往机场迎迓已说明一切；而国家主席习近平更在今(14日)早的欢迎仪式上，与两度被中方制裁的美国国务卿卢比奥握手，更成为特朗普访华的热话。多家媒体都以图文并茂方式，报道二人握手的一刻，被形容为「制裁者与被制裁者」同台的戏码。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260514-%E4%B8%AD%E5%9B%BD%E9%AB%98%E8%A7%84%E6%A0%BC%E6%8E%A5%E5%BE%85%E7%89%B9%E6%9C%97%E6%99%AE-%E4%B9%A0%E8%BF%91%E5%B9%B3%E4%B8%8E%E8%A2%AB%E5%88%B6%E8%A3%81%E8%80%85%E5%8D%A2%E6%AF%94%E5%A5%A5%E6%8F%A1%E6%89%8B%E6%88%90%E7%83%AD%E8%AF%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778742631000.webp","sourceId":"rfi"},{"id":1778742294000,"createdDate":"2026-05-14 07:04","name":"法国国际广播电台","title":"「特习会」登场：习近平称中美经贸团队达总体平衡成果 特朗普指两国关系会很好","content":"全球瞩目的「特习会」今(14日)早在北京人民大会堂举行，中国国家主席习近平强调，台湾问题是中美关系中最重要的问题，又说中美应是伙伴而非对手，并透露双方经贸团队昨天达成了总体平衡积极的成果。美国总统特朗普则表示，期待与中国开展贸易合作，相信两国关系会前所未有地好。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260514-%E7%89%B9%E4%B9%A0%E4%BC%9A-%E7%99%BB%E5%9C%BA-%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%A7%B0%E4%B8%AD%E7%BE%8E%E7%BB%8F%E8%B4%B8%E5%9B%A2%E9%98%9F%E8%BE%BE%E6%80%BB%E4%BD%93%E5%B9%B3%E8%A1%A1%E6%88%90%E6%9E%9C-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8C%87%E4%B8%A4%E5%9B%BD%E5%85%B3%E7%B3%BB%E4%BC%9A%E5%BE%88%E5%A5%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778742294000.webp","sourceId":"rfi"},{"id":1778777465000,"createdDate":"2026-05-14 16:51","name":"法国国际广播电台","title":"法国总统马克龙访非洲联盟总部","content":"在非洲联盟总部所在地、埃塞俄比亚首都亚的斯亚贝巴（Addis-Abeba），法国总统马克龙(présidentEmmanuelMacron)于2026年05月13日周三在与非盟（UA）委员会主席马哈茂德·阿里·优素福(MahmoudAliYoussouf)和联合国（ONU）秘书长安东尼奥·古特雷斯(AntonioGuterres)举行三方会晤后表示，支持[非盟和平基金]（Fondspourlapaixdel'Unionafricaine）。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260514-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E6%B3%95%E5%9B%BD%E6%80%BB%E7%BB%9F%E9%A9%AC%E5%85%8B%E9%BE%99%E8%AE%BF%E9%9D%9E%E6%B4%B2%E8%81%94%E7%9B%9F%E6%80%BB%E9%83%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778777465000.webp","sourceId":"rfi"},{"id":1778775005000,"createdDate":"2026-05-14 16:10","name":"法国国际广播电台","title":"俄军接连两日大举空袭乌克兰，欧委会主席称莫斯科公开嘲笑和平努力","content":"刚刚借助美国总统的休战提议安然度过了卫国战争胜利纪念阅兵的俄罗斯正以更猛烈的方式空袭乌克兰。自13日清晨起，已经有超过1500架无人机对乌克兰境内目标发动攻击。欧盟委员会主席冯德莱恩14日表示，俄罗斯是在公开嘲笑进行中的推动和平努力。法国总统马克龙则认为，由此可见，俄罗斯不知道如何结束它发起的侵略战争。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260514-%E4%BF%84%E5%86%9B%E6%8E%A5%E8%BF%9E%E4%B8%A4%E6%97%A5%E5%A4%A7%E4%B8%BE%E7%A9%BA%E8%A2%AD%E4%B9%8C%E5%85%8B%E5%85%B0%EF%BC%8C%E6%AC%A7%E5%A7%94%E4%BC%9A%E4%B8%BB%E5%B8%AD%E7%A7%B0%E8%8E%AB%E6%96%AF%E7%A7%91%E5%85%AC%E5%BC%80%E5%98%B2%E7%AC%91%E5%92%8C%E5%B9%B3%E5%8A%AA%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778775005000.webp","sourceId":"rfi"},{"id":1778772731000,"createdDate":"2026-05-14 15:32","name":"法国国际广播电台","title":"谁在谈判中更有优势，更占上风，贝森特怎么说？","content":"美国财政部长贝森特（ScottBessent）周四表示，预计在特朗普总统访问北京期间，将宣布中国向波音公司订购大量飞机的消息，并称美方希望扩大对中国的出口。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260514-%E8%B0%81%E5%9C%A8%E8%B0%88%E5%88%A4%E4%B8%AD%E6%9B%B4%E6%9C%89%E4%BC%98%E5%8A%BF%EF%BC%8C%E6%9B%B4%E5%8D%A0%E4%B8%8A%E9%A3%8E%EF%BC%8C%E8%B4%9D%E6%A3%AE%E7%89%B9%E6%80%8E%E4%B9%88%E8%AF%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778772731000.webp","sourceId":"rfi"},{"id":1778772654000,"createdDate":"2026-05-14 15:30","name":"法国国际广播电台","title":"金砖国家新德里外长会：成员国难寻统一立场","content":"来自巴西、俄罗斯、印度、中国、南非等国的金砖国家外长会议于5月14日星期四在印度首都新德里正式召开。此次会议为期两天，召开背景正值国际局势持续紧张，包括伊朗战争持续、全球能源供应波动、包括中美在内的主要大国外交互动重叠以及全球经济不确定性上升等多重因素交织，使得此次会晤在原本的多边合作议程之外，呈现出更为复杂的现实背景。本次金砖外长会议的重要性不仅体现在议程层面，也体现在各方如何协调立场、应对危机以及维持组织凝聚力方面。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%8D%B0%E5%A4%AA%E7%BA%B5%E8%A7%88/20260514-%E9%87%91%E7%A0%96%E5%9B%BD%E5%AE%B6%E6%96%B0%E5%BE%B7%E9%87%8C%E5%A4%96%E9%95%BF%E4%BC%9A-%E6%88%90%E5%91%98%E5%9B%BD%E9%9A%BE%E5%AF%BB%E7%BB%9F%E4%B8%80%E7%AB%8B%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778772654000.webp","sourceId":"rfi"},{"id":1778769327000,"createdDate":"2026-05-14 14:35","name":"法国国际广播电台","title":"你知道吗？被看作人类健康杀手的蚊子也有花粉传播作用","content":"随着夏季来临，人类尤其是生活在湿热环境中的人类会更多面对蚊子的困扰。但这些看似微小轻盈的动物不仅困扰人类的夜间清梦，更是人类健康一个意想不到的杀手。根据卫生部门的数据，全球每年有近76万人死于蚊子叮咬传染的疾病，比如登革热，比如疟疾或黄热病，又比如近年来开始引发注意的基孔肯雅热等等。既然蚊子对人类健康构成威胁，那是否有必要采取措施彻底消灭蚊子？学界目前对此仍有争议。因为蚊子虽是多种病毒传播的媒介，但它在自然界竟然也有着花粉传播的功能，而且它毕竟也是动植物世界的一员，彻底根除是否良策似乎还有待进一步研究。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260514-%E4%BD%A0%E7%9F%A5%E9%81%93%E5%90%97-%E8%A2%AB%E7%9C%8B%E4%BD%9C%E4%BA%BA%E7%B1%BB%E5%81%A5%E5%BA%B7%E6%9D%80%E6%89%8B%E7%9A%84%E8%9A%8A%E5%AD%90%E4%B9%9F%E6%9C%89%E8%8A%B1%E7%B2%89%E4%BC%A0%E6%92%AD%E4%BD%9C%E7%94%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778769327000.webp","sourceId":"rfi"},{"id":1778767057000,"createdDate":"2026-05-14 13:57","name":"法国国际广播电台","title":"鲁比奥：未就伊朗问题寻求中方帮助，美对台政策没有改变，黎智英案被提及","content":"美国国务卿鲁比奥（MarcoRubio）周四在接受全国广播公司（NBC）专访时表示，特朗普总统在与习近平主席的峰会上讨论了伊朗战争和霍尔木兹海峡问题，并称美方没有寻求中国在伊朗问题上的帮助。鲁比奥在特习会后受访时说道，“中方表示不赞成将霍尔木兹海峡军事化，也不赞成通行费制度，这也是我们的立场”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260514-%E9%B2%81%E6%AF%94%E5%A5%A5-%E6%9C%AA%E5%B0%B1%E4%BC%8A%E6%9C%97%E9%97%AE%E9%A2%98%E5%AF%BB%E6%B1%82%E4%B8%AD%E6%96%B9%E5%B8%AE%E5%8A%A9%EF%BC%8C%E7%BE%8E%E5%AF%B9%E5%8F%B0%E6%94%BF%E7%AD%96%E6%B2%A1%E6%9C%89%E6%94%B9%E5%8F%98%EF%BC%8C%E9%BB%8E%E6%99%BA%E8%8B%B1%E6%A1%88%E8%A2%AB%E6%8F%90%E5%8F%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778767057000.webp","sourceId":"rfi"},{"id":1778762201000,"createdDate":"2026-05-14 12:36","name":"法国国际广播电台","title":"克宫：普京访华很快就会进行，与特朗普访华无关","content":"俄罗斯总统新闻秘书佩斯科夫周四表示，克里姆林宫将很快宣布俄总统普京访问中国的日期。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260514-%E5%85%8B%E5%AE%AB-%E6%99%AE%E4%BA%AC%E8%AE%BF%E5%8D%8E%E5%BE%88%E5%BF%AB%E5%B0%B1%E4%BC%9A%E8%BF%9B%E8%A1%8C%EF%BC%8C%E4%B8%8E%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E6%97%A0%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778762201000.webp","sourceId":"rfi"},{"id":1778760878000,"createdDate":"2026-05-14 12:14","name":"法国国际广播电台","title":"鲁比奥制裁是否已解除、习近平是否视特朗普为朋友， 中国外交部怎么说？","content":"中国外交部发言人郭嘉昆在周四的例行记者会上，没有直接回答有关中国国家主席习近平是否视美国总统特朗普（DonaldTrump）为朋友的问题。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260514-%E9%B2%81%E6%AF%94%E5%A5%A5%E5%88%B6%E8%A3%81%E6%98%AF%E5%90%A6%E5%B7%B2%E8%A7%A3%E9%99%A4-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%98%AF%E5%90%A6%E8%A7%86%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%BA%E6%9C%8B%E5%8F%8B%EF%BC%8C-%E4%B8%AD%E5%9B%BD%E5%A4%96%E4%BA%A4%E9%83%A8%E6%80%8E%E4%B9%88%E8%AF%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778760878000.webp","sourceId":"rfi"},{"id":1778757300000,"createdDate":"2026-05-14 11:15","name":"法国国际广播电台","title":"习近平向随特朗普访华的美国企业高管表示：中国将进一步开放","content":"在中美两国领导人举行主要围绕贸易和台湾等争议性议题的会谈期间，习近平会见了随特朗普访美的美国商界领袖，并释放出中国正朝着更大开放的方向迈进的信号。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260514-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%90%91%E9%9A%8F%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E7%9A%84%E7%BE%8E%E5%9B%BD%E4%BC%81%E4%B8%9A%E9%AB%98%E7%AE%A1%E8%A1%A8%E7%A4%BA-%E4%B8%AD%E5%9B%BD%E5%B0%86%E8%BF%9B%E4%B8%80%E6%AD%A5%E5%BC%80%E6%94%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778757300000.webp","sourceId":"rfi"},{"id":1778756594000,"createdDate":"2026-05-14 11:03","name":"法国国际广播电台","title":"费加罗报社论：“特朗普站在习近平墙脚下”","content":"大家好，欢迎收听法国报纸摘要，举世瞩目的「特习会」在周四5月14日当地时间上午10点于北京举行，成为法国今天各大日报头版头条。《费加罗报》表示，在激烈对峙之后，特朗普如今在北京寻求与习近平缓和关系。对于台湾议题，据《解放报》最新报道指出，中国领导人习近平就向他的美国同行特朗普明确表达了自己的意图。峰会伊始，中国就警告说，如果美国在台湾问题上处理不当，中美之间将出现“冲突”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260514-%E8%B4%B9%E5%8A%A0%E7%BD%97%E6%8A%A5%E7%A4%BE%E8%AE%BA-%E7%89%B9%E6%9C%97%E6%99%AE%E7%AB%99%E5%9C%A8%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%A2%99%E8%84%9A%E4%B8%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778756594000.webp","sourceId":"rfi"},{"id":1778754978000,"createdDate":"2026-05-14 10:36","name":"法国国际广播电台","title":"习近平就台湾问题发出警告，特朗普希望中美关系“比以往任何时候都更好”","content":"当地时间周四，中国国家主席习近平与美国总统特朗普在北京举行会谈。这是近十年来美国总统首次正式访华，也是双方围绕中美关系、贸易、台湾、伊朗局势等议题展开的一次高规格峰会。整场会谈持续约两个小时，地点设在北京人民大会堂。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260514-%E4%B8%AD%E7%BE%8E%E5%8C%97%E4%BA%AC%E4%BC%9A%E8%B0%88-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%B0%B1%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98%E5%8F%91%E5%87%BA%E8%AD%A6%E5%91%8A%EF%BC%8C%E5%8F%8C%E6%96%B9%E8%81%9A%E7%84%A6%E8%B4%B8%E6%98%93%E4%B8%8E%E4%BC%8A%E6%9C%97%E5%B1%80%E5%8A%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778754978000.webp","sourceId":"rfi"},{"id":1778754950000,"createdDate":"2026-05-14 10:35","name":"法国国际广播电台","title":"习特会登场 聚焦战略再平","content":"美国总统开启访华之旅，中美元首会晤正式登场。外界认为在高度不稳定的全球局势和超级大国激烈战略竞争的动荡环境下，中美寻求在各方面保持谨慎的共存与竞争关系，既非完全脱钩，也难以恢复全面合作。无论习特会结果如何，此次访问意味着中美关系正在寻找新的平衡点，这将对世界未来的走向产生重大影响。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260514-%E4%B9%A0%E7%89%B9%E4%BC%9A%E7%99%BB%E5%9C%BA-%E8%81%9A%E7%84%A6%E6%88%98%E7%95%A5%E5%86%8D%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778754950000.webp","sourceId":"rfi"},{"id":1778754014000,"createdDate":"2026-05-14 10:20","name":"法国国际广播电台","title":"白宫新闻稿：双方一致认为海峡须保持开放，伊朗不能拥有核武器，未提台湾","content":"中国国家主席习近平周四在北京人民大会堂同在华进行国事访问的美国总统特朗普（DonaldTrump）举行了会谈。今次特朗普和习近平的会晤持续了约2小时15分钟，比两位领导人去年10月在韩国釜山的上次会晤多出了约35分钟。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260514-%E7%99%BD%E5%AE%AB%E6%96%B0%E9%97%BB%E7%A8%BF-%E5%8F%8C%E6%96%B9%E4%B8%80%E8%87%B4%E8%AE%A4%E4%B8%BA%E6%B5%B7%E5%B3%A1%E9%A1%BB%E4%BF%9D%E6%8C%81%E5%BC%80%E6%94%BE%EF%BC%8C%E4%BC%8A%E6%9C%97%E4%B8%8D%E8%83%BD%E6%8B%A5%E6%9C%89%E6%A0%B8%E6%AD%A6%E5%99%A8%EF%BC%8C%E6%9C%AA%E6%8F%90%E5%8F%B0%E6%B9%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778754014000.webp","sourceId":"rfi"},{"id":1778751546000,"createdDate":"2026-05-14 09:39","name":"法国国际广播电台","title":"在曼哈顿唐人街开办中国海外警务站 美籍华裔男子卢建旺被陪审团定罪","content":"一名男子被控在曼哈顿唐人街一栋不起眼的办公楼内秘密运营中国间谍机构，周三被判犯有非法从事外国代理活动的罪行。现年64岁的卢建旺、又名“哈里·卢”（Harry Lu）还被判犯有妨碍司法公正罪，原因是他删除了美国检方所称的包含北京方面下令噤声、骚扰和恐吓民主异见人士的短信。他还被判定在相关共谋指控中无罪。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260514-%E5%9C%A8%E6%9B%BC%E5%93%88%E9%A1%BF%E5%94%90%E4%BA%BA%E8%A1%97%E5%BC%80%E5%8A%9E%E4%B8%AD%E5%9B%BD%E6%B5%B7%E5%A4%96%E8%AD%A6%E5%8A%A1%E7%AB%99-%E7%BE%8E%E7%B1%8D%E5%8D%8E%E8%A3%94%E7%94%B7%E5%AD%90%E5%8D%A2%E5%BB%BA%E6%97%BA%E8%A2%AB%E9%99%AA%E5%AE%A1%E5%9B%A2%E5%AE%9A%E7%BD%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778751546000.webp","sourceId":"rfi"},{"id":1778751415000,"createdDate":"2026-05-14 09:36","name":"法国国际广播电台","title":"以黎新一轮直接谈判今日在华盛顿开启，边境冲突持续升级","content":"5月14日星期四，以色列与黎巴嫩代表在美国首都华盛顿开启新一轮直接谈判。这场为期两天的会谈，正值以色列与黎巴嫩真主党武装持续交火。美国政府希望借此推动双方在停火及双边关系问题上取得突破。自1948年以色列建国以来，两国在官方层面始终处于战争状态。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260514-%E4%BB%A5%E9%BB%8E%E6%96%B0%E4%B8%80%E8%BD%AE%E7%9B%B4%E6%8E%A5%E8%B0%88%E5%88%A4%E4%BB%8A%E6%97%A5%E5%9C%A8%E5%8D%8E%E7%9B%9B%E9%A1%BF%E5%BC%80%E5%90%AF%EF%BC%8C%E8%BE%B9%E5%A2%83%E5%86%B2%E7%AA%81%E6%8C%81%E7%BB%AD%E5%8D%87%E7%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/14/1778751415000.webp","sourceId":"rfi"}]