[{"id":1779759304000,"createdDate":"2026-05-26 01:35","name":"美国之音","title":"美国军方表示，对伊朗南部地区进行了第二次自卫打击\n ","content":"美国中央司令部表示，星期一(5月25日)晚些时候，美军在伊朗南部地区发动了自卫性打击，以保护美军免受伊朗政权部队的威胁。","newsLink":"https://www.voachinese.com/a/us-military-says-it-carried-out-2nd-self-defense-strikes-on-southern-iran-since-start-of-truce-with-iranian-regime-on-april-8-20260525/8153977.html","thumbnail":"","detailImage":"news/detail/voa/2026/05/26/1779759304000.webp","sourceId":"voa"},{"id":1779808212000,"createdDate":"2026-05-26 15:10","name":"美国之音","title":"俄罗斯威胁对乌克兰首都发动系统性打击","content":"乌克兰空军星期二(5月26日)说，俄罗斯连夜向乌克兰发射了两枚“伊斯坎德尔-M”弹道导弹和122架无人机。防空部队击落或压制了111架无人机，有11个地点记录了冲击。截至上午发布最新情况时，袭击仍在持续。","newsLink":"https://www.voachinese.com/a/russia-threatens-systematic-strikes-on-ukraine-s-capital-20260526/8154071.html","thumbnail":"","detailImage":"news/detail/voa/2026/05/26/1779808212000.webp","sourceId":"voa"}]