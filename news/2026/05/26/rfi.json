[{"id":1779788475000,"createdDate":"2026-05-26 09:41","name":"法国国际广播电台","title":"特朗普蛮横施压阿拉伯盟友签署《亚伯拉罕协议》，要他们与以色列建交","content":"经过一个周末的外交混乱、会谈、危机会议以及精心策划的向媒体泄密之后，截至5月25日星期一，美国仍然一无所获：正式宣布伊朗停止敌对行动并重新开放霍尔木兹海峡的简短文本还没有与德黑兰最终敲定。包括巴基斯坦、卡塔尔和沙特阿拉伯在内的众多国家都在努力弥合分歧。当天早上，他们意外地收到了来自华盛顿的一条不同寻常的信息。这并非出于感谢，而是压力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260526-%E7%89%B9%E6%9C%97%E6%99%AE%E8%9B%AE%E6%A8%AA%E6%96%BD%E5%8E%8B%E9%98%BF%E6%8B%89%E4%BC%AF%E7%9B%9F%E5%8F%8B%E7%AD%BE%E7%BD%B2-%E4%BA%9A%E4%BC%AF%E6%8B%89%E7%BD%95%E5%8D%8F%E8%AE%AE-%EF%BC%8C%E8%A6%81%E4%BB%96%E4%BB%AC%E4%B8%8E%E4%BB%A5%E8%89%B2%E5%88%97%E5%BB%BA%E4%BA%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779788475000.webp","sourceId":"rfi"},{"id":1779787558000,"createdDate":"2026-05-26 09:25","name":"法国国际广播电台","title":"美国在谈判取得进展之际仍对伊朗发动空袭，中国呼吁相关方遵守停火协议","content":"尽管在解决中东战争的谈判中出现明显进展，美国周一（5月25日）仍宣布对伊朗南部导弹设施发动空袭，这一行动对停火协议造成冲击。中国周二（5月26日）呼吁相关方遵守停火协议。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260526-%E7%BE%8E%E5%9B%BD%E5%9C%A8%E8%B0%88%E5%88%A4%E5%8F%96%E5%BE%97%E8%BF%9B%E5%B1%95%E4%B9%8B%E9%99%85%E4%BB%8D%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%8F%91%E5%8A%A8%E7%A9%BA%E8%A2%AD%EF%BC%8C%E4%B8%AD%E5%9B%BD%E5%91%BC%E5%90%81%E7%9B%B8%E5%85%B3%E6%96%B9%E9%81%B5%E5%AE%88%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779787558000.webp","sourceId":"rfi"},{"id":1779786595000,"createdDate":"2026-05-26 09:09","name":"法国国际广播电台","title":"俄乌战争推动台湾无人机产量暴增，“不含中国材料”成最大卖点","content":"法新社周二（5月26日）发布报道称，台湾在乌克兰战争的推动下，无人机产量迅速增长，并希望将自身打造为亚洲无人机产业的重要枢纽。在中国无人机产业快速崛起的背景下，该报道详细分析了台湾无人机产业发展面临的机遇与困局。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260526-%E5%8F%B0%E6%B9%BE%E6%97%A0%E4%BA%BA%E6%9C%BA%E4%BA%A7%E9%87%8F%E6%9A%B4%E5%A2%9E%EF%BC%8C-%E4%B8%8D%E5%90%AB%E4%B8%AD%E5%9B%BD%E6%9D%90%E6%96%99-%E6%88%90%E6%9C%80%E5%A4%A7%E5%8D%96%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779786595000.webp","sourceId":"rfi"},{"id":1779785146000,"createdDate":"2026-05-26 08:45","name":"法国国际广播电台","title":"习近平：中国与巴基斯坦友谊“牢不可破” 联合声明促中东早日和平稳定","content":"在巴基斯坦总理谢里夫访华最后一天（5月26日），中巴两国发表18点联合声明。声明称，双方同意高质量共建“一带一路”，举行中巴经济走廊联委会会议，推动中巴经济走廊“2.0升级版”，并提出释放瓜达尔港潜力，打造地区互联互通枢纽。此前周一，在与谢里夫会晤时，中国国家主席习近平赞扬了中国和巴基斯坦“牢不可破”的友谊，並肯定巴基斯坦对伊朗和平努力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260526-%E4%B9%A0%E8%BF%91%E5%B9%B3-%E4%B8%AD%E5%9B%BD%E4%B8%8E%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%8F%8B%E8%B0%8A-%E7%89%A2%E4%B8%8D%E5%8F%AF%E7%A0%B4-%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E%E4%BF%83%E4%B8%AD%E4%B8%9C%E6%97%A9%E6%97%A5%E5%92%8C%E5%B9%B3%E7%A8%B3%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779785146000.webp","sourceId":"rfi"},{"id":1779784648000,"createdDate":"2026-05-26 08:37","name":"法国国际广播电台","title":"习近平可能于本周到访平壤之际，朝鲜向黄海方向发射弹道导弹","content":"韩国军方周二（5月26日）宣布，朝鲜当天向朝鲜半岛西海岸外的黄海海域发射了多枚飞行物，其中包括一枚弹道导弹。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260526-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%8F%AF%E8%83%BD%E4%BA%8E%E6%9C%AC%E5%91%A8%E5%88%B0%E8%AE%BF%E5%B9%B3%E5%A3%A4%E4%B9%8B%E9%99%85%EF%BC%8C%E6%9C%9D%E9%B2%9C%E5%91%A8%E4%BA%8C%E5%90%91%E9%BB%84%E6%B5%B7%E6%96%B9%E5%90%91%E5%8F%91%E5%B0%84%E5%BC%B9%E9%81%93%E5%AF%BC%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779784648000.webp","sourceId":"rfi"},{"id":1779784046000,"createdDate":"2026-05-26 08:27","name":"法国国际广播电台","title":"韩国计划十年内在本土建成首艘核动力潜艇","content":"韩国周二（5月26日）宣布，计划在本土建造首艘核动力潜艇，并于2030年代中期下水。韩国希望借此加强对拥核邻国朝鲜的威慑能力。对首尔而言，制造核潜艇将意味着其造船和国防工业实现重大飞跃，同时也将使韩国跻身拥有核潜艇的少数国家之列。目前拥有核潜艇的国家包括美国、澳大利亚、中国、俄罗斯、印度、法国和英国。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260526-%E9%9F%A9%E5%9B%BD%E8%AE%A1%E5%88%92%E5%8D%81%E5%B9%B4%E5%86%85%E5%9C%A8%E6%9C%AC%E5%9C%9F%E5%BB%BA%E6%88%90%E6%A0%B8%E5%8A%A8%E5%8A%9B%E6%BD%9C%E8%89%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779784046000.webp","sourceId":"rfi"},{"id":1779783508000,"createdDate":"2026-05-26 08:18","name":"法国国际广播电台","title":"国民党副主席萧旭岑出席浙江台湾合作周开幕 称台湾人是堂正的的中国人","content":"国民党副主席萧旭岑26日出席「2026浙江、台湾合作周」开幕式，他表示，国民党当前两岸路线为推动和平发展，并重申坚持九二共识、反对台独。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260526-%E5%9B%BD%E6%B0%91%E5%85%9A%E5%89%AF%E4%B8%BB%E5%B8%AD%E8%90%A7%E6%97%AD%E5%B2%91%E5%87%BA%E5%B8%AD%E6%B5%99%E6%B1%9F%E5%8F%B0%E6%B9%BE%E5%90%88%E4%BD%9C%E5%91%A8%E5%BC%80%E5%B9%95-%E7%A7%B0%E5%8F%B0%E6%B9%BE%E4%BA%BA%E6%98%AF%E5%A0%82%E6%AD%A3%E7%9A%84%E7%9A%84%E4%B8%AD%E5%9B%BD%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779783508000.webp","sourceId":"rfi"},{"id":1779783298000,"createdDate":"2026-05-26 08:14","name":"法国国际广播电台","title":"特习会后美国注意力重新回印太？卢比奥：四方安全对话（QUAD）成员国将在海事和矿产领域开展新合作","content":"美国、印度、澳大利亚和日本周二（5月26日）共同在印度宣布，将在海事和矿产领域开展新的合作，以重振北京密切关注的联盟⸺四方安全对话（QUAD）。当前，外界质疑美国对盟友外交的投入不足，还质疑成员国在伊朗问题上存在分歧，因此这一联合声明被视为具有不同寻常的意义。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260526-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%90%8E%E7%BE%8E%E5%9B%BD%E6%B3%A8%E6%84%8F%E5%8A%9B%E9%87%8D%E6%96%B0%E5%9B%9E%E5%8D%B0%E5%A4%AA-%E5%8D%A2%E6%AF%94%E5%A5%A5-%E5%9B%9B%E6%96%B9%E5%AE%89%E5%85%A8%E5%AF%B9%E8%AF%9D-quad-%E6%88%90%E5%91%98%E5%9B%BD%E5%B0%86%E5%9C%A8%E6%B5%B7%E4%BA%8B%E5%92%8C%E7%9F%BF%E4%BA%A7%E9%A2%86%E5%9F%9F%E5%BC%80%E5%B1%95%E6%96%B0%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779783298000.webp","sourceId":"rfi"},{"id":1779782880000,"createdDate":"2026-05-26 08:08","name":"法国国际广播电台","title":"又一艘日本油轮通过霍尔木兹海峡 伊战以来已有6艘日本油轮通过该海峡","content":"日本时间25日，又有1艘与日本有关的船舶成功通过事实上处于封锁状态的霍尔木兹海峡，目前仍留在波斯湾内的日本相关船只还有38艘。自2月底美以开始对伊朗发动攻击以来，通过霍尔木兹海峡的与日本有关的船舶至此已达6艘。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260526-%E5%8F%88%E4%B8%80%E8%89%98%E6%97%A5%E6%9C%AC%E6%B2%B9%E8%BD%AE%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E4%BC%8A%E6%88%98%E4%BB%A5%E6%9D%A5%E5%B7%B2%E6%9C%896%E8%89%98%E6%97%A5%E6%9C%AC%E6%B2%B9%E8%BD%AE%E9%80%9A%E8%BF%87%E8%AF%A5%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779782880000.webp","sourceId":"rfi"},{"id":1779776446000,"createdDate":"2026-05-26 06:20","name":"法国国际广播电台","title":"港财爷指欧洲求变 可合作 惟法国学者称欧企在港营商日困 欧盟应减对华倚赖","content":"香港政府近月加强与欧盟和欧洲国家的联系，财政司长陈茂波日前从欧洲回港後更表示，此行让他感受到欧洲求变意识十分强烈，认为港欧在经贸丶投资和创科等多个领域可以合作丶共创双赢。不过，法国政治学者高敬文(Prof.Jean-PierreCabestan）向本台指出，欧盟确有兴趣与香港开展更多业务，但在对华政策不变和香港市场日益被中资企业主导的情况下，欧洲企业在香港营商日益困难；若欧盟要去风险，便应减少对华倚赖。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260526-%E6%B8%AF%E8%B4%A2%E7%88%B7%E6%8C%87%E6%AC%A7%E6%B4%B2%E6%B1%82%E5%8F%98-%E5%8F%AF%E5%90%88%E4%BD%9C-%E6%83%9F%E6%B3%95%E5%9B%BD%E5%AD%A6%E8%80%85%E7%A7%B0%E6%AC%A7%E4%BC%81%E5%9C%A8%E6%B8%AF%E8%90%A5%E5%95%86%E6%97%A5%E5%9B%B0-%E6%AC%A7%E7%9B%9F%E5%BA%94%E5%87%8F%E5%AF%B9%E5%8D%8E%E5%80%9A%E8%B5%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779776446000.webp","sourceId":"rfi"},{"id":1779810190000,"createdDate":"2026-05-26 15:43","name":"法国国际广播电台","title":"【视频】法国遭遇提前到来的热浪","content":"据法国气象局（Météo-France）称，本周一（5月25日）是法国五月份有史以来最热的一天。周一午夜，法国气象局对西部八个省份——菲尼斯泰尔省、莫尔比昂省、芒什省、伊勒-维莱讷省、曼恩-卢瓦尔省、马耶讷省、旺代省和卢瓦尔-大西洋省——发布了橙色高温预警。本周剩余时间预计将持续高温天气。和法广同属法国世界媒体集团的法国电视24台的新闻记者西蒙·佩尔西茨对此进行了报道。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260526-%E8%A7%86%E9%A2%91-%E6%B3%95%E5%9B%BD%E9%81%AD%E9%81%87%E6%8F%90%E5%89%8D%E5%88%B0%E6%9D%A5%E7%9A%84%E7%83%AD%E6%B5%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779810190000.webp","sourceId":"rfi"},{"id":1779807227000,"createdDate":"2026-05-26 14:53","name":"法国国际广播电台","title":"四方安全对话：美日印澳外长“严重关切”南海局势，并在未点名中国的情况下警告针对台湾的“军机危险机动行为”","content":"“四方安全对话”（Quad）成员国美国、印度、日本和澳大利亚外长周二（5月26日）表示，对东海和南海局势“严重关切”，并在未点名中国的情况下，警告任何针对台湾采取行动的行为。此前，台湾国防部称，自25日6时至26日6时，侦获中国军机29架次（逾越中线进入北部、中部、西南及东部空域24架次）、军舰7艘及公务船1艘，持续在台海周边活动。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260526-%E5%9B%9B%E6%96%B9%E5%AE%89%E5%85%A8%E5%AF%B9%E8%AF%9D-%E7%BE%8E%E6%97%A5%E5%8D%B0%E6%BE%B3%E5%A4%96%E9%95%BF-%E4%B8%A5%E9%87%8D%E5%85%B3%E5%88%87-%E5%8D%97%E6%B5%B7%E5%B1%80%E5%8A%BF%EF%BC%8C%E5%B9%B6%E5%9C%A8%E6%9C%AA%E7%82%B9%E5%90%8D%E4%B8%AD%E5%9B%BD%E7%9A%84%E6%83%85%E5%86%B5%E4%B8%8B%E8%AD%A6%E5%91%8A%E9%92%88%E5%AF%B9%E5%8F%B0%E6%B9%BE%E7%9A%84-%E5%86%9B%E6%9C%BA%E5%8D%B1%E9%99%A9%E6%9C%BA%E5%8A%A8%E8%A1%8C%E4%B8%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779807227000.webp","sourceId":"rfi"},{"id":1779806682000,"createdDate":"2026-05-26 14:44","name":"法国国际广播电台","title":"美俄自我削弱 中国进一步崛起","content":"俄国总统普京在美国总统特朗普结束中国之行数天后便访问了北京，引发世界关注。德国媒体在关注会晤时，广泛看到了中国的进一步强大以及美国和俄国因挑起战争造成的自我削弱。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9F%8F%E6%9E%97%E9%A3%9E%E9%B8%BF/20260526-%E7%BE%8E%E4%BF%84%E8%87%AA%E6%88%91%E5%89%8A%E5%BC%B1-%E4%B8%AD%E5%9B%BD%E8%BF%9B%E4%B8%80%E6%AD%A5%E5%B4%9B%E8%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779806682000.webp","sourceId":"rfi"},{"id":1779805933000,"createdDate":"2026-05-26 14:32","name":"法国国际广播电台","title":"法国未来几天局部地区气温可能攀升至38至39摄氏度","content":"法国气象局周二（5月26日）表示，袭击法国的这场“历史性且前所未有”的早期高温天气，未来几天局部地区气温可能达到38摄氏度甚至39摄氏度。法国西部13个省份周三被列入橙色高温预警范围。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260526-%E6%B3%95%E5%9B%BD%E6%9C%AA%E6%9D%A5%E5%87%A0%E5%A4%A9%E5%B1%80%E5%9C%B0%E6%B0%94%E6%B8%A9%E5%8F%AF%E8%83%BD%E6%94%80%E5%8D%87%E8%87%B338%E8%87%B339%E6%91%84%E6%B0%8F%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779805933000.webp","sourceId":"rfi"},{"id":1779805521000,"createdDate":"2026-05-26 14:25","name":"法国国际广播电台","title":"赞比亚独立媒体人谈人权峰会的取消与新闻自由","content":"赞比亚科技部长费利克斯·穆塔蒂4月29日宣布，由于需要全面披露峰会讨论的主要议题，原定于2026年5月5日至8日在赞比亚举行的数字人权峰会（RightsCon峰会）将延期。最终，RightsCon的组织方宣布，2026年峰会将不会如期举行。 人权观察组织引述赞比亚当地人权活动人士披露说此次大会延期是由于中国政府就台湾受邀代表出席一事向赞比亚当局表达了不满。赞比亚独立媒体《新闻挖掘者》（NewsDiggers）是最早公开披露此一消息的媒体，法广就此采访了该媒体的总编约瑟夫·姆文达（JosephMwenda）。此外，约瑟夫·姆文达先生还就赞比亚的新闻自由发表了他的观点。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260526-%E8%B5%9E%E6%AF%94%E4%BA%9A%E7%8B%AC%E7%AB%8B%E5%AA%92%E4%BD%93%E4%BA%BA%E8%B0%88%E4%BA%BA%E6%9D%83%E5%B3%B0%E4%BC%9A%E7%9A%84%E5%8F%96%E6%B6%88%E4%B8%8E%E6%96%B0%E9%97%BB%E8%87%AA%E7%94%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779805521000.webp","sourceId":"rfi"},{"id":1779804749000,"createdDate":"2026-05-26 14:12","name":"法国国际广播电台","title":"中国国货航追加订购4架空客A350F货机，去年11月曾首次订购6架","content":"欧洲飞机制造商空客（Airbus）周二（5月26日）宣布，中国国际货运航空公司（AirChinaCargo）在原有订单基础上，追加订购了4架A350F大型货机，订单总数增至10架。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260526-%E7%BB%A7%E5%8E%BB%E5%B9%B411%E6%9C%88%E9%A6%96%E6%AC%A1%E8%AE%A2%E8%B4%AD6%E6%9E%B6%E9%A3%9E%E6%9C%BA%E5%90%8E%EF%BC%8C%E4%B8%AD%E5%9B%BD%E5%9B%BD%E8%B4%A7%E8%88%AA%E5%8F%88%E8%BF%BD%E5%8A%A0%E8%AE%A2%E8%B4%AD4%E6%9E%B6%E7%A9%BA%E5%AE%A2a350f%E8%B4%A7%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779804749000.webp","sourceId":"rfi"},{"id":1779802794000,"createdDate":"2026-05-26 13:39","name":"法国国际广播电台","title":"法国春分迎热浪：为何上周末起高温破纪录？已破7死记录 西部13省黄色预警","content":"各位听众，法国春分天热浪却早早来袭，而且已间接或直接造成7人死亡记录，引发大家开始关注：法国为何从上个周末起，迎来破纪录高温？BFM全天候新闻电视台最新报道：法国气象局对法国西部13个省份发布了黄色热浪预警，创下该季节的纪录。另据十字架报解析指出，由于受“欧米伽阻塞”现象影响，法国各地正经历提前到来的热浪。预计西南海岸的波尔多省气温于2026年5月22日（星期五）的周末达到36摄氏度。法国气象局预测，热浪高峰期将在25日周一起初来到，并将持续到5月底。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E5%A2%83%E4%B8%8E%E5%8F%91%E5%B1%95/20260526-%E6%B3%95%E5%9B%BD%E6%98%A5%E5%88%86%E8%BF%8E%E7%83%AD%E6%B5%AA-%E4%B8%BA%E4%BD%95%E4%B8%8A%E5%91%A8%E6%9C%AB%E8%B5%B7%E9%AB%98%E6%B8%A9%E7%A0%B4%E7%BA%AA%E5%BD%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779802794000.webp","sourceId":"rfi"},{"id":1779796574000,"createdDate":"2026-05-26 11:56","name":"法国国际广播电台","title":"菲律宾总统小马科斯抵达日本，将于28日与高市早苗会谈，日菲拟升级为“全面战略伙伴关系”","content":"据共同社快讯，菲律宾总统府消息称，总统小马科斯所乘坐的飞机已于26日抵达日本东京。另一篇报道显示，小马科斯预计将于28日在东京与日本首相高市早苗举行会谈，将聚焦在东海和南海加强军事胁迫的中国，拟以安全保障领域为中心确认加强合作。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260526-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E6%80%BB%E7%BB%9F%E5%B0%8F%E9%A9%AC%E7%A7%91%E6%96%AF%E6%8A%B5%E8%BE%BE%E6%97%A5%E6%9C%AC%EF%BC%8C%E5%B0%86%E4%BA%8E28%E6%97%A5%E4%B8%8E%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E4%BC%9A%E8%B0%88%EF%BC%8C%E6%97%A5%E8%8F%B2%E6%8B%9F%E5%8D%87%E7%BA%A7%E4%B8%BA-%E5%85%A8%E9%9D%A2%E6%88%98%E7%95%A5%E4%BC%99%E4%BC%B4%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779796574000.webp","sourceId":"rfi"},{"id":1779795906000,"createdDate":"2026-05-26 11:45","name":"法国国际广播电台","title":"印太为核心战略的美澳日印“四方安全对话”重启 北京重申：不应针对第三方","content":"美国国务卿卢比奥、澳大利亚外长黄英贤、日本外长茂木敏充、以及印度外长苏杰生周二（5月26日）在印度首都新德里聚首，这是四国外长自2024年9月以来第3次举行这类会议，以寻求重启“四方安全对话”以亚太地区为核心的动力。对此，中国外交部则重申，任何合作都不应针对第三方，或损害地区国家之间的互信和合作。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260526-%E5%8D%B0%E5%A4%AA%E4%B8%BA%E6%A0%B8%E5%BF%83%E6%88%98%E7%95%A5%E7%9A%84%E7%BE%8E%E6%BE%B3%E6%97%A5%E5%8D%B0-%E5%9B%9B%E6%96%B9%E5%AE%89%E5%85%A8%E5%AF%B9%E8%AF%9D-%E9%87%8D%E5%90%AF-%E5%8C%97%E4%BA%AC%E9%87%8D%E7%94%B3-%E4%B8%8D%E5%BA%94%E9%92%88%E5%AF%B9%E7%AC%AC%E4%B8%89%E6%96%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779795906000.webp","sourceId":"rfi"},{"id":1779792212000,"createdDate":"2026-05-26 10:43","name":"法国国际广播电台","title":"美中科技竞争之际　中国仍成美芯片企业重要市场","content":"美中科技与贸易紧张持续升温之际，美国半导体企业去年在中国市场营收仍大幅成长。最新研究显示，包括英伟达（Nvidia）、高通（Qualcomm）与超微半导体（AMD）等26家美国芯片企业，去年在中国收入平均增加两成，显示中国对人工智能（AI）与高阶芯片需求依旧强劲，也反映美国科技企业仍难以割舍中国市场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260526-%E7%BE%8E%E4%B8%AD%E7%A7%91%E6%8A%80%E7%AB%9E%E4%BA%89%E4%B9%8B%E9%99%85-%E4%B8%AD%E5%9B%BD%E4%BB%8D%E6%88%90%E7%BE%8E%E8%8A%AF%E7%89%87%E4%BC%81%E4%B8%9A%E9%87%8D%E8%A6%81%E5%B8%82%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779792212000.webp","sourceId":"rfi"},{"id":1779790049000,"createdDate":"2026-05-26 10:07","name":"法国国际广播电台","title":"郑钦文法网首轮爆冷出局，排名跌至117位，表示将从低级别赛事开始打起","content":"5月25日是2026年法网第二个比赛日，当天的一大焦点新闻是2024年奥运冠军郑钦文爆冷出局。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260526-%E9%83%91%E9%92%A6%E6%96%87%E6%B3%95%E7%BD%91%E9%A6%96%E8%BD%AE%E7%88%86%E5%86%B7%E5%87%BA%E5%B1%80%EF%BC%8C%E6%8E%92%E5%90%8D%E8%B7%8C%E8%87%B3117%E4%BD%8D%EF%BC%8C%E8%AE%A1%E5%88%92%E5%8F%82%E5%8A%A0%E4%BD%8E%E7%BA%A7%E5%88%AB%E8%B5%9B%E4%BA%8B%E9%87%8D%E8%BF%94%E7%8A%B6%E6%80%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779790049000.webp","sourceId":"rfi"},{"id":1779789599000,"createdDate":"2026-05-26 09:59","name":"法国国际广播电台","title":"台湾会否与乌克兰一样坚韧？亚洲是否比欧洲“不愿为基辅而战”更不愿“为台北而战”？","content":"今日出刊的本台订阅的法国主流日刊有多则与中国相关的报道，内容涵盖华为芯片新动向、德国新爆出的中国间谍案、欧委会将于5月29日召开会议研究“更加坚定和有效的贸易防御政策”工具，应对“正侵蚀欧洲工业体系”的中国、本次中东危机正构成对石油美元体系的完美风暴，可能成为‘石油人民币’的催化剂、乌克兰和伊朗之后，台湾的命运等。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260526-%E5%8F%B0%E6%B9%BE%E4%BC%9A%E5%90%A6%E4%B8%8E%E4%B9%8C%E5%85%8B%E5%85%B0%E4%B8%80%E6%A0%B7%E5%9D%9A%E9%9F%A7-%E4%BA%9A%E6%B4%B2%E6%98%AF%E5%90%A6%E6%AF%94%E6%AC%A7%E6%B4%B2-%E4%B8%8D%E6%84%BF%E4%B8%BA%E5%9F%BA%E8%BE%85%E8%80%8C%E6%88%98-%E6%9B%B4%E4%B8%8D%E6%84%BF-%E4%B8%BA%E5%8F%B0%E5%8C%97%E8%80%8C%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779789599000.webp","sourceId":"rfi"},{"id":1779788544000,"createdDate":"2026-05-26 09:42","name":"法国国际广播电台","title":"日美借“四方安全对话”契机商讨对华政策，台湾问题与稀土是核心议题","content":"当前正值日美澳印“四边机制”（Quad）外长会议，共同社报道称，日本外相茂木敏充26日在印度首都新德里与美国国务卿卢比奥举行会谈。这将是本月在北京举行的美中首脑会谈之后日美两国主要部长首次面对面会谈。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260526-%E6%97%A5%E7%BE%8E%E5%A4%96%E9%95%BF%E5%B0%86%E5%9C%A8%E5%8D%B0%E5%BA%A6%E4%BC%9A%E8%B0%88%E5%95%86%E8%AE%A8%E5%AF%B9%E5%8D%8E%E6%94%BF%E7%AD%96%EF%BC%8C%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98%E4%B8%8E%E7%A8%80%E5%9C%9F%E6%98%AF%E6%A0%B8%E5%BF%83%E8%AE%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779788544000.webp","sourceId":"rfi"}]