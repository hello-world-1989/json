[{"id":1779788475000,"createdDate":"2026-05-26 09:41","name":"法国国际广播电台","title":"特朗普蛮横施压阿拉伯盟友签署《亚伯拉罕协议》，要他们与以色列建交","content":"经过一个周末的外交混乱、会谈、危机会议以及精心策划的向媒体泄密之后，截至5月25日星期一，美国仍然一无所获：正式宣布伊朗停止敌对行动并重新开放霍尔木兹海峡的简短文本还没有与德黑兰最终敲定。包括巴基斯坦、卡塔尔和沙特阿拉伯在内的众多国家都在努力弥合分歧。当天早上，他们意外地收到了来自华盛顿的一条不同寻常的信息。这并非出于感谢，而是压力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260526-%E7%89%B9%E6%9C%97%E6%99%AE%E8%9B%AE%E6%A8%AA%E6%96%BD%E5%8E%8B%E9%98%BF%E6%8B%89%E4%BC%AF%E7%9B%9F%E5%8F%8B%E7%AD%BE%E7%BD%B2-%E4%BA%9A%E4%BC%AF%E6%8B%89%E7%BD%95%E5%8D%8F%E8%AE%AE-%EF%BC%8C%E8%A6%81%E4%BB%96%E4%BB%AC%E4%B8%8E%E4%BB%A5%E8%89%B2%E5%88%97%E5%BB%BA%E4%BA%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779788475000.webp","sourceId":"rfi"},{"id":1779787558000,"createdDate":"2026-05-26 09:25","name":"法国国际广播电台","title":"美国在谈判取得进展之际仍对伊朗发动空袭，中国呼吁相关方遵守停火协议","content":"尽管在解决中东战争的谈判中出现明显进展，美国周一（5月25日）仍宣布对伊朗南部导弹设施发动空袭，这一行动对停火协议造成冲击。中国周二（5月26日）呼吁相关方遵守停火协议。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260526-%E7%BE%8E%E5%9B%BD%E5%9C%A8%E8%B0%88%E5%88%A4%E5%8F%96%E5%BE%97%E8%BF%9B%E5%B1%95%E4%B9%8B%E9%99%85%E4%BB%8D%E5%AF%B9%E4%BC%8A%E6%9C%97%E5%8F%91%E5%8A%A8%E7%A9%BA%E8%A2%AD%EF%BC%8C%E4%B8%AD%E5%9B%BD%E5%91%BC%E5%90%81%E7%9B%B8%E5%85%B3%E6%96%B9%E9%81%B5%E5%AE%88%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779787558000.webp","sourceId":"rfi"},{"id":1779786595000,"createdDate":"2026-05-26 09:09","name":"法国国际广播电台","title":"俄乌战争推动台湾无人机产量暴增，“不含中国材料”成最大卖点","content":"法新社周二（5月26日）发布报道称，台湾在乌克兰战争的推动下，无人机产量迅速增长，并希望将自身打造为亚洲无人机产业的重要枢纽。在中国无人机产业快速崛起的背景下，该报道详细分析了台湾无人机产业发展面临的机遇与困局。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260526-%E5%8F%B0%E6%B9%BE%E6%97%A0%E4%BA%BA%E6%9C%BA%E4%BA%A7%E9%87%8F%E6%9A%B4%E5%A2%9E%EF%BC%8C-%E4%B8%8D%E5%90%AB%E4%B8%AD%E5%9B%BD%E6%9D%90%E6%96%99-%E6%88%90%E6%9C%80%E5%A4%A7%E5%8D%96%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779786595000.webp","sourceId":"rfi"},{"id":1779785146000,"createdDate":"2026-05-26 08:45","name":"法国国际广播电台","title":"习近平：中国与巴基斯坦友谊“牢不可破” 联合声明促中东早日和平稳定","content":"在巴基斯坦总理谢里夫访华最后一天（5月26日），中巴两国发表18点联合声明。声明称，双方同意高质量共建“一带一路”，举行中巴经济走廊联委会会议，推动中巴经济走廊“2.0升级版”，并提出释放瓜达尔港潜力，打造地区互联互通枢纽。此前周一，在与谢里夫会晤时，中国国家主席习近平赞扬了中国和巴基斯坦“牢不可破”的友谊，並肯定巴基斯坦对伊朗和平努力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260526-%E4%B9%A0%E8%BF%91%E5%B9%B3-%E4%B8%AD%E5%9B%BD%E4%B8%8E%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%8F%8B%E8%B0%8A-%E7%89%A2%E4%B8%8D%E5%8F%AF%E7%A0%B4-%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E%E4%BF%83%E4%B8%AD%E4%B8%9C%E6%97%A9%E6%97%A5%E5%92%8C%E5%B9%B3%E7%A8%B3%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779785146000.webp","sourceId":"rfi"},{"id":1779784648000,"createdDate":"2026-05-26 08:37","name":"法国国际广播电台","title":"习近平可能于本周到访平壤之际，朝鲜向黄海方向发射弹道导弹","content":"韩国军方周二（5月26日）宣布，朝鲜当天向朝鲜半岛西海岸外的黄海海域发射了多枚飞行物，其中包括一枚弹道导弹。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260526-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%8F%AF%E8%83%BD%E4%BA%8E%E6%9C%AC%E5%91%A8%E5%88%B0%E8%AE%BF%E5%B9%B3%E5%A3%A4%E4%B9%8B%E9%99%85%EF%BC%8C%E6%9C%9D%E9%B2%9C%E5%91%A8%E4%BA%8C%E5%90%91%E9%BB%84%E6%B5%B7%E6%96%B9%E5%90%91%E5%8F%91%E5%B0%84%E5%BC%B9%E9%81%93%E5%AF%BC%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779784648000.webp","sourceId":"rfi"},{"id":1779784046000,"createdDate":"2026-05-26 08:27","name":"法国国际广播电台","title":"韩国计划十年内在本土建成首艘核动力潜艇","content":"韩国周二（5月26日）宣布，计划在本土建造首艘核动力潜艇，并于2030年代中期下水。韩国希望借此加强对拥核邻国朝鲜的威慑能力。对首尔而言，制造核潜艇将意味着其造船和国防工业实现重大飞跃，同时也将使韩国跻身拥有核潜艇的少数国家之列。目前拥有核潜艇的国家包括美国、澳大利亚、中国、俄罗斯、印度、法国和英国。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260526-%E9%9F%A9%E5%9B%BD%E8%AE%A1%E5%88%92%E5%8D%81%E5%B9%B4%E5%86%85%E5%9C%A8%E6%9C%AC%E5%9C%9F%E5%BB%BA%E6%88%90%E6%A0%B8%E5%8A%A8%E5%8A%9B%E6%BD%9C%E8%89%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779784046000.webp","sourceId":"rfi"},{"id":1779783508000,"createdDate":"2026-05-26 08:18","name":"法国国际广播电台","title":"国民党副主席萧旭岑出席浙江台湾合作周开幕 称台湾人是堂正的的中国人","content":"国民党副主席萧旭岑26日出席「2026浙江、台湾合作周」开幕式，他表示，国民党当前两岸路线为推动和平发展，并重申坚持九二共识、反对台独。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260526-%E5%9B%BD%E6%B0%91%E5%85%9A%E5%89%AF%E4%B8%BB%E5%B8%AD%E8%90%A7%E6%97%AD%E5%B2%91%E5%87%BA%E5%B8%AD%E6%B5%99%E6%B1%9F%E5%8F%B0%E6%B9%BE%E5%90%88%E4%BD%9C%E5%91%A8%E5%BC%80%E5%B9%95-%E7%A7%B0%E5%8F%B0%E6%B9%BE%E4%BA%BA%E6%98%AF%E5%A0%82%E6%AD%A3%E7%9A%84%E7%9A%84%E4%B8%AD%E5%9B%BD%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779783508000.webp","sourceId":"rfi"},{"id":1779783298000,"createdDate":"2026-05-26 08:14","name":"法国国际广播电台","title":"特习会后美国注意力重新回印太？卢比奥：四方安全对话（QUAD）成员国将在海事和矿产领域开展新合作","content":"美国、印度、澳大利亚和日本周二（5月26日）共同在印度宣布，将在海事和矿产领域开展新的合作，以重振北京密切关注的联盟⸺四方安全对话（QUAD）。当前，外界质疑美国对盟友外交的投入不足，还质疑成员国在伊朗问题上存在分歧，因此这一联合声明被视为具有不同寻常的意义。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260526-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%90%8E%E7%BE%8E%E5%9B%BD%E6%B3%A8%E6%84%8F%E5%8A%9B%E9%87%8D%E6%96%B0%E5%9B%9E%E5%8D%B0%E5%A4%AA-%E5%8D%A2%E6%AF%94%E5%A5%A5-%E5%9B%9B%E6%96%B9%E5%AE%89%E5%85%A8%E5%AF%B9%E8%AF%9D-quad-%E6%88%90%E5%91%98%E5%9B%BD%E5%B0%86%E5%9C%A8%E6%B5%B7%E4%BA%8B%E5%92%8C%E7%9F%BF%E4%BA%A7%E9%A2%86%E5%9F%9F%E5%BC%80%E5%B1%95%E6%96%B0%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779783298000.webp","sourceId":"rfi"},{"id":1779782880000,"createdDate":"2026-05-26 08:08","name":"法国国际广播电台","title":"又一艘日本油轮通过霍尔木兹海峡 伊战以来已有6艘日本油轮通过该海峡","content":"日本时间25日，又有1艘与日本有关的船舶成功通过事实上处于封锁状态的霍尔木兹海峡，目前仍留在波斯湾内的日本相关船只还有38艘。自2月底美以开始对伊朗发动攻击以来，通过霍尔木兹海峡的与日本有关的船舶至此已达6艘。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260526-%E5%8F%88%E4%B8%80%E8%89%98%E6%97%A5%E6%9C%AC%E6%B2%B9%E8%BD%AE%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E4%BC%8A%E6%88%98%E4%BB%A5%E6%9D%A5%E5%B7%B2%E6%9C%896%E8%89%98%E6%97%A5%E6%9C%AC%E6%B2%B9%E8%BD%AE%E9%80%9A%E8%BF%87%E8%AF%A5%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779782880000.webp","sourceId":"rfi"},{"id":1779776446000,"createdDate":"2026-05-26 06:20","name":"法国国际广播电台","title":"港财爷指欧洲求变 可合作 惟法国学者称欧企在港营商日困 欧盟应减对华倚赖","content":"香港政府近月加强与欧盟和欧洲国家的联系，财政司长陈茂波日前从欧洲回港後更表示，此行让他感受到欧洲求变意识十分强烈，认为港欧在经贸丶投资和创科等多个领域可以合作丶共创双赢。不过，法国政治学者高敬文(Prof.Jean-PierreCabestan）向本台指出，欧盟确有兴趣与香港开展更多业务，但在对华政策不变和香港市场日益被中资企业主导的情况下，欧洲企业在香港营商日益困难；若欧盟要去风险，便应减少对华倚赖。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260526-%E6%B8%AF%E8%B4%A2%E7%88%B7%E6%8C%87%E6%AC%A7%E6%B4%B2%E6%B1%82%E5%8F%98-%E5%8F%AF%E5%90%88%E4%BD%9C-%E6%83%9F%E6%B3%95%E5%9B%BD%E5%AD%A6%E8%80%85%E7%A7%B0%E6%AC%A7%E4%BC%81%E5%9C%A8%E6%B8%AF%E8%90%A5%E5%95%86%E6%97%A5%E5%9B%B0-%E6%AC%A7%E7%9B%9F%E5%BA%94%E5%87%8F%E5%AF%B9%E5%8D%8E%E5%80%9A%E8%B5%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/26/1779776446000.webp","sourceId":"rfi"}]