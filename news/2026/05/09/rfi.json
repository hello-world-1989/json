[{"id":1778312444000,"createdDate":"2026-05-09 07:40","name":"法国国际广播电台","title":"战争效应：中国4月出口强劲反弹14.1% 贸易顺差扩大至848亿美元","content":"中国4月出口表现远超预期，年增率达14.1%。据路透社报道指出，主因是海外买家担忧中东局势推升成本而提前囤货，中国工厂遂而竞相满足海外买家的大量订单，导致中国4月份出口增速加快。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260509-%E6%88%98%E4%BA%89%E6%95%88%E5%BA%94-%E4%B8%AD%E5%9B%BD4%E6%9C%88%E5%87%BA%E5%8F%A3%E5%BC%BA%E5%8A%B2%E5%8F%8D%E5%BC%B914-1-%E8%B4%B8%E6%98%93%E9%A1%BA%E5%B7%AE%E6%89%A9%E5%A4%A7%E8%87%B3848%E4%BA%BF%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778312444000.webp","sourceId":"rfi"},{"id":1778311995000,"createdDate":"2026-05-09 07:33","name":"法国国际广播电台","title":"泰国一名中国公民家中被查获大量武器","content":"泰国当局周六宣布，在一处中国公民的住所内查获了突击步枪、爆炸物、手榴弹和杀伤人员地雷，调查人员正在调查其是否存在恐怖主义动机。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260509-%E6%B3%B0%E5%9B%BD%E4%B8%80%E5%90%8D%E4%B8%AD%E5%9B%BD%E5%85%AC%E6%B0%91%E5%AE%B6%E4%B8%AD%E8%A2%AB%E6%9F%A5%E8%8E%B7%E5%A4%A7%E9%87%8F%E6%AD%A6%E5%99%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778311995000.webp","sourceId":"rfi"},{"id":1778342331000,"createdDate":"2026-05-09 15:58","name":"法国国际广播电台","title":"特朗普访华前 美国制裁九个协助伊朗军事及卫星定位的中国大陆及香港实体","content":"在美国总统唐纳德·特朗普计划访华并与习近平举行峰会的前几天，美国财政部和国务院宣布对9家被控协助伊朗军队的中国内地和香港企业实施制裁。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260509-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E5%89%8D-%E7%BE%8E%E5%9B%BD%E5%88%B6%E8%A3%81%E4%B9%9D%E4%B8%AA%E5%8D%8F%E5%8A%A9%E4%BC%8A%E6%9C%97%E5%86%9B%E4%BA%8B%E5%8F%8A%E5%8D%AB%E6%98%9F%E5%AE%9A%E4%BD%8D%E7%9A%84%E4%B8%AD%E5%9B%BD%E5%A4%A7%E9%99%86%E5%8F%8A%E9%A6%99%E6%B8%AF%E5%AE%9E%E4%BD%93","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778342331000.webp","sourceId":"rfi"},{"id":1778342213000,"createdDate":"2026-05-09 15:56","name":"法国国际广播电台","title":"澳洲学者张越：中美AI竞争可能会走上分道扬镳的两个路径","content":"日新月异的人工智能技术发展已经成为中美两大国战略竞争的一个核心议题。就在美国总统特朗普时隔九年准备再访北京前夕，中国政府发改委发出通知，叫停美国网络巨头谷歌的母公司Meta对中国人工智能助理软件Manus的收购行动，坐实了此前关于中国会阻止本国数字技术精英企业和人才外流的猜测。紧接着，美国联邦通信委员会5月1日决定不再允许面向美国市场的电子产品在中国进行测试，引来中方的抗议……如何看中国有关当局阻止在本土成长起来的科技精英出海的作为？中美两国在高科技领域互建“小院高强”的作为对中美两国的技术发展、对全球在人工智能领域的发展有何影响？澳大利亚悉尼科技大学中澳关系研究院研究员张越女士专注研究科技政策以及它对地缘政治关系的影响。她接受本台电话采访时表示，中国叫停人工智能助理软件Manus收购案对中国科技企业起到一种杀鸡儆猴的效果，而中美两国未来在AI领域的竞争将不再是大模型之间的竞争，而是两种AI生态系统的竞争。但人工智能技术关系着人类未来几十年的生存发展，中美双方需要合作。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%85%AC%E6%B0%91%E8%AE%BA%E5%9D%9B/20260509-%E6%BE%B3%E6%B4%B2%E5%AD%A6%E8%80%85%E5%BC%A0%E8%B6%8A-%E4%B8%AD%E7%BE%8Eai%E7%AB%9E%E4%BA%89%E5%8F%AF%E8%83%BD%E4%BC%9A%E8%B5%B0%E4%B8%8A%E5%88%86%E9%81%93%E6%89%AC%E9%95%B3%E7%9A%84%E4%B8%A4%E4%B8%AA%E8%B7%AF%E5%BE%84","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778342213000.webp","sourceId":"rfi"},{"id":1778338935000,"createdDate":"2026-05-09 15:02","name":"法国国际广播电台","title":"伊朗最高领袖顾问：霍尔木兹海峡“与原子弹同样宝贵”！","content":"伊朗最高领袖的一名顾问周五说，原来霍尔木兹海峡跟原子弹一样宝贵，我们长期以来忽视了。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260509-%E4%BC%8A%E6%9C%97%E6%9C%80%E9%AB%98%E9%A2%86%E8%A2%96%E9%A1%BE%E9%97%AE-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E4%B8%8E%E5%8E%9F%E5%AD%90%E5%BC%B9%E5%90%8C%E6%A0%B7%E5%AE%9D%E8%B4%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778338935000.webp","sourceId":"rfi"},{"id":1778336478000,"createdDate":"2026-05-09 14:21","name":"法国国际广播电台","title":"俄罗斯卫国战争胜利纪念日近二十年来最低调阅兵匆匆收场","content":"一如往年，俄罗斯5月9日为纪念所谓“卫国战争胜利”举行的红场阅兵如期举行。尽管美国总统特朗普在此前一天提议的三天休战停火建议得以让这次阅兵活动没有受到乌克兰军事打击行动的干扰，但阅兵活动也只持续了大约45分钟就匆匆结束，是近20年来最为低调一次阅兵活动，与一年前纪念二战结束80周年阅兵活动的规模形成鲜明反差，从侧面反映出俄罗斯在这场已经持续了四年有余的战争中如今陷入的被动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260509-%E4%BF%84%E7%BD%97%E6%96%AF%E5%8D%AB%E5%9B%BD%E6%88%98%E4%BA%89%E8%83%9C%E5%88%A9%E7%BA%AA%E5%BF%B5%E6%97%A5%E8%BF%91%E4%BA%8C%E5%8D%81%E5%B9%B4%E6%9D%A5%E6%9C%80%E4%BD%8E%E8%B0%83%E9%98%85%E5%85%B5%E5%8C%86%E5%8C%86%E6%94%B6%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778336478000.webp","sourceId":"rfi"},{"id":1778334262000,"createdDate":"2026-05-09 13:44","name":"法国国际广播电台","title":"美国击沉两艘伊朗油轮 等德黑兰回应 伊朗仍在研究","content":"美国周五击沉两艘伊朗油轮，同时表示，正等待德黑兰回应美方最新提出的永久结束敌对行动方案。然而伊朗外交部发言人表示，伊朗仍在研究美国的提议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260509-%E7%BE%8E%E5%9B%BD%E5%87%BB%E6%B2%89%E4%B8%A4%E8%89%98%E4%BC%8A%E6%9C%97%E7%A9%BA%E6%B2%B9%E8%BD%AE-%E7%AD%89%E5%BE%B7%E9%BB%91%E5%85%B0%E5%9B%9E%E5%BA%94-%E4%BC%8A%E6%9C%97%E4%BB%8D%E5%9C%A8%E7%A0%94%E7%A9%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778334262000.webp","sourceId":"rfi"},{"id":1778331605000,"createdDate":"2026-05-09 13:00","name":"法国国际广播电台","title":"特朗普希望俄乌3天停火协议能够延长","content":"美国总特朗普周五深夜表示，他希望由美国斡旋达成的俄罗斯与乌克兰之间为期三天的停火能够得到延长。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260509-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B8%8C%E6%9C%9B%E4%BF%84%E4%B9%8C3%E5%A4%A9%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E8%83%BD%E5%A4%9F%E5%BB%B6%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778331605000.webp","sourceId":"rfi"},{"id":1778330061000,"createdDate":"2026-05-09 12:34","name":"法国国际广播电台","title":"汉坦病毒：谭德塞飞抵西班牙将去加那利群岛协调涉事邮轮撤离乘客","content":"世卫组织总干事谭德塞今天周六上午在X平台发布消息说：我已抵达西班牙，将与政府高级官员一同前往特内里费岛（加纳利群岛之一），监督洪迪乌斯号（MVHondius）邮轮上的乘客和船员及卫生专家安全下船。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260509-%E6%B1%89%E5%9D%A6%E7%97%85%E6%AF%92-%E8%B0%AD%E5%BE%B7%E5%A1%9E%E9%A3%9E%E6%8A%B5%E8%A5%BF%E7%8F%AD%E7%89%99%E5%B0%86%E5%8E%BB%E5%8A%A0%E9%82%A3%E5%88%A9%E7%BE%A4%E5%B2%9B%E5%8D%8F%E8%B0%83%E6%B6%89%E4%BA%8B%E9%82%AE%E8%BD%AE%E6%92%A4%E7%A6%BB%E4%B9%98%E5%AE%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778330061000.webp","sourceId":"rfi"},{"id":1778328327000,"createdDate":"2026-05-09 12:05","name":"法国国际广播电台","title":"首届法非创新与增长峰会前，法国总统马克龙抵埃及启动访非行程","content":"法国总统马克龙9日启程前往埃及，在承载着悠久历史的港口城市亚历山大开始非洲访问行程。在埃及之后，他将于周日抵达肯尼亚首都内罗毕，并在那里出席首届以创新和增长为主题的法非峰会，随后在周三访问埃塞俄比亚之后，结束这次访非行程。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260509-%E9%A6%96%E5%B1%8A%E6%B3%95%E9%9D%9E%E5%88%9B%E6%96%B0%E4%B8%8E%E5%A2%9E%E9%95%BF%E5%B3%B0%E4%BC%9A%E5%89%8D%EF%BC%8C%E6%B3%95%E5%9B%BD%E6%80%BB%E7%BB%9F%E9%A9%AC%E5%85%8B%E9%BE%99%E6%8A%B5%E5%9F%83%E5%8F%8A%E5%90%AF%E5%8A%A8%E8%AE%BF%E9%9D%9E%E8%A1%8C%E7%A8%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778328327000.webp","sourceId":"rfi"},{"id":1778327374000,"createdDate":"2026-05-09 11:49","name":"法国国际广播电台","title":"普京举行“缩小版”二战胜利阅兵式 外国政要寥寥无几","content":"俄罗斯周六举行缩小版二战胜利阅兵式。法新社记者观察到，今天莫斯科市中心的移动互联网无法使用，首都街道几乎空无一人。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260509-%E6%99%AE%E4%BA%AC%E4%B8%BE%E8%A1%8C-%E7%BC%A9%E5%B0%8F%E7%89%88-%E4%BA%8C%E6%88%98%E8%83%9C%E5%88%A9%E9%98%85%E5%85%B5%E5%BC%8F-%E5%A4%96%E5%9B%BD%E6%94%BF%E8%A6%81%E5%AF%A5%E5%AF%A5%E6%97%A0%E5%87%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778327374000.webp","sourceId":"rfi"},{"id":1778324678000,"createdDate":"2026-05-09 11:04","name":"法国国际广播电台","title":"中国出口仍保势头特别是对美实现增长、台湾批准250亿美元预算购买美制武器","content":"大家好，欢迎收听法国报纸摘要，美国总统特朗普周五宣布，俄罗斯与乌克兰从周六起实施为期三天的停火，并表示希望此次停火成为“这场战争走向结束的开端”；除俄乌停火，特朗普还说，预计伊朗将在“今晚”对他提出的永久结束敌对行动的最新提议作出回应。乌战与伊战这两场战争最新进展成为5月9日法国全国性报纸国际版的两大话题。《十字架报》并专访历史学家加利亚·阿克曼，请其分析俄罗斯总统普京是如何将1945年胜利纪念活动转变为其政权支柱的这一转变，并解释了为什么今年的阅兵式以极简形式举行，以他之见认为这象征着如今脆弱的俄罗斯。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260509-%E4%B8%AD%E5%9B%BD%E5%87%BA%E5%8F%A3%E4%BB%8D%E4%BF%9D%E5%8A%BF%E5%A4%B4%E7%89%B9%E5%88%AB%E6%98%AF%E5%AF%B9%E7%BE%8E%E5%AE%9E%E7%8E%B0%E5%A2%9E%E9%95%BF-%E5%8F%B0%E6%B9%BE%E6%89%B9%E5%87%86250%E4%BA%BF%E7%BE%8E%E5%85%83%E9%A2%84%E7%AE%97%E8%B4%AD%E4%B9%B0%E7%BE%8E%E5%88%B6%E6%AD%A6%E5%99%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778324678000.webp","sourceId":"rfi"},{"id":1778315024000,"createdDate":"2026-05-09 08:23","name":"法国国际广播电台","title":"日美印澳“四方安全对话”外长会议将在印度举行","content":"日本时间8日，据多名消息人士透露，日本、美国、澳大利亚和印度正协调于本月下旬在印度首都新德里举行四国合作机制“四方安全对话（Quad）”外长会议。如果此次“四方安全对话”外长会议举行，将是继去年7月在美国华盛顿召开之后再次举行，而在轻视多边框架的特朗普政权之下，已搁置近两年的“四方安全对话”首脑峰会是否重启，十分引人注目。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260509-%E6%97%A5%E7%BE%8E%E5%8D%B0%E6%BE%B3-%E5%9B%9B%E6%96%B9%E5%AE%89%E5%85%A8%E5%AF%B9%E8%AF%9D-%E5%A4%96%E9%95%BF%E4%BC%9A%E8%AE%AE%E5%B0%86%E5%9C%A8%E5%8D%B0%E5%BA%A6%E4%B8%BE%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778315024000.webp","sourceId":"rfi"},{"id":1778361778000,"createdDate":"2026-05-09 21:22","name":"法国国际广播电台","title":"英国向中东部署“龙”号驱逐舰 准备参与多国护航行动","content":"英国政府周六(5月9日）表示，正向中东部署英国皇家海军45型防空驱逐舰“龙”号（HMSDragon），为未来可能展开的多国联合行动做准备，以便在条件允许时保障霍尔木兹海峡航运安全。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260509-%E8%8B%B1%E5%9B%BD%E5%90%91%E4%B8%AD%E4%B8%9C%E9%83%A8%E7%BD%B2-%E9%BE%99-%E5%8F%B7%E9%A9%B1%E9%80%90%E8%88%B0-%E5%87%86%E5%A4%87%E5%8F%82%E4%B8%8E%E5%A4%9A%E5%9B%BD%E6%8A%A4%E8%88%AA%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778361778000.webp","sourceId":"rfi"},{"id":1778361556000,"createdDate":"2026-05-09 21:19","name":"法国国际广播电台","title":"中国交付巴基斯坦首艘潜艇 巴总统赴三亚接艇","content":"巴基斯坦2015年向中国订购8艘配备不依赖空气推进（AIP）系统的潜艇，中国国防部周六(5月9日）证实，已经向巴方交付首艘潜艇，并称这是中巴之间“正常的装备合作”。据巴方称，巴基斯坦总统扎尔达里4月30日亲赴海南三亚军港接艇。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260509-%E4%B8%AD%E5%9B%BD%E4%BA%A4%E4%BB%98%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E9%A6%96%E8%89%98%E6%BD%9C%E8%89%87-%E5%B7%B4%E6%80%BB%E7%BB%9F%E8%B5%B4%E4%B8%89%E4%BA%9A%E6%8E%A5%E8%89%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778361556000.webp","sourceId":"rfi"},{"id":1778361314000,"createdDate":"2026-05-09 21:15","name":"法国国际广播电台","title":"世卫组织：爆发汉坦病毒疫情邮轮全员列为“高风险接触者” 需监测42天","content":"世界卫生组织（WHO）周六(5月9日）表示，在荷兰籍极地邮轮“洪迪厄斯”号（MVHondius）上暴发的汉坦毒疫情，已导致3人死亡、多人感染或疑似感染。世卫组织决定将船上近150名乘客与船员全部列为“高风险接触者”，并建议所有下船人员接受为期42天的主动健康监测。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260509-%E4%B8%96%E5%8D%AB%E7%BB%84%E7%BB%87-%E7%88%86%E5%8F%91%E6%B1%89%E5%9D%A6%E7%97%85%E6%AF%92%E7%96%AB%E6%83%85%E9%82%AE%E8%BD%AE%E5%85%A8%E5%91%98%E5%88%97%E4%B8%BA-%E9%AB%98%E9%A3%8E%E9%99%A9%E6%8E%A5%E8%A7%A6%E8%80%85-%E9%9C%80%E7%9B%91%E6%B5%8B42%E5%A4%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778361314000.webp","sourceId":"rfi"},{"id":1778361035000,"createdDate":"2026-05-09 21:10","name":"法国国际广播电台","title":"匈牙利亲欧派领导人毛焦尔出任总理 终结奥尔班16年执政","content":"匈牙利亲欧洲保守派政治人物、蒂萨党主席彼得·毛焦尔(PeterMagyar)周六(5月9日）正式就任匈牙利总理，宣告持续16年的奥尔班时代落幕，毛焦尔承诺推动“政权更替”，重建法治与民主。欧盟委员会主席冯德莱恩祝贺毛焦尔就任总理表示，匈牙利正在开启“新的篇章\"。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260509-%E5%8C%88%E7%89%99%E5%88%A9%E4%BA%B2%E6%AC%A7%E6%B4%BE%E9%A2%86%E5%AF%BC%E4%BA%BA%E6%AF%9B%E7%84%A6%E5%B0%94%E5%87%BA%E4%BB%BB%E6%80%BB%E7%90%86-%E7%BB%88%E7%BB%93%E5%A5%A5%E5%B0%94%E7%8F%AD16%E5%B9%B4%E6%89%A7%E6%94%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778361035000.webp","sourceId":"rfi"},{"id":1778360780000,"createdDate":"2026-05-09 21:06","name":"法国国际广播电台","title":"普京称乌克兰战争“正接近尾声” 但局势仍然严峻","content":"俄罗斯总统普京周六(5月9日）表示，他认为持续超过四年的乌克兰战争“正接近尾声”，但普京同时警告局势依然“严峻”，并再次批评西方国家持续向乌克兰提供支持。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260509-%E6%99%AE%E4%BA%AC%E7%A7%B0%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E4%BA%89-%E6%AD%A3%E6%8E%A5%E8%BF%91%E5%B0%BE%E5%A3%B0-%E4%BD%86%E5%B1%80%E5%8A%BF%E4%BB%8D%E7%84%B6%E4%B8%A5%E5%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778360780000.webp","sourceId":"rfi"},{"id":1778358359000,"createdDate":"2026-05-09 20:25","name":"法国国际广播电台","title":"德国民调：默茨支持率跌至历史低谷，选项党首次超越联盟党","content":"据慕尼黑《墨丘利报》报道：德国黑红联合政府执政满一年之际，德国民众对政府的情绪跌至历史低点。根据Infratestdimap为德国电视一台（ARD）所做的“德国趋势”（Deutschlandtrend）民调，目前仅有13%的德国民众对政府感到满意，六分之五的人表示不满。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260509-%E5%BE%B7%E5%9B%BD%E6%B0%91%E8%B0%83-%E9%BB%98%E8%8C%A8%E6%94%AF%E6%8C%81%E7%8E%87%E8%B7%8C%E8%87%B3%E5%8E%86%E5%8F%B2%E4%BD%8E%E8%B0%B7%EF%BC%8C%E9%80%89%E9%A1%B9%E5%85%9A%E9%A6%96%E6%AC%A1%E8%B6%85%E8%B6%8A%E8%81%94%E7%9B%9F%E5%85%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778358359000.webp","sourceId":"rfi"},{"id":1778357918000,"createdDate":"2026-05-09 20:18","name":"法国国际广播电台","title":"巴黎警察星期六逮捕违禁示威的极左翼和极右翼人士","content":"据法新社从巴黎警察局获悉，周六在巴黎，39名示威者分别因违禁参加法国极右翼团体举行示威活动， 违禁参加反法西斯示威活动被捕。根据下午6点30分的最新统计，执法部门在巴黎各处，包括共和国广场、金字塔广场、圣米歇尔广场和蒙帕纳斯广场，共抓住了94人，其中39人被拘留，这些人既有极右翼也有极左翼活动人士。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260509-%E5%B7%B4%E9%BB%8E%E8%AD%A6%E5%AF%9F%E6%98%9F%E6%9C%9F%E5%85%AD%E9%80%AE%E6%8D%95%E8%BF%9D%E7%A6%81%E7%A4%BA%E5%A8%81%E7%9A%84%E6%9E%81%E5%B7%A6%E7%BF%BC%E5%92%8C%E6%9E%81%E5%8F%B3%E7%BF%BC%E8%AE%A4%E8%AF%86","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778357918000.webp","sourceId":"rfi"},{"id":1778357582000,"createdDate":"2026-05-09 20:13","name":"法国国际广播电台","title":"以色列无人机在黎巴嫩瞄准女孩， 黎以下周在华盛顿会谈","content":"以色列周六对黎巴嫩南部发动空袭，造成8人死亡。此外，以色列还对贝鲁特以南的一条高速公路发动了更多空袭，法新社说，这个地点位于真主党传统据点之外，远离持续冲突的中心地带。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260509-%E4%BB%A5%E8%89%B2%E5%88%97%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%9C%A8%E9%BB%8E%E5%B7%B4%E5%AB%A9%E7%9E%84%E5%87%86%E5%A5%B3%E5%AD%A9%EF%BC%8C-%E9%BB%8E%E4%BB%A5%E4%B8%8B%E5%91%A8%E5%9C%A8%E5%8D%8E%E7%9B%9B%E9%A1%BF%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/09/1778357582000.webp","sourceId":"rfi"}]