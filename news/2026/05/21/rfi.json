[{"id":1779354704000,"createdDate":"2026-05-21 09:11","name":"法国国际广播电台","title":"巴勒斯坦影片《昨日眼未阖》竞赛一种注目单元","content":"戛纳影节第八天的下午，在电影宫的德彪西展厅，放映了一种注目单元的一部竞赛片《昨日眼未阖》。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260521-%E5%B7%B4%E5%8B%92%E6%96%AF%E5%9D%A6%E5%BD%B1%E7%89%87-%E6%98%A8%E6%97%A5%E7%9C%BC%E6%9C%AA%E9%98%96-%E7%AB%9E%E8%B5%9B%E4%B8%80%E7%A7%8D%E6%B3%A8%E7%9B%AE%E5%8D%95%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779354704000.webp","sourceId":"rfi"},{"id":1779354498000,"createdDate":"2026-05-21 09:08","name":"法国国际广播电台","title":"大马就TikTok涉未能审核有关最高元首的冒犯性内容向其发出法定要求","content":"马来西亚通信与多媒体委员会（MCMC）周四表示，已向社交媒体平台TikTok发出法定要求，指控其未能及时有效地审核平台上针对马来西亚王室的冒犯性和诽谤性内容。该委员会在一份声明中指出，此次行动源于一个据称与马来西亚最高元首易卜拉欣有关的账户传播相关内容。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260521-%E5%A4%A7%E9%A9%AC%E5%B0%B1tiktok%E6%B6%89%E6%9C%AA%E8%83%BD%E5%AE%A1%E6%A0%B8%E6%9C%89%E5%85%B3%E6%9C%80%E9%AB%98%E5%85%83%E9%A6%96%E7%9A%84%E5%86%92%E7%8A%AF%E6%80%A7%E5%86%85%E5%AE%B9%E5%90%91%E5%85%B6%E5%8F%91%E5%87%BA%E6%B3%95%E5%AE%9A%E8%A6%81%E6%B1%82","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779354498000.webp","sourceId":"rfi"},{"id":1779352899000,"createdDate":"2026-05-21 08:41","name":"法国国际广播电台","title":"达尔文港中国业主提交国际仲裁进行抵制 澳大利亚表示“失望”","content":"澳大利亚国防部长马尔斯今天周四表示，堪培拉对战略要地达尔文港的中国承租方阻挠将其归还澳大利亚感到“失望”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260521-%E8%BE%BE%E5%B0%94%E6%96%87%E6%B8%AF%E4%B8%AD%E5%9B%BD%E4%B8%9A%E4%B8%BB%E6%8F%90%E4%BA%A4%E5%9B%BD%E9%99%85%E4%BB%B2%E8%A3%81%E8%BF%9B%E8%A1%8C%E6%8A%B5%E5%88%B6-%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E8%A1%A8%E7%A4%BA-%E5%A4%B1%E6%9C%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779352899000.webp","sourceId":"rfi"},{"id":1779352298000,"createdDate":"2026-05-21 08:31","name":"法国国际广播电台","title":"大国握手言欢 小国谨慎观望","content":"在过去短短一周内，美国、俄罗斯最高领导人先后到访北京。国际舆论将大国关系与国际秩序话题推向全球视野。与此同时，各方依然高度关注撼动全球航运与能源供应链的伊朗局势。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260521-%E5%A4%A7%E5%9B%BD%E6%8F%A1%E6%89%8B%E8%A8%80%E6%AC%A2-%E5%B0%8F%E5%9B%BD%E8%B0%A8%E6%85%8E%E8%A7%82%E6%9C%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779352298000.webp","sourceId":"rfi"},{"id":1779351776000,"createdDate":"2026-05-21 08:22","name":"法国国际广播电台","title":"日本反驳中俄联合声明严厉批判日本","content":"日本内阁官房副长官尾崎正直21日在记者会上，就中国和俄罗斯首脑在联合声明中以“新军国主义”等措辞批评日本一事反驳称：“中俄的主张完全站不住脚。”","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260521-%E6%97%A5%E6%9C%AC%E5%8F%8D%E9%A9%B3%E4%B8%AD%E4%BF%84%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E%E4%B8%A5%E5%8E%89%E6%89%B9%E5%88%A4%E6%97%A5%E6%9C%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779351776000.webp","sourceId":"rfi"},{"id":1779351746000,"createdDate":"2026-05-21 08:22","name":"法国国际广播电台","title":"习近平据报最早下周访问朝鲜 中国安全礼宾团队已预先准备","content":"中国国家主席习近平最近在与美国总统特朗普的峰会上讨论了朝鲜核问题，他极有可能最早于下周访问朝鲜。据韩联社报导，一位高级政府官员周三透露称，“有情报显示，习近平很快将访问朝鲜”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260521-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%9C%80%E6%97%A9%E4%B8%8B%E5%91%A8%E8%AE%BF%E9%97%AE%E6%9C%9D%E9%B2%9C-%E4%B8%AD%E5%9B%BD%E5%AE%89%E5%85%A8%E7%A4%BC%E5%AE%BE%E5%9B%A2%E9%98%9F%E5%B7%B2%E9%A2%84%E5%85%88%E5%87%86%E5%A4%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779351746000.webp","sourceId":"rfi"},{"id":1779351565000,"createdDate":"2026-05-21 08:19","name":"法国国际广播电台","title":"特朗普可能与赖清德通话，或将是1979年来美台领导人首次直接沟通","content":"美国总统特朗普周三（5月21日）表示，他将与台湾总统赖清德通话。台湾当局对此立即表示欢迎。如果双方真的通话，这将是自1979年以来双方领导人首次直接通话。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260521-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%AF%E8%83%BD%E4%B8%8E%E8%B5%96%E6%B8%85%E5%BE%B7%E9%80%9A%E8%AF%9D%EF%BC%8C%E6%88%96%E5%B0%86%E6%98%AF1979%E5%B9%B4%E6%9D%A5%E7%BE%8E%E5%8F%B0%E9%A2%86%E5%AF%BC%E4%BA%BA%E9%A6%96%E6%AC%A1%E7%9B%B4%E6%8E%A5%E6%B2%9F%E9%80%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779351565000.webp","sourceId":"rfi"},{"id":1779346571000,"createdDate":"2026-05-21 06:56","name":"法国国际广播电台","title":"港府称新田科技城能创2500亿贡献GDP 超越全港商界 遭亲政府议员质疑","content":"被写入「十五五」规划的「北部都会区」发展计划(下称「北都」)，已成港府必须执行的「硬任务」。港府以「北都」发展项目之一的新田科技城，全面运作后可望每年为香港带来2500亿港元(下同，折算约282亿欧元)的本地生产总值(GDP），向立法会申请拨款，注资入一间公司以推动该区发展。不过，有关估计连亲政府议员也质疑是「过份乐观」；有评论更忧虑，港府采取与中国地方政府依靠融资发债相似的方式发展「北都」，最终会耗尽香港库房。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260521-%E6%B8%AF%E5%BA%9C%E7%A7%B0%E6%96%B0%E7%94%B0%E7%A7%91%E6%8A%80%E5%9F%8E%E8%83%BD%E5%88%9B2500%E4%BA%BF%E8%B4%A1%E7%8C%AEgdp-%E8%B6%85%E8%B6%8A%E5%85%A8%E6%B8%AF%E5%95%86%E7%95%8C-%E9%81%AD%E4%BA%B2%E6%94%BF%E5%BA%9C%E8%AE%AE%E5%91%98%E8%B4%A8%E7%96%91","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779346571000.webp","sourceId":"rfi"}]