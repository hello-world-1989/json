[{"id":1779354704000,"createdDate":"2026-05-21 09:11","name":"法国国际广播电台","title":"巴勒斯坦影片《昨日眼未阖》竞赛一种注目单元","content":"戛纳影节第八天的下午，在电影宫的德彪西展厅，放映了一种注目单元的一部竞赛片《昨日眼未阖》。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260521-%E5%B7%B4%E5%8B%92%E6%96%AF%E5%9D%A6%E5%BD%B1%E7%89%87-%E6%98%A8%E6%97%A5%E7%9C%BC%E6%9C%AA%E9%98%96-%E7%AB%9E%E8%B5%9B%E4%B8%80%E7%A7%8D%E6%B3%A8%E7%9B%AE%E5%8D%95%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779354704000.webp","sourceId":"rfi"},{"id":1779354498000,"createdDate":"2026-05-21 09:08","name":"法国国际广播电台","title":"大马就TikTok涉未能审核有关最高元首的冒犯性内容向其发出法定要求","content":"马来西亚通信与多媒体委员会（MCMC）周四表示，已向社交媒体平台TikTok发出法定要求，指控其未能及时有效地审核平台上针对马来西亚王室的冒犯性和诽谤性内容。该委员会在一份声明中指出，此次行动源于一个据称与马来西亚最高元首易卜拉欣有关的账户传播相关内容。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260521-%E5%A4%A7%E9%A9%AC%E5%B0%B1tiktok%E6%B6%89%E6%9C%AA%E8%83%BD%E5%AE%A1%E6%A0%B8%E6%9C%89%E5%85%B3%E6%9C%80%E9%AB%98%E5%85%83%E9%A6%96%E7%9A%84%E5%86%92%E7%8A%AF%E6%80%A7%E5%86%85%E5%AE%B9%E5%90%91%E5%85%B6%E5%8F%91%E5%87%BA%E6%B3%95%E5%AE%9A%E8%A6%81%E6%B1%82","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779354498000.webp","sourceId":"rfi"},{"id":1779352899000,"createdDate":"2026-05-21 08:41","name":"法国国际广播电台","title":"达尔文港中国业主提交国际仲裁进行抵制 澳大利亚表示“失望”","content":"澳大利亚国防部长马尔斯今天周四表示，堪培拉对战略要地达尔文港的中国承租方阻挠将其归还澳大利亚感到“失望”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260521-%E8%BE%BE%E5%B0%94%E6%96%87%E6%B8%AF%E4%B8%AD%E5%9B%BD%E4%B8%9A%E4%B8%BB%E6%8F%90%E4%BA%A4%E5%9B%BD%E9%99%85%E4%BB%B2%E8%A3%81%E8%BF%9B%E8%A1%8C%E6%8A%B5%E5%88%B6-%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E8%A1%A8%E7%A4%BA-%E5%A4%B1%E6%9C%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779352899000.webp","sourceId":"rfi"},{"id":1779352298000,"createdDate":"2026-05-21 08:31","name":"法国国际广播电台","title":"大国握手言欢 小国谨慎观望","content":"在过去短短一周内，美国、俄罗斯最高领导人先后到访北京。国际舆论将大国关系与国际秩序话题推向全球视野。与此同时，各方依然高度关注撼动全球航运与能源供应链的伊朗局势。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260521-%E5%A4%A7%E5%9B%BD%E6%8F%A1%E6%89%8B%E8%A8%80%E6%AC%A2-%E5%B0%8F%E5%9B%BD%E8%B0%A8%E6%85%8E%E8%A7%82%E6%9C%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779352298000.webp","sourceId":"rfi"},{"id":1779351776000,"createdDate":"2026-05-21 08:22","name":"法国国际广播电台","title":"日本反驳中俄联合声明严厉批判日本","content":"日本内阁官房副长官尾崎正直21日在记者会上，就中国和俄罗斯首脑在联合声明中以“新军国主义”等措辞批评日本一事反驳称：“中俄的主张完全站不住脚。”","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260521-%E6%97%A5%E6%9C%AC%E5%8F%8D%E9%A9%B3%E4%B8%AD%E4%BF%84%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E%E4%B8%A5%E5%8E%89%E6%89%B9%E5%88%A4%E6%97%A5%E6%9C%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779351776000.webp","sourceId":"rfi"},{"id":1779351746000,"createdDate":"2026-05-21 08:22","name":"法国国际广播电台","title":"习近平据报最早下周访问朝鲜 中国安全礼宾团队已预先准备","content":"中国国家主席习近平最近在与美国总统特朗普的峰会上讨论了朝鲜核问题，他极有可能最早于下周访问朝鲜。据韩联社报导，一位高级政府官员周三透露称，“有情报显示，习近平很快将访问朝鲜”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260521-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%9C%80%E6%97%A9%E4%B8%8B%E5%91%A8%E8%AE%BF%E9%97%AE%E6%9C%9D%E9%B2%9C-%E4%B8%AD%E5%9B%BD%E5%AE%89%E5%85%A8%E7%A4%BC%E5%AE%BE%E5%9B%A2%E9%98%9F%E5%B7%B2%E9%A2%84%E5%85%88%E5%87%86%E5%A4%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779351746000.webp","sourceId":"rfi"},{"id":1779351565000,"createdDate":"2026-05-21 08:19","name":"法国国际广播电台","title":"特朗普可能与赖清德通话，或将是1979年来美台领导人首次直接沟通","content":"美国总统特朗普周三（5月21日）表示，他将与台湾总统赖清德通话。台湾当局对此立即表示欢迎。如果双方真的通话，这将是自1979年以来双方领导人首次直接通话。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260521-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%AF%E8%83%BD%E4%B8%8E%E8%B5%96%E6%B8%85%E5%BE%B7%E9%80%9A%E8%AF%9D%EF%BC%8C%E6%88%96%E5%B0%86%E6%98%AF1979%E5%B9%B4%E6%9D%A5%E7%BE%8E%E5%8F%B0%E9%A2%86%E5%AF%BC%E4%BA%BA%E9%A6%96%E6%AC%A1%E7%9B%B4%E6%8E%A5%E6%B2%9F%E9%80%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779351565000.webp","sourceId":"rfi"},{"id":1779346571000,"createdDate":"2026-05-21 06:56","name":"法国国际广播电台","title":"港府称新田科技城能创2500亿贡献GDP 超越全港商界 遭亲政府议员质疑","content":"被写入「十五五」规划的「北部都会区」发展计划(下称「北都」)，已成港府必须执行的「硬任务」。港府以「北都」发展项目之一的新田科技城，全面运作后可望每年为香港带来2500亿港元(下同，折算约282亿欧元)的本地生产总值(GDP），向立法会申请拨款，注资入一间公司以推动该区发展。不过，有关估计连亲政府议员也质疑是「过份乐观」；有评论更忧虑，港府采取与中国地方政府依靠融资发债相似的方式发展「北都」，最终会耗尽香港库房。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260521-%E6%B8%AF%E5%BA%9C%E7%A7%B0%E6%96%B0%E7%94%B0%E7%A7%91%E6%8A%80%E5%9F%8E%E8%83%BD%E5%88%9B2500%E4%BA%BF%E8%B4%A1%E7%8C%AEgdp-%E8%B6%85%E8%B6%8A%E5%85%A8%E6%B8%AF%E5%95%86%E7%95%8C-%E9%81%AD%E4%BA%B2%E6%94%BF%E5%BA%9C%E8%AE%AE%E5%91%98%E8%B4%A8%E7%96%91","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779346571000.webp","sourceId":"rfi"},{"id":1779377406000,"createdDate":"2026-05-21 15:30","name":"法国国际广播电台","title":"克宫：普京向习近平提出将伊朗浓缩铀运往俄罗斯 习分享了特朗普访华情况","content":"俄罗斯总统新闻秘书佩斯科夫周四向记者透露称，中国国家主席习近平在与到访的俄总统普京的一次非正式茶话会上，就美国总统特朗普近期访华的情况交换了意见。他补充说，两位领导人还讨论了伊朗问题。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260521-%E5%85%8B%E5%AE%AB-%E6%99%AE%E4%BA%AC%E5%90%91%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%8F%90%E5%87%BA%E5%B0%86%E4%BC%8A%E6%9C%97%E6%B5%93%E7%BC%A9%E9%93%80%E8%BF%90%E5%BE%80%E4%BF%84%E7%BD%97%E6%96%AF-%E4%B9%A0%E5%88%86%E4%BA%AB%E4%BA%86%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E6%83%85%E5%86%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779377406000.webp","sourceId":"rfi"},{"id":1779376688000,"createdDate":"2026-05-21 15:18","name":"法国国际广播电台","title":"部署电子部队、防空导弹：位于中日角力前线的日本与那国岛","content":"位于日本最西端的小岛与那国岛，距离台湾仅110公里，在天气晴朗时，人们甚至可以在岛上直接望见台湾。随着台海局势升温，以及中日间围绕安全问题的紧张关系不断加剧，这里正逐渐成为日本最敏感的前线之一。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260521-%E9%83%A8%E7%BD%B2%E7%94%B5%E5%AD%90%E9%83%A8%E9%98%9F-%E9%98%B2%E7%A9%BA%E5%AF%BC%E5%BC%B9-%E4%BD%8D%E4%BA%8E%E4%B8%AD%E6%97%A5%E8%A7%92%E5%8A%9B%E6%9C%80%E5%89%8D%E7%BA%BF%E7%9A%84%E6%97%A5%E6%9C%AC%E4%B8%8E%E9%82%A3%E5%9B%BD%E5%B2%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779376688000.webp","sourceId":"rfi"},{"id":1779376394000,"createdDate":"2026-05-21 15:13","name":"法国国际广播电台","title":"俄交通部长称俄中准备在无人技术领域开展合作 克宫拒就俄军人在华受训报道置评","content":"俄罗斯总统新闻秘书佩斯科夫周四拒绝就西方媒体关于数百名俄罗斯军人据称在中国接受训练的报道置评。佩斯科夫在一次简报会上回答相关提问时称，“不，我无法置评。欧美报纸刊登了大量虚假信息。这是我们面临的一个问题。在处理此类虚假信息时，我们需要非常谨慎”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260521-%E4%BF%84%E4%BA%A4%E9%80%9A%E9%83%A8%E9%95%BF%E7%A7%B0%E4%BF%84%E4%B8%AD%E5%87%86%E5%A4%87%E5%9C%A8%E6%97%A0%E4%BA%BA%E6%8A%80%E6%9C%AF%E9%A2%86%E5%9F%9F%E5%BC%80%E5%B1%95%E5%90%88%E4%BD%9C-%E5%85%8B%E5%AE%AB%E6%8B%92%E5%B0%B1%E4%BF%84%E5%86%9B%E4%BA%BA%E5%9C%A8%E5%8D%8E%E5%8F%97%E8%AE%AD%E6%8A%A5%E9%81%93%E7%BD%AE%E8%AF%84","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779376394000.webp","sourceId":"rfi"},{"id":1779376341000,"createdDate":"2026-05-21 15:12","name":"法国国际广播电台","title":"第十届世界无人机大会在深圳开幕","content":"20265月21日至23日，2026第十届世界无人机大会暨国际低空经济与无人系统博览会在深圳开幕。在三天的时间里，全球100多个国家的1200多家企业在这里展示上万款无人飞行器或衍生产品。深圳再次成为世界无人机之都。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260521-%E7%AC%AC%E5%8D%81%E5%B1%8A%E4%B8%96%E7%95%8C%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%A4%A7%E4%BC%9A%E5%9C%A8%E6%B7%B1%E5%9C%B3%E5%BC%80%E5%B9%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779376341000.webp","sourceId":"rfi"},{"id":1779374519000,"createdDate":"2026-05-21 14:41","name":"法国国际广播电台","title":"电影如何能远离政治？","content":"2026法国戛纳电影节期间围绕法国富豪文森-博洛雷对文化创作独立性的影响的舆论风波重新将文化创作与政治的关系提上舆论前台。电影是否应当远离政治？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%89%B9%E5%88%AB%E8%8A%82%E7%9B%AE/20260521-2026%E6%88%9B%E7%BA%B3%E7%94%B5%E5%BD%B1%E8%8A%82-%E7%94%B5%E5%BD%B1%E5%A6%82%E4%BD%95%E8%83%BD%E8%BF%9C%E7%A6%BB%E6%94%BF%E6%B2%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779374519000.webp","sourceId":"rfi"},{"id":1779373348000,"createdDate":"2026-05-21 14:22","name":"法国国际广播电台","title":"北京：若欧方出台贸易新工具，中方将坚决反制 卡拉斯将中国带来的经济挑战比作“癌症”","content":"就媒体报道，欧盟委员会正在抓紧制定一项新贸易工具，以应对中国产能过剩问题的消息，中国商务部新闻发言人何亚东在周四举行的例行新闻发布会上表示，如欧方执意推动出台所谓新工具并对中国企业或产品采取歧视性限制措施，中方将坚决反制。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260521-%E5%8C%97%E4%BA%AC-%E8%8B%A5%E6%AC%A7%E6%96%B9%E5%87%BA%E5%8F%B0%E8%B4%B8%E6%98%93%E6%96%B0%E5%B7%A5%E5%85%B7%EF%BC%8C%E4%B8%AD%E6%96%B9%E5%B0%86%E5%9D%9A%E5%86%B3%E5%8F%8D%E5%88%B6-%E5%8D%A1%E6%8B%89%E6%96%AF%E5%B0%86%E4%B8%AD%E5%9B%BD%E5%B8%A6%E6%9D%A5%E7%9A%84%E7%BB%8F%E6%B5%8E%E6%8C%91%E6%88%98%E6%AF%94%E4%BD%9C-%E7%99%8C%E7%97%87","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779373348000.webp","sourceId":"rfi"},{"id":1779367851000,"createdDate":"2026-05-21 12:50","name":"法国国际广播电台","title":"美国因何以历史旧案起诉古巴前领导人劳尔-卡斯特罗？","content":"美国司法部20日宣布针对1996年发生的一起两架民用飞机被古巴战机击落事件，控告古巴前领导人劳尔-卡斯特罗谋杀美国人罪名。中国外交部21日就此表示，反对滥用司法手段，反对外国势力对古巴施加压力。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260521-%E7%BE%8E%E5%9B%BD%E5%9B%A0%E4%BD%95%E4%BB%A5%E5%8E%86%E5%8F%B2%E6%97%A7%E6%A1%88%E8%B5%B7%E8%AF%89%E5%8F%A4%E5%B7%B4%E5%89%8D%E6%80%BB%E7%BB%9F%E5%8A%B3%E5%B0%94-%E5%8D%A1%E6%96%AF%E7%89%B9%E7%BD%97","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779367851000.webp","sourceId":"rfi"},{"id":1779366534000,"createdDate":"2026-05-21 12:28","name":"法国国际广播电台","title":"车企担忧供应链混乱 欧盟拟暂时解除对一涉俄中国半导体供应商的制裁","content":"彭博社报导指，欧盟将提议暂时解除对一家中国半导体供应商的制裁，此前汽车制造商警告称，如不解除制裁，将导致供应链混乱。据知情人士透露，欧盟委员会最早将于本周提出这项豁免提议。此举的实施需要欧盟27个成员国的批准。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260521-%E8%BD%A6%E4%BC%81%E6%8B%85%E5%BF%A7%E4%BE%9B%E5%BA%94%E9%93%BE%E6%B7%B7%E4%B9%B1-%E6%AC%A7%E7%9B%9F%E6%8B%9F%E6%9A%82%E6%97%B6%E8%A7%A3%E9%99%A4%E5%AF%B9%E4%B8%80%E6%B6%89%E4%BF%84%E4%B8%AD%E5%9B%BD%E5%8D%8A%E5%AF%BC%E4%BD%93%E4%BE%9B%E5%BA%94%E5%95%86%E7%9A%84%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779366534000.webp","sourceId":"rfi"},{"id":1779364071000,"createdDate":"2026-05-21 11:47","name":"法国国际广播电台","title":"伊朗最高领袖据报已下令要求浓缩铀库存必须留在国内","content":"据路透社援引两名伊朗高级消息人士报导称，伊朗最高领袖穆杰塔巴已下令禁止将该国接近武器级的铀运往国外，此举表明德黑兰当局在和平谈判中对美方的主要要求之一持更加强硬的立场。穆杰塔巴的这项命令可能会进一步令美国总统特朗普（DonaldTrump）感到沮丧，并使结束美以对伊战争的谈判更加复杂。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260521-%E4%BC%8A%E6%9C%97%E6%9C%80%E9%AB%98%E9%A2%86%E8%A2%96%E6%8D%AE%E6%8A%A5%E5%B7%B2%E4%B8%8B%E4%BB%A4%E8%A6%81%E6%B1%82%E6%B5%93%E7%BC%A9%E9%93%80%E5%BA%93%E5%AD%98%E5%BF%85%E9%A1%BB%E7%95%99%E5%9C%A8%E5%9B%BD%E5%86%85","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779364071000.webp","sourceId":"rfi"},{"id":1779361783000,"createdDate":"2026-05-21 11:09","name":"法国国际广播电台","title":"在北京，习近平与普京共同演绎了一场“失衡”的“默契”","content":"大家好，欢迎收听法国报纸摘要。今天5月21日《费加罗报》与《回声报》继续评析普京与习近平举行峰会对外展示的信息：中国正将自身置于国际博弈的中心。《十字架报》头版话题则是战火下的加沙地带学童教育被严重拖延。戛纳电影节也进入高潮《解放报》以角逐金棕榈的法国影片《我们的救赎》作为封面焦点。表示导演埃马纽埃尔·马雷以既细腻又犀利的镜头语言，深入描绘了维希政权时期，一位逐渐堕入卑劣深渊的官僚祖父，用审视的目光剖析了那段通敌的历史……","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260521-%E5%9C%A8%E5%8C%97%E4%BA%AC%EF%BC%8C%E4%B9%A0%E8%BF%91%E5%B9%B3%E4%B8%8E%E6%99%AE%E4%BA%AC%E5%85%B1%E5%90%8C%E6%BC%94%E7%BB%8E%E4%BA%86%E4%B8%80%E5%9C%BA-%E5%A4%B1%E8%A1%A1-%E7%9A%84-%E9%BB%98%E5%A5%91","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779361783000.webp","sourceId":"rfi"},{"id":1779359999000,"createdDate":"2026-05-21 10:39","name":"法国国际广播电台","title":"五角大楼要员今夏访华计划被迫搁置 中方指看特朗普是否推进140亿美元对台军售","content":"据英国《金融时报》报导称，由于中国就价值140亿美元的对台军售案向美国总统特朗普施压，中方搁置了美国战争部负责政策事务的副部长科尔比（ElbridgeColby）的访华计划。该报援引知情人士报导称，科尔比已与中国官员讨论了夏季访问北京的事宜。但中方已表示，在特朗普决定如何处理上述对台军售案前，中方不会同意此次访问。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260521-%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC%E8%A6%81%E5%91%98%E4%BB%8A%E5%A4%8F%E8%AE%BF%E5%8D%8E%E8%AE%A1%E5%88%92%E8%A2%AB%E8%BF%AB%E6%90%81%E7%BD%AE-%E4%B8%AD%E6%96%B9%E6%8C%87%E7%9C%8B%E7%89%B9%E6%9C%97%E6%99%AE%E6%98%AF%E5%90%A6%E6%8E%A8%E8%BF%9B140%E4%BA%BF%E7%BE%8E%E5%85%83%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779359999000.webp","sourceId":"rfi"},{"id":1779357108000,"createdDate":"2026-05-21 09:51","name":"法国国际广播电台","title":"台总统府：未接获特赖通话讯息，台美沟通畅通无阻 北京：坚决反对美台开展官方往来","content":"美国总统特朗普（DonaldTrump）周三向媒体表示，他会与台湾总统赖清德通话。当被问及在决定是否批准对台出售美国国会批准的一项重大军售前致电赖清德时，特朗普当天在马里兰州安德鲁斯联合基地告诉记者：“我会和他谈谈”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260521-%E5%8F%B0%E6%80%BB%E7%BB%9F%E5%BA%9C-%E6%9C%AA%E6%8E%A5%E8%8E%B7%E7%89%B9%E8%B5%96%E9%80%9A%E8%AF%9D%E8%AE%AF%E6%81%AF%EF%BC%8C%E5%8F%B0%E7%BE%8E%E6%B2%9F%E9%80%9A%E7%95%85%E9%80%9A%E6%97%A0%E9%98%BB-%E5%8C%97%E4%BA%AC-%E5%9D%9A%E5%86%B3%E5%8F%8D%E5%AF%B9%E7%BE%8E%E5%8F%B0%E5%BC%80%E5%B1%95%E5%AE%98%E6%96%B9%E5%BE%80%E6%9D%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/21/1779357108000.webp","sourceId":"rfi"}]