[{"id":1780074964000,"createdDate":"2026-05-29 17:16","name":"法国国际广播电台","title":"习近平与金正恩又要见面了吗？","content":"5月14日至15日和20日在北京与美国总统特朗普和俄罗斯总统普京举行了峰会后，中国国家主席习近平似乎正在筹备未来几周对平壤进行国事访问。如果成形，这将是他2026年的首次出访。分析认为，将平壤放在习近平今年访问行程的象征性顶端的意义在于，即纠正了西方关于平壤在乌克兰战争期间永久滑入莫斯科势力范围的说法，同时也将北京定位为地区格局的主要仲裁者。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260529-%E4%B9%A0%E8%BF%91%E5%B9%B3%E4%B8%8E%E9%87%91%E6%AD%A3%E6%81%A9%E5%8F%88%E8%A6%81%E8%A7%81%E9%9D%A2%E4%BA%86%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780074964000.webp","sourceId":"rfi"},{"id":1780068975000,"createdDate":"2026-05-29 15:36","name":"法国国际广播电台","title":"美前防长埃斯珀：预计澳大利亚会在台海冲突中助美发挥作用，已探讨多年","content":"曾在美国总统特朗普第一任期内担任国防部长的埃斯珀（MarkEsper）近日在受访时表示，若中国对台动武，预计澳大利亚届时将协助美国，发挥一定作用，并称美澳这两个盟国多年来一直在讨论这种可能性。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260529-%E7%BE%8E%E5%89%8D%E9%98%B2%E9%95%BF%E5%9F%83%E6%96%AF%E7%8F%80-%E9%A2%84%E8%AE%A1%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E4%BC%9A%E5%9C%A8%E5%8F%B0%E6%B5%B7%E5%86%B2%E7%AA%81%E4%B8%AD%E5%8A%A9%E7%BE%8E%E5%8F%91%E6%8C%A5%E4%BD%9C%E7%94%A8%EF%BC%8C%E5%B7%B2%E6%8E%A2%E8%AE%A8%E5%A4%9A%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780068975000.webp","sourceId":"rfi"},{"id":1780068895000,"createdDate":"2026-05-29 15:34","name":"法国国际广播电台","title":"英伟达宣布将每年在台湾投资一千五百亿美元","content":"当前人工智能领域的领军企业英伟达宣布要加码投资台湾，并在台北建设英伟达台湾总部。2026年5月27日，英伟达首席执行官黄仁勋在台北出席新总部计划动员大会，向上千名与会员工发放礼品。黄仁勋认为，台湾不仅是人工智能的中心，而且在未来很长时间里，仍将是世界高科技生产中心。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260529-%E8%8B%B1%E4%BC%9F%E8%BE%BE%E5%AE%A3%E5%B8%83%E5%B0%86%E6%AF%8F%E5%B9%B4%E5%9C%A8%E5%8F%B0%E6%B9%BE%E6%8A%95%E8%B5%84%E4%B8%80%E5%8D%83%E4%BA%94%E7%99%BE%E4%BA%BF%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780068895000.webp","sourceId":"rfi"},{"id":1780065178000,"createdDate":"2026-05-29 14:32","name":"法国国际广播电台","title":"港记协前主席陈朗昇上诉失败 阻差办公罪成须即时入狱五天","content":"香港记者协会时任主席陈朗昇，年前采访被截查时，因反问警方截查理由及查问便衣警员身份，被裁定阻差办公罪成判囚，今日上诉失败后，须即时入狱五天。他是第一位在任记协主席因新闻工作被判入狱的，却是2019年反修例运动以来，至少第十五名入狱的新闻工作者。陈朗升在法庭作出裁决前表示，心情忐忑，更质问香港小宪法中承诺的新闻自由在哪？记协对裁决深感遗憾，主席郑嘉如认为，裁决令依法行使诘问执法者公民权利之人须冒极大风险，若此，相关权利便是名存实亡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260529-%E6%B8%AF%E8%AE%B0%E5%8D%8F%E5%89%8D%E4%B8%BB%E5%B8%AD%E9%99%88%E6%9C%97%E6%98%87%E4%B8%8A%E8%AF%89%E5%A4%B1%E8%B4%A5-%E9%98%BB%E5%B7%AE%E5%8A%9E%E5%85%AC%E7%BD%AA%E6%88%90%E9%A1%BB%E5%8D%B3%E6%97%B6%E5%85%A5%E7%8B%B1%E4%BA%94%E5%A4%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780065178000.webp","sourceId":"rfi"},{"id":1780064482000,"createdDate":"2026-05-29 14:21","name":"法国国际广播电台","title":"加强对日投资审查 日本版美国外国投资委员会获绿灯","content":"自东京方面消息，旨在加强审查海外企业和投资者对日投资的《外汇及外国贸易法》修正案周五（29日）在日本参院全体会议上，凭借执政党等多数赞成获得通过，正式成为法律。其主要内容是创设负责事前审查工作的“对日外国投资委员会”，即日本版美国外国投资委员会（CFIUS），自民党和日本维新会的联合执政协议中包括了这一内容。目的是仿效美国外国投资委员会的跨部门合作，防止重要基建和核心技术外流，从而加强经济安保。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260529-%E5%8A%A0%E5%BC%BA%E5%AF%B9%E6%97%A5%E6%8A%95%E8%B5%84%E5%AE%A1%E6%9F%A5-%E6%97%A5%E6%9C%AC%E7%89%88%E7%BE%8E%E5%9B%BD%E5%A4%96%E5%9B%BD%E6%8A%95%E8%B5%84%E5%A7%94%E5%91%98%E4%BC%9A%E8%8E%B7%E7%BB%BF%E7%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780064482000.webp","sourceId":"rfi"},{"id":1780064253000,"createdDate":"2026-05-29 14:17","name":"法国国际广播电台","title":"美印太司令寻求国会批准预算 促在台湾问题上遏制中国","content":"美国印太司令帕帕罗近日在提交给国会的一份报告中表示，美军正低调寻求增强其在台湾问题上遏制或对抗中国的能力，包括研发新型反舰炸弹和先进水雷。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260529-%E7%BE%8E%E5%8D%B0%E5%A4%AA%E5%8F%B8%E4%BB%A4%E5%AF%BB%E6%B1%82%E5%9B%BD%E4%BC%9A%E6%89%B9%E5%87%86%E9%A2%84%E7%AE%97-%E4%BF%83%E5%9C%A8%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98%E4%B8%8A%E9%81%8F%E5%88%B6%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780064253000.webp","sourceId":"rfi"},{"id":1780060857000,"createdDate":"2026-05-29 13:20","name":"法国国际广播电台","title":"王毅访加拿大前加护卫舰穿越台湾海峡 北京：反对以航行自由为名损害主权安全","content":"中国外交部长王毅即将于5月28日至30日访问加拿大之际，加国防部证实，加拿大皇家海军“夏洛特敦”号护卫舰于5月22日进行了例行穿越台湾海峡的航行，并于23日完成。北京方面，中国外交部发言人毛宁在周五的例行记者会上应询时表示，“中方尊重各国依据国际法享有的航行权利，同时坚决反对任何国家以‘航行自由’为名损害中国的主权和安全”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260529-%E7%8E%8B%E6%AF%85%E8%AE%BF%E5%8A%A0%E5%89%8D%E5%8A%A0%E6%8B%BF%E5%A4%A7%E6%8A%A4%E5%8D%AB%E8%88%B0%E7%A9%BF%E8%B6%8A%E5%8F%B0%E6%B9%BE%E6%B5%B7%E5%B3%A1-%E5%8C%97%E4%BA%AC-%E5%8F%8D%E5%AF%B9%E4%BB%A5%E8%88%AA%E8%A1%8C%E8%87%AA%E7%94%B1%E4%B8%BA%E5%90%8D%E6%8D%9F%E5%AE%B3%E4%B8%BB%E6%9D%83%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780060857000.webp","sourceId":"rfi"},{"id":1780056759000,"createdDate":"2026-05-29 12:12","name":"法国国际广播电台","title":"欧委会指贸易和投资关系不可持续 官媒：中方对贸易摩擦既不陌生也不害怕","content":"在欧盟委员会召开会议讨论可能对中国出口实施限制措施的几个小时前，中方向欧盟发出严厉警告，为欧中之间新一轮贸易摩擦埋下了伏笔。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260529-%E6%AC%A7%E5%A7%94%E4%BC%9A%E6%8C%87%E8%B4%B8%E6%98%93%E5%92%8C%E6%8A%95%E8%B5%84%E5%85%B3%E7%B3%BB%E4%B8%8D%E5%8F%AF%E6%8C%81%E7%BB%AD-%E5%AE%98%E5%AA%92-%E4%B8%AD%E6%96%B9%E5%AF%B9%E8%B4%B8%E6%98%93%E6%91%A9%E6%93%A6%E6%97%A2%E4%B8%8D%E9%99%8C%E7%94%9F%E4%B9%9F%E4%B8%8D%E5%AE%B3%E6%80%95","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780056759000.webp","sourceId":"rfi"},{"id":1780055559000,"createdDate":"2026-05-29 11:52","name":"法国国际广播电台","title":"释永信一审获刑24年 服判不上诉","content":"中国官媒新华社周五报导称，河南省新乡市中级人民法院一审公开宣判被告人、现年60岁的刘应成（原法名释永信）犯职务侵占罪、挪用资金罪、非国家工作人员受贿罪、行贿罪，数罪并罚，决定执行有期徒刑二十四年，并处罚金人民币三百五十万元。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260529-%E9%87%8A%E6%B0%B8%E4%BF%A1%E4%B8%80%E5%AE%A1%E8%8E%B7%E5%88%9124%E5%B9%B4-%E7%BD%9A%E9%87%91%E4%BA%BA%E6%B0%91%E5%B8%81350%E4%B8%87%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780055559000.webp","sourceId":"rfi"},{"id":1780055468000,"createdDate":"2026-05-29 11:51","name":"法国国际广播电台","title":"弥合破碎的奇迹！“婴儿空运行动”51年后的母子重逢","content":"51年前，在越南西贡陷落前夕，美国资助了名为“婴儿空运行动”（OperationBabylift），旨在“撤离”面临报复风险的混血孤儿。自那时起，这3000名被“撤离”到西方国家的儿童中，有些人一直在积极寻找自己的亲生父母，有些人成功找到了。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260529-%E5%BC%A5%E5%90%88%E7%A0%B4%E7%A2%8E%E7%9A%84%E5%A5%87%E8%BF%B9-%E5%A9%B4%E5%84%BF%E7%A9%BA%E8%BF%90%E8%A1%8C%E5%8A%A8-51%E5%B9%B4%E5%90%8E%E7%9A%84%E6%AF%8D%E5%AD%90%E9%87%8D%E9%80%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780055468000.webp","sourceId":"rfi"},{"id":1780053674000,"createdDate":"2026-05-29 11:21","name":"法国国际广播电台","title":"快报：香格里拉对话前夕 伦敦智库报告台海危局预警中美“核对抗升级”的黑暗前景","content":"大家好，欢迎收听法国报纸摘要，今天是5月29日星期五，法国全国性日报头版关注重点以国内事务为主，例如《十字架报》认为五月出现的极端高温现已成为一个政治议题！与此同时，周刊《快报》电子版亚太栏目登出分析文章称，在香格里拉对话这场亚洲安全峰会召开前夕，伦敦国际战略研究所（IISS）发布的一份报告对中美在台湾问题上可能发生的核对抗升级风险，表示担忧。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260529-%E5%BF%AB%E6%8A%A5-%E9%A6%99%E6%A0%BC%E9%87%8C%E6%8B%89%E5%AF%B9%E8%AF%9D%E5%89%8D%E5%A4%95-%E4%BC%A6%E6%95%A6%E6%99%BA%E5%BA%93%E6%8A%A5%E5%91%8A%E5%8F%B0%E6%B5%B7%E5%8D%B1%E5%B1%80%E9%A2%84%E8%AD%A6%E4%B8%AD%E7%BE%8E-%E6%A0%B8%E5%AF%B9%E6%8A%97%E5%8D%87%E7%BA%A7-%E7%9A%84%E9%BB%91%E6%9A%97%E5%89%8D%E6%99%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780053674000.webp","sourceId":"rfi"},{"id":1780051562000,"createdDate":"2026-05-29 10:46","name":"法国国际广播电台","title":"冯德莱恩主张就贸易问题对华采取更强硬政策 柏林立场受关注","content":"欧盟委员会主席冯德莱恩（UrsulavonderLeyen）将要求高级官员支持对从中国进口的补贴商品采取严厉打击措施，这将引发一场与欧盟成员国之间的博弈，部分成员国仍希望维护与北京的关系。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260529-%E5%86%AF%E5%BE%B7%E8%8E%B1%E6%81%A9%E4%B8%BB%E5%BC%A0%E5%B0%B1%E8%B4%B8%E6%98%93%E9%97%AE%E9%A2%98%E5%AF%B9%E5%8D%8E%E9%87%87%E5%8F%96%E6%9B%B4%E5%BC%BA%E7%A1%AC%E6%94%BF%E7%AD%96-%E6%9F%8F%E6%9E%97%E7%AB%8B%E5%9C%BA%E5%8F%97%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780051562000.webp","sourceId":"rfi"},{"id":1780049014000,"createdDate":"2026-05-29 10:03","name":"法国国际广播电台","title":"中国正在西北核导弹发射井附近修建由发射台、掩体等组成的庞大网络","content":"在中国偏远的沙漠地区，一个庞大的军事设施正在形成。一些安全专家认为，该设施似乎旨在确保美国对中国核武库的先发制人打击无法可靠地摧毁北京的反击能力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260529-%E4%B8%AD%E5%9B%BD%E6%AD%A3%E5%9C%A8%E8%A5%BF%E5%8C%97%E6%A0%B8%E5%AF%BC%E5%BC%B9%E5%8F%91%E5%B0%84%E4%BA%95%E9%99%84%E8%BF%91%E4%BF%AE%E5%BB%BA%E7%94%B1%E5%8F%91%E5%B0%84%E5%8F%B0-%E6%8E%A9%E4%BD%93%E7%AD%89%E7%BB%84%E6%88%90%E7%9A%84%E5%BA%9E%E5%A4%A7%E7%BD%91%E7%BB%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780049014000.webp","sourceId":"rfi"},{"id":1780046084000,"createdDate":"2026-05-29 09:14","name":"法国国际广播电台","title":"特朗普访华后美国高层密集访亚洲 印太战略往哪走？","content":"美国总统特朗普（DonaldTrump）访问中国后，华盛顿随即展开一连串亚洲外交与安全行动。国务卿卢比奥（MarcoRubio）前往印度出席“四方安全对话”（Quad）外长会议，国防部长赫格塞斯（PeteHegseth）则准备赴新加坡参加香格里拉对话。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260529-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E5%90%8E%E7%BE%8E%E5%9B%BD%E9%AB%98%E5%B1%82%E5%AF%86%E9%9B%86%E8%AE%BF%E4%BA%9A%E6%B4%B2-%E5%8D%B0%E5%A4%AA%E6%88%98%E7%95%A5%E5%BE%80%E5%93%AA%E8%B5%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780046084000.webp","sourceId":"rfi"},{"id":1780045621000,"createdDate":"2026-05-29 09:07","name":"法国国际广播电台","title":"董广平逮捕令被撤销后移交至出入境管理机构 韩法务部长：谨慎处理此事","content":"据韩国泰安海洋警察署周五（29日）消息，日前因乘橡皮艇擅自进入韩国领海被拘留的中国异见人士董广平的逮捕令被撤销后，其已被移交至大田出入境外国人事务所。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260529-%E8%91%A3%E5%B9%BF%E5%B9%B3%E9%80%AE%E6%8D%95%E4%BB%A4%E8%A2%AB%E6%92%A4%E9%94%80%E5%90%8E%E7%A7%BB%E4%BA%A4%E8%87%B3%E5%87%BA%E5%85%A5%E5%A2%83%E7%AE%A1%E7%90%86%E6%9C%BA%E6%9E%84-%E9%9F%A9%E6%B3%95%E5%8A%A1%E9%83%A8%E9%95%BF-%E8%B0%A8%E6%85%8E%E5%A4%84%E7%90%86%E6%AD%A4%E4%BA%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780045621000.webp","sourceId":"rfi"},{"id":1780044945000,"createdDate":"2026-05-29 08:55","name":"法国国际广播电台","title":"日本菲律宾举行首脑会谈 不指名强烈批评中国","content":"日本时间5月28日晚，日本首相高市早苗与菲律宾总统马科斯举行会谈，双方领导人对东海及南海局势表示严重关切，并再次确认，强烈反对任何企图以武力或胁迫单方面改变已经和平地确立的现状的行为，在会谈后发表的联合声明中，以中国为背景，强烈批评了在东海和南海的“霸权主义”行为，双方还强调台湾海峡和平与稳定的重要性，并呼吁通过对话和平解决两岸问题，但是在长达7千多字的联合声明中，并未提及中国的名字。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260529-%E6%97%A5%E6%9C%AC%E8%8F%B2%E5%BE%8B%E5%AE%BE%E4%B8%BE%E8%A1%8C%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88-%E4%B8%8D%E6%8C%87%E5%90%8D%E5%BC%BA%E7%83%88%E6%89%B9%E8%AF%84%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780044945000.webp","sourceId":"rfi"},{"id":1780044462000,"createdDate":"2026-05-29 08:47","name":"法国国际广播电台","title":"马英九基金会正式向萧旭岑提告背信、侵占  从财务争议演变为前总统马英九政治遗产争夺战","content":"马英九基金会在29日针对前执行长萧旭岑及王光慈涉背信、侵占等案件，已正式提起刑事告诉。台湾媒体人分析，马英九基金会风波，表面上是财务纪律争议，实际上已经演变成一场谁能代表马英九的权力代理人战争。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260529-%E9%A9%AC%E8%8B%B1%E4%B9%9D%E5%9F%BA%E9%87%91%E4%BC%9A%E6%AD%A3%E5%BC%8F%E5%90%91%E8%90%A7%E6%97%AD%E5%B2%91%E6%8F%90%E5%91%8A%E8%83%8C%E4%BF%A1-%E4%BE%B5%E5%8D%A0-%E4%BB%8E%E8%B4%A2%E5%8A%A1%E4%BA%89%E8%AE%AE%E6%BC%94%E5%8F%98%E4%B8%BA%E5%89%8D%E6%80%BB%E7%BB%9F%E9%A9%AC%E8%8B%B1%E4%B9%9D%E6%94%BF%E6%B2%BB%E9%81%97%E4%BA%A7%E4%BA%89%E5%A4%BA%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780044462000.webp","sourceId":"rfi"},{"id":1780043016000,"createdDate":"2026-05-29 08:23","name":"法国国际广播电台","title":"新加坡外长：朝鲜目前似乎无意与韩、美接触","content":"新加坡外长维文（VivianBalakrishnan）在结束对朝鲜罕见的两天访问之后表示，这个受到国际政治孤立状态的国家目前似乎无意与美国、韩国或日本展开接触，而是选择加强其自给自足和军事威慑能力。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260529-%E6%96%B0%E5%8A%A0%E5%9D%A1%E5%A4%96%E9%95%BF-%E6%9C%9D%E9%B2%9C%E7%9B%AE%E5%89%8D%E4%BC%BC%E4%B9%8E%E6%97%A0%E6%84%8F%E4%B8%8E%E9%9F%A9-%E7%BE%8E%E6%8E%A5%E8%A7%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780043016000.webp","sourceId":"rfi"},{"id":1780041477000,"createdDate":"2026-05-29 07:57","name":"法国国际广播电台","title":"法国社会党第一书记福雷访台：“中华人民共和国从未统治过台湾哪怕一秒钟”","content":"社会党第一书记奥利维尔·福雷（OlivierFaure）于5月23日至29日赴台湾进行议会访问。《解放报》驻台记者指出，福雷此行也是与法兰西不屈服党党魁梅朗雄在台湾问题上的立场划清界限的一种方式。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260529-%E6%B3%95%E5%9B%BD%E7%A4%BE%E4%BC%9A%E5%85%9A%E7%AC%AC%E4%B8%80%E4%B9%A6%E8%AE%B0%E7%A6%8F%E9%9B%B7%E8%AE%BF%E5%8F%B0-%E4%B8%AD%E5%8D%8E%E4%BA%BA%E6%B0%91%E5%85%B1%E5%92%8C%E5%9B%BD%E4%BB%8E%E6%9C%AA%E7%BB%9F%E6%B2%BB%E8%BF%87%E5%8F%B0%E6%B9%BE%E5%93%AA%E6%80%95%E4%B8%80%E7%A7%92%E9%92%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780041477000.webp","sourceId":"rfi"},{"id":1780037804000,"createdDate":"2026-05-29 06:56","name":"法国国际广播电台","title":"香港4月出口升42.9% 创五年多新高 惟电子产品增幅料放缓","content":"受惠於全球对人工智能(AI)相关电子产品的需求持续强劲，香港4月份的整体出口和进口货值分别上升42.9%和44.4%，远高於市场预期；当中，出口已连升26个月，增幅更是五年多以来新高。业界和金融分析师估计，电子产品出口增加已持续约一年，下半年出口按年增幅可能会收窄，估计全年出口或录得一至两成增长。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260529-%E9%A6%99%E6%B8%AF4%E6%9C%88%E5%87%BA%E5%8F%A3%E5%8D%8742-9-%E5%88%9B%E4%BA%94%E5%B9%B4%E5%A4%9A%E6%96%B0%E9%AB%98-%E6%83%9F%E7%94%B5%E5%AD%90%E4%BA%A7%E5%93%81%E5%A2%9E%E5%B9%85%E6%96%99%E6%94%BE%E7%BC%93","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780037804000.webp","sourceId":"rfi"},{"id":1780037551000,"createdDate":"2026-05-29 06:52","name":"法国国际广播电台","title":"习近平既赞胡耀邦 「天安门母亲」吁秉持其「有错必纠」精神为六四平反","content":"今年是因纪念为人民平反的中共前总书记胡耀邦逝世而触发的「六四事件」37周年，由当年死难者家属组成的「天安门母亲」，呼吁中国国家主席习近平体现他自己赞扬胡「无私无畏丶有错必纠的精神」，公正解决这一人间悲剧，包括公布「六四」真相丶赔偿难属及追究担责者的法律责任。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260529-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%97%A2%E8%B5%9E%E8%83%A1%E8%80%80%E9%82%A6-%E5%A4%A9%E5%AE%89%E9%97%A8%E6%AF%8D%E4%BA%B2-%E5%90%81%E7%A7%89%E6%8C%81%E5%85%B6-%E6%9C%89%E9%94%99%E5%BF%85%E7%BA%A0-%E7%B2%BE%E7%A5%9E%E4%B8%BA%E5%85%AD%E5%9B%9B%E5%B9%B3%E5%8F%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/29/1780037551000.webp","sourceId":"rfi"}]