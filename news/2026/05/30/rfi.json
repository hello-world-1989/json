[{"id":1780131961000,"createdDate":"2026-05-30 09:06","name":"法国国际广播电台","title":"消息人士：特朗普预计不会在习近平今秋访美前与赖清德通话","content":"据多位知情人士向哥伦比亚广播公司（CBS）透露，美国总统特朗普（DonaldTrump）预计不会在习近平主席今年秋季可能访美之前与台湾总统赖清德通话。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260530-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB-%E7%89%B9%E6%9C%97%E6%99%AE%E9%A2%84%E8%AE%A1%E4%B8%8D%E4%BC%9A%E5%9C%A8%E4%B9%A0%E8%BF%91%E5%B9%B3%E4%BB%8A%E7%A7%8B%E8%AE%BF%E7%BE%8E%E5%89%8D%E4%B8%8E%E8%B5%96%E6%B8%85%E5%BE%B7%E9%80%9A%E8%AF%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780131961000.webp","sourceId":"rfi"},{"id":1780129925000,"createdDate":"2026-05-30 08:32","name":"法国国际广播电台","title":"中国就日本与菲律宾启动两国海洋划界谈判提出严正交涉","content":"日本首相高市早苗与菲律宾总统马科斯于日本时间5月28日发表关于全面战略伙伴关系的日菲联合声明，联合声明表明，双方已就启动划定两国专属经济区（EEZ）及大陆架海洋边界的谈判达成一致。为此，日本时间5月29日，中国外交部发言人毛宁在其主持的例行记者会上表示：中方对此强烈不满，坚决反对，已分别向日、菲提出严正交涉。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260530-%E4%B8%AD%E5%9B%BD%E5%B0%B1%E6%97%A5%E6%9C%AC%E4%B8%8E%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%90%AF%E5%8A%A8%E4%B8%A4%E5%9B%BD%E6%B5%B7%E6%B4%8B%E5%88%92%E7%95%8C%E8%B0%88%E5%88%A4%E6%8F%90%E5%87%BA%E4%B8%A5%E6%AD%A3%E4%BA%A4%E6%B6%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780129925000.webp","sourceId":"rfi"}]