[{"id":1780131961000,"createdDate":"2026-05-30 09:06","name":"法国国际广播电台","title":"消息人士：特朗普预计不会在习近平今秋访美前与赖清德通话","content":"据多位知情人士向哥伦比亚广播公司（CBS）透露，美国总统特朗普（DonaldTrump）预计不会在习近平主席今年秋季可能访美之前与台湾总统赖清德通话。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260530-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB-%E7%89%B9%E6%9C%97%E6%99%AE%E9%A2%84%E8%AE%A1%E4%B8%8D%E4%BC%9A%E5%9C%A8%E4%B9%A0%E8%BF%91%E5%B9%B3%E4%BB%8A%E7%A7%8B%E8%AE%BF%E7%BE%8E%E5%89%8D%E4%B8%8E%E8%B5%96%E6%B8%85%E5%BE%B7%E9%80%9A%E8%AF%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780131961000.webp","sourceId":"rfi"},{"id":1780129925000,"createdDate":"2026-05-30 08:32","name":"法国国际广播电台","title":"中国就日本与菲律宾启动两国海洋划界谈判提出严正交涉","content":"日本首相高市早苗与菲律宾总统马科斯于日本时间5月28日发表关于全面战略伙伴关系的日菲联合声明，联合声明表明，双方已就启动划定两国专属经济区（EEZ）及大陆架海洋边界的谈判达成一致。为此，日本时间5月29日，中国外交部发言人毛宁在其主持的例行记者会上表示：中方对此强烈不满，坚决反对，已分别向日、菲提出严正交涉。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260530-%E4%B8%AD%E5%9B%BD%E5%B0%B1%E6%97%A5%E6%9C%AC%E4%B8%8E%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%90%AF%E5%8A%A8%E4%B8%A4%E5%9B%BD%E6%B5%B7%E6%B4%8B%E5%88%92%E7%95%8C%E8%B0%88%E5%88%A4%E6%8F%90%E5%87%BA%E4%B8%A5%E6%AD%A3%E4%BA%A4%E6%B6%89","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780129925000.webp","sourceId":"rfi"},{"id":1780151923000,"createdDate":"2026-05-30 14:38","name":"法国国际广播电台","title":"美战争部长：对台政策与本届政府初期并无二致，立场依然不变","content":"美国战争部长赫格塞思（PeteHegseth）周六向媒体表示，“我们对台湾的立场依然不变”，并称“我们对当前的安全形势共享着清醒的认识，并一致认为，任何霸权主导的太平洋都将破坏地区权力平衡，损害我们共同努力维护的均势。美国战争部正全力以赴，防止此类拆散的局面发生”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260530-%E7%BE%8E%E6%88%98%E4%BA%89%E9%83%A8%E9%95%BF-%E5%AF%B9%E5%8F%B0%E6%94%BF%E7%AD%96%E4%B8%8E%E6%9C%AC%E5%B1%8A%E6%94%BF%E5%BA%9C%E5%88%9D%E6%9C%9F%E5%B9%B6%E6%97%A0%E4%BA%8C%E8%87%B4%EF%BC%8C%E7%AB%8B%E5%9C%BA%E4%BE%9D%E7%84%B6%E4%B8%8D%E5%8F%98","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780151923000.webp","sourceId":"rfi"},{"id":1780148870000,"createdDate":"2026-05-30 13:47","name":"法国国际广播电台","title":"菲防长谈菲中南海争端：我们将面临一场长期斗争，别无选择只能展现韧性","content":"菲律宾国防部长特奥多罗（GilbertoTeodoro）表示，菲律宾与中国的海上争端日益激烈，并指“我们将面临一场长期的斗争”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260530-%E8%8F%B2%E9%98%B2%E9%95%BF%E8%B0%88%E8%8F%B2%E4%B8%AD%E5%8D%97%E6%B5%B7%E4%BA%89%E7%AB%AF-%E6%88%91%E4%BB%AC%E5%B0%86%E9%9D%A2%E4%B8%B4%E4%B8%80%E5%9C%BA%E9%95%BF%E6%9C%9F%E6%96%97%E4%BA%89%EF%BC%8C%E5%88%AB%E6%97%A0%E9%80%89%E6%8B%A9%E5%8F%AA%E8%83%BD%E5%B1%95%E7%8E%B0%E9%9F%A7%E6%80%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780148870000.webp","sourceId":"rfi"},{"id":1780144881000,"createdDate":"2026-05-30 12:41","name":"法国国际广播电台","title":"柏林愿讨论更强有力的贸易保护措施 北京：若欧方推出新贸易工具，将坚决反制","content":"欧盟委员会周五召开会议，就欧中关系进行指导性辩论。欧盟委员会会后通过新闻稿表示，“欧盟委员会的总体方法仍然是去风险，而非脱钩。中国是一个至关重要的伙伴，接触和对话将继续。与此同时，目前的贸易和投资关系是不可持续的。随着经济和安全利益日益交织，这两个方面都需要采取更有力、更协调一致的应对措施”。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260530-%E6%9F%8F%E6%9E%97%E6%84%BF%E8%AE%A8%E8%AE%BA%E6%9B%B4%E5%BC%BA%E6%9C%89%E5%8A%9B%E7%9A%84%E8%B4%B8%E6%98%93%E4%BF%9D%E6%8A%A4%E6%8E%AA%E6%96%BD-%E5%8C%97%E4%BA%AC-%E8%8B%A5%E6%AC%A7%E6%96%B9%E6%8E%A8%E5%87%BA%E6%96%B0%E8%B4%B8%E6%98%93%E5%B7%A5%E5%85%B7%EF%BC%8C%E5%B0%86%E5%9D%9A%E5%86%B3%E5%8F%8D%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780144881000.webp","sourceId":"rfi"},{"id":1780143280000,"createdDate":"2026-05-30 12:14","name":"法国国际广播电台","title":"酷热如何应对？ 建筑被动冷却术是取代空调机的好方案","content":"各位听众，日前全球各地纷纷传出酷热气候，法国也是少有的五月早到的酷热高温。大家伤透脑筋如何应对这种历来鲜见的气温现象，专家提出一项可参考的意见：为了使室内温度更加清爽舒适，可以采用低能耗或零能耗解决方案（即被动式冷却解决方案）。虽然由于法国的低碳电力生产，空调机用电的碳足迹在法国仍然相对较小，但在许多其他国家并非如此。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260530-%E9%85%B7%E7%83%AD%E5%A6%82%E4%BD%95%E5%BA%94%E5%AF%B9-%E5%BB%BA%E7%AD%91%E8%A2%AB%E5%8A%A8%E5%86%B7%E5%8D%B4%E6%9C%AF%E6%98%AF%E5%8F%96%E4%BB%A3%E7%A9%BA%E8%B0%83%E6%9C%BA%E7%9A%84%E5%A5%BD%E6%96%B9%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780143280000.webp","sourceId":"rfi"},{"id":1780142290000,"createdDate":"2026-05-30 11:58","name":"法国国际广播电台","title":"中方驱逐一纽时记者后 美吊销一新华社记者签证","content":"美国特朗普政府吊销了一名在美为中国官媒新华社工作的中国公民的签证，这显然是对中方驱逐一名《纽约时报》记者的对等回应。一位知情人士证实了签证已被吊销。由于此事涉及签证隐私，该人士要求匿名。一位美国国务院官员证实，确实有吊销该签证的计划。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260530-%E4%B8%AD%E6%96%B9%E9%A9%B1%E9%80%90%E4%B8%80%E7%BA%BD%E6%97%B6%E8%AE%B0%E8%80%85%E5%90%8E-%E7%BE%8E%E5%90%8A%E9%94%80%E4%B8%80%E6%96%B0%E5%8D%8E%E7%A4%BE%E8%AE%B0%E8%80%85%E7%AD%BE%E8%AF%81","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780142290000.webp","sourceId":"rfi"},{"id":1780138400000,"createdDate":"2026-05-30 10:53","name":"法国国际广播电台","title":"欧盟准备用本土的替代方案， 摆脱对美国数字公司和中国芯片的依赖","content":"欧盟正准备出台措施，摆脱对美国数字公司和中国芯片的依赖，转而采用欧洲本土的替代方案.法新社今天报道，据他们看到的一份战略草案文件显示，备受瞩目的芯片、云计算和人工智能新规将于周三公布，这是欧盟“重夺自己在全球地缘经济竞争中的地位”的努力的一部分。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260530-%E6%AC%A7%E7%9B%9F%E5%87%86%E5%A4%87%E7%94%A8%E6%9C%AC%E5%9C%9F%E7%9A%84%E6%9B%BF%E4%BB%A3%E6%96%B9%E6%A1%88%EF%BC%8C-%E6%91%86%E8%84%B1%E5%AF%B9%E7%BE%8E%E5%9B%BD%E6%95%B0%E5%AD%97%E5%85%AC%E5%8F%B8%E5%92%8C%E4%B8%AD%E5%9B%BD%E8%8A%AF%E7%89%87%E7%9A%84%E4%BE%9D%E8%B5%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780138400000.webp","sourceId":"rfi"},{"id":1780137161000,"createdDate":"2026-05-30 10:32","name":"法国国际广播电台","title":"伊朗据报或使用中制肩扛式导弹击落了美F-15战机 中方：反对无根据抹黑","content":"据三位知情人士向美国全国广播公司（NBC）透露称，上个月在伊朗西南部被击落并引发危险救援行动的美军F-15战斗机，可能是被中国制造的肩扛式导弹击中的。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260530-%E4%BC%8A%E6%9C%97%E6%8D%AE%E6%8A%A5%E6%88%96%E4%BD%BF%E7%94%A8%E4%B8%AD%E5%88%B6%E8%82%A9%E6%89%9B%E5%BC%8F%E5%AF%BC%E5%BC%B9%E5%87%BB%E8%90%BD%E4%BA%86%E7%BE%8Ef-15e%E6%88%98%E6%9C%BA-%E4%B8%AD%E6%96%B9-%E5%8F%8D%E5%AF%B9%E6%97%A0%E6%A0%B9%E6%8D%AE%E6%8A%B9%E9%BB%91","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780137161000.webp","sourceId":"rfi"},{"id":1780135363000,"createdDate":"2026-05-30 10:02","name":"法国国际广播电台","title":"赫格塞思淡化对华措辞但称不容中国主导印太，越南称不选边站队","content":"在新加坡举行的第23届香格里拉对话会成为今年亚太安全议题的重要焦点。美国、中国、东盟以及地区盟友围绕印太安全、军费支出、台海、南海等问题释放出一系列信号。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260530-%E8%B5%AB%E6%A0%BC%E5%A1%9E%E6%80%9D%E6%B7%A1%E5%8C%96%E5%AF%B9%E5%8D%8E%E6%8E%AA%E8%BE%9E%E4%BD%86%E7%A7%B0%E4%B8%8D%E5%AE%B9%E4%B8%AD%E5%9B%BD%E4%B8%BB%E5%AF%BC%E5%8D%B0%E5%A4%AA%EF%BC%8C%E8%B6%8A%E5%8D%97%E7%A7%B0%E4%B8%8D%E9%80%89%E8%BE%B9%E7%AB%99%E9%98%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780135363000.webp","sourceId":"rfi"},{"id":1780135108000,"createdDate":"2026-05-30 09:58","name":"法国国际广播电台","title":"驻韩美军司令称韩国是亚洲心脏的匕首 中使馆指越线 青瓦台向美方表立场","content":"据青瓦台官员周六透露，韩方已就驻韩美军司令兼联合国军司令布伦森（XavierBrunson）近期将韩国比作亚洲“匕首”的争议性言论向美国表明立场。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260530-%E9%A9%BB%E9%9F%A9%E7%BE%8E%E5%86%9B%E5%8F%B8%E4%BB%A4%E7%A7%B0%E9%9F%A9%E5%9B%BD%E6%98%AF%E4%BA%9A%E6%B4%B2%E5%BF%83%E8%84%8F%E7%9A%84%E5%8C%95%E9%A6%96-%E4%B8%AD%E4%BD%BF%E9%A6%86%E6%8C%87%E8%B6%8A%E7%BA%BF-%E9%9D%92%E7%93%A6%E5%8F%B0%E5%90%91%E7%BE%8E%E6%96%B9%E8%A1%A8%E7%AB%8B%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780135108000.webp","sourceId":"rfi"},{"id":1780133092000,"createdDate":"2026-05-30 09:24","name":"法国国际广播电台","title":"欧洲警告：俄罗斯加大技术窃取力度，经济压力下对西方展开更激进情报行动","content":"美联社报道，多名欧洲高级情报官员表示，在西方制裁持续施压以及俄乌战争长期消耗的背景下，俄罗斯情报机构正加大获取西方技术和国防机密的力度，其行动方式也变得更加积极和复杂。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260530-%E6%AC%A7%E6%B4%B2%E8%AD%A6%E5%91%8A-%E4%BF%84%E7%BD%97%E6%96%AF%E5%8A%A0%E5%A4%A7%E6%8A%80%E6%9C%AF%E7%AA%83%E5%8F%96%E5%8A%9B%E5%BA%A6%EF%BC%8C%E7%BB%8F%E6%B5%8E%E5%8E%8B%E5%8A%9B%E4%B8%8B%E5%AF%B9%E8%A5%BF%E6%96%B9%E5%B1%95%E5%BC%80%E6%9B%B4%E6%BF%80%E8%BF%9B%E6%83%85%E6%8A%A5%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/05/30/1780133092000.webp","sourceId":"rfi"}]