[{"id":1779873485000,"createdDate":"2026-05-27 09:18","name":"法国国际广播电台","title":"西藏流亡政府首脑边巴次仁宣誓就职","content":"边巴次仁（PenpaTsering）再次当选藏人行政中央司政（西藏流亡政府首脑），并于5月27日周三在印度北部达兰萨拉宣誓就职。藏人精神领袖达赖喇嘛出席了这个就职仪式。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260527-%E8%A5%BF%E8%97%8F%E6%B5%81%E4%BA%A1%E6%94%BF%E5%BA%9C%E9%A6%96%E8%84%91%E8%BE%B9%E5%B7%B4%E6%AC%A1%E4%BB%81%E5%AE%A3%E8%AA%93%E5%B0%B1%E8%81%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779873485000.webp","sourceId":"rfi"},{"id":1779871624000,"createdDate":"2026-05-27 08:47","name":"法国国际广播电台","title":"报告显示：欧洲在华企业仍举步维艰  但信心微弱回暖","content":"周三（5月27号）公布的一项调查显示，欧洲企业在华子公司的经营环境连续第二年恶化，但目前已出现初步改善迹象。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260527-%E6%8A%A5%E5%91%8A%E6%98%BE%E7%A4%BA-%E6%AC%A7%E6%B4%B2%E5%9C%A8%E5%8D%8E%E4%BC%81%E4%B8%9A%E4%BB%8D%E4%B8%BE%E6%AD%A5%E7%BB%B4%E8%89%B0-%E4%BD%86%E4%BF%A1%E5%BF%83%E5%BE%AE%E5%BC%B1%E5%9B%9E%E6%9A%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779871624000.webp","sourceId":"rfi"},{"id":1779868543000,"createdDate":"2026-05-27 07:55","name":"法国国际广播电台","title":"日本天皇皇后迎接菲律宾总统马科斯及夫人","content":"5月26日至29日，菲律宾总统马科斯二世及夫人作为国宾访问日本。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260527-%E6%97%A5%E6%9C%AC%E5%A4%A9%E7%9A%87%E7%9A%87%E5%90%8E%E8%BF%8E%E6%8E%A5%E8%8F%B2%E5%BE%8B%E5%AE%BE%E6%80%BB%E7%BB%9F%E9%A9%AC%E7%A7%91%E6%96%AF%E5%8F%8A%E5%A4%AB%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779868543000.webp","sourceId":"rfi"},{"id":1779865432000,"createdDate":"2026-05-27 07:03","name":"法国国际广播电台","title":"深圳「十五五」称积极对接香港北都 夥建优质生活圈 评论指港势「被对接」","content":"香港首份五年经济规划(「一五」)尚未出炉，但广东省已在正式发布的经济和社会发展第十五个五年规划纲要(简称「十五五」纲要)表示，要对接香港的「一五」；而深圳同日公布的「十五五」纲要，亦表明要对接香港的北部都会区，到2030年，将基本形成与香港园区协同创新的格局。该市更把今後五年的年均GDP目标订在「5%以上」，较广东省更高。香港评论指，如此形势，香港只能被动对接，香港主要税收来源之一的地价和楼价，料难维持高水平。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260527-%E6%B7%B1%E5%9C%B3-%E5%8D%81%E4%BA%94%E4%BA%94-%E7%A7%B0%E7%A7%AF%E6%9E%81%E5%AF%B9%E6%8E%A5%E9%A6%99%E6%B8%AF%E5%8C%97%E9%83%BD-%E5%A4%A5%E5%BB%BA%E4%BC%98%E8%B4%A8%E7%94%9F%E6%B4%BB%E5%9C%88-%E8%AF%84%E8%AE%BA%E6%8C%87%E6%B8%AF%E5%8A%BF-%E8%A2%AB%E5%AF%B9%E6%8E%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779865432000.webp","sourceId":"rfi"}]