[{"id":1779873485000,"createdDate":"2026-05-27 09:18","name":"法国国际广播电台","title":"西藏流亡政府首脑边巴次仁宣誓就职","content":"边巴次仁（PenpaTsering）再次当选藏人行政中央司政（西藏流亡政府首脑），并于5月27日周三在印度北部达兰萨拉宣誓就职。藏人精神领袖达赖喇嘛出席了这个就职仪式。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260527-%E8%A5%BF%E8%97%8F%E6%B5%81%E4%BA%A1%E6%94%BF%E5%BA%9C%E9%A6%96%E8%84%91%E8%BE%B9%E5%B7%B4%E6%AC%A1%E4%BB%81%E5%AE%A3%E8%AA%93%E5%B0%B1%E8%81%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779873485000.webp","sourceId":"rfi"},{"id":1779871624000,"createdDate":"2026-05-27 08:47","name":"法国国际广播电台","title":"报告显示：欧洲在华企业仍举步维艰  但信心微弱回暖","content":"周三（5月27号）公布的一项调查显示，欧洲企业在华子公司的经营环境连续第二年恶化，但目前已出现初步改善迹象。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260527-%E6%8A%A5%E5%91%8A%E6%98%BE%E7%A4%BA-%E6%AC%A7%E6%B4%B2%E5%9C%A8%E5%8D%8E%E4%BC%81%E4%B8%9A%E4%BB%8D%E4%B8%BE%E6%AD%A5%E7%BB%B4%E8%89%B0-%E4%BD%86%E4%BF%A1%E5%BF%83%E5%BE%AE%E5%BC%B1%E5%9B%9E%E6%9A%96","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779871624000.webp","sourceId":"rfi"},{"id":1779868543000,"createdDate":"2026-05-27 07:55","name":"法国国际广播电台","title":"日本天皇皇后迎接菲律宾总统马科斯及夫人","content":"5月26日至29日，菲律宾总统马科斯二世及夫人作为国宾访问日本。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260527-%E6%97%A5%E6%9C%AC%E5%A4%A9%E7%9A%87%E7%9A%87%E5%90%8E%E8%BF%8E%E6%8E%A5%E8%8F%B2%E5%BE%8B%E5%AE%BE%E6%80%BB%E7%BB%9F%E9%A9%AC%E7%A7%91%E6%96%AF%E5%8F%8A%E5%A4%AB%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779868543000.webp","sourceId":"rfi"},{"id":1779865432000,"createdDate":"2026-05-27 07:03","name":"法国国际广播电台","title":"深圳「十五五」称积极对接香港北都 夥建优质生活圈 评论指港势「被对接」","content":"香港首份五年经济规划(「一五」)尚未出炉，但广东省已在正式发布的经济和社会发展第十五个五年规划纲要(简称「十五五」纲要)表示，要对接香港的「一五」；而深圳同日公布的「十五五」纲要，亦表明要对接香港的北部都会区，到2030年，将基本形成与香港园区协同创新的格局。该市更把今後五年的年均GDP目标订在「5%以上」，较广东省更高。香港评论指，如此形势，香港只能被动对接，香港主要税收来源之一的地价和楼价，料难维持高水平。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260527-%E6%B7%B1%E5%9C%B3-%E5%8D%81%E4%BA%94%E4%BA%94-%E7%A7%B0%E7%A7%AF%E6%9E%81%E5%AF%B9%E6%8E%A5%E9%A6%99%E6%B8%AF%E5%8C%97%E9%83%BD-%E5%A4%A5%E5%BB%BA%E4%BC%98%E8%B4%A8%E7%94%9F%E6%B4%BB%E5%9C%88-%E8%AF%84%E8%AE%BA%E6%8C%87%E6%B8%AF%E5%8A%BF-%E8%A2%AB%E5%AF%B9%E6%8E%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779865432000.webp","sourceId":"rfi"},{"id":1779902456000,"createdDate":"2026-05-27 17:20","name":"法国国际广播电台","title":"日本议会通过新法 加强国家情报能力","content":"根据日本议会周三通过的新法，国家情报局将整合各部委和机构收集的信息，并向由首相领导的新成立的国家情报会议汇报。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260527-%E6%97%A5%E6%9C%AC%E8%AE%AE%E4%BC%9A%E9%80%9A%E8%BF%87%E6%96%B0%E6%B3%95-%E5%8A%A0%E5%BC%BA%E5%9B%BD%E5%AE%B6%E6%83%85%E6%8A%A5%E8%83%BD%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779902456000.webp","sourceId":"rfi"},{"id":1779901783000,"createdDate":"2026-05-27 17:09","name":"法国国际广播电台","title":"法国老佛爷百货关闭北京门店","content":"法国百货公司老佛爷（GaleriesLafayette）2026年5月27日周三关闭了位于北京的门店。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260527-%E6%B3%95%E5%9B%BD%E8%80%81%E4%BD%9B%E7%88%B7%E7%99%BE%E8%B4%A7%E5%85%B3%E9%97%AD%E5%8C%97%E4%BA%AC%E9%97%A8%E5%BA%97","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779901783000.webp","sourceId":"rfi"},{"id":1779898050000,"createdDate":"2026-05-27 16:07","name":"法国国际广播电台","title":"德国经济部长访华 主张与竞争对手中国建立“现代化伙伴关系”","content":"德国经济部长赖歇周三在她开启为期三天的中国之行时表示，她打算倡导与中国建立“现代伙伴关系”。法新社说，中国曾是德国经济增长的引擎，现已成为德国的强劲竞争对手。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260527-%E5%BE%B7%E5%9B%BD%E7%BB%8F%E6%B5%8E%E9%83%A8%E9%95%BF%E8%AE%BF%E5%8D%8E-%E4%B8%BB%E5%BC%A0%E4%B8%8E%E7%AB%9E%E4%BA%89%E5%AF%B9%E6%89%8B%E4%B8%AD%E5%9B%BD%E5%BB%BA%E7%AB%8B-%E7%8E%B0%E4%BB%A3%E5%8C%96%E4%BC%99%E4%BC%B4%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779898050000.webp","sourceId":"rfi"},{"id":1779897506000,"createdDate":"2026-05-27 15:58","name":"法国国际广播电台","title":"德国和西班牙反对欧盟禁止华为设备计划","content":"彭博社透露，德国和西班牙正在带头反对欧盟委员会计划将禁止中国技术供应商参与欧洲电信网络作为新的网络安全规则的一部分。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260527-%E5%BE%B7%E5%9B%BD%E5%92%8C%E8%A5%BF%E7%8F%AD%E7%89%99%E5%8F%8D%E5%AF%B9%E6%AC%A7%E7%9B%9F%E7%A6%81%E6%AD%A2%E5%8D%8E%E4%B8%BA%E8%AE%BE%E5%A4%87%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779897506000.webp","sourceId":"rfi"},{"id":1779896787000,"createdDate":"2026-05-27 15:46","name":"法国国际广播电台","title":"以色列宣布击毙哈马斯卡桑旅新首领 其前任11天前遭击杀","content":"以色列周三宣布击毙了哈马斯武装部门卡桑旅的新头目，该头目的前任刚刚在5月15日死于以色列空袭。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260527-%E4%BB%A5%E8%89%B2%E5%88%97%E5%AE%A3%E5%B8%83%E5%87%BB%E6%AF%99%E5%93%88%E9%A9%AC%E6%96%AF%E5%8D%A1%E6%A1%91%E6%97%85%E6%96%B0%E9%A6%96%E9%A2%86-%E5%85%B6%E5%89%8D%E4%BB%BB11%E5%A4%A9%E5%89%8D%E8%A2%AB%E5%87%BB%E6%9D%80","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779896787000.webp","sourceId":"rfi"},{"id":1779893957000,"createdDate":"2026-05-27 14:59","name":"法国国际广播电台","title":"伊朗认为与美国再次开战可能性不大 部分解封互联网","content":"伊朗周三表示，与美国重启敌对行动的可能性不大。背景是油价回落，市场乐观情绪回升，伊朗互联网也部分解封。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260527-%E4%BC%8A%E6%9C%97%E8%AE%A4%E4%B8%BA%E4%B8%8E%E7%BE%8E%E5%9B%BD%E5%86%8D%E6%AC%A1%E5%BC%80%E6%88%98%E5%8F%AF%E8%83%BD%E6%80%A7%E4%B8%8D%E5%A4%A7-%E9%83%A8%E5%88%86%E8%A7%A3%E5%B0%81%E4%BA%92%E8%81%94%E7%BD%91","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779893957000.webp","sourceId":"rfi"},{"id":1779893046000,"createdDate":"2026-05-27 14:44","name":"法国国际广播电台","title":"埃博拉趁战乱加速扩散, 美加印等启动隔离与入境限制, 世卫呼吁停火","content":"5月27日，世界卫生组织呼吁刚果民主共和国东部停火。战争造成的人口大规模流动正在加速埃博拉疫情的扩散，而本次疫情已成为有记录以来规模第三大的同类暴发事件。鉴于此，世界多地开始采取入境限制。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260527-%E5%9F%83%E5%8D%9A%E6%8B%89%E8%B6%81%E6%88%98%E4%B9%B1%E5%8A%A0%E9%80%9F%E6%89%A9%E6%95%A3-%E7%BE%8E%E5%8A%A0%E5%8D%B0%E7%AD%89%E5%90%AF%E5%8A%A8%E9%9A%94%E7%A6%BB%E4%B8%8E%E5%85%A5%E5%A2%83%E9%99%90%E5%88%B6-%E4%B8%96%E5%8D%AB%E5%91%BC%E5%90%81%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779893046000.webp","sourceId":"rfi"},{"id":1779890397000,"createdDate":"2026-05-27 13:59","name":"法国国际广播电台","title":"中国拖延批准欧洲空客交付 以促欧洲采购中国商飞C919","content":"中国签署购买空客飞机协议后，迟迟不批准这些飞机交付。据报此举是为促欧洲监管机构快速认证中国商用C919飞机，加快这款综合采用西方技术的廉价飞机飞向全世界。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260527-%E4%B8%AD%E5%9B%BD%E6%8B%96%E5%BB%B6%E6%89%B9%E5%87%86%E6%AC%A7%E6%B4%B2%E7%A9%BA%E5%AE%A2%E4%BA%A4%E4%BB%98-%E4%BB%A5%E4%BF%83%E6%AC%A7%E6%B4%B2%E9%87%87%E8%B4%AD%E4%B8%AD%E5%9B%BD%E5%95%86%E9%A3%9Ec919","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779890397000.webp","sourceId":"rfi"},{"id":1779890251000,"createdDate":"2026-05-27 13:57","name":"法国国际广播电台","title":"中国人权活动人士人士董广平驾橡胶艇成功逃抵韩国","content":"一名韩国律师27日向法新社证实，因参加人权活动而在中国多次坐牢的活动人士董广平凭借一艘橡胶艇于25日晚间成功抵达韩国海岸，并已被韩国海防队拘押，等待调查。人权组织“中国人权”敦促韩国政府遵守人道主义原则和国际人权义务，确保董光平不被遣返回中国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260527-%E4%B8%AD%E5%9B%BD%E4%BA%BA%E6%9D%83%E6%B4%BB%E5%8A%A8%E4%BA%BA%E5%A3%AB%E4%BA%BA%E5%A3%AB%E8%91%A3%E5%B9%BF%E5%B9%B3%E9%A9%BE%E6%A9%A1%E8%83%B6%E8%89%87%E6%88%90%E5%8A%9F%E9%80%83%E6%8A%B5%E9%9F%A9%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779890251000.webp","sourceId":"rfi"},{"id":1779889749000,"createdDate":"2026-05-27 13:49","name":"法国国际广播电台","title":"回声报：北京担忧美澳日印的斐济港口项目 欧企看到在华经商环境改善迹象","content":"大家好，今天是5月27日星期三，本期法国报纸摘要，我们为您介绍《回声报》上两篇与中国有关的报道：一则是，在中国，欧洲企业看到商业环境开始改善的迹象；另一则是，特朗普访华后，美国加大了对中国的施压力度。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260527-%E6%AC%A7%E6%B4%B2%E4%BC%81%E4%B8%9A%E7%9C%8B%E5%88%B0%E5%9C%A8%E5%8D%8E%E7%BB%8F%E5%95%86%E7%8E%AF%E5%A2%83%E5%BC%80%E5%A7%8B%E6%94%B9%E5%96%84%E7%9A%84%E8%BF%B9%E8%B1%A1-%E5%8C%97%E4%BA%AC%E4%B8%BA%E4%BD%95%E6%8B%85%E5%BF%A7%E7%BE%8E%E6%BE%B3%E6%97%A5%E5%8D%B0%E5%9C%A8%E6%96%90%E6%B5%8E%E7%9A%84%E6%B8%AF%E5%8F%A3%E5%9F%BA%E5%BB%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779889749000.webp","sourceId":"rfi"},{"id":1779886786000,"createdDate":"2026-05-27 12:59","name":"法国国际广播电台","title":"法国热浪预警值：为何同样气温在不同省份有不同的对待？","content":"法国正经历前所未有的热浪，法国气象局已将菲尼斯泰尔省(leFinistère)的高温预警级别提升至橙色，气象预报：该省于2026年5月26日（星期二）出现极端高温，气温将达到34摄氏度；而吉伦特省(laGironde)尽管气象预报气温达36摄氏度，但仍维持在黄色预警级别。造成这种差异的原因是，预警级别是根据各省的具体情况进行调整的。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E5%A2%83%E4%B8%8E%E5%8F%91%E5%B1%95/20260527-%E6%B3%95%E5%9B%BD%E7%83%AD%E6%B5%AA%E9%A2%84%E8%AD%A6%E5%80%BC-%E4%B8%BA%E4%BD%95%E5%90%8C%E6%A0%B7%E6%B0%94%E6%B8%A9%E5%9C%A8%E4%B8%8D%E5%90%8C%E7%9C%81%E4%BB%BD%E6%9C%89%E4%B8%8D%E5%90%8C%E7%9A%84%E5%AF%B9%E5%BE%85","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779886786000.webp","sourceId":"rfi"},{"id":1779878074000,"createdDate":"2026-05-27 10:34","name":"法国国际广播电台","title":"董军或连续第二年缺席香格里拉对话 美中再失直接军事沟通机会","content":"香格里拉对话将于5月29日在新加坡登场，据彭博社引述知情人士报道，中国防长董军预计将连续第2年缺席这场亚洲规模最大的年度安全论坛，使得美国与中国错失高层直接军事沟通机会。届时中东战争、台海局势等议题，将成为香格里拉这个国防论坛上的焦点。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260527-%E8%91%A3%E5%86%9B%E6%88%96%E5%B0%86%E8%BF%9E%E7%BB%AD%E7%AC%AC%E4%BA%8C%E5%B9%B4%E7%BC%BA%E5%B8%AD%E9%A6%99%E6%A0%BC%E9%87%8C%E6%8B%89%E5%AF%B9%E8%AF%9D-%E7%BE%8E%E4%B8%AD%E5%86%8D%E5%A4%B1%E7%9B%B4%E6%8E%A5%E5%86%9B%E4%BA%8B%E6%B2%9F%E9%80%9A%E6%9C%BA%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/05/27/1779878074000.webp","sourceId":"rfi"}]