[{"id":1782897967000,"createdDate":"2026-07-01 09:26","name":"法国国际广播电台","title":"法国强势晋级16强，英格兰、比利时迎来淘汰赛考验，球迷庆祝期间现死伤","content":"6月30日，法国队、挪威队和墨西哥队分别战胜各自对手，顺利晋级八分之一决赛。其中法国队以3比0完胜瑞典队，延续了本届赛事开赛以来的强势表现。随着淘汰赛进行，英格兰队、比利时队、美国队等也将在接下来的比赛中争夺晋级资格。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260701-%E6%B3%95%E5%9B%BD%E5%BC%BA%E5%8A%BF%E6%99%8B%E7%BA%A716%E5%BC%BA%EF%BC%8C%E8%8B%B1%E6%A0%BC%E5%85%B0-%E6%AF%94%E5%88%A9%E6%97%B6%E8%BF%8E%E6%9D%A5%E6%B7%98%E6%B1%B0%E8%B5%9B%E8%80%83%E9%AA%8C%EF%BC%8C%E5%A2%A8%E8%A5%BF%E5%93%A5%E7%8B%82%E6%AC%A2%E6%9C%9F%E9%97%B4%E7%8E%B0%E6%AD%BB%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782897967000.webp","sourceId":"rfi"},{"id":1782893487000,"createdDate":"2026-07-01 08:11","name":"法国国际广播电台","title":"路透独家: 中俄秘密军事训练获高层批准 包括放射生化战 与乌克兰有关","content":"路透社报道显示，此次俄罗斯军人在中国接受的训练包括生物和化学战，与乌克兰战争有关，已获高层批准。至少有四名将军参与其中。欧洲官员对中俄防务关系日益感到担忧。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260701-%E8%B7%AF%E9%80%8F%E7%8B%AC%E5%AE%B6-%E4%B8%AD%E4%BF%84%E7%A7%98%E5%AF%86%E5%86%9B%E4%BA%8B%E8%AE%AD%E7%BB%83%E8%8E%B7%E9%AB%98%E5%B1%82%E6%89%B9%E5%87%86-%E5%8C%85%E6%8B%AC%E6%94%BE%E5%B0%84%E7%94%9F%E5%8C%96%E6%88%98-%E4%B8%8E%E4%B9%8C%E5%85%8B%E5%85%B0%E6%9C%89%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782893487000.webp","sourceId":"rfi"},{"id":1782891953000,"createdDate":"2026-07-01 07:45","name":"法国国际广播电台","title":"日本首相高市早苗从7月1日开始访问印度","content":"高市早苗首相1日乘坐政府专机从羽田机场启程，前往印度访问。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260701-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E4%BB%8E7%E6%9C%881%E6%97%A5%E5%BC%80%E5%A7%8B%E8%AE%BF%E9%97%AE%E5%8D%B0%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782891953000.webp","sourceId":"rfi"},{"id":1782889834000,"createdDate":"2026-07-01 07:10","name":"法国国际广播电台","title":"港府回归庆典突加插中共党庆活动 评论称为中共在港公开活动铺路","content":"今(7月1日)天是英国把香港移交给中国的29周年纪念日，港府除了如常大肆庆祝回归(中国的称呼)之外，更突然「同场加映」在港有如「地下党」般存在的中国共产党成立105周年庆祝活动，要求出席庆典的政商界人士一同观看北京党庆大会的直播。分析认为，是次安排是要把党庆等中共活动逐步在香港变成官方活动，为中共在港活动公开化丶落地化及常态化铺路。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260701-%E6%B8%AF%E5%BA%9C%E5%9B%9E%E5%BD%92%E5%BA%86%E5%85%B8%E7%AA%81%E5%8A%A0%E6%8F%92%E4%B8%AD%E5%85%B1%E5%85%9A%E5%BA%86%E6%B4%BB%E5%8A%A8-%E8%AF%84%E8%AE%BA%E7%A7%B0%E4%B8%BA%E4%B8%AD%E5%85%B1%E5%9C%A8%E6%B8%AF%E5%85%AC%E5%BC%80%E6%B4%BB%E5%8A%A8%E9%93%BA%E8%B7%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782889834000.webp","sourceId":"rfi"},{"id":1782924591000,"createdDate":"2026-07-01 16:49","name":"法国国际广播电台","title":"委内瑞拉双地震遇难者升至1943人 面临食物短缺疫情爆发 新一批美军抵达","content":"委内瑞拉6月24日双地震最新统计遇难人数为1,943人。联合国周二警告称，幸存者严重缺乏食物和住所，可能很快面临疫情暴发。此前公布的死亡人数为1,719人。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260701-%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E5%8F%8C%E5%9C%B0%E9%9C%87%E9%81%87%E9%9A%BE%E8%80%85%E5%8D%87%E8%87%B31943%E4%BA%BA-%E9%9D%A2%E4%B8%B4%E9%A3%9F%E7%89%A9%E7%9F%AD%E7%BC%BA%E7%96%AB%E6%83%85%E7%88%86%E5%8F%91-%E6%96%B0%E4%B8%80%E6%89%B9%E7%BE%8E%E5%86%9B%E6%8A%B5%E8%BE%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782924591000.webp","sourceId":"rfi"},{"id":1782920909000,"createdDate":"2026-07-01 15:48","name":"法国国际广播电台","title":"中国加强管控向境外投资及人才流出新规7.1正式生效","content":"在与美国的技术竞争背景下，北京从7.1周三起加强了对流向海外投资的管控，相关规定正式生效，旨在保障被视为敏感领域的“国家安全”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260701-%E4%B8%AD%E5%9B%BD%E5%8A%A0%E5%BC%BA%E7%AE%A1%E6%8E%A7%E5%90%91%E5%A2%83%E5%A4%96%E6%8A%95%E8%B5%84%E5%8F%8A%E4%BA%BA%E6%89%8D%E6%B5%81%E5%87%BA%E6%96%B0%E8%A7%847-1%E6%AD%A3%E5%BC%8F%E7%94%9F%E6%95%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782920909000.webp","sourceId":"rfi"},{"id":1782919259000,"createdDate":"2026-07-01 15:20","name":"法国国际广播电台","title":"卢卡申科赦免28名政治犯，以缓和与西方关系","content":"据美联社报报导，为了改善与西方的关系，白俄罗斯总统卢卡申科周三（7月1日）赦免了28名政治犯。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260701-%E5%8D%A2%E5%8D%A1%E7%94%B3%E7%A7%91%E8%B5%A6%E5%85%8D28%E5%90%8D%E6%94%BF%E6%B2%BB%E7%8A%AF%EF%BC%8C%E4%BB%A5%E7%BC%93%E5%92%8C%E4%B8%8E%E8%A5%BF%E6%96%B9%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782919259000.webp","sourceId":"rfi"},{"id":1782917900000,"createdDate":"2026-07-01 14:58","name":"法国国际广播电台","title":"中共建党105周年：习近平誓言强军 承认反腐败是“持久战”","content":"法新社7月1日北京消息，中国国家主席习近平周三在中共建党105周年之际承诺，将加强并实现军队现代化，同时根除执政的中国共产党（CPC）内部的腐败问题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260701-%E4%B8%AD%E5%85%B1%E5%BB%BA%E5%85%9A105%E5%91%A8%E5%B9%B4-%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AA%93%E8%A8%80%E5%BC%BA%E5%86%9B-%E6%89%BF%E8%AE%A4%E5%8F%8D%E8%85%90%E8%B4%A5%E6%98%AF-%E6%8C%81%E4%B9%85%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782917900000.webp","sourceId":"rfi"},{"id":1782914922000,"createdDate":"2026-07-01 14:08","name":"法国国际广播电台","title":"中共建党105周年 习近平七一讲话突出哪些重点？","content":"今天7月1日是中国共产党建党105周年纪念日。在北京按传统在人民大会堂举行的庆祝大会上，中共总书记习近平讲话表示，“需要时刻准备经受风高浪急、甚至惊涛骇浪的重大考验“，要求全党坚定信心、接续奋斗，持续推进从严治党，根除腐败，加强军队建设，以及贯彻对台方略。台湾方面当天回应称，习近平的对台论述基本是“旧调重弹”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260701-%E4%B8%AD%E5%85%B1%E5%BB%BA%E5%85%9A105%E5%91%A8%E5%B9%B4-%E4%B9%A0%E8%BF%91%E5%B9%B3%E4%B8%83%E4%B8%80%E8%AE%B2%E8%AF%9D%E7%AA%81%E5%87%BA%E9%82%A3%E4%BA%9B%E9%87%8D%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782914922000.webp","sourceId":"rfi"},{"id":1782914830000,"createdDate":"2026-07-01 14:07","name":"法国国际广播电台","title":"解放报：今在中国，习近平关于民族团结的理念就是法律","content":"大家好，欢迎收听法国报纸摘要。法国队以3比0完胜瑞典高歌猛进16强，下一场将对战劲敌巴拉圭，成为周三7月1日出刊的法国报纸头版话题之一。至于，中国于三月通过的《民族团结法》今天正式上路，则是《解放报》国际亚太版关注的焦点。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260701-%E8%A7%A3%E6%94%BE%E6%8A%A5-%E4%BB%8A%E5%9C%A8%E4%B8%AD%E5%9B%BD%EF%BC%8C%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%85%B3%E4%BA%8E%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E7%9A%84%E7%90%86%E5%BF%B5%E5%B0%B1%E6%98%AF%E6%B3%95%E5%BE%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782914830000.webp","sourceId":"rfi"},{"id":1782912826000,"createdDate":"2026-07-01 13:33","name":"法国国际广播电台","title":"视频 中国港口货物箱吞吐量创历史新高","content":"中国2025年港口日均吞吐货物量超过5千万吨，集装箱吞吐量约97万箱，占全球约三分之一的海上货物运输量，请看视频报道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260701-%E8%A7%86%E9%A2%91-%E4%B8%AD%E5%9B%BD%E6%B8%AF%E5%8F%A3%E8%B4%A7%E7%89%A9%E7%AE%B1%E5%90%9E%E5%90%90%E9%87%8F%E5%88%9B%E5%8E%86%E5%8F%B2%E6%96%B0%E9%AB%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782912826000.webp","sourceId":"rfi"},{"id":1782912023000,"createdDate":"2026-07-01 13:20","name":"法国国际广播电台","title":"视频 法国球迷为蓝调队欢呼雀跃","content":"法国在32强赛中占绝对优势，击败瑞典，球迷们欢声雀跃支持法国，法国球员姆巴佩现场表现突出，请看视频报道。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260701-%E8%A7%86%E9%A2%91-%E6%B3%95%E5%9B%BD%E7%90%83%E8%BF%B7%E4%B8%BA%E8%93%9D%E8%B0%83%E9%98%9F%E6%AC%A2%E5%91%BC%E9%9B%80%E8%B7%83","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782912023000.webp","sourceId":"rfi"},{"id":1782911433000,"createdDate":"2026-07-01 13:10","name":"法国国际广播电台","title":"中国7月1日实施《民族团结进步促进法》，称这将成为两岸最终实现完全统一的法治支撑","content":"中国将于7月1日起实施《民族团结进步促进法》，此法目的就是要以法律形式明确习近平所提出的民族政策。但其实此法与台湾息息相关，不仅因为第63条赋予境外管辖权利，更为台海两岸最终实现完全统一提供法治支撑。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260701-%E4%B8%AD%E5%9B%BD7%E6%9C%881%E6%97%A5%E5%AE%9E%E6%96%BD-%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E8%BF%9B%E6%AD%A5%E4%BF%83%E8%BF%9B%E6%B3%95-%EF%BC%8C%E7%A7%B0%E8%BF%99%E5%B0%86%E6%88%90%E4%B8%BA%E4%B8%A4%E5%B2%B8%E6%9C%80%E7%BB%88%E5%AE%9E%E7%8E%B0%E5%AE%8C%E5%85%A8%E7%BB%9F%E4%B8%80%E7%9A%84%E6%B3%95%E6%B2%BB%E6%94%AF%E6%92%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782911433000.webp","sourceId":"rfi"},{"id":1782906849000,"createdDate":"2026-07-01 11:54","name":"法国国际广播电台","title":"民族团结法7.1正式生效：强制同化 迫害人权 威胁台湾 针对海外 引发担忧","content":"中国一项关于民族团结的新法律于7.1周三正式生效，引发非政府组织“大赦国际”的担忧，该组织认为该法将助长对少数民族的“强制同化”，同时也招致了柏林和台北方面的强烈批评。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260701-%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E6%B3%957-1%E6%AD%A3%E5%BC%8F%E7%94%9F%E6%95%88-%E5%BC%BA%E5%88%B6%E5%90%8C%E5%8C%96-%E8%BF%AB%E5%AE%B3%E4%BA%BA%E6%9D%83-%E5%A8%81%E8%83%81%E5%8F%B0%E6%B9%BE-%E9%92%88%E5%AF%B9%E6%B5%B7%E5%A4%96-%E5%BC%95%E5%8F%91%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782906849000.webp","sourceId":"rfi"},{"id":1782895187000,"createdDate":"2026-07-01 08:39","name":"法国国际广播电台","title":"欧盟今起对进入欧盟小额包裹开征3欧元 遏制中国廉价商品涌入","content":"欧盟周三（7月1日）起对进入欧盟的小额包裹开征3欧元费用，此举是欧盟主要为遏制Shein（希音）、Temu（拼多多海外平台）和阿里巴巴旗下AliExpress（速卖通）等中国跨境电商“不公平竞争”的第一步。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260701-%E6%AC%A7%E7%9B%9F%E4%BB%8A%E8%B5%B7%E5%AF%B9%E8%BF%9B%E5%85%A5%E6%AC%A7%E7%9B%9F%E5%B0%8F%E9%A2%9D%E5%8C%85%E8%A3%B9%E5%BC%80%E5%BE%813%E6%AC%A7%E5%85%83-%E9%81%8F%E5%88%B6%E4%B8%AD%E5%9B%BD%E5%BB%89%E4%BB%B7%E5%95%86%E5%93%81%E6%B6%8C%E5%85%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782895187000.webp","sourceId":"rfi"}]