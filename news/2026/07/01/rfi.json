[{"id":1782897967000,"createdDate":"2026-07-01 09:26","name":"法国国际广播电台","title":"法国强势晋级16强，英格兰、比利时迎来淘汰赛考验，球迷庆祝期间现死伤","content":"6月30日，法国队、挪威队和墨西哥队分别战胜各自对手，顺利晋级八分之一决赛。其中法国队以3比0完胜瑞典队，延续了本届赛事开赛以来的强势表现。随着淘汰赛进行，英格兰队、比利时队、美国队等也将在接下来的比赛中争夺晋级资格。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260701-%E6%B3%95%E5%9B%BD%E5%BC%BA%E5%8A%BF%E6%99%8B%E7%BA%A716%E5%BC%BA%EF%BC%8C%E8%8B%B1%E6%A0%BC%E5%85%B0-%E6%AF%94%E5%88%A9%E6%97%B6%E8%BF%8E%E6%9D%A5%E6%B7%98%E6%B1%B0%E8%B5%9B%E8%80%83%E9%AA%8C%EF%BC%8C%E5%A2%A8%E8%A5%BF%E5%93%A5%E7%8B%82%E6%AC%A2%E6%9C%9F%E9%97%B4%E7%8E%B0%E6%AD%BB%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782897967000.webp","sourceId":"rfi"},{"id":1782893487000,"createdDate":"2026-07-01 08:11","name":"法国国际广播电台","title":"路透独家: 中俄秘密军事训练获高层批准 包括放射生化战 与乌克兰有关","content":"路透社报道显示，此次俄罗斯军人在中国接受的训练包括生物和化学战，与乌克兰战争有关，已获高层批准。至少有四名将军参与其中。欧洲官员对中俄防务关系日益感到担忧。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260701-%E8%B7%AF%E9%80%8F%E7%8B%AC%E5%AE%B6-%E4%B8%AD%E4%BF%84%E7%A7%98%E5%AF%86%E5%86%9B%E4%BA%8B%E8%AE%AD%E7%BB%83%E8%8E%B7%E9%AB%98%E5%B1%82%E6%89%B9%E5%87%86-%E5%8C%85%E6%8B%AC%E6%94%BE%E5%B0%84%E7%94%9F%E5%8C%96%E6%88%98-%E4%B8%8E%E4%B9%8C%E5%85%8B%E5%85%B0%E6%9C%89%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782893487000.webp","sourceId":"rfi"},{"id":1782891953000,"createdDate":"2026-07-01 07:45","name":"法国国际广播电台","title":"日本首相高市早苗从7月1日开始访问印度","content":"高市早苗首相1日乘坐政府专机从羽田机场启程，前往印度访问。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260701-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E4%BB%8E7%E6%9C%881%E6%97%A5%E5%BC%80%E5%A7%8B%E8%AE%BF%E9%97%AE%E5%8D%B0%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782891953000.webp","sourceId":"rfi"},{"id":1782889834000,"createdDate":"2026-07-01 07:10","name":"法国国际广播电台","title":"港府回归庆典突加插中共党庆活动 评论称为中共在港公开活动铺路","content":"今(7月1日)天是英国把香港移交给中国的29周年纪念日，港府除了如常大肆庆祝回归(中国的称呼)之外，更突然「同场加映」在港有如「地下党」般存在的中国共产党成立105周年庆祝活动，要求出席庆典的政商界人士一同观看北京党庆大会的直播。分析认为，是次安排是要把党庆等中共活动逐步在香港变成官方活动，为中共在港活动公开化丶落地化及常态化铺路。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260701-%E6%B8%AF%E5%BA%9C%E5%9B%9E%E5%BD%92%E5%BA%86%E5%85%B8%E7%AA%81%E5%8A%A0%E6%8F%92%E4%B8%AD%E5%85%B1%E5%85%9A%E5%BA%86%E6%B4%BB%E5%8A%A8-%E8%AF%84%E8%AE%BA%E7%A7%B0%E4%B8%BA%E4%B8%AD%E5%85%B1%E5%9C%A8%E6%B8%AF%E5%85%AC%E5%BC%80%E6%B4%BB%E5%8A%A8%E9%93%BA%E8%B7%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/01/1782889834000.webp","sourceId":"rfi"}]