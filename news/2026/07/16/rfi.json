[{"id":1784197608000,"createdDate":"2026-07-16 10:26","name":"法国国际广播电台","title":"《光明日报》驻布拉格记者涉谍案被捕后续 一捷克商人在华因涉嫌危害国家安全被查","content":"中国外交部周四表示，一名自6月底以来在中国被拘留的捷克公民正因涉嫌危害国家安全罪接受调查。捷克外交部于周三宣布了这一拘留消息，并表示其官员已与该公民取得领事联系，但未透露更多细节。捷克新闻网站“SeznamZpravy”报导称，一名曾在华经商的捷克商人遭中国安全部门在机场拘留，预计将被控从事间谍活动。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260716-%E5%85%89%E6%98%8E%E6%97%A5%E6%8A%A5-%E9%A9%BB%E5%B8%83%E6%8B%89%E6%A0%BC%E8%AE%B0%E8%80%85%E6%B6%89%E8%B0%8D%E6%A1%88%E8%A2%AB%E6%8D%95%E5%90%8E%E7%BB%AD-%E4%B8%80%E6%8D%B7%E5%85%8B%E5%95%86%E4%BA%BA%E5%9C%A8%E5%8D%8E%E5%9B%A0%E6%B6%89%E5%AB%8C%E5%8D%B1%E5%AE%B3%E5%9B%BD%E5%AE%B6%E5%AE%89%E5%85%A8%E8%A2%AB%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784197608000.webp","sourceId":"rfi"},{"id":1784195073000,"createdDate":"2026-07-16 09:44","name":"法国国际广播电台","title":"欧盟文件指责中俄为首“按照自身利益重塑全球秩序，助长回归势力范围的逻辑”","content":"据《南华早报》报导，欧盟在一份措辞极其严厉的新立场文件中指责中国和俄罗斯试图“按照自身利益重塑全球秩序”，并“助长回归势力范围的逻辑”；这是该集团迄今为止针对北京最强烈的官方批评之一。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260716-%E6%AC%A7%E7%9B%9F%E6%96%87%E4%BB%B6%E6%8C%87%E8%B4%A3%E4%B8%AD%E4%BF%84%E4%B8%BA%E9%A6%96-%E6%8C%89%E7%85%A7%E8%87%AA%E8%BA%AB%E5%88%A9%E7%9B%8A%E9%87%8D%E5%A1%91%E5%85%A8%E7%90%83%E7%A7%A9%E5%BA%8F%EF%BC%8C%E5%8A%A9%E9%95%BF%E5%9B%9E%E5%BD%92%E5%8A%BF%E5%8A%9B%E8%8C%83%E5%9B%B4%E7%9A%84%E9%80%BB%E8%BE%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784195073000.webp","sourceId":"rfi"},{"id":1784194086000,"createdDate":"2026-07-16 09:28","name":"法国国际广播电台","title":"法国队18日对阵英国队争夺第三名，德尚将告别法国队主教练生涯","content":"阿根廷队15日以2：1战胜英国队后，2026世界杯足球赛赛程进入尾声。7月19日，阿根廷队与西班牙队将在纽约争夺本届世界杯的冠亚军。在此之前，冠军梦碎的法国队和英国队则将于18日在迈阿密进行最后一场比赛，决出本届世界杯的第三名。法国队在7月14日法国国庆日以2：0输给西班牙，错失最后角逐的机会，它将以怎样的心态参加象征性的最后一场比赛值得关注。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260716-%E6%B3%95%E5%9B%BD%E9%98%9F18%E6%97%A5%E5%AF%B9%E9%98%B5%E8%8B%B1%E5%9B%BD%E9%98%9F%E4%BA%89%E5%A4%BA%E7%AC%AC%E4%B8%89%E5%90%8D%EF%BC%8C%E5%BE%B7%E5%B0%9A%E5%B0%86%E5%91%8A%E5%88%AB%E6%B3%95%E5%9B%BD%E9%98%9F%E4%B8%BB%E6%95%99%E7%BB%83%E7%94%9F%E6%B6%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784194086000.webp","sourceId":"rfi"},{"id":1784192764000,"createdDate":"2026-07-16 09:06","name":"法国国际广播电台","title":"东盟调整对缅策略 南海仲裁集体沉默","content":"最近，随着转型后的缅甸新政府针对中美俄印等大国陆续开启外交出访行程，为了应对不断变化的地缘政治形势，东盟开始调整对缅策略，旨在逐步化解孤立缅甸造成的外交僵局。时值南海仲裁结果出台十周年甚嚣尘上，美菲联合全球盟友集体施压，遭到北京强力反制，东盟抉择两难之际，多数国家选择保持审慎态度。与此同时，泰国和柬埔寨领导人急于招商引资几乎同步访问北京，由此引发外界关于“北京开展斡旋、调停泰柬双边冲突”的高度关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260716-%E4%B8%9C%E7%9B%9F%E8%B0%83%E6%95%B4%E5%AF%B9%E7%BC%85%E7%AD%96%E7%95%A5-%E5%8D%97%E6%B5%B7%E4%BB%B2%E8%A3%81%E9%9B%86%E4%BD%93%E6%B2%89%E9%BB%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784192764000.webp","sourceId":"rfi"},{"id":1784192745000,"createdDate":"2026-07-16 09:05","name":"法国国际广播电台","title":"特朗普据报将在周四晚演讲中谈及中国涉嫌干预美国选举事宜","content":"据哥伦比亚广播公司（CBS）援引知情人士报导称，美国总统特朗普（DonaldTrump）周四晚间的演讲预计将涉及此前未被披露的中国涉嫌干预美国选举一事。其中包含的内容包括：关于北京方面窃取美国选民数据的指控，以及中情局（CIA）知晓此事却未在特朗普首个总统任期内向其通报相关信息的证据。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260716-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8D%AE%E6%8A%A5%E5%B0%86%E5%9C%A8%E5%91%A8%E5%9B%9B%E6%99%9A%E6%BC%94%E8%AE%B2%E4%B8%AD%E8%B0%88%E5%8F%8A%E4%B8%AD%E5%9B%BD%E6%B6%89%E5%AB%8C%E5%B9%B2%E9%A2%84%E7%BE%8E%E5%9B%BD%E9%80%89%E4%B8%BE%E4%BA%8B%E5%AE%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784192745000.webp","sourceId":"rfi"},{"id":1784191817000,"createdDate":"2026-07-16 08:50","name":"法国国际广播电台","title":"英国宣布将中国敬业集团原旗下英国钢铁公司国有化","content":"英国政府周四（7月16日）宣布将钢铁企业“英国钢铁公司”（BritishSteel）国有化。该公司此前由中国敬业集团所有，英国政府于去年4月接管该企业，以避免其旗下两座高炉关闭。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260716-%E8%8B%B1%E5%9B%BD%E5%AE%A3%E5%B8%83%E5%B0%86%E4%B8%AD%E5%9B%BD%E6%95%AC%E4%B8%9A%E9%9B%86%E5%9B%A2%E5%8E%9F%E6%97%97%E4%B8%8B%E8%8B%B1%E5%9B%BD%E9%92%A2%E9%93%81%E5%85%AC%E5%8F%B8%E5%9B%BD%E6%9C%89%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784191817000.webp","sourceId":"rfi"},{"id":1784191613000,"createdDate":"2026-07-16 08:46","name":"法国国际广播电台","title":"英伟达首席执行官黄仁勋访日 宣布和日本多家顶级企业合作","content":"市值位居全球第一的美国半导体巨头英伟达（NVIDIA）首席执行官黄仁勋（JensenHuang）于15日开始访问日本。16日，三菱重工、东京电子、欧姆龙等多家日本企业相继宣布，将与英伟达开展合作。2025年4月21日，当时的石破首相在首相官邸会见访日的黄仁勋，对其来访表示欢迎，黄仁勋是否能与高市首相见面不得而知。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260716-%E8%8B%B1%E4%BC%9F%E8%BE%BE%E9%A6%96%E5%B8%AD%E6%89%A7%E8%A1%8C%E5%AE%98%E9%BB%84%E4%BB%81%E5%8B%8B%E8%AE%BF%E6%97%A5-%E5%AE%A3%E5%B8%83%E5%92%8C%E6%97%A5%E6%9C%AC%E5%A4%9A%E5%AE%B6%E9%A1%B6%E7%BA%A7%E4%BC%81%E4%B8%9A%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784191613000.webp","sourceId":"rfi"},{"id":1784190614000,"createdDate":"2026-07-16 08:30","name":"法国国际广播电台","title":"就向中国情报人员泄露受限信息做虚假陈述 美联储前高级顾问被判囚38个月","content":"美国司法部周三表示，美联储一名前高级顾问因向调查人员就向中国情报人员泄露有关美联储的机密信息一事作虚假陈述，被判处38个月联邦监禁。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260716-%E5%B0%B1%E5%90%91%E4%B8%AD%E5%9B%BD%E6%83%85%E6%8A%A5%E4%BA%BA%E5%91%98%E6%B3%84%E9%9C%B2%E5%8F%97%E9%99%90%E4%BF%A1%E6%81%AF%E5%81%9A%E8%99%9A%E5%81%87%E9%99%88%E8%BF%B0-%E7%BE%8E%E8%81%94%E5%82%A8%E5%89%8D%E9%AB%98%E7%BA%A7%E9%A1%BE%E9%97%AE%E8%A2%AB%E5%88%A4%E5%9B%9A38%E4%B8%AA%E6%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784190614000.webp","sourceId":"rfi"},{"id":1784184202000,"createdDate":"2026-07-16 06:43","name":"法国国际广播电台","title":"香港加强打压独立书店惹关注 赖清德忧公共讨论受压 团体斥要灭自由思想空间","content":"香港警方国安处人员昨(15日)午以书店输入海外怀疑煽动书籍而拘捕两间书店合共五人，引起海外关注。从历经书禁年代走来的台湾总统赖清德表示，当书店面对红线压力，人民的思考与表达自由不再，公共讨论空间也不断被压缩；另外两个国际人权组织亦发表声明批评港府，指港府针对独立书店的打压不断升级，再次证明国安法律已被武器化，用以消灭自由思想及讨论空间，使异见噤声。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260716-%E9%A6%99%E6%B8%AF%E5%8A%A0%E5%BC%BA%E6%89%93%E5%8E%8B%E7%8B%AC%E7%AB%8B%E4%B9%A6%E5%BA%97%E6%83%B9%E5%85%B3%E6%B3%A8-%E8%B5%96%E6%B8%85%E5%BE%B7%E5%BF%A7%E5%85%AC%E5%85%B1%E8%AE%A8%E8%AE%BA%E5%8F%97%E5%8E%8B-%E5%9B%A2%E4%BD%93%E6%96%A5%E8%A6%81%E7%81%AD%E8%87%AA%E7%94%B1%E6%80%9D%E6%83%B3%E7%A9%BA%E9%97%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784184202000.webp","sourceId":"rfi"},{"id":1784183912000,"createdDate":"2026-07-16 06:38","name":"法国国际广播电台","title":"港国安一日内拘两独立书店共五人 首涉从海外进口煽动书籍","content":"香港警方国安处人员在香港书展开幕日搜查已预告结业的独立书店「留下书舍」和香港老牌书店「田园书屋」，并以涉嫌干犯《基本法》23条下的新煽动罪，拘捕包括负责人在内的五名男女，同时从书店带走多箱书籍及物品。这是当局首次公开表明基於海外进口书籍涉嫌有煽动意图而采取行动，但又拒绝披露沙及的书籍名称及煽动因素。有媒体引述消息称，相关「隐身禁书」包括《唯红花绽放：习近平时代的认同与归属》等由台湾出版的书籍。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260716-%E6%B8%AF%E5%9B%BD%E5%AE%89%E4%B8%80%E6%97%A5%E5%86%85%E6%8B%98%E4%B8%A4%E7%8B%AC%E7%AB%8B%E4%B9%A6%E5%BA%97%E5%85%B1%E4%BA%94%E4%BA%BA-%E9%A6%96%E6%B6%89%E4%BB%8E%E6%B5%B7%E5%A4%96%E8%BF%9B%E5%8F%A3%E7%85%BD%E5%8A%A8%E4%B9%A6%E7%B1%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784183912000.webp","sourceId":"rfi"},{"id":1784183585000,"createdDate":"2026-07-16 06:33","name":"法国国际广播电台","title":"事隔七年 脱罪法律系女生重审暴动罪成 判囚34个月","content":"涉嫌参与2019年社会运动期间於湾仔发生的冲突事件的大学法律系女学生，经审讯後裁定暴动罪名不成立，律政司经上诉後得直，案件被发还重审后，遭改判暴动罪成，判监34个月。法官表示，已考虑被告由无罪改判有罪，将失去成为律师机会等因素，酌情减刑。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260716-%E4%BA%8B%E9%9A%94%E4%B8%83%E5%B9%B4-%E8%84%B1%E7%BD%AA%E6%B3%95%E5%BE%8B%E7%B3%BB%E5%A5%B3%E7%94%9F%E9%87%8D%E5%AE%A1%E6%9A%B4%E5%8A%A8%E7%BD%AA%E6%88%90-%E5%88%A4%E5%9B%9A34%E4%B8%AA%E6%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784183585000.webp","sourceId":"rfi"},{"id":1784217320000,"createdDate":"2026-07-16 15:55","name":"法国国际广播电台","title":"中方扣留巴旗船舶激增 巴拿马官员出访北京，力求化解纠纷","content":"巴拿马官员正前往北京，试图化解一场争端；此前，中国当局大幅加强了扣留巴拿马籍船只的力度，导致数百艘船只退出了该国的船舶登记。这场冲突在2月升级：当时，巴拿马在面临美国施加的巨大压力、要求其遏制中方在巴拿马运河的影响力之际，接管了由总部位于香港的长和（CKHutchison）运营的两个港口——巴拿马最高法院更早时已裁定该公司的特许经营权无效。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260716-%E4%B8%AD%E6%96%B9%E6%89%A3%E7%95%99%E5%B7%B4%E6%97%97%E8%88%B9%E8%88%B6%E6%BF%80%E5%A2%9E-%E5%B7%B4%E6%8B%BF%E9%A9%AC%E5%AE%98%E5%91%98%E5%87%BA%E8%AE%BF%E5%8C%97%E4%BA%AC%EF%BC%8C%E5%8A%9B%E6%B1%82%E5%8C%96%E8%A7%A3%E7%BA%A0%E7%BA%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784217320000.webp","sourceId":"rfi"},{"id":1784215571000,"createdDate":"2026-07-16 15:26","name":"法国国际广播电台","title":"中方已请求泰国尽快遣返调查记者白兆东 人权组织呼吁允许其前往他所选择的国家","content":"中方已要求泰国迅速引渡著名调查记者白兆东；人权组织指出，该记者因调查国内腐败问题，回国后将面临政治迫害和酷刑风险。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260716-%E4%B8%AD%E6%96%B9%E5%B7%B2%E8%AF%B7%E6%B1%82%E6%B3%B0%E5%9B%BD%E5%B0%BD%E5%BF%AB%E9%81%A3%E8%BF%94%E8%B0%83%E6%9F%A5%E8%AE%B0%E8%80%85%E7%99%BD%E5%85%86%E4%B8%9C-%E4%BA%BA%E6%9D%83%E7%BB%84%E7%BB%87%E5%91%BC%E5%90%81%E5%85%81%E8%AE%B8%E5%85%B6%E5%89%8D%E5%BE%80%E4%BB%96%E6%89%80%E9%80%89%E6%8B%A9%E7%9A%84%E5%9B%BD%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784215571000.webp","sourceId":"rfi"},{"id":1784213686000,"createdDate":"2026-07-16 14:54","name":"法国国际广播电台","title":"众议员致信美商务部长促禁购中国存储芯片 参议员提法案加强对中国在美制药业投资审查","content":"美国众议院美国与中共战略竞争特设委员会主席穆勒纳尔（JohnMoolenaar）致信敦促特朗普政府禁止美国企业从长鑫存储（CXMT）和长江存储（YMTC）采购存储芯片，以避免在人工智能基础设施的关键组件上依赖中国。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260716-%E4%BC%97%E8%AE%AE%E5%91%98%E8%87%B4%E4%BF%A1%E7%BE%8E%E5%95%86%E5%8A%A1%E9%83%A8%E9%95%BF%E4%BF%83%E7%A6%81%E8%B4%AD%E4%B8%AD%E5%9B%BD%E5%AD%98%E5%82%A8%E8%8A%AF%E7%89%87-%E5%8F%82%E8%AE%AE%E5%91%98%E6%8F%90%E6%B3%95%E6%A1%88%E5%8A%A0%E5%BC%BA%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%9C%A8%E7%BE%8E%E5%88%B6%E8%8D%AF%E4%B8%9A%E6%8A%95%E8%B5%84%E5%AE%A1%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784213686000.webp","sourceId":"rfi"},{"id":1784210051000,"createdDate":"2026-07-16 13:54","name":"法国国际广播电台","title":"马朝旭预计下周访美 或为习近平访问华盛顿铺垫","content":"据《南华早报》报导，中国外交部副部长马朝旭预计将于下周访问美国；此行很可能是为中国国家主席习近平今年晚些时候访问华盛顿进行铺垫。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260716-%E9%A9%AC%E6%9C%9D%E6%97%AD%E9%A2%84%E8%AE%A1%E4%B8%8B%E5%91%A8%E8%AE%BF%E7%BE%8E-%E6%88%96%E4%B8%BA%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%BF%E9%97%AE%E5%8D%8E%E7%9B%9B%E9%A1%BF%E9%93%BA%E5%9E%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784210051000.webp","sourceId":"rfi"},{"id":1784209172000,"createdDate":"2026-07-16 13:39","name":"法国国际广播电台","title":"巴新外长宣布立即关闭台湾驻处：北京高度赞赏 台北严正抗议","content":"巴布亚新几内亚外交部长特卡琴科（JustinTkatchenko）周四宣布，该国政府已决定立即关闭“驻巴布亚纽几内亚台北经济办事处”，此举受到北京方面的“高度赞赏”；不过，台北方面表示该代表处将“持续维持正常运作”。长期以来，太平洋地区一直是两岸外交角力的场所。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260716-%E5%B7%B4%E6%96%B0%E5%A4%96%E9%95%BF%E5%AE%A3%E5%B8%83%E7%AB%8B%E5%8D%B3%E5%85%B3%E9%97%AD%E5%8F%B0%E6%B9%BE%E9%A9%BB%E5%A4%84-%E5%8C%97%E4%BA%AC%E9%AB%98%E5%BA%A6%E8%B5%9E%E8%B5%8F-%E5%8F%B0%E5%8C%97%E4%B8%A5%E6%AD%A3%E6%8A%97%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784209172000.webp","sourceId":"rfi"},{"id":1784207843000,"createdDate":"2026-07-16 13:17","name":"法国国际广播电台","title":"法国专家谈台湾是否需要基因编辑植物","content":"欧盟的新转基因技术（NGTs）使用法案在获得欧洲议会批准之后于7月16日正式生效，无论是支持还是反对推广此一技术的人都认为这将对欧洲的农业带来翻天覆地的变化，尽管目前还很难预测此一变化究竟是改善还是恶化。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260716-%E6%B3%95%E5%9B%BD%E4%B8%93%E5%AE%B6%E8%B0%88%E5%8F%B0%E6%B9%BE%E6%98%AF%E5%90%A6%E9%9C%80%E8%A6%81%E5%9F%BA%E5%9B%A0%E7%BC%96%E8%BE%91%E6%A4%8D%E7%89%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784207843000.webp","sourceId":"rfi"},{"id":1784206572000,"createdDate":"2026-07-16 12:56","name":"法国国际广播电台","title":"团队有声音担心中方视缄默为索取更多让步契机 美贸易代表指9月特习会多为盘点进展","content":"在美国总统特朗普（DonaldTrump）的贸易团队内部，两个令人清醒的结论正逐渐浮出水面：中国在贸易协议上存在违约行为，而美国对此却不会采取实质性举措。恢复关键矿产和稀土的获取——这对美国企业生产包括汽车和战斗机在内的各类产品至关重要——是特朗普去年在韩国釜山与中国国家主席习近平达成的协议中的一项核心目标。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260716-%E5%9B%A2%E9%98%9F%E6%9C%89%E5%A3%B0%E9%9F%B3%E6%8B%85%E5%BF%83%E4%B8%AD%E6%96%B9%E8%A7%86%E7%BC%84%E9%BB%98%E4%B8%BA%E7%B4%A2%E5%8F%96%E6%9B%B4%E5%A4%9A%E8%AE%A9%E6%AD%A5%E5%A5%91%E6%9C%BA-%E7%BE%8E%E8%B4%B8%E6%98%93%E4%BB%A3%E8%A1%A8%E6%8C%879%E6%9C%88%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%A4%9A%E4%B8%BA%E7%9B%98%E7%82%B9%E8%BF%9B%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784206572000.webp","sourceId":"rfi"},{"id":1784197646000,"createdDate":"2026-07-16 10:27","name":"法国国际广播电台","title":"“年轻消费群的寻鲜需求”：在大巴黎，中日韩亚洲超市势不可挡","content":"周三15日晚间，法国国民议会以291票赞成、241票反对，仅50票的微弱优势通过了患有绝症的成年人在符合严格条件后可获结束生命药物的立法。法国也由此加入了少数允许这一权利的国家行列其中包括比利时、荷兰、瑞士、加拿大和乌拉圭等。今天周四7月16日，法国各主流日报无不发表立场分明的评论与分析文章。除围绕安乐死获得通过的争议外，《回声报》关注了亚洲超市在整个巴黎强势崛起的现象。法国亚洲超市龙头企业陈氏兄弟今夏将在在巴黎西北部开设1000平方米的新门店。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260716-%E5%B9%B4%E8%BD%BB%E6%B6%88%E8%B4%B9%E7%BE%A4%E7%9A%84%E5%AF%BB%E9%B2%9C%E9%9C%80%E6%B1%82-%E5%9C%A8%E5%A4%A7%E5%B7%B4%E9%BB%8E%EF%BC%8C%E4%B8%AD%E6%97%A5%E9%9F%A9%E4%BA%9A%E6%B4%B2%E8%B6%85%E5%B8%82%E5%8A%BF%E4%B8%8D%E5%8F%AF%E6%8C%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784197646000.webp","sourceId":"rfi"},{"id":1784241139000,"createdDate":"2026-07-16 22:32","name":"法国国际广播电台","title":"法国和德国加强包括核威慑在内的联合防务计划","content":"法国和德国将在周五举行的联合政府会议上，寻求走出之前一个陷入困境的战斗机项目失败的阴影，并加强包括核威慑在内的其他联合防务计划。法国总统马克龙与德国总理默茨将主持周五在科隆附近举行的年度会议。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260716-%E6%B3%95%E5%9B%BD%E5%92%8C%E5%BE%B7%E5%9B%BD%E5%8A%A0%E5%BC%BA%E5%8C%85%E6%8B%AC%E6%A0%B8%E5%A8%81%E6%85%91%E5%9C%A8%E5%86%85%E7%9A%84%E8%81%94%E5%90%88%E9%98%B2%E5%8A%A1%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784241139000.webp","sourceId":"rfi"},{"id":1784236046000,"createdDate":"2026-07-16 21:07","name":"法国国际广播电台","title":"特朗普将就选举公正性发表全国讲话","content":"美国总统特朗普将于周四向美国民众发表讲话，重点阐述他所声称的美国选举制度的种种漏洞。尽管他已在2016年和2024年两次当选总统，但他仍然反复强调——却未提供任何证据——美国的投票程序存在腐败，对共和党不利。他还坚称自己赢得了2020年的总统大选。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260716-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B0%86%E5%B0%B1%E9%80%89%E4%B8%BE%E5%85%AC%E6%AD%A3%E6%80%A7%E5%8F%91%E8%A1%A8%E5%85%A8%E5%9B%BD%E8%AE%B2%E8%AF%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784236046000.webp","sourceId":"rfi"},{"id":1784235932000,"createdDate":"2026-07-16 21:05","name":"法国国际广播电台","title":"枫丹白露大火后     繁忙的高速公路A6终开通","content":"巴黎近郊枫丹白露的大火基本上得到控制，但“泥炭火”很容易死灰复燃，恐怕需要更长的时间才能彻底扑灭火势。被誉为“太阳高速公路”的A6从这个周四晚20点正式开通，这对开车去了南部海岸度假的人来说，可以通过这条高速公路顺利地返回巴黎大区。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260716-%E6%9E%AB%E4%B8%B9%E7%99%BD%E9%9C%B2%E5%A4%A7%E7%81%AB%E5%90%8E-%E7%B9%81%E5%BF%99%E7%9A%84%E9%AB%98%E9%80%9F%E5%85%AC%E8%B7%AFa6%E7%BB%88%E5%BC%80%E9%80%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784235932000.webp","sourceId":"rfi"},{"id":1784235531000,"createdDate":"2026-07-16 20:58","name":"法国国际广播电台","title":"加拿大火灾烟雾蔓延至美国纽约","content":"周四，加拿大安大略省偏远地区肆虐的野火产生的烟雾飘过美国东北部，进入纽约市，导致数百万人面临严重恶化的空气质量。继周三多伦多被末日般的黄色烟雾笼罩之后，与加拿大接壤的明尼苏达州、威斯康星州、密歇根州和伊利诺伊州受到的影响尤为严重，预计纽约市也将在当天下午受到影响。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260716-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E7%81%AB%E7%81%BE%E7%83%9F%E9%9B%BE%E8%94%93%E5%BB%B6%E8%87%B3%E7%BE%8E%E5%9B%BD%E7%BA%BD%E7%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784235531000.webp","sourceId":"rfi"},{"id":1784235092000,"createdDate":"2026-07-16 20:51","name":"法国国际广播电台","title":"小鹏汽车考虑在德国建生产线","content":"中国汽车制造商小鹏MONAL037月16日将在德国慕尼黑举行全球上市发布会，2026年将在全球64个国家开启销售。小鹏汽车首席执行官何小鹏7月16日表示，该公司正在探索利用德国闲置工厂生产汽车的可能性，因为德国主要汽车制造商正在寻求解决产能过剩问题的方案。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260716-%E5%B0%8F%E9%B9%8F%E6%B1%BD%E8%BD%A6%E8%80%83%E8%99%91%E5%9C%A8%E5%BE%B7%E5%9B%BD%E5%BB%BA%E7%94%9F%E4%BA%A7%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784235092000.webp","sourceId":"rfi"},{"id":1784234809000,"createdDate":"2026-07-16 20:46","name":"法国国际广播电台","title":"乌民众走上街头   抗议泽连斯基大规模改组政府","content":"周四，乌克兰议会任命前石油天然气公司首席执行官谢尔盖·科列茨基（SergiiKoretsky）为总理。此前，民众普遍对泽连斯基表示不信任，认为他罢免了广受欢迎的国防部长米哈伊洛·费多罗夫（MykhaïloFedorov）。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260716-%E4%B9%8C%E6%B0%91%E4%BC%97%E8%B5%B0%E4%B8%8A%E8%A1%97%E5%A4%B4-%E6%8A%97%E8%AE%AE%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%A4%A7%E8%A7%84%E6%A8%A1%E6%94%B9%E7%BB%84%E6%94%BF%E5%BA%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784234809000.webp","sourceId":"rfi"},{"id":1784234660000,"createdDate":"2026-07-16 20:44","name":"法国国际广播电台","title":"美国宣布两大墨贩毒集团为“恐怖组织”","content":"美国国务卿马可·卢比奥周四宣布，美国已将两个墨西哥贩毒集团列为“外国恐怖组织”。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260716-%E7%BE%8E%E5%9B%BD%E5%AE%A3%E5%B8%83%E4%B8%A4%E5%A4%A7%E5%A2%A8%E8%B4%A9%E6%AF%92%E9%9B%86%E5%9B%A2%E4%B8%BA-%E6%81%90%E6%80%96%E7%BB%84%E7%BB%87","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784234660000.webp","sourceId":"rfi"},{"id":1784234547000,"createdDate":"2026-07-16 20:42","name":"法国国际广播电台","title":"美国新《移民和国籍法》：依靠政府福利生活外国人可能被拒绿卡","content":"美国国土安全部（DHS）周四（7月16日）发布最终规则包括：如果外国人在美国依靠政府福利生活、无法自力更生，那么在申请绿卡时可能被拒。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260716-%E7%BE%8E%E5%9B%BD%E6%96%B0-%E7%A7%BB%E6%B0%91%E5%92%8C%E5%9B%BD%E7%B1%8D%E6%B3%95-%E4%BE%9D%E9%9D%A0%E6%94%BF%E5%BA%9C%E7%A6%8F%E5%88%A9%E7%94%9F%E6%B4%BB%E5%A4%96%E5%9B%BD%E4%BA%BA%E5%8F%AF%E8%83%BD%E8%A2%AB%E6%8B%92%E7%BB%BF%E5%8D%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784234547000.webp","sourceId":"rfi"},{"id":1784234340000,"createdDate":"2026-07-16 20:39","name":"法国国际广播电台","title":"决赛时应为美执法人员击毙的两移民默哀一分钟","content":"人权观察组织（HRW）周四呼吁国际足联在周日世界杯决赛前默哀一分钟，悼念本月被美国移民和海关执法局（ICE）执法人员杀害的两名外籍人士。一名哥伦比亚男子于周一在缅因州被杀，一名墨西哥男子于上周在德克萨斯州休斯顿被杀。这两起事件均发生在特朗普总统打击非法移民行动期间，当时执法人员正在进行交通拦截。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260716-%E5%86%B3%E8%B5%9B%E6%97%B6%E5%BA%94%E4%B8%BA%E7%BE%8E%E6%89%A7%E6%B3%95%E4%BA%BA%E5%91%98%E5%87%BB%E6%AF%99%E7%9A%84%E4%B8%A4%E7%A7%BB%E6%B0%91%E9%BB%98%E5%93%80%E4%B8%80%E5%88%86%E9%92%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784234340000.webp","sourceId":"rfi"},{"id":1784231902000,"createdDate":"2026-07-16 19:58","name":"法国国际广播电台","title":"民调：中国全球好感度首度超越美国","content":"根据最新全球民意调查，美国长年在国际社会享有较中国更高好感度的局面今年首度出现逆转。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260716-%E6%B0%91%E8%B0%83-%E4%B8%AD%E5%9B%BD%E5%85%A8%E7%90%83%E5%A5%BD%E6%84%9F%E5%BA%A6%E9%A6%96%E5%BA%A6%E8%B6%85%E8%B6%8A%E7%BE%8E%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784231902000.webp","sourceId":"rfi"},{"id":1784230954000,"createdDate":"2026-07-16 19:42","name":"法国国际广播电台","title":"世界杯半决赛：阿根廷赢英国  “特别的胜利”引发外交风波","content":"在15日的半决赛中，阿根廷足球球星梅西（LionelMessi）率队逆转击败英格兰队、挺进世界杯决赛后，形容这是一场“特别的胜利”。其中含义令人生发更多的想象。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260716-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%8D%8A%E5%86%B3%E8%B5%9B-%E9%98%BF%E6%A0%B9%E5%BB%B7%E8%B5%A2%E8%8B%B1%E5%9B%BD-%E7%89%B9%E5%88%AB%E7%9A%84%E8%83%9C%E5%88%A9-%E5%BC%95%E5%8F%91%E5%A4%96%E4%BA%A4%E9%A3%8E%E6%B3%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784230954000.webp","sourceId":"rfi"},{"id":1784226988000,"createdDate":"2026-07-16 18:36","name":"法国国际广播电台","title":"法媒：人工智能在中国绝非纸上谈兵","content":"7月16日，成立世界人工智能合作组织协定签署仪式在上海举行。另外，2026世界人工智能大会暨人工智能全球治理高级别会议将于7月17日至20日在上海举行。中国国家主席习近平将出席大会开幕式并发表主旨讲话。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260716-%E6%B3%95%E5%AA%92-%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E5%9C%A8%E4%B8%AD%E5%9B%BD%E7%BB%9D%E9%9D%9E%E7%BA%B8%E4%B8%8A%E8%B0%88%E5%85%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784226988000.webp","sourceId":"rfi"},{"id":1784225302000,"createdDate":"2026-07-16 18:08","name":"法国国际广播电台","title":"世界杯决赛：特朗普将前往观赛","content":"白宫发言人周四宣布，美国特朗普将出席周日（巴黎时间19日）西班牙与阿根廷之间的世界杯决赛。特朗普将为获胜队颁奖？白宫只证实会去，没有说明是否会给获胜队颁奖事宜。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260716-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%86%B3%E8%B5%9B-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B0%86%E5%89%8D%E5%BE%80%E8%A7%82%E8%B5%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784225302000.webp","sourceId":"rfi"}]