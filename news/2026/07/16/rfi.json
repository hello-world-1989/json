[{"id":1784197608000,"createdDate":"2026-07-16 10:26","name":"法国国际广播电台","title":"《光明日报》驻布拉格记者涉谍案被捕后续 一捷克商人在华因涉嫌危害国家安全被查","content":"中国外交部周四表示，一名自6月底以来在中国被拘留的捷克公民正因涉嫌危害国家安全罪接受调查。捷克外交部于周三宣布了这一拘留消息，并表示其官员已与该公民取得领事联系，但未透露更多细节。捷克新闻网站“SeznamZpravy”报导称，一名曾在华经商的捷克商人遭中国安全部门在机场拘留，预计将被控从事间谍活动。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260716-%E5%85%89%E6%98%8E%E6%97%A5%E6%8A%A5-%E9%A9%BB%E5%B8%83%E6%8B%89%E6%A0%BC%E8%AE%B0%E8%80%85%E6%B6%89%E8%B0%8D%E6%A1%88%E8%A2%AB%E6%8D%95%E5%90%8E%E7%BB%AD-%E4%B8%80%E6%8D%B7%E5%85%8B%E5%95%86%E4%BA%BA%E5%9C%A8%E5%8D%8E%E5%9B%A0%E6%B6%89%E5%AB%8C%E5%8D%B1%E5%AE%B3%E5%9B%BD%E5%AE%B6%E5%AE%89%E5%85%A8%E8%A2%AB%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784197608000.webp","sourceId":"rfi"},{"id":1784195073000,"createdDate":"2026-07-16 09:44","name":"法国国际广播电台","title":"欧盟文件指责中俄为首“按照自身利益重塑全球秩序，助长回归势力范围的逻辑”","content":"据《南华早报》报导，欧盟在一份措辞极其严厉的新立场文件中指责中国和俄罗斯试图“按照自身利益重塑全球秩序”，并“助长回归势力范围的逻辑”；这是该集团迄今为止针对北京最强烈的官方批评之一。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260716-%E6%AC%A7%E7%9B%9F%E6%96%87%E4%BB%B6%E6%8C%87%E8%B4%A3%E4%B8%AD%E4%BF%84%E4%B8%BA%E9%A6%96-%E6%8C%89%E7%85%A7%E8%87%AA%E8%BA%AB%E5%88%A9%E7%9B%8A%E9%87%8D%E5%A1%91%E5%85%A8%E7%90%83%E7%A7%A9%E5%BA%8F%EF%BC%8C%E5%8A%A9%E9%95%BF%E5%9B%9E%E5%BD%92%E5%8A%BF%E5%8A%9B%E8%8C%83%E5%9B%B4%E7%9A%84%E9%80%BB%E8%BE%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784195073000.webp","sourceId":"rfi"},{"id":1784194086000,"createdDate":"2026-07-16 09:28","name":"法国国际广播电台","title":"法国队18日对阵英国队争夺第三名，德尚将告别法国队主教练生涯","content":"阿根廷队15日以2：1战胜英国队后，2026世界杯足球赛赛程进入尾声。7月19日，阿根廷队与西班牙队将在纽约争夺本届世界杯的冠亚军。在此之前，冠军梦碎的法国队和英国队则将于18日在迈阿密进行最后一场比赛，决出本届世界杯的第三名。法国队在7月14日法国国庆日以2：0输给西班牙，错失最后角逐的机会，它将以怎样的心态参加象征性的最后一场比赛值得关注。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260716-%E6%B3%95%E5%9B%BD%E9%98%9F18%E6%97%A5%E5%AF%B9%E9%98%B5%E8%8B%B1%E5%9B%BD%E9%98%9F%E4%BA%89%E5%A4%BA%E7%AC%AC%E4%B8%89%E5%90%8D%EF%BC%8C%E5%BE%B7%E5%B0%9A%E5%B0%86%E5%91%8A%E5%88%AB%E6%B3%95%E5%9B%BD%E9%98%9F%E4%B8%BB%E6%95%99%E7%BB%83%E7%94%9F%E6%B6%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784194086000.webp","sourceId":"rfi"},{"id":1784192764000,"createdDate":"2026-07-16 09:06","name":"法国国际广播电台","title":"东盟调整对缅策略 南海仲裁集体沉默","content":"最近，随着转型后的缅甸新政府针对中美俄印等大国陆续开启外交出访行程，为了应对不断变化的地缘政治形势，东盟开始调整对缅策略，旨在逐步化解孤立缅甸造成的外交僵局。时值南海仲裁结果出台十周年甚嚣尘上，美菲联合全球盟友集体施压，遭到北京强力反制，东盟抉择两难之际，多数国家选择保持审慎态度。与此同时，泰国和柬埔寨领导人急于招商引资几乎同步访问北京，由此引发外界关于“北京开展斡旋、调停泰柬双边冲突”的高度关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260716-%E4%B8%9C%E7%9B%9F%E8%B0%83%E6%95%B4%E5%AF%B9%E7%BC%85%E7%AD%96%E7%95%A5-%E5%8D%97%E6%B5%B7%E4%BB%B2%E8%A3%81%E9%9B%86%E4%BD%93%E6%B2%89%E9%BB%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784192764000.webp","sourceId":"rfi"},{"id":1784192745000,"createdDate":"2026-07-16 09:05","name":"法国国际广播电台","title":"特朗普据报将在周四晚演讲中谈及中国涉嫌干预美国选举事宜","content":"据哥伦比亚广播公司（CBS）援引知情人士报导称，美国总统特朗普（DonaldTrump）周四晚间的演讲预计将涉及此前未被披露的中国涉嫌干预美国选举一事。其中包含的内容包括：关于北京方面窃取美国选民数据的指控，以及中情局（CIA）知晓此事却未在特朗普首个总统任期内向其通报相关信息的证据。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260716-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8D%AE%E6%8A%A5%E5%B0%86%E5%9C%A8%E5%91%A8%E5%9B%9B%E6%99%9A%E6%BC%94%E8%AE%B2%E4%B8%AD%E8%B0%88%E5%8F%8A%E4%B8%AD%E5%9B%BD%E6%B6%89%E5%AB%8C%E5%B9%B2%E9%A2%84%E7%BE%8E%E5%9B%BD%E9%80%89%E4%B8%BE%E4%BA%8B%E5%AE%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784192745000.webp","sourceId":"rfi"},{"id":1784191817000,"createdDate":"2026-07-16 08:50","name":"法国国际广播电台","title":"英国宣布将中国敬业集团原旗下英国钢铁公司国有化","content":"英国政府周四（7月16日）宣布将钢铁企业“英国钢铁公司”（BritishSteel）国有化。该公司此前由中国敬业集团所有，英国政府于去年4月接管该企业，以避免其旗下两座高炉关闭。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260716-%E8%8B%B1%E5%9B%BD%E5%AE%A3%E5%B8%83%E5%B0%86%E4%B8%AD%E5%9B%BD%E6%95%AC%E4%B8%9A%E9%9B%86%E5%9B%A2%E5%8E%9F%E6%97%97%E4%B8%8B%E8%8B%B1%E5%9B%BD%E9%92%A2%E9%93%81%E5%85%AC%E5%8F%B8%E5%9B%BD%E6%9C%89%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784191817000.webp","sourceId":"rfi"},{"id":1784191613000,"createdDate":"2026-07-16 08:46","name":"法国国际广播电台","title":"英伟达首席执行官黄仁勋访日 宣布和日本多家顶级企业合作","content":"市值位居全球第一的美国半导体巨头英伟达（NVIDIA）首席执行官黄仁勋（JensenHuang）于15日开始访问日本。16日，三菱重工、东京电子、欧姆龙等多家日本企业相继宣布，将与英伟达开展合作。2025年4月21日，当时的石破首相在首相官邸会见访日的黄仁勋，对其来访表示欢迎，黄仁勋是否能与高市首相见面不得而知。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260716-%E8%8B%B1%E4%BC%9F%E8%BE%BE%E9%A6%96%E5%B8%AD%E6%89%A7%E8%A1%8C%E5%AE%98%E9%BB%84%E4%BB%81%E5%8B%8B%E8%AE%BF%E6%97%A5-%E5%AE%A3%E5%B8%83%E5%92%8C%E6%97%A5%E6%9C%AC%E5%A4%9A%E5%AE%B6%E9%A1%B6%E7%BA%A7%E4%BC%81%E4%B8%9A%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784191613000.webp","sourceId":"rfi"},{"id":1784190614000,"createdDate":"2026-07-16 08:30","name":"法国国际广播电台","title":"就向中国情报人员泄露受限信息做虚假陈述 美联储前高级顾问被判囚38个月","content":"美国司法部周三表示，美联储一名前高级顾问因向调查人员就向中国情报人员泄露有关美联储的机密信息一事作虚假陈述，被判处38个月联邦监禁。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260716-%E5%B0%B1%E5%90%91%E4%B8%AD%E5%9B%BD%E6%83%85%E6%8A%A5%E4%BA%BA%E5%91%98%E6%B3%84%E9%9C%B2%E5%8F%97%E9%99%90%E4%BF%A1%E6%81%AF%E5%81%9A%E8%99%9A%E5%81%87%E9%99%88%E8%BF%B0-%E7%BE%8E%E8%81%94%E5%82%A8%E5%89%8D%E9%AB%98%E7%BA%A7%E9%A1%BE%E9%97%AE%E8%A2%AB%E5%88%A4%E5%9B%9A38%E4%B8%AA%E6%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784190614000.webp","sourceId":"rfi"},{"id":1784184202000,"createdDate":"2026-07-16 06:43","name":"法国国际广播电台","title":"香港加强打压独立书店惹关注 赖清德忧公共讨论受压 团体斥要灭自由思想空间","content":"香港警方国安处人员昨(15日)午以书店输入海外怀疑煽动书籍而拘捕两间书店合共五人，引起海外关注。从历经书禁年代走来的台湾总统赖清德表示，当书店面对红线压力，人民的思考与表达自由不再，公共讨论空间也不断被压缩；另外两个国际人权组织亦发表声明批评港府，指港府针对独立书店的打压不断升级，再次证明国安法律已被武器化，用以消灭自由思想及讨论空间，使异见噤声。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260716-%E9%A6%99%E6%B8%AF%E5%8A%A0%E5%BC%BA%E6%89%93%E5%8E%8B%E7%8B%AC%E7%AB%8B%E4%B9%A6%E5%BA%97%E6%83%B9%E5%85%B3%E6%B3%A8-%E8%B5%96%E6%B8%85%E5%BE%B7%E5%BF%A7%E5%85%AC%E5%85%B1%E8%AE%A8%E8%AE%BA%E5%8F%97%E5%8E%8B-%E5%9B%A2%E4%BD%93%E6%96%A5%E8%A6%81%E7%81%AD%E8%87%AA%E7%94%B1%E6%80%9D%E6%83%B3%E7%A9%BA%E9%97%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784184202000.webp","sourceId":"rfi"},{"id":1784183912000,"createdDate":"2026-07-16 06:38","name":"法国国际广播电台","title":"港国安一日内拘两独立书店共五人 首涉从海外进口煽动书籍","content":"香港警方国安处人员在香港书展开幕日搜查已预告结业的独立书店「留下书舍」和香港老牌书店「田园书屋」，并以涉嫌干犯《基本法》23条下的新煽动罪，拘捕包括负责人在内的五名男女，同时从书店带走多箱书籍及物品。这是当局首次公开表明基於海外进口书籍涉嫌有煽动意图而采取行动，但又拒绝披露沙及的书籍名称及煽动因素。有媒体引述消息称，相关「隐身禁书」包括《唯红花绽放：习近平时代的认同与归属》等由台湾出版的书籍。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260716-%E6%B8%AF%E5%9B%BD%E5%AE%89%E4%B8%80%E6%97%A5%E5%86%85%E6%8B%98%E4%B8%A4%E7%8B%AC%E7%AB%8B%E4%B9%A6%E5%BA%97%E5%85%B1%E4%BA%94%E4%BA%BA-%E9%A6%96%E6%B6%89%E4%BB%8E%E6%B5%B7%E5%A4%96%E8%BF%9B%E5%8F%A3%E7%85%BD%E5%8A%A8%E4%B9%A6%E7%B1%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784183912000.webp","sourceId":"rfi"},{"id":1784183585000,"createdDate":"2026-07-16 06:33","name":"法国国际广播电台","title":"事隔七年 脱罪法律系女生重审暴动罪成 判囚34个月","content":"涉嫌参与2019年社会运动期间於湾仔发生的冲突事件的大学法律系女学生，经审讯後裁定暴动罪名不成立，律政司经上诉後得直，案件被发还重审后，遭改判暴动罪成，判监34个月。法官表示，已考虑被告由无罪改判有罪，将失去成为律师机会等因素，酌情减刑。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260716-%E4%BA%8B%E9%9A%94%E4%B8%83%E5%B9%B4-%E8%84%B1%E7%BD%AA%E6%B3%95%E5%BE%8B%E7%B3%BB%E5%A5%B3%E7%94%9F%E9%87%8D%E5%AE%A1%E6%9A%B4%E5%8A%A8%E7%BD%AA%E6%88%90-%E5%88%A4%E5%9B%9A34%E4%B8%AA%E6%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784183585000.webp","sourceId":"rfi"},{"id":1784217320000,"createdDate":"2026-07-16 15:55","name":"法国国际广播电台","title":"中方扣留巴旗船舶激增 巴拿马官员出访北京，力求化解纠纷","content":"巴拿马官员正前往北京，试图化解一场争端；此前，中国当局大幅加强了扣留巴拿马籍船只的力度，导致数百艘船只退出了该国的船舶登记。这场冲突在2月升级：当时，巴拿马在面临美国施加的巨大压力、要求其遏制中方在巴拿马运河的影响力之际，接管了由总部位于香港的长和（CKHutchison）运营的两个港口——巴拿马最高法院更早时已裁定该公司的特许经营权无效。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260716-%E4%B8%AD%E6%96%B9%E6%89%A3%E7%95%99%E5%B7%B4%E6%97%97%E8%88%B9%E8%88%B6%E6%BF%80%E5%A2%9E-%E5%B7%B4%E6%8B%BF%E9%A9%AC%E5%AE%98%E5%91%98%E5%87%BA%E8%AE%BF%E5%8C%97%E4%BA%AC%EF%BC%8C%E5%8A%9B%E6%B1%82%E5%8C%96%E8%A7%A3%E7%BA%A0%E7%BA%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784217320000.webp","sourceId":"rfi"},{"id":1784215571000,"createdDate":"2026-07-16 15:26","name":"法国国际广播电台","title":"中方已请求泰国尽快遣返调查记者白兆东 人权组织呼吁允许其前往他所选择的国家","content":"中方已要求泰国迅速引渡著名调查记者白兆东；人权组织指出，该记者因调查国内腐败问题，回国后将面临政治迫害和酷刑风险。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260716-%E4%B8%AD%E6%96%B9%E5%B7%B2%E8%AF%B7%E6%B1%82%E6%B3%B0%E5%9B%BD%E5%B0%BD%E5%BF%AB%E9%81%A3%E8%BF%94%E8%B0%83%E6%9F%A5%E8%AE%B0%E8%80%85%E7%99%BD%E5%85%86%E4%B8%9C-%E4%BA%BA%E6%9D%83%E7%BB%84%E7%BB%87%E5%91%BC%E5%90%81%E5%85%81%E8%AE%B8%E5%85%B6%E5%89%8D%E5%BE%80%E4%BB%96%E6%89%80%E9%80%89%E6%8B%A9%E7%9A%84%E5%9B%BD%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784215571000.webp","sourceId":"rfi"},{"id":1784213686000,"createdDate":"2026-07-16 14:54","name":"法国国际广播电台","title":"众议员致信美商务部长促禁购中国存储芯片 参议员提法案加强对中国在美制药业投资审查","content":"美国众议院美国与中共战略竞争特设委员会主席穆勒纳尔（JohnMoolenaar）致信敦促特朗普政府禁止美国企业从长鑫存储（CXMT）和长江存储（YMTC）采购存储芯片，以避免在人工智能基础设施的关键组件上依赖中国。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260716-%E4%BC%97%E8%AE%AE%E5%91%98%E8%87%B4%E4%BF%A1%E7%BE%8E%E5%95%86%E5%8A%A1%E9%83%A8%E9%95%BF%E4%BF%83%E7%A6%81%E8%B4%AD%E4%B8%AD%E5%9B%BD%E5%AD%98%E5%82%A8%E8%8A%AF%E7%89%87-%E5%8F%82%E8%AE%AE%E5%91%98%E6%8F%90%E6%B3%95%E6%A1%88%E5%8A%A0%E5%BC%BA%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%9C%A8%E7%BE%8E%E5%88%B6%E8%8D%AF%E4%B8%9A%E6%8A%95%E8%B5%84%E5%AE%A1%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784213686000.webp","sourceId":"rfi"},{"id":1784210051000,"createdDate":"2026-07-16 13:54","name":"法国国际广播电台","title":"马朝旭预计下周访美 或为习近平访问华盛顿铺垫","content":"据《南华早报》报导，中国外交部副部长马朝旭预计将于下周访问美国；此行很可能是为中国国家主席习近平今年晚些时候访问华盛顿进行铺垫。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260716-%E9%A9%AC%E6%9C%9D%E6%97%AD%E9%A2%84%E8%AE%A1%E4%B8%8B%E5%91%A8%E8%AE%BF%E7%BE%8E-%E6%88%96%E4%B8%BA%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%BF%E9%97%AE%E5%8D%8E%E7%9B%9B%E9%A1%BF%E9%93%BA%E5%9E%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784210051000.webp","sourceId":"rfi"},{"id":1784209172000,"createdDate":"2026-07-16 13:39","name":"法国国际广播电台","title":"巴新外长宣布立即关闭台湾驻处：北京高度赞赏 台北严正抗议","content":"巴布亚新几内亚外交部长特卡琴科（JustinTkatchenko）周四宣布，该国政府已决定立即关闭“驻巴布亚纽几内亚台北经济办事处”，此举受到北京方面的“高度赞赏”；不过，台北方面表示该代表处将“持续维持正常运作”。长期以来，太平洋地区一直是两岸外交角力的场所。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260716-%E5%B7%B4%E6%96%B0%E5%A4%96%E9%95%BF%E5%AE%A3%E5%B8%83%E7%AB%8B%E5%8D%B3%E5%85%B3%E9%97%AD%E5%8F%B0%E6%B9%BE%E9%A9%BB%E5%A4%84-%E5%8C%97%E4%BA%AC%E9%AB%98%E5%BA%A6%E8%B5%9E%E8%B5%8F-%E5%8F%B0%E5%8C%97%E4%B8%A5%E6%AD%A3%E6%8A%97%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784209172000.webp","sourceId":"rfi"},{"id":1784207843000,"createdDate":"2026-07-16 13:17","name":"法国国际广播电台","title":"法国专家谈台湾是否需要基因编辑植物","content":"欧盟的新转基因技术（NGTs）使用法案在获得欧洲议会批准之后于7月16日正式生效，无论是支持还是反对推广此一技术的人都认为这将对欧洲的农业带来翻天覆地的变化，尽管目前还很难预测此一变化究竟是改善还是恶化。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260716-%E6%B3%95%E5%9B%BD%E4%B8%93%E5%AE%B6%E8%B0%88%E5%8F%B0%E6%B9%BE%E6%98%AF%E5%90%A6%E9%9C%80%E8%A6%81%E5%9F%BA%E5%9B%A0%E7%BC%96%E8%BE%91%E6%A4%8D%E7%89%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784207843000.webp","sourceId":"rfi"},{"id":1784206572000,"createdDate":"2026-07-16 12:56","name":"法国国际广播电台","title":"团队有声音担心中方视缄默为索取更多让步契机 美贸易代表指9月特习会多为盘点进展","content":"在美国总统特朗普（DonaldTrump）的贸易团队内部，两个令人清醒的结论正逐渐浮出水面：中国在贸易协议上存在违约行为，而美国对此却不会采取实质性举措。恢复关键矿产和稀土的获取——这对美国企业生产包括汽车和战斗机在内的各类产品至关重要——是特朗普去年在韩国釜山与中国国家主席习近平达成的协议中的一项核心目标。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260716-%E5%9B%A2%E9%98%9F%E6%9C%89%E5%A3%B0%E9%9F%B3%E6%8B%85%E5%BF%83%E4%B8%AD%E6%96%B9%E8%A7%86%E7%BC%84%E9%BB%98%E4%B8%BA%E7%B4%A2%E5%8F%96%E6%9B%B4%E5%A4%9A%E8%AE%A9%E6%AD%A5%E5%A5%91%E6%9C%BA-%E7%BE%8E%E8%B4%B8%E6%98%93%E4%BB%A3%E8%A1%A8%E6%8C%879%E6%9C%88%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%A4%9A%E4%B8%BA%E7%9B%98%E7%82%B9%E8%BF%9B%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784206572000.webp","sourceId":"rfi"},{"id":1784197646000,"createdDate":"2026-07-16 10:27","name":"法国国际广播电台","title":"“年轻消费群的寻鲜需求”：在大巴黎，中日韩亚洲超市势不可挡","content":"周三15日晚间，法国国民议会以291票赞成、241票反对，仅50票的微弱优势通过了患有绝症的成年人在符合严格条件后可获结束生命药物的立法。法国也由此加入了少数允许这一权利的国家行列其中包括比利时、荷兰、瑞士、加拿大和乌拉圭等。今天周四7月16日，法国各主流日报无不发表立场分明的评论与分析文章。除围绕安乐死获得通过的争议外，《回声报》关注了亚洲超市在整个巴黎强势崛起的现象。法国亚洲超市龙头企业陈氏兄弟今夏将在在巴黎西北部开设1000平方米的新门店。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260716-%E5%B9%B4%E8%BD%BB%E6%B6%88%E8%B4%B9%E7%BE%A4%E7%9A%84%E5%AF%BB%E9%B2%9C%E9%9C%80%E6%B1%82-%E5%9C%A8%E5%A4%A7%E5%B7%B4%E9%BB%8E%EF%BC%8C%E4%B8%AD%E6%97%A5%E9%9F%A9%E4%BA%9A%E6%B4%B2%E8%B6%85%E5%B8%82%E5%8A%BF%E4%B8%8D%E5%8F%AF%E6%8C%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/07/16/1784197646000.webp","sourceId":"rfi"}]