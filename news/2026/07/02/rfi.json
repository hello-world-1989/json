[{"id":1782950656000,"createdDate":"2026-07-02 00:04","name":"法国国际广播电台","title":"美智库报告：与中国有关网络介入反AI资料中心运动","content":"美国智库比特币政策研究所（BitcoinPolicyInstitute）30日发布最新报告指出，与中国共产党有已知联系、现居上海的美籍科技富豪内维尔．罗伊．辛汉（NevilleRoySingham），透过其资助的美国社会主义与解放党（PartyforSocialismandLiberation）等组织，在全美多州推动反对人工智能（AI）资料中心建设的运动，借此扩大反对AI基础设施的舆论，并企图削弱美国在AI竞争中的优势。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260702-%E7%BE%8E%E6%99%BA%E5%BA%93%E6%8A%A5%E5%91%8A-%E4%B8%8E%E4%B8%AD%E5%9B%BD%E6%9C%89%E5%85%B3%E7%BD%91%E7%BB%9C%E4%BB%8B%E5%85%A5%E5%8F%8Dai%E8%B5%84%E6%96%99%E4%B8%AD%E5%BF%83%E8%BF%90%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1782950656000.webp","sourceId":"rfi"},{"id":1782984343000,"createdDate":"2026-07-02 09:25","name":"法国国际广播电台","title":"俄军人员死亡数字二战以来前所未有，俄乌阶段性战损比或接近8比1","content":"乌克兰战争持续四年多，战场损失仍在不断扩大。美国智库战略与国际问题研究中心CSIS近日发布的一项研究显示，自冲突爆发以来，俄罗斯和乌克兰两国军队死亡、受伤及失踪人员合计已超过200万人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260702-%E4%BF%84%E5%86%9B%E4%BA%BA%E5%91%98%E6%AD%BB%E4%BA%A1%E6%95%B0%E5%AD%97%E4%BA%8C%E6%88%98%E4%BB%A5%E6%9D%A5%E5%89%8D%E6%89%80%E6%9C%AA%E6%9C%89%EF%BC%8C%E4%BF%84%E4%B9%8C%E9%98%B6%E6%AE%B5%E6%80%A7%E6%88%98%E6%8D%9F%E6%AF%94%E6%88%96%E6%8E%A5%E8%BF%918%E6%AF%941","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1782984343000.webp","sourceId":"rfi"},{"id":1782979740000,"createdDate":"2026-07-02 08:09","name":"法国国际广播电台","title":"俄罗斯大规模轰炸基辅造成至少13人死86人伤","content":"在泽连斯基发出警告后，乌克兰首都周四晨遭到俄罗斯导弹和无人机的大规模袭击，多栋住宅楼整层被摧毁，至少13人死亡、86人受伤。法新社记者看到，在基辅街头，居民们带着床叠纷纷奔向避难所。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260702-%E4%BF%84%E7%BD%97%E6%96%AF%E5%A4%A7%E8%A7%84%E6%A8%A1%E8%BD%B0%E7%82%B8%E5%9F%BA%E8%BE%85%E9%80%A0%E6%88%90%E8%87%B3%E5%B0%9113%E4%BA%BA%E6%AD%BB86%E4%BA%BA%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1782979740000.webp","sourceId":"rfi"},{"id":1782979020000,"createdDate":"2026-07-02 07:57","name":"法国国际广播电台","title":"爱国议员被揭知法犯法　黄锦辉涉酒驾撞车后不顾而去","content":"北京要求已「清一色」由爱国者组成的立法会议员，需注意公众形象和树立榜样，但新一届爱国者议员却接连出现违法情况。继新民党议员陈家佩早前被揭发驾车时逆线行驶被控后，循负责选出行政展官的小圈子选举委员会入局的黄锦辉议员，近日被揭发涉嫌醉酒驾驶，撞车后更不顾而去。有评论表示，市民对立法者的品德有更高期望，若议员知法犯法，质疑他们如何令市民信服其通过的法例和监察政府。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260702-%E7%88%B1%E5%9B%BD%E8%AE%AE%E5%91%98%E8%A2%AB%E6%8F%AD%E7%9F%A5%E6%B3%95%E7%8A%AF%E6%B3%95-%E9%BB%84%E9%94%A6%E8%BE%89%E6%B6%89%E9%85%92%E9%A9%BE%E6%92%9E%E8%BD%A6%E5%90%8E%E4%B8%8D%E9%A1%BE%E8%80%8C%E5%8E%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1782979020000.webp","sourceId":"rfi"},{"id":1782978667000,"createdDate":"2026-07-02 07:51","name":"法国国际广播电台","title":"如何高兴？ 港府「7.1」严密佈防 又在昔日刺警案及游行点送走多人","content":"港府在七一回归纪念日大肆庆祝，但市面气氛未见热闹，而旅游旺区之一的铜锣湾一带更是难以令人放松，因为警方当天下午起便在这处曾经发生市民刺伤警员後自杀以示不满的地方加强戒备，晚上更派出无人机执勤。在这情况下，仍有部分市民在事发地点表达对施政的不满和悼念案中死者，但他们多被警方带走。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260702-%E5%A6%82%E4%BD%95%E9%AB%98%E5%85%B4-%E6%B8%AF%E5%BA%9C-7-1-%E4%B8%A5%E5%AF%86%E4%BD%88%E9%98%B2-%E5%8F%88%E5%9C%A8%E6%98%94%E6%97%A5%E5%88%BA%E8%AD%A6%E6%A1%88%E5%8F%8A%E6%B8%B8%E8%A1%8C%E7%82%B9%E9%80%81%E8%B5%B0%E5%A4%9A%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1782978667000.webp","sourceId":"rfi"},{"id":1783014942000,"createdDate":"2026-07-02 17:55","name":"法国国际广播电台","title":"欧盟和美国对中国出台针对海外人士的《民族团结法》表示关切","content":"中国新《民族团结法》受到美国和欧盟关切。美国认为该法在适用范围和执行上“成问题”。欧盟呼吁中国保障少数民族的权利。中国称有权在境外执行该法的立场引发国际社会警惕。此项立法亦引发台湾担忧。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260702-%E6%AC%A7%E7%9B%9F%E5%92%8C%E7%BE%8E%E5%9B%BD%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%87%BA%E5%8F%B0%E9%92%88%E5%AF%B9%E6%B5%B7%E5%A4%96%E4%BA%BA%E5%A3%AB%E7%9A%84-%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E6%B3%95-%E8%A1%A8%E7%A4%BA%E5%85%B3%E5%88%87","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1783014942000.webp","sourceId":"rfi"},{"id":1783009129000,"createdDate":"2026-07-02 16:18","name":"法国国际广播电台","title":"半导体走私中国: 美国超微电脑公司两名高管在台湾被逮捕","content":"台湾一名检察官周四宣布，美国超微电脑公司（SuperMicroComputer）两名员工已被羁押，此举与涉嫌向中国走私用于人工智能半导体产品调查有关。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260702-%E5%8D%8A%E5%AF%BC%E4%BD%93%E8%B5%B0%E7%A7%81%E4%B8%AD%E5%9B%BD-%E7%BE%8E%E5%9B%BD%E8%B6%85%E5%BE%AE%E7%94%B5%E8%84%91%E5%85%AC%E5%8F%B8%E4%B8%A4%E5%90%8D%E9%AB%98%E7%AE%A1%E5%9C%A8%E5%8F%B0%E6%B9%BE%E8%A2%AB%E9%80%AE%E6%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1783009129000.webp","sourceId":"rfi"},{"id":1783007038000,"createdDate":"2026-07-02 15:43","name":"法国国际广播电台","title":"美国驻台最高外交官:台湾需要“蜂巢”无人机群有助阻止冲突保障安全","content":"美国驻台湾事实上的大使称，无人机提供了“改变游戏规则的契机”，台湾政府已提出价值65.9亿美元的各类无人机方案。而在议会占多数的反对党国民党砍政府无人机预算后，提出了自己的无人机立法草案。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260702-%E7%BE%8E%E5%9B%BD%E9%A9%BB%E5%8F%B0%E6%9C%80%E9%AB%98%E5%A4%96%E4%BA%A4%E5%AE%98-%E5%8F%B0%E6%B9%BE%E9%9C%80%E8%A6%81-%E8%9C%82%E5%B7%A2-%E6%97%A0%E4%BA%BA%E6%9C%BA%E7%BE%A4%E6%9C%89%E5%8A%A9%E9%98%BB%E6%AD%A2%E5%86%B2%E7%AA%81%E4%BF%9D%E9%9A%9C%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1783007038000.webp","sourceId":"rfi"},{"id":1783002637000,"createdDate":"2026-07-02 14:30","name":"法国国际广播电台","title":"铜锣湾书店店长林荣基病逝台北享寿70岁","content":"中央社台北7月2日电：香港铜锣湾书店店长林荣基今晚在台北马偕医院病逝，享寿70岁。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260702-%E9%93%9C%E9%94%A3%E6%B9%BE%E4%B9%A6%E5%BA%97%E5%BA%97%E9%95%BF%E6%9E%97%E8%8D%A3%E5%9F%BA%E5%9C%A8%E5%8F%B0%E5%8C%97%E7%97%85%E9%80%9D-%E4%BA%AB%E5%AF%BF70%E5%B2%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1783002637000.webp","sourceId":"rfi"},{"id":1782993789000,"createdDate":"2026-07-02 12:03","name":"法国国际广播电台","title":"北京小飞机撞中国尊中信大厦：当局称该驾驶员曾有自杀念头","content":"法新社北京消息：当局周四表示，上周驾驶小型观光飞机撞向北京最高摩天大楼并造成13人受伤的飞行员，生前有自杀倾向。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260702-%E5%8C%97%E4%BA%AC%E5%B0%8F%E9%A3%9E%E6%9C%BA%E6%92%9E%E4%B8%AD%E5%9B%BD%E5%B0%8A%E4%B8%AD%E4%BF%A1%E5%A4%A7%E5%8E%A6-%E5%BD%93%E5%B1%80%E7%A7%B0%E8%AF%A5%E9%A9%BE%E9%A9%B6%E5%91%98%E6%9B%BE%E6%9C%89%E8%87%AA%E6%9D%80%E5%BF%B5%E5%A4%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1782993789000.webp","sourceId":"rfi"},{"id":1782991605000,"createdDate":"2026-07-02 11:26","name":"法国国际广播电台","title":"莫迪举行隆重仪式 欢迎日本首相高市早苗到访","content":"7月2日，印度总理莫迪在新德里的总统府举行隆重仪式，欢迎到访的日本首相高市早苗。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260702-%E8%8E%AB%E8%BF%AA%E4%B8%BE%E8%A1%8C%E9%9A%86%E9%87%8D%E4%BB%AA%E5%BC%8F-%E6%AC%A2%E8%BF%8E%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E5%88%B0%E8%AE%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1782991605000.webp","sourceId":"rfi"},{"id":1782989871000,"createdDate":"2026-07-02 10:57","name":"法国国际广播电台","title":"欧洲支持尼日利亚采用电动渡轮","content":"欧洲投资银行（EIB/BEI）支持尼日利亚在拉各斯泻湖（lalagunedeLagos）采用电动渡轮。这是本台法广（RFI）法语栏目[非洲经济]（AfriqueEconomie）今天（2026年07月02日星期四）的最新报道。欧洲投资银行（BEI）副行长在访问拉各斯（Lagos）期间表示，对尼日利亚的这座特大城市而言，是一个机遇（uneaubaine）。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260702-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E6%AC%A7%E6%B4%B2%E6%94%AF%E6%8C%81%E5%B0%BC%E6%97%A5%E5%88%A9%E4%BA%9A%E9%87%87%E7%94%A8%E7%94%B5%E5%8A%A8%E6%B8%A1%E8%BD%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1782989871000.webp","sourceId":"rfi"},{"id":1782987155000,"createdDate":"2026-07-02 10:12","name":"法国国际广播电台","title":"欧洲防务景气高位却突踩刹车：法德军工巨头为何宣布暂缓上市？","content":"法德防务集团KNDS于7月1日宣布，由于当前欧洲防务板块市场波动较大，公司决定暂缓首次公开募股（IPO）计划，待市场条件改善后再恢复推进。这项原本于6月24日才正式公布的上市计划，在宣布仅一周后便被推迟。这不免引发疑问，因为欧洲防务行业的景气程度在至少四十年来从未如此之高。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260702-%E6%AC%A7%E6%B4%B2%E9%98%B2%E5%8A%A1%E6%99%AF%E6%B0%94%E9%AB%98%E4%BD%8D%E5%8D%B4%E7%AA%81%E8%B8%A9%E5%88%B9%E8%BD%A6-%E6%B3%95%E5%BE%B7%E5%86%9B%E5%B7%A5%E5%B7%A8%E5%A4%B4%E4%B8%BA%E4%BD%95%E5%AE%A3%E5%B8%83%E6%9A%82%E7%BC%93%E4%B8%8A%E5%B8%82","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1782987155000.webp","sourceId":"rfi"},{"id":1782985812000,"createdDate":"2026-07-02 09:50","name":"法国国际广播电台","title":"世界杯：比利时英格兰惊天逆转  美加墨三主办国均晋级16强","content":"回顾7月1日星期三的比赛，又有三支球队晋级16强，三支饮憾出局。截至目前，16强已锁定十席：加拿大、巴西、巴拉圭、摩洛哥、挪威、法国、墨西哥、英格兰、比利时、美国。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260702-%E4%B8%96%E7%95%8C%E6%9D%AF-%E6%AF%94%E5%88%A9%E6%97%B6%E4%B8%8A%E6%BC%94%E6%83%8A%E5%A4%A9%E9%80%86%E8%BD%AC-%E8%8B%B1%E6%A0%BC%E5%85%B0%E5%92%8C%E7%BE%8E%E5%9B%BD%E4%B9%9F%E5%9D%87%E6%99%8B%E7%BA%A716%E5%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/02/1782985812000.webp","sourceId":"rfi"}]