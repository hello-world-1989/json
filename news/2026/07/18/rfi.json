[{"id":1784365497000,"createdDate":"2026-07-18 09:04","name":"法国国际广播电台","title":"美国对巴布新下令关闭台湾驻该国代表处的报道“深表关切”","content":"巴布亚新几内亚外交部长贾斯汀·特卡琴科周四（7月16号）突然宣布，“立即关闭台湾驻巴纽代表处并停止运作”；此举招致北京方面的赞扬，却遭到台北方面的谴责。美国对巴布亚新几内亚下令关闭台湾驻该国代表处的报道“深表关切”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260718-%E7%BE%8E%E5%9B%BD%E5%AF%B9%E5%B7%B4%E5%B8%83%E6%96%B0%E4%B8%8B%E4%BB%A4%E5%85%B3%E9%97%AD%E5%8F%B0%E6%B9%BE%E9%A9%BB%E8%AF%A5%E5%9B%BD%E4%BB%A3%E8%A1%A8%E5%A4%84%E7%9A%84%E6%8A%A5%E9%81%93-%E6%B7%B1%E8%A1%A8%E5%85%B3%E5%88%87","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784365497000.webp","sourceId":"rfi"},{"id":1784395015000,"createdDate":"2026-07-18 17:16","name":"法国国际广播电台","title":"雷暴天中断西班牙和阿根廷的热身训练","content":"7月18日，纽约和新泽西地区遭遇强雷暴天气，西班牙和阿根廷队在周日世界杯决赛前的最后训练被迫中断。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260718-%E9%9B%B7%E6%9A%B4%E5%A4%A9%E4%B8%AD%E6%96%AD%E8%A5%BF%E7%8F%AD%E7%89%99%E5%92%8C%E9%98%BF%E6%A0%B9%E5%BB%B7%E7%9A%84%E7%83%AD%E8%BA%AB%E8%AE%AD%E7%BB%83","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784395015000.webp","sourceId":"rfi"},{"id":1784393919000,"createdDate":"2026-07-18 16:58","name":"法国国际广播电台","title":"特朗普脱口而出： 中美将联合申办世界杯","content":"世界杯决赛即将拉开序幕，特朗普发表了讲话。特朗普表示他希望未来再次举办世界杯，但不与加拿大和墨西哥联合举办，并开玩笑说要与中国联合申办，尽管这种可能性微乎其微。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260718-%E7%89%B9%E6%9C%97%E6%99%AE%E8%84%B1%E5%8F%A3%E8%80%8C%E5%87%BA-%E4%B8%AD%E7%BE%8E%E5%B0%86%E8%81%94%E5%90%88%E7%94%B3%E5%8A%9E%E4%B8%96%E7%95%8C%E6%9D%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784393919000.webp","sourceId":"rfi"},{"id":1784388171000,"createdDate":"2026-07-18 15:22","name":"法国国际广播电台","title":"伊朗副外长称德黑兰已“暂停”履行伊美谅解备忘录承诺","content":"伊朗副外长加里巴巴迪表示，鉴于与美国冲突再起，德黑兰方面已“暂停”履行上月与美国签署的谅解备忘录中所作的承诺。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260718-%E4%BC%8A%E6%9C%97%E5%89%AF%E5%A4%96%E9%95%BF%E7%A7%B0%E5%BE%B7%E9%BB%91%E5%85%B0%E5%B7%B2-%E6%9A%82%E5%81%9C-%E5%B1%A5%E8%A1%8C%E4%BC%8A%E7%BE%8E%E8%B0%85%E8%A7%A3%E5%A4%87%E5%BF%98%E5%BD%95%E6%89%BF%E8%AF%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784388171000.webp","sourceId":"rfi"},{"id":1784387318000,"createdDate":"2026-07-18 15:08","name":"法国国际广播电台","title":"《美墨加协定》谈判之际 墨西哥境内中国产重型卡车数量激增受美方关切","content":"墨西哥境内中国产重型卡车数量的激增，正成为其寻求免受美国关税影响道路上的新障碍；华盛顿方面正施压要求获得保证，确保其南部邻国墨西哥不会成为中国制造商进入北美市场的后门。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260718-%E7%BE%8E%E5%A2%A8%E5%8A%A0%E5%8D%8F%E5%AE%9A-%E8%B0%88%E5%88%A4%E4%B9%8B%E9%99%85-%E5%A2%A8%E8%A5%BF%E5%93%A5%E5%A2%83%E5%86%85%E4%B8%AD%E5%9B%BD%E4%BA%A7%E9%87%8D%E5%9E%8B%E5%8D%A1%E8%BD%A6%E6%95%B0%E9%87%8F%E6%BF%80%E5%A2%9E%E5%8F%97%E7%BE%8E%E6%96%B9%E5%85%B3%E5%88%87","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784387318000.webp","sourceId":"rfi"},{"id":1784384838000,"createdDate":"2026-07-18 14:27","name":"法国国际广播电台","title":"日防相援引欧洲国家核武动作为例 称核问题讨论“不得不提”","content":"综合《朝日新闻》等媒体消息，日本防卫大臣小泉进次郎在一档周五播出的网络访谈节目中，呼吁有必要围绕安保问题就核武器展开讨论。他表示：“对日本而言，这是一个很难展开讨论的议题，但核问题是我们不得不触及的课题之一”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260718-%E6%97%A5%E9%98%B2%E7%9B%B8%E6%8F%B4%E5%BC%95%E6%AC%A7%E6%B4%B2%E5%9B%BD%E5%AE%B6%E6%A0%B8%E6%AD%A6%E5%8A%A8%E4%BD%9C%E4%B8%BA%E4%BE%8B-%E7%A7%B0%E6%A0%B8%E9%97%AE%E9%A2%98%E8%AE%A8%E8%AE%BA-%E4%B8%8D%E5%BE%97%E4%B8%8D%E6%8F%90","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784384838000.webp","sourceId":"rfi"},{"id":1784384037000,"createdDate":"2026-07-18 14:13","name":"法国国际广播电台","title":"《费加罗报》：中国今年已下水五艘核潜艇  美国海底统治地位是否将终结？","content":"法国《费加罗报》周六（7月18号）报道，中国海军的崛起远非新鲜事，要找到如此庞大的核潜艇产量，恐怕要追溯到苏联时期。这对于中国造船厂来说已经是一个纪录，而此前其惊人的产量主要体现在水面舰艇方面。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260718-%E8%B4%B9%E5%8A%A0%E7%BD%97%E6%8A%A5-%E4%B8%AD%E5%9B%BD%E4%BB%8A%E5%B9%B4%E5%B7%B2%E4%B8%8B%E6%B0%B4%E4%BA%94%E8%89%98%E6%A0%B8%E6%BD%9C%E8%89%87-%E7%BE%8E%E5%9B%BD%E6%B5%B7%E5%BA%95%E7%BB%9F%E6%B2%BB%E5%9C%B0%E4%BD%8D%E6%98%AF%E5%90%A6%E5%B0%86%E7%BB%88%E7%BB%93","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784384037000.webp","sourceId":"rfi"},{"id":1784381970000,"createdDate":"2026-07-18 13:39","name":"法国国际广播电台","title":"各打五十大板？泽连斯基考虑撤换拒绝与前防长说话的乌军总司令","content":"据英国《金融时报》报导称，乌克兰总统泽连斯基正考虑撤换人称“屠夫”的乌武装部队总司令瑟尔斯基（OleksandrSyrsky），以求化解其总统任期内最严重的军事领导层危机。此前，泽连斯基炒掉了现年35岁的乌克兰国防部长费多罗夫，原因是两人之间日益加深的分歧已无法调和；而瑟尔斯基对乌军的领导也随之成为了舆论和抗议抨击的焦点。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260718-%E5%90%84%E6%89%93%E4%BA%94%E5%8D%81%E5%A4%A7%E6%9D%BF-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E8%80%83%E8%99%91%E6%92%A4%E6%8D%A2%E6%8B%92%E7%BB%9D%E4%B8%8E%E5%89%8D%E9%98%B2%E9%95%BF%E8%AF%B4%E8%AF%9D%E7%9A%84%E4%B9%8C%E5%86%9B%E6%80%BB%E5%8F%B8%E4%BB%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784381970000.webp","sourceId":"rfi"},{"id":1784380482000,"createdDate":"2026-07-18 13:14","name":"法国国际广播电台","title":"美涉港“紧急状态”不再续  未恢复其自治地位 亦未取缔李家超林郑等人制裁","content":"美国总统特朗普2020年7月签署的行政命令 « 涉港国家紧急状态 »7月14日届满后不再延续，先前被制裁的中港官员有9人从名单剔除，但香港特首李家超等39人则继续受制裁。同时也未恢复香港的自治地位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260718-%E7%BE%8E%E5%AF%B9%E6%B8%AF-%E7%B4%A7%E6%80%A5%E7%8A%B6%E6%80%81-%E4%B8%8D%E5%86%8D%E7%BB%AD-%E6%9C%AA%E6%81%A2%E5%A4%8D%E5%85%B6%E8%87%AA%E6%B2%BB%E5%9C%B0%E4%BD%8D-%E6%9C%AA%E5%8F%96%E7%BC%94%E6%9D%8E%E5%AE%B6%E8%B6%85%E5%8F%8A%E6%9E%97%E9%83%91%E7%AD%89%E4%BA%BA%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784380482000.webp","sourceId":"rfi"},{"id":1784380201000,"createdDate":"2026-07-18 13:10","name":"法国国际广播电台","title":"美副国务卿致信187所研究型一级高校 促对外国资金流入保持高度警惕","content":"根据哥伦比亚广播公司（CBS）对提交给美国教育部的高校资金记录进行的审查，美国主要大学已从名列美国政府观察名单的外国实体处获得了数以百万美元计的资金。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260718-%E7%BE%8E%E5%89%AF%E5%9B%BD%E5%8A%A1%E5%8D%BF%E8%87%B4%E4%BF%A1187%E6%89%80%E7%A0%94%E7%A9%B6%E5%9E%8B%E4%B8%80%E7%BA%A7%E9%AB%98%E6%A0%A1-%E4%BF%83%E5%AF%B9%E5%A4%96%E5%9B%BD%E8%B5%84%E9%87%91%E6%B5%81%E5%85%A5%E4%BF%9D%E6%8C%81%E9%AB%98%E5%BA%A6%E8%AD%A6%E6%83%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784380201000.webp","sourceId":"rfi"},{"id":1784374356000,"createdDate":"2026-07-18 11:32","name":"法国国际广播电台","title":"匈牙利新政府拟打击环境违规、提高征税等 中国电动汽车企业好日子不再？","content":"匈牙利价值200亿美元的电动汽车产业长期以来一直受到前总理欧尔班（ViktorOrban）的庇护，如今该产业正面临清算时刻：匈牙利新政府正着手打击环境违规行为，并计划提高税收。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260718-%E5%8C%88%E7%89%99%E5%88%A9%E6%96%B0%E6%94%BF%E5%BA%9C%E6%8B%9F%E6%89%93%E5%87%BB%E7%8E%AF%E5%A2%83%E8%BF%9D%E8%A7%84%EF%BC%8C%E6%8F%90%E9%AB%98%E5%BE%81%E7%A8%8E%E7%AD%89-%E4%B8%AD%E5%9B%BD%E7%94%B5%E5%8A%A8%E6%B1%BD%E8%BD%A6%E4%BC%81%E4%B8%9A%E5%A5%BD%E6%97%A5%E5%AD%90%E4%B8%8D%E5%86%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784374356000.webp","sourceId":"rfi"},{"id":1784372614000,"createdDate":"2026-07-18 11:03","name":"法国国际广播电台","title":"美国司法部：在联邦设备上下载TikTok不再违法","content":"美国司法部本周认定，禁止在政府设备上使用TikTok的这项联邦法律已不再适用于这款社交视频应用程序。此举是在TikTok的美国业务转移至一家主要由美国投资者组成的合资企业六个月后做出的。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260718-%E7%BE%8E%E5%9B%BD%E5%8F%B8%E6%B3%95%E9%83%A8-%E5%9C%A8%E8%81%94%E9%82%A6%E8%AE%BE%E5%A4%87%E4%B8%8A%E4%B8%8B%E8%BD%BD-tiktok-%E4%B8%8D%E5%86%8D%E8%BF%9D%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784372614000.webp","sourceId":"rfi"},{"id":1784370501000,"createdDate":"2026-07-18 10:28","name":"法国国际广播电台","title":"日企北京开会 驻华大使指应关注中方强化出口管制 呼吁有顾虑可向大使馆咨询","content":"一个有大约200名在中国开展业务的日资企业相关等人士参加的会议周五在北京举行。日本驻华大使金杉宪治在会上表示，考虑到两名日本公民因稀土出口问题在中国被捕一事，指出“最应关注的问题之一就是出口管制措施的加强”，并呼吁如有顾虑，应向大使馆等机构咨询。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260718-%E6%97%A5%E4%BC%81%E5%8C%97%E4%BA%AC%E5%BC%80%E4%BC%9A-%E9%A9%BB%E5%8D%8E%E5%A4%A7%E4%BD%BF%E6%8C%87%E5%BA%94%E5%85%B3%E6%B3%A8%E4%B8%AD%E6%96%B9%E5%BC%BA%E5%8C%96%E5%87%BA%E5%8F%A3%E7%AE%A1%E5%88%B6-%E5%91%BC%E5%90%81%E6%9C%89%E9%A1%BE%E8%99%91%E5%8F%AF%E5%90%91%E5%A4%A7%E4%BD%BF%E9%A6%86%E5%92%A8%E8%AF%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784370501000.webp","sourceId":"rfi"},{"id":1784370128000,"createdDate":"2026-07-18 10:22","name":"法国国际广播电台","title":"日本外相将出席东盟外长会议 表示将随机应变对应中国攻讦","content":"第59届东盟外长会议及系列相关会议从18日起在菲律宾进行，中国外长王毅、美国国务卿卢比奥、日本外相茂木敏充等都将出席，在茂木敏充于日本时间17日举行的记者会上，有记者问：对于中方针对日本提出的“新军国主义”等批评，您是否打算借此次机会予以反驳？茂木表示：至于会议上的具体发言，由于还要考虑整个会议的气氛，以及各国届时会发表怎样的意见，因此需要根据现场情况随机应变加以应对。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260718-%E6%97%A5%E6%9C%AC%E5%A4%96%E7%9B%B8%E5%B0%86%E5%87%BA%E5%B8%AD%E4%B8%9C%E7%9B%9F%E5%A4%96%E9%95%BF%E4%BC%9A%E8%AE%AE-%E8%A1%A8%E7%A4%BA%E5%B0%86%E9%9A%8F%E6%9C%BA%E5%BA%94%E5%8F%98%E5%AF%B9%E5%BA%94%E4%B8%AD%E5%9B%BD%E6%94%BB%E8%AE%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784370128000.webp","sourceId":"rfi"},{"id":1784368968000,"createdDate":"2026-07-18 10:02","name":"法国国际广播电台","title":"特朗普指责中方曾试图影响美选举结果后 白宫确认9月的特习会仍将按计划进行","content":"白宫新闻秘书莱维特（KarolineLeavitt）周五向媒体确认，尽管美国总统特朗普周四晚发表电视讲话指责中方曾干预美国选举，但中国国家主席习近平9月份的访美行程仍将按计划进行。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260718-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8C%87%E8%B4%A3%E4%B8%AD%E6%96%B9%E6%9B%BE%E8%AF%95%E5%9B%BE%E5%BD%B1%E5%93%8D%E9%80%89%E4%B8%BE%E7%BB%93%E6%9E%9C%E5%90%8E-%E7%99%BD%E5%AE%AB%E7%A1%AE%E8%AE%A49%E6%9C%88%E4%BB%BD%E7%9A%84%E7%89%B9%E4%B9%A0%E4%BC%9A%E4%BB%8D%E5%B0%86%E6%8C%89%E8%AE%A1%E5%88%92%E8%BF%9B%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/18/1784368968000.webp","sourceId":"rfi"}]