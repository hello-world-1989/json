[{"id":1784629841000,"createdDate":"2026-07-21 10:30","name":"法国国际广播电台","title":"应对中国倾销钢铁 欧洲等收紧进口配额 印度转向国内市场","content":"由于欧洲和英国等主要市场收紧钢铁进口配额，印度钢铁制造商正转向国内市场以弥补出口疲软，不过受到来自中国低价钢铁的竞争，让印度制造商难以应对。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260721-%E5%BA%94%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%80%BE%E9%94%80%E9%92%A2%E9%93%81-%E6%AC%A7%E6%B4%B2%E7%AD%89%E6%94%B6%E7%B4%A7%E8%BF%9B%E5%8F%A3%E9%85%8D%E9%A2%9D-%E5%8D%B0%E5%BA%A6%E8%BD%AC%E5%90%91%E5%9B%BD%E5%86%85%E5%B8%82%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784629841000.webp","sourceId":"rfi"},{"id":1784622136000,"createdDate":"2026-07-21 08:22","name":"法国国际广播电台","title":"联合国报告: 2025年亚州因网络诈骗损失1140亿美元 中韩台重灾区","content":"联合国公布报告指出，去年,东亚、东南亚、澳洲和新西兰的电诈受害者的损失高达1141亿美元，金额比2023年增长了三倍。电诈行业正趋于全球一体化，且在技术应用方面处于领先地位。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260721-%E8%81%94%E5%90%88%E5%9B%BD%E6%8A%A5%E5%91%8A-2025%E5%B9%B4%E4%BA%9A%E5%B7%9E%E5%9B%A0%E7%BD%91%E7%BB%9C%E8%AF%88%E9%AA%97%E6%8D%9F%E5%A4%B11140%E4%BA%BF%E7%BE%8E%E5%85%83-%E4%B8%AD%E9%9F%A9%E5%8F%B0%E9%87%8D%E7%81%BE%E5%8C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784622136000.webp","sourceId":"rfi"},{"id":1784621769000,"createdDate":"2026-07-21 08:16","name":"法国国际广播电台","title":"卢比奥首访菲律宾：谴责中国的“危险”行径，致力维护东南亚的航行自由","content":"东盟外长会议今天（7月21日）在菲律宾马尼拉举行，11个成员国与美、中、日、韩、印度、欧盟、俄罗斯等伙伴国家都将参与。这也是美国国务卿卢比奥上任以来首度访问菲律宾，他在抵达前夕投书当地媒体，强调美国致力维护东南亚的航行自由，并重申美国对东南亚的防御保护伞承诺。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260721-%E5%8D%A2%E6%AF%94%E5%A5%A5%E9%A6%96%E8%AE%BF%E8%8F%B2%E5%BE%8B%E5%AE%BE-%E8%B0%B4%E8%B4%A3%E4%B8%AD%E5%9B%BD%E7%9A%84-%E5%8D%B1%E9%99%A9-%E8%A1%8C%E5%BE%84%EF%BC%8C%E8%87%B4%E5%8A%9B%E7%BB%B4%E6%8A%A4%E4%B8%9C%E5%8D%97%E4%BA%9A%E7%9A%84%E8%88%AA%E8%A1%8C%E8%87%AA%E7%94%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784621769000.webp","sourceId":"rfi"},{"id":1784621534000,"createdDate":"2026-07-21 08:12","name":"法国国际广播电台","title":"中俄舰队首次在日本专属经济区进行射击演习","content":"在中国军舰与俄罗斯军舰联合航行期间，两军在日本冲之鸟岛附近的日本专属经济区（EEZ）内进行了实弹射击演习。日本政府认为此举可能危及船舶航行安全，已向中方提出交涉。日本防卫省表示，这是首次确认并对外公布中国军舰在日本专属经济区内实施实弹射击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260721-%E4%B8%AD%E4%BF%84%E8%88%B0%E9%98%9F%E9%A6%96%E6%AC%A1%E5%9C%A8%E6%97%A5%E6%9C%AC%E4%B8%93%E5%B1%9E%E7%BB%8F%E6%B5%8E%E5%8C%BA%E8%BF%9B%E8%A1%8C%E5%B0%84%E5%87%BB%E6%BC%94%E4%B9%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784621534000.webp","sourceId":"rfi"},{"id":1784620749000,"createdDate":"2026-07-21 07:59","name":"法国国际广播电台","title":"轻度智障港男宣传台湾复国党 认「煽颠罪」判监28个月","content":"一名报称有轻度弱智和患有癫痫症的年轻男子，在网上认识台湾的「中华保台反共复国党」(下称「复国党」)负责人後，代为在港招揽团员。他早前承认一项「煽动他人颠覆国家政权」(简称煽颠)罪，国安法指定法官陈广池判刑时，虽然认同被告的个人障碍使他容易被煽动，且案件属於「情节较轻」，但对国安风险不能掉以轻心的前提下，判处被告入狱28个月。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260721-%E8%BD%BB%E5%BA%A6%E6%99%BA%E9%9A%9C%E6%B8%AF%E7%94%B7%E5%AE%A3%E4%BC%A0%E5%8F%B0%E6%B9%BE%E5%A4%8D%E5%9B%BD%E5%85%9A-%E8%AE%A4-%E7%85%BD%E9%A2%A0%E7%BD%AA-%E5%88%A4%E7%9B%9128%E4%B8%AA%E6%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784620749000.webp","sourceId":"rfi"},{"id":1784620328000,"createdDate":"2026-07-21 07:52","name":"法国国际广播电台","title":"香港与老挝签备忘录 推动黄金交易 结算系统试运後首份","content":"为推动香港黄金市场，香港与东南亚区内黄金资源排在前列的老挝签订合作谅解备忘录，为合资格的老挝黄金持有者提供便利对接香港认可黄金精炼网络的渠道，并鼓励更广泛采用符合国际标准的精炼金条在港进行交易和交割。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260721-%E9%A6%99%E6%B8%AF%E4%B8%8E%E8%80%81%E6%8C%9D%E7%AD%BE%E5%A4%87%E5%BF%98%E5%BD%95-%E6%8E%A8%E5%8A%A8%E9%BB%84%E9%87%91%E4%BA%A4%E6%98%93-%E7%BB%93%E7%AE%97%E7%B3%BB%E7%BB%9F%E8%AF%95%E8%BF%90%E5%BE%8C%E9%A6%96%E4%BB%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784620328000.webp","sourceId":"rfi"}]