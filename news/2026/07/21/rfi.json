[{"id":1784629841000,"createdDate":"2026-07-21 10:30","name":"法国国际广播电台","title":"应对中国倾销钢铁 欧洲等收紧进口配额 印度转向国内市场","content":"由于欧洲和英国等主要市场收紧钢铁进口配额，印度钢铁制造商正转向国内市场以弥补出口疲软，不过受到来自中国低价钢铁的竞争，让印度制造商难以应对。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260721-%E5%BA%94%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%80%BE%E9%94%80%E9%92%A2%E9%93%81-%E6%AC%A7%E6%B4%B2%E7%AD%89%E6%94%B6%E7%B4%A7%E8%BF%9B%E5%8F%A3%E9%85%8D%E9%A2%9D-%E5%8D%B0%E5%BA%A6%E8%BD%AC%E5%90%91%E5%9B%BD%E5%86%85%E5%B8%82%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784629841000.webp","sourceId":"rfi"},{"id":1784622136000,"createdDate":"2026-07-21 08:22","name":"法国国际广播电台","title":"联合国报告: 2025年亚州因网络诈骗损失1140亿美元 中韩台重灾区","content":"联合国公布报告指出，去年,东亚、东南亚、澳洲和新西兰的电诈受害者的损失高达1141亿美元，金额比2023年增长了三倍。电诈行业正趋于全球一体化，且在技术应用方面处于领先地位。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260721-%E8%81%94%E5%90%88%E5%9B%BD%E6%8A%A5%E5%91%8A-2025%E5%B9%B4%E4%BA%9A%E5%B7%9E%E5%9B%A0%E7%BD%91%E7%BB%9C%E8%AF%88%E9%AA%97%E6%8D%9F%E5%A4%B11140%E4%BA%BF%E7%BE%8E%E5%85%83-%E4%B8%AD%E9%9F%A9%E5%8F%B0%E9%87%8D%E7%81%BE%E5%8C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784622136000.webp","sourceId":"rfi"},{"id":1784621769000,"createdDate":"2026-07-21 08:16","name":"法国国际广播电台","title":"卢比奥首访菲律宾：谴责中国的“危险”行径，致力维护东南亚的航行自由","content":"东盟外长会议今天（7月21日）在菲律宾马尼拉举行，11个成员国与美、中、日、韩、印度、欧盟、俄罗斯等伙伴国家都将参与。这也是美国国务卿卢比奥上任以来首度访问菲律宾，他在抵达前夕投书当地媒体，强调美国致力维护东南亚的航行自由，并重申美国对东南亚的防御保护伞承诺。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260721-%E5%8D%A2%E6%AF%94%E5%A5%A5%E9%A6%96%E8%AE%BF%E8%8F%B2%E5%BE%8B%E5%AE%BE-%E8%B0%B4%E8%B4%A3%E4%B8%AD%E5%9B%BD%E7%9A%84-%E5%8D%B1%E9%99%A9-%E8%A1%8C%E5%BE%84%EF%BC%8C%E8%87%B4%E5%8A%9B%E7%BB%B4%E6%8A%A4%E4%B8%9C%E5%8D%97%E4%BA%9A%E7%9A%84%E8%88%AA%E8%A1%8C%E8%87%AA%E7%94%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784621769000.webp","sourceId":"rfi"},{"id":1784621534000,"createdDate":"2026-07-21 08:12","name":"法国国际广播电台","title":"中俄舰队首次在日本专属经济区进行射击演习","content":"在中国军舰与俄罗斯军舰联合航行期间，两军在日本冲之鸟岛附近的日本专属经济区（EEZ）内进行了实弹射击演习。日本政府认为此举可能危及船舶航行安全，已向中方提出交涉。日本防卫省表示，这是首次确认并对外公布中国军舰在日本专属经济区内实施实弹射击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260721-%E4%B8%AD%E4%BF%84%E8%88%B0%E9%98%9F%E9%A6%96%E6%AC%A1%E5%9C%A8%E6%97%A5%E6%9C%AC%E4%B8%93%E5%B1%9E%E7%BB%8F%E6%B5%8E%E5%8C%BA%E8%BF%9B%E8%A1%8C%E5%B0%84%E5%87%BB%E6%BC%94%E4%B9%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784621534000.webp","sourceId":"rfi"},{"id":1784620749000,"createdDate":"2026-07-21 07:59","name":"法国国际广播电台","title":"轻度智障港男宣传台湾复国党 认「煽颠罪」判监28个月","content":"一名报称有轻度弱智和患有癫痫症的年轻男子，在网上认识台湾的「中华保台反共复国党」(下称「复国党」)负责人後，代为在港招揽团员。他早前承认一项「煽动他人颠覆国家政权」(简称煽颠)罪，国安法指定法官陈广池判刑时，虽然认同被告的个人障碍使他容易被煽动，且案件属於「情节较轻」，但对国安风险不能掉以轻心的前提下，判处被告入狱28个月。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260721-%E8%BD%BB%E5%BA%A6%E6%99%BA%E9%9A%9C%E6%B8%AF%E7%94%B7%E5%AE%A3%E4%BC%A0%E5%8F%B0%E6%B9%BE%E5%A4%8D%E5%9B%BD%E5%85%9A-%E8%AE%A4-%E7%85%BD%E9%A2%A0%E7%BD%AA-%E5%88%A4%E7%9B%9128%E4%B8%AA%E6%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784620749000.webp","sourceId":"rfi"},{"id":1784620328000,"createdDate":"2026-07-21 07:52","name":"法国国际广播电台","title":"香港与老挝签备忘录 推动黄金交易 结算系统试运後首份","content":"为推动香港黄金市场，香港与东南亚区内黄金资源排在前列的老挝签订合作谅解备忘录，为合资格的老挝黄金持有者提供便利对接香港认可黄金精炼网络的渠道，并鼓励更广泛采用符合国际标准的精炼金条在港进行交易和交割。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260721-%E9%A6%99%E6%B8%AF%E4%B8%8E%E8%80%81%E6%8C%9D%E7%AD%BE%E5%A4%87%E5%BF%98%E5%BD%95-%E6%8E%A8%E5%8A%A8%E9%BB%84%E9%87%91%E4%BA%A4%E6%98%93-%E7%BB%93%E7%AE%97%E7%B3%BB%E7%BB%9F%E8%AF%95%E8%BF%90%E5%BE%8C%E9%A6%96%E4%BB%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784620328000.webp","sourceId":"rfi"},{"id":1784655673000,"createdDate":"2026-07-21 17:41","name":"法国国际广播电台","title":"英国新首相伯纳姆上任，莫斯科表示对与伦敦改善关系“不抱任何希望”","content":"英国工党首相安迪-伯纳姆上任后不久，便向泽连斯基表达了他对乌克兰人民的“坚定承诺”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260721-%E8%8B%B1%E5%9B%BD%E6%96%B0%E9%A6%96%E7%9B%B8%E4%BC%AF%E7%BA%B3%E5%A7%86%E4%B8%8A%E4%BB%BB%EF%BC%8C%E8%8E%AB%E6%96%AF%E7%A7%91%E8%A1%A8%E7%A4%BA%E5%AF%B9%E4%B8%8E%E4%BC%A6%E6%95%A6%E6%94%B9%E5%96%84%E5%85%B3%E7%B3%BB-%E4%B8%8D%E6%8A%B1%E4%BB%BB%E4%BD%95%E5%B8%8C%E6%9C%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784655673000.webp","sourceId":"rfi"},{"id":1784654383000,"createdDate":"2026-07-21 17:19","name":"法国国际广播电台","title":"巴拿马与中国续签港口协议","content":"巴拿马周一宣布，已与中国达成协议，续签一项给予巴拿马籍船舶在中国港口优惠待遇的海运条约。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260721-%E5%B7%B4%E6%8B%BF%E9%A9%AC%E4%B8%8E%E4%B8%AD%E5%9B%BD%E7%BB%AD%E7%AD%BE%E6%B8%AF%E5%8F%A3%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784654383000.webp","sourceId":"rfi"},{"id":1784651736000,"createdDate":"2026-07-21 16:35","name":"法国国际广播电台","title":"台湾立法院罕见团结为“星链”开绿灯 旨在确保与中国冲突时通信安全","content":"台湾立法机构周二通过了相关修法，允许互联网服务提供商“星链”（Starlink）在台湾运营其网络，旨在确保在与邻近的中国发生冲突时通信渠道畅通。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260721-%E5%8F%B0%E6%B9%BE%E7%AB%8B%E6%B3%95%E9%99%A2%E7%BD%95%E8%A7%81%E5%9B%A2%E7%BB%93%E4%B8%BA-%E6%98%9F%E9%93%BE-%E5%BC%80%E7%BB%BF%E7%81%AF-%E6%97%A8%E5%9C%A8%E7%A1%AE%E4%BF%9D%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%86%B2%E7%AA%81%E6%97%B6%E9%80%9A%E4%BF%A1%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784651736000.webp","sourceId":"rfi"},{"id":1784647948000,"createdDate":"2026-07-21 15:32","name":"法国国际广播电台","title":"南中国海摩擦: 菲律宾总统小马科斯召见中国大使","content":"菲律宾媒体GMANews报道，鉴于阿永金礁（仁爱礁）局势再度紧张，周二菲律宾总统费迪南德·马科斯总统以“国家安全”为由召见了中国驻菲律宾大使井泉。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260721-%E5%8D%97%E4%B8%AD%E5%9B%BD%E6%B5%B7%E6%91%A9%E6%93%A6-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E6%80%BB%E7%BB%9F%E5%B0%8F%E9%A9%AC%E7%A7%91%E6%96%AF%E5%8F%AC%E8%A7%81%E4%B8%AD%E5%9B%BD%E5%A4%A7%E4%BD%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784647948000.webp","sourceId":"rfi"},{"id":1784647836000,"createdDate":"2026-07-21 15:30","name":"法国国际广播电台","title":"伊朗战争：特朗普陷入困境","content":"美国继续对伊朗发动军事袭击，霍尔木兹海峡难以恢复正常，德国媒体有何看法？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9F%8F%E6%9E%97%E9%A3%9E%E9%B8%BF/20260721-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89-%E7%89%B9%E6%9C%97%E6%99%AE%E9%99%B7%E5%85%A5%E5%9B%B0%E5%A2%83","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784647836000.webp","sourceId":"rfi"},{"id":1784644948000,"createdDate":"2026-07-21 14:42","name":"法国国际广播电台","title":"南中国海摩擦：北京召见菲律宾大使","content":"中国周二就前一天在南海一处有争议小岛附近发生的事件召见菲律宾大使，法新社说，这是两国长期存在的海上争端中的最新一幕。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260721-%E5%8D%97%E4%B8%AD%E5%9B%BD%E6%B5%B7%E6%91%A9%E6%93%A6-%E5%8C%97%E4%BA%AC%E5%8F%AC%E8%A7%81%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%A4%A7%E4%BD%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784644948000.webp","sourceId":"rfi"},{"id":1784642452000,"createdDate":"2026-07-21 14:00","name":"法国国际广播电台","title":"澳大利亚对中国在南海行动表示关切 承诺进一步加强菲律宾海上能力","content":"澳大利亚外长黄英贤在菲律宾和中国船员于南海一处有争议礁石附近发生冲突后，谴责中国“危险且破坏稳定的行为”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260721-%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%9C%A8%E5%8D%97%E6%B5%B7%E8%A1%8C%E5%8A%A8%E8%A1%A8%E7%A4%BA%E5%85%B3%E5%88%87-%E6%89%BF%E8%AF%BA%E8%BF%9B%E4%B8%80%E6%AD%A5%E5%8A%A0%E5%BC%BA%E8%8F%B2%E5%BE%8B%E5%AE%BE%E6%B5%B7%E4%B8%8A%E8%83%BD%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784642452000.webp","sourceId":"rfi"},{"id":1784640992000,"createdDate":"2026-07-21 13:36","name":"法国国际广播电台","title":"英国迎来新首相 欧盟创纪录重罚速卖通 美中AI竞争的“模型蒸馏”争议","content":"周二（7月21日）各报头版主题各有侧重。《费加罗报》聚焦法国国民议会预计今天将通过法案，禁止15岁以下未成年人使用网络社媒，法国也因此有望成为欧洲首个采取这一措施的国家。而在政治共识的背后，对于年龄验证、隐私保护及平台执行等方面上仍存争议。《解放报》关注总统马克龙提名共和党参议员诺埃尔·比费出任新的人权事务专员，其反同性婚姻、主张强硬移民政策的保守立场，引发工会和社会团体的担忧，呼吁联署反对提名。天主教《十字架报》头版则报道旺代省长期探索居民、游客、农民与自然环境共享水资源的集体治理模式，以应对水资源日益短缺。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260721-%E8%8B%B1%E5%9B%BD%E8%BF%8E%E6%9D%A5%E6%96%B0%E9%A6%96%E7%9B%B8-%E6%AC%A7%E7%9B%9F%E5%88%9B%E7%BA%AA%E5%BD%95%E9%87%8D%E7%BD%9A%E9%80%9F%E5%8D%96%E9%80%9A-%E7%BE%8E%E4%B8%ADai%E7%AB%9E%E4%BA%89%E7%9A%84-%E6%A8%A1%E5%9E%8B%E8%92%B8%E9%A6%8F-%E4%B9%8B%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784640992000.webp","sourceId":"rfi"},{"id":1784640046000,"createdDate":"2026-07-21 13:20","name":"法国国际广播电台","title":"中国开源模型 Kimi K3 再给特朗普政府出了一道“禁或不禁”的难解题","content":"美国网媒Axios指出，中国人工智能实验室月之暗面最新推出的一款低成本模型，给美国政府出了个大难题。报道披露，白宫正在展开一场暗中博弈，以抵御来自竞争对手中国的低成本开源模型的威胁，并保护占据行业主导地位的美国本土AI企业。但也有报道说，对于是否应限制使用中国开源AI模型，特朗普政府内部的分歧不小。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260721-%E4%B8%AD%E5%9B%BD%E5%BC%80%E6%BA%90%E6%A8%A1%E5%9E%8B-kimi-k3-%E5%86%8D%E7%BB%99%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E5%87%BA%E4%BA%86%E4%B8%80%E9%81%93-%E7%A6%81%E6%88%96%E4%B8%8D%E7%A6%81-%E7%9A%84%E9%9A%BE%E8%A7%A3%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784640046000.webp","sourceId":"rfi"},{"id":1784634630000,"createdDate":"2026-07-21 11:50","name":"法国国际广播电台","title":"美军连炸伊朗第十夜 伊朗袭美军雷达防空系统 胡塞威胁沙特红海出口","content":"在伊朗与美国重启敌对行动两周后，双方加剧了军事打击，冲突有向红海蔓延之势。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260721-%E7%BE%8E%E5%86%9B%E8%BF%9E%E7%82%B8%E4%BC%8A%E6%9C%97%E7%AC%AC%E5%8D%81%E5%A4%9C-%E4%BC%8A%E6%9C%97%E8%A2%AD%E7%BE%8E%E5%86%9B%E9%9B%B7%E8%BE%BE%E9%98%B2%E7%A9%BA%E7%B3%BB%E7%BB%9F-%E8%83%A1%E5%A1%9E%E5%A8%81%E8%83%81%E6%B2%99%E7%89%B9%E7%BA%A2%E6%B5%B7%E5%87%BA%E5%8F%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784634630000.webp","sourceId":"rfi"},{"id":1784619923000,"createdDate":"2026-07-21 07:45","name":"法国国际广播电台","title":"赞比亚系列报道之二 ： 专家指河底沉积物不去除污染威胁继续存在","content":"中国国有有色矿业集团下属的赞比亚谦比希湿法冶炼有限公司（Sino-Metals LeachZambia）去年二月发生尾矿坝坍塌事件，导致大量有毒废水通过支流流入该国最长的河流卡富埃河。有媒体曾经形容说，该污染事件导致这条河流在一夜之间死亡。然而半年之后，赞比亚政府表示局势已基本恢复正常，水体的酸碱值pH值已恢复正常，重金属浓度也在不断下降，公司已依照政府指令履行修复和治理义务，并完成对个体农户的赔偿工作。 法广为此特别前往事故发生地段，试图了解受害者是否确实受到应有的赔偿以及当地的环境污染状况究竟如何。在上一次节目中为大家播出了对中资企业多位受害者的采访， 在今天的节目中我们将请专家点评采矿尤其是中资企业的环境影响。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E5%A2%83%E4%B8%8E%E5%8F%91%E5%B1%95/20260721-%E8%B5%9E%E6%AF%94%E4%BA%9A%E7%B3%BB%E5%88%97%E6%8A%A5%E9%81%93%E4%B9%8B%E4%BA%8C-%E4%B8%93%E5%AE%B6%E8%AF%84%E4%B8%AD%E8%B5%84%E4%BC%81%E4%B8%9A%E7%9A%84%E6%B1%A1%E6%9F%93%E7%A8%8B%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/07/21/1784619923000.webp","sourceId":"rfi"}]