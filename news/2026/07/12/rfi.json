[{"id":1783815822000,"createdDate":"2026-07-12 00:23","name":"法国国际广播电台","title":"英格兰队苦战2比1逆转黑马挪威 晋级半决赛","content":"世界杯四分之一决赛第三场周六在美国迈阿密硬石体育场开踢，英格兰对阵挪威，挪威率先破门，多亏贝林厄姆梅开二度，英国在加时赛阶段2比1逆转一路挺进的黑马挪威，争取到一张半决赛门票。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260712-%E8%8B%B1%E6%A0%BC%E5%85%B0%E9%98%9F%E8%8B%A6%E6%88%982%E6%AF%941%E9%80%86%E8%BD%AC%E9%BB%91%E9%A9%AC%E6%8C%AA%E5%A8%81-%E6%99%8B%E7%BA%A7%E5%8D%8A%E5%86%B3%E8%B5%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783815822000.webp","sourceId":"rfi"},{"id":1783849634000,"createdDate":"2026-07-12 09:47","name":"法国国际广播电台","title":"美共和党参议员格雷厄姆猝死享71岁生前支持乌克兰","content":"美国参议员林赛·格雷厄姆周六突然去世，享年71岁。他是共和党重量级人物，从特朗普的公开批评者转变为特朗普在国会山的盟友之一。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260712-%E7%BE%8E%E5%85%B1%E5%92%8C%E5%85%9A%E5%8F%82%E8%AE%AE%E5%91%98%E6%A0%BC%E9%9B%B7%E5%8E%84%E5%A7%86%E7%8C%9D%E6%AD%BB%E4%BA%AB71%E5%B2%81%E7%94%9F%E5%89%8D%E6%94%AF%E6%8C%81%E4%B9%8C%E5%85%8B%E5%85%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783849634000.webp","sourceId":"rfi"},{"id":1783847155000,"createdDate":"2026-07-12 09:05","name":"法国国际广播电台","title":"霍尔木兹海峡商船遭袭后，美军狂炸伊朗百多目标 伊朗宣布关闭海峡并袭中东多国","content":"一艘货轮周六在霍尔木兹海峡遭袭后，美军对伊朗军事目标发动140多次空袭，伊朗宣布关闭霍尔木兹海峡，并袭击了美国在中东国的一系列军事基地。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260712-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%95%86%E8%88%B9%E9%81%AD%E8%A2%AD%E5%90%8E%EF%BC%8C%E7%BE%8E%E5%86%9B%E7%8B%82%E7%82%B8%E4%BC%8A%E6%9C%97%E7%99%BE%E5%A4%9A%E7%9B%AE%E6%A0%87-%E4%BC%8A%E6%9C%97%E5%AE%A3%E5%B8%83%E5%85%B3%E9%97%AD%E6%B5%B7%E5%B3%A1%E5%B9%B6%E8%A2%AD%E4%B8%AD%E4%B8%9C%E5%A4%9A%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783847155000.webp","sourceId":"rfi"},{"id":1783846573000,"createdDate":"2026-07-12 08:56","name":"法国国际广播电台","title":"世界杯四强全部产生，英格兰、阿根廷苦战晋级，半决赛对阵正式出炉","content":"7月12日，世界杯四分之一决赛全部结束。继法国队和西班牙队率先晋级后，英格兰队与阿根廷队也分别经过加时赛取胜，成功锁定最后两个半决赛席位。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260712-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%9B%9B%E5%BC%BA%E5%85%A8%E9%83%A8%E4%BA%A7%E7%94%9F%EF%BC%8C%E8%8B%B1%E6%A0%BC%E5%85%B0-%E9%98%BF%E6%A0%B9%E5%BB%B7%E8%8B%A6%E6%88%98%E6%99%8B%E7%BA%A7%EF%BC%8C%E5%8D%8A%E5%86%B3%E8%B5%9B%E5%AF%B9%E9%98%B5%E6%AD%A3%E5%BC%8F%E5%87%BA%E7%82%89","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783846573000.webp","sourceId":"rfi"},{"id":1783845762000,"createdDate":"2026-07-12 08:42","name":"法国国际广播电台","title":"日本等14国发表联合声明  指出中国南海扩张没有法律根据","content":"日本、美国、菲律宾等14个国家，在依据《联合国海洋法公约》设立的仲裁庭作出裁决、否定中国关于其对南海大部分海域拥有主权主张满十周年之际，发表了联合声明。声明表示再次确认仲裁庭作出的“中国关于扩张性海洋权益主张缺乏法律依据”的裁决。日本外务省12日公布了这一消息。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260712-%E6%97%A5%E6%9C%AC%E7%AD%8914%E5%9B%BD%E5%8F%91%E8%A1%A8%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E-%E6%8C%87%E5%87%BA%E4%B8%AD%E5%9B%BD%E5%8D%97%E6%B5%B7%E6%89%A9%E5%BC%A0%E6%B2%A1%E6%9C%89%E6%B3%95%E5%BE%8B%E6%A0%B9%E6%8D%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783845762000.webp","sourceId":"rfi"},{"id":1783844907000,"createdDate":"2026-07-12 08:28","name":"法国国际广播电台","title":"法国第三波热浪：环法首次因高温缩短赛程 艾菲尔铁塔、卢浮宫提早闭馆","content":"法国正经历自5月以来的第三波热浪，气象部门周日（7月12日）向包括大巴黎等本土37个省发布最高级别的红色高温警报，受影响地区超过全国人口三分之一。与此同时，干旱高温导致全国多地火灾风险升高。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260712-%E6%B3%95%E5%9B%BD%E7%AC%AC%E4%B8%89%E6%B3%A2%E7%83%AD%E6%B5%AA-%E7%8E%AF%E6%B3%95%E9%A6%96%E6%AC%A1%E5%9B%A0%E9%AB%98%E6%B8%A9%E7%BC%A9%E7%9F%AD%E8%B5%9B%E7%A8%8B-%E8%89%BE%E8%8F%B2%E5%B0%94%E9%93%81%E5%A1%94-%E5%8D%A2%E6%B5%AE%E5%AE%AB%E6%8F%90%E6%97%A9%E9%97%AD%E9%A6%86","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783844907000.webp","sourceId":"rfi"},{"id":1783866042000,"createdDate":"2026-07-12 14:20","name":"法国国际广播电台","title":"泽连斯基痛悼林赛·格雷厄姆:10次访乌克兰与我们人民站在一起","content":"乌克兰总统泽连斯基周日表示，他对美国共和党参议员林赛·格雷厄姆的去世感到“深切悲痛”，并称格雷厄姆是一位“坚定的领导人”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260712-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E7%97%9B%E6%82%BC%E6%9E%97%E8%B5%9B%C2%B7%E6%A0%BC%E9%9B%B7%E5%8E%84%E5%A7%86-10%E6%AC%A1%E8%AE%BF%E4%B9%8C%E5%85%8B%E5%85%B0%E4%B8%8E%E6%88%91%E4%BB%AC%E4%BA%BA%E6%B0%91%E7%AB%99%E5%9C%A8%E4%B8%80%E8%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783866042000.webp","sourceId":"rfi"},{"id":1783861718000,"createdDate":"2026-07-12 13:08","name":"法国国际广播电台","title":"美伊第三轮互袭 霍尔木兹海峡被封 停火何以为继？","content":"在经历了“非战非和”以及短暂的缓和后，中东局势再度急剧升温。伊朗在美军新一轮空袭后周日宣布无限期关闭霍尔木兹海峡，并向卡塔尔、巴林、阿联酋、科威特等海湾邻国发射导弹和无人机，同时袭击美国在卡塔尔的空军基地。美伊持续升级的军事行动进一步冲击原本已名存实亡的停火协议，海湾局势再度紧绷。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260712-%E7%BE%8E%E4%BC%8A%E7%AC%AC%E4%B8%89%E8%BD%AE%E4%BA%92%E8%A2%AD-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E8%A2%AB%E5%B0%81-%E5%81%9C%E7%81%AB%E4%BD%95%E4%BB%A5%E4%B8%BA%E7%BB%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783861718000.webp","sourceId":"rfi"},{"id":1783860569000,"createdDate":"2026-07-12 12:49","name":"法国国际广播电台","title":"台风“巴威”降级为热带风暴带给中国狂风暴雨","content":"台风“巴威”周日已降级为热带风暴，但仍伴着狂风暴雨向中国东部推进，该地区已有近200万人被疏散。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260712-%E5%8F%B0%E9%A3%8E-%E5%B7%B4%E5%A8%81-%E9%99%8D%E7%BA%A7%E4%B8%BA%E7%83%AD%E5%B8%A6%E9%A3%8E%E6%9A%B4%E5%B8%A6%E7%BB%99%E4%B8%AD%E5%9B%BD%E7%8B%82%E9%A3%8E%E6%9A%B4%E9%9B%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783860569000.webp","sourceId":"rfi"},{"id":1783857520000,"createdDate":"2026-07-12 11:58","name":"法国国际广播电台","title":"新德里称在霍尔木兹海峡遭袭的船上共有11名印度人","content":"新德里周日表示，在霍尔木兹海峡遭袭的船上共有11名印度公民，此时伊朗与美国已重启敌对行动。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260712-%E6%96%B0%E5%BE%B7%E9%87%8C%E7%A7%B0%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%81%AD%E8%A2%AD%E7%9A%84%E8%88%B9%E4%B8%8A%E5%85%B1%E6%9C%8911%E5%90%8D%E5%8D%B0%E5%BA%A6%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783857520000.webp","sourceId":"rfi"},{"id":1783852988000,"createdDate":"2026-07-12 10:43","name":"法国国际广播电台","title":"欧洲对美对华双重依赖，\"幸福的全球化\"不再幸福","content":"各位好，由于本台订阅的法国主流日刊周日大多不出刊，在本期法国报纸摘要节目中，我们为您选取出刊的法国世界报相关重点做综述。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260712-%E6%AC%A7%E6%B4%B2%E5%AF%B9%E7%BE%8E%E5%AF%B9%E5%8D%8E%E5%8F%8C%E9%87%8D%E4%BE%9D%E8%B5%96%EF%BC%8C-%E5%B9%B8%E7%A6%8F%E7%9A%84%E5%85%A8%E7%90%83%E5%8C%96-%E4%B8%8D%E5%86%8D%E5%B9%B8%E7%A6%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783852988000.webp","sourceId":"rfi"}]