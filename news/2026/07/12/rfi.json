[{"id":1783815822000,"createdDate":"2026-07-12 00:23","name":"法国国际广播电台","title":"英格兰队苦战2比1逆转黑马挪威 晋级半决赛","content":"世界杯四分之一决赛第三场周六在美国迈阿密硬石体育场开踢，英格兰对阵挪威，挪威率先破门，多亏贝林厄姆梅开二度，英国在加时赛阶段2比1逆转一路挺进的黑马挪威，争取到一张半决赛门票。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260712-%E8%8B%B1%E6%A0%BC%E5%85%B0%E9%98%9F%E8%8B%A6%E6%88%982%E6%AF%941%E9%80%86%E8%BD%AC%E9%BB%91%E9%A9%AC%E6%8C%AA%E5%A8%81-%E6%99%8B%E7%BA%A7%E5%8D%8A%E5%86%B3%E8%B5%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783815822000.webp","sourceId":"rfi"},{"id":1783849634000,"createdDate":"2026-07-12 09:47","name":"法国国际广播电台","title":"美共和党参议员格雷厄姆猝死享71岁生前支持乌克兰","content":"美国参议员林赛·格雷厄姆周六突然去世，享年71岁。他是共和党重量级人物，从特朗普的公开批评者转变为特朗普在国会山的盟友之一。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260712-%E7%BE%8E%E5%85%B1%E5%92%8C%E5%85%9A%E5%8F%82%E8%AE%AE%E5%91%98%E6%A0%BC%E9%9B%B7%E5%8E%84%E5%A7%86%E7%8C%9D%E6%AD%BB%E4%BA%AB71%E5%B2%81%E7%94%9F%E5%89%8D%E6%94%AF%E6%8C%81%E4%B9%8C%E5%85%8B%E5%85%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783849634000.webp","sourceId":"rfi"},{"id":1783847155000,"createdDate":"2026-07-12 09:05","name":"法国国际广播电台","title":"霍尔木兹海峡商船遭袭后，美军狂炸伊朗百多目标 伊朗宣布关闭海峡并袭中东多国","content":"一艘货轮周六在霍尔木兹海峡遭袭后，美军对伊朗军事目标发动140多次空袭，伊朗宣布关闭霍尔木兹海峡，并袭击了美国在中东国的一系列军事基地。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260712-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%95%86%E8%88%B9%E9%81%AD%E8%A2%AD%E5%90%8E%EF%BC%8C%E7%BE%8E%E5%86%9B%E7%8B%82%E7%82%B8%E4%BC%8A%E6%9C%97%E7%99%BE%E5%A4%9A%E7%9B%AE%E6%A0%87-%E4%BC%8A%E6%9C%97%E5%AE%A3%E5%B8%83%E5%85%B3%E9%97%AD%E6%B5%B7%E5%B3%A1%E5%B9%B6%E8%A2%AD%E4%B8%AD%E4%B8%9C%E5%A4%9A%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783847155000.webp","sourceId":"rfi"},{"id":1783846573000,"createdDate":"2026-07-12 08:56","name":"法国国际广播电台","title":"世界杯四强全部产生，英格兰、阿根廷苦战晋级，半决赛对阵正式出炉","content":"7月12日，世界杯四分之一决赛全部结束。继法国队和西班牙队率先晋级后，英格兰队与阿根廷队也分别经过加时赛取胜，成功锁定最后两个半决赛席位。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260712-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%9B%9B%E5%BC%BA%E5%85%A8%E9%83%A8%E4%BA%A7%E7%94%9F%EF%BC%8C%E8%8B%B1%E6%A0%BC%E5%85%B0-%E9%98%BF%E6%A0%B9%E5%BB%B7%E8%8B%A6%E6%88%98%E6%99%8B%E7%BA%A7%EF%BC%8C%E5%8D%8A%E5%86%B3%E8%B5%9B%E5%AF%B9%E9%98%B5%E6%AD%A3%E5%BC%8F%E5%87%BA%E7%82%89","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783846573000.webp","sourceId":"rfi"},{"id":1783845762000,"createdDate":"2026-07-12 08:42","name":"法国国际广播电台","title":"日本等14国发表联合声明  指出中国南海扩张没有法律根据","content":"日本、美国、菲律宾等14个国家，在依据《联合国海洋法公约》设立的仲裁庭作出裁决、否定中国关于其对南海大部分海域拥有主权主张满十周年之际，发表了联合声明。声明表示再次确认仲裁庭作出的“中国关于扩张性海洋权益主张缺乏法律依据”的裁决。日本外务省12日公布了这一消息。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260712-%E6%97%A5%E6%9C%AC%E7%AD%8914%E5%9B%BD%E5%8F%91%E8%A1%A8%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E-%E6%8C%87%E5%87%BA%E4%B8%AD%E5%9B%BD%E5%8D%97%E6%B5%B7%E6%89%A9%E5%BC%A0%E6%B2%A1%E6%9C%89%E6%B3%95%E5%BE%8B%E6%A0%B9%E6%8D%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783845762000.webp","sourceId":"rfi"},{"id":1783844907000,"createdDate":"2026-07-12 08:28","name":"法国国际广播电台","title":"法国第三波热浪：环法首次因高温缩短赛程 艾菲尔铁塔、卢浮宫提早闭馆","content":"法国正经历自5月以来的第三波热浪，气象部门周日（7月12日）向包括大巴黎等本土37个省发布最高级别的红色高温警报，受影响地区超过全国人口三分之一。与此同时，干旱高温导致全国多地火灾风险升高。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260712-%E6%B3%95%E5%9B%BD%E7%AC%AC%E4%B8%89%E6%B3%A2%E7%83%AD%E6%B5%AA-%E7%8E%AF%E6%B3%95%E9%A6%96%E6%AC%A1%E5%9B%A0%E9%AB%98%E6%B8%A9%E7%BC%A9%E7%9F%AD%E8%B5%9B%E7%A8%8B-%E8%89%BE%E8%8F%B2%E5%B0%94%E9%93%81%E5%A1%94-%E5%8D%A2%E6%B5%AE%E5%AE%AB%E6%8F%90%E6%97%A9%E9%97%AD%E9%A6%86","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783844907000.webp","sourceId":"rfi"},{"id":1783866042000,"createdDate":"2026-07-12 14:20","name":"法国国际广播电台","title":"泽连斯基痛悼林赛·格雷厄姆:10次访乌克兰与我们人民站在一起","content":"乌克兰总统泽连斯基周日表示，他对美国共和党参议员林赛·格雷厄姆的去世感到“深切悲痛”，并称格雷厄姆是一位“坚定的领导人”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260712-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E7%97%9B%E6%82%BC%E6%9E%97%E8%B5%9B%C2%B7%E6%A0%BC%E9%9B%B7%E5%8E%84%E5%A7%86-10%E6%AC%A1%E8%AE%BF%E4%B9%8C%E5%85%8B%E5%85%B0%E4%B8%8E%E6%88%91%E4%BB%AC%E4%BA%BA%E6%B0%91%E7%AB%99%E5%9C%A8%E4%B8%80%E8%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783866042000.webp","sourceId":"rfi"},{"id":1783861718000,"createdDate":"2026-07-12 13:08","name":"法国国际广播电台","title":"美伊第三轮互袭 霍尔木兹海峡被封 停火何以为继？","content":"在经历了“非战非和”以及短暂的缓和后，中东局势再度急剧升温。伊朗在美军新一轮空袭后周日宣布无限期关闭霍尔木兹海峡，并向卡塔尔、巴林、阿联酋、科威特等海湾邻国发射导弹和无人机，同时袭击美国在卡塔尔的空军基地。美伊持续升级的军事行动进一步冲击原本已名存实亡的停火协议，海湾局势再度紧绷。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260712-%E7%BE%8E%E4%BC%8A%E7%AC%AC%E4%B8%89%E8%BD%AE%E4%BA%92%E8%A2%AD-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E8%A2%AB%E5%B0%81-%E5%81%9C%E7%81%AB%E4%BD%95%E4%BB%A5%E4%B8%BA%E7%BB%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783861718000.webp","sourceId":"rfi"},{"id":1783860569000,"createdDate":"2026-07-12 12:49","name":"法国国际广播电台","title":"台风“巴威”降级为热带风暴带给中国狂风暴雨","content":"台风“巴威”周日已降级为热带风暴，但仍伴着狂风暴雨向中国东部推进，该地区已有近200万人被疏散。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260712-%E5%8F%B0%E9%A3%8E-%E5%B7%B4%E5%A8%81-%E9%99%8D%E7%BA%A7%E4%B8%BA%E7%83%AD%E5%B8%A6%E9%A3%8E%E6%9A%B4%E5%B8%A6%E7%BB%99%E4%B8%AD%E5%9B%BD%E7%8B%82%E9%A3%8E%E6%9A%B4%E9%9B%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783860569000.webp","sourceId":"rfi"},{"id":1783857520000,"createdDate":"2026-07-12 11:58","name":"法国国际广播电台","title":"新德里称在霍尔木兹海峡遭袭的船上共有11名印度人","content":"新德里周日表示，在霍尔木兹海峡遭袭的船上共有11名印度公民，此时伊朗与美国已重启敌对行动。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260712-%E6%96%B0%E5%BE%B7%E9%87%8C%E7%A7%B0%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%81%AD%E8%A2%AD%E7%9A%84%E8%88%B9%E4%B8%8A%E5%85%B1%E6%9C%8911%E5%90%8D%E5%8D%B0%E5%BA%A6%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783857520000.webp","sourceId":"rfi"},{"id":1783852988000,"createdDate":"2026-07-12 10:43","name":"法国国际广播电台","title":"欧洲对美对华双重依赖，\"幸福的全球化\"不再幸福","content":"各位好，由于本台订阅的法国主流日刊周日大多不出刊，在本期法国报纸摘要节目中，我们为您选取出刊的法国世界报相关重点做综述。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260712-%E6%AC%A7%E6%B4%B2%E5%AF%B9%E7%BE%8E%E5%AF%B9%E5%8D%8E%E5%8F%8C%E9%87%8D%E4%BE%9D%E8%B5%96%EF%BC%8C-%E5%B9%B8%E7%A6%8F%E7%9A%84%E5%85%A8%E7%90%83%E5%8C%96-%E4%B8%8D%E5%86%8D%E5%B9%B8%E7%A6%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783852988000.webp","sourceId":"rfi"},{"id":1783896551000,"createdDate":"2026-07-12 22:49","name":"法国国际广播电台","title":"最后时刻 谁能摘冠？","content":"有惊险，没有地震，有冲击，没有乱阵，最终，黑马马失前蹄，搅局者出局，球星云集的法国、西班牙、阿根廷、英国未失水准，按照各自的轨迹晋级世界杯半决赛，距离摘取冠军星看起来仅一步之遥，然而这是何等巨大的一步 !","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260712-%E6%9C%80%E5%90%8E%E6%97%B6%E5%88%BB-%E8%B0%81%E8%83%BD%E6%91%98%E5%86%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783896551000.webp","sourceId":"rfi"},{"id":1783891640000,"createdDate":"2026-07-12 21:27","name":"法国国际广播电台","title":"西班牙前首相称法国队没有法国人引发众怒","content":"距离法国在世界杯半决赛对阵西班牙仅剩两天之际，西班牙前保守派首相拉霍伊谬称法国队“没有法国人”在法国引发轩然大波，并遭到他的社会党继任者桑切斯首相的严厉谴责。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260712-%E8%A5%BF%E7%8F%AD%E7%89%99%E5%89%8D%E9%A6%96%E7%9B%B8%E7%A7%B0%E6%B3%95%E5%9B%BD%E9%98%9F%E6%B2%A1%E6%9C%89%E6%B3%95%E5%9B%BD%E4%BA%BA%E5%BC%95%E5%8F%91%E4%BC%97%E6%80%92","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783891640000.webp","sourceId":"rfi"},{"id":1783891021000,"createdDate":"2026-07-12 21:17","name":"法国国际广播电台","title":"阿尔及利亚和马里改善外交关系","content":"北非国家阿尔及利亚和其邻国马里之间已经中断了超过一年之久的直接对话现已恢复。在双边关系好转的大背景下，阿尔及尔和巴马科于2026年7月10日星期五分别宣布，双方大使都将返回各自的驻地履职。本台法广非洲组（RFIAfrique）法语通讯员在今天07月12号星期日的更新报道中指出，多哥、刚果（布）以及俄罗斯，均为缓和阿尔及利亚和马里之间的关系发挥了作用。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260712-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E9%98%BF%E5%B0%94%E5%8F%8A%E5%88%A9%E4%BA%9A%E5%92%8C%E9%A9%AC%E9%87%8C%E6%94%B9%E5%96%84%E5%A4%96%E4%BA%A4%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783891021000.webp","sourceId":"rfi"},{"id":1783890624000,"createdDate":"2026-07-12 21:10","name":"法国国际广播电台","title":"宝马在中国市场遭遇急剧下滑 但Mini品牌成为亮点","content":"据慕尼黑《墨丘利报》报道：德国汽车集团宝马的销量下滑趋势2026年仍在持续，尤其是在中国市场，销量出现大幅下降。不过，集团内部也并非全无好消息。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260712-%E5%AE%9D%E9%A9%AC%E5%9C%A8%E4%B8%AD%E5%9B%BD%E5%B8%82%E5%9C%BA%E9%81%AD%E9%81%87%E6%80%A5%E5%89%A7%E4%B8%8B%E6%BB%91-%E4%BD%86mini%E5%93%81%E7%89%8C%E6%88%90%E4%B8%BA%E4%BA%AE%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783890624000.webp","sourceId":"rfi"},{"id":1783890335000,"createdDate":"2026-07-12 21:05","name":"法国国际广播电台","title":"法国热浪达到峰值 3座核反应堆停运、37省进入红色警戒","content":"法国今年第三轮高温天气周日（7月12日）进入峰值，导致3座核反应堆停运，全国超过三分之一人口所在地区进入最高级别红色高温警戒，而本周初炎热天气仍将持续。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260712-%E6%B3%95%E5%9B%BD%E7%83%AD%E6%B5%AA%E8%BE%BE%E5%88%B0%E5%B3%B0%E5%80%BC-3%E5%BA%A7%E6%A0%B8%E5%8F%8D%E5%BA%94%E5%A0%86%E5%81%9C%E8%BF%90-37%E7%9C%81%E8%BF%9B%E5%85%A5%E7%BA%A2%E8%89%B2%E8%AD%A6%E6%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783890335000.webp","sourceId":"rfi"},{"id":1783890324000,"createdDate":"2026-07-12 21:05","name":"法国国际广播电台","title":"沃尔兹：中俄仍在古巴设情报据点　威胁美国国家安全","content":"美国驻联合国大使迈克．沃尔兹（MikeWaltz）12日表示，中国与俄罗斯目前仍在古巴设有情报据点，持续搜集美国军事基地周边资讯，对美国国家安全构成威胁。他强调，特朗普（DonaldTrump）政府将持续反制中俄在西半球的影响力，不会再容忍古巴成为外国对手在美国近海的情报前哨。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260712-%E6%B2%83%E5%B0%94%E5%85%B9-%E4%B8%AD%E4%BF%84%E4%BB%8D%E5%9C%A8%E5%8F%A4%E5%B7%B4%E8%AE%BE%E6%83%85%E6%8A%A5%E6%8D%AE%E7%82%B9-%E5%A8%81%E8%83%81%E7%BE%8E%E5%9B%BD%E5%9B%BD%E5%AE%B6%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783890324000.webp","sourceId":"rfi"},{"id":1783890109000,"createdDate":"2026-07-12 21:01","name":"法国国际广播电台","title":"以色列定于10月27日举行大选　内塔尼亚胡寻求连任面临政治考验","content":"以色列总理内塔尼亚胡领导的执政联盟周日（7月12日）宣布，以色列将于10月27日举行议会选举。这将是2023年10月7日巴勒斯坦伊斯兰抵抗运动（哈马斯）突袭以色列，以及随后加沙、黎巴嫩和伊朗冲突爆发以来，以色列首次举行全国大选。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260712-%E4%BB%A5%E8%89%B2%E5%88%97%E5%AE%9A%E4%BA%8E10%E6%9C%8827%E6%97%A5%E4%B8%BE%E8%A1%8C%E5%A4%A7%E9%80%89-%E5%86%85%E5%A1%94%E5%B0%BC%E4%BA%9A%E8%83%A1%E5%AF%BB%E6%B1%82%E8%BF%9E%E4%BB%BB%E8%BF%8E%E6%94%BF%E6%B2%BB%E8%80%83%E9%AA%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783890109000.webp","sourceId":"rfi"},{"id":1783889923000,"createdDate":"2026-07-12 20:58","name":"法国国际广播电台","title":"泽连斯基宣布乌克兰政府将改组 聚焦防务、能源与外交战略调整","content":"乌克兰总统泽连斯基周日（7月12日）宣布，将启动政府改组，并提议撤换就任未满一年的总理尤利娅·斯维里坚科，以配合乌克兰新的政治战略。根据乌克兰法律，总理辞职须经国会批准，一旦获准，现政府将总辞职。泽连斯基表示，新战略将重点落实与盟友达成的防务合作协议，加强能源安全，并调整外交团队布局。政府改组的具体安排预计将在未来数天内公布。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260712-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%AE%A3%E5%B8%83%E4%B9%8C%E5%85%8B%E5%85%B0%E6%94%BF%E5%BA%9C%E5%B0%86%E6%94%B9%E7%BB%84-%E8%81%9A%E7%84%A6%E9%98%B2%E5%8A%A1-%E8%83%BD%E6%BA%90%E4%B8%8E%E5%A4%96%E4%BA%A4%E6%88%98%E7%95%A5%E8%B0%83%E6%95%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783889923000.webp","sourceId":"rfi"},{"id":1783889404000,"createdDate":"2026-07-12 20:50","name":"法国国际广播电台","title":"伊朗宣布关闭霍尔木兹海峡后美伊再度交火 国际社会呼吁缓和局势","content":"伊朗宣布关闭霍尔木兹海峡后，海湾地区周日（7月12日）再度爆发新一轮军事冲突。美国则表示，这条具有重要战略意义的国际航道仍保持开放。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260712-%E4%BC%8A%E6%9C%97%E5%AE%A3%E5%B8%83%E5%85%B3%E9%97%AD%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%90%8E%E7%BE%8E%E4%BC%8A%E5%86%8D%E5%BA%A6%E4%BA%A4%E7%81%AB-%E5%9B%BD%E9%99%85%E7%A4%BE%E4%BC%9A%E5%91%BC%E5%90%81%E7%BC%93%E5%92%8C%E5%B1%80%E5%8A%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783889404000.webp","sourceId":"rfi"},{"id":1783882739000,"createdDate":"2026-07-12 18:58","name":"法国国际广播电台","title":"南非对国脚亚当斯死因启动调查","content":"曾于两周前06月25日在2026年世界杯足球赛上参加与韩国国足对阵的南非25岁国脚杰登·亚当斯（JaydenAdams）于2026年07月11日星期六突然传出死讯。南非体育、艺术和文化部长盖顿·麦肯齐（GaytonMckenzie）在对外宣布这一消息时，没有提到具体死因。本台法广非洲组（RFIAfrique）法语通讯员在今天07月12号星期日发自约翰内斯堡（Johannesburg）的更新报道中指出，这位英年早逝的中场球员正处于其职业生涯的上升阶段。南非警方宣布对此启动调查。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260712-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-2026%E4%B8%96%E7%95%8C%E6%9D%AF-%E5%8D%97%E9%9D%9E%E5%AF%B9%E5%9B%BD%E8%84%9A%E4%BA%9A%E5%BD%93%E6%96%AF%E6%AD%BB%E5%9B%A0%E5%90%AF%E5%8A%A8%E8%B0%83%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/12/1783882739000.webp","sourceId":"rfi"}]