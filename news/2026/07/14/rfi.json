[{"id":1784024146000,"createdDate":"2026-07-14 10:15","name":"法国国际广播电台","title":"法国媒体今日关注：是国庆日也是尼斯恐袭10周年、枫丹白露火灾或系人为、法国队球衣爆火","content":"今天是法国一年一度的国庆日，法国各大报纸无疑聚焦于此。此外，法国报纸关注的议题还有：枫丹白露森林大火与今晚法国与西班牙的首场半决赛。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260714-%E6%B3%95%E5%9B%BD%E5%AA%92%E4%BD%93%E4%BB%8A%E6%97%A5%E5%85%B3%E6%B3%A8-%E6%98%AF%E5%9B%BD%E5%BA%86%E6%97%A5%E4%B9%9F%E6%98%AF%E5%B0%BC%E6%96%AF%E6%81%90%E8%A2%AD10%E5%91%A8%E5%B9%B4-%E6%9E%AB%E4%B8%B9%E7%99%BD%E9%9C%B2%E7%81%AB%E7%81%BE%E6%88%96%E7%B3%BB%E4%BA%BA%E4%B8%BA-%E6%B3%95%E5%9B%BD%E9%98%9F%E7%90%83%E8%A1%A3%E7%88%86%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/14/1784024146000.webp","sourceId":"rfi"},{"id":1784021712000,"createdDate":"2026-07-14 09:35","name":"法国国际广播电台","title":"从普拉蒂尼到亚马尔：法西大战再写世界杯经典","content":"7月14日，2026年世界杯首场半决赛即将在美国达拉斯打响，法国与西班牙队在夺冠之路上再次狭路相逢。从普拉蒂尼、齐达内、姆巴佩，到年轻足球天才亚马尔，法新社回顾两支欧洲豪门在历次世界大赛中的经典对抗。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260714-%E4%BB%8E%E6%99%AE%E6%8B%89%E8%92%82%E5%B0%BC%E5%88%B0%E4%BA%9A%E9%A9%AC%E5%B0%94-%E6%B3%95%E8%A5%BF%E5%A4%A7%E6%88%98%E5%86%8D%E5%86%99%E4%B8%96%E7%95%8C%E6%9D%AF%E7%BB%8F%E5%85%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/14/1784021712000.webp","sourceId":"rfi"},{"id":1784021426000,"createdDate":"2026-07-14 09:30","name":"法国国际广播电台","title":"法国国庆宏大阅兵 多国参加 向乌克兰及其欧洲盟友致敬","content":"周二，法国总统马克龙驱车沿香榭丽舍大道行进，参加了他总统任期内的最后一次7月14日国庆阅兵。此次阅兵规模宏大，旨在向乌克兰及其欧洲盟友致敬。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260714-%E6%B3%95%E5%9B%BD%E5%9B%BD%E5%BA%86%E5%AE%8F%E5%A4%A7%E9%98%85%E5%85%B5-%E5%A4%9A%E5%9B%BD%E5%8F%82%E5%8A%A0-%E5%90%91%E4%B9%8C%E5%85%8B%E5%85%B0%E5%8F%8A%E5%85%B6%E6%AC%A7%E6%B4%B2%E7%9B%9F%E5%8F%8B%E8%87%B4%E6%95%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/07/14/1784021426000.webp","sourceId":"rfi"},{"id":1784017721000,"createdDate":"2026-07-14 08:28","name":"法国国际广播电台","title":"“大搞家族腐败”马兴瑞被“双开”：何卫东、张又侠之后 政治局委员落马第三人","content":"据中国官媒新华社今天（7月14日）报道，原中共政治局委员、中共新疆维吾尔自治区原党委书记马兴瑞被开除党籍和公职（双开）。官方通报，马兴瑞「搞权色、钱色交易」，纵容放任亲属利用职务影响牟取巨额利益，大搞家族腐败，「性质极其严重，影响极其恶劣」。这是中共首度公布马兴瑞落马的涉案内容。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260714-%E5%A4%A7%E6%90%9E%E5%AE%B6%E6%97%8F%E8%85%90%E8%B4%A5-%E9%A9%AC%E5%85%B4%E7%91%9E%E8%A2%AB-%E5%8F%8C%E5%BC%80-%E4%BD%95%E5%8D%AB%E4%B8%9C-%E5%BC%A0%E5%8F%88%E4%BE%A0%E4%B9%8B%E5%90%8E-%E6%94%BF%E6%B2%BB%E5%B1%80%E5%A7%94%E5%91%98%E8%90%BD%E9%A9%AC%E7%AC%AC%E4%B8%89%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/14/1784017721000.webp","sourceId":"rfi"},{"id":1784015498000,"createdDate":"2026-07-14 07:51","name":"法国国际广播电台","title":"法国驻台代表龙烨任满离台 身为爱丽舍宫倚重的非洲顾问为何当初却选择了台湾？","content":"法国在台协会主任龙烨（FranckParis）将于16日任满离台，2023年8月抵台的他当时人生地不熟，也不会说中文，但台湾却对他开启大门。三年后他表示，台湾真的会让人上瘾。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260714-%E6%B3%95%E5%9B%BD%E9%A9%BB%E5%8F%B0%E4%BB%A3%E8%A1%A8%E9%BE%99%E7%83%A8%E4%BB%BB%E6%BB%A1%E7%A6%BB%E5%8F%B0-%E8%BA%AB%E4%B8%BA%E7%88%B1%E4%B8%BD%E8%88%8D%E5%AE%AB%E5%80%9A%E9%87%8D%E7%9A%84%E9%9D%9E%E6%B4%B2%E9%A1%BE%E9%97%AE%E4%B8%BA%E4%BD%95%E5%BD%93%E5%88%9D%E5%8D%B4%E9%80%89%E6%8B%A9%E4%BA%86%E5%8F%B0%E6%B9%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/14/1784015498000.webp","sourceId":"rfi"},{"id":1784015200000,"createdDate":"2026-07-14 07:46","name":"法国国际广播电台","title":"一周内两间独立书店预告结业  「留下书舍」留不下 政治红线与经营原因并存","content":"在一年一度的香港书展周三(15日)开幕前夕，由一群前新闻工作者创办丶曾被拒参展的「留下书舍」预告，基於「难以捉摸的红线」和香港经济情况，决定於下月底结业。这是一星期内，第二间独立书店预告结业，预料港人接触书籍的光谱将进一步收窄，城市没有灵魂的程度更甚。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260714-%E4%B8%80%E5%91%A8%E5%86%85%E4%B8%A4%E9%97%B4%E7%8B%AC%E7%AB%8B%E4%B9%A6%E5%BA%97%E9%A2%84%E5%91%8A%E7%BB%93%E4%B8%9A-%E7%95%99%E4%B8%8B%E4%B9%A6%E8%88%8D-%E7%95%99%E4%B8%8D%E4%B8%8B-%E6%94%BF%E6%B2%BB%E7%BA%A2%E7%BA%BF%E4%B8%8E%E7%BB%8F%E8%90%A5%E5%8E%9F%E5%9B%A0%E5%B9%B6%E5%AD%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/14/1784015200000.webp","sourceId":"rfi"},{"id":1784015012000,"createdDate":"2026-07-14 07:43","name":"法国国际广播电台","title":"研究指中国将政治内容管控嵌入AI模型　随DeepSeek等技术「出海」影响海外","content":"中国自主研发的生成式人工智能模型DeepSeek等，近年迅速在海外普及。一项最新研究指出，北京近年透过建立人工智能安全标准丶政企合作及模型测试制度，把符合中共政治要求的内容管控机制及官方叙事，预先嵌入生成式人工智能模型之中，令相关内容管控逻辑随着中国人工智能模型加快走向全球而输出海外，影响其他国家的资讯环境；香港丶台湾及美国的舆情已受到影响。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260714-%E7%A0%94%E7%A9%B6%E6%8C%87%E4%B8%AD%E5%9B%BD%E5%B0%86%E6%94%BF%E6%B2%BB%E5%86%85%E5%AE%B9%E7%AE%A1%E6%8E%A7%E5%B5%8C%E5%85%A5ai%E6%A8%A1%E5%9E%8B-%E9%9A%8Fdeepseek%E7%AD%89%E6%8A%80%E6%9C%AF-%E5%87%BA%E6%B5%B7-%E5%BD%B1%E5%93%8D%E6%B5%B7%E5%A4%96","thumbnail":"","detailImage":"news/detail/rfi/2026/07/14/1784015012000.webp","sourceId":"rfi"},{"id":1784014806000,"createdDate":"2026-07-14 07:40","name":"法国国际广播电台","title":"欧洲思想文化长廊：希腊：欧洲文化永不磨灭的光辉 第2 米洛文明：照亮希腊的曙光（下）","content":"历史学家一般都把希腊历史的起点确定在公元前776年，那是首届奥林匹克运动会举行的一年。但这个确定过于狭窄。海因里希·谢里曼不是专业历史学家，他仅凭对荷马史诗的热爱和确信，开始了寻找特洛伊的冒险。他的成就揭示了希腊文明的发轫要早的多。这启发了一位英国绅士立志从事更大的冒险，他就是亚瑟·伊文斯。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260714-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%B8%8C%E8%85%8A-%E6%AC%A7%E6%B4%B2%E6%96%87%E5%8C%96%E6%B0%B8%E4%B8%8D%E7%A3%A8%E7%81%AD%E7%9A%84%E5%85%89%E8%BE%89-%E7%AC%AC2-%E7%B1%B3%E6%B4%9B%E6%96%87%E6%98%8E-%E7%85%A7%E4%BA%AE%E5%B8%8C%E8%85%8A%E7%9A%84%E6%9B%99%E5%85%89-%E4%B8%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/14/1784014806000.webp","sourceId":"rfi"}]