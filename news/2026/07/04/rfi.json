[{"id":1783155182000,"createdDate":"2026-07-04 08:53","name":"法国国际广播电台","title":"法国阿维尼翁艺术节：艺术上推怀疑论，政治上几位总统候选人先锋开讲","content":"一年一度的法国阿维尼翁艺术节今天7月4日开幕。这是国际一年一度的法国阿维尼翁艺术节今天7月4日开幕。这是国际舞台艺术的一个重要展示窗口，世界各地的戏剧，舞蹈等演出团体到阿维尼翁展示他们的最新创作，欧洲，尤其是法国的剧院到阿维尼翁来挑他们下一季的商业演出剧目。对阿维尼翁当地来说，既是文化名片，又是旅游，饭店和餐饮等行业的引擎。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260704-%E6%B3%95%E5%9B%BD%E9%98%BF%E7%BB%B4%E5%B0%BC%E7%BF%81%E8%89%BA%E6%9C%AF%E8%8A%82-%E8%89%BA%E6%9C%AF%E4%B8%8A%E6%8E%A8%E6%80%80%E7%96%91%E8%AE%BA%EF%BC%8C%E6%94%BF%E6%B2%BB%E4%B8%8A%E5%87%A0%E4%BD%8D%E6%80%BB%E7%BB%9F%E5%80%99%E9%80%89%E4%BA%BA%E5%85%88%E9%94%8B%E5%BC%80%E8%AE%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783155182000.webp","sourceId":"rfi"},{"id":1783154074000,"createdDate":"2026-07-04 08:34","name":"法国国际广播电台","title":"秘鲁诞生第二代日裔总统 日本媒体热烈报道","content":"南美洲秘鲁选举管理机构3日正式宣布，在6月7日举行的总统选举第二轮投票中，已故前总统阿尔韦托·藤森的长女、右翼候选人藤森庆子（51岁）获胜。藤森庆子为日裔第三代，她在第四次参选后终于赢得总统宝座，并将于本月28日就职。藤森一家与日本渊源很深，尤其是阿尔韦托·藤森解决1996年12月发生的“秘鲁日本大使公邸占拠事件”的行动在日本家喻户晓，因此日本媒体对藤森原总统的女儿当选新一任总统尤为关注。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260704-%E7%A7%98%E9%B2%81%E8%AF%9E%E7%94%9F%E7%AC%AC%E4%BA%8C%E4%BB%A3%E6%97%A5%E8%A3%94%E6%80%BB%E7%BB%9F-%E6%97%A5%E6%9C%AC%E5%AA%92%E4%BD%93%E7%83%AD%E7%83%88%E6%8A%A5%E9%81%93","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783154074000.webp","sourceId":"rfi"},{"id":1783149284000,"createdDate":"2026-07-04 07:14","name":"法国国际广播电台","title":"2026年世界杯：阿根廷苦战惊险晋级16强，佛得角虽败犹荣“书写传奇”","content":"在2026年世界杯32强赛的一场焦点战中，卫冕冠军阿根廷队遭遇了意想不到的顽强阻击。面对此前被视为“鱼腩”的佛得角队，阿根廷队在鏖战至加时赛后，才最终以3-2艰难取胜，惊险晋级16强。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260704-2026%E5%B9%B4%E4%B8%96%E7%95%8C%E6%9D%AF-%E9%98%BF%E6%A0%B9%E5%BB%B7%E8%8B%A6%E6%88%98%E6%83%8A%E9%99%A9%E6%99%8B%E7%BA%A716%E5%BC%BA%EF%BC%8C%E4%BD%9B%E5%BE%97%E8%A7%92%E8%99%BD%E8%B4%A5%E7%8A%B9%E8%8D%A3-%E4%B9%A6%E5%86%99%E4%BC%A0%E5%A5%87","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783149284000.webp","sourceId":"rfi"},{"id":1783182694000,"createdDate":"2026-07-04 16:31","name":"法国国际广播电台","title":"乌克兰军队否认其一座关键城市失守","content":"乌克兰军队周六否认了莫斯科周五宣称占领乌克兰城市科斯蒂安蒂尼夫卡的声明。该市目前是前线战斗的焦点。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260704-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%86%9B%E9%98%9F%E5%90%A6%E8%AE%A4%E5%85%B6%E4%B8%80%E5%BA%A7%E5%85%B3%E9%94%AE%E5%9F%8E%E5%B8%82%E5%A4%B1%E5%AE%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783182694000.webp","sourceId":"rfi"},{"id":1783182035000,"createdDate":"2026-07-04 16:20","name":"法国国际广播电台","title":"乌克兰对圣彼得堡石油终端和海军基地发动袭击","content":"周五至周六夜间，乌克兰对俄罗斯发动了大规模无人机和导弹袭击，圣彼得堡地区首当其冲。莫斯科方面承诺将对这些袭击进行反击，此前几天，基辅刚刚遭遇了致命空袭。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260704-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%AF%B9%E5%9C%A3%E5%BD%BC%E5%BE%97%E5%A0%A1%E7%9F%B3%E6%B2%B9%E7%BB%88%E7%AB%AF%E5%92%8C%E6%B5%B7%E5%86%9B%E5%9F%BA%E5%9C%B0%E5%8F%91%E5%8A%A8%E8%A2%AD%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783182035000.webp","sourceId":"rfi"},{"id":1783178320000,"createdDate":"2026-07-04 15:18","name":"法国国际广播电台","title":"尽管国际反对 中国在台湾以东海域再启动海警“执法”巡逻","content":"路透社北京/台北电：中国周六表示，已在台湾东部海域启动了一项新的海警巡逻行动。上个月，一支中国特遣队在台湾近海的活动曾引发部分西方国家首都担忧，并随即招致台北方面的强烈反应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260704-%E5%B0%BD%E7%AE%A1%E5%9B%BD%E9%99%85%E5%8F%8D%E5%AF%B9-%E4%B8%AD%E5%9B%BD%E5%9C%A8%E5%8F%B0%E6%B9%BE%E4%BB%A5%E4%B8%9C%E6%B5%B7%E5%9F%9F%E5%86%8D%E5%90%AF%E5%8A%A8%E6%B5%B7%E8%AD%A6-%E6%89%A7%E6%B3%95-%E5%B7%A1%E9%80%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783178320000.webp","sourceId":"rfi"},{"id":1783176865000,"createdDate":"2026-07-04 14:54","name":"法国国际广播电台","title":"美国建国250周年：隆重庆典难掩建国初心与当今现实的差距","content":"7月4日是美国独立日。2026年恰逢美国建国250周年，今年的庆典活动自然不同寻常。而总统特朗普想借此次庆典凸显他“要让美国再次”伟大的口号的决心更让这次庆典极尽隆重。只是这些隆重的表象难以掩饰这个世界第一大强国感到的危机。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260704-%E7%BE%8E%E5%9B%BD%E5%BB%BA%E5%9B%BD250%E5%91%A8%E5%B9%B4-%E9%9A%86%E9%87%8D%E5%BA%86%E5%85%B8%E9%9A%BE%E6%8E%A9%E7%90%86%E6%83%B3%E4%B8%8E%E7%8E%B0%E5%AE%9E%E7%9A%84%E5%B7%AE%E8%B7%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783176865000.webp","sourceId":"rfi"},{"id":1783172311000,"createdDate":"2026-07-04 13:38","name":"法国国际广播电台","title":"美国独立250周年 特朗普警告国家面临共产主义威胁","content":"据法新社介绍，周五晚在250周年独立庆典前夕，特朗普在标志性的拉什莫尔总统山脚下发表讲话称，美国的国家认同正在本土遭受来自“激进分子和极端分子”的“新一轮攻势”。随后他警告称，“共产主义威胁正卷土重来威胁美国。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260704-%E7%BE%8E%E5%9B%BD%E7%8B%AC%E7%AB%8B250%E5%91%A8%E5%B9%B4-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AD%A6%E5%91%8A%E5%9B%BD%E5%AE%B6%E9%9D%A2%E4%B8%B4%E5%85%B1%E4%BA%A7%E4%B8%BB%E4%B9%89%E5%A8%81%E8%83%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783172311000.webp","sourceId":"rfi"},{"id":1783168207000,"createdDate":"2026-07-04 12:30","name":"法国国际广播电台","title":"教皇良十四在兰佩杜萨岛呼吁欧洲采取更多行动保护逃难移民","content":"天主教教皇良十四世4日上午抵达意大利南部小岛兰佩杜萨，向冒险渡海逃难的遇难者致敬，向那些为最无助者提供帮助的人表达感谢，呼吁欧洲采取更多行动，保护被迫逃离家乡者。他日前也特别提醒他自己的母国美国不要忘记自己的移民国家历史。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260704-%E6%95%99%E7%9A%87%E8%89%AF%E5%8D%81%E5%9B%9B%E5%9C%A8%E5%85%B0%E4%BD%A9%E6%9D%9C%E8%90%A8%E5%B2%9B%E5%91%BC%E5%90%81%E6%AC%A7%E6%B4%B2%E9%87%87%E5%8F%96%E6%9B%B4%E5%A4%9A%E8%A1%8C%E5%8A%A8%E4%BF%9D%E6%8A%A4%E9%80%83%E9%9A%BE%E7%A7%BB%E6%B0%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783168207000.webp","sourceId":"rfi"},{"id":1783166494000,"createdDate":"2026-07-04 12:01","name":"法国国际广播电台","title":"德黑兰开启哈梅内伊公开悼念活动 数千伊朗民众涌向葬礼现场","content":"伊朗前最高领袖阿里·哈梅内伊的国葬仪式于周六在德黑兰一座庞大的宗教建筑群内正式开始，数以千计的伊朗人涌向这里参加这场仪式，该仪式在以色列和美国发动战争后，呈现出一场力量展示的态势。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260704-%E8%B6%8A%E5%8D%97%E7%AC%AC%E4%BA%8C%E5%AD%A3%E5%BA%A6%E5%A2%9E%E9%95%BF8-39-%E4%B8%8A%E5%8D%8A%E5%B9%B4%E5%A4%96%E5%9B%BD%E6%8A%95%E8%B5%84%E9%A3%99%E5%8D%8761","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783166494000.webp","sourceId":"rfi"},{"id":1783162144000,"createdDate":"2026-07-04 10:49","name":"法国国际广播电台","title":"回声报：汽车到鹅肝，中国无所不食","content":"今天7月4日是美国独立250周年纪念日，成为周六当天法国各大日报头版的评论焦点。《费加罗报》的社论指出，这场本应团结这个分裂国家的纪念活动，却被现任总统特朗普打造成了一场彰显个人荣耀的庆典。历史上历任总统都将美国视为“自由世界的灯塔”，直到特朗普的出现才发生了转变，美国开国元勋的精神遗产，对他而言更像是一种自我目的或个人追求，而非为国家利益而战的使命。此外，《回声报》登出资深编辑勒布舍的评论文章称，从汽车到鹅肝，中国的胃口正在吞噬一切！","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260704-%E5%9B%9E%E5%A3%B0%E6%8A%A5-%E6%B1%BD%E8%BD%A6%E5%88%B0%E9%B9%85%E8%82%9D%EF%BC%8C%E4%B8%AD%E5%9B%BD%E6%97%A0%E6%89%80%E4%B8%8D%E9%A3%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783162144000.webp","sourceId":"rfi"},{"id":1783208567000,"createdDate":"2026-07-04 23:42","name":"法国国际广播电台","title":"法国1比0巴拉圭 摩洛哥横扫加拿大","content":"世界杯1/8决赛周六拉开帷幕。摩洛哥与加拿大率先在休斯顿展开对决，摩洛哥以3比0横扫加拿大。随后法国队与巴拉圭队展开激战，法国队幸获罚点球，1比0胜出。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260704-%E6%B3%95%E5%9B%BD1%E6%AF%940%E5%B7%B4%E6%8B%89%E5%9C%AD-%E6%91%A9%E6%B4%9B%E5%93%A5%E6%A8%AA%E6%89%AB%E5%8A%A0%E6%8B%BF%E5%A4%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783208567000.webp","sourceId":"rfi"},{"id":1783204133000,"createdDate":"2026-07-04 22:28","name":"法国国际广播电台","title":"中方否认贸易失衡责任及援俄指控　丹麦外长呼吁欧盟协调对华政策","content":"正在北欧四国访问的中国外长王毅，2日与丹麦外交大臣拉斯穆森举行会谈，会后拉斯穆森接受丹麦政治报专访表示，会谈中曾提及中欧贸易严重失衡与在俄乌战争支持俄罗斯的议题，中方否认其责任，拉斯穆森呼吁欧盟27国必须团结一致，才能具备与中国对话的条件。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260704-%E4%B8%AD%E6%96%B9%E5%90%A6%E8%AE%A4%E8%B4%B8%E6%98%93%E5%A4%B1%E8%A1%A1%E8%B4%A3%E4%BB%BB%E5%8F%8A%E6%8F%B4%E4%BF%84%E6%8C%87%E6%8E%A7-%E4%B8%B9%E9%BA%A6%E5%A4%96%E9%95%BF%E5%91%BC%E5%90%81%E6%AC%A7%E7%9B%9F%E5%8D%8F%E8%B0%83%E5%AF%B9%E5%8D%8E%E6%94%BF%E7%AD%96","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783204133000.webp","sourceId":"rfi"},{"id":1783202018000,"createdDate":"2026-07-04 21:53","name":"法国国际广播电台","title":"教皇呼吁欧洲加强保护移民 地中海偷渡死亡人数持续攀升","content":"在欧洲持续收紧移民政策之际，教皇利奥十四世周六（7月4日）访问意大利南部兰佩杜萨岛，呼吁欧洲采取更多行动保护移民。这座位于地中海的小岛长期处于欧洲移民危机前沿，已成为偷渡者命丧地中海的象征。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260704-%E6%95%99%E7%9A%87%E5%91%BC%E5%90%81%E6%AC%A7%E6%B4%B2%E5%8A%A0%E5%BC%BA%E4%BF%9D%E6%8A%A4%E7%A7%BB%E6%B0%91-%E5%9C%B0%E4%B8%AD%E6%B5%B7%E5%81%B7%E6%B8%A1%E6%AD%BB%E4%BA%A1%E4%BA%BA%E6%95%B0%E6%8C%81%E7%BB%AD%E6%94%80%E5%8D%87","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783202018000.webp","sourceId":"rfi"},{"id":1783201862000,"createdDate":"2026-07-04 21:51","name":"法国国际广播电台","title":"法国能源巨头呼吁欧洲与中国合作推进能源转型","content":"法国电力集团（EDF）首席执行官贝尔纳·丰塔纳和法国道达尔能源集团（TotalEnergies）首席执行官帕特里克·普亚内周六（7月4日）在普罗旺斯地区艾克斯经济论坛上表示，在推动低碳电气化转型的过程中，欧洲应与中国工业界加强合作，而不是采取封闭策略。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260704-%E6%B3%95%E5%9B%BD%E8%83%BD%E6%BA%90%E5%B7%A8%E5%A4%B4%E5%91%BC%E5%90%81%E6%AC%A7%E6%B4%B2%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%90%88%E4%BD%9C%E6%8E%A8%E8%BF%9B%E8%83%BD%E6%BA%90%E8%BD%AC%E5%9E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783201862000.webp","sourceId":"rfi"},{"id":1783201432000,"createdDate":"2026-07-04 21:43","name":"法国国际广播电台","title":"特朗普高调主导美国建国250周年庆典 国庆活动政治化引争议","content":"美国总统特朗普周六（7月4日）将在首都华盛顿国家广场举行一场带有竞选造势色彩的大型集会，纪念美国建国250周年，为持续数周的庆祝活动画上句号。这场庆典被指过度政治化、加剧社会分裂而持续引发争议。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260704-%E7%89%B9%E6%9C%97%E6%99%AE%E9%AB%98%E8%B0%83%E4%B8%BB%E5%AF%BC%E7%BE%8E%E5%9B%BD%E5%BB%BA%E5%9B%BD250%E5%91%A8%E5%B9%B4%E5%BA%86%E5%85%B8-%E5%9B%BD%E5%BA%86%E6%B4%BB%E5%8A%A8%E6%94%BF%E6%B2%BB%E5%8C%96%E5%BC%95%E4%BA%89%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783201432000.webp","sourceId":"rfi"},{"id":1783193993000,"createdDate":"2026-07-04 19:39","name":"法国国际广播电台","title":"加蓬寻求长久解决供水紧张方案","content":"濒临大西洋的西非国家加蓬由于缺水，现已被迫宣布全国进入[水力紧急状态]（l’étatd’urgencehydrique）。本台法广非洲组（RFIAfrique）法语通讯员发回消息说，为满足民生用水之需，已调动军队用于供水的利伯维尔（Libreville）当局寻求一个可长久解决全国供水紧张的方案。当地民众目前可使用深水井应急。加蓬的中文国名，也有译作加彭（leGabon）。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260704-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%8A%A0%E8%93%AC%E5%AF%BB%E6%B1%82%E9%95%BF%E4%B9%85%E8%A7%A3%E5%86%B3%E4%BE%9B%E6%B0%B4%E7%B4%A7%E5%BC%A0%E6%96%B9%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783193993000.webp","sourceId":"rfi"},{"id":1783192255000,"createdDate":"2026-07-04 19:10","name":"法国国际广播电台","title":"联合国暂停在中非部分人道行动","content":"在位于非洲中部的内陆地区，由于安全局势不稳定，联合国人道主义事务协调厅（ONU-OCHA/BCAH）暂时停止了在中非共和国（RCA-Républiquecentrafricaine）东南部上姆博穆省（Haut-Mbomou）的救援行动。本台法广非洲组（RFIAfrique）法语通讯员从该国首都发回消息说，相关地区安全局势恶化，从事人道主义的工作者们遭受暴力和攻击。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260704-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E8%81%94%E5%90%88%E5%9B%BD%E6%9A%82%E5%81%9C%E5%9C%A8%E4%B8%AD%E9%9D%9E%E9%83%A8%E5%88%86%E4%BA%BA%E9%81%93%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783192255000.webp","sourceId":"rfi"},{"id":1783190261000,"createdDate":"2026-07-04 18:37","name":"法国国际广播电台","title":"美国代理国家情报总监解雇数十名情报官员","content":"美国媒体MSNOW周五报导，美国总统特朗普（DonaldTrump）政府持续调整情报体系人事。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260704-%E7%BE%8E%E5%9B%BD%E4%BB%A3%E7%90%86%E5%9B%BD%E5%AE%B6%E6%83%85%E6%8A%A5%E6%80%BB%E7%9B%91%E8%A7%A3%E9%9B%87%E6%95%B0%E5%8D%81%E5%90%8D%E6%83%85%E6%8A%A5%E5%AE%98%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783190261000.webp","sourceId":"rfi"},{"id":1783187688000,"createdDate":"2026-07-04 17:54","name":"法国国际广播电台","title":"马里多个地方及一所监狱再遭协同袭击","content":"周六，马里再次遭到圣战分子及其盟友图阿雷格族独立主义武装在全国范围内发动的大规模协同袭击，而就在几周前，反政府武装曾发起一场大规模攻势，期间占领了战略要地基达尔市，并导致国防部长被炸身亡。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260704-%E9%A9%AC%E9%87%8C%E5%A4%9A%E5%9C%B0%E5%8F%8A%E4%B8%80%E6%89%80%E7%9B%91%E7%8B%B1%E5%86%8D%E9%81%AD%E5%8D%8F%E5%90%8C%E8%A2%AD%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/04/1783187688000.webp","sourceId":"rfi"}]