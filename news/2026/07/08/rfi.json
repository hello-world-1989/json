[{"id":1783469247000,"createdDate":"2026-07-08 00:07","name":"法国国际广播电台","title":"中国试射战略导弹：具有明显的战略和政治含义","content":"法国世界报周二发表文章，关注中国试射弹道导弹。7月6日星期一，中国从一艘核潜艇向太平洋发射了一枚装载惰性弹头的战略导弹。该怎么看中国此次试射弹道导弹呢？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260708-%E4%B8%AD%E5%9B%BD%E8%AF%95%E5%B0%84%E6%88%98%E7%95%A5%E5%AF%BC%E5%BC%B9-%E5%85%B7%E6%9C%89%E6%98%8E%E6%98%BE%E7%9A%84%E6%88%98%E7%95%A5%E5%92%8C%E6%94%BF%E6%B2%BB%E5%90%AB%E4%B9%89","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783469247000.webp","sourceId":"rfi"},{"id":1783505081000,"createdDate":"2026-07-08 10:04","name":"法国国际广播电台","title":"特朗普：在我看来，与伊朗签署的谅解备忘录已结束，他们想除掉我","content":"美国总统特朗普（DonaldTrump）周三声称，在他看来，与伊朗签署的结束冲突的谅解备忘录已经“结束”，并指不想与德黑兰方面接触，称伊朗领导层是“病态的人”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260708-%E7%89%B9%E6%9C%97%E6%99%AE-%E5%9C%A8%E6%88%91%E7%9C%8B%E6%9D%A5%EF%BC%8C%E4%B8%8E%E4%BC%8A%E6%9C%97%E7%AD%BE%E7%BD%B2%E7%9A%84%E8%B0%85%E8%A7%A3%E5%A4%87%E5%BF%98%E5%BD%95%E5%B7%B2%E7%BB%93%E6%9D%9F%EF%BC%8C%E4%BB%96%E4%BB%AC%E6%83%B3%E9%99%A4%E6%8E%89%E6%88%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783505081000.webp","sourceId":"rfi"},{"id":1783503465000,"createdDate":"2026-07-08 09:37","name":"法国国际广播电台","title":"澳总理：太平洋岛国论坛将就中方导弹试射发表非常强有力声明 菲律宾亦表关切","content":"太平洋岛国图瓦卢周三对中国试射一枚洲际弹道导弹并使其落入该国附近海域一事，表达了“深切而严重的关切”。中国一艘潜艇周一试射了一枚携带模拟弹头的“战略”导弹；据监测显示，该导弹似乎落在了所罗门群岛、瑙鲁和图瓦卢之间的海域。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260708-%E6%BE%B3%E6%80%BB%E7%90%86-%E5%A4%AA%E5%B9%B3%E6%B4%8B%E5%B2%9B%E5%9B%BD%E8%AE%BA%E5%9D%9B%E5%B0%86%E5%B0%B1%E4%B8%AD%E6%96%B9%E5%AF%BC%E5%BC%B9%E8%AF%95%E5%B0%84%E5%8F%91%E8%A1%A8%E9%9D%9E%E5%B8%B8%E5%BC%BA%E6%9C%89%E5%8A%9B%E5%A3%B0%E6%98%8E-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E4%BA%A6%E8%A1%A8%E5%85%B3%E5%88%87","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783503465000.webp","sourceId":"rfi"},{"id":1783502698000,"createdDate":"2026-07-08 09:24","name":"法国国际广播电台","title":"中国多地遭遇暴雨台风等极端天象 已知近40人遇难","content":"广西，湖北和甘肃等多地最近几天频繁遭受极端气候带来的袭击，已知造成近四十人遇难。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260708-%E4%B8%AD%E5%9B%BD%E5%A4%9A%E5%9C%B0%E9%81%AD%E9%81%87%E6%9A%B4%E9%9B%A8%E5%8F%B0%E9%A3%8E%E7%AD%89%E6%9E%81%E7%AB%AF%E5%A4%A9%E8%B1%A1-%E5%B7%B2%E7%9F%A5%E8%BF%9140%E4%BA%BA%E9%81%87%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783502698000.webp","sourceId":"rfi"},{"id":1783501002000,"createdDate":"2026-07-08 08:56","name":"法国国际广播电台","title":"梅西传射救赛 阿根廷三球逆转埃及晋级八强","content":"世界杯卫冕冠军阿根廷在16强淘汰赛上演惊天逆转，面对首次闯入16强的非洲黑马埃及队，阿根廷一度两球落后、濒临出局，但在比赛最后11分钟连入三球，以3比2完成史诗级翻盘，成功晋级八强。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260708-%E6%A2%85%E8%A5%BF%E4%BC%A0%E5%B0%84%E6%95%91%E8%B5%9B-%E9%98%BF%E6%A0%B9%E5%BB%B7%E4%B8%89%E7%90%83%E9%80%86%E8%BD%AC%E5%9F%83%E5%8F%8A%E6%99%8B%E7%BA%A7%E5%85%AB%E5%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783501002000.webp","sourceId":"rfi"},{"id":1783500068000,"createdDate":"2026-07-08 08:41","name":"法国国际广播电台","title":"美联邦通信委员会将一家有中国背景的加州IT公司列国安威胁名单","content":"美国联邦通信委员会（FCC）周二宣布，将总部位于加州的华高科技（DigitalsystemTechnology）列入对美国国家安全构成风险的公司名单，理由是该公司与中国电信企业存在关联，且由中国公民拥有。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260708-%E7%BE%8E%E8%81%94%E9%82%A6%E9%80%9A%E4%BF%A1%E5%A7%94%E5%91%98%E4%BC%9A%E5%B0%86%E4%B8%80%E5%AE%B6%E6%9C%89%E4%B8%AD%E5%9B%BD%E8%83%8C%E6%99%AF%E7%9A%84%E5%8A%A0%E5%B7%9Eit%E5%85%AC%E5%8F%B8%E5%88%97%E5%9B%BD%E5%AE%89%E5%A8%81%E8%83%81%E5%90%8D%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783500068000.webp","sourceId":"rfi"},{"id":1783497785000,"createdDate":"2026-07-08 08:03","name":"法国国际广播电台","title":"2026中国影响力网络年会:「韧性」是当今民主国家应对中国威胁的关键策略","content":"2026中国影响力网络年会于7日和8日在台举办，研讨会旨在探讨中国对全球影响力的最新趋势，并试图提出中国威权扩张因应对策。对此，学者表示，全面性韧性是建立有效且可信吓阻能力的关键。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260708-2026%E4%B8%AD%E5%9B%BD%E5%BD%B1%E5%93%8D%E5%8A%9B%E7%BD%91%E7%BB%9C%E5%B9%B4%E4%BC%9A-%E9%9F%A7%E6%80%A7-%E6%98%AF%E5%BD%93%E4%BB%8A%E6%B0%91%E4%B8%BB%E5%9B%BD%E5%AE%B6%E5%BA%94%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%A8%81%E8%83%81%E7%9A%84%E5%85%B3%E9%94%AE%E7%AD%96%E7%95%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783497785000.webp","sourceId":"rfi"},{"id":1783497345000,"createdDate":"2026-07-08 07:55","name":"法国国际广播电台","title":"日美韩三国外长会谈 对中国发射洲际导弹同感担忧","content":"在土耳其安卡拉举行的北大西洋公约组织（NATO）首脑会议期间，7日举行了相关会谈。与会各方还就朝鲜的核与导弹计划，以及中国军方于6日向太平洋海域从核潜艇发射弹道导弹一事进行了讨论。正在访问土耳其的茂木外务大臣，于日本时间8日凌晨与美国国务卿鲁比奥以及韩国外交部长赵显举行了会谈。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260708-%E6%97%A5%E7%BE%8E%E9%9F%A9%E4%B8%89%E5%9B%BD%E5%A4%96%E9%95%BF%E4%BC%9A%E8%B0%88-%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%8F%91%E5%B0%84%E6%B4%B2%E9%99%85%E5%AF%BC%E5%BC%B9%E5%90%8C%E6%84%9F%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783497345000.webp","sourceId":"rfi"},{"id":1783495558000,"createdDate":"2026-07-08 07:25","name":"法国国际广播电台","title":"韩国的舞蹈语言尝试将年轻人的生活符号和环保思考结合起来","content":"韩语是第80届阿维尼翁戏剧节的特邀语言。昨天晚上，韩国编舞家SungImHer用一部取名为“1摄氏度”的舞蹈，尝试让人们通过韩国舞蹈的语言了解韩国社会的部分追求：生态保护。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260708-%E9%9F%A9%E5%9B%BD%E7%9A%84%E8%88%9E%E8%B9%88%E8%AF%AD%E8%A8%80%E5%B0%9D%E8%AF%95%E5%B0%86%E5%B9%B4%E8%BD%BB%E4%BA%BA%E7%9A%84%E7%94%9F%E6%B4%BB%E7%AC%A6%E5%8F%B7%E5%92%8C%E7%8E%AF%E4%BF%9D%E6%80%9D%E8%80%83%E7%BB%93%E5%90%88%E8%B5%B7%E6%9D%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783495558000.webp","sourceId":"rfi"},{"id":1783490517000,"createdDate":"2026-07-08 06:01","name":"法国国际广播电台","title":"藉激活投资融资推人民币国际化 资金南下香港额度大增至8000亿","content":"继正式在香港试运黄金中央结算系统後，北京政府同时在港推出多项加速人民币国际化的措施，包括让大陆资金南下香港投资的债券通「南向通」年度投资额度大增六成至8000亿元人民币(下同，折合约1031亿欧元），另又把人民币业务资金安排总额度倍增至5000亿元，使推动人民币国际化的范围由贸易推广至投资和融资等方面。北京官员指出，相关措施可吸引更多主权机构和国际企业来港发债融资，令香港发展为区内具主导地位的融资枢纽。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260708-%E8%97%89%E6%BF%80%E6%B4%BB%E6%8A%95%E8%B5%84%E8%9E%8D%E8%B5%84%E6%8E%A8%E4%BA%BA%E6%B0%91%E5%B8%81%E5%9B%BD%E9%99%85%E5%8C%96-%E8%B5%84%E9%87%91%E5%8D%97%E4%B8%8B%E9%A6%99%E6%B8%AF%E9%A2%9D%E5%BA%A6%E5%A4%A7%E5%A2%9E%E8%87%B38000%E4%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783490517000.webp","sourceId":"rfi"},{"id":1783490273000,"createdDate":"2026-07-08 05:57","name":"法国国际广播电台","title":"充公黎智英近1.3亿元资产案 今早聆讯被取消","content":"壹传媒创办人黎智英在被裁定串谋勾结外国势力等罪名成立後遭港府引用国安法律申请充公其财产，涉及金额至少1.27亿港元(下同，折合约1400万欧元)，原定排期今(8日)早进行聆讯，但突然取消。负责检控的律政司回覆传媒时表示，会另订聆讯日期。这意味充公行动将会继续。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260708-%E5%85%85%E5%85%AC%E9%BB%8E%E6%99%BA%E8%8B%B1%E8%BF%911-3%E4%BA%BF%E5%85%83%E8%B5%84%E4%BA%A7%E6%A1%88-%E4%BB%8A%E6%97%A9%E8%81%86%E8%AE%AF%E8%A2%AB%E5%8F%96%E6%B6%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783490273000.webp","sourceId":"rfi"}]