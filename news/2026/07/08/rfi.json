[{"id":1783469247000,"createdDate":"2026-07-08 00:07","name":"法国国际广播电台","title":"中国试射战略导弹：具有明显的战略和政治含义","content":"法国世界报周二发表文章，关注中国试射弹道导弹。7月6日星期一，中国从一艘核潜艇向太平洋发射了一枚装载惰性弹头的战略导弹。该怎么看中国此次试射弹道导弹呢？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260708-%E4%B8%AD%E5%9B%BD%E8%AF%95%E5%B0%84%E6%88%98%E7%95%A5%E5%AF%BC%E5%BC%B9-%E5%85%B7%E6%9C%89%E6%98%8E%E6%98%BE%E7%9A%84%E6%88%98%E7%95%A5%E5%92%8C%E6%94%BF%E6%B2%BB%E5%90%AB%E4%B9%89","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783469247000.webp","sourceId":"rfi"},{"id":1783505081000,"createdDate":"2026-07-08 10:04","name":"法国国际广播电台","title":"特朗普：在我看来，与伊朗签署的谅解备忘录已结束，他们想除掉我","content":"美国总统特朗普（DonaldTrump）周三声称，在他看来，与伊朗签署的结束冲突的谅解备忘录已经“结束”，并指不想与德黑兰方面接触，称伊朗领导层是“病态的人”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260708-%E7%89%B9%E6%9C%97%E6%99%AE-%E5%9C%A8%E6%88%91%E7%9C%8B%E6%9D%A5%EF%BC%8C%E4%B8%8E%E4%BC%8A%E6%9C%97%E7%AD%BE%E7%BD%B2%E7%9A%84%E8%B0%85%E8%A7%A3%E5%A4%87%E5%BF%98%E5%BD%95%E5%B7%B2%E7%BB%93%E6%9D%9F%EF%BC%8C%E4%BB%96%E4%BB%AC%E6%83%B3%E9%99%A4%E6%8E%89%E6%88%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783505081000.webp","sourceId":"rfi"},{"id":1783503465000,"createdDate":"2026-07-08 09:37","name":"法国国际广播电台","title":"澳总理：太平洋岛国论坛将就中方导弹试射发表非常强有力声明 菲律宾亦表关切","content":"太平洋岛国图瓦卢周三对中国试射一枚洲际弹道导弹并使其落入该国附近海域一事，表达了“深切而严重的关切”。中国一艘潜艇周一试射了一枚携带模拟弹头的“战略”导弹；据监测显示，该导弹似乎落在了所罗门群岛、瑙鲁和图瓦卢之间的海域。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260708-%E6%BE%B3%E6%80%BB%E7%90%86-%E5%A4%AA%E5%B9%B3%E6%B4%8B%E5%B2%9B%E5%9B%BD%E8%AE%BA%E5%9D%9B%E5%B0%86%E5%B0%B1%E4%B8%AD%E6%96%B9%E5%AF%BC%E5%BC%B9%E8%AF%95%E5%B0%84%E5%8F%91%E8%A1%A8%E9%9D%9E%E5%B8%B8%E5%BC%BA%E6%9C%89%E5%8A%9B%E5%A3%B0%E6%98%8E-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E4%BA%A6%E8%A1%A8%E5%85%B3%E5%88%87","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783503465000.webp","sourceId":"rfi"},{"id":1783502698000,"createdDate":"2026-07-08 09:24","name":"法国国际广播电台","title":"中国多地遭遇暴雨台风等极端天象 已知近40人遇难","content":"广西，湖北和甘肃等多地最近几天频繁遭受极端气候带来的袭击，已知造成近四十人遇难。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260708-%E4%B8%AD%E5%9B%BD%E5%A4%9A%E5%9C%B0%E9%81%AD%E9%81%87%E6%9A%B4%E9%9B%A8%E5%8F%B0%E9%A3%8E%E7%AD%89%E6%9E%81%E7%AB%AF%E5%A4%A9%E8%B1%A1-%E5%B7%B2%E7%9F%A5%E8%BF%9140%E4%BA%BA%E9%81%87%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783502698000.webp","sourceId":"rfi"},{"id":1783501002000,"createdDate":"2026-07-08 08:56","name":"法国国际广播电台","title":"梅西传射救赛 阿根廷三球逆转埃及晋级八强","content":"世界杯卫冕冠军阿根廷在16强淘汰赛上演惊天逆转，面对首次闯入16强的非洲黑马埃及队，阿根廷一度两球落后、濒临出局，但在比赛最后11分钟连入三球，以3比2完成史诗级翻盘，成功晋级八强。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260708-%E6%A2%85%E8%A5%BF%E4%BC%A0%E5%B0%84%E6%95%91%E8%B5%9B-%E9%98%BF%E6%A0%B9%E5%BB%B7%E4%B8%89%E7%90%83%E9%80%86%E8%BD%AC%E5%9F%83%E5%8F%8A%E6%99%8B%E7%BA%A7%E5%85%AB%E5%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783501002000.webp","sourceId":"rfi"},{"id":1783500068000,"createdDate":"2026-07-08 08:41","name":"法国国际广播电台","title":"美联邦通信委员会将一家有中国背景的加州IT公司列国安威胁名单","content":"美国联邦通信委员会（FCC）周二宣布，将总部位于加州的华高科技（DigitalsystemTechnology）列入对美国国家安全构成风险的公司名单，理由是该公司与中国电信企业存在关联，且由中国公民拥有。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260708-%E7%BE%8E%E8%81%94%E9%82%A6%E9%80%9A%E4%BF%A1%E5%A7%94%E5%91%98%E4%BC%9A%E5%B0%86%E4%B8%80%E5%AE%B6%E6%9C%89%E4%B8%AD%E5%9B%BD%E8%83%8C%E6%99%AF%E7%9A%84%E5%8A%A0%E5%B7%9Eit%E5%85%AC%E5%8F%B8%E5%88%97%E5%9B%BD%E5%AE%89%E5%A8%81%E8%83%81%E5%90%8D%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783500068000.webp","sourceId":"rfi"},{"id":1783497785000,"createdDate":"2026-07-08 08:03","name":"法国国际广播电台","title":"2026中国影响力网络年会:「韧性」是当今民主国家应对中国威胁的关键策略","content":"2026中国影响力网络年会于7日和8日在台举办，研讨会旨在探讨中国对全球影响力的最新趋势，并试图提出中国威权扩张因应对策。对此，学者表示，全面性韧性是建立有效且可信吓阻能力的关键。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260708-2026%E4%B8%AD%E5%9B%BD%E5%BD%B1%E5%93%8D%E5%8A%9B%E7%BD%91%E7%BB%9C%E5%B9%B4%E4%BC%9A-%E9%9F%A7%E6%80%A7-%E6%98%AF%E5%BD%93%E4%BB%8A%E6%B0%91%E4%B8%BB%E5%9B%BD%E5%AE%B6%E5%BA%94%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%A8%81%E8%83%81%E7%9A%84%E5%85%B3%E9%94%AE%E7%AD%96%E7%95%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783497785000.webp","sourceId":"rfi"},{"id":1783497345000,"createdDate":"2026-07-08 07:55","name":"法国国际广播电台","title":"日美韩三国外长会谈 对中国发射洲际导弹同感担忧","content":"在土耳其安卡拉举行的北大西洋公约组织（NATO）首脑会议期间，7日举行了相关会谈。与会各方还就朝鲜的核与导弹计划，以及中国军方于6日向太平洋海域从核潜艇发射弹道导弹一事进行了讨论。正在访问土耳其的茂木外务大臣，于日本时间8日凌晨与美国国务卿鲁比奥以及韩国外交部长赵显举行了会谈。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260708-%E6%97%A5%E7%BE%8E%E9%9F%A9%E4%B8%89%E5%9B%BD%E5%A4%96%E9%95%BF%E4%BC%9A%E8%B0%88-%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%8F%91%E5%B0%84%E6%B4%B2%E9%99%85%E5%AF%BC%E5%BC%B9%E5%90%8C%E6%84%9F%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783497345000.webp","sourceId":"rfi"},{"id":1783495558000,"createdDate":"2026-07-08 07:25","name":"法国国际广播电台","title":"韩国的舞蹈语言尝试将年轻人的生活符号和环保思考结合起来","content":"韩语是第80届阿维尼翁戏剧节的特邀语言。昨天晚上，韩国编舞家SungImHer用一部取名为“1摄氏度”的舞蹈，尝试让人们通过韩国舞蹈的语言了解韩国社会的部分追求：生态保护。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260708-%E9%9F%A9%E5%9B%BD%E7%9A%84%E8%88%9E%E8%B9%88%E8%AF%AD%E8%A8%80%E5%B0%9D%E8%AF%95%E5%B0%86%E5%B9%B4%E8%BD%BB%E4%BA%BA%E7%9A%84%E7%94%9F%E6%B4%BB%E7%AC%A6%E5%8F%B7%E5%92%8C%E7%8E%AF%E4%BF%9D%E6%80%9D%E8%80%83%E7%BB%93%E5%90%88%E8%B5%B7%E6%9D%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783495558000.webp","sourceId":"rfi"},{"id":1783490517000,"createdDate":"2026-07-08 06:01","name":"法国国际广播电台","title":"藉激活投资融资推人民币国际化 资金南下香港额度大增至8000亿","content":"继正式在香港试运黄金中央结算系统後，北京政府同时在港推出多项加速人民币国际化的措施，包括让大陆资金南下香港投资的债券通「南向通」年度投资额度大增六成至8000亿元人民币(下同，折合约1031亿欧元），另又把人民币业务资金安排总额度倍增至5000亿元，使推动人民币国际化的范围由贸易推广至投资和融资等方面。北京官员指出，相关措施可吸引更多主权机构和国际企业来港发债融资，令香港发展为区内具主导地位的融资枢纽。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260708-%E8%97%89%E6%BF%80%E6%B4%BB%E6%8A%95%E8%B5%84%E8%9E%8D%E8%B5%84%E6%8E%A8%E4%BA%BA%E6%B0%91%E5%B8%81%E5%9B%BD%E9%99%85%E5%8C%96-%E8%B5%84%E9%87%91%E5%8D%97%E4%B8%8B%E9%A6%99%E6%B8%AF%E9%A2%9D%E5%BA%A6%E5%A4%A7%E5%A2%9E%E8%87%B38000%E4%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783490517000.webp","sourceId":"rfi"},{"id":1783490273000,"createdDate":"2026-07-08 05:57","name":"法国国际广播电台","title":"充公黎智英近1.3亿元资产案 今早聆讯被取消","content":"壹传媒创办人黎智英在被裁定串谋勾结外国势力等罪名成立後遭港府引用国安法律申请充公其财产，涉及金额至少1.27亿港元(下同，折合约1400万欧元)，原定排期今(8日)早进行聆讯，但突然取消。负责检控的律政司回覆传媒时表示，会另订聆讯日期。这意味充公行动将会继续。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260708-%E5%85%85%E5%85%AC%E9%BB%8E%E6%99%BA%E8%8B%B1%E8%BF%911-3%E4%BA%BF%E5%85%83%E8%B5%84%E4%BA%A7%E6%A1%88-%E4%BB%8A%E6%97%A9%E8%81%86%E8%AE%AF%E8%A2%AB%E5%8F%96%E6%B6%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783490273000.webp","sourceId":"rfi"},{"id":1783532400000,"createdDate":"2026-07-08 17:40","name":"法国国际广播电台","title":"特朗普：不乘坐卡塔尔赠送的新空军一号返回华盛顿","content":"美国总统特朗普周三宣布，他将不会乘坐卡塔尔赠送的波音747“空军一号”专机在北约峰会后返回华盛顿。他周二乘坐这架飞机抵达土耳其首都，之后将乘坐另一架“空军一号”离开。那架被外界广泛关注的波音747-8，由卡塔尔方面赠送，经美国军方全面改装。但因花费高昂、安全隐患以及法律问题，“赠机”一事始终争议不断。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260708-%E7%89%B9%E6%9C%97%E6%99%AE-%E4%B8%8D%E4%B9%98%E5%9D%90%E5%8D%A1%E5%A1%94%E5%B0%94%E8%B5%A0%E9%80%81%E7%9A%84%E6%96%B0%E7%A9%BA%E5%86%9B%E4%B8%80%E5%8F%B7%E8%BF%94%E5%9B%9E%E5%8D%8E%E7%9B%9B%E9%A1%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783532400000.webp","sourceId":"rfi"},{"id":1783527998000,"createdDate":"2026-07-08 16:26","name":"法国国际广播电台","title":"法对奥委会加速俄运动员重返国际赛场深表遗憾","content":"国际奥委会取消对俄罗斯运动员的参赛限制之后，法国对此表示深切遗憾。法国体育部长发表声明表示：“法国将继续致力于捍卫奥林匹克价值观，尊重国际法，声援乌克兰，并维护体育运动的完整性”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260708-%E6%B3%95%E5%AF%B9%E5%A5%A5%E5%A7%94%E4%BC%9A%E5%8A%A0%E9%80%9F%E4%BF%84%E8%BF%90%E5%8A%A8%E5%91%98%E9%87%8D%E8%BF%94%E5%9B%BD%E9%99%85%E8%B5%9B%E5%9C%BA%E6%B7%B1%E8%A1%A8%E9%81%97%E6%86%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783527998000.webp","sourceId":"rfi"},{"id":1783527067000,"createdDate":"2026-07-08 16:11","name":"法国国际广播电台","title":"广播艺评 ： 被青春欲滴的肢体勾勒的台湾痕迹","content":"象君舞蹈剧场“痕迹”这样的作品，没有外在的、添加的的意识形态上的豪言壮语，但却从台湾生活里来，到台湾生活中去，从台湾生活里来，到国际舞台上去，反反复复，从肢体到甜点，从水滴声到求神，都是寻常百姓的普普通通，台湾生活的点点滴滴。在浩浩荡荡的大意识形态、大口号、大标语“众里寻她千百度”的消耗里，他们却是在灯火阑珊处的那个人，那只舞，那个内在的台湾符号。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%96%87%E5%8C%96%E8%89%BA%E6%9C%AF/20260708-%E5%B9%BF%E6%92%AD%E8%89%BA%E8%AF%84-%E8%A2%AB%E9%9D%92%E6%98%A5%E6%AC%B2%E6%BB%B4%E7%9A%84%E8%82%A2%E4%BD%93%E5%8B%BE%E5%8B%92%E7%9A%84%E5%8F%B0%E6%B9%BE%E7%97%95%E8%BF%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783527067000.webp","sourceId":"rfi"},{"id":1783525303000,"createdDate":"2026-07-08 15:41","name":"法国国际广播电台","title":"俄罗斯宣布禁止柴油出口，7月开始进口石油产品","content":"俄罗斯官方7月8日公布消息称，为缓解国内燃料供应压力，俄罗斯政府当天正式实施柴油出口禁令，并同步推出一系列保障国内市场供应的措施。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260708-%E5%8F%97-%E6%81%90%E6%80%96%E6%B4%BB%E5%8A%A8-%E5%BD%B1%E5%93%8D%EF%BC%8C%E4%BF%84%E7%BD%97%E6%96%AF%E5%AE%A3%E5%B8%83%E7%A6%81%E6%AD%A2%E6%9F%B4%E6%B2%B9%E5%87%BA%E5%8F%A3%EF%BC%8C7%E6%9C%88%E5%BC%80%E5%A7%8B%E8%BF%9B%E5%8F%A3%E7%9F%B3%E6%B2%B9%E4%BA%A7%E5%93%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783525303000.webp","sourceId":"rfi"},{"id":1783522843000,"createdDate":"2026-07-08 15:00","name":"法国国际广播电台","title":"当德国终于开始认真再武装，法意波三国为何隐隐不安？","content":"各位好，本期出刊的法国世界报头版关注点如下：法国极右翼政党国民联盟领袖马琳·勒庞“挪用公款”官司审议结果出炉，由于司法程序与其参加2027年法国总统选举不冲突，她在宣判当天宣布参加法国大选；塞内加尔采纳了一则严格打击同性恋的法律，该国同性恋群体日常担心被抓捕；法国就业市场遭遇当头冷水；德国武装计划撕开了法国、意大利和波兰的旧日恐惧；英国选举之前，法拉奇丑闻缠身；受气候变化影响，法国大批房屋开裂等。本期节目中，我们为您选取国际版面的重要话题做综述。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260708-%E5%BD%93%E5%BE%B7%E5%9B%BD%E7%BB%88%E4%BA%8E%E5%BC%80%E5%A7%8B%E8%AE%A4%E7%9C%9F%E5%86%8D%E6%AD%A6%E8%A3%85%EF%BC%8C%E6%B3%95%E6%84%8F%E6%B3%A2%E4%B8%89%E5%9B%BD%E4%B8%BA%E4%BD%95%E9%9A%90%E9%9A%90%E4%B8%8D%E5%AE%89","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783522843000.webp","sourceId":"rfi"},{"id":1783520996000,"createdDate":"2026-07-08 14:29","name":"法国国际广播电台","title":"国台办发言人称袭击矢板明夫港人是义愤举动 陆委会指美化暴力","content":"就媒体人矢板明夫周一在台中被一名香港人袭击一事，中国国务院台办发言人陈斌华在周三的例行新闻发布会上应询时表示，“这名香港男子出于义愤做出相关举动，完全是偶然发生的普通治安类个案”。对此，陆委会则批评，对岸不谴责暴力犯罪，反而将“暴力”美化为“义愤”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260708-%E5%9B%BD%E5%8F%B0%E5%8A%9E%E5%8F%91%E8%A8%80%E4%BA%BA%E7%A7%B0%E8%A2%AD%E5%87%BB%E7%9F%A2%E6%9D%BF%E6%98%8E%E5%A4%AB%E6%B8%AF%E4%BA%BA%E6%98%AF%E4%B9%89%E6%84%A4%E4%B8%BE%E5%8A%A8-%E9%99%86%E5%A7%94%E4%BC%9A%E6%8C%87%E7%BE%8E%E5%8C%96%E6%9A%B4%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783520996000.webp","sourceId":"rfi"},{"id":1783519271000,"createdDate":"2026-07-08 14:01","name":"法国国际广播电台","title":"特朗普：将向乌克兰颁发生产“爱国者”导弹的许可","content":"美国总统特朗普（DonaldTrump）周三表示，美国将向乌克兰颁发生产“爱国者”导弹的许可证，他还称俄乌双方都希望看到这场战争得到解决。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260708-%E7%89%B9%E6%9C%97%E6%99%AE-%E5%B0%86%E5%90%91%E4%B9%8C%E5%85%8B%E5%85%B0%E9%A2%81%E5%8F%91%E7%94%9F%E4%BA%A7-%E7%88%B1%E5%9B%BD%E8%80%85-%E5%AF%BC%E5%BC%B9%E7%9A%84%E8%AE%B8%E5%8F%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783519271000.webp","sourceId":"rfi"},{"id":1783518197000,"createdDate":"2026-07-08 13:43","name":"法国国际广播电台","title":"美议员致函NBA奇才队老板 要求终止与上五角大楼清单的阿里巴巴商业关系","content":"华盛顿NBA和NHL球队的老板收到了一封来自美国众议院美国与中共战略竞争特设委员会主席穆勒纳尔（JohnMoolenaar）的信函，要求他切断与阿里巴巴的商业关系；这家中国科技巨头此前已提起诉讼，对五角大楼近期将其列入“中国军事公司”清单的认定提出异议。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260708-%E7%BE%8E%E8%AE%AE%E5%91%98%E8%87%B4%E5%87%BDnba%E5%A5%87%E6%89%8D%E9%98%9F%E8%80%81%E6%9D%BF-%E8%A6%81%E6%B1%82%E7%BB%88%E6%AD%A2%E4%B8%8E%E4%B8%8A%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC%E6%B8%85%E5%8D%95%E7%9A%84%E9%98%BF%E9%87%8C%E5%B7%B4%E5%B7%B4%E5%95%86%E4%B8%9A%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783518197000.webp","sourceId":"rfi"},{"id":1783515976000,"createdDate":"2026-07-08 13:06","name":"法国国际广播电台","title":"日防相：中朝对俄支持与欧洲对乌援助努力相抵，北约与印太四国合作更为必要","content":"出席了北约峰会相关会议的日本防卫大臣小泉进次郎周三凌晨在安卡拉希尔顿酒店举行的记者会上表示，“我指出，作为本次北约峰会最大议题的对乌克兰援助，正因中国和朝鲜对俄罗斯的支持而使欧洲的努力相抵；鉴于中国、俄罗斯和朝鲜这三个国家及地区协作，北约与印太四国（IP4）开展合作的必要性已达到前所未有的高度，就此达成了共识”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260708-%E6%97%A5%E9%98%B2%E7%9B%B8-%E6%AD%A3%E5%9B%A0%E4%B8%AD%E6%9C%9D%E5%AF%B9%E4%BF%84%E6%94%AF%E6%8C%81%E8%80%8C%E4%BD%BF%E6%AC%A7%E6%B4%B2%E7%9A%84%E5%AF%B9%E4%B9%8C%E6%8F%B4%E5%8A%A9%E5%8A%AA%E5%8A%9B%E7%9B%B8%E6%8A%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783515976000.webp","sourceId":"rfi"},{"id":1783515908000,"createdDate":"2026-07-08 13:05","name":"法国国际广播电台","title":"法国近百名科学家联名呼吁制定紧急气候法","content":"就在法国再度陷入新一轮高温酷暑之际，近一百名致力于应对气候变化的知名人士在法国《世界报》发表公开信，呼吁必须制定紧急气候法，以阻止化石燃料的扩张并尽快减少温室气体排放，声明指出，倘若化石燃料行业从业者继续一如既往，那么极端天气强度和频率就会继续增加。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260708-%E6%B3%95%E5%9B%BD%E8%BF%91%E7%99%BE%E5%90%8D%E7%A7%91%E5%AD%A6%E5%AE%B6%E8%81%94%E5%90%8D%E5%91%BC%E5%90%81%E5%88%B6%E5%AE%9A%E7%B4%A7%E6%80%A5%E6%B0%94%E5%80%99%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783515908000.webp","sourceId":"rfi"},{"id":1783510281000,"createdDate":"2026-07-08 11:31","name":"法国国际广播电台","title":"乌外长收到王毅发出的访华邀请：目前正商讨可能访问日期","content":"乌克兰外交部周二通过其“电报”频道发布消息称，乌克兰外交部长瑟比加（AndriiSybiha）收到了中国外交部长王毅发出的访华邀请。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260708-%E4%B9%8C%E5%A4%96%E9%95%BF%E6%94%B6%E5%88%B0%E7%8E%8B%E6%AF%85%E5%8F%91%E5%87%BA%E7%9A%84%E8%AE%BF%E5%8D%8E%E9%82%80%E8%AF%B7-%E7%9B%AE%E5%89%8D%E6%AD%A3%E5%95%86%E8%AE%A8%E5%8F%AF%E8%83%BD%E8%AE%BF%E9%97%AE%E6%97%A5%E6%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783510281000.webp","sourceId":"rfi"},{"id":1783508247000,"createdDate":"2026-07-08 10:57","name":"法国国际广播电台","title":"中法政坛风云诡变：蔡奇成习体制关键人物 勒庞表态角逐总统大位","content":"玛丽娜·勒庞宣布竞选总统，周二晚她在法国电视一台回应主持人提问时称，她将是2027法国总统大选的候选人，引发舆论高度关注並攻占周三法国各大日报（7月8日）的头版头条。相对于法国政坛这颗最新的震撼弹，《快报》周刊电子版国际亚太栏目登出由玛丽翁·普罗斯特执笔的文章解析，蔡奇目前为什么变成“习近平体制”的关键人物。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260708-%E4%B8%AD%E6%B3%95%E6%94%BF%E5%9D%9B%E9%A3%8E%E4%BA%91%E8%AF%A1%E5%8F%98-%E8%94%A1%E5%A5%87%E6%88%90%E4%B9%A0%E4%BD%93%E5%88%B6%E5%85%B3%E9%94%AE%E4%BA%BA%E7%89%A9-%E5%8B%92%E5%BA%9E%E8%A1%A8%E6%80%81%E8%A7%92%E9%80%90%E6%80%BB%E7%BB%9F%E5%A4%A7%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783508247000.webp","sourceId":"rfi"},{"id":1783507631000,"createdDate":"2026-07-08 10:47","name":"法国国际广播电台","title":"美议员调查美企日益广泛使用中国AI模型 美国务院：该情况引发严重关切","content":"随着围绕人工智能部署的地缘政治紧张局势加剧，美国立法者正在考虑如何遏制本土企业日益广泛地采用中国人工智能模型。人工智能已成为美中两国竞争的焦点，双方都在争夺该领域的主导地位。中国的人工智能模型正受到美国企业的青睐，因为它们在缩小与美国同类产品性能差距的同时，使用成本也更低。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260708-%E7%BE%8E%E8%AE%AE%E5%91%98%E8%B0%83%E6%9F%A5%E7%BE%8E%E4%BC%81%E6%97%A5%E7%9B%8A%E5%B9%BF%E6%B3%9B%E4%BD%BF%E7%94%A8%E4%B8%AD%E5%9B%BDai%E6%A8%A1%E5%9E%8B-%E7%BE%8E%E5%9B%BD%E5%8A%A1%E9%99%A2-%E8%AF%A5%E6%83%85%E5%86%B5%E5%BC%95%E5%8F%91%E4%B8%A5%E9%87%8D%E5%85%B3%E5%88%87","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783507631000.webp","sourceId":"rfi"},{"id":1783506971000,"createdDate":"2026-07-08 10:36","name":"法国国际广播电台","title":"台湾正打造无人机国家队，面对中国威胁台湾希望将无人机转化为战略优势","content":"从乌俄战争到美伊冲突，正在改写现代战争的型态，无人机已成为守护生命的关键，而面对中国时时威胁的台湾，无人机产业也因此变得无比重要。正处于无人机产业发展转折点的台湾，除了在嘉义成立的无人机国家队，在国际上还有哪些优势？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260708-%E5%8F%B0%E6%B9%BE%E6%AD%A3%E6%89%93%E9%80%A0%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%9B%BD%E5%AE%B6%E9%98%9F%EF%BC%8C%E9%9D%A2%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%A8%81%E8%83%81%E5%8F%B0%E6%B9%BE%E5%B8%8C%E6%9C%9B%E5%B0%86%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%BD%AC%E5%8C%96%E4%B8%BA%E6%88%98%E7%95%A5%E4%BC%98%E5%8A%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783506971000.webp","sourceId":"rfi"},{"id":1783544316000,"createdDate":"2026-07-08 20:58","name":"法国国际广播电台","title":"德国梅赛德斯-奔驰在中国市场销量大幅下滑","content":"据德国《商报》报道：德国豪华汽车生产商梅赛德斯-奔驰在中国市场的销量大幅下滑。尽管在美国和欧洲市场实现了增长，但这仍无法弥补在中国市场的下滑。不过，电动车型的发展让梅赛德斯-奔驰看到了希望。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260708-%E5%BE%B7%E5%9B%BD%E6%A2%85%E8%B5%9B%E5%BE%B7%E6%96%AF-%E5%A5%94%E9%A9%B0%E5%9C%A8%E4%B8%AD%E5%9B%BD%E5%B8%82%E5%9C%BA%E9%94%80%E9%87%8F%E5%A4%A7%E5%B9%85%E4%B8%8B%E6%BB%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783544316000.webp","sourceId":"rfi"},{"id":1783543887000,"createdDate":"2026-07-08 20:51","name":"法国国际广播电台","title":"民调：约30%的美国人认为以色列对巴勒斯坦犯下种族灭绝","content":"最新美联社（AP）与美国芝加哥大学全国民意研究中心（NORCCenterforPublicAffairsResearch）联合民调显示，过去数十年获得美国两党广泛支持的以色列，如今正面临美国民意快速转变。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260708-%E6%B0%91%E8%B0%83-%E7%BA%A630-%E7%9A%84%E7%BE%8E%E5%9B%BD%E4%BA%BA%E8%AE%A4%E4%B8%BA%E4%BB%A5%E8%89%B2%E5%88%97%E5%AF%B9%E5%B7%B4%E5%8B%92%E6%96%AF%E5%9D%A6%E7%8A%AF%E4%B8%8B%E7%A7%8D%E6%97%8F%E7%81%AD%E7%BB%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783543887000.webp","sourceId":"rfi"},{"id":1783543822000,"createdDate":"2026-07-08 20:50","name":"法国国际广播电台","title":"至少有6000名水手仍被困在霍尔木兹海峡","content":"国际海事组织（IMO）对特朗普终止与伊朗的停火协议后，数千名海员被困在海湾地区的船只上表示震惊。船员们已被无情地困在了这片海域上。负责海上安全的联合国机构——国际海事组织（IMO）周三估计，约有6000名海员仍然滞留在波斯湾。与此同时，该组织强烈谴责了该地区和霍尔木兹海峡再次爆发的冲突。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260708-%E8%87%B3%E5%B0%91%E6%9C%896000%E5%90%8D%E6%B0%B4%E6%89%8B%E4%BB%8D%E8%A2%AB%E5%9B%B0%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783543822000.webp","sourceId":"rfi"},{"id":1783543441000,"createdDate":"2026-07-08 20:44","name":"法国国际广播电台","title":"法国竞争监管机构向Meta发出警告","content":"法国竞争管理局（CompetitionAuthority）7月8日对社群巨头Meta祭出强制令，要求其在15天内提出付款计划，并与法国媒体团体重启谈判，以支付自2025年起积欠至今的新闻内容使用费。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260708-%E6%B3%95%E5%9B%BD%E7%AB%9E%E4%BA%89%E7%9B%91%E7%AE%A1%E6%9C%BA%E6%9E%84%E5%90%91meta%E5%8F%91%E5%87%BA%E8%AD%A6%E5%91%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783543441000.webp","sourceId":"rfi"},{"id":1783543377000,"createdDate":"2026-07-08 20:42","name":"法国国际广播电台","title":"特朗普希望美国留在北约 好向盟国卖武器","content":"美国总统特朗普在土耳其首都安卡拉举行的北约组织（NATO）领袖峰会闭门会议中，向北约盟国表示，他希望美国继续留在北约。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260708-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B8%8C%E6%9C%9B%E7%BE%8E%E5%9B%BD%E7%95%99%E5%9C%A8%E5%8C%97%E7%BA%A6-%E5%A5%BD%E5%90%91%E7%9B%9F%E5%9B%BD%E5%8D%96%E6%AD%A6%E5%99%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783543377000.webp","sourceId":"rfi"},{"id":1783543179000,"createdDate":"2026-07-08 20:39","name":"法国国际广播电台","title":"哈梅内伊灵柩跨境进入伊圣城纳杰夫","content":"伊朗于本月4日启动为期六天的送葬仪式。哈梅内伊的灵柩8日抵达邻国伊拉克圣城纳杰夫，完成当地送葬仪式后，预计将于明天（9日）返回伊朗圣城马什哈德安葬。纳加夫（Najaf）对全球什叶派穆斯林具有特殊意义，因为此地是先知穆罕默德（ProphetMohammad）的堂弟及女婿阿里（ImamAli）的长眠之地。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260708-%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E7%81%B5%E6%9F%A9%E8%B7%A8%E5%A2%83%E8%BF%9B%E5%85%A5%E4%BC%8A%E5%9C%A3%E5%9F%8E%E7%BA%B3%E6%9D%B0%E5%A4%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783543179000.webp","sourceId":"rfi"},{"id":1783543007000,"createdDate":"2026-07-08 20:36","name":"法国国际广播电台","title":"中国工信部警示Claude Code存安全隐患","content":"中国国家网络安全威胁和漏洞信息共享平台（NVDB）近日宣布，已检测到人工智能编程工具“ClaudeCode”存在安全漏洞。该漏洞可能允许软件在未经用户同意的情况下，将包括用户位置和身份识别信息在内的敏感信息传输至Anthropic公司的服务器。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260708-%E4%B8%AD%E5%9B%BD%E5%B7%A5%E4%BF%A1%E9%83%A8%E8%AD%A6%E7%A4%BAclaude-code%E5%AD%98%E5%AE%89%E5%85%A8%E9%9A%90%E6%82%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783543007000.webp","sourceId":"rfi"},{"id":1783542697000,"createdDate":"2026-07-08 20:31","name":"法国国际广播电台","title":"刑满前   古巴让一名被关押的艺术家“失踪”","content":"部位于迈阿密的人权组织Cubalex周三对古巴异见艺术家路易斯·曼努埃尔·奥特罗·阿尔肯塔拉（LuisManuelOteroAlcántara）的命运表示关切。阿尔坎塔拉于周二被从监狱带走，距离他刑期结束仅剩两天。法新社联系了这位异见人士的几位家人和密友，他们证实他们不知道他的下落。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260708-%E5%88%91%E6%BB%A1%E5%89%8D-%E5%8F%A4%E5%B7%B4%E8%AE%A9%E4%B8%80%E5%90%8D%E8%A2%AB%E5%85%B3%E6%8A%BC%E7%9A%84%E8%89%BA%E6%9C%AF%E5%AE%B6-%E5%A4%B1%E8%B8%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783542697000.webp","sourceId":"rfi"},{"id":1783542478000,"createdDate":"2026-07-08 20:27","name":"法国国际广播电台","title":"特朗普会不会阻止美西贸易？","content":"特朗普周三重申了他对西班牙实施贸易禁运的意图，并命令财政部长斯科特·贝森特“终止与西班牙的一切贸易（……），包括访问”，原因是双方因马德里的国防开支问题而关系紧张。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260708-%E7%89%B9%E6%9C%97%E6%99%AE%E4%BC%9A%E4%B8%8D%E4%BC%9A%E9%98%BB%E6%AD%A2%E7%BE%8E%E8%A5%BF%E8%B4%B8%E6%98%93","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783542478000.webp","sourceId":"rfi"},{"id":1783542033000,"createdDate":"2026-07-08 20:20","name":"法国国际广播电台","title":"埃尔多安向来宾赠送刻有他名字的手枪","content":"英国首相基尔·斯塔默周三表示，土耳其总统埃尔多安向出席北约峰会的各国领导人赠送了手枪和弹药。斯塔默在从安卡拉返回英国的航班上对英国记者解释说，埃尔多安总统向每位领导人赠送了一支刻有他名字的手枪和一盒弹药。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260708-%E5%9F%83%E5%B0%94%E5%A4%9A%E5%AE%89%E5%90%91%E6%9D%A5%E5%AE%BE%E8%B5%A0%E9%80%81%E5%88%BB%E6%9C%89%E4%BB%96%E5%90%8D%E5%AD%97%E7%9A%84%E6%89%8B%E6%9E%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783542033000.webp","sourceId":"rfi"},{"id":1783541267000,"createdDate":"2026-07-08 20:07","name":"法国国际广播电台","title":"令人吃惊！法摩八强赛裁判全来自阿根廷","content":"世界杯八强赛迎来焦点对决，卫冕冠军法国在波士顿迎战黑马摩洛哥。上届半决赛法国2-0完胜对手，四年后两队再度交手。正式比赛开始前一天，主裁和助手裁判竟全员都来自阿根廷，法国国内新闻电台(FranceInfo)表示：这种安排是世界杯历史上首次出现主裁和助理裁判全部为同一国籍，好奇怪的选择！","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260708-%E4%BB%A4%E4%BA%BA%E5%90%83%E6%83%8A-%E6%B3%95%E6%91%A9%E5%85%AB%E5%BC%BA%E8%B5%9B%E8%A3%81%E5%88%A4%E5%85%A8%E6%9D%A5%E8%87%AA%E9%98%BF%E6%A0%B9%E5%BB%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783541267000.webp","sourceId":"rfi"},{"id":1783540376000,"createdDate":"2026-07-08 19:52","name":"法国国际广播电台","title":"俄乌战争四年多 美国终授权乌克兰生产爱国者防空飞弹","content":"7月8日在土耳其首都安卡拉举行的北约组织（NATO）峰会后，美国总统特朗普在峰会场边会晤了乌克兰总统泽连斯基，并表示美国将授权乌克兰自己生产爱国者防空飞弹。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260708-%E4%BF%84%E4%B9%8C%E6%88%98%E4%BA%89%E5%9B%9B%E5%B9%B4%E5%A4%9A-%E7%BE%8E%E5%9B%BD%E7%BB%88%E6%8E%88%E6%9D%83%E4%B9%8C%E5%85%8B%E5%85%B0%E7%94%9F%E4%BA%A7%E7%88%B1%E5%9B%BD%E8%80%85%E9%98%B2%E7%A9%BA%E9%A3%9E%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/08/1783540376000.webp","sourceId":"rfi"}]