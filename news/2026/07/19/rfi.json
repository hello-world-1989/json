[{"id":1784481382000,"createdDate":"2026-07-19 17:16","name":"法国国际广播电台","title":"丹麦名将重重摔倒   无缘第三次冠军   退出环法赛","content":"这简直是令人难以置信的一幕！曾夺下两届冠军的丹麦名将乔纳斯·文格加德JonasVingegaard在距离终点20公里处不幸摔车受伤，摔得非常厉害，自己无法站立起来，急救车及时赶到，他被迫退出本届赛事。据最新消息，乔纳斯·溫格高·拉斯穆森锁骨骨折，将在未来几天接受手术。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260719-%E4%B8%B9%E9%BA%A6%E5%90%8D%E5%B0%86%E9%87%8D%E9%87%8D%E6%91%94%E5%80%92-%E6%97%A0%E7%BC%98%E7%AC%AC%E4%B8%89%E6%AC%A1%E5%86%A0%E5%86%9B-%E9%80%80%E5%87%BA%E7%8E%AF%E6%B3%95%E8%B5%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784481382000.webp","sourceId":"rfi"},{"id":1784480335000,"createdDate":"2026-07-19 16:58","name":"法国国际广播电台","title":"塞内加尔和冈比亚边境争端复燃","content":"在西非国家塞内加尔与冈比亚之间的外交紧张于本周再次复燃。本次争端的起因是塞内加尔军队在2026年07月16日星期四拆毁了冈比亚西南部边境村庄布洛克（Bulock）附近的一个冈比亚军事哨所的围墙。这举动再次燃起了两国间的边界争端。这是本台法广（RFI）非洲通讯员今天（2026年07月19号星期日）发自达喀尔（Dakar）的一则最新法语消息。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260719-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%A1%9E%E5%86%85%E5%8A%A0%E5%B0%94%E5%92%8C%E5%86%88%E6%AF%94%E4%BA%9A%E8%BE%B9%E5%A2%83%E4%BA%89%E7%AB%AF%E5%A4%8D%E7%87%83","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784480335000.webp","sourceId":"rfi"},{"id":1784480332000,"createdDate":"2026-07-19 16:58","name":"法国国际广播电台","title":"柏林《每日镜报》：美国“选举安全的噩梦”并不是中国，而是美国自己的总统","content":"多家德国媒体对特朗普的全国讲话表示了多方关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260719-%E6%9F%8F%E6%9E%97-%E6%AF%8F%E6%97%A5%E9%95%9C%E6%8A%A5-%E7%BE%8E%E5%9B%BD-%E9%80%89%E4%B8%BE%E5%AE%89%E5%85%A8%E7%9A%84%E5%99%A9%E6%A2%A6-%E5%B9%B6%E4%B8%8D%E6%98%AF%E4%B8%AD%E5%9B%BD%EF%BC%8C%E8%80%8C%E6%98%AF%E7%BE%8E%E5%9B%BD%E8%87%AA%E5%B7%B1%E7%9A%84%E6%80%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784480332000.webp","sourceId":"rfi"},{"id":1784478397000,"createdDate":"2026-07-19 16:26","name":"法国国际广播电台","title":"美国一周内2起ICE致命枪击掀民众怒火","content":"美国一周内接连发生两起美国移民暨海关执法局（ICE）探员开枪击毙移民事件，引爆全美多地民众愤怒与示威抗议。","newsLink":"https://www.rfi.fr/cn/%E4%BA%BA%E6%9D%83/20260719-%E7%BE%8E%E5%9B%BD%E4%B8%80%E5%91%A8%E5%86%852%E8%B5%B7ice%E8%87%B4%E5%91%BD%E6%9E%AA%E5%87%BB%E6%8E%80%E6%B0%91%E4%BC%97%E6%80%92%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784478397000.webp","sourceId":"rfi"},{"id":1784471413000,"createdDate":"2026-07-19 14:30","name":"法国国际广播电台","title":"伊朗外长透露自己尚未见到过新任最高领袖 指使哈梅内伊被击杀的漏洞或仍存在","content":"伊朗外交部长阿拉格齐最新在受访时表示，他尚未与伊朗新任最高领袖穆杰塔巴当面会晤。阿拉格齐称，自从后者接替其父出任最高领袖以来，“只有极少人见过他”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260719-%E4%BC%8A%E6%9C%97%E5%A4%96%E9%95%BF%E9%80%8F%E9%9C%B2%E8%87%AA%E5%B7%B1%E5%B0%9A%E6%9C%AA%E8%A7%81%E5%88%B0%E8%BF%87%E6%96%B0%E4%BB%BB%E6%9C%80%E9%AB%98%E9%A2%86%E8%A2%96-%E6%8C%87%E4%BD%BF%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E8%A2%AB%E5%87%BB%E6%9D%80%E7%9A%84%E6%BC%8F%E6%B4%9E%E6%88%96%E4%BB%8D%E5%AD%98%E5%9C%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784471413000.webp","sourceId":"rfi"},{"id":1784468900000,"createdDate":"2026-07-19 13:48","name":"法国国际广播电台","title":"年底修订安保三文件是否触及“非核三原则”受关注 东京有意加强美延伸威慑","content":"据《日经亚洲》报导，作为年底修订“安保三文件”工作的一部分，日本政府将寻求加强由美国提供的延伸威慑途径。所谓“安保三文件”指的是《国家安全保障战略》《国家防卫战略》和《防卫力量整备计划》这三份文件。此举包括旨在应对中国不断增强的核能力，本月中方向太平洋试射潜射弹道导弹便凸显了这一动向。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260719-%E5%B9%B4%E5%BA%95%E4%BF%AE%E8%AE%A2%E5%AE%89%E4%BF%9D%E4%B8%89%E6%96%87%E4%BB%B6%E6%98%AF%E5%90%A6%E8%A7%A6%E5%8F%8A-%E9%9D%9E%E6%A0%B8%E4%B8%89%E5%8E%9F%E5%88%99-%E5%8F%97%E5%85%B3%E6%B3%A8-%E4%B8%9C%E4%BA%AC%E6%9C%89%E6%84%8F%E5%8A%A0%E5%BC%BA%E7%BE%8E%E5%BB%B6%E4%BC%B8%E5%A8%81%E6%85%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784468900000.webp","sourceId":"rfi"},{"id":1784465321000,"createdDate":"2026-07-19 12:48","name":"法国国际广播电台","title":"中国AI初创先锋月之暗面据报拟最早六个月内赴港上市","content":"据彭博社援引知情人士报导称，中国人工智能（AI）先锋企业月之暗面（MoonshotAI）已向投资者发出股东决议，寻求支持其在香港上市。该公司正着手利用资本市场机遇，此前其最新发布的模型颠覆了外界对中国日益增长的AI实力的认知，并引发全球科技股剧烈震荡。启动这一通知程序表明，该公司最早可能在未来六个月内进行首次公开​​募股（IPO）。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260719-%E4%B8%AD%E5%9B%BDai%E5%88%9D%E5%88%9B%E5%85%88%E9%94%8B%E6%9C%88%E4%B9%8B%E6%9A%97%E9%9D%A2%E6%8D%AE%E6%8A%A5%E6%8B%9F%E6%9C%80%E6%97%A9%E5%85%AD%E4%B8%AA%E6%9C%88%E5%86%85%E8%B5%B4%E6%B8%AF%E4%B8%8A%E5%B8%82","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784465321000.webp","sourceId":"rfi"},{"id":1784463291000,"createdDate":"2026-07-19 12:14","name":"法国国际广播电台","title":"共和党议员致信SEC主席 指“中国军事公司”清单上榜实体不应在美交易","content":"两位共和党籍资深国会议员日前致信美国证券交易委员会（SEC）主席阿特金斯（PaulAtkins），请求该机构考虑限制在美上市的“中国军事公司”进入美国资本市场，以保护美国的经济与国家安全。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260719-%E5%85%B1%E5%92%8C%E5%85%9A%E8%AE%AE%E5%91%98%E8%87%B4%E4%BF%A1sec%E4%B8%BB%E5%B8%AD-%E6%8C%87-%E4%B8%AD%E5%9B%BD%E5%86%9B%E4%BA%8B%E5%85%AC%E5%8F%B8-%E6%B8%85%E5%8D%95%E4%B8%8A%E6%A6%9C%E5%AE%9E%E4%BD%93%E4%B8%8D%E5%BA%94%E5%9C%A8%E7%BE%8E%E4%BA%A4%E6%98%93","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784463291000.webp","sourceId":"rfi"},{"id":1784460288000,"createdDate":"2026-07-19 11:24","name":"法国国际广播电台","title":"英国钢铁公司被国有化 中国敬业集团要求赔偿","content":"中国钢铁制造企业敬业集团旗下的英国钢铁公司（BritishSteel）被伦敦收归国有后，敬业集团（JingyeSteel）周日提出赔偿要求，并威胁将对英国政府采取法律行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260719-%E8%8B%B1%E5%9B%BD%E9%92%A2%E9%93%81%E5%85%AC%E5%8F%B8%E8%A2%AB%E5%9B%BD%E6%9C%89%E5%8C%96-%E4%B8%AD%E5%9B%BD%E6%95%AC%E4%B8%9A%E9%9B%86%E5%9B%A2%E8%A6%81%E6%B1%82%E8%B5%94%E5%81%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784460288000.webp","sourceId":"rfi"},{"id":1784457798000,"createdDate":"2026-07-19 10:43","name":"法国国际广播电台","title":"2名美军人员在伊朗袭击中身亡，1人失踪后 美军连续第8晚打击伊朗","content":"美国中央司令部周六宣布两名美军人员在约旦遭伊朗袭击身亡、另有一人失踪；随后，美军表示已连续第八晚对伊朗发动攻击。自上周一项一个月前签署的临时停火协议破裂以来，美伊双方的攻击行动不断升级，引发了局势可能重回全面战争状态的担忧。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260719-%E4%B8%A4%E5%90%8D%E7%BE%8E%E5%86%9B%E4%BA%BA%E5%91%98%E9%81%AD%E4%BC%8A%E6%9C%97%E8%A2%AD%E5%87%BB%E8%BA%AB%E4%BA%A1%EF%BC%8C1%E4%BA%BA%E5%A4%B1%E8%B8%AA%E5%90%8E-%E7%BE%8E%E5%86%9B%E8%BF%9E%E7%BB%AD%E7%AC%AC8%E6%99%9A%E6%89%93%E5%87%BB%E4%BC%8A%E6%9C%97","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784457798000.webp","sourceId":"rfi"},{"id":1784455717000,"createdDate":"2026-07-19 10:08","name":"法国国际广播电台","title":"日本拟研发无人船供海上保安厅使用 加强沿海警戒监控","content":"据《读卖新闻》报导，为加强日本周边海域的警戒监控，日本政府已确定从下一财年起着手研发供海上保安厅使用的无人船。该举措将与巡逻船及无人机等相结合，以应对中国日益活跃的海上扩张。日本政府还计划于12月份对《关于强化海上保安能力的方针》进行时隔4年的修订，并出台包括利用无人船在内的海上保安强化措施。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260719-%E6%97%A5%E6%9C%AC%E6%8B%9F%E7%A0%94%E5%8F%91%E6%97%A0%E4%BA%BA%E8%88%B9%E4%BE%9B%E6%B5%B7%E4%B8%8A%E4%BF%9D%E5%AE%89%E5%8E%85%E4%BD%BF%E7%94%A8-%E5%8A%A0%E5%BC%BA%E6%B2%BF%E6%B5%B7%E8%AD%A6%E6%88%92%E7%9B%91%E6%8E%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784455717000.webp","sourceId":"rfi"},{"id":1784454893000,"createdDate":"2026-07-19 09:54","name":"法国国际广播电台","title":"赖清德：绝对不要让“民主台湾”走回头路变成“中国台湾”","content":"台湾民进党全代会今天（7月19号）登场，身兼党主席的总统赖清德致词表示时说，期待全体党工岗位要站起来对抗中国红色恐怖对台湾社会的威胁，齐心守护民主自由的活动，绝对不要让“民主台湾”走回头路，变成“中国台湾”。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260719-%E8%B5%96%E6%B8%85%E5%BE%B7-%E7%BB%9D%E5%AF%B9%E4%B8%8D%E8%A6%81%E8%AE%A9-%E6%B0%91%E4%B8%BB%E5%8F%B0%E6%B9%BE-%E8%B5%B0%E5%9B%9E%E5%A4%B4%E8%B7%AF%E5%8F%98%E6%88%90-%E4%B8%AD%E5%9B%BD%E5%8F%B0%E6%B9%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784454893000.webp","sourceId":"rfi"},{"id":1784451453000,"createdDate":"2026-07-19 08:57","name":"法国国际广播电台","title":"国家开发银行原行长欧阳卫民官宣被查","content":"据中央纪委国家监委网站周日（19日）消息，国家开发银行原党委副书记、行长欧阳卫民涉嫌严重违纪违法，目前正接受中央纪委国家监委纪律审查和监察调查。“财新网”报导指，现年63岁的欧阳卫民是近年国开行第七位落马的行领导。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260719-%E5%9B%BD%E5%AE%B6%E5%BC%80%E5%8F%91%E9%93%B6%E8%A1%8C%E5%8E%9F%E8%A1%8C%E9%95%BF%E6%AC%A7%E9%98%B3%E5%8D%AB%E6%B0%91%E5%AE%98%E5%AE%A3%E8%A2%AB%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784451453000.webp","sourceId":"rfi"},{"id":1784451028000,"createdDate":"2026-07-19 08:50","name":"法国国际广播电台","title":"参加长崎原子弹爆炸纪念仪式国家和地区将过百 史上最多","content":"长崎原子弹爆炸81周年和平祈念仪式将8月9日在长崎举行，长崎市市长铃木史朗表示，预计出席仪式的国家和地区数量将超过100个，创历史新高。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260719-%E5%8F%82%E5%8A%A0%E9%95%BF%E5%B4%8E%E5%8E%9F%E5%AD%90%E5%BC%B9%E7%88%86%E7%82%B8%E7%BA%AA%E5%BF%B5%E4%BB%AA%E5%BC%8F%E5%9B%BD%E5%AE%B6%E5%92%8C%E5%9C%B0%E5%8C%BA%E5%B0%86%E8%BF%87%E7%99%BE-%E5%8F%B2%E4%B8%8A%E6%9C%80%E5%A4%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784451028000.webp","sourceId":"rfi"},{"id":1784449694000,"createdDate":"2026-07-19 08:28","name":"法国国际广播电台","title":"德国基民盟政治家施潘因美国代孕事件辞职","content":"据德国广播电台报道：由于围绕其在美国通过代孕获子所引发的争议带来巨大压力，德国联盟党（CDU/CSU）联邦议院党团主席延斯·施潘（JensSpahn）宣布辞职。德国总理弗里德里希·默茨（FriedrichMerz）表示，这一决定“正确且不可避免”。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260719-%E5%BE%B7%E5%9B%BD%E5%9F%BA%E6%B0%91%E7%9B%9F%E6%94%BF%E6%B2%BB%E5%AE%B6%E6%96%BD%E6%BD%98%E5%9B%A0%E7%BE%8E%E5%9B%BD%E4%BB%A3%E5%AD%95%E4%BA%8B%E4%BB%B6%E8%BE%9E%E8%81%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784449694000.webp","sourceId":"rfi"},{"id":1784448423000,"createdDate":"2026-07-19 08:07","name":"法国国际广播电台","title":"《给阿嬷的情书》重现早年南洋华侨与中国家乡间亲情 但电影出海在新加坡却被读出「统战」","content":"中国今年票房黑马《给阿嬷的情书》，凭借着口碑在中国内地狂揽超过19亿人民币票房。6月18日起也在新加坡、马来西亚和汶莱等第一波海外国家上映。但在中国市场爆红的《给阿嬷的情书》，却在新加坡掀起当地海外华人身份认同与中国统战目的等的争议。网友是如何看待此议题？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%BE%AE%E8%A8%80%E5%BE%AE%E8%AF%AD/20260719-%E7%BB%99%E9%98%BF%E5%AC%B7%E7%9A%84%E6%83%85%E4%B9%A6-%E9%87%8D%E7%8E%B0%E6%97%A9%E5%B9%B4%E5%8D%97%E6%B4%8B%E5%8D%8E%E4%BE%A8%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%AE%B6%E4%B9%A1%E9%97%B4%E4%BA%B2%E6%83%85-%E4%BD%86%E7%94%B5%E5%BD%B1%E5%87%BA%E6%B5%B7%E5%9C%A8%E6%96%B0%E5%8A%A0%E5%9D%A1%E5%8D%B4%E8%A2%AB%E8%AF%BB%E5%87%BA-%E7%BB%9F%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/19/1784448423000.webp","sourceId":"rfi"}]