[{"id":1783421702000,"createdDate":"2026-07-07 10:55","name":"法国国际广播电台","title":"AI领域的中国龙卷风：当法国政府部门开始使用阿里千问","content":"各位好，7月7日出刊的法国主流日刊密集关注的话题如下：2027年法国大选临近，极右翼政党国民联盟领袖玛琳·勒庞的政治命运掌握在法官的手中、轰动法国的“消失的妻子”一案当中，涉案丈夫时隔五年终于承认自己是杀妻凶手、法国南部面临史上罕见的山火灾情，政府紧急应对、北约在土耳其开峰会、马克龙成为叙利亚政权更迭以来首个造访大马士革的西方国家领导人、针对本届世界杯，尤其是国际足联的多角度吐槽、哈马斯宣布解散其在加沙的管理机构等。在本期的法国报纸摘要栏目中，我们为您选取与中国相关的话题做综述。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260707-ai%E9%A2%86%E5%9F%9F%E7%9A%84%E4%B8%AD%E5%9B%BD%E9%BE%99%E5%8D%B7%E9%A3%8E-%E5%BD%93%E6%B3%95%E5%9B%BD%E6%94%BF%E5%BA%9C%E9%83%A8%E9%97%A8%E5%BC%80%E5%A7%8B%E4%BD%BF%E7%94%A8%E9%98%BF%E9%87%8C%E5%8D%83%E9%97%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783421702000.webp","sourceId":"rfi"},{"id":1783420948000,"createdDate":"2026-07-07 10:42","name":"法国国际广播电台","title":"摩纳哥乌寡头遭包裹炸弹袭击案 嫌疑女子遭枪杀 尸体在基辅附近被发现","content":"据《乌克兰真理报》周二报导，一名涉嫌于上周在摩纳哥针对一位出生于乌克兰的富商实施炸弹袭击的乌克兰女性，其尸体在首都基辅附近被发现。该报援引执法部门消息人士的话称，该女子遭枪杀，其尸体于当地时间周一晚11点左右被发现。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260707-%E6%91%A9%E7%BA%B3%E5%93%A5%E4%B9%8C%E5%AF%A1%E5%A4%B4%E9%81%AD%E5%8C%85%E8%A3%B9%E7%82%B8%E5%BC%B9%E8%A2%AD%E5%87%BB%E6%A1%88-%E5%AB%8C%E7%96%91%E5%A5%B3%E5%AD%90%E9%81%AD%E6%9E%AA%E6%9D%80-%E5%B0%B8%E4%BD%93%E5%9C%A8%E5%9F%BA%E8%BE%85%E9%99%84%E8%BF%91%E8%A2%AB%E5%8F%91%E7%8E%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783420948000.webp","sourceId":"rfi"},{"id":1783419909000,"createdDate":"2026-07-07 10:25","name":"法国国际广播电台","title":"所罗门群岛总理：中方试射导弹非朋友应有行径 澳总理：此举是挑衅行为","content":"澳大利亚和所罗门群岛周二承诺深化双边关系，并对解放军海军战略核潜艇向太平洋发射潜射战略导弹的举动提出批评；专家指出，此举可能加剧太平洋地区的战略竞争。澳大利亚总理阿尔巴尼斯（AnthonyAlbanese）周二在霍尼亚拉会见了所罗门群岛总理威尔（MatthewWale）。阿尔巴尼斯表示，澳方不希望看到任何可能破坏太平洋地区和平与安全的行动。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260707-%E6%89%80%E7%BD%97%E9%97%A8%E7%BE%A4%E5%B2%9B%E6%80%BB%E7%90%86-%E4%B8%AD%E6%96%B9%E8%AF%95%E5%B0%84%E5%AF%BC%E5%BC%B9%E9%9D%9E%E6%9C%8B%E5%8F%8B%E5%BA%94%E6%9C%89%E8%A1%8C%E5%BE%84-%E6%BE%B3%E6%80%BB%E7%90%86-%E6%AD%A4%E4%B8%BE%E6%98%AF%E6%8C%91%E8%A1%85%E8%A1%8C%E4%B8%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783419909000.webp","sourceId":"rfi"},{"id":1783418179000,"createdDate":"2026-07-07 09:56","name":"法国国际广播电台","title":"2026年世界杯：比利时队4:1击败美国队 与西班牙队进入四分之一决赛","content":"美国队主力球员巴洛根在32强赛中被红牌罚下，但由于美国总统特朗普的运作，他仍被允许上场参加淘汰赛，不过他未能阻止美国队以1比4的惨败，比利时队表现出色，凭借德凯特莱尔的梅开二度后就完全掌控了赛事，取得决定性胜利，进入四分之一决赛，比利时队将与西班牙队对决。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260707-2026%E5%B9%B4%E4%B8%96%E7%95%8C%E6%9D%AF-%E6%AF%94%E5%88%A9%E6%97%B6%E9%98%9F4-1%E5%87%BB%E8%B4%A5%E7%BE%8E%E5%9B%BD%E9%98%9F-%E4%B8%8E%E8%A5%BF%E7%8F%AD%E7%89%99%E9%98%9F%E8%BF%9B%E5%85%A5%E5%9B%9B%E5%88%86%E4%B9%8B%E4%B8%80%E5%86%B3%E8%B5%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783418179000.webp","sourceId":"rfi"},{"id":1783415936000,"createdDate":"2026-07-07 09:18","name":"法国国际广播电台","title":"袭击矢板明夫男子被依反渗透法等罪移送台中地检署 另名香港男子已先离台","content":"据联合新闻网等媒体报导，媒体人矢板明夫周一在台中被打，台中警方和移民署与航警联手，在3.5小时内迅速逮到涉案的香港男子，台湾内政部长刘世芳周二到台中颁奖金感谢有功人员。台中市警局长吴敬田表示，嫌犯左手刺青是破案关键之一，经查还有一名共犯已离境，警方追查身分中。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260707-%E8%A2%AD%E5%87%BB%E7%9F%A2%E6%9D%BF%E6%98%8E%E5%A4%AB%E7%94%B7%E5%AD%90%E8%A2%AB%E4%BE%9D%E5%8F%8D%E6%B8%97%E9%80%8F%E6%B3%95%E7%AD%89%E7%BD%AA%E7%A7%BB%E9%80%81%E5%8F%B0%E4%B8%AD%E5%9C%B0%E6%A3%80%E7%BD%B2-%E5%8F%A6%E5%90%8D%E9%A6%99%E6%B8%AF%E7%94%B7%E5%AD%90%E5%B7%B2%E5%85%88%E7%A6%BB%E5%8F%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783415936000.webp","sourceId":"rfi"},{"id":1783413277000,"createdDate":"2026-07-07 08:34","name":"法国国际广播电台","title":"下榻大马士革酒店附近发生两起炸弹爆炸 爱丽舍宫：马克龙安然无恙","content":"当地时间周二上午，在法国总统马克龙对叙利亚进行历史性访问的第二天，大马士革发生两起爆炸，地点靠近他下榻的酒店。据一位叙利亚安全消息人士透露， 其中一枚炸弹被放置在垃圾箱内，另一枚则被放置在四季酒店附近的一辆汽车上，该酒店位于首都市中心。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260707-%E4%B8%8B%E6%A6%BB%E5%A4%A7%E9%A9%AC%E5%A3%AB%E9%9D%A9%E9%85%92%E5%BA%97%E9%99%84%E8%BF%91%E5%8F%91%E7%94%9F%E4%B8%A4%E8%B5%B7%E7%82%B8%E5%BC%B9%E7%88%86%E7%82%B8-%E7%88%B1%E4%B8%BD%E8%88%8D%E5%AE%AB-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%AE%89%E7%84%B6%E6%97%A0%E6%81%99","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783413277000.webp","sourceId":"rfi"},{"id":1783412691000,"createdDate":"2026-07-07 08:24","name":"法国国际广播电台","title":"智库执行长矢板明夫在台中遇袭 台湾外交部谴责中国实行《民族团结法》后首起对台跨国镇压","content":"印太战略智库执行长矢板明夫6日在台中遭中国及黑衣男子殴打脸部。嫌犯在同日已遭警察逮捕。台湾外交部7日记者会中谴责，此为中国跨境镇压，也是中国《民族团结法》实施之后的首起暴力事件。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260707-%E6%99%BA%E5%BA%93%E6%89%A7%E8%A1%8C%E9%95%BF%E7%9F%A2%E6%9D%BF%E6%98%8E%E5%A4%AB%E5%9C%A8%E5%8F%B0%E4%B8%AD%E9%81%87%E8%A2%AD-%E5%8F%B0%E6%B9%BE%E5%A4%96%E4%BA%A4%E9%83%A8%E8%B0%B4%E8%B4%A3%E4%B8%AD%E5%9B%BD%E5%AE%9E%E8%A1%8C-%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E6%B3%95-%E5%90%8E%E9%A6%96%E8%B5%B7%E5%AF%B9%E5%8F%B0%E8%B7%A8%E5%9B%BD%E9%95%87%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783412691000.webp","sourceId":"rfi"},{"id":1783412463000,"createdDate":"2026-07-07 08:21","name":"法国国际广播电台","title":"金明日获释，那黎智英呢？彭博：北京为习近平访美铺路而施薄面但有“红线”","content":"中国日前突然释放被监禁长达9个月的北京锡安教会创办人金明日牧师返回美国。据彭博社引述分析指出，北京有意在习近平9月访美前，藉由释放金明日展现“善意”。然而，北京恐怕不会轻易释放同样被华盛顿关切的香港壹传媒创办人黎智英。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260707-%E9%87%91%E6%98%8E%E6%97%A5%E8%8E%B7%E9%87%8A%EF%BC%8C%E9%82%A3%E9%BB%8E%E6%99%BA%E8%8B%B1%E5%91%A2-%E5%BD%AD%E5%8D%9A-%E5%8C%97%E4%BA%AC%E4%B8%BA%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%BF%E7%BE%8E%E9%93%BA%E8%B7%AF%E8%80%8C%E6%96%BD%E8%96%84%E9%9D%A2%E4%BD%86%E6%9C%89-%E7%BA%A2%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783412463000.webp","sourceId":"rfi"},{"id":1783411547000,"createdDate":"2026-07-07 08:05","name":"法国国际广播电台","title":"日本官房长官对中国发射导弹等军事动向表示深刻担忧","content":"围绕7月6日中国发射弹道导弹一事，日本内阁官房长官木原稔在7日的记者会上表示，“中国的军事动向已经成为我国以及国际社会深刻担忧的问题。”他并强调：“今后将继续努力开展信息收集和分析。”同时再次表明，将抓紧推进修改日本《安保三文件》的工作。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260707-%E6%97%A5%E6%9C%AC%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%8F%91%E5%B0%84%E5%AF%BC%E5%BC%B9%E7%AD%89%E5%86%9B%E4%BA%8B%E5%8A%A8%E5%90%91%E8%A1%A8%E7%A4%BA%E6%B7%B1%E5%88%BB%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783411547000.webp","sourceId":"rfi"},{"id":1783411206000,"createdDate":"2026-07-07 08:00","name":"法国国际广播电台","title":"香港抢占星洲先机 今起试运黄金结算系统 争当枢纽兼造定价基础","content":"由港府与上海及11家金融机构支持的香港黄金中央结算系统，今日开始试运，香港行政长官李家超表示，在地缘政治危机与经济不确定的世界中，香港这结算系统为打造黄金交易生态系统奠定基础，并将惠及全球寻求安全资产的人和资本。系统试运为香港与新加坡争夺拥有定价权的亚洲黄金交易枢纽这目标赢得时间先机，因为後者的场外结算系统会在年底才能建立。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260707-%E9%A6%99%E6%B8%AF%E6%8A%A2%E5%8D%A0%E6%98%9F%E6%B4%B2%E5%85%88%E6%9C%BA-%E4%BB%8A%E8%B5%B7%E8%AF%95%E8%BF%90%E9%BB%84%E9%87%91%E7%BB%93%E7%AE%97%E7%B3%BB%E7%BB%9F-%E4%BA%89%E5%BD%93%E6%9E%A2%E7%BA%BD%E5%85%BC%E9%80%A0%E5%AE%9A%E4%BB%B7%E5%9F%BA%E7%A1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783411206000.webp","sourceId":"rfi"},{"id":1783411131000,"createdDate":"2026-07-07 07:58","name":"法国国际广播电台","title":"特朗普：习近平将於9月24日访美到白宫","content":"美国总统特朗普(又译川普)证实，白宫将在9月24日左右接待访美的中国国家主席习近平。相关时间正是联合国大会举行期间，未知习近平届时会否出席会议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260707-%E7%89%B9%E6%9C%97%E6%99%AE-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%B0%86%E6%96%BC9%E6%9C%8824%E6%97%A5%E8%AE%BF%E7%BE%8E%E5%88%B0%E7%99%BD%E5%AE%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783411131000.webp","sourceId":"rfi"}]