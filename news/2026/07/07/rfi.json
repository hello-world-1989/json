[{"id":1783421702000,"createdDate":"2026-07-07 10:55","name":"法国国际广播电台","title":"AI领域的中国龙卷风：当法国政府部门开始使用阿里千问","content":"各位好，7月7日出刊的法国主流日刊密集关注的话题如下：2027年法国大选临近，极右翼政党国民联盟领袖玛琳·勒庞的政治命运掌握在法官的手中、轰动法国的“消失的妻子”一案当中，涉案丈夫时隔五年终于承认自己是杀妻凶手、法国南部面临史上罕见的山火灾情，政府紧急应对、北约在土耳其开峰会、马克龙成为叙利亚政权更迭以来首个造访大马士革的西方国家领导人、针对本届世界杯，尤其是国际足联的多角度吐槽、哈马斯宣布解散其在加沙的管理机构等。在本期的法国报纸摘要栏目中，我们为您选取与中国相关的话题做综述。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260707-ai%E9%A2%86%E5%9F%9F%E7%9A%84%E4%B8%AD%E5%9B%BD%E9%BE%99%E5%8D%B7%E9%A3%8E-%E5%BD%93%E6%B3%95%E5%9B%BD%E6%94%BF%E5%BA%9C%E9%83%A8%E9%97%A8%E5%BC%80%E5%A7%8B%E4%BD%BF%E7%94%A8%E9%98%BF%E9%87%8C%E5%8D%83%E9%97%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783421702000.webp","sourceId":"rfi"},{"id":1783420948000,"createdDate":"2026-07-07 10:42","name":"法国国际广播电台","title":"摩纳哥乌寡头遭包裹炸弹袭击案 嫌疑女子遭枪杀 尸体在基辅附近被发现","content":"据《乌克兰真理报》周二报导，一名涉嫌于上周在摩纳哥针对一位出生于乌克兰的富商实施炸弹袭击的乌克兰女性，其尸体在首都基辅附近被发现。该报援引执法部门消息人士的话称，该女子遭枪杀，其尸体于当地时间周一晚11点左右被发现。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260707-%E6%91%A9%E7%BA%B3%E5%93%A5%E4%B9%8C%E5%AF%A1%E5%A4%B4%E9%81%AD%E5%8C%85%E8%A3%B9%E7%82%B8%E5%BC%B9%E8%A2%AD%E5%87%BB%E6%A1%88-%E5%AB%8C%E7%96%91%E5%A5%B3%E5%AD%90%E9%81%AD%E6%9E%AA%E6%9D%80-%E5%B0%B8%E4%BD%93%E5%9C%A8%E5%9F%BA%E8%BE%85%E9%99%84%E8%BF%91%E8%A2%AB%E5%8F%91%E7%8E%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783420948000.webp","sourceId":"rfi"},{"id":1783419909000,"createdDate":"2026-07-07 10:25","name":"法国国际广播电台","title":"所罗门群岛总理：中方试射导弹非朋友应有行径 澳总理：此举是挑衅行为","content":"澳大利亚和所罗门群岛周二承诺深化双边关系，并对解放军海军战略核潜艇向太平洋发射潜射战略导弹的举动提出批评；专家指出，此举可能加剧太平洋地区的战略竞争。澳大利亚总理阿尔巴尼斯（AnthonyAlbanese）周二在霍尼亚拉会见了所罗门群岛总理威尔（MatthewWale）。阿尔巴尼斯表示，澳方不希望看到任何可能破坏太平洋地区和平与安全的行动。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260707-%E6%89%80%E7%BD%97%E9%97%A8%E7%BE%A4%E5%B2%9B%E6%80%BB%E7%90%86-%E4%B8%AD%E6%96%B9%E8%AF%95%E5%B0%84%E5%AF%BC%E5%BC%B9%E9%9D%9E%E6%9C%8B%E5%8F%8B%E5%BA%94%E6%9C%89%E8%A1%8C%E5%BE%84-%E6%BE%B3%E6%80%BB%E7%90%86-%E6%AD%A4%E4%B8%BE%E6%98%AF%E6%8C%91%E8%A1%85%E8%A1%8C%E4%B8%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783419909000.webp","sourceId":"rfi"},{"id":1783418179000,"createdDate":"2026-07-07 09:56","name":"法国国际广播电台","title":"2026年世界杯：比利时队4:1击败美国队 与西班牙队进入四分之一决赛","content":"美国队主力球员巴洛根在32强赛中被红牌罚下，但由于美国总统特朗普的运作，他仍被允许上场参加淘汰赛，不过他未能阻止美国队以1比4的惨败，比利时队表现出色，凭借德凯特莱尔的梅开二度后就完全掌控了赛事，取得决定性胜利，进入四分之一决赛，比利时队将与西班牙队对决。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260707-2026%E5%B9%B4%E4%B8%96%E7%95%8C%E6%9D%AF-%E6%AF%94%E5%88%A9%E6%97%B6%E9%98%9F4-1%E5%87%BB%E8%B4%A5%E7%BE%8E%E5%9B%BD%E9%98%9F-%E4%B8%8E%E8%A5%BF%E7%8F%AD%E7%89%99%E9%98%9F%E8%BF%9B%E5%85%A5%E5%9B%9B%E5%88%86%E4%B9%8B%E4%B8%80%E5%86%B3%E8%B5%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783418179000.webp","sourceId":"rfi"},{"id":1783415936000,"createdDate":"2026-07-07 09:18","name":"法国国际广播电台","title":"袭击矢板明夫男子被依反渗透法等罪移送台中地检署 另名香港男子已先离台","content":"据联合新闻网等媒体报导，媒体人矢板明夫周一在台中被打，台中警方和移民署与航警联手，在3.5小时内迅速逮到涉案的香港男子，台湾内政部长刘世芳周二到台中颁奖金感谢有功人员。台中市警局长吴敬田表示，嫌犯左手刺青是破案关键之一，经查还有一名共犯已离境，警方追查身分中。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260707-%E8%A2%AD%E5%87%BB%E7%9F%A2%E6%9D%BF%E6%98%8E%E5%A4%AB%E7%94%B7%E5%AD%90%E8%A2%AB%E4%BE%9D%E5%8F%8D%E6%B8%97%E9%80%8F%E6%B3%95%E7%AD%89%E7%BD%AA%E7%A7%BB%E9%80%81%E5%8F%B0%E4%B8%AD%E5%9C%B0%E6%A3%80%E7%BD%B2-%E5%8F%A6%E5%90%8D%E9%A6%99%E6%B8%AF%E7%94%B7%E5%AD%90%E5%B7%B2%E5%85%88%E7%A6%BB%E5%8F%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783415936000.webp","sourceId":"rfi"},{"id":1783413277000,"createdDate":"2026-07-07 08:34","name":"法国国际广播电台","title":"下榻大马士革酒店附近发生两起炸弹爆炸 爱丽舍宫：马克龙安然无恙","content":"当地时间周二上午，在法国总统马克龙对叙利亚进行历史性访问的第二天，大马士革发生两起爆炸，地点靠近他下榻的酒店。据一位叙利亚安全消息人士透露， 其中一枚炸弹被放置在垃圾箱内，另一枚则被放置在四季酒店附近的一辆汽车上，该酒店位于首都市中心。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260707-%E4%B8%8B%E6%A6%BB%E5%A4%A7%E9%A9%AC%E5%A3%AB%E9%9D%A9%E9%85%92%E5%BA%97%E9%99%84%E8%BF%91%E5%8F%91%E7%94%9F%E4%B8%A4%E8%B5%B7%E7%82%B8%E5%BC%B9%E7%88%86%E7%82%B8-%E7%88%B1%E4%B8%BD%E8%88%8D%E5%AE%AB-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%AE%89%E7%84%B6%E6%97%A0%E6%81%99","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783413277000.webp","sourceId":"rfi"},{"id":1783412691000,"createdDate":"2026-07-07 08:24","name":"法国国际广播电台","title":"智库执行长矢板明夫在台中遇袭 台湾外交部谴责中国实行《民族团结法》后首起对台跨国镇压","content":"印太战略智库执行长矢板明夫6日在台中遭中国及黑衣男子殴打脸部。嫌犯在同日已遭警察逮捕。台湾外交部7日记者会中谴责，此为中国跨境镇压，也是中国《民族团结法》实施之后的首起暴力事件。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260707-%E6%99%BA%E5%BA%93%E6%89%A7%E8%A1%8C%E9%95%BF%E7%9F%A2%E6%9D%BF%E6%98%8E%E5%A4%AB%E5%9C%A8%E5%8F%B0%E4%B8%AD%E9%81%87%E8%A2%AD-%E5%8F%B0%E6%B9%BE%E5%A4%96%E4%BA%A4%E9%83%A8%E8%B0%B4%E8%B4%A3%E4%B8%AD%E5%9B%BD%E5%AE%9E%E8%A1%8C-%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E6%B3%95-%E5%90%8E%E9%A6%96%E8%B5%B7%E5%AF%B9%E5%8F%B0%E8%B7%A8%E5%9B%BD%E9%95%87%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783412691000.webp","sourceId":"rfi"},{"id":1783412463000,"createdDate":"2026-07-07 08:21","name":"法国国际广播电台","title":"金明日获释，那黎智英呢？彭博：北京为习近平访美铺路而施薄面但有“红线”","content":"中国日前突然释放被监禁长达9个月的北京锡安教会创办人金明日牧师返回美国。据彭博社引述分析指出，北京有意在习近平9月访美前，藉由释放金明日展现“善意”。然而，北京恐怕不会轻易释放同样被华盛顿关切的香港壹传媒创办人黎智英。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260707-%E9%87%91%E6%98%8E%E6%97%A5%E8%8E%B7%E9%87%8A%EF%BC%8C%E9%82%A3%E9%BB%8E%E6%99%BA%E8%8B%B1%E5%91%A2-%E5%BD%AD%E5%8D%9A-%E5%8C%97%E4%BA%AC%E4%B8%BA%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%BF%E7%BE%8E%E9%93%BA%E8%B7%AF%E8%80%8C%E6%96%BD%E8%96%84%E9%9D%A2%E4%BD%86%E6%9C%89-%E7%BA%A2%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783412463000.webp","sourceId":"rfi"},{"id":1783411547000,"createdDate":"2026-07-07 08:05","name":"法国国际广播电台","title":"日本官房长官对中国发射导弹等军事动向表示深刻担忧","content":"围绕7月6日中国发射弹道导弹一事，日本内阁官房长官木原稔在7日的记者会上表示，“中国的军事动向已经成为我国以及国际社会深刻担忧的问题。”他并强调：“今后将继续努力开展信息收集和分析。”同时再次表明，将抓紧推进修改日本《安保三文件》的工作。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260707-%E6%97%A5%E6%9C%AC%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%8F%91%E5%B0%84%E5%AF%BC%E5%BC%B9%E7%AD%89%E5%86%9B%E4%BA%8B%E5%8A%A8%E5%90%91%E8%A1%A8%E7%A4%BA%E6%B7%B1%E5%88%BB%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783411547000.webp","sourceId":"rfi"},{"id":1783411206000,"createdDate":"2026-07-07 08:00","name":"法国国际广播电台","title":"香港抢占星洲先机 今起试运黄金结算系统 争当枢纽兼造定价基础","content":"由港府与上海及11家金融机构支持的香港黄金中央结算系统，今日开始试运，香港行政长官李家超表示，在地缘政治危机与经济不确定的世界中，香港这结算系统为打造黄金交易生态系统奠定基础，并将惠及全球寻求安全资产的人和资本。系统试运为香港与新加坡争夺拥有定价权的亚洲黄金交易枢纽这目标赢得时间先机，因为後者的场外结算系统会在年底才能建立。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260707-%E9%A6%99%E6%B8%AF%E6%8A%A2%E5%8D%A0%E6%98%9F%E6%B4%B2%E5%85%88%E6%9C%BA-%E4%BB%8A%E8%B5%B7%E8%AF%95%E8%BF%90%E9%BB%84%E9%87%91%E7%BB%93%E7%AE%97%E7%B3%BB%E7%BB%9F-%E4%BA%89%E5%BD%93%E6%9E%A2%E7%BA%BD%E5%85%BC%E9%80%A0%E5%AE%9A%E4%BB%B7%E5%9F%BA%E7%A1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783411206000.webp","sourceId":"rfi"},{"id":1783411131000,"createdDate":"2026-07-07 07:58","name":"法国国际广播电台","title":"特朗普：习近平将於9月24日访美到白宫","content":"美国总统特朗普(又译川普)证实，白宫将在9月24日左右接待访美的中国国家主席习近平。相关时间正是联合国大会举行期间，未知习近平届时会否出席会议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260707-%E7%89%B9%E6%9C%97%E6%99%AE-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%B0%86%E6%96%BC9%E6%9C%8824%E6%97%A5%E8%AE%BF%E7%BE%8E%E5%88%B0%E7%99%BD%E5%AE%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783411131000.webp","sourceId":"rfi"},{"id":1783447100000,"createdDate":"2026-07-07 17:58","name":"法国国际广播电台","title":"酒店业：将其在华酒店规模扩大一倍","content":"这家法国酒店集团周二在上海公布了其在华发展雄心。雅高计划利用中国旅游业的蓬勃发展，在短短几年内将其在华酒店数量从800家增至1600家，尤其侧重于高端酒店。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260707-%E9%85%92%E5%BA%97%E4%B8%9A-%E5%B0%86%E5%85%B6%E5%9C%A8%E5%8D%8E%E9%85%92%E5%BA%97%E8%A7%84%E6%A8%A1%E6%89%A9%E5%A4%A7%E4%B8%80%E5%80%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783447100000.webp","sourceId":"rfi"},{"id":1783446300000,"createdDate":"2026-07-07 17:45","name":"法国国际广播电台","title":"纽约37层高楼因承重柱发生弯曲疏散人员","content":"纽约曼哈顿一栋在建办公楼7日上午出现倒塌风险，消防部门实施人员紧急疏散。市长佐兰·马姆达尼（ZohranMamdani）在新闻发布会上表示：“两根承重柱发生弯曲，此外还有多处裂缝和楼层下沉。大楼目前仍不稳定。我们抵达现场后发现，其中一根受损的柱子出现了进一步的移动。”","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260707-%E7%BA%BD%E7%BA%A637%E5%B1%82%E9%AB%98%E6%A5%BC%E5%9B%A0%E6%89%BF%E9%87%8D%E6%9F%B1%E5%8F%91%E7%94%9F%E5%BC%AF%E6%9B%B2%E7%96%8F%E6%95%A3%E4%BA%BA%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783446300000.webp","sourceId":"rfi"},{"id":1783445021000,"createdDate":"2026-07-07 17:23","name":"法国国际广播电台","title":"特朗普宣布解除对土耳其制裁　称将考虑恢复F-35战机军售","content":"美国总统特朗普（DonaldTrump）7日在土耳其安卡拉出席北约峰会期间宣布，美国将解除因土耳其采购俄罗斯S-400防空飞弹系统，而对安卡拉祭出的制裁，并表示恢复向土耳其出售F-35匿踪战机“绝对是我们会考虑的事情”。不过，由于美国现行法律仍限制土耳其在持有S-400系统情况下重新加入F-35计划，因此即使制裁解除，土耳其重返F-35计划仍面临法律障碍。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260707-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AE%A3%E5%B8%83%E8%A7%A3%E9%99%A4%E5%AF%B9%E5%9C%9F%E8%80%B3%E5%85%B6%E5%88%B6%E8%A3%81-%E7%A7%B0%E5%B0%86%E8%80%83%E8%99%91%E6%81%A2%E5%A4%8Df-35%E6%88%98%E6%9C%BA%E5%86%9B%E5%94%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783445021000.webp","sourceId":"rfi"},{"id":1783444758000,"createdDate":"2026-07-07 17:19","name":"法国国际广播电台","title":"北约峰会   特朗普对格陵兰岛发出新的威胁","content":"美国总统特朗普7月7日抵达土耳其首都安卡拉，土耳其总统埃尔多安到场迎接。北约领导人在安卡拉举行两天峰会，讨论提升国防开支及强化联盟防务等议题。美国总统特朗普周二重申，美国应该接管格陵兰岛。他重申了该岛“被中国和俄罗斯的船只包围”的说法。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260707-%E5%8C%97%E7%BA%A6%E5%B3%B0%E4%BC%9A-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AF%B9%E6%A0%BC%E9%99%B5%E5%85%B0%E5%B2%9B%E5%8F%91%E5%87%BA%E6%96%B0%E7%9A%84%E5%A8%81%E8%83%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783444758000.webp","sourceId":"rfi"},{"id":1783442016000,"createdDate":"2026-07-07 16:33","name":"法国国际广播电台","title":"【视频】北约峰会：成员国面临团结考验","content":"北约32个成员国齐聚土耳其安卡拉举行峰会，目标只有一个：避免惹恼美国。但峰会真的能避开所有敏感话题、顺利召开吗？本台特派记者FlorenciaValdés从安卡拉发回了报道。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260707-%E8%A7%86%E9%A2%91-%E5%8C%97%E7%BA%A6%E5%B3%B0%E4%BC%9A-%E6%88%90%E5%91%98%E5%9B%BD%E9%9D%A2%E4%B8%B4%E5%9B%A2%E7%BB%93%E8%80%83%E9%AA%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783442016000.webp","sourceId":"rfi"},{"id":1783438995000,"createdDate":"2026-07-07 15:43","name":"法国国际广播电台","title":"中国太平洋试射导弹 区域多国强烈抗议 军事专家：极可能是巨浪-3潜射洲际导弹","content":"周一（7月6日），中国一艘核动力潜艇在太平洋试射了一枚携载有“模拟弹头”的远程弹道导弹，这是两年来的首次此类发射。据中国官媒新华社表示，导弹“准确落入预定海域”，此次试射“不针对任何特定国家和目标”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260707-%E4%B8%AD%E5%9B%BD%E5%A4%AA%E5%B9%B3%E6%B4%8B%E8%AF%95%E5%B0%84%E5%AF%BC%E5%BC%B9-%E5%8C%BA%E5%9F%9F%E5%A4%9A%E5%9B%BD%E5%BC%BA%E7%83%88%E6%8A%97%E8%AE%AE-%E5%86%9B%E4%BA%8B%E4%B8%93%E5%AE%B6-%E8%AF%95%E5%B0%84%E7%9A%84%E6%9E%81%E5%8F%AF%E8%83%BD%E6%98%AF%E5%B7%A8%E6%B5%AA-3%E6%BD%9C%E5%B0%84%E6%B4%B2%E9%99%85%E5%AF%BC%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783438995000.webp","sourceId":"rfi"},{"id":1783432421000,"createdDate":"2026-07-07 13:53","name":"法国国际广播电台","title":"勒庞获准参选法国2027总统选举　电子脚镣刑罚或影响竞选","content":"法国巴黎上诉法院7日裁定，极右翼政党国民联盟（RN）领导人玛丽娜·勒庞在欧洲议会虚假聘用案中罪名成立，但缩减了此前的刑罚。根据新判决，勒庞被禁止担任公职15个月，并需佩戴电子脚镣服刑一年。由于禁任期自2025年3月起计算，预计已于今年届满，原则上已不影响她参加明年4月至5月举行的法国总统选举。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260707-%E5%8B%92%E5%BA%9E%E8%8E%B7%E5%87%86%E5%8F%82%E9%80%89%E6%B3%95%E5%9B%BD2027%E6%80%BB%E7%BB%9F%E9%80%89%E4%B8%BE-%E7%94%B5%E5%AD%90%E8%84%9A%E9%95%A3%E5%88%91%E7%BD%9A%E6%88%96%E5%BD%B1%E5%93%8D%E7%AB%9E%E9%80%89","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783432421000.webp","sourceId":"rfi"},{"id":1783431588000,"createdDate":"2026-07-07 13:39","name":"法国国际广播电台","title":"德国媒体看美国独立250周年","content":"就美国独立250周年，德国媒体表示了多方关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9F%8F%E6%9E%97%E9%A3%9E%E9%B8%BF/20260707-%E5%BE%B7%E5%9B%BD%E5%AA%92%E4%BD%93%E7%9C%8B%E7%BE%8E%E5%9B%BD%E7%8B%AC%E7%AB%8B250%E5%91%A8%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783431588000.webp","sourceId":"rfi"},{"id":1783430400000,"createdDate":"2026-07-07 13:20","name":"法国国际广播电台","title":"印尼与印度签署涉农业、关键矿产及“布拉莫斯”等导弹的协议","content":"印尼总统府表示，印尼与印度周二签署了一系列涉及关键矿产、农业和防务领域的协议，其中包括关于“布拉莫斯”（BrahMos）超音速巡航导弹系统的协议。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260707-%E5%8D%B0%E5%B0%BC%E4%B8%8E%E5%8D%B0%E5%BA%A6%E7%AD%BE%E7%BD%B2%E6%B6%89%E5%86%9C%E4%B8%9A-%E5%85%B3%E9%94%AE%E7%9F%BF%E4%BA%A7%E5%8F%8A-%E5%B8%83%E6%8B%89%E8%8E%AB%E6%96%AF-%E7%AD%89%E5%A4%9A%E7%A7%8D%E5%AF%BC%E5%BC%B9%E7%9A%84%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783430400000.webp","sourceId":"rfi"},{"id":1783429961000,"createdDate":"2026-07-07 13:12","name":"法国国际广播电台","title":"王维洛：六蓝水库溃坝除了气候管理之外还有其他三大因素","content":"中国广西南宁横州市六蓝水库7月6日发生溃坝，造成下游多个村庄遭到淹没，数万人受灾，目前死亡人数已经增加至八人。广西当局曾经在2023年斥资¥3亿人民币用来加固水坝。为何依然会发生溃坝事故？每年夏天，中国南方台风思念几乎年年都会发生水库溃坝所造成的水灾。如何才能够避免类似的灾难？法广就此电话采访了旅居德国的水利专家王维洛博士。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260707-%E7%8E%8B%E7%BB%B4%E6%B4%9B-%E5%85%AD%E8%93%9D%E6%B0%B4%E5%BA%93%E6%BA%83%E5%9D%9D%E9%99%A4%E4%BA%86%E6%B0%94%E5%80%99%E7%AE%A1%E7%90%86%E4%B9%8B%E5%A4%96%E8%BF%98%E6%9C%89%E5%85%B6%E4%BB%96%E4%B8%89%E5%A4%A7%E5%9B%A0%E7%B4%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783429961000.webp","sourceId":"rfi"},{"id":1783428718000,"createdDate":"2026-07-07 12:51","name":"法国国际广播电台","title":"检方指袭击矢板明夫男子是“预谋性、受雇跨境施暴” 向法院声押禁见","content":"据联合新闻网等媒体报导，媒体人矢板明夫周一在台中市永丰栈酒店演讲后遭攻击，动手的香港籍廖姓男子逃逸在台中国际机场落网；警方周二依反渗透法等罪嫌移送，检方复讯后认为廖是“预谋性、受雇跨境施暴”，有逃亡、串灭证之虞，依伤害等罪嫌将他向法院声押禁见。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260707-%E6%A3%80%E6%96%B9%E6%8C%87%E8%A2%AD%E5%87%BB%E7%9F%A2%E6%9D%BF%E6%98%8E%E5%A4%AB%E7%94%B7%E5%AD%90%E6%98%AF-%E9%A2%84%E8%B0%8B%E6%80%A7-%E5%8F%97%E9%9B%87%E8%B7%A8%E5%A2%83%E6%96%BD%E6%9A%B4-%E5%90%91%E6%B3%95%E9%99%A2%E5%A3%B0%E6%8A%BC%E7%A6%81%E8%A7%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783428718000.webp","sourceId":"rfi"},{"id":1783425446000,"createdDate":"2026-07-07 11:57","name":"法国国际广播电台","title":"消息人士：DeepSeek正开发自有AI推理芯片，相关努力始于约一年前","content":"据路透社援引三位知情人士报导称，中国初创企业DeepSeek正在开发自有的人工智能（AI）芯片。此举有望降低该公司对英伟达及华为芯片的依赖——此前，DeepSeek全球热门模型的训练与运行均仰赖这些芯片。上述消息人士称，该芯片专为推理环节设计——即AI计算中已训练模型根据用户需求生成响应的阶段——而非用于训练新模型。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260707-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB-deepseek%E6%AD%A3%E7%A0%94%E5%8F%91%E8%87%AA%E6%9C%89ai%E8%8A%AF%E7%89%87%EF%BC%8C%E7%9B%B8%E5%85%B3%E5%8A%AA%E5%8A%9B%E5%A7%8B%E4%BA%8E%E7%BA%A6%E4%B8%80%E5%B9%B4%E5%89%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783425446000.webp","sourceId":"rfi"},{"id":1783425031000,"createdDate":"2026-07-07 11:50","name":"法国国际广播电台","title":"湖北多地遭极端强雷暴、罕见龙卷风袭击 至少11人死亡","content":"周一（7月6号）晚间，强对流天气带来的强雷暴、大风甚至龙卷风袭击了中国中部湖北省多个地区，造成11人死亡，1人失踪。目前，救援工作已在该省展开。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260707-%E6%B9%96%E5%8C%97%E5%A4%9A%E5%9C%B0%E9%81%AD%E6%9E%81%E7%AB%AF%E5%BC%BA%E9%9B%B7%E6%9A%B4-%E7%BD%95%E8%A7%81%E9%BE%99%E5%8D%B7%E9%A3%8E%E8%A2%AD%E5%87%BB-%E8%87%B3%E5%B0%9111%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783425031000.webp","sourceId":"rfi"},{"id":1783466325000,"createdDate":"2026-07-07 23:18","name":"法国国际广播电台","title":"玛丽娜·勒庞宣布竞选总统，引起法国政界强烈反应","content":"周一晚上，在接受法国电视一台的晚20点电视新闻节目采访时，玛丽娜·勒庞宣布，她将是2027法国总统大选的候选人，并宣布对周一的裁决上诉到到最高法院。玛丽娜·勒庞宣布自己竞选总统，引起了法国政界的强烈反应。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260707-%E7%8E%9B%E4%B8%BD%E5%A8%9C%C2%B7%E5%8B%92%E5%BA%9E%E5%AE%A3%E5%B8%83%E7%AB%9E%E9%80%89%E6%80%BB%E7%BB%9F%EF%BC%8C%E5%BC%95%E8%B5%B7%E6%B3%95%E5%9B%BD%E6%94%BF%E7%95%8C%E5%BC%BA%E7%83%88%E5%8F%8D%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783466325000.webp","sourceId":"rfi"},{"id":1783458083000,"createdDate":"2026-07-07 21:01","name":"法国国际广播电台","title":"美国恢复对伊朗石油经济制裁","content":"美国周二恢复了对伊朗石油的经济制裁，称此举是对伊朗在霍尔木兹海峡“完全不可接受”的行为的回应。此前，多艘船只在霍尔木兹海峡遭到袭击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260707-%E7%BE%8E%E5%9B%BD%E6%81%A2%E5%A4%8D%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%9F%B3%E6%B2%B9%E7%BB%8F%E6%B5%8E%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783458083000.webp","sourceId":"rfi"},{"id":1783457492000,"createdDate":"2026-07-07 20:51","name":"法国国际广播电台","title":"越南拘捕撰写胡志明书籍的作家阮清南","content":"河内警方周二宣布，一本近期出版的关于越南共产党创始人胡志明的书籍的作者因涉嫌从事敌对国家活动而被捕。阮清南（NguyenThanhNam）曾任越南电信巨头FPT的首席执行官，该公司由他一手创立。今年5月，他出版了《与清的故事——光的新记述》，引发争议。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260707-%E8%B6%8A%E5%8D%97%E6%8B%98%E6%8D%95%E6%92%B0%E5%86%99%E8%83%A1%E5%BF%97%E6%98%8E%E4%B9%A6%E7%B1%8D%E7%9A%84%E4%BD%9C%E5%AE%B6%E9%98%AE%E6%B8%85%E5%8D%97","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783457492000.webp","sourceId":"rfi"},{"id":1783456985000,"createdDate":"2026-07-07 20:43","name":"法国国际广播电台","title":"中国敢言经济学家高善文病逝年仅55岁","content":"高善文是中国少数敢言的经济学家，周二（7日）传出高善文已经病逝，享年仅55岁。高善文曾经公开质疑中国经济数据造假而被北京当局全网封禁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260707-%E4%B8%AD%E5%9B%BD%E6%95%A2%E8%A8%80%E7%BB%8F%E6%B5%8E%E5%AD%A6%E5%AE%B6%E9%AB%98%E5%96%84%E6%96%87%E7%97%85%E9%80%9D%E5%B9%B4%E4%BB%8555%E5%B2%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783456985000.webp","sourceId":"rfi"},{"id":1783456795000,"createdDate":"2026-07-07 20:39","name":"法国国际广播电台","title":"叙利亚发生爆炸袭击后  马克龙没有改变行程安排","content":"在法国总统马克龙访问该国期间，首都大马士革7月7日发生了爆炸事件。爆炸发生在马克龙下榻的四季酒店附近，造成至少18人受伤。不过，爆炸发生时，法国总统正与叙利亚临时总统艾哈迈德·色拉（Ahmadal-Sharaa）在总统府举行会晤。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260707-%E5%8F%99%E5%88%A9%E4%BA%9A%E5%8F%91%E7%94%9F%E7%88%86%E7%82%B8%E8%A2%AD%E5%87%BB%E5%90%8E-%E9%A9%AC%E5%85%8B%E9%BE%99%E6%B2%A1%E6%9C%89%E6%94%B9%E5%8F%98%E8%A1%8C%E7%A8%8B%E5%AE%89%E6%8E%92","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783456795000.webp","sourceId":"rfi"},{"id":1783456606000,"createdDate":"2026-07-07 20:36","name":"法国国际广播电台","title":"津巴布韦总统任期从5年延长至7年      废除直选制","content":"津巴布韦总统埃默森·姆南加古瓦（EmmersonMnangagwa）周二签署了一项宪法修正案，将他的任期延长两年至2030年，并废除了总统直选制度。在津巴布韦，姆南加古瓦领导的拥有83年历史的津巴布韦非洲民族联盟-爱国阵线（ZANU-PF）在议会中占据多数席位，这些修改引发了反对派的强烈批评。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260707-%E6%B4%A5%E5%B7%B4%E5%B8%83%E9%9F%A6%E6%80%BB%E7%BB%9F%E4%BB%BB%E6%9C%9F%E4%BB%8E5%E5%B9%B4%E5%BB%B6%E9%95%BF%E8%87%B37%E5%B9%B4-%E5%BA%9F%E9%99%A4%E7%9B%B4%E9%80%89%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783456606000.webp","sourceId":"rfi"},{"id":1783456349000,"createdDate":"2026-07-07 20:32","name":"法国国际广播电台","title":"法参议院议长要求制裁辱骂姆巴佩的巴议员","content":"法国参议院议长热拉尔·拉尔歇尔周二致信巴拉圭参议院议长巴斯利奥·努涅斯，要求对发表“种族主义和仇外”言论的巴拉圭参议员进行制裁。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260707-%E6%B3%95%E5%8F%82%E8%AE%AE%E9%99%A2%E8%AE%AE%E9%95%BF%E8%A6%81%E6%B1%82%E5%88%B6%E8%A3%81%E8%BE%B1%E9%AA%82%E5%A7%86%E5%B7%B4%E4%BD%A9%E7%9A%84%E5%B7%B4%E8%AE%AE%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783456349000.webp","sourceId":"rfi"},{"id":1783454704000,"createdDate":"2026-07-07 20:05","name":"法国国际广播电台","title":"知难而上   玛丽娜·勒庞上诉最高法院   参加2027年总统大选","content":"法国极右翼领袖玛丽娜·勒庞是否有权参加2027年总统大选，此一消息占据了7月7日的头条新闻。7日晚间新闻时，玛丽娜·勒庞来到法国私营电视一台发布了两个消息：一是向最高法院提起上诉；二是参加2027年总统竞选。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260707-%E7%9F%A5%E9%9A%BE%E8%80%8C%E4%B8%8A-%E7%8E%9B%E4%B8%BD%E5%A8%9C%C2%B7%E5%8B%92%E5%BA%9E%E4%B8%8A%E8%AF%89%E6%9C%80%E9%AB%98%E6%B3%95%E9%99%A2-%E5%8F%82%E5%8A%A02027%E5%B9%B4%E6%80%BB%E7%BB%9F%E5%A4%A7%E9%80%89","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783454704000.webp","sourceId":"rfi"},{"id":1783454678000,"createdDate":"2026-07-07 20:04","name":"法国国际广播电台","title":"中国地下教会牧师获释 特朗普拿什么牌斡旋的？","content":"中国地下教会牧师金明日在被羁押250多天后于上周五（7月4日）获释，并获准赴美与家人团聚。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260707-%E4%B8%AD%E5%9B%BD%E5%9C%B0%E4%B8%8B%E6%95%99%E4%BC%9A%E7%89%A7%E5%B8%88%E8%8E%B7%E9%87%8A-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8B%BF%E4%BB%80%E4%B9%88%E7%89%8C%E6%96%A1%E6%97%8B%E7%9A%84","thumbnail":"","detailImage":"news/detail/rfi/2026/07/07/1783454678000.webp","sourceId":"rfi"}]