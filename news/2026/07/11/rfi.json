[{"id":1783729081000,"createdDate":"2026-07-11 00:18","name":"法国国际广播电台","title":"欧盟与中国展开“北京烤鸭之战”，中国鸭子生产商需要担忧吗？","content":"法国世界报周五关注欧盟与中国的“北京烤鸭之战”。继钢铁、电动汽车和小包裹之后，如今，欧盟与中国之间的贸易摩擦又延伸到了北京烤鸭。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260711-%E6%AC%A7%E7%9B%9F%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%B1%95%E5%BC%80-%E5%8C%97%E4%BA%AC%E7%83%A4%E9%B8%AD%E4%B9%8B%E6%88%98-%EF%BC%8C%E4%B8%AD%E5%9B%BD%E9%B8%AD%E5%AD%90%E7%94%9F%E4%BA%A7%E5%95%86%E9%9C%80%E8%A6%81%E6%8B%85%E5%BF%A7%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783729081000.webp","sourceId":"rfi"},{"id":1783728862000,"createdDate":"2026-07-11 00:14","name":"法国国际广播电台","title":"法国：高温天气对农业收成的影响逐步显现","content":"法国正在经历今年的第三波热浪，高温天气对农业的影响越来越严重。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260711-%E6%B3%95%E5%9B%BD-%E9%AB%98%E6%B8%A9%E5%A4%A9%E6%B0%94%E5%AF%B9%E5%86%9C%E4%B8%9A%E6%94%B6%E6%88%90%E7%9A%84%E5%BD%B1%E5%93%8D%E9%80%90%E6%AD%A5%E6%98%BE%E7%8E%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783728862000.webp","sourceId":"rfi"},{"id":1783761843000,"createdDate":"2026-07-11 09:24","name":"法国国际广播电台","title":"大型强台风袭击日本 8人受伤两万多户停电","content":"大型强台风9号于日本时间11日早晨接近日本先岛诸岛，随后沿台湾东部海域向北移动。目前，石垣岛已进入台风暴风圈，预计强风天气将持续至11日傍晚，长时间遭受暴风侵袭。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E5%A4%A7%E5%9E%8B%E5%BC%BA%E5%8F%B0%E9%A3%8E%E8%A2%AD%E5%87%BB%E6%97%A5%E6%9C%AC-8%E4%BA%BA%E5%8F%97%E4%BC%A4%E4%B8%A4%E4%B8%87%E5%A4%9A%E6%88%B7%E5%81%9C%E7%94%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783761843000.webp","sourceId":"rfi"},{"id":1783757786000,"createdDate":"2026-07-11 08:16","name":"法国国际广播电台","title":"朝鲜谴责北约峰会：无核化应先从美国盟友开始","content":"朝鲜周六（7月11日）谴责美国及其盟友在本周北约峰会后进一步强化其军事集团、加速军备扩张，并称“无核化”应首先针对美国盟友。官媒前日报道，朝鲜决定推进军队现代化，“在数量和质量上“加强核武能力。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E6%9C%9D%E9%B2%9C%E8%B0%B4%E8%B4%A3%E5%8C%97%E7%BA%A6%E5%B3%B0%E4%BC%9A-%E6%97%A0%E6%A0%B8%E5%8C%96%E5%BA%94%E5%85%88%E4%BB%8E%E7%BE%8E%E5%9B%BD%E7%9B%9F%E5%8F%8B%E5%BC%80%E5%A7%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783757786000.webp","sourceId":"rfi"},{"id":1783756271000,"createdDate":"2026-07-11 07:51","name":"法国国际广播电台","title":"西班牙2比1淘汰比利时，半决赛会师法国","content":"2026年世界杯四强已经确定两席。7月10日进行的一场四分之一决赛中，西班牙队以2比1击败比利时队，成功晋级半决赛，将与法国队争夺一个决赛席位。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E8%A5%BF%E7%8F%AD%E7%89%992%E6%AF%941%E6%B7%98%E6%B1%B0%E6%AF%94%E5%88%A9%E6%97%B6%EF%BC%8C%E5%8D%8A%E5%86%B3%E8%B5%9B%E4%BC%9A%E5%B8%88%E6%B3%95%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783756271000.webp","sourceId":"rfi"},{"id":1783789747000,"createdDate":"2026-07-11 17:09","name":"法国国际广播电台","title":"台风“巴维”来啦，中国近200万人撤离","content":"随着台风“巴威”逼近，中国已有近200万人被疏散。周六，该台风带来的强风和暴雨袭击了台湾及日本多个岛屿，导致数万户家庭断电。","newsLink":"https://www.rfi.fr/cn/%E7%94%9F%E6%80%81/20260711-%E5%8F%B0%E9%A3%8E-%E5%B7%B4%E7%BB%B4-%E6%9D%A5%E5%95%A6%EF%BC%8C%E4%B8%AD%E5%9B%BD%E8%BF%91200%E4%B8%87%E4%BA%BA%E6%92%A4%E7%A6%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783789747000.webp","sourceId":"rfi"},{"id":1783782932000,"createdDate":"2026-07-11 15:15","name":"法国国际广播电台","title":"俄导弹袭基辅已知6人伤 美议员称制裁俄罗斯法案有“重大进展”","content":"乌克兰官员们表示，俄罗斯周六对乌克兰首都基辅发动的弹道导弹袭击造成至少6人受伤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E4%BF%84%E5%AF%BC%E5%BC%B9%E8%A2%AD%E5%9F%BA%E8%BE%85%E5%B7%B2%E7%9F%A56%E4%BA%BA%E4%BC%A4-%E7%BE%8E%E8%AE%AE%E5%91%98%E7%A7%B0%E5%88%B6%E8%A3%81%E4%BF%84%E7%BD%97%E6%96%AF%E6%B3%95%E6%A1%88%E6%9C%89-%E9%87%8D%E5%A4%A7%E8%BF%9B%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783782932000.webp","sourceId":"rfi"},{"id":1783782072000,"createdDate":"2026-07-11 15:01","name":"法国国际广播电台","title":"伊朗称已对美守承诺 特朗普称停火已终结 要求伊朗保证霍峡畅通并停止袭击","content":"伊朗周六表示，自签署停火谅解备忘录以来，该国一直对美国“信守承诺”。唐纳德·特朗普周五再称该停火协议“已终结”，但同时表示愿意继续与德黑兰方面谈判，并顺带指责德黑兰企图暗杀他。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E4%BC%8A%E6%9C%97%E7%A7%B0%E5%B7%B2%E5%AF%B9%E7%BE%8E%E5%AE%88%E6%89%BF%E8%AF%BA-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E5%81%9C%E7%81%AB%E5%B7%B2%E7%BB%88%E7%BB%93-%E8%A6%81%E6%B1%82%E4%BC%8A%E6%9C%97%E4%BF%9D%E8%AF%81%E9%9C%8D%E5%B3%A1%E7%95%85%E9%80%9A%E5%B9%B6%E5%81%9C%E6%AD%A2%E8%A2%AD%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783782072000.webp","sourceId":"rfi"},{"id":1783773502000,"createdDate":"2026-07-11 12:38","name":"法国国际广播电台","title":"特朗普警告伊朗:1000枚导弹就绪，一旦暗杀美国总统，立即发射","content":"唐纳德·特朗普周五表示，他已要求美军做好准备，一旦德黑兰政府企图暗杀美国总统，就对伊朗发动打击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AD%A6%E5%91%8A%E4%BC%8A%E6%9C%97-1000%E6%9E%9A%E5%AF%BC%E5%BC%B9%E5%B0%B1%E7%BB%AA%EF%BC%8C%E4%B8%80%E6%97%A6%E6%9A%97%E6%9D%80%E7%BE%8E%E5%9B%BD%E6%80%BB%E7%BB%9F%EF%BC%8C%E7%AB%8B%E5%8D%B3%E5%8F%91%E5%B0%84","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783773502000.webp","sourceId":"rfi"},{"id":1783772561000,"createdDate":"2026-07-11 12:22","name":"法国国际广播电台","title":"莫迪首访新西兰 印新关系提升至战略伙伴","content":"印度总理莫迪周六（7月11日）继续其印太海域三国的访问，继印度尼西亚和澳大利亚后，莫迪周五晚抵达奥克兰，开启他对最后一站新西兰的访问。这是莫迪首次访问新西兰，也是印度总理40年来的首次访新，凸显新德里正加快推进在亚太地区“东向战略”布局。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260711-%E8%8E%AB%E8%BF%AA%E9%A6%96%E8%AE%BF%E6%96%B0%E8%A5%BF%E5%85%B0-%E5%8D%B0%E6%96%B0%E5%85%B3%E7%B3%BB%E6%8F%90%E5%8D%87%E8%87%B3%E6%88%98%E7%95%A5%E4%BC%99%E4%BC%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783772561000.webp","sourceId":"rfi"},{"id":1783771045000,"createdDate":"2026-07-11 11:57","name":"法国国际广播电台","title":"朝鲜军队高官因大规模腐败被免职","content":"法新社周六报道，一名负责朝鲜军队政治机构的高官因贪腐被免职，并被开除出劳动党。近几年来，打击腐败一直是朝鲜官方言论中的一个反复出现的主题。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E6%9C%9D%E9%B2%9C%E5%86%9B%E9%98%9F%E9%AB%98%E5%AE%98%E5%9B%A0%E5%A4%A7%E8%A7%84%E6%A8%A1%E8%85%90%E8%B4%A5%E8%A2%AB%E5%85%8D%E8%81%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783771045000.webp","sourceId":"rfi"},{"id":1783811628000,"createdDate":"2026-07-11 23:13","name":"法国国际广播电台","title":"大热门撞上大热门 法国如何跨越西班牙大关","content":"冤家路窄 !世界杯半决赛，法国队将遭遇老对手“斗牛士”西班牙，两个大热门，争夺一个世界杯决赛席位 !","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260711-%E5%A4%A7%E7%83%AD%E9%97%A8%E6%92%9E%E4%B8%8A%E5%A4%A7%E7%83%AD%E9%97%A8-%E6%B3%95%E5%9B%BD%E5%A6%82%E4%BD%95%E8%B7%A8%E8%B6%8A%E8%A5%BF%E7%8F%AD%E7%89%99%E5%A4%A7%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783811628000.webp","sourceId":"rfi"},{"id":1783806767000,"createdDate":"2026-07-11 21:52","name":"法国国际广播电台","title":"美国敦促伊朗保障霍尔木兹海峡通航　多方斡旋推动美伊恢复谈判","content":"伊朗外长阿拉格齐周六（7月11日）抵达阿曼，就确保船只安全通过霍尔木兹海峡与阿方磋商。美国则要求伊朗公开承诺停止袭击过往船只，保障这条全球重要能源运输通道自由、安全通行。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260711-%E7%BE%8E%E5%9B%BD%E6%95%A6%E4%BF%83%E4%BC%8A%E6%9C%97%E4%BF%9D%E9%9A%9C%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%80%9A%E8%88%AA-%E5%A4%9A%E6%96%B9%E6%96%A1%E6%97%8B%E6%8E%A8%E5%8A%A8%E7%BE%8E%E4%BC%8A%E6%81%A2%E5%A4%8D%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783806767000.webp","sourceId":"rfi"},{"id":1783806497000,"createdDate":"2026-07-11 21:48","name":"法国国际广播电台","title":"美国新一轮热浪来袭 约4400万人处于高温预警之下","content":"美国也将迎来新一轮高温天气。官方周六（7月11日）称，约4400万美国人目前处于高温预警之下，落基山脉地区和美国北部大平原正迎来新一轮热浪，部分地区最高气温预计将超过38摄氏度。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260711-%E7%BE%8E%E5%9B%BD%E6%96%B0%E4%B8%80%E8%BD%AE%E7%83%AD%E6%B5%AA%E6%9D%A5%E8%A2%AD-%E7%BA%A64400%E4%B8%87%E4%BA%BA%E5%A4%84%E4%BA%8E%E9%AB%98%E6%B8%A9%E9%A2%84%E8%AD%A6%E4%B9%8B%E4%B8%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783806497000.webp","sourceId":"rfi"},{"id":1783806050000,"createdDate":"2026-07-11 21:40","name":"法国国际广播电台","title":"法国超过三分之一地区发布高温红色预警 山火风险持续升高","content":"法国目前正遭遇今年夏季最严重的一轮热浪侵袭。气象部门周六（7月11日）宣布，全国超过三分之一地区将于13日进入最高级别的高温红色预警，持续高温也使山林火灾风险急剧上升。法国多地决定取消国庆烟花表演，以降低高温和火灾风险。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260711-%E6%B3%95%E5%9B%BD%E8%B6%85%E8%BF%87%E4%B8%89%E5%88%86%E4%B9%8B%E4%B8%80%E5%9C%B0%E5%8C%BA%E5%8F%91%E5%B8%83%E9%AB%98%E6%B8%A9%E7%BA%A2%E8%89%B2%E9%A2%84%E8%AD%A6-%E5%B1%B1%E7%81%AB%E9%A3%8E%E9%99%A9%E6%8C%81%E7%BB%AD%E5%8D%87%E9%AB%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783806050000.webp","sourceId":"rfi"},{"id":1783805365000,"createdDate":"2026-07-11 21:29","name":"法国国际广播电台","title":"台风“巴威”登陆浙江沿海 中国多地严阵以待 200万人疏散","content":"台风“巴威”周六（7月11日）深夜登陆中国浙江沿海，登陆时最大风速达每小时145公里。中国官方在台风来袭前已疏散近200万人，并在多地采取停工停课、交通停运等防范措施，以应对可能出现的强风暴雨。上海也加强防台措施，组织转移近30万人，并启用905处防汛避灾安置场所。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260711-%E5%8F%B0%E9%A3%8E-%E5%B7%B4%E5%A8%81-%E7%99%BB%E9%99%86%E6%B5%99%E6%B1%9F%E6%B2%BF%E6%B5%B7-%E4%B8%AD%E5%9B%BD%E5%A4%9A%E5%9C%B0%E4%B8%A5%E9%98%B5%E4%BB%A5%E5%BE%85-200%E4%B8%87%E4%BA%BA%E7%96%8F%E6%95%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783805365000.webp","sourceId":"rfi"},{"id":1783802527000,"createdDate":"2026-07-11 20:42","name":"法国国际广播电台","title":"南非国家队球员杰登·亚当斯猝逝","content":"南非体育部长宣布，刚刚随南非国家队参加完2026年世界杯的中场球员杰登·亚当斯(JaydenAdams)于周六猝然离世，年仅25岁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260711-%E5%8D%97%E9%9D%9E%E5%9B%BD%E5%AE%B6%E9%98%9F%E7%90%83%E5%91%98%E6%9D%B0%E7%99%BB%C2%B7%E4%BA%9A%E5%BD%93%E6%96%AF%E7%8C%9D%E9%80%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783802527000.webp","sourceId":"rfi"},{"id":1783802065000,"createdDate":"2026-07-11 20:34","name":"法国国际广播电台","title":"与中国竞争 德国经济学家：德国“技术中立”政策意味着“德国工业的衰落”","content":"在电动汽车产业，中国早已超越德国。德国经济研究所（DIW）经济学家马丁·戈尔尼希（MartinGornig）认为，德国政府目前的政策不足以应对中国日益增强的产业优势。但德国工业依然拥有新的发展机遇。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260711-%E4%B8%8E%E4%B8%AD%E5%9B%BD%E7%AB%9E%E4%BA%89-%E5%BE%B7%E5%9B%BD%E7%BB%8F%E6%B5%8E%E5%AD%A6%E5%AE%B6-%E5%BE%B7%E5%9B%BD-%E6%8A%80%E6%9C%AF%E4%B8%AD%E7%AB%8B-%E6%94%BF%E7%AD%96%E6%84%8F%E5%91%B3%E7%9D%80-%E5%BE%B7%E5%9B%BD%E5%B7%A5%E4%B8%9A%E7%9A%84%E8%A1%B0%E8%90%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783802065000.webp","sourceId":"rfi"},{"id":1783801736000,"createdDate":"2026-07-11 20:28","name":"法国国际广播电台","title":"美司法部传唤《纽约时报》4记者作证　涉报导特朗普新空军一号安全疑虑","content":"美国司法部向《纽约时报》（TheNewYorkTimes）4名记者发出传票，要求就报导美国总统特朗普（DonaldTrump）新“空军一号”（AirForceOne）安全疑虑一事，赴纽约曼哈顿联邦大陪审团作证，引发新闻自由团体强烈批评，认为此举进一步打压新闻自由，也是特朗普政府追查政府泄密案的最新行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260711-%E7%BE%8E%E5%8F%B8%E6%B3%95%E9%83%A8%E4%BC%A0%E5%94%A4-%E7%BA%BD%E7%BA%A6%E6%97%B6%E6%8A%A5-4%E8%AE%B0%E8%80%85%E4%BD%9C%E8%AF%81-%E6%B6%89%E6%8A%A5%E5%AF%BC%E7%89%B9%E6%9C%97%E6%99%AE%E6%96%B0%E7%A9%BA%E5%86%9B%E4%B8%80%E5%8F%B7%E5%AE%89%E5%85%A8%E7%96%91%E8%99%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783801736000.webp","sourceId":"rfi"},{"id":1783792005000,"createdDate":"2026-07-11 17:46","name":"法国国际广播电台","title":"日本宣布首次成功实现可重复使用火箭的起飞和着陆","content":"日本宇宙航空研究开发机构周六宣布，日本首次成功实现可重复使用火箭的起飞和着陆，这是该技术领域的一项重要进展，该技术尤其有助于降低航天任务的成本。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E6%97%A5%E6%9C%AC%E5%AE%A3%E5%B8%83%E9%A6%96%E6%AC%A1%E6%88%90%E5%8A%9F%E5%AE%9E%E7%8E%B0%E5%8F%AF%E9%87%8D%E5%A4%8D%E4%BD%BF%E7%94%A8%E7%81%AB%E7%AE%AD%E7%9A%84%E8%B5%B7%E9%A3%9E%E5%92%8C%E7%9D%80%E9%99%86","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783792005000.webp","sourceId":"rfi"},{"id":1783791045000,"createdDate":"2026-07-11 17:30","name":"法国国际广播电台","title":"中国宣布首次成功回收可重复使用火箭","content":"中国国家航天局周五宣布首次成功实现可重复使用火箭的回收，这是中国实现太空雄心的一项重大突破，旨在大幅降低发射成本。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260711-%E4%B8%AD%E5%9B%BD%E5%AE%A3%E5%B8%83%E9%A6%96%E6%AC%A1%E6%88%90%E5%8A%9F%E5%9B%9E%E6%94%B6%E5%8F%AF%E9%87%8D%E5%A4%8D%E4%BD%BF%E7%94%A8%E7%81%AB%E7%AE%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783791045000.webp","sourceId":"rfi"}]