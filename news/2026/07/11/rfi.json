[{"id":1783729081000,"createdDate":"2026-07-11 00:18","name":"法国国际广播电台","title":"欧盟与中国展开“北京烤鸭之战”，中国鸭子生产商需要担忧吗？","content":"法国世界报周五关注欧盟与中国的“北京烤鸭之战”。继钢铁、电动汽车和小包裹之后，如今，欧盟与中国之间的贸易摩擦又延伸到了北京烤鸭。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260711-%E6%AC%A7%E7%9B%9F%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%B1%95%E5%BC%80-%E5%8C%97%E4%BA%AC%E7%83%A4%E9%B8%AD%E4%B9%8B%E6%88%98-%EF%BC%8C%E4%B8%AD%E5%9B%BD%E9%B8%AD%E5%AD%90%E7%94%9F%E4%BA%A7%E5%95%86%E9%9C%80%E8%A6%81%E6%8B%85%E5%BF%A7%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783729081000.webp","sourceId":"rfi"},{"id":1783728862000,"createdDate":"2026-07-11 00:14","name":"法国国际广播电台","title":"法国：高温天气对农业收成的影响逐步显现","content":"法国正在经历今年的第三波热浪，高温天气对农业的影响越来越严重。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260711-%E6%B3%95%E5%9B%BD-%E9%AB%98%E6%B8%A9%E5%A4%A9%E6%B0%94%E5%AF%B9%E5%86%9C%E4%B8%9A%E6%94%B6%E6%88%90%E7%9A%84%E5%BD%B1%E5%93%8D%E9%80%90%E6%AD%A5%E6%98%BE%E7%8E%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783728862000.webp","sourceId":"rfi"},{"id":1783761843000,"createdDate":"2026-07-11 09:24","name":"法国国际广播电台","title":"大型强台风袭击日本 8人受伤两万多户停电","content":"大型强台风9号于日本时间11日早晨接近日本先岛诸岛，随后沿台湾东部海域向北移动。目前，石垣岛已进入台风暴风圈，预计强风天气将持续至11日傍晚，长时间遭受暴风侵袭。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E5%A4%A7%E5%9E%8B%E5%BC%BA%E5%8F%B0%E9%A3%8E%E8%A2%AD%E5%87%BB%E6%97%A5%E6%9C%AC-8%E4%BA%BA%E5%8F%97%E4%BC%A4%E4%B8%A4%E4%B8%87%E5%A4%9A%E6%88%B7%E5%81%9C%E7%94%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783761843000.webp","sourceId":"rfi"},{"id":1783757786000,"createdDate":"2026-07-11 08:16","name":"法国国际广播电台","title":"朝鲜谴责北约峰会：无核化应先从美国盟友开始","content":"朝鲜周六（7月11日）谴责美国及其盟友在本周北约峰会后进一步强化其军事集团、加速军备扩张，并称“无核化”应首先针对美国盟友。官媒前日报道，朝鲜决定推进军队现代化，“在数量和质量上“加强核武能力。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E6%9C%9D%E9%B2%9C%E8%B0%B4%E8%B4%A3%E5%8C%97%E7%BA%A6%E5%B3%B0%E4%BC%9A-%E6%97%A0%E6%A0%B8%E5%8C%96%E5%BA%94%E5%85%88%E4%BB%8E%E7%BE%8E%E5%9B%BD%E7%9B%9F%E5%8F%8B%E5%BC%80%E5%A7%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783757786000.webp","sourceId":"rfi"},{"id":1783756271000,"createdDate":"2026-07-11 07:51","name":"法国国际广播电台","title":"西班牙2比1淘汰比利时，半决赛会师法国","content":"2026年世界杯四强已经确定两席。7月10日进行的一场四分之一决赛中，西班牙队以2比1击败比利时队，成功晋级半决赛，将与法国队争夺一个决赛席位。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E8%A5%BF%E7%8F%AD%E7%89%992%E6%AF%941%E6%B7%98%E6%B1%B0%E6%AF%94%E5%88%A9%E6%97%B6%EF%BC%8C%E5%8D%8A%E5%86%B3%E8%B5%9B%E4%BC%9A%E5%B8%88%E6%B3%95%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783756271000.webp","sourceId":"rfi"},{"id":1783789747000,"createdDate":"2026-07-11 17:09","name":"法国国际广播电台","title":"台风“巴维”来啦，中国近200万人撤离","content":"随着台风“巴威”逼近，中国已有近200万人被疏散。周六，该台风带来的强风和暴雨袭击了台湾及日本多个岛屿，导致数万户家庭断电。","newsLink":"https://www.rfi.fr/cn/%E7%94%9F%E6%80%81/20260711-%E5%8F%B0%E9%A3%8E-%E5%B7%B4%E7%BB%B4-%E6%9D%A5%E5%95%A6%EF%BC%8C%E4%B8%AD%E5%9B%BD%E8%BF%91200%E4%B8%87%E4%BA%BA%E6%92%A4%E7%A6%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783789747000.webp","sourceId":"rfi"},{"id":1783782932000,"createdDate":"2026-07-11 15:15","name":"法国国际广播电台","title":"俄导弹袭基辅已知6人伤 美议员称制裁俄罗斯法案有“重大进展”","content":"乌克兰官员们表示，俄罗斯周六对乌克兰首都基辅发动的弹道导弹袭击造成至少6人受伤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E4%BF%84%E5%AF%BC%E5%BC%B9%E8%A2%AD%E5%9F%BA%E8%BE%85%E5%B7%B2%E7%9F%A56%E4%BA%BA%E4%BC%A4-%E7%BE%8E%E8%AE%AE%E5%91%98%E7%A7%B0%E5%88%B6%E8%A3%81%E4%BF%84%E7%BD%97%E6%96%AF%E6%B3%95%E6%A1%88%E6%9C%89-%E9%87%8D%E5%A4%A7%E8%BF%9B%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783782932000.webp","sourceId":"rfi"},{"id":1783782072000,"createdDate":"2026-07-11 15:01","name":"法国国际广播电台","title":"伊朗称已对美守承诺 特朗普称停火已终结 要求伊朗保证霍峡畅通并停止袭击","content":"伊朗周六表示，自签署停火谅解备忘录以来，该国一直对美国“信守承诺”。唐纳德·特朗普周五再称该停火协议“已终结”，但同时表示愿意继续与德黑兰方面谈判，并顺带指责德黑兰企图暗杀他。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E4%BC%8A%E6%9C%97%E7%A7%B0%E5%B7%B2%E5%AF%B9%E7%BE%8E%E5%AE%88%E6%89%BF%E8%AF%BA-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E5%81%9C%E7%81%AB%E5%B7%B2%E7%BB%88%E7%BB%93-%E8%A6%81%E6%B1%82%E4%BC%8A%E6%9C%97%E4%BF%9D%E8%AF%81%E9%9C%8D%E5%B3%A1%E7%95%85%E9%80%9A%E5%B9%B6%E5%81%9C%E6%AD%A2%E8%A2%AD%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783782072000.webp","sourceId":"rfi"},{"id":1783773502000,"createdDate":"2026-07-11 12:38","name":"法国国际广播电台","title":"特朗普警告伊朗:1000枚导弹就绪，一旦暗杀美国总统，立即发射","content":"唐纳德·特朗普周五表示，他已要求美军做好准备，一旦德黑兰政府企图暗杀美国总统，就对伊朗发动打击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AD%A6%E5%91%8A%E4%BC%8A%E6%9C%97-1000%E6%9E%9A%E5%AF%BC%E5%BC%B9%E5%B0%B1%E7%BB%AA%EF%BC%8C%E4%B8%80%E6%97%A6%E6%9A%97%E6%9D%80%E7%BE%8E%E5%9B%BD%E6%80%BB%E7%BB%9F%EF%BC%8C%E7%AB%8B%E5%8D%B3%E5%8F%91%E5%B0%84","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783773502000.webp","sourceId":"rfi"},{"id":1783772561000,"createdDate":"2026-07-11 12:22","name":"法国国际广播电台","title":"莫迪首访新西兰 印新关系提升至战略伙伴","content":"印度总理莫迪周六（7月11日）继续其印太海域三国的访问，继印度尼西亚和澳大利亚后，莫迪周五晚抵达奥克兰，开启他对最后一站新西兰的访问。这是莫迪首次访问新西兰，也是印度总理40年来的首次访新，凸显新德里正加快推进在亚太地区“东向战略”布局。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260711-%E8%8E%AB%E8%BF%AA%E9%A6%96%E8%AE%BF%E6%96%B0%E8%A5%BF%E5%85%B0-%E5%8D%B0%E6%96%B0%E5%85%B3%E7%B3%BB%E6%8F%90%E5%8D%87%E8%87%B3%E6%88%98%E7%95%A5%E4%BC%99%E4%BC%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783772561000.webp","sourceId":"rfi"},{"id":1783771045000,"createdDate":"2026-07-11 11:57","name":"法国国际广播电台","title":"朝鲜军队高官因大规模腐败被免职","content":"法新社周六报道，一名负责朝鲜军队政治机构的高官因贪腐被免职，并被开除出劳动党。近几年来，打击腐败一直是朝鲜官方言论中的一个反复出现的主题。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E6%9C%9D%E9%B2%9C%E5%86%9B%E9%98%9F%E9%AB%98%E5%AE%98%E5%9B%A0%E5%A4%A7%E8%A7%84%E6%A8%A1%E8%85%90%E8%B4%A5%E8%A2%AB%E5%85%8D%E8%81%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783771045000.webp","sourceId":"rfi"}]