[{"id":1783729081000,"createdDate":"2026-07-11 00:18","name":"法国国际广播电台","title":"欧盟与中国展开“北京烤鸭之战”，中国鸭子生产商需要担忧吗？","content":"法国世界报周五关注欧盟与中国的“北京烤鸭之战”。继钢铁、电动汽车和小包裹之后，如今，欧盟与中国之间的贸易摩擦又延伸到了北京烤鸭。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260711-%E6%AC%A7%E7%9B%9F%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%B1%95%E5%BC%80-%E5%8C%97%E4%BA%AC%E7%83%A4%E9%B8%AD%E4%B9%8B%E6%88%98-%EF%BC%8C%E4%B8%AD%E5%9B%BD%E9%B8%AD%E5%AD%90%E7%94%9F%E4%BA%A7%E5%95%86%E9%9C%80%E8%A6%81%E6%8B%85%E5%BF%A7%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783729081000.webp","sourceId":"rfi"},{"id":1783728862000,"createdDate":"2026-07-11 00:14","name":"法国国际广播电台","title":"法国：高温天气对农业收成的影响逐步显现","content":"法国正在经历今年的第三波热浪，高温天气对农业的影响越来越严重。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260711-%E6%B3%95%E5%9B%BD-%E9%AB%98%E6%B8%A9%E5%A4%A9%E6%B0%94%E5%AF%B9%E5%86%9C%E4%B8%9A%E6%94%B6%E6%88%90%E7%9A%84%E5%BD%B1%E5%93%8D%E9%80%90%E6%AD%A5%E6%98%BE%E7%8E%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783728862000.webp","sourceId":"rfi"},{"id":1783761843000,"createdDate":"2026-07-11 09:24","name":"法国国际广播电台","title":"大型强台风袭击日本 8人受伤两万多户停电","content":"大型强台风9号于日本时间11日早晨接近日本先岛诸岛，随后沿台湾东部海域向北移动。目前，石垣岛已进入台风暴风圈，预计强风天气将持续至11日傍晚，长时间遭受暴风侵袭。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E5%A4%A7%E5%9E%8B%E5%BC%BA%E5%8F%B0%E9%A3%8E%E8%A2%AD%E5%87%BB%E6%97%A5%E6%9C%AC-8%E4%BA%BA%E5%8F%97%E4%BC%A4%E4%B8%A4%E4%B8%87%E5%A4%9A%E6%88%B7%E5%81%9C%E7%94%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783761843000.webp","sourceId":"rfi"},{"id":1783757786000,"createdDate":"2026-07-11 08:16","name":"法国国际广播电台","title":"朝鲜谴责北约峰会：无核化应先从美国盟友开始","content":"朝鲜周六（7月11日）谴责美国及其盟友在本周北约峰会后进一步强化其军事集团、加速军备扩张，并称“无核化”应首先针对美国盟友。官媒前日报道，朝鲜决定推进军队现代化，“在数量和质量上“加强核武能力。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E6%9C%9D%E9%B2%9C%E8%B0%B4%E8%B4%A3%E5%8C%97%E7%BA%A6%E5%B3%B0%E4%BC%9A-%E6%97%A0%E6%A0%B8%E5%8C%96%E5%BA%94%E5%85%88%E4%BB%8E%E7%BE%8E%E5%9B%BD%E7%9B%9F%E5%8F%8B%E5%BC%80%E5%A7%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783757786000.webp","sourceId":"rfi"},{"id":1783756271000,"createdDate":"2026-07-11 07:51","name":"法国国际广播电台","title":"西班牙2比1淘汰比利时，半决赛会师法国","content":"2026年世界杯四强已经确定两席。7月10日进行的一场四分之一决赛中，西班牙队以2比1击败比利时队，成功晋级半决赛，将与法国队争夺一个决赛席位。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260711-%E8%A5%BF%E7%8F%AD%E7%89%992%E6%AF%941%E6%B7%98%E6%B1%B0%E6%AF%94%E5%88%A9%E6%97%B6%EF%BC%8C%E5%8D%8A%E5%86%B3%E8%B5%9B%E4%BC%9A%E5%B8%88%E6%B3%95%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/11/1783756271000.webp","sourceId":"rfi"}]