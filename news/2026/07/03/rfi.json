[{"id":1783075133000,"createdDate":"2026-07-03 10:38","name":"法国国际广播电台","title":"法国2027年大选：十年前马克龙清洗了旧政治阶层，如今法国人期待新篇章","content":"各位好，7月3日出刊的法国主流日刊集中关注了将于2027年4月18日和5月2日举行的两轮法国总统选举的前瞻。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260703-%E6%B3%95%E5%9B%BD2027%E5%B9%B4%E5%A4%A7%E9%80%89-%E5%8D%81%E5%B9%B4%E5%89%8D%E9%A9%AC%E5%85%8B%E9%BE%99%E6%B8%85%E6%B4%97%E4%BA%86%E6%97%A7%E6%94%BF%E6%B2%BB%E9%98%B6%E5%B1%82%EF%BC%8C%E5%A6%82%E4%BB%8A%E6%B3%95%E5%9B%BD%E4%BA%BA%E6%9C%9F%E5%BE%85%E6%96%B0%E7%AF%87%E7%AB%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783075133000.webp","sourceId":"rfi"},{"id":1783073857000,"createdDate":"2026-07-03 10:17","name":"法国国际广播电台","title":"哈梅内伊葬礼：伊朗重量级将军无惧暗杀公开露面，现任最高领袖是否也会出席？","content":"在伊朗最高领袖阿里·哈梅内伊遇袭身亡数月后，终于，伊朗民众要为他举行葬礼和安葬仪式了。此前，由于战事持续，他的葬礼一直被推迟。周五（7月3日）首先迎来的是遗体告别式，葬礼则将持续数日。此次葬礼也将成为对伊朗遭受重创的神权政权的一次考验，检验伊朗是否仍有能力组织起大规模的民众活动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260703-%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E8%91%AC%E7%A4%BC-%E4%BC%8A%E6%9C%97%E9%87%8D%E9%87%8F%E7%BA%A7%E5%B0%86%E5%86%9B%E6%97%A0%E6%83%A7%E6%9A%97%E6%9D%80%E5%85%AC%E5%BC%80%E9%9C%B2%E9%9D%A2%EF%BC%8C%E7%8E%B0%E4%BB%BB%E6%9C%80%E9%AB%98%E9%A2%86%E8%A2%96%E6%98%AF%E5%90%A6%E4%B9%9F%E4%BC%9A%E5%87%BA%E5%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783073857000.webp","sourceId":"rfi"},{"id":1783068578000,"createdDate":"2026-07-03 08:49","name":"法国国际广播电台","title":"世界杯16强最后三个名额即将决出，梅西率阿根廷迎战佛得角","content":"世界杯16强争夺赛即将在今天结束。目前16强名单仅剩三个名额，将于星期五（7月3号）晚和星期六(7月4日)凌晨决出。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260703-%E4%B8%96%E7%95%8C%E6%9D%AF16%E5%BC%BA%E6%9C%80%E5%90%8E%E4%B8%89%E4%B8%AA%E5%90%8D%E9%A2%9D%E5%8D%B3%E5%B0%86%E5%86%B3%E5%87%BA%EF%BC%8C%E6%A2%85%E8%A5%BF%E7%8E%87%E9%98%BF%E6%A0%B9%E5%BB%B7%E8%BF%8E%E6%88%98%E4%BD%9B%E5%BE%97%E8%A7%92","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783068578000.webp","sourceId":"rfi"},{"id":1783067331000,"createdDate":"2026-07-03 08:28","name":"法国国际广播电台","title":"日本首相访印度将投资两兆 莫迪与高市以兄妹相称","content":"日本首相高市早苗日本时间7月1日至3日访问印度，2日与印度总理莫迪在首脑会谈后的联合记者会上，出现了互称“兄妹”的一幕，以展现两位领导人之间的亲密关系。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260703-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E8%AE%BF%E5%8D%B0%E5%BA%A6%E5%B0%86%E6%8A%95%E8%B5%84%E4%B8%A4%E5%85%86-%E8%8E%AB%E8%BF%AA%E4%B8%8E%E9%AB%98%E5%B8%82%E4%BB%A5%E5%85%84%E5%A6%B9%E7%9B%B8%E7%A7%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783067331000.webp","sourceId":"rfi"},{"id":1783066541000,"createdDate":"2026-07-03 08:15","name":"法国国际广播电台","title":"逃离中共威权却未选择沉默而在台湾重建铜锣湾书店 店长林荣基在台病逝","content":"香港铜锣湾书店创办人林荣基，因癌症复发，于2日在台北马阶医院病逝，享寿70岁。台湾政坛、各界人士都纷纷公开悼念其坚守信念的一生。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260703-%E9%80%83%E7%A6%BB%E4%B8%AD%E5%85%B1%E5%A8%81%E6%9D%83%E5%8D%B4%E6%9C%AA%E9%80%89%E6%8B%A9%E6%B2%89%E9%BB%98%E8%80%8C%E5%9C%A8%E5%8F%B0%E6%B9%BE%E9%87%8D%E5%BB%BA%E9%93%9C%E9%94%A3%E6%B9%BE%E4%B9%A6%E5%BA%97-%E5%BA%97%E9%95%BF%E6%9E%97%E8%8D%A3%E5%9F%BA%E5%9C%A8%E5%8F%B0%E7%97%85%E9%80%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783066541000.webp","sourceId":"rfi"},{"id":1783065699000,"createdDate":"2026-07-03 08:01","name":"法国国际广播电台","title":"铜锣湾书店店长林荣基病逝 在台港人送别 赖清德发文悼念","content":"揭发中国跨境掳人的铜锣湾书店事件中的店长林荣基，因本身经历而在香港修订逃犯条例期间移居台湾七年後，昨(2日)晚在台北病逝，终年70岁。多名在台港人在他临终前赶赴医院送别，形容林荣基安详离世。不少与他相识的港台两地政界人士，以及中国异见人士，均对其死讯感到错愕，纷纷发文悼念。台湾总统赖清德形容，林荣基一生见证言论自由的可贵，留下的勇气不会消失；因香港民主派初选47人案被判囚的前立法会议员毛孟静，则对上月未能赴台与林荣基见面感到遗憾。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260703-%E9%93%9C%E9%94%A3%E6%B9%BE%E4%B9%A6%E5%BA%97%E5%BA%97%E9%95%BF%E6%9E%97%E8%8D%A3%E5%9F%BA%E7%97%85%E9%80%9D-%E5%9C%A8%E5%8F%B0%E6%B8%AF%E4%BA%BA%E9%80%81%E5%88%AB-%E8%B5%96%E6%B8%85%E5%BE%B7%E5%8F%91%E6%96%87%E6%82%BC%E5%BF%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783065699000.webp","sourceId":"rfi"},{"id":1783099361000,"createdDate":"2026-07-03 17:22","name":"法国国际广播电台","title":"曾被视为习近平劲敌: 薄瓜瓜发文曝父亲是功夫高手","content":"​​中共落马高官薄熙来之子薄瓜瓜7月3日在X平台发文，向在狱中的父亲祝福生日快乐，并突然透露自己的父亲其实是“功夫高手”。自由时报说，薄熙来曾被视为习近平劲敌，曾经都是可能接班胡锦涛的人选。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260703-%E6%9B%BE%E8%A2%AB%E8%A7%86%E4%B8%BA%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%8A%B2%E6%95%8C-%E8%96%84%E7%93%9C%E7%93%9C%E5%8F%91%E6%96%87%E6%9B%9D%E7%88%B6%E4%BA%B2%E6%98%AF%E5%8A%9F%E5%A4%AB%E9%AB%98%E6%89%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783099361000.webp","sourceId":"rfi"},{"id":1783093958000,"createdDate":"2026-07-03 15:52","name":"法国国际广播电台","title":"特朗普将在总统山发表演说 开启美国独立250周年庆典","content":"周五，唐纳德·特朗普将以拉什莫尔山（总统山）及其四位总统雕像的标志性景观为背景发表讲话，正式开启美国建国250周年的庆祝活动。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260703-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B0%86%E5%9C%A8%E6%80%BB%E7%BB%9F%E5%B1%B1%E5%8F%91%E8%A1%A8%E6%BC%94%E8%AF%B4-%E5%BC%80%E5%90%AF%E7%BE%8E%E5%9B%BD%E7%8B%AC%E7%AB%8B250%E5%91%A8%E5%B9%B4%E5%BA%86%E5%85%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783093958000.webp","sourceId":"rfi"},{"id":1783091138000,"createdDate":"2026-07-03 15:05","name":"法国国际广播电台","title":"民族团结法：北京指责批评者“散布谎言”","content":"法新社7月3日北京消息，针对一项旨在促进“民族团结”的中国新立法，北京周五敦促其他国家“停止散布谎言”；欧洲国家、联合国及人权非政府组织均认为该立法威胁到了少数群体的自由。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260703-%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E6%B3%95-%E5%8C%97%E4%BA%AC%E6%8C%87%E8%B4%A3%E6%89%B9%E8%AF%84%E8%80%85-%E6%95%A3%E5%B8%83%E8%B0%8E%E8%A8%80","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783091138000.webp","sourceId":"rfi"},{"id":1783087958000,"createdDate":"2026-07-03 14:12","name":"法国国际广播电台","title":"加拿大与菲律宾提升为战略伙伴关系","content":"加拿大总理办公室发表联合声明称，加拿大和菲律宾于周四（7月2日）同意将双边关系提升为战略伙伴关系，深化在国防、贸易和地区安全方面的合作。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260703-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E4%B8%8E%E8%8F%B2%E5%BE%8B%E5%AE%BE%E6%8F%90%E5%8D%87%E4%B8%BA%E6%88%98%E7%95%A5%E4%BC%99%E4%BC%B4%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783087958000.webp","sourceId":"rfi"},{"id":1783087437000,"createdDate":"2026-07-03 14:03","name":"法国国际广播电台","title":"燃油危机 促使俄罗斯人争相购买中国电动汽车","content":"由于燃油危机导致俄罗斯大部分地区油价飙升并发生缺油，加油站前排起长队，导致许多车主纷纷转向购买中国品牌的电动汽车。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260703-%E7%87%83%E6%B2%B9%E5%8D%B1%E6%9C%BA-%E4%BF%83%E4%BD%BF%E4%BF%84%E7%BD%97%E6%96%AF%E4%BA%BA%E4%BA%89%E7%9B%B8%E8%B4%AD%E4%B9%B0%E4%B8%AD%E5%9B%BD%E7%94%B5%E5%8A%A8%E6%B1%BD%E8%BD%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783087437000.webp","sourceId":"rfi"},{"id":1783086038000,"createdDate":"2026-07-03 13:40","name":"法国国际广播电台","title":"一名藏人在纽约联合国大楼前自焚身亡 据报生前曾强烈谴责中国通过民族团结法","content":"周四一名男子在联合国总部前自焚身亡。国际声援西藏运动主席确认死者为洛布加·朗增，称他是“一位坚持不懈捍卫西藏的人士”，“曾强烈谴责中国“民族团结法”。联合国秘书长发声明表示骇然和悲痛，并向自焚者的家人表示哀悼”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260703-%E4%B8%80%E5%90%8D%E8%97%8F%E4%BA%BA%E5%9C%A8%E7%BA%BD%E7%BA%A6%E8%81%94%E5%90%88%E5%9B%BD%E5%A4%A7%E6%A5%BC%E5%89%8D%E8%87%AA%E7%84%9A%E8%BA%AB%E4%BA%A1-%E6%8D%AE%E6%8A%A5%E7%94%9F%E5%89%8D%E6%9B%BE%E5%BC%BA%E7%83%88%E8%B0%B4%E8%B4%A3%E4%B8%AD%E5%9B%BD%E9%80%9A%E8%BF%87%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783086038000.webp","sourceId":"rfi"},{"id":1783080059000,"createdDate":"2026-07-03 12:00","name":"法国国际广播电台","title":"阿里·哈梅内伊灵柩运抵德黑兰 伊朗将在美国庆日举行国葬 中国人大副委员长前往吊丧","content":"伊朗前最高领袖阿里·哈梅内伊的灵柩于周五抵达德黑兰的一处宗教场所，四个月前他死于美以联合空袭。德黑兰打算在美国国庆期间举行一场史无前例的盛大葬礼。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260703-%E9%98%BF%E9%87%8C%C2%B7%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E7%81%B5%E6%9F%A9%E8%BF%90%E6%8A%B5%E5%BE%B7%E9%BB%91%E5%85%B0-%E4%BC%8A%E6%9C%97%E5%B0%86%E5%9C%A8%E7%BE%8E%E5%9B%BD%E5%BA%86%E6%97%A5%E4%B8%BE%E8%A1%8C%E5%9B%BD%E8%91%AC-%E4%B8%AD%E5%9B%BD%E4%BA%BA%E5%A4%A7%E5%89%AF%E5%A7%94%E5%91%98%E9%95%BF%E5%89%8D%E5%BE%80%E5%90%8A%E4%B8%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783080059000.webp","sourceId":"rfi"},{"id":1783078846000,"createdDate":"2026-07-03 11:40","name":"法国国际广播电台","title":"胜利就在眼前却最终“崩盘” 塞内加尔球员遗憾世界杯出局","content":"2026世界杯十六分之一淘汰赛，塞内加尔在对比利时的比赛中，在比赛第86分钟前塞内加尔还以2-0领先的情况下，却无奈在临近比赛结束几分钟前被连追2球，最终以2比3惜败出局。赛后，两名塞尔加尔球员在现场接受法广采访，表达他们对比赛失败的无奈和遗憾。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260703-%E8%83%9C%E5%88%A9%E6%9B%BE%E8%A7%A6%E6%89%8B%E5%8F%AF%E5%8F%8A%E5%8D%B4%E6%9C%80%E7%BB%88-%E5%B4%A9%E7%9B%98-%E5%A1%9E%E5%86%85%E5%8A%A0%E5%B0%94%E7%90%83%E5%91%98%E9%81%97%E6%86%BE%E4%B8%96%E7%95%8C%E6%9D%AF%E5%87%BA%E5%B1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783078846000.webp","sourceId":"rfi"},{"id":1783121792000,"createdDate":"2026-07-03 23:36","name":"法国国际广播电台","title":"六月热浪：欧洲“历史性的”极端天气事件","content":"欧洲多国气象专家认为，现已结束的、席卷欧洲的热浪是欧洲历史上最严重的高温事件之一。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260703-%E5%85%AD%E6%9C%88%E7%83%AD%E6%B5%AA-%E6%AC%A7%E6%B4%B2-%E5%8E%86%E5%8F%B2%E6%80%A7%E7%9A%84-%E6%9E%81%E7%AB%AF%E5%A4%A9%E6%B0%94%E4%BA%8B%E4%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783121792000.webp","sourceId":"rfi"},{"id":1783121547000,"createdDate":"2026-07-03 23:32","name":"法国国际广播电台","title":"美国独立250周年纪念：一场属于特朗普个人的庆祝活动","content":"2026年7月4日，是美国独立250周年纪念日。法国世界报周五就此发表的社论表示，相关的本应该象征国家团结的庆典，如今却更像是一场美国总统特朗普个人的自我颂扬仪式。在政治日益两极分化、国际形象持续下滑的美国，这一重要的时刻被蒙上了浓重的阴影。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260703-%E7%BE%8E%E5%9B%BD%E7%8B%AC%E7%AB%8B250%E5%91%A8%E5%B9%B4%E7%BA%AA%E5%BF%B5-%E4%B8%80%E5%9C%BA%E5%B1%9E%E4%BA%8E%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%AA%E4%BA%BA%E7%9A%84%E5%BA%86%E7%A5%9D%E6%B4%BB%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783121547000.webp","sourceId":"rfi"},{"id":1783118119000,"createdDate":"2026-07-03 22:35","name":"法国国际广播电台","title":"欧洲： “最严酷的热浪”袭击之后","content":"日前侵袭欧洲的热浪正在横扫美国东岸，纽约的体感温度可能超过破纪录的45°C，这将对美国建国250周年的庆祝活动、以及如火如荼的世界杯足球大赛造成不可忽视的影响。而刚刚逃出火炉的欧洲人，开始评估酷热造成的后果，统计不幸死于热浪的人数。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260703-%E6%AC%A7%E6%B4%B2-%E6%9C%80%E4%B8%A5%E9%85%B7%E7%9A%84%E7%83%AD%E6%B5%AA%E8%A2%AD%E5%87%BB%E4%B9%8B%E5%90%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783118119000.webp","sourceId":"rfi"},{"id":1783114870000,"createdDate":"2026-07-03 21:41","name":"法国国际广播电台","title":"英日意签署46亿英镑合同 推进第六代战斗机研发","content":"英国、日本和意大利周五（7月3日）签署总额46亿英镑的合同，为三国联合研发第六代战斗机“全球空中作战计划”（GCAP）提供资金支持。英国国防部表示，目标是在2035年让该型战斗机投入使用。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260703-%E8%8B%B1%E6%97%A5%E6%84%8F%E7%AD%BE%E7%BD%B246%E4%BA%BF%E8%8B%B1%E9%95%91%E5%90%88%E5%90%8C-%E6%8E%A8%E8%BF%9B%E7%AC%AC%E5%85%AD%E4%BB%A3%E6%88%98%E6%96%97%E6%9C%BA%E7%A0%94%E5%8F%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783114870000.webp","sourceId":"rfi"},{"id":1783114555000,"createdDate":"2026-07-03 21:35","name":"法国国际广播电台","title":"被控进行模型蒸馏 阿里巴巴据报禁用Anthropic编程工具","content":"路透社援引知情人士透露，中国科技巨头阿里巴巴禁止员工在工作中使用美国人工智能公司Anthropic推出的AI编程助手ClaudeCode。此前，该工具因具备可识别与中国有关用户的部分功能而引发关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260703-%E8%A2%AB%E6%8E%A7%E8%BF%9B%E8%A1%8C%E6%A8%A1%E5%9E%8B%E8%92%B8%E9%A6%8F-%E9%98%BF%E9%87%8C%E5%B7%B4%E5%B7%B4%E6%8D%AE%E6%8A%A5%E7%A6%81%E7%94%A8anthropic%E7%BC%96%E7%A8%8B%E5%B7%A5%E5%85%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783114555000.webp","sourceId":"rfi"},{"id":1783114380000,"createdDate":"2026-07-03 21:33","name":"法国国际广播电台","title":"气象组织：未来数月全球多地热浪等极端天气风险上升","content":"世界气象组织周五（7月3日）表示，随着热带太平洋地区厄尔尼诺条件持续增强，未来数月全球出现更强热浪和其他极端天气的可能性正在上升。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260703-%E6%B0%94%E8%B1%A1%E7%BB%84%E7%BB%87-%E6%9C%AA%E6%9D%A5%E6%95%B0%E6%9C%88%E5%85%A8%E7%90%83%E5%A4%9A%E5%9C%B0%E7%83%AD%E6%B5%AA%E7%AD%89%E6%9E%81%E7%AB%AF%E5%A4%A9%E6%B0%94%E9%A3%8E%E9%99%A9%E4%B8%8A%E5%8D%87","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783114380000.webp","sourceId":"rfi"},{"id":1783114149000,"createdDate":"2026-07-03 21:29","name":"法国国际广播电台","title":"德国就“俄军在华受训”报道紧急召见中国驻德大使","content":"德国外交部周五（7月3日）表示，德国政府日前因媒体有关俄罗斯军人在中国接受培训的报道，于2日紧急约见中国驻德国大使。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260703-%E5%BE%B7%E5%9B%BD%E5%B0%B1-%E4%BF%84%E5%86%9B%E5%9C%A8%E5%8D%8E%E5%8F%97%E8%AE%AD-%E6%8A%A5%E9%81%93%E7%B4%A7%E6%80%A5%E5%8F%AC%E8%A7%81%E4%B8%AD%E5%9B%BD%E9%A9%BB%E5%BE%B7%E5%A4%A7%E4%BD%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783114149000.webp","sourceId":"rfi"},{"id":1783113979000,"createdDate":"2026-07-03 21:26","name":"法国国际广播电台","title":"伊美停火：法国“戴高乐”号航母返回土伦港","content":"法国总统马克龙周五（7月3日）宣布，鉴于伊朗和美国6月17日达成结束敌对行动的协议，法国\"戴高乐\"号航空母舰将结束中东部署，返回母港土伦。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260703-%E4%BC%8A%E7%BE%8E%E5%81%9C%E7%81%AB%E5%90%8E-%E6%B3%95%E5%9B%BD-%E6%88%B4%E9%AB%98%E4%B9%90-%E5%8F%B7%E8%88%AA%E6%AF%8D%E8%BF%94%E5%9B%9E%E5%9C%9F%E4%BC%A6%E6%B8%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783113979000.webp","sourceId":"rfi"},{"id":1783113224000,"createdDate":"2026-07-03 21:13","name":"法国国际广播电台","title":"北约欧洲成员国及加拿大承诺两年内向乌克兰提供1400亿欧元军援","content":"北约欧洲成员国和加拿大将在下周于安卡拉举行的北约峰会上承诺，在2026年和2027年分别向乌克兰每年提供700亿欧元的军援。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260703-%E5%8C%97%E7%BA%A6%E6%AC%A7%E6%B4%B2%E6%88%90%E5%91%98%E5%9B%BD%E5%8F%8A%E5%8A%A0%E6%8B%BF%E5%A4%A7%E6%89%BF%E8%AF%BA%E4%B8%A4%E5%B9%B4%E5%86%85%E5%90%91%E4%B9%8C%E5%85%8B%E5%85%B0%E6%8F%90%E4%BE%9B1400%E4%BA%BF%E6%AC%A7%E5%85%83%E5%86%9B%E6%8F%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783113224000.webp","sourceId":"rfi"},{"id":1783112978000,"createdDate":"2026-07-03 21:09","name":"法国国际广播电台","title":"纽时：美忧以色列暗杀伊朗和谈代表曾私下示警","content":"美国官员透露，华盛顿在与伊朗推动停火谈判期间，曾担心以色列可能暗杀伊朗两名主要谈判代表，为避免和谈因此破局，美方透过中东友好国家向伊朗传递警讯，提醒注意可能的暗杀风险。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260703-%E7%BA%BD%E6%97%B6-%E7%BE%8E%E5%BF%A7%E4%BB%A5%E8%89%B2%E5%88%97%E6%9A%97%E6%9D%80%E4%BC%8A%E6%9C%97%E5%92%8C%E8%B0%88%E4%BB%A3%E8%A1%A8%E6%9B%BE%E7%A7%81%E4%B8%8B%E7%A4%BA%E8%AD%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783112978000.webp","sourceId":"rfi"},{"id":1783103235000,"createdDate":"2026-07-03 18:27","name":"法国国际广播电台","title":"【视频】委内瑞拉地震过后 救援人员在废墟中不懈搜寻生存者","content":"委内瑞拉遭遇强震一周后，救援队仍在搜寻失踪人员。在拉瓜伊拉州（LaGuaira）的卡拉巴列达（Caraballeda），灾情极其严重。在无人援助的情况下。家属们正拼命地独自清理建筑废墟，试图从中寻回亲人的遗体。每天，他们都向国际救援人员求助，希望能让亲人入土为安。本台特派记者、西班牙文组的同仁梅丽莎·巴拉（MélissaBarra）和贾德·埃尔·库里（JadElKhoury）从委内瑞拉发回了报道。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260703-%E8%A7%86%E9%A2%91-%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E5%9C%B0%E9%9C%87%E8%BF%87%E5%90%8E-%E6%95%91%E6%8F%B4%E4%BA%BA%E5%91%98%E5%9C%A8%E5%BA%9F%E5%A2%9F%E4%B8%AD%E4%B8%8D%E6%87%88%E6%90%9C%E5%AF%BB%E7%94%9F%E5%AD%98%E8%80%85","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783103235000.webp","sourceId":"rfi"},{"id":1783103084000,"createdDate":"2026-07-03 18:24","name":"法国国际广播电台","title":"越南第二季度增长8.39% 上半年外国投资飙升61%","content":"越南统计总局周五宣布，尽管受到中东战争导致的进口中断和燃料成本上涨的影响，越南4月至6月季度经济增长率仍达8.39%。世界银行本周调整后，将其归类为“中高收入”国家。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260703-%E8%B6%8A%E5%8D%97%E7%AC%AC%E4%BA%8C%E5%AD%A3%E5%BA%A6%E5%A2%9E%E9%95%BF8-39-%E4%B8%8A%E5%8D%8A%E5%B9%B4%E5%A4%96%E5%9B%BD%E6%8A%95%E8%B5%84%E9%A3%99%E5%8D%8761","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783103084000.webp","sourceId":"rfi"},{"id":1783101697000,"createdDate":"2026-07-03 18:01","name":"法国国际广播电台","title":"俄罗斯对乌克兰首都发动最猛烈空袭造成的死亡人数升至30人","content":"据救援部门表示，周五在废墟中又发现三具新遗体后，周四凌晨俄罗斯袭击基辅的死亡人数再次上调至30人。这是自战争爆发以来，俄罗斯无人机和导弹对乌克兰首都发动的最严重袭击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260703-%E4%BF%84%E7%BD%97%E6%96%AF%E5%AF%B9%E4%B9%8C%E5%85%8B%E5%85%B0%E9%A6%96%E9%83%BD%E5%8F%91%E5%8A%A8%E6%9C%80%E7%8C%9B%E7%83%88%E7%A9%BA%E8%A2%AD%E9%80%A0%E6%88%90%E7%9A%84%E6%AD%BB%E4%BA%A1%E4%BA%BA%E6%95%B0%E5%8D%87%E8%87%B330%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/03/1783101697000.webp","sourceId":"rfi"}]