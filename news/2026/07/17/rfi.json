[{"id":1784280592000,"createdDate":"2026-07-17 09:29","name":"法国国际广播电台","title":"日本在反对的声浪中通过《国旗损毁等处罚法案》","content":"惩罚损毁日本国旗行为的《国旗损毁等处罚法案》，日本时间17日上午在日本参议院全体会议上进行表决，并以执政党及部分在野党多数赞成获得通过，正式成立。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260717-%E6%97%A5%E6%9C%AC%E5%9C%A8%E5%8F%8D%E5%AF%B9%E7%9A%84%E5%A3%B0%E6%B5%AA%E4%B8%AD%E9%80%9A%E8%BF%87-%E5%9B%BD%E6%97%97%E6%8D%9F%E6%AF%81%E7%AD%89%E5%A4%84%E7%BD%9A%E6%B3%95%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784280592000.webp","sourceId":"rfi"},{"id":1784280056000,"createdDate":"2026-07-17 09:20","name":"法国国际广播电台","title":"美国动保团体发起全球连署声援“旺旺”案　舆论接力关注吁中国制定动物保护法","content":"中国广东省揭阳市流浪母犬“旺旺”及幼犬，遭4名未满14岁男童残忍虐杀事件持续延烧，风波已从中国社群平台扩大至海外。美国动物保护团体LadyFreethinker（LFT）近日正式发起国际连署，要求中国政府针对涉案男童进行密集心理矫治、依法追究监护人责任，并制定全面性的动物保护法。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260717-%E7%BE%8E%E5%9B%BD%E5%8A%A8%E4%BF%9D%E5%9B%A2%E4%BD%93%E5%8F%91%E8%B5%B7%E5%85%A8%E7%90%83%E8%BF%9E%E7%BD%B2%E5%A3%B0%E6%8F%B4-%E6%97%BA%E6%97%BA-%E6%A1%88-%E8%88%86%E8%AE%BA%E6%8E%A5%E5%8A%9B%E5%85%B3%E6%B3%A8%E5%90%81%E4%B8%AD%E5%9B%BD%E5%88%B6%E5%AE%9A%E5%8A%A8%E7%89%A9%E4%BF%9D%E6%8A%A4%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784280056000.webp","sourceId":"rfi"},{"id":1784278694000,"createdDate":"2026-07-17 08:58","name":"法国国际广播电台","title":"中国官媒AI视频将菲人描绘成猴子 菲外交部要求下架 防长斥卑劣宣传","content":"菲律宾外交部于周四晚发表声明，强烈谴责中方官媒《中国日报》发布关于2016年南海仲裁案裁决的人工智能（AI）生成视频及社论动画，这些内容将菲律宾人描绘成猴子。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260717-%E4%B8%AD%E5%9B%BD%E5%AE%98%E5%AA%92ai%E8%A7%86%E9%A2%91%E5%B0%86%E8%8F%B2%E4%BA%BA%E6%8F%8F%E7%BB%98%E6%88%90%E7%8C%B4%E5%AD%90-%E8%8F%B2%E5%A4%96%E4%BA%A4%E9%83%A8%E8%A6%81%E6%B1%82%E4%B8%8B%E6%9E%B6-%E9%98%B2%E9%95%BF%E6%96%A5%E5%8D%91%E5%8A%A3%E5%AE%A3%E4%BC%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784278694000.webp","sourceId":"rfi"},{"id":1784276981000,"createdDate":"2026-07-17 08:29","name":"法国国际广播电台","title":"日本修订皇室继承法坚持男性继承皇位：宁可收养远支皇族男性，也不允许女性继位","content":"日本国会周五（7月17日）通过了对19世纪《皇室典范》的历史性修订，坚持只有父系血统的男性才能继承皇位。具体来说，此次修订主要包括两项措施：一是允许与皇室有远亲关系的父系男性成员通过收养方式重新进入皇室，以延续未来皇位继承；二是允许女性皇族在与平民结婚后继续保留皇族身份。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260717-%E6%97%A5%E6%9C%AC%E4%BF%AE%E8%AE%A2%E7%9A%87%E5%AE%A4%E7%BB%A7%E6%89%BF%E6%B3%95-%E5%9D%9A%E6%8C%81%E7%94%B7%E6%80%A7%E7%BB%A7%E6%89%BF%E7%9A%87%E4%BD%8D%EF%BC%8C%E5%AE%81%E5%8F%AF%E6%94%B6%E5%85%BB%E8%BF%9C%E6%94%AF%E7%9A%87%E6%97%8F%E7%94%B7%E6%80%A7%EF%BC%8C%E4%B9%9F%E4%B8%8D%E5%85%81%E8%AE%B8%E5%A5%B3%E6%80%A7%E7%BB%A7%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784276981000.webp","sourceId":"rfi"},{"id":1784273756000,"createdDate":"2026-07-17 07:35","name":"法国国际广播电台","title":"台积电宣布再加码投资美国总额上冲2650亿美元 行政院将确保三个优先维护台湾科技产业生态","content":"台积电将再投资美国亚利桑那州1000亿美元，使其对美总投资金额达2650亿美元。这使台积电最终将在美拥有10座晶圆厂和2座封装厂，也是其海外布局中规模最大的生产基地。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260717-%E5%8F%B0%E7%A7%AF%E7%94%B5%E5%AE%A3%E5%B8%83%E5%86%8D%E5%8A%A0%E7%A0%81%E6%8A%95%E8%B5%84%E7%BE%8E%E5%9B%BD%E6%80%BB%E9%A2%9D%E4%B8%8A%E5%86%B22650%E4%BA%BF%E7%BE%8E%E5%85%83-%E8%A1%8C%E6%94%BF%E9%99%A2%E5%B0%86%E7%A1%AE%E4%BF%9D%E4%B8%89%E4%B8%AA%E4%BC%98%E5%85%88%E7%BB%B4%E6%8A%A4%E5%8F%B0%E6%B9%BE%E7%A7%91%E6%8A%80%E4%BA%A7%E4%B8%9A%E7%94%9F%E6%80%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784273756000.webp","sourceId":"rfi"},{"id":1784271356000,"createdDate":"2026-07-17 06:55","name":"法国国际广播电台","title":"书店抓人：港府拒设「禁书名单」　辩称免助不法者避开法网 分析料削投资信心","content":"港府高调拘捕两间独立书店负责人及员工后，官方是否应公开「禁书名单」，再次成为关注焦点。港府高层被追问时，辩称官方不制订禁书名单，是为防止有人借更改书名避过法网，但亲中学者亦承认，官方做法会令经营者陷入两难，认为值得探讨。分析认为，官方担心公开「禁书名单」，等同宣告香港已没有出版自由，但事件已向外界呈现香港正进行资讯审查，料将影响国际投资者对香港作为金融中心的信心。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260717-%E4%B9%A6%E5%BA%97%E6%8A%93%E4%BA%BA-%E6%B8%AF%E5%BA%9C%E6%8B%92%E8%AE%BE-%E7%A6%81%E4%B9%A6%E5%90%8D%E5%8D%95-%E8%BE%A9%E7%A7%B0%E5%85%8D%E5%8A%A9%E4%B8%8D%E6%B3%95%E8%80%85%E9%81%BF%E5%BC%80%E6%B3%95%E7%BD%91-%E5%88%86%E6%9E%90%E6%96%99%E5%89%8A%E6%8A%95%E8%B5%84%E4%BF%A1%E5%BF%83","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784271356000.webp","sourceId":"rfi"},{"id":1784305191000,"createdDate":"2026-07-17 16:19","name":"法国国际广播电台","title":"美议员致函特朗普促禁中国水产品进口 指涉强迫劳动与非法捕鱼威胁美国市场","content":"美国国会暨行政当局中国委员会（CECC）跨党派议员近日致函总统特朗普（DonaldTrump），呼吁发布行政命令，全面禁止由中国相关船只捕捞或在中国加工的水产品进口美国，指控中国水产品供应链涉及强迫劳动、非法捕鱼及规避监管，已损害美国渔民利益，并构成经济、食品安全及国家安全风险。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260717-%E7%BE%8E%E8%AE%AE%E5%91%98%E8%87%B4%E5%87%BD%E7%89%B9%E6%9C%97%E6%99%AE%E4%BF%83%E7%A6%81%E4%B8%AD%E5%9B%BD%E6%B0%B4%E4%BA%A7%E5%93%81%E8%BF%9B%E5%8F%A3-%E6%8C%87%E6%B6%89%E5%BC%BA%E8%BF%AB%E5%8A%B3%E5%8A%A8%E4%B8%8E%E9%9D%9E%E6%B3%95%E6%8D%95%E9%B1%BC%E5%A8%81%E8%83%81%E7%BE%8E%E5%9B%BD%E5%B8%82%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784305191000.webp","sourceId":"rfi"},{"id":1784303998000,"createdDate":"2026-07-17 15:59","name":"法国国际广播电台","title":"重庆彭水山体滑坡   至少8死34失踪","content":"中国东南部发生山体滑坡，造成至少8人死亡，34人失踪，现场搜救出18人。据中央电视台报道，滑坡发生在重庆彭水县汉葭街道，时间约为上午9点10分（格林尼治标准时间凌晨1点10分），当地已部署800多名救援人员。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260717-%E9%87%8D%E5%BA%86%E5%BD%AD%E6%B0%B4%E5%B1%B1%E4%BD%93%E6%BB%91%E5%9D%A1-%E8%87%B3%E5%B0%918%E6%AD%BB34%E5%A4%B1%E8%B8%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784303998000.webp","sourceId":"rfi"},{"id":1784303510000,"createdDate":"2026-07-17 15:51","name":"法国国际广播电台","title":"马克龙谈与默茨会谈：在涉华经贸问题上，我们的看法从未如此一致","content":"法德两国领导人周五商定，将于9月就对华贸易问题提出一份联合“路线图”；中国被指通过货币政策和政府补贴等手段，对欧洲产业进行不公平竞争。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260717-%E9%A9%AC%E5%85%8B%E9%BE%99%E8%B0%88%E4%B8%8E%E9%BB%98%E8%8C%A8%E4%BC%9A%E8%B0%88-%E5%9C%A8%E6%B6%89%E5%8D%8E%E7%BB%8F%E8%B4%B8%E9%97%AE%E9%A2%98%E4%B8%8A%EF%BC%8C%E6%88%91%E4%BB%AC%E7%9A%84%E7%9C%8B%E6%B3%95%E4%BB%8E%E6%9C%AA%E8%BF%99%E4%B9%88%E4%B8%80%E8%87%B4%E8%BF%87","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784303510000.webp","sourceId":"rfi"},{"id":1784302308000,"createdDate":"2026-07-17 15:31","name":"法国国际广播电台","title":"中美经济对决或在气候问题上见分晓：威权政权如北京更易有应对之法？","content":"美国气候变化风险专家爱丽丝·C·希尔（AliceC.Hill）日前接受法国周刊《快报》专访，据该周刊指出，若按这位研究气候变化风险专家的观点，北京与华盛顿之间的经济战争在一定程度上将取决于它们应对极端天气事件频发的适应能力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260717-%E4%B8%AD%E7%BE%8E%E7%BB%8F%E6%B5%8E%E5%AF%B9%E5%86%B3%E6%88%96%E5%9C%A8%E6%B0%94%E5%80%99%E9%97%AE%E9%A2%98%E4%B8%8A%E8%A7%81%E5%88%86%E6%99%93-%E5%A8%81%E6%9D%83%E6%94%BF%E6%9D%83%E5%A6%82%E5%8C%97%E4%BA%AC%E6%9B%B4%E6%98%93%E6%9C%89%E5%BA%94%E5%AF%B9%E4%B9%8B%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784302308000.webp","sourceId":"rfi"},{"id":1784301930000,"createdDate":"2026-07-17 15:25","name":"法国国际广播电台","title":"中国AI公司月之暗面发布全球最大开源模型 向美国领先企业发起挑战","content":"中国人工智能初创企业月之暗面（MoonshotAI）7月17日发布了新一代大语言模型KimiK3。公司表示，这是一款拥有2.8万亿参数的开源权重模型，也是目前全球规模最大的同类模型，其性能已接近美国人工智能公司Anthropic的旗舰模型。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260717-%E4%B8%AD%E5%9B%BDai%E5%85%AC%E5%8F%B8%E6%9C%88%E4%B9%8B%E6%9A%97%E9%9D%A2%E5%8F%91%E5%B8%83%E5%85%A8%E7%90%83%E6%9C%80%E5%A4%A7%E5%BC%80%E6%BA%90%E6%A8%A1%E5%9E%8B-%E5%90%91%E7%BE%8E%E5%9B%BD%E9%A2%86%E5%85%88%E4%BC%81%E4%B8%9A%E5%8F%91%E8%B5%B7%E6%8C%91%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784301930000.webp","sourceId":"rfi"},{"id":1784300630000,"createdDate":"2026-07-17 15:03","name":"法国国际广播电台","title":"中国商务部：美方已向中方确认，不再延续涉港国家紧急状态","content":"中国商务部新闻发言人周五以答记者问方式表示，近期，美方已向中方确认，第13936号行政令中的涉港国家紧急状态今年到期后不再延续，该行政令将终止。香港2019年反修例风波后，美国以维护香港民主、人权为由，实施大量涉港制裁措施。其中，第13936号行政命令是时任美国总统特朗普（DonaldTrump）于2020年7月14日签署的行政命令，目的是中止给予香港的特殊待遇并实施制裁。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260717-%E4%B8%AD%E5%9B%BD%E5%95%86%E5%8A%A1%E9%83%A8-%E7%BE%8E%E6%96%B9%E5%B7%B2%E5%90%91%E4%B8%AD%E6%96%B9%E7%A1%AE%E8%AE%A4%EF%BC%8C%E4%B8%8D%E5%86%8D%E5%BB%B6%E7%BB%AD%E6%B6%89%E6%B8%AF%E5%9B%BD%E5%AE%B6%E7%B4%A7%E6%80%A5%E7%8A%B6%E6%80%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784300630000.webp","sourceId":"rfi"},{"id":1784298290000,"createdDate":"2026-07-17 14:24","name":"法国国际广播电台","title":"受伊朗战事影响 中企正寻求降低对卡塔尔液化天然气的依赖","content":"鉴于霍尔木兹海峡航运持续不断被干扰威胁到了既有的供应链，中国的液化天然气进口商正寻求各种方案，以降低对卡塔尔的依赖。据彭博社援引知情人士报导称，包括中国石化和中国石油在内的主要国有买家，正与那些无需经由波斯湾进行运输的燃料出口商展开洽谈。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260717-%E5%8F%97%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%8B%E5%BD%B1%E5%93%8D-%E4%B8%AD%E4%BC%81%E6%AD%A3%E5%AF%BB%E6%B1%82%E9%99%8D%E4%BD%8E%E5%AF%B9%E5%8D%A1%E5%A1%94%E5%B0%94%E6%B6%B2%E5%8C%96%E5%A4%A9%E7%84%B6%E6%B0%94%E7%9A%84%E4%BE%9D%E8%B5%96","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784298290000.webp","sourceId":"rfi"},{"id":1784296539000,"createdDate":"2026-07-17 13:55","name":"法国国际广播电台","title":"台积电两纳米到五纳米芯片的专业生产能力无人能及","content":"17日出版的法国全国性大报头版主题侧重各不相同，但都以法国国内话题开篇。右翼倾向的《费加罗报》头版头条关注的是面对明年的总统选举，中右翼阵营挑选稳妥侯选人的盘算。左翼倾向的《解放报》则将美国富豪伊隆-马斯克对法国极右翼政党领导人玛丽娜-勒庞的支持以及该党由此感到的尴尬，作为头版主题。财经报刊《回声报》侧重法国政府缩减2027年政府预算的努力，天主教报刊《十字架报》则凸出法国多地出现的严重干旱。在国际版，乌克兰国防部长在总统泽连斯基推动的政府改组动作中辞职引发民间抗议以及美国和伊朗间武装冲突再起导致霍尔木兹海峡再度面对通航中断危险是各报一致关注的话题。关于中国，《回声报》引述国际能源署报告，提醒警惕关键矿产提炼生产过于集中在中国所暗含的风险。《回声报》和《费加罗报》经济副刊也都刊登文章，注意到人工智能技术发展对先进制程芯片的需求给台积电带来的巨大利润。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260717-%E5%8F%B0%E7%A7%AF%E7%94%B5%E4%B8%A4%E7%BA%B3%E7%B1%B3%E5%88%B0%E4%BA%94%E7%BA%B3%E7%B1%B3%E8%8A%AF%E7%89%87%E7%9A%84%E4%B8%93%E4%B8%9A%E7%94%9F%E4%BA%A7%E8%83%BD%E5%8A%9B%E6%97%A0%E4%BA%BA%E8%83%BD%E5%8F%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784296539000.webp","sourceId":"rfi"},{"id":1784296199000,"createdDate":"2026-07-17 13:49","name":"法国国际广播电台","title":"鲁比奥周日访马尼拉出席东盟相关会议 或会见王毅为特习会铺路受关注","content":"美国国务卿鲁比奥（MarcoRubio）将于本周末前往马尼拉，出席东盟相关会议；预计他将与中国外交部长王毅会晤，为中国国家主席习近平与美国总统特朗普可能于9月举行的峰会做准备。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260717-%E9%B2%81%E6%AF%94%E5%A5%A5%E5%91%A8%E6%97%A5%E8%AE%BF%E9%A9%AC%E5%B0%BC%E6%8B%89%E5%87%BA%E5%B8%AD%E4%B8%9C%E7%9B%9F%E7%9B%B8%E5%85%B3%E4%BC%9A%E8%AE%AE-%E6%88%96%E4%BC%9A%E8%A7%81%E7%8E%8B%E6%AF%85%E4%B8%BA%E7%89%B9%E4%B9%A0%E4%BC%9A%E9%93%BA%E8%B7%AF%E5%8F%97%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784296199000.webp","sourceId":"rfi"},{"id":1784295123000,"createdDate":"2026-07-17 13:32","name":"法国国际广播电台","title":"乌军方高层内讧：最年轻国防部长遭免职，民众上街抗议泽连斯基的决策","content":"近来，在总统泽连斯基的主导下，乌克兰政府迎来一系列高层人事改组。眼下正值乌军对俄作战开始取得成效，且俄罗斯持续发动大规模空袭之际，这场高层人事风波无疑会使乌克兰军方领导层陷入政治危机。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260717-%E4%B9%8C%E5%86%9B%E6%96%B9%E9%AB%98%E5%B1%82%E5%86%85%E8%AE%A7-%E6%9C%80%E5%B9%B4%E8%BD%BB%E5%9B%BD%E9%98%B2%E9%83%A8%E9%95%BF%E9%81%AD%E5%85%8D%E8%81%8C%EF%BC%8C%E6%B0%91%E4%BC%97%E4%B8%8A%E8%A1%97%E6%8A%97%E8%AE%AE%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E7%9A%84%E5%86%B3%E7%AD%96","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784295123000.webp","sourceId":"rfi"},{"id":1784293588000,"createdDate":"2026-07-17 13:06","name":"法国国际广播电台","title":"俾路支省补给路线遭破坏 巴基斯坦总理强调在巴中国人安全是重中之重","content":"巴基斯坦总理夏巴兹（ShehbazSharif）周五在出席活动时强调，在巴中国公民的安全“对我们而言是至为重要的”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260717-%E4%BF%BE%E8%B7%AF%E6%94%AF%E7%9C%81%E8%A1%A5%E7%BB%99%E8%B7%AF%E7%BA%BF%E9%81%AD%E7%A0%B4%E5%9D%8F-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E6%80%BB%E7%90%86%E8%AA%93%E8%A8%80%E5%9C%A8%E5%B7%B4%E4%B8%AD%E5%9B%BD%E4%BA%BA%E5%AE%89%E5%85%A8%E6%98%AF%E9%87%8D%E4%B8%AD%E4%B9%8B%E9%87%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784293588000.webp","sourceId":"rfi"},{"id":1784288491000,"createdDate":"2026-07-17 11:41","name":"法国国际广播电台","title":"美国拟收紧签证规定中国记者最长90天 北京：保留采取对等反制措施权利","content":"特朗普政府周四采取行动，将缩短针对外国留学生、文化交流访客及记者的签证有效期。美国国土安全部发布的这项新最终规则，为国际学生持有的F类签证、允许文化交流项目参与者在美国工作的J类签证，以及媒体从业人员持有的I类签证设定了固定有效期。目前，这些签证的有效期通常涵盖在美国境内的项目或受雇期间。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260717-%E7%BE%8E%E5%9B%BD%E6%8B%9F%E6%94%B6%E7%B4%A7%E7%AD%BE%E8%AF%81%E8%A7%84%E5%AE%9A%E4%B8%AD%E5%9B%BD%E8%AE%B0%E8%80%85%E6%9C%80%E9%95%BF90%E5%A4%A9-%E5%8C%97%E4%BA%AC-%E4%BF%9D%E7%95%99%E9%87%87%E5%8F%96%E5%AF%B9%E7%AD%89%E5%8F%8D%E5%88%B6%E6%8E%AA%E6%96%BD%E6%9D%83%E5%88%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784288491000.webp","sourceId":"rfi"},{"id":1784283906000,"createdDate":"2026-07-17 10:25","name":"法国国际广播电台","title":"特朗普指责中方曾试图影响2020年大选结果 北京：有关说法纯属无中生有","content":"美国总统特朗普（DonaldTrump）周四晚间在白宫发表讲话时声称，中国干预了2020年大选，而美国情报机构对此进行了掩盖。特朗普此举重新挑起了关于中方在2020年大选中所扮演角色的政治敏感争论，并直接挑战了美国情报界的评估结论——即北京方面并未试图影响选举结果。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260717-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8C%87%E8%B4%A3%E4%B8%AD%E6%96%B9%E6%9B%BE%E8%AF%95%E5%9B%BE%E5%BD%B1%E5%93%8D2020%E5%B9%B4%E5%A4%A7%E9%80%89%E7%BB%93%E6%9E%9C-%E5%8C%97%E4%BA%AC-%E6%9C%89%E5%85%B3%E8%AF%B4%E6%B3%95%E7%BA%AF%E5%B1%9E%E6%97%A0%E4%B8%AD%E7%94%9F%E6%9C%89","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784283906000.webp","sourceId":"rfi"}]