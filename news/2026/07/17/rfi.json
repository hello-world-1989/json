[{"id":1784280592000,"createdDate":"2026-07-17 09:29","name":"法国国际广播电台","title":"日本在反对的声浪中通过《国旗损毁等处罚法案》","content":"惩罚损毁日本国旗行为的《国旗损毁等处罚法案》，日本时间17日上午在日本参议院全体会议上进行表决，并以执政党及部分在野党多数赞成获得通过，正式成立。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260717-%E6%97%A5%E6%9C%AC%E5%9C%A8%E5%8F%8D%E5%AF%B9%E7%9A%84%E5%A3%B0%E6%B5%AA%E4%B8%AD%E9%80%9A%E8%BF%87-%E5%9B%BD%E6%97%97%E6%8D%9F%E6%AF%81%E7%AD%89%E5%A4%84%E7%BD%9A%E6%B3%95%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784280592000.webp","sourceId":"rfi"},{"id":1784280056000,"createdDate":"2026-07-17 09:20","name":"法国国际广播电台","title":"美国动保团体发起全球连署声援“旺旺”案　舆论接力关注吁中国制定动物保护法","content":"中国广东省揭阳市流浪母犬“旺旺”及幼犬，遭4名未满14岁男童残忍虐杀事件持续延烧，风波已从中国社群平台扩大至海外。美国动物保护团体LadyFreethinker（LFT）近日正式发起国际连署，要求中国政府针对涉案男童进行密集心理矫治、依法追究监护人责任，并制定全面性的动物保护法。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260717-%E7%BE%8E%E5%9B%BD%E5%8A%A8%E4%BF%9D%E5%9B%A2%E4%BD%93%E5%8F%91%E8%B5%B7%E5%85%A8%E7%90%83%E8%BF%9E%E7%BD%B2%E5%A3%B0%E6%8F%B4-%E6%97%BA%E6%97%BA-%E6%A1%88-%E8%88%86%E8%AE%BA%E6%8E%A5%E5%8A%9B%E5%85%B3%E6%B3%A8%E5%90%81%E4%B8%AD%E5%9B%BD%E5%88%B6%E5%AE%9A%E5%8A%A8%E7%89%A9%E4%BF%9D%E6%8A%A4%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784280056000.webp","sourceId":"rfi"},{"id":1784278694000,"createdDate":"2026-07-17 08:58","name":"法国国际广播电台","title":"中国官媒AI视频将菲人描绘成猴子 菲外交部要求下架 防长斥卑劣宣传","content":"菲律宾外交部于周四晚发表声明，强烈谴责中方官媒《中国日报》发布关于2016年南海仲裁案裁决的人工智能（AI）生成视频及社论动画，这些内容将菲律宾人描绘成猴子。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260717-%E4%B8%AD%E5%9B%BD%E5%AE%98%E5%AA%92ai%E8%A7%86%E9%A2%91%E5%B0%86%E8%8F%B2%E4%BA%BA%E6%8F%8F%E7%BB%98%E6%88%90%E7%8C%B4%E5%AD%90-%E8%8F%B2%E5%A4%96%E4%BA%A4%E9%83%A8%E8%A6%81%E6%B1%82%E4%B8%8B%E6%9E%B6-%E9%98%B2%E9%95%BF%E6%96%A5%E5%8D%91%E5%8A%A3%E5%AE%A3%E4%BC%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784278694000.webp","sourceId":"rfi"},{"id":1784276981000,"createdDate":"2026-07-17 08:29","name":"法国国际广播电台","title":"日本修订皇室继承法坚持男性继承皇位：宁可收养远支皇族男性，也不允许女性继位","content":"日本国会周五（7月17日）通过了对19世纪《皇室典范》的历史性修订，坚持只有父系血统的男性才能继承皇位。具体来说，此次修订主要包括两项措施：一是允许与皇室有远亲关系的父系男性成员通过收养方式重新进入皇室，以延续未来皇位继承；二是允许女性皇族在与平民结婚后继续保留皇族身份。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260717-%E6%97%A5%E6%9C%AC%E4%BF%AE%E8%AE%A2%E7%9A%87%E5%AE%A4%E7%BB%A7%E6%89%BF%E6%B3%95-%E5%9D%9A%E6%8C%81%E7%94%B7%E6%80%A7%E7%BB%A7%E6%89%BF%E7%9A%87%E4%BD%8D%EF%BC%8C%E5%AE%81%E5%8F%AF%E6%94%B6%E5%85%BB%E8%BF%9C%E6%94%AF%E7%9A%87%E6%97%8F%E7%94%B7%E6%80%A7%EF%BC%8C%E4%B9%9F%E4%B8%8D%E5%85%81%E8%AE%B8%E5%A5%B3%E6%80%A7%E7%BB%A7%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784276981000.webp","sourceId":"rfi"},{"id":1784273756000,"createdDate":"2026-07-17 07:35","name":"法国国际广播电台","title":"台积电宣布再加码投资美国总额上冲2650亿美元 行政院将确保三个优先维护台湾科技产业生态","content":"台积电将再投资美国亚利桑那州1000亿美元，使其对美总投资金额达2650亿美元。这使台积电最终将在美拥有10座晶圆厂和2座封装厂，也是其海外布局中规模最大的生产基地。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260717-%E5%8F%B0%E7%A7%AF%E7%94%B5%E5%AE%A3%E5%B8%83%E5%86%8D%E5%8A%A0%E7%A0%81%E6%8A%95%E8%B5%84%E7%BE%8E%E5%9B%BD%E6%80%BB%E9%A2%9D%E4%B8%8A%E5%86%B22650%E4%BA%BF%E7%BE%8E%E5%85%83-%E8%A1%8C%E6%94%BF%E9%99%A2%E5%B0%86%E7%A1%AE%E4%BF%9D%E4%B8%89%E4%B8%AA%E4%BC%98%E5%85%88%E7%BB%B4%E6%8A%A4%E5%8F%B0%E6%B9%BE%E7%A7%91%E6%8A%80%E4%BA%A7%E4%B8%9A%E7%94%9F%E6%80%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784273756000.webp","sourceId":"rfi"},{"id":1784271356000,"createdDate":"2026-07-17 06:55","name":"法国国际广播电台","title":"书店抓人：港府拒设「禁书名单」　辩称免助不法者避开法网 分析料削投资信心","content":"港府高调拘捕两间独立书店负责人及员工后，官方是否应公开「禁书名单」，再次成为关注焦点。港府高层被追问时，辩称官方不制订禁书名单，是为防止有人借更改书名避过法网，但亲中学者亦承认，官方做法会令经营者陷入两难，认为值得探讨。分析认为，官方担心公开「禁书名单」，等同宣告香港已没有出版自由，但事件已向外界呈现香港正进行资讯审查，料将影响国际投资者对香港作为金融中心的信心。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260717-%E4%B9%A6%E5%BA%97%E6%8A%93%E4%BA%BA-%E6%B8%AF%E5%BA%9C%E6%8B%92%E8%AE%BE-%E7%A6%81%E4%B9%A6%E5%90%8D%E5%8D%95-%E8%BE%A9%E7%A7%B0%E5%85%8D%E5%8A%A9%E4%B8%8D%E6%B3%95%E8%80%85%E9%81%BF%E5%BC%80%E6%B3%95%E7%BD%91-%E5%88%86%E6%9E%90%E6%96%99%E5%89%8A%E6%8A%95%E8%B5%84%E4%BF%A1%E5%BF%83","thumbnail":"","detailImage":"news/detail/rfi/2026/07/17/1784271356000.webp","sourceId":"rfi"}]