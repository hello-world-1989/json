[{"id":1784302448000,"createdDate":"2026-07-17 15:34","name":"美国之音","title":"伊朗袭击致油轮受损、一名儿童受伤，美军打击伊朗政权的军事基础设施","content":"一艘油轮星期四(7月16日)晚间在阿曼海岸附近遭到袭击，一名儿童在伊朗对卡塔尔的空袭中受伤，美国军方同时扩大对伊朗的打击范围，包括打击伊朗政权的军事基础设施。","newsLink":"https://www.voachinese.com/a/oil-tanker-hit-child-injured-in-iranian-attacks-as-us-military-targets-regime-s-military-infrastructure-20260717/8172937.html","thumbnail":"","detailImage":"news/detail/voa/2026/07/17/1784302448000.webp","sourceId":"voa"},{"id":1784323772000,"createdDate":"2026-07-17 21:29","name":"美国之音","title":"赖清德视察台湾无人机研发 盼立法院尽速通过特别预算","content":"台湾总统赖清德星期五(7月17日)表示，无人机是不对称战力的代表性武器，他呼吁立法院尽速通过无人机特别预算，支持政府打造无人攻防系统，以维护台湾安全及印太地区和平稳定。","newsLink":"https://www.voachinese.com/a/taiwan-president-called-for-support-of-drone-spending-in-building-asymmetric-capabilities-to-countering-china-s-grey-zone-coercion-20260717/8173040.html","thumbnail":"","detailImage":"news/detail/voa/2026/07/17/1784323772000.webp","sourceId":"voa"},{"id":1784323085000,"createdDate":"2026-07-17 21:18","name":"美国之音","title":" 美议员致函美证交会主席，呼吁限制美国资本流入中国军事企业","content":"两名共和党议员致函美国证券交易委员会(SEC)负责人，要求这家金融监管机构考虑限制美国资本流入在美国上市的中国公司。","newsLink":"https://www.voachinese.com/a/us-lawmakers-call-on-sec-to-restrict-capital-flows-to-chinese-military-companies-20260717/8173047.html","thumbnail":"","detailImage":"news/detail/voa/2026/07/17/1784323085000.webp","sourceId":"voa"},{"id":1784315737000,"createdDate":"2026-07-17 19:15","name":"美国之音","title":"美众议员推出法案，旨在阻止中国企业收购美国通用航空公司","content":"两名共和党众议员推出一部法案，旨在阻止中国收购美国的通用航空公司。","newsLink":"https://www.voachinese.com/a/us-representatives-introduced-bill-aimed-at-stopping-chinese-companies-from-acquiring-american-general-aviation-companies-20260717/8173007.html","thumbnail":"","detailImage":"news/detail/voa/2026/07/17/1784315737000.webp","sourceId":"voa"},{"id":1784314649000,"createdDate":"2026-07-17 18:57","name":"美国之音","title":"野火烟雾将有害空气从美国中西部带到了东海岸","content":"美国中西部和东海岸的官员星期五(7月17日)警告民众待在室内，来自明尼苏达州和加拿大的野火产生的危险烟雾同时笼罩了几千万人的居住地。","newsLink":"http