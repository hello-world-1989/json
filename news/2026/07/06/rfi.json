[{"id":1783339703000,"createdDate":"2026-07-06 12:08","name":"法国国际广播电台","title":"北约峰会前 乌克兰首都再遭俄罗斯致命空袭  获救居民心存余悸","content":"周一（7月6号），俄罗斯再次空袭基辅地区，造成至少14人死亡。法新社记者目睹了数十起爆炸。此次空袭发生在北约峰会在安卡拉召开（7日至8日）的前夕。乌克兰总统泽连斯基计划在北约峰会上与美国总统特朗普会晤，希望在俄罗斯大规模入侵乌克兰四年多后，重启陷入停滞的和平进程。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E5%8C%97%E7%BA%A6%E5%B3%B0%E4%BC%9A%E5%89%8D-%E4%B9%8C%E5%85%8B%E5%85%B0%E9%A6%96%E9%83%BD%E5%86%8D%E9%81%AD%E4%BF%84%E7%BD%97%E6%96%AF%E8%87%B4%E5%91%BD%E7%A9%BA%E8%A2%AD-%E8%8E%B7%E6%95%91%E5%B1%85%E6%B0%91%E5%BF%83%E5%AD%98%E4%BD%99%E6%82%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783339703000.webp","sourceId":"rfi"},{"id":1783338471000,"createdDate":"2026-07-06 11:47","name":"法国国际广播电台","title":"英国进一步收紧海外政治捐款规定 以遏制外国“可疑资金”干政","content":"英国周一收紧了针对海外政治捐款的规定，旨在防止外国资金影响选举，同时也为了应对外界对英国住房、社区和地方政府大臣里德（SteveReed）所提出的“可疑资金”问题的担忧。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260706-%E8%8B%B1%E5%9B%BD%E8%BF%9B%E4%B8%80%E6%AD%A5%E6%94%B6%E7%B4%A7%E6%B5%B7%E5%A4%96%E6%94%BF%E6%B2%BB%E6%8D%90%E6%AC%BE%E8%A7%84%E5%AE%9A-%E4%BB%A5%E9%81%8F%E5%88%B6%E5%A4%96%E5%9B%BD-%E5%8F%AF%E7%96%91%E8%B5%84%E9%87%91-%E5%B9%B2%E6%94%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783338471000.webp","sourceId":"rfi"},{"id":1783335026000,"createdDate":"2026-07-06 10:50","name":"法国国际广播电台","title":"中俄军演 将在日本周边联合巡航","content":"中国国防部于5日宣布，中俄两国海军将于7月内在山东省青岛附近海域举行联合军事演习“海上联合-2026”。演习结束后，部分部队将转移至太平洋，实施“海上联合巡航”，预计将航经日本周边海域。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E4%B8%AD%E4%BF%84%E5%86%9B%E6%BC%94-%E5%B0%86%E5%9C%A8%E6%97%A5%E6%9C%AC%E5%91%A8%E8%BE%B9%E8%81%94%E5%90%88%E5%B7%A1%E8%88%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783335026000.webp","sourceId":"rfi"},{"id":1783334631000,"createdDate":"2026-07-06 10:43","name":"法国国际广播电台","title":"澳洲和斐济签署含共同防御条款的“和平之洋联盟”条约 新西兰总理指有意加入","content":"澳大利亚和位于西南太平洋中心的斐济周一在“武瓦莱联盟”安全与发展条约的基础上，又达成了一项新的防务联盟条约，这一重大进展可能会重塑太平洋地区的战略格局。武瓦莱是斐济语中家庭的意思。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E6%BE%B3%E6%B4%B2%E5%92%8C%E6%96%90%E6%B5%8E%E7%AD%BE%E7%BD%B2%E5%90%AB%E5%85%B1%E5%90%8C%E9%98%B2%E5%BE%A1%E6%9D%A1%E6%AC%BE%E7%9A%84-%E5%92%8C%E5%B9%B3%E4%B9%8B%E6%B4%8B%E8%81%94%E7%9B%9F-%E6%9D%A1%E7%BA%A6-%E6%96%B0%E8%A5%BF%E5%85%B0%E6%80%BB%E7%90%86%E6%8C%87%E6%9C%89%E6%84%8F%E5%8A%A0%E5%85%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783334631000.webp","sourceId":"rfi"},{"id":1783334315000,"createdDate":"2026-07-06 10:38","name":"法国国际广播电台","title":"挪威首次闯入世界杯8强 哈兰德赛后专访：这一切太梦幻了","content":"2026年7月5日，挪威在一场艰苦而扣人心弦的比赛中，以2比1战胜巴西，历史上首次闯入世界杯八强。接下来，他们将在四分之一决赛中迎战英格兰。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E6%8C%AA%E5%A8%81%E9%A6%96%E6%AC%A1%E9%97%AF%E5%85%A5%E4%B8%96%E7%95%8C%E6%9D%AF8%E5%BC%BA-%E5%93%88%E5%85%B0%E5%BE%B7%E8%B5%9B%E5%90%8E%E4%B8%93%E8%AE%BF-%E8%BF%99%E4%B8%80%E5%88%87%E5%A4%AA%E6%A2%A6%E5%B9%BB%E4%BA%86","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783334315000.webp","sourceId":"rfi"},{"id":1783332026000,"createdDate":"2026-07-06 10:00","name":"法国国际广播电台","title":"委内瑞拉地震遇难者达3342人，临时政府面临人类史重大灾难与政治考验","content":"委内瑞拉两次强震造成的灾情持续扩大。根据委内瑞拉信息部公布的最新数据，地震已造成至少3342人死亡，16470人受伤，另有17345人无家可归。这场灾难也正演变为一场政治考验。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E5%9C%B0%E9%9C%87%E9%81%87%E9%9A%BE%E8%80%85%E8%BE%BE3342%E4%BA%BA%EF%BC%8C%E4%B8%B4%E6%97%B6%E6%94%BF%E5%BA%9C%E9%9D%A2%E4%B8%B4%E4%BA%BA%E7%B1%BB%E5%8F%B2%E9%87%8D%E5%A4%A7%E7%81%BE%E9%9A%BE%E4%B8%8E%E6%94%BF%E6%B2%BB%E8%80%83%E9%AA%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783332026000.webp","sourceId":"rfi"},{"id":1783331725000,"createdDate":"2026-07-06 09:55","name":"法国国际广播电台","title":"中方向太平洋试射潜射战略导弹 日澳新表关切 新西兰外长指不受欢迎","content":"据官媒新华社报导称，7月6日12时01分，解放军海军1艘战略核潜艇向太平洋相关公海海域，成功发射1发携载训练模拟弹头的潜射战略导弹，准确落入预定海域。此次导弹试射是中方年度军事训练的例行性安排，已事先向有关国家作了通报，符合国际法和国际惯例，不针对任何特定国家和目标。然而，中方此举引发了日本、澳大利亚和新西兰等国的关切与批评。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E4%B8%AD%E6%96%B9%E5%90%91%E5%A4%AA%E5%B9%B3%E6%B4%8B%E8%AF%95%E5%B0%84%E6%BD%9C%E5%B0%84%E6%88%98%E7%95%A5%E5%AF%BC%E5%BC%B9-%E6%97%A5%E6%BE%B3%E6%96%B0%E8%A1%A8%E5%85%B3%E5%88%87-%E6%96%B0%E8%A5%BF%E5%85%B0%E5%A4%96%E9%95%BF%E6%8C%87%E4%B8%8D%E5%8F%97%E6%AC%A2%E8%BF%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783331725000.webp","sourceId":"rfi"},{"id":1783328696000,"createdDate":"2026-07-06 09:04","name":"法国国际广播电台","title":"中俄军演今日开启，中国核潜艇同步试射导弹，北京称已提前通报相关方，多国表担忧","content":"7月6日，中俄年度联合海军演习正式开启。同一天，中国人民解放军海军一艘战略核动力导弹潜艇在太平洋国际水域方向成功发射了一枚战略导弹。根据中国官方发布的消息，此次发射的导弹搭载的是一枚装有模拟装药的训练弹头，并未携带核弹头。官方表示，导弹最终落入预定海域。中国方面将此次行动定义为年度例行军事训练的一部分，并表示有关安排符合国际法和国际惯例，不针对任何特定国家或目标。近年来，北京与以美国、澳大利亚为代表的西方国家持续争夺太平洋岛国地区的影响力，而中国也不断扩大其在南太平洋的经济和安全合作。本次中方的导弹试射，引发了周边国家的强烈关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260706-%E4%B8%AD%E4%BF%84%E5%86%9B%E6%BC%94%E4%BB%8A%E6%97%A5%E5%BC%80%E5%90%AF%EF%BC%8C%E4%B8%AD%E5%9B%BD%E6%A0%B8%E6%BD%9C%E8%89%87%E5%90%8C%E6%AD%A5%E8%AF%95%E5%B0%84%E5%AF%BC%E5%BC%B9%EF%BC%8C%E5%8C%97%E4%BA%AC%E7%A7%B0%E5%B7%B2%E6%8F%90%E5%89%8D%E9%80%9A%E6%8A%A5%E7%9B%B8%E5%85%B3%E6%96%B9%EF%BC%8C%E5%A4%9A%E5%9B%BD%E4%BB%8D%E8%A1%A8%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783328696000.webp","sourceId":"rfi"},{"id":1783327242000,"createdDate":"2026-07-06 08:40","name":"法国国际广播电台","title":"矢板明夫台中遭挥拳攻击 犯案黑衣男机场落网","content":"据中央社报导，印太战略智库执行长矢板明夫受邀担任春雨文教基金会在台中市举办的营队讲师，当地时间周一中午结束离开饭店时，遭不明人士尾随挥拳攻击脸部，经工作人员送医后，随即前往警方报案。联合新闻网等媒体最新消息指，警方周一下午4时许，在台中机场将涉案廖姓男子缉捕到案，依伤害罪侦办，将建请检察官声请羁押。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260706-%E7%9F%A2%E6%9D%BF%E6%98%8E%E5%A4%AB%E5%8F%B0%E4%B8%AD%E9%81%AD%E6%8C%A5%E6%8B%B3%E6%94%BB%E5%87%BB-%E7%8A%AF%E6%A1%88%E9%BB%91%E8%A1%A3%E7%94%B7%E6%9C%BA%E5%9C%BA%E8%90%BD%E7%BD%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783327242000.webp","sourceId":"rfi"},{"id":1783324125000,"createdDate":"2026-07-06 07:48","name":"法国国际广播电台","title":"阿维尼翁镜面般反映法国政治生活： 舞台既给前总统， 也给总统候选人","content":"艺术节期间的阿维尼翁，戏里戏外，法国的政治生活也成了舞台艺术关心，关照和反映的内容。戏里面，演员们演前总统萨科齐和奥朗德。戏外，阿维尼翁艺术节和剧团协会邀请相当下届法国总统的政治家上台讲文化政策。7月5日是第一位受邀的政治家贝特朗。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260706-%E9%98%BF%E7%BB%B4%E5%B0%BC%E7%BF%81%E9%95%9C%E9%9D%A2%E8%88%AC%E5%8F%8D%E6%98%A0%E6%B3%95%E5%9B%BD%E6%94%BF%E6%B2%BB%E7%94%9F%E6%B4%BB-%E8%88%9E%E5%8F%B0%E6%97%A2%E7%BB%99%E5%89%8D%E6%80%BB%E7%BB%9F%EF%BC%8C-%E4%B9%9F%E7%BB%99%E6%80%BB%E7%BB%9F%E5%80%99%E9%80%89%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783324125000.webp","sourceId":"rfi"},{"id":1783323587000,"createdDate":"2026-07-06 07:39","name":"法国国际广播电台","title":"陆妇来港产子婴变脑瘫 追责16年终得迟来公义 医生被除牌九个月","content":"中国内地妇人16年前来香港产子，但婴儿出生三天後出院时，发现患上脑瘫，涉事夫妇向香港医务委员会(医委会)投诉，一直到昨(5日)早才获医委会裁定，涉事的儿科医生薜守智未有在男婴首次出现「新生儿癫痫」後立刻返回医院处理，属专业失当，且薛未有悔意，须立即除牌九个月。涉事夫妇认为这虽是迟来的公义，但惩处属恰当，日後会透过民事向医生及医疗机构索偿。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260706-%E9%99%86%E5%A6%87%E6%9D%A5%E6%B8%AF%E4%BA%A7%E5%AD%90%E5%A9%B4%E5%8F%98%E8%84%91%E7%98%AB-%E8%BF%BD%E8%B4%A316%E5%B9%B4%E7%BB%88%E5%BE%97%E8%BF%9F%E6%9D%A5%E5%85%AC%E4%B9%89-%E5%8C%BB%E7%94%9F%E8%A2%AB%E9%99%A4%E7%89%8C%E4%B9%9D%E4%B8%AA%E6%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783323587000.webp","sourceId":"rfi"},{"id":1783322813000,"createdDate":"2026-07-06 07:26","name":"法国国际广播电台","title":"金管局：香港已将人民币幅射至12国 未来数周推更多人民币国际化措施","content":"在人民币於全球国际支付中占比逐年下降丶而中国卻在「十五五」经济规划中声言要建设金融强国之际，香港这个全球最大的离岸人民币中心正努力协助人民币国际化「提速」。金融管理局总裁余伟文透露，该局已将人民币业务资金安排总额度倍增至2000亿元人民币(折合约258亿欧元)，并经香港的银行体系，联汇至12个不同国家及地区。预计未来数周，将会有更多关於人民币国际化和债券市场的措施推出。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260706-%E9%87%91%E7%AE%A1%E5%B1%80-%E9%A6%99%E6%B8%AF%E5%B7%B2%E5%B0%86%E4%BA%BA%E6%B0%91%E5%B8%81%E5%B9%85%E5%B0%84%E8%87%B312%E5%9B%BD-%E6%9C%AA%E6%9D%A5%E6%95%B0%E5%91%A8%E6%8E%A8%E6%9B%B4%E5%A4%9A%E4%BA%BA%E5%B8%81%E5%9B%BD%E9%99%85%E5%8C%96%E6%8E%AA%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783322813000.webp","sourceId":"rfi"},{"id":1783322398000,"createdDate":"2026-07-06 07:19","name":"法国国际广播电台","title":"欧洲思想文化长廊：希腊：欧洲文化永不磨灭的光辉第1 ：米洛文明：照亮希腊的曙光 （上）","content":"我们已经走遍欧洲，沿途观赏了无数瑰丽的文化景观，文艺复兴、宗教改革、英国的宪政、哲学和诗歌、德国浪漫主义，但这些文化景观都有一个共同的源泉，那就是古代希腊。王尔德说：“我们现代生活中的一切都受惠于希腊人。”雪莱更干脆宣称：“我们都是希腊人”。德国浪漫派同仁言必称希腊，拜伦甚至为希腊献出生命。他的一首《哀希腊》道尽了欧洲文人对希腊的无尽向往和哀思。今天我们回到希腊，来寻找崇敬希腊的理由。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260706-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%B8%8C%E8%85%8A-%E6%AC%A7%E6%B4%B2%E6%96%87%E5%8C%96%E6%B0%B8%E4%B8%8D%E7%A3%A8%E7%81%AD%E7%9A%84%E5%85%89%E8%BE%89%E7%AC%AC1-%E7%B1%B3%E6%B4%9B%E6%96%87%E6%98%8E-%E7%85%A7%E4%BA%AE%E5%B8%8C%E8%85%8A%E7%9A%84%E6%9B%99%E5%85%89-%E4%B8%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783322398000.webp","sourceId":"rfi"}]