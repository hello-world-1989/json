[{"id":1783339703000,"createdDate":"2026-07-06 12:08","name":"法国国际广播电台","title":"北约峰会前 乌克兰首都再遭俄罗斯致命空袭  获救居民心存余悸","content":"周一（7月6号），俄罗斯再次空袭基辅地区，造成至少14人死亡。法新社记者目睹了数十起爆炸。此次空袭发生在北约峰会在安卡拉召开（7日至8日）的前夕。乌克兰总统泽连斯基计划在北约峰会上与美国总统特朗普会晤，希望在俄罗斯大规模入侵乌克兰四年多后，重启陷入停滞的和平进程。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E5%8C%97%E7%BA%A6%E5%B3%B0%E4%BC%9A%E5%89%8D-%E4%B9%8C%E5%85%8B%E5%85%B0%E9%A6%96%E9%83%BD%E5%86%8D%E9%81%AD%E4%BF%84%E7%BD%97%E6%96%AF%E8%87%B4%E5%91%BD%E7%A9%BA%E8%A2%AD-%E8%8E%B7%E6%95%91%E5%B1%85%E6%B0%91%E5%BF%83%E5%AD%98%E4%BD%99%E6%82%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783339703000.webp","sourceId":"rfi"},{"id":1783338471000,"createdDate":"2026-07-06 11:47","name":"法国国际广播电台","title":"英国进一步收紧海外政治捐款规定 以遏制外国“可疑资金”干政","content":"英国周一收紧了针对海外政治捐款的规定，旨在防止外国资金影响选举，同时也为了应对外界对英国住房、社区和地方政府大臣里德（SteveReed）所提出的“可疑资金”问题的担忧。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260706-%E8%8B%B1%E5%9B%BD%E8%BF%9B%E4%B8%80%E6%AD%A5%E6%94%B6%E7%B4%A7%E6%B5%B7%E5%A4%96%E6%94%BF%E6%B2%BB%E6%8D%90%E6%AC%BE%E8%A7%84%E5%AE%9A-%E4%BB%A5%E9%81%8F%E5%88%B6%E5%A4%96%E5%9B%BD-%E5%8F%AF%E7%96%91%E8%B5%84%E9%87%91-%E5%B9%B2%E6%94%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783338471000.webp","sourceId":"rfi"},{"id":1783335026000,"createdDate":"2026-07-06 10:50","name":"法国国际广播电台","title":"中俄军演 将在日本周边联合巡航","content":"中国国防部于5日宣布，中俄两国海军将于7月内在山东省青岛附近海域举行联合军事演习“海上联合-2026”。演习结束后，部分部队将转移至太平洋，实施“海上联合巡航”，预计将航经日本周边海域。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E4%B8%AD%E4%BF%84%E5%86%9B%E6%BC%94-%E5%B0%86%E5%9C%A8%E6%97%A5%E6%9C%AC%E5%91%A8%E8%BE%B9%E8%81%94%E5%90%88%E5%B7%A1%E8%88%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783335026000.webp","sourceId":"rfi"},{"id":1783334631000,"createdDate":"2026-07-06 10:43","name":"法国国际广播电台","title":"澳洲和斐济签署含共同防御条款的“和平之洋联盟”条约 新西兰总理指有意加入","content":"澳大利亚和位于西南太平洋中心的斐济周一在“武瓦莱联盟”安全与发展条约的基础上，又达成了一项新的防务联盟条约，这一重大进展可能会重塑太平洋地区的战略格局。武瓦莱是斐济语中家庭的意思。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E6%BE%B3%E6%B4%B2%E5%92%8C%E6%96%90%E6%B5%8E%E7%AD%BE%E7%BD%B2%E5%90%AB%E5%85%B1%E5%90%8C%E9%98%B2%E5%BE%A1%E6%9D%A1%E6%AC%BE%E7%9A%84-%E5%92%8C%E5%B9%B3%E4%B9%8B%E6%B4%8B%E8%81%94%E7%9B%9F-%E6%9D%A1%E7%BA%A6-%E6%96%B0%E8%A5%BF%E5%85%B0%E6%80%BB%E7%90%86%E6%8C%87%E6%9C%89%E6%84%8F%E5%8A%A0%E5%85%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783334631000.webp","sourceId":"rfi"},{"id":1783334315000,"createdDate":"2026-07-06 10:38","name":"法国国际广播电台","title":"挪威首次闯入世界杯8强 哈兰德赛后专访：这一切太梦幻了","content":"2026年7月5日，挪威在一场艰苦而扣人心弦的比赛中，以2比1战胜巴西，历史上首次闯入世界杯八强。接下来，他们将在四分之一决赛中迎战英格兰。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E6%8C%AA%E5%A8%81%E9%A6%96%E6%AC%A1%E9%97%AF%E5%85%A5%E4%B8%96%E7%95%8C%E6%9D%AF8%E5%BC%BA-%E5%93%88%E5%85%B0%E5%BE%B7%E8%B5%9B%E5%90%8E%E4%B8%93%E8%AE%BF-%E8%BF%99%E4%B8%80%E5%88%87%E5%A4%AA%E6%A2%A6%E5%B9%BB%E4%BA%86","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783334315000.webp","sourceId":"rfi"},{"id":1783332026000,"createdDate":"2026-07-06 10:00","name":"法国国际广播电台","title":"委内瑞拉地震遇难者达3342人，临时政府面临人类史重大灾难与政治考验","content":"委内瑞拉两次强震造成的灾情持续扩大。根据委内瑞拉信息部公布的最新数据，地震已造成至少3342人死亡，16470人受伤，另有17345人无家可归。这场灾难也正演变为一场政治考验。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E5%9C%B0%E9%9C%87%E9%81%87%E9%9A%BE%E8%80%85%E8%BE%BE3342%E4%BA%BA%EF%BC%8C%E4%B8%B4%E6%97%B6%E6%94%BF%E5%BA%9C%E9%9D%A2%E4%B8%B4%E4%BA%BA%E7%B1%BB%E5%8F%B2%E9%87%8D%E5%A4%A7%E7%81%BE%E9%9A%BE%E4%B8%8E%E6%94%BF%E6%B2%BB%E8%80%83%E9%AA%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783332026000.webp","sourceId":"rfi"},{"id":1783331725000,"createdDate":"2026-07-06 09:55","name":"法国国际广播电台","title":"中方向太平洋试射潜射战略导弹 日澳新表关切 新西兰外长指不受欢迎","content":"据官媒新华社报导称，7月6日12时01分，解放军海军1艘战略核潜艇向太平洋相关公海海域，成功发射1发携载训练模拟弹头的潜射战略导弹，准确落入预定海域。此次导弹试射是中方年度军事训练的例行性安排，已事先向有关国家作了通报，符合国际法和国际惯例，不针对任何特定国家和目标。然而，中方此举引发了日本、澳大利亚和新西兰等国的关切与批评。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E4%B8%AD%E6%96%B9%E5%90%91%E5%A4%AA%E5%B9%B3%E6%B4%8B%E8%AF%95%E5%B0%84%E6%BD%9C%E5%B0%84%E6%88%98%E7%95%A5%E5%AF%BC%E5%BC%B9-%E6%97%A5%E6%BE%B3%E6%96%B0%E8%A1%A8%E5%85%B3%E5%88%87-%E6%96%B0%E8%A5%BF%E5%85%B0%E5%A4%96%E9%95%BF%E6%8C%87%E4%B8%8D%E5%8F%97%E6%AC%A2%E8%BF%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783331725000.webp","sourceId":"rfi"},{"id":1783328696000,"createdDate":"2026-07-06 09:04","name":"法国国际广播电台","title":"中俄军演今日开启，中国核潜艇同步试射导弹，北京称已提前通报相关方，多国表担忧","content":"7月6日，中俄年度联合海军演习正式开启。同一天，中国人民解放军海军一艘战略核动力导弹潜艇在太平洋国际水域方向成功发射了一枚战略导弹。根据中国官方发布的消息，此次发射的导弹搭载的是一枚装有模拟装药的训练弹头，并未携带核弹头。官方表示，导弹最终落入预定海域。中国方面将此次行动定义为年度例行军事训练的一部分，并表示有关安排符合国际法和国际惯例，不针对任何特定国家或目标。近年来，北京与以美国、澳大利亚为代表的西方国家持续争夺太平洋岛国地区的影响力，而中国也不断扩大其在南太平洋的经济和安全合作。本次中方的导弹试射，引发了周边国家的强烈关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260706-%E4%B8%AD%E4%BF%84%E5%86%9B%E6%BC%94%E4%BB%8A%E6%97%A5%E5%BC%80%E5%90%AF%EF%BC%8C%E4%B8%AD%E5%9B%BD%E6%A0%B8%E6%BD%9C%E8%89%87%E5%90%8C%E6%AD%A5%E8%AF%95%E5%B0%84%E5%AF%BC%E5%BC%B9%EF%BC%8C%E5%8C%97%E4%BA%AC%E7%A7%B0%E5%B7%B2%E6%8F%90%E5%89%8D%E9%80%9A%E6%8A%A5%E7%9B%B8%E5%85%B3%E6%96%B9%EF%BC%8C%E5%A4%9A%E5%9B%BD%E4%BB%8D%E8%A1%A8%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783328696000.webp","sourceId":"rfi"},{"id":1783327242000,"createdDate":"2026-07-06 08:40","name":"法国国际广播电台","title":"矢板明夫台中遭挥拳攻击 犯案黑衣男机场落网","content":"据中央社报导，印太战略智库执行长矢板明夫受邀担任春雨文教基金会在台中市举办的营队讲师，当地时间周一中午结束离开饭店时，遭不明人士尾随挥拳攻击脸部，经工作人员送医后，随即前往警方报案。联合新闻网等媒体最新消息指，警方周一下午4时许，在台中机场将涉案廖姓男子缉捕到案，依伤害罪侦办，将建请检察官声请羁押。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260706-%E7%9F%A2%E6%9D%BF%E6%98%8E%E5%A4%AB%E5%8F%B0%E4%B8%AD%E9%81%AD%E6%8C%A5%E6%8B%B3%E6%94%BB%E5%87%BB-%E7%8A%AF%E6%A1%88%E9%BB%91%E8%A1%A3%E7%94%B7%E6%9C%BA%E5%9C%BA%E8%90%BD%E7%BD%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783327242000.webp","sourceId":"rfi"},{"id":1783324125000,"createdDate":"2026-07-06 07:48","name":"法国国际广播电台","title":"阿维尼翁镜面般反映法国政治生活： 舞台既给前总统， 也给总统候选人","content":"艺术节期间的阿维尼翁，戏里戏外，法国的政治生活也成了舞台艺术关心，关照和反映的内容。戏里面，演员们演前总统萨科齐和奥朗德。戏外，阿维尼翁艺术节和剧团协会邀请相当下届法国总统的政治家上台讲文化政策。7月5日是第一位受邀的政治家贝特朗。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260706-%E9%98%BF%E7%BB%B4%E5%B0%BC%E7%BF%81%E9%95%9C%E9%9D%A2%E8%88%AC%E5%8F%8D%E6%98%A0%E6%B3%95%E5%9B%BD%E6%94%BF%E6%B2%BB%E7%94%9F%E6%B4%BB-%E8%88%9E%E5%8F%B0%E6%97%A2%E7%BB%99%E5%89%8D%E6%80%BB%E7%BB%9F%EF%BC%8C-%E4%B9%9F%E7%BB%99%E6%80%BB%E7%BB%9F%E5%80%99%E9%80%89%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783324125000.webp","sourceId":"rfi"},{"id":1783323587000,"createdDate":"2026-07-06 07:39","name":"法国国际广播电台","title":"陆妇来港产子婴变脑瘫 追责16年终得迟来公义 医生被除牌九个月","content":"中国内地妇人16年前来香港产子，但婴儿出生三天後出院时，发现患上脑瘫，涉事夫妇向香港医务委员会(医委会)投诉，一直到昨(5日)早才获医委会裁定，涉事的儿科医生薜守智未有在男婴首次出现「新生儿癫痫」後立刻返回医院处理，属专业失当，且薛未有悔意，须立即除牌九个月。涉事夫妇认为这虽是迟来的公义，但惩处属恰当，日後会透过民事向医生及医疗机构索偿。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260706-%E9%99%86%E5%A6%87%E6%9D%A5%E6%B8%AF%E4%BA%A7%E5%AD%90%E5%A9%B4%E5%8F%98%E8%84%91%E7%98%AB-%E8%BF%BD%E8%B4%A316%E5%B9%B4%E7%BB%88%E5%BE%97%E8%BF%9F%E6%9D%A5%E5%85%AC%E4%B9%89-%E5%8C%BB%E7%94%9F%E8%A2%AB%E9%99%A4%E7%89%8C%E4%B9%9D%E4%B8%AA%E6%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783323587000.webp","sourceId":"rfi"},{"id":1783322813000,"createdDate":"2026-07-06 07:26","name":"法国国际广播电台","title":"金管局：香港已将人民币幅射至12国 未来数周推更多人民币国际化措施","content":"在人民币於全球国际支付中占比逐年下降丶而中国卻在「十五五」经济规划中声言要建设金融强国之际，香港这个全球最大的离岸人民币中心正努力协助人民币国际化「提速」。金融管理局总裁余伟文透露，该局已将人民币业务资金安排总额度倍增至2000亿元人民币(折合约258亿欧元)，并经香港的银行体系，联汇至12个不同国家及地区。预计未来数周，将会有更多关於人民币国际化和债券市场的措施推出。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260706-%E9%87%91%E7%AE%A1%E5%B1%80-%E9%A6%99%E6%B8%AF%E5%B7%B2%E5%B0%86%E4%BA%BA%E6%B0%91%E5%B8%81%E5%B9%85%E5%B0%84%E8%87%B312%E5%9B%BD-%E6%9C%AA%E6%9D%A5%E6%95%B0%E5%91%A8%E6%8E%A8%E6%9B%B4%E5%A4%9A%E4%BA%BA%E5%B8%81%E5%9B%BD%E9%99%85%E5%8C%96%E6%8E%AA%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783322813000.webp","sourceId":"rfi"},{"id":1783322398000,"createdDate":"2026-07-06 07:19","name":"法国国际广播电台","title":"欧洲思想文化长廊：希腊：欧洲文化永不磨灭的光辉第1 ：米洛文明：照亮希腊的曙光 （上）","content":"我们已经走遍欧洲，沿途观赏了无数瑰丽的文化景观，文艺复兴、宗教改革、英国的宪政、哲学和诗歌、德国浪漫主义，但这些文化景观都有一个共同的源泉，那就是古代希腊。王尔德说：“我们现代生活中的一切都受惠于希腊人。”雪莱更干脆宣称：“我们都是希腊人”。德国浪漫派同仁言必称希腊，拜伦甚至为希腊献出生命。他的一首《哀希腊》道尽了欧洲文人对希腊的无尽向往和哀思。今天我们回到希腊，来寻找崇敬希腊的理由。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260706-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%B8%8C%E8%85%8A-%E6%AC%A7%E6%B4%B2%E6%96%87%E5%8C%96%E6%B0%B8%E4%B8%8D%E7%A3%A8%E7%81%AD%E7%9A%84%E5%85%89%E8%BE%89%E7%AC%AC1-%E7%B1%B3%E6%B4%9B%E6%96%87%E6%98%8E-%E7%85%A7%E4%BA%AE%E5%B8%8C%E8%85%8A%E7%9A%84%E6%9B%99%E5%85%89-%E4%B8%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783322398000.webp","sourceId":"rfi"},{"id":1783360171000,"createdDate":"2026-07-06 17:49","name":"法国国际广播电台","title":"特朗普证实要求FIFA覆核巴洛根红牌　强调未施压改判","content":"美国总统特朗普（DonaldTrump）6日证实，他曾要求国际足球总会（FIFA）重新检视美国男子足球代表队前锋巴洛根（FolarinBalogun）的红牌及自动停赛处分，但强调仅要求覆核，并未要求FIFA改判，也未介入最终决定。FIFA其后撤销巴洛根一场停赛，使他得以出战世界杯16强对比利时之战，但决定引发比利时足协申诉，也在国际足坛掀起公平性争议。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260706-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AF%81%E5%AE%9E%E8%A6%81%E6%B1%82fifa%E8%A6%86%E6%A0%B8%E5%B7%B4%E6%B4%9B%E6%A0%B9%E7%BA%A2%E7%89%8C-%E5%BC%BA%E8%B0%83%E6%9C%AA%E6%96%BD%E5%8E%8B%E6%94%B9%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783360171000.webp","sourceId":"rfi"},{"id":1783358698000,"createdDate":"2026-07-06 17:24","name":"法国国际广播电台","title":"欧足联（UEFA）怒斥国际足联（Fifa ）主席     实属罕见","content":"中国人常言道：“无规矩不成方圆”，那么美国总统特朗普给国际足联主席打电话是否可以改变赛规呢？欧洲足球协会联盟7月6日在一份措辞强硬的声明中表示：“我们对这一史无前例、令人费解且毫无正当理由的决定感到震惊，”欧足联（UEFA）在一份措辞异常严厉的声明中表示，并称此举“越过了红线”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E6%AC%A7%E8%B6%B3%E8%81%94-uefa-%E6%80%92%E6%96%A5%E5%9B%BD%E9%99%85%E8%B6%B3%E8%81%94-fifa-%E4%B8%BB%E5%B8%AD-%E5%AE%9E%E5%B1%9E%E7%BD%95%E8%A7%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783358698000.webp","sourceId":"rfi"},{"id":1783357011000,"createdDate":"2026-07-06 16:56","name":"法国国际广播电台","title":"印尼和新加坡承诺加强战略伙伴关系","content":"印尼总统普拉博沃·苏比安托和新加坡总理黄循财于周一（7月6日）举行了会晤，承诺加强两国在贸易、投资和互联互通等多个领域的合作。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260706-%E5%8D%B0%E5%B0%BC%E5%92%8C%E6%96%B0%E5%8A%A0%E5%9D%A1%E6%89%BF%E8%AF%BA%E5%8A%A0%E5%BC%BA%E6%88%98%E7%95%A5%E4%BC%99%E4%BC%B4%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783357011000.webp","sourceId":"rfi"},{"id":1783356126000,"createdDate":"2026-07-06 16:42","name":"法国国际广播电台","title":"巴拉圭输不起      女议员辱骂姆巴佩     法强烈抗议","content":"7月6日，法国体育部长玛丽娜·法拉丽（MarinaFerrari）对巴拉圭参议员针对基利安·姆巴佩（KylianMbappé）发表的“恶毒”且“种族主义”言论表示愤慨。此前，巴拉圭队在2026年世界杯16强赛中以0比1输给了法国。法国足协6日谴责这些“卑劣且不可接受”的言论。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E5%B7%B4%E6%8B%89%E5%9C%AD%E8%BE%93%E4%B8%8D%E8%B5%B7-%E5%A5%B3%E8%AE%AE%E5%91%98%E8%BE%B1%E9%AA%82%E5%A7%86%E5%B7%B4%E4%BD%A9-%E6%B3%95%E5%BC%BA%E7%83%88%E6%8A%97%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783356126000.webp","sourceId":"rfi"},{"id":1783353147000,"createdDate":"2026-07-06 15:52","name":"法国国际广播电台","title":"涉虚报服务器去向 新加坡检方在英伟达芯片案中追加新指控","content":"新加坡检方对一起人工智能（AI）服务器欺诈案的关键嫌疑人追加了包括洗钱在内的指控；此举是该东南亚国家加大力度打击英伟达芯片被非法转运至中国等地行动的一部分。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260706-%E6%B6%89%E8%99%9A%E6%8A%A5%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%8E%BB%E5%90%91-%E6%96%B0%E5%8A%A0%E5%9D%A1%E6%A3%80%E6%96%B9%E5%9C%A8%E8%8B%B1%E4%BC%9F%E8%BE%BE%E8%8A%AF%E7%89%87%E6%A1%88%E4%B8%AD%E6%8F%90%E5%87%BA%E6%96%B0%E6%8C%87%E6%8E%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783353147000.webp","sourceId":"rfi"},{"id":1783352029000,"createdDate":"2026-07-06 15:33","name":"法国国际广播电台","title":"美国法院暂缓执行阿里巴巴因入美国五角大楼黑名单而遭受游说禁令","content":"一名美国联邦地区法官7月5日下令五角大楼暂缓对阿里巴巴集团执行一项适用的法律条款，这项法律此前导致阿里巴巴所有游说顾问终止代理关系。法官将在审查该措施是否符合宪法期间暂缓对中国科技巨头阿里巴巴实施该法律，此案将考验美国限制中国企业游说能力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260706-%E7%BE%8E%E5%9B%BD%E6%B3%95%E9%99%A2%E6%9A%82%E7%BC%93%E6%89%A7%E8%A1%8C%E9%98%BF%E9%87%8C%E5%B7%B4%E5%B7%B4%E5%9B%A0%E5%85%A5%E7%BE%8E%E5%9B%BD%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC%E9%BB%91%E5%90%8D%E5%8D%95%E8%80%8C%E9%81%AD%E5%8F%97%E6%B8%B8%E8%AF%B4%E7%A6%81%E4%BB%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783352029000.webp","sourceId":"rfi"},{"id":1783350989000,"createdDate":"2026-07-06 15:16","name":"法国国际广播电台","title":"曾被中方制裁、荷兰外贸大臣即将访华：提出关切事项也是访问一部分","content":"荷兰外贸与发展合作大臣舍尔茨玛（SjoerdSjoerdsma）将于周二开启为期三天的访华经贸之旅；此行正值围绕半导体企业安世半导体和阿斯麦（ASML）的紧张局势引发关注之际。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260706-%E6%9B%BE%E8%A2%AB%E4%B8%AD%E6%96%B9%E5%88%B6%E8%A3%81%E7%9A%84%E8%8D%B7%E5%85%B0%E5%A4%96%E8%B4%B8%E5%A4%A7%E8%87%A3%E5%8D%B3%E5%B0%86%E8%AE%BF%E5%8D%8E-%E6%8F%90%E5%87%BA%E5%85%B3%E5%88%87%E4%BA%8B%E9%A1%B9%E4%B9%9F%E6%98%AF%E8%AE%BF%E9%97%AE%E4%B8%80%E9%83%A8%E5%88%86","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783350989000.webp","sourceId":"rfi"},{"id":1783348811000,"createdDate":"2026-07-06 14:40","name":"法国国际广播电台","title":"菲防长拒绝中方大使关于在黄岩岛设立共同渔场的提议：我们不是昨天才出生的","content":"菲律宾国防部长特奥多罗（GilbertoTeodoro）周一驳回了中方关于在南中国海争议海域斯卡伯勒浅滩（中方称黄岩岛、菲方称马辛洛克浅滩）设立共同渔场的提议——该提议本是作为缓解两国紧张局势努力的一部分。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E8%8F%B2%E9%98%B2%E9%95%BF%E6%8B%92%E7%BB%9D%E4%B8%AD%E6%96%B9%E5%A4%A7%E4%BD%BF%E5%85%B3%E4%BA%8E%E5%9C%A8%E9%BB%84%E5%B2%A9%E5%B2%9B%E8%AE%BE%E7%AB%8B%E5%85%B1%E5%90%8C%E6%B8%94%E5%9C%BA%E7%9A%84%E6%8F%90%E8%AE%AE-%E6%88%91%E4%BB%AC%E4%B8%8D%E6%98%AF%E6%98%A8%E5%A4%A9%E6%89%8D%E5%87%BA%E7%94%9F%E7%9A%84","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783348811000.webp","sourceId":"rfi"},{"id":1783347277000,"createdDate":"2026-07-06 14:14","name":"法国国际广播电台","title":"越南最南端建跨海大桥 押注40亿美元基建扩大航运、制衡中柬","content":"据彭博社报导，在越南最南端，沿着坑洼不平的道路从胡志明市驱车约八小时即可到达此地；重型卡车轰鸣着穿过红树林沼泽和虾塘，而士兵与施工队正日以继夜地建造该国最长的跨海大桥。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260706-%E8%B6%8A%E5%8D%97%E6%9C%80%E5%8D%97%E7%AB%AF%E5%BB%BA%E8%B7%A8%E6%B5%B7%E5%A4%A7%E6%A1%A5-%E6%8A%BC%E6%B3%A840%E4%BA%BF%E7%BE%8E%E5%85%83%E5%9F%BA%E5%BB%BA%E6%89%A9%E5%A4%A7%E8%88%AA%E8%BF%90-%E5%88%B6%E8%A1%A1%E4%B8%AD%E6%9F%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783347277000.webp","sourceId":"rfi"},{"id":1783344603000,"createdDate":"2026-07-06 13:30","name":"法国国际广播电台","title":"中国海警船在钓鱼岛水域要求日本海上保安厅测量船停止调查预示着什么？","content":"日本时间6月30日晚10时左右，在距冲绳本岛西北约290公里的钓鱼岛附近，日本认为是“专属经济区”（EEZ）内，海上保安厅测量船“拓洋”号正在实施海洋调查时，多次收到中国海警船通过无线电发出的停止调查要求。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260706-%E4%B8%AD%E5%9B%BD%E6%B5%B7%E8%AD%A6%E8%88%B9%E5%9C%A8%E9%92%93%E9%B1%BC%E5%B2%9B%E6%B0%B4%E5%9F%9F%E8%A6%81%E6%B1%82%E6%97%A5%E6%9C%AC%E6%B5%B7%E4%B8%8A%E4%BF%9D%E5%AE%89%E5%8E%85%E6%B5%8B%E9%87%8F%E8%88%B9%E5%81%9C%E6%AD%A2%E8%B0%83%E6%9F%A5%E9%A2%84%E7%A4%BA%E7%9D%80%E4%BB%80%E4%B9%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783344603000.webp","sourceId":"rfi"},{"id":1783343913000,"createdDate":"2026-07-06 13:18","name":"法国国际广播电台","title":"达赖喇嘛91岁 莫迪发文祝健康长寿","content":"印度总理莫迪（NarendraModi）周一向西藏精神领袖达赖喇嘛致以生日问候，并表示后者所传达的和平理念一直是世界各地人们的指引力量。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260706-%E8%BE%BE%E8%B5%96%E5%96%87%E5%98%9B91%E5%B2%81-%E8%8E%AB%E8%BF%AA%E5%8F%91%E6%96%87%E7%A5%9D%E5%81%A5%E5%BA%B7%E9%95%BF%E5%AF%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783343913000.webp","sourceId":"rfi"},{"id":1783340258000,"createdDate":"2026-07-06 12:17","name":"法国国际广播电台","title":"矢板明夫遭挥拳攻击 陆委会：已迅速逮捕港籍犯嫌 或涉跨境镇压、决不轻忽","content":"据中央社报导，印太战略智库执行长矢板明夫周一在台中遭挥拳攻击脸部。陆委会当日回应称，这是中共民族团结进步促进法生效后，进行的首件跨境镇压案件，政府决不会轻忽。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260706-%E7%9F%A2%E6%9D%BF%E6%98%8E%E5%A4%AB%E9%81%AD%E6%8C%A5%E6%8B%B3%E6%94%BB%E5%87%BB-%E9%99%86%E5%A7%94%E4%BC%9A-%E5%B7%B2%E8%BF%85%E9%80%9F%E9%80%AE%E6%8D%95%E6%B8%AF%E7%B1%8D%E7%8A%AF%E5%AB%8C-%E6%88%96%E6%B6%89%E8%B7%A8%E5%A2%83%E9%95%87%E5%8E%8B-%E5%86%B3%E4%B8%8D%E8%BD%BB%E5%BF%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783340258000.webp","sourceId":"rfi"},{"id":1783339233000,"createdDate":"2026-07-06 12:00","name":"法国国际广播电台","title":"鏖战阿兹特克 英格兰3比2力克墨西哥晋级八强","content":"在墨西哥城阿兹特克体育场（EstadioAzteca）举行这场八分之一比赛惊心动魄，最后英格兰队以3比2战胜了对手墨西哥队。在长达40分钟的比赛时间里，英格兰队少一人应战，并顶住了墨西哥队的反扑，在惊心动魄的收官阶段战斗至最后一秒，最终成功晋级，留给墨西哥队无尽的遗憾。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E9%8F%96%E6%88%98%E9%98%BF%E5%85%B9%E7%89%B9%E5%85%8B%EF%BC%8C%E8%8B%B1%E6%A0%BC%E5%85%B03%E6%AF%942%E5%8A%9B%E5%85%8B%E5%A2%A8%E8%A5%BF%E5%93%A5%E6%99%8B%E7%BA%A7%E5%85%AB%E5%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783339233000.webp","sourceId":"rfi"},{"id":1783382153000,"createdDate":"2026-07-06 23:55","name":"法国国际广播电台","title":"中国：人工智能已成为珠三角制造业新一轮转型升级的重要工具","content":"人工智能正在成为珠三角制造企业新一轮转型升级的重要驱动力。依托完整的产业链、积极的政府政策支持和持续增长的创新能力，中国南方正努力把人工智能融入制造业全流程，以提升产业竞争力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260706-%E4%B8%AD%E5%9B%BD-%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E5%B7%B2%E6%88%90%E4%B8%BA%E7%8F%A0%E4%B8%89%E8%A7%92%E5%88%B6%E9%80%A0%E4%B8%9A%E6%96%B0%E4%B8%80%E8%BD%AE%E8%BD%AC%E5%9E%8B%E5%8D%87%E7%BA%A7%E7%9A%84%E9%87%8D%E8%A6%81%E5%B7%A5%E5%85%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783382153000.webp","sourceId":"rfi"},{"id":1783374897000,"createdDate":"2026-07-06 21:54","name":"法国国际广播电台","title":"非洲组装中国配件电动机车畅销","content":"自伊朗战争爆发以来，在非洲本地组装的电动摩托车，中文也有译作机车（moto）的销量暴增。这是本台法广（RFI）法语«运输»（ChroniqueTransports）专栏记者于两天前星期六（2026年07月04日）上网的最新一集内容。在伊朗战争导致汽油供应受到限制的大背景下，电动踏板车（scooters）和电动摩托车（motos）的销量过去三个月内增长了40%。这是用中国零配件在非洲组装。尤其是那几个在拥有电动摩托车组装厂的非洲国家。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260706-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2%E7%BB%84%E8%A3%85%E4%B8%AD%E5%9B%BD%E9%85%8D%E4%BB%B6%E7%94%B5%E5%8A%A8%E6%9C%BA%E8%BD%A6%E7%95%85%E9%94%80","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783374897000.webp","sourceId":"rfi"},{"id":1783374845000,"createdDate":"2026-07-06 21:54","name":"法国国际广播电台","title":"古巴再次发生全国性大停电","content":"古巴国家电力公司宣布，该国周一再次发生全国性停电。这是不到六个月的第三次，也是自2024年底以来的第八次。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E5%8F%A4%E5%B7%B4%E5%86%8D%E6%AC%A1%E5%8F%91%E7%94%9F%E5%85%A8%E5%9B%BD%E6%80%A7%E5%A4%A7%E5%81%9C%E7%94%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783374845000.webp","sourceId":"rfi"},{"id":1783373343000,"createdDate":"2026-07-06 21:29","name":"法国国际广播电台","title":"面对“种族歧视”    马克龙鼎力支持姆巴佩","content":"爱丽舍宫周一表示，法国总统马克龙鼎力支持法国队队长姆巴佩表示支持，马克龙谴责了巴拉圭参议员在2026年世界杯16强赛后针对姆巴佩发起的“种族主义攻击”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E9%9D%A2%E5%AF%B9-%E7%A7%8D%E6%97%8F%E6%AD%A7%E8%A7%86-%E9%A9%AC%E5%85%8B%E9%BE%99%E9%BC%8E%E5%8A%9B%E6%94%AF%E6%8C%81%E5%A7%86%E5%B7%B4%E4%BD%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783373343000.webp","sourceId":"rfi"},{"id":1783370528000,"createdDate":"2026-07-06 20:42","name":"法国国际广播电台","title":"马克龙到访叙利亚","content":"法国总统马克龙于周一晚抵达大马士革，出访叙利亚。这是自巴沙尔·阿萨德政权倒台及艾哈迈德·沙拉（Ahmadal-Chareh）总统倒台以来，西方国家元首首次访问叙利亚。法国总统6日晚参观了大马士革古城。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260706-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%88%B0%E8%AE%BF%E5%8F%99%E5%88%A9%E4%BA%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783370528000.webp","sourceId":"rfi"},{"id":1783370275000,"createdDate":"2026-07-06 20:37","name":"法国国际广播电台","title":"布鲁塞尔蓬皮杜运河中心起火   部分建筑顶层受损","content":"布鲁塞尔新的当代艺术中心-蓬皮杜运河中心（KANAL-CentrePompidou又译卡纳尔-蓬皮杜中心）起火。6日下午当地时间18点左右，消防员立即赶至火灾现场，扑灭建筑物屋顶的火灾，两小时后火势似乎已得到控制。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260706-%E5%B8%83%E9%B2%81%E5%A1%9E%E5%B0%94%E8%93%AC%E7%9A%AE%E6%9D%9C%E8%BF%90%E6%B2%B3%E4%B8%AD%E5%BF%83%E8%B5%B7%E7%81%AB-%E9%83%A8%E5%88%86%E5%BB%BA%E7%AD%91%E9%A1%B6%E5%B1%82%E5%8F%97%E6%8D%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783370275000.webp","sourceId":"rfi"},{"id":1783370040000,"createdDate":"2026-07-06 20:34","name":"法国国际广播电台","title":"AI监管跟不上 联合国呼吁全球规范保护少年儿童","content":"联合国秘书长古特雷斯（AntonioGuterres）7月6日警告，人工智能（AI）发展已超出所有人能跟上的速度，呼吁制定全球性规范，降低潜在风险，特别是保护少年儿童。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-ai%E7%9B%91%E7%AE%A1%E8%B7%9F%E4%B8%8D%E4%B8%8A-%E8%81%94%E5%90%88%E5%9B%BD%E5%91%BC%E5%90%81%E5%85%A8%E7%90%83%E8%A7%84%E8%8C%83%E4%BF%9D%E6%8A%A4%E5%B0%91%E5%B9%B4%E5%84%BF%E7%AB%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783370040000.webp","sourceId":"rfi"},{"id":1783370016000,"createdDate":"2026-07-06 20:33","name":"法国国际广播电台","title":"华沙已向基辅提供38亿欧元的军事援助","content":"波兰国防部长周一宣布，自2022年俄罗斯入侵乌克兰以来，波兰已向乌克兰提供了总额达38亿欧元的军事援助。在华沙与基辅关系紧张以及右翼反对派向政府施压的背景下，华沙决定公开有关向乌克兰提供军事装备的信息。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260706-%E5%8D%8E%E6%B2%99%E5%B7%B2%E5%90%91%E5%9F%BA%E8%BE%85%E6%8F%90%E4%BE%9B38%E4%BA%BF%E6%AC%A7%E5%85%83%E7%9A%84%E5%86%9B%E4%BA%8B%E6%8F%B4%E5%8A%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783370016000.webp","sourceId":"rfi"},{"id":1783369783000,"createdDate":"2026-07-06 20:29","name":"法国国际广播电台","title":"特朗普介入世界杯判罚     比利时强烈反弹","content":"上一场比赛获得“红牌”的美国队头号射手福拉林·巴洛贡（FolarinBalogun）禁赛暂缓一年执行。他因此得以出战6日美国队与比利时队的16强赛。就在比利时队即将与美国队进行16强赛前几小时，比利时副首相兼外交大臣普雷沃（MaximePrévot）批评国际足联这一决定，称该做法“令人无法理解”。国际足联主席亲自证实特朗普就美国队球员红牌判罚给他打过电话。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E7%89%B9%E6%9C%97%E6%99%AE%E4%BB%8B%E5%85%A5%E4%B8%96%E7%95%8C%E6%9D%AF%E5%88%A4%E7%BD%9A-%E6%AF%94%E5%88%A9%E6%97%B6%E5%BC%BA%E7%83%88%E5%8F%8D%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783369783000.webp","sourceId":"rfi"},{"id":1783369570000,"createdDate":"2026-07-06 20:26","name":"法国国际广播电台","title":"美盛大烟花表演后     华盛顿陷入一片有毒烟雾之中","content":"美国华盛顿为庆祝建国250周年举行史上规模最大烟花表演，燃放85万枚烟花。本周末，华盛顿特区的空气质量降至全年最差水平。起因是为庆祝美国国庆日而举行的大规模烟花汇演，此次活动导致污染水平飙升至“极不健康”的范围。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260706-%E7%BE%8E%E7%9B%9B%E5%A4%A7%E7%83%9F%E8%8A%B1%E8%A1%A8%E6%BC%94%E5%90%8E-%E5%8D%8E%E7%9B%9B%E9%A1%BF%E9%99%B7%E5%85%A5%E4%B8%80%E7%89%87%E6%9C%89%E6%AF%92%E7%83%9F%E9%9B%BE%E4%B9%8B%E4%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783369570000.webp","sourceId":"rfi"},{"id":1783369292000,"createdDate":"2026-07-06 20:21","name":"法国国际广播电台","title":"李柯：比亚迪并未与斯特兰蒂斯（Stellantis）商讨合作","content":"中国汽车制造商比亚迪（BYD）的一位高管7月6日在接受法国《回声报》（LesEchos）采访时表示，公司并未与斯特兰蒂斯有限公司（StellantisN.V.）就涉及陷入困境的豪华品牌玛莎拉蒂（Maserati）的潜在合作事宜进行商谈。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260706-%E6%9D%8E%E6%9F%AF-%E6%AF%94%E4%BA%9A%E8%BF%AA%E5%B9%B6%E6%9C%AA%E4%B8%8E%E6%96%AF%E7%89%B9%E5%85%B0%E8%92%82%E6%96%AF-stellantis-%E5%95%86%E8%AE%A8%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783369292000.webp","sourceId":"rfi"},{"id":1783369145000,"createdDate":"2026-07-06 20:19","name":"法国国际广播电台","title":"法国无尸杀妻案       罪犯180度大转弯","content":"一个罪犯从拒不认罪到供认不讳，整整经历了5年。震惊法国的无尸杀妻案7月6日发生戏剧性转折。被判30年监禁的朱比拉（CédricJubillar）在给律师的一封亲笔信中说，前妻德尔菲娜·奥萨格尔(DelphineAussaguel)是他杀的，他会配合司法机构寻找尸体，而他在此前的庭审一直声称，他没有杀害妻子，对他的指控是冤枉的。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260706-%E6%B3%95%E5%9B%BD%E6%97%A0%E5%B0%B8%E6%9D%80%E5%A6%BB%E6%A1%88-%E7%BD%AA%E7%8A%AF180%E5%BA%A6%E5%A4%A7%E8%BD%AC%E5%BC%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783369145000.webp","sourceId":"rfi"},{"id":1783367868000,"createdDate":"2026-07-06 19:57","name":"法国国际广播电台","title":"马达加斯加提高招聘最低工资","content":"印度洋中的岛国马达加斯加政府刚刚颁布了新的薪资标准。而且实施的生效日期还追溯至2026年3月1日。因此，雇主还需向雇员们补发四个月的工资差额。在非农业部门，最低的起薪上调至30万阿里亚里（约合60欧元）。这是本台法广非洲组（RFIAfrique）今天2026年07月06日周一的最新法文消息之一。据介绍，工会方面对此措施已经期待了数月之久，但另有人认为力度依然欠缺。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260706-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E9%A9%AC%E8%BE%BE%E5%8A%A0%E6%96%AF%E5%8A%A0%E6%8F%90%E9%AB%98%E6%8B%9B%E8%81%98%E6%9C%80%E4%BD%8E%E5%B7%A5%E8%B5%84","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783367868000.webp","sourceId":"rfi"},{"id":1783366963000,"createdDate":"2026-07-06 19:42","name":"法国国际广播电台","title":"姆巴佩：“一位令人蔑视、不称职的女人”","content":"巴拉圭遭法国淘汰后，巴拉圭参议员阿马里利亚社媒发文嘲讽姆巴佩：“这个粗人连写字都没学会；他不喝母乳，反倒喝椰子汁，他听过的最有教养的声音来自黑猩猩。姆巴佩随后对这种辱骂快速做出了回应。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260706-%E5%A7%86%E5%B7%B4%E4%BD%A9-%E4%B8%80%E4%BD%8D%E4%BB%A4%E4%BA%BA%E8%94%91%E8%A7%86-%E4%B8%8D%E7%A7%B0%E8%81%8C%E7%9A%84%E5%A5%B3%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783366963000.webp","sourceId":"rfi"},{"id":1783366106000,"createdDate":"2026-07-06 19:28","name":"法国国际广播电台","title":"安卡拉北约峰会议题多：自身防卫与中东乌克兰格陵兰","content":"北约峰会7月7日至8日将在土耳其首都安卡拉举行，北约32个成员国领袖将齐聚一堂，预计将检视北约盟国落实国防开支承诺及分摊支出的进展。这一峰会的背景是还在进行时的美伊冲突和谈判，以及俄乌战争的出路等关乎国际社会的重大议题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260706-%E5%AE%89%E5%8D%A1%E6%8B%89%E5%8C%97%E7%BA%A6%E5%B3%B0%E4%BC%9A%E8%AE%AE%E9%A2%98%E5%A4%9A-%E8%87%AA%E8%BA%AB%E9%98%B2%E5%8D%AB%E4%B8%8E%E4%B8%AD%E4%B8%9C%E4%B9%8C%E5%85%8B%E5%85%B0%E6%A0%BC%E9%99%B5%E5%85%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/06/1783366106000.webp","sourceId":"rfi"}]