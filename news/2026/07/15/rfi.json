[{"id":1784110492000,"createdDate":"2026-07-15 10:14","name":"法国国际广播电台","title":"中国六月经济表现究竟是好还是坏？法国绝症病患终能如愿“安乐死”？","content":"今天7月15日，法国“安乐死”法案将迎来最终表决，这项改革是马克龙第二任期的重要承诺之一，各大日报头版话题无不聚焦在此。6月30日，法国国民议会以295票对232票三读通过了临终关怀法案，标志着安乐死与协助者合法化进程迈过了倒数门槛。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260715-%E4%B8%AD%E5%9B%BD%E5%85%AD%E6%9C%88%E7%BB%8F%E6%B5%8E%E8%A1%A8%E7%8E%B0%E7%A9%B6%E7%AB%9F%E6%98%AF%E5%A5%BD%E8%BF%98%E6%98%AF%E5%9D%8F-%E6%B3%95%E5%9B%BD%E7%BB%9D%E7%97%87%E7%97%85%E6%82%A3%E7%BB%88%E8%83%BD%E5%A6%82%E6%84%BF-%E5%AE%89%E4%B9%90%E6%AD%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784110492000.webp","sourceId":"rfi"},{"id":1784109960000,"createdDate":"2026-07-15 10:06","name":"法国国际广播电台","title":"台湾年底地方大选竞选活动陆续开跑 独特的选举文化从竞选小物看起","content":"台湾2026年九合一地方大选将在11月28日举行，虽然距离投票日还有约5个月，但各政党已展开积极布局。网路上也开始看到不少民众贴出自己收到的竞选小物，五花八门、创意无限的竞选赠品展现出台湾特有的选举文化。以台北市为例，选民们已开始期待民进党候选人沈伯洋的竞选小物。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260715-%E5%8F%B0%E6%B9%BE%E5%B9%B4%E5%BA%95%E5%9C%B0%E6%96%B9%E5%A4%A7%E9%80%89%E7%AB%9E%E9%80%89%E6%B4%BB%E5%8A%A8%E9%99%86%E7%BB%AD%E5%BC%80%E8%B7%91-%E7%8B%AC%E7%89%B9%E7%9A%84%E9%80%89%E4%B8%BE%E6%96%87%E5%8C%96%E4%BB%8E%E7%AB%9E%E9%80%89%E5%B0%8F%E7%89%A9%E7%9C%8B%E8%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784109960000.webp","sourceId":"rfi"},{"id":1784107455000,"createdDate":"2026-07-15 09:24","name":"法国国际广播电台","title":"美两党参议员提《制止跨国镇压法案》加重对被定罪个人的刑期和罚金","content":"美国国会参议院议员周二提出一项两党法案，旨在加重对那些在美国本土威胁他人的外国政府代理人的处罚；此举意在应对官员们所称的由中国和伊朗等国实施的跨国镇压日益猖獗的现象。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260715-%E7%BE%8E%E4%B8%A4%E5%85%9A%E5%8F%82%E8%AE%AE%E5%91%98%E6%8F%90-%E5%88%B6%E6%AD%A2%E8%B7%A8%E5%9B%BD%E9%95%87%E5%8E%8B%E6%B3%95%E6%A1%88-%E5%8A%A0%E9%87%8D%E5%AF%B9%E8%A2%AB%E5%AE%9A%E7%BD%AA%E4%B8%AA%E4%BA%BA%E7%9A%84%E5%88%91%E6%9C%9F%E5%92%8C%E7%BD%9A%E9%87%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784107455000.webp","sourceId":"rfi"},{"id":1784105928000,"createdDate":"2026-07-15 08:58","name":"法国国际广播电台","title":"半决赛惨败：媒体狠批法国队表现  德尚认输但质疑裁判水平  失望的姆巴佩要吸取教训","content":"法国队在2026年世界杯半决赛中被西班牙队以0-2的比分淘汰出局。这场比赛于7月14日在达拉斯附近的阿灵顿举行，法国队未能实现连续第三次晋级决赛的梦想，这也是教练迪迪埃·德尚执教的最后一届世界杯。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260715-%E5%8D%8A%E5%86%B3%E8%B5%9B%E6%83%A8%E8%B4%A5-%E5%AA%92%E4%BD%93%E7%8B%A0%E6%89%B9%E6%B3%95%E5%9B%BD%E9%98%9F%E8%A1%A8%E7%8E%B0-%E5%BE%B7%E5%B0%9A%E8%B4%A8%E5%A4%B1%E6%9C%9B-%E8%B4%A8%E7%96%91%E8%A3%81%E5%88%A4%E6%B0%B4%E5%B9%B3-%E5%A7%86%E5%B7%B4%E4%BD%A9%E7%A7%B0%E8%A6%81%E5%90%B8%E5%8F%96%E6%95%99%E8%AE%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784105928000.webp","sourceId":"rfi"},{"id":1784105626000,"createdDate":"2026-07-15 08:53","name":"法国国际广播电台","title":"中国第二季度经济增长4.3% 创三年半以来新低","content":"中国国家统计局周三（7月15日）公布，今年第二季度经济增长4.3%，低于市场预期，也较第一季度5%的增速回落，为2022年第四季度以来的最低。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260715-%E4%B8%AD%E5%9B%BD%E7%AC%AC%E4%BA%8C%E5%AD%A3%E5%BA%A6%E7%BB%8F%E6%B5%8E%E5%A2%9E%E9%95%BF4-3-%E5%88%9B%E4%B8%89%E5%B9%B4%E5%8D%8A%E4%BB%A5%E6%9D%A5%E6%96%B0%E4%BD%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784105626000.webp","sourceId":"rfi"},{"id":1784103309000,"createdDate":"2026-07-15 08:15","name":"法国国际广播电台","title":"75岁中宣部原副部长蔡赴朝被查","content":"中央纪委国家监委网站周三（15日）官宣，中共中央宣传部原副部长，原国家新闻出版广电总局党组书记、局长蔡赴朝涉嫌严重违纪违法，目前正接受中央纪委国家监委纪律审查和监察调查。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260715-%E4%B8%AD%E5%A4%AE%E5%AE%A3%E4%BC%A0%E9%83%A8%E5%8E%9F%E5%89%AF%E9%83%A8%E9%95%BF%E8%94%A1%E8%B5%B4%E6%9C%9D%E8%A2%AB%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784103309000.webp","sourceId":"rfi"},{"id":1784102119000,"createdDate":"2026-07-15 07:55","name":"法国国际广播电台","title":"台北市长候选人沈伯洋将访美 成立后援会并打造台北无限城论坛","content":"民进党台北市长参选人沈伯洋20日将访美，除了将在洛杉矶与纽约成立后援会，也将与美国各城市就极端气候、热岛效应与鼠患等议题交流。沈伯洋表示，将突破过去双城论坛模式并以“无限城”理念拓展城市外交。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260715-%E5%8F%B0%E5%8C%97%E5%B8%82%E9%95%B7%E5%80%99%E9%81%B8%E4%BA%BA%E6%B2%88%E4%BC%AF%E6%B4%8B%E5%B0%87%E8%A8%AA%E7%BE%8E-%E6%88%90%E7%AB%8B%E5%BE%8C%E6%8F%B4%E6%9C%83%E4%B8%A6%E6%89%93%E9%80%A0%E5%8F%B0%E5%8C%97%E7%84%A1%E9%99%90%E5%9F%8E%E8%AB%96%E5%A3%87","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784102119000.webp","sourceId":"rfi"},{"id":1784099519000,"createdDate":"2026-07-15 07:11","name":"法国国际广播电台","title":"日本巡逻舰避台风进入台湾海峡 中国抗议 日本反驳","content":"日本内阁官房长官木原稔日前就海上保安厅巡逻舰驶入台湾海峡避难，中国提出抗议一事表示：“7月9日至12日期间，为躲避第9号台风带来的恶劣天气，巡视船在公海海域进行了避难。对于相关报道，政府不便发表评论，但今后将继续全力做好警戒监视工作，并将以冷静且坚定的态度应对中方。”","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260715-%E6%97%A5%E6%9C%AC%E5%B7%A1%E9%80%BB%E8%88%B0%E9%81%BF%E5%8F%B0%E9%A3%8E%E8%BF%9B%E5%85%A5%E5%8F%B0%E6%B9%BE%E6%B5%B7%E5%B3%A1-%E4%B8%AD%E5%9B%BD%E6%8A%97%E8%AE%AE-%E6%97%A5%E6%9C%AC%E5%8F%8D%E9%A9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784099519000.webp","sourceId":"rfi"},{"id":1784098914000,"createdDate":"2026-07-15 07:01","name":"法国国际广播电台","title":"香港“行政主导”再惹热议：建制元老称《基本法》未列明 前京官重申但未释疑","content":"自北京全面管治香港后，多次提出香港属行政主导体制，并要求强化行政长官作为“当家人”的角色，但建制派元老丶前立法会主席曾钰成近日表示，光强调行政主导却没有清楚说明其定义并不理想，引发外界关注。前官员和北京的新“护法”均趁机在一个宣讲会上解画，辩称《基本法》即使没有写明“行政主导”，特首的主导地位已十分清晰，强调爱国爱港人士需要坚定维护行政主导。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260715-%E9%A6%99%E6%B8%AF-%E8%A1%8C%E6%94%BF%E4%B8%BB%E5%AF%BC-%E5%86%8D%E6%83%B9%E7%86%B1%E8%AD%B0-%E5%BB%BA%E5%88%B6%E5%85%83%E8%80%81%E7%A7%B0-%E5%9F%BA%E6%9C%AC%E6%B3%95-%E6%9C%AA%E5%88%97%E6%98%8E-%E5%89%8D%E4%BA%AC%E5%AE%98%E9%87%8D%E7%94%B3%E4%BD%86%E6%9C%AA%E9%87%8B%E7%96%91","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784098914000.webp","sourceId":"rfi"},{"id":1784131561000,"createdDate":"2026-07-15 16:06","name":"法国国际广播电台","title":"香港再有书店遭国安处搜查 拘5男女检取涉案煽动书籍","content":"香港再有书店因为涉嫌拥有煽动刊物而遭警方国安处人员搜查。香港电台报导指，警方国安处周三搜查旺角两间店铺，拘捕五人，涉嫌于店内展示具煽动意图的物品，以及出售具煽动意图的刊物。国安处人员检取一批涉案书籍。消息指，被搜查的是两间书店“田园书屋”及“留下书舍”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260715-%E9%A6%99%E6%B8%AF%E5%86%8D%E6%9C%89%E4%B9%A6%E5%BA%97%E9%81%AD%E5%9B%BD%E5%AE%89%E5%A4%84%E6%90%9C%E6%9F%A5-%E6%8B%985%E7%94%B7%E5%A5%B3%E6%A3%80%E5%8F%96%E6%B6%89%E6%A1%88%E7%85%BD%E5%8A%A8%E4%B9%A6%E7%B1%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784131561000.webp","sourceId":"rfi"},{"id":1784129150000,"createdDate":"2026-07-15 15:25","name":"法国国际广播电台","title":"匈牙利前外长辞议员出任比亚迪高管 现总理：选民看到他代表了谁的利益","content":"匈牙利前外交部长、前总理欧尔班（ViktorOrban）的盟友西雅尔多（PeterSzijjarto）周三宣布辞去议员职务，转而为中国电动汽车巨头比亚迪工作，此举引发了关于利益冲突的指责。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260715-%E5%8C%88%E7%89%99%E5%88%A9%E5%89%8D%E5%A4%96%E9%95%BF%E8%BE%9E%E8%AE%AE%E5%91%98%E5%87%BA%E4%BB%BB%E6%AF%94%E4%BA%9A%E8%BF%AA%E9%AB%98%E7%AE%A1-%E7%8E%B0%E6%80%BB%E7%90%86-%E9%80%89%E6%B0%91%E7%9C%8B%E5%88%B0%E4%BB%96%E4%BB%A3%E8%A1%A8%E4%BA%86%E8%B0%81%E7%9A%84%E5%88%A9%E7%9B%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784129150000.webp","sourceId":"rfi"},{"id":1784127530000,"createdDate":"2026-07-15 14:58","name":"法国国际广播电台","title":"台湾据报拟采购数十艘无人艇供海巡署使用 与美防务公司合作","content":"一位知情高官向《日经亚洲》透露称，台湾已决定为其海巡署采购数十艘无人艇。此举旨在利用美国技术，以加强防卫能力，并应对中国在该地区日趋扩张性的海上活动。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260715-%E5%8F%B0%E6%B9%BE%E6%8D%AE%E6%8A%A5%E6%8B%9F%E9%87%87%E8%B4%AD%E6%95%B0%E5%8D%81%E8%89%98%E6%97%A0%E4%BA%BA%E8%89%87%E4%BE%9B%E6%B5%B7%E5%B7%A1%E7%BD%B2%E4%BD%BF%E7%94%A8-%E4%B8%8E%E7%BE%8E%E9%98%B2%E5%8A%A1%E5%85%AC%E5%8F%B8%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784127530000.webp","sourceId":"rfi"},{"id":1784120194000,"createdDate":"2026-07-15 12:56","name":"法国国际广播电台","title":"欧盟组建紧急事态应对小组 以备与中方就稀土问题对峙等情形","content":"随着针对关键稀土出口管制的“休战期”即将结束，欧盟正组建一个紧急工作组，以应对包括可能与中国发生的贸易冲突在内的各类危机。据英国《金融时报》援引三位官员报导称，该工作组由来自欧盟委员会主要部门的官员组成，旨在针对日益动荡的全球局势，预判并应对未来的紧急事态。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260715-%E6%AC%A7%E7%9B%9F%E7%BB%84%E5%BB%BA%E7%B4%A7%E6%80%A5%E4%BA%8B%E6%80%81%E5%BA%94%E5%AF%B9%E5%B0%8F%E7%BB%84-%E4%BB%A5%E5%A4%87%E4%B8%8E%E4%B8%AD%E6%96%B9%E5%B0%B1%E7%A8%80%E5%9C%9F%E9%97%AE%E9%A2%98%E5%AF%B9%E5%B3%99%E7%AD%89%E6%83%85%E5%BD%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784120194000.webp","sourceId":"rfi"},{"id":1784117465000,"createdDate":"2026-07-15 12:11","name":"法国国际广播电台","title":"格雷厄姆生前力推对俄制裁法案有望落实 包含对俄油气五大买家征至多100％关税","content":"一个由美国两党参议员组成的小组公布了一项修订后的对俄制裁法案。已故共和党籍联邦参议员格雷厄姆（LindseyGraham）生前曾力推敲定该法案，这也是他为促成妥协及结束俄乌战争所做的最后努力之一。若该法案获得通过，将通过对俄罗斯油气的前五大进口国，很可能包括中国和印度征收100%关税，从而加大对俄总统普京的施压。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260715-%E6%A0%BC%E9%9B%B7%E5%8E%84%E5%A7%86%E7%94%9F%E5%89%8D%E5%8A%9B%E6%8E%A8%E5%AF%B9%E4%BF%84%E5%88%B6%E8%A3%81%E6%B3%95%E6%A1%88%E6%9C%89%E6%9C%9B%E8%90%BD%E5%AE%9E-%E5%8C%85%E5%90%AB%E5%AF%B9%E4%BF%84%E6%B2%B9%E6%B0%94%E4%BA%94%E5%A4%A7%E4%B9%B0%E5%AE%B6%E6%96%BD%E5%8A%A0%E8%87%B3%E5%A4%9A100%EF%BC%85%E5%85%B3%E7%A8%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784117465000.webp","sourceId":"rfi"},{"id":1784111195000,"createdDate":"2026-07-15 10:26","name":"法国国际广播电台","title":"德机械设备协会促对华采取更有力行动 高官：很可能在欧盟层面会采取单边保护措施","content":"德国机械设备制造业联合会（VDMA）周三敦促欧盟针对其所指的来自中国的不公平竞争采取更迅速、更有力的行动，并建议对特定产品类别征收反补贴税，同时调整贸易案件的评估方式。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260715-%E5%BE%B7%E6%9C%BA%E6%A2%B0%E8%AE%BE%E5%A4%87%E5%8D%8F%E4%BC%9A%E4%BF%83%E5%AF%B9%E5%8D%8E%E9%87%87%E5%8F%96%E6%9B%B4%E6%9C%89%E5%8A%9B%E8%A1%8C%E5%8A%A8-%E9%AB%98%E5%AE%98-%E5%BE%88%E5%8F%AF%E8%83%BD%E5%9C%A8%E6%AC%A7%E7%9B%9F%E5%B1%82%E9%9D%A2%E4%BC%9A%E9%87%87%E5%8F%96%E5%8D%95%E8%BE%B9%E4%BF%9D%E6%8A%A4%E6%8E%AA%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784111195000.webp","sourceId":"rfi"},{"id":1784151730000,"createdDate":"2026-07-15 21:42","name":"法国国际广播电台","title":"美国男性军人身体里有多少睾酮 ？美国国防部长说，到30岁就得查","content":"美国男性军人身体里有多少睾酮？美国国防部长说，到30岁就得查。皮特·赫格塞思周三宣布，作为年度健康检查的一个项目，30岁及以上的美国军人将接受睾酮缺乏症检测。赫格塞思在社交平台X上发布的一段视频，配文中，他写道：“高睾酮（High-T）战争部”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260715-%E7%BE%8E%E5%9B%BD%E7%94%B7%E6%80%A7%E5%86%9B%E4%BA%BA%E8%BA%AB%E4%BD%93%E9%87%8C%E6%9C%89%E5%A4%9A%E5%B0%91%E7%9D%BE%E9%85%AE-%E7%BE%8E%E5%9B%BD%E5%9B%BD%E9%98%B2%E9%83%A8%E9%95%BF%E8%AF%B4%EF%BC%8C%E5%88%B030%E5%B2%81%E5%B0%B1%E5%BE%97%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784151730000.webp","sourceId":"rfi"},{"id":1784150893000,"createdDate":"2026-07-15 21:28","name":"法国国际广播电台","title":"阿根廷2比1逆转英格兰，周六即将迎来\"英法战争\"","content":"在周三（7月15日）进行的2026年世界杯半决赛中，阿根廷队在先失一球的情况下，以2比1逆转战胜英格兰队。梅西贡献两次助攻，帮助球队晋级决赛。周六，法国队将对阵英格兰队。周日，阿根廷队将在决赛中迎战西班牙队。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260715-%E9%98%BF%E6%A0%B9%E5%BB%B72%E6%AF%941%E9%80%86%E8%BD%AC%E8%8B%B1%E6%A0%BC%E5%85%B0%EF%BC%8C%E5%91%A8%E5%85%AD%E5%8D%B3%E5%B0%86%E8%BF%8E%E6%9D%A5-%E8%8B%B1%E6%B3%95%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784150893000.webp","sourceId":"rfi"},{"id":1784149132000,"createdDate":"2026-07-15 20:58","name":"法国国际广播电台","title":"《华尔街日报》回顾高善文生命最后一年","content":"中国大陆知名经济学家高善文7月7日病逝引发关注，尤其是对高善文受到官方打压的过往有多方报道，最新的报道来自美国的《华尔街日报》。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260715-%E5%8D%8E%E5%B0%94%E8%A1%97%E6%97%A5%E6%8A%A5-%E5%9B%9E%E9%A1%BE%E9%AB%98%E5%96%84%E6%96%87%E7%94%9F%E5%91%BD%E6%9C%80%E5%90%8E%E4%B8%80%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784149132000.webp","sourceId":"rfi"},{"id":1784146205000,"createdDate":"2026-07-15 20:10","name":"法国国际广播电台","title":"乌克兰史上最年轻国防部长宣布辞职，任内曾积极推动扩大无人机应用并助乌军获取星链","content":"乌克兰国防部长米哈伊洛·费多罗夫（MykhailoFedorov）周三宣布辞去职务。此前，乌克兰总理已经辞职，据悉，这是总统泽连斯基推动政府改组的一部分。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260715-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%8F%B2%E4%B8%8A%E6%9C%80%E5%B9%B4%E8%BD%BB%E5%9B%BD%E9%98%B2%E9%83%A8%E9%95%BF%E5%AE%A3%E5%B8%83%E8%BE%9E%E8%81%8C%EF%BC%8C%E4%BB%BB%E5%86%85%E6%9B%BE%E7%A7%AF%E6%9E%81%E6%8E%A8%E5%8A%A8%E6%89%A9%E5%A4%A7%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%BA%94%E7%94%A8%E5%B9%B6%E5%8A%A9%E4%B9%8C%E5%86%9B%E8%8E%B7%E5%8F%96%E6%98%9F%E9%93%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784146205000.webp","sourceId":"rfi"},{"id":1784145778000,"createdDate":"2026-07-15 20:02","name":"法国国际广播电台","title":"美军连续第5天打击伊朗 也门青年运动威胁关闭曼德海峡","content":"美国军方15日宣布，已在美东时间15日当天上午6时对伊朗展开新一波空袭。这是美国连续第5天打击伊朗。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260715-%E7%BE%8E%E5%86%9B%E8%BF%9E%E7%BB%AD%E7%AC%AC5%E5%A4%A9%E6%89%93%E5%87%BB%E4%BC%8A%E6%9C%97-%E4%B9%9F%E9%97%A8%E9%9D%92%E5%B9%B4%E8%BF%90%E5%8A%A8%E5%A8%81%E8%83%81%E5%85%B3%E9%97%AD%E6%9B%BC%E5%BE%B7%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784145778000.webp","sourceId":"rfi"},{"id":1784145329000,"createdDate":"2026-07-15 19:55","name":"法国国际广播电台","title":"美伊冲突升级：美国持续空袭伊朗，德黑兰威胁封锁更多能源通道","content":"美国周三（7月15日）继续对伊朗发动空袭。与此同时，美国重新实施了针对伊朗港口的封锁措施。伊朗方面则强调对霍尔木兹海峡拥有主权，并威胁将进一步封锁地区内更多关键能源运输通道。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260715-%E7%BE%8E%E4%BC%8A%E5%86%B2%E7%AA%81%E5%8D%87%E7%BA%A7-%E7%BE%8E%E5%9B%BD%E6%8C%81%E7%BB%AD%E7%A9%BA%E8%A2%AD%E4%BC%8A%E6%9C%97%EF%BC%8C%E5%BE%B7%E9%BB%91%E5%85%B0%E5%A8%81%E8%83%81%E5%B0%81%E9%94%81%E6%9B%B4%E5%A4%9A%E8%83%BD%E6%BA%90%E9%80%9A%E9%81%93","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784145329000.webp","sourceId":"rfi"},{"id":1784144055000,"createdDate":"2026-07-15 19:34","name":"法国国际广播电台","title":"枫丹白露森林火灾嫌犯：两名18岁青年被移送司法机关，其中一人为志愿消防员","content":"周三（7月15日），两名18岁年轻人，因涉嫌在枫丹白露森林引发火灾被移送司法机关处理，其中一人为志愿消防员。与此同时，数百名消防员仍在这片森林中奋力扑救不断复燃的火点。预计法国总统马克龙将于周四上午视察现场。","newsLink":"https://www.rfi.fr/cn/%E7%94%9F%E6%80%81/20260715-%E6%9E%AB%E4%B8%B9%E7%99%BD%E9%9C%B2%E6%A3%AE%E6%9E%97%E7%81%AB%E7%81%BE%E5%AB%8C%E7%8A%AF-%E4%B8%A4%E5%90%8D18%E5%B2%81%E9%9D%92%E5%B9%B4%E8%A2%AB%E7%A7%BB%E9%80%81%E5%8F%B8%E6%B3%95%E6%9C%BA%E5%85%B3%EF%BC%8C%E5%85%B6%E4%B8%AD%E4%B8%80%E4%BA%BA%E4%B8%BA%E5%BF%97%E6%84%BF%E6%B6%88%E9%98%B2%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784144055000.webp","sourceId":"rfi"},{"id":1784141641000,"createdDate":"2026-07-15 18:54","name":"法国国际广播电台","title":"亚马逊抢先布局南非卫星互联网市场，马斯克指责歧视白人，星链仍未获准入资格","content":"亚马逊周三（7月15日）宣布，将在南非推出卫星互联网服务，正式进军这一市场。而亚马逊的主要竞争对手、埃隆·马斯克旗下的星链（Starlink）目前仍被排除在南非市场之外。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260715-%E4%BA%9A%E9%A9%AC%E9%80%8A%E6%8A%A2%E5%85%88%E5%B8%83%E5%B1%80%E5%8D%97%E9%9D%9E%E5%8D%AB%E6%98%9F%E4%BA%92%E8%81%94%E7%BD%91%E5%B8%82%E5%9C%BA%EF%BC%8C%E9%A9%AC%E6%96%AF%E5%85%8B%E6%8C%87%E8%B4%A3%E5%8D%97%E9%9D%9E%E6%94%BF%E5%BA%9C%E6%AD%A7%E8%A7%86%E7%99%BD%E4%BA%BA%EF%BC%8C%E6%98%9F%E9%93%BE%E4%BB%8D%E6%9C%AA%E8%8E%B7%E5%87%86%E5%85%A5%E8%B5%84%E6%A0%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784141641000.webp","sourceId":"rfi"},{"id":1784140553000,"createdDate":"2026-07-15 18:35","name":"法国国际广播电台","title":"特朗普称暂不与伊朗谈判　美伊冲突升温拖累民调与经济","content":"美国总统特朗普（DonaldTrump）15日表示，目前无意与伊朗展开谈判，并指责伊朗新一批谈判代表阻碍双方达成协议。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260715-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E6%9A%82%E4%B8%8D%E4%B8%8E%E4%BC%8A%E6%9C%97%E8%B0%88%E5%88%A4-%E7%BE%8E%E4%BC%8A%E5%86%B2%E7%AA%81%E5%8D%87%E6%B8%A9%E6%8B%96%E7%B4%AF%E6%B0%91%E8%B0%83%E4%B8%8E%E7%BB%8F%E6%B5%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784140553000.webp","sourceId":"rfi"},{"id":1784139302000,"createdDate":"2026-07-15 18:15","name":"法国国际广播电台","title":"法国国民议会通过“协助死亡”法案 ，患者在严格条件下可选择结束生命，医保将承担所有费用","content":"法国国民议会周三(7月15日)最终通过一项法案，允许患有无法治愈疾病的成年人在符合严格条件的情况下获得致死性药物，以结束自己的生命。国民议会当天以291票赞成、241票反对通过该措施。此次投票意味着法国总统马克龙三年多前提出的这项立法正式完成议会程序。法国由此加入了少数允许这一权利的国家行列，其中包括比利时、荷兰、瑞士、加拿大和乌拉圭等。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260715-%E6%B3%95%E5%9B%BD%E5%9B%BD%E6%B0%91%E8%AE%AE%E4%BC%9A%E9%80%9A%E8%BF%87-%E5%8D%8F%E5%8A%A9%E6%AD%BB%E4%BA%A1%E6%9D%83-%E6%B3%95%E6%A1%88-%EF%BC%8C%E6%82%A3%E8%80%85%E5%9C%A8%E4%B8%A5%E6%A0%BC%E6%9D%A1%E4%BB%B6%E4%B8%8B%E5%8F%AF%E9%80%89%E6%8B%A9%E7%BB%93%E6%9D%9F%E7%94%9F%E5%91%BD%EF%BC%8C%E5%8C%BB%E4%BF%9D%E5%B0%86%E6%89%BF%E6%8B%85%E6%89%80%E6%9C%89%E8%B4%B9%E7%94%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784139302000.webp","sourceId":"rfi"},{"id":1784137864000,"createdDate":"2026-07-15 17:51","name":"法国国际广播电台","title":"欧盟将新一轮对俄制裁方案表决推迟一周  泽连斯基呼吁不要放弃努力","content":"法新社7月15日消息称，欧盟决定将有关新一轮对俄罗斯制裁方案的表决推迟至7月23日，同时将原定于本周三到期的俄罗斯石油出口价格上限机制延长至同一天。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260715-%E6%AC%A7%E7%9B%9F%E5%B0%86%E6%96%B0%E4%B8%80%E8%BD%AE%E5%AF%B9%E4%BF%84%E5%88%B6%E8%A3%81%E6%96%B9%E6%A1%88%E8%A1%A8%E5%86%B3%E6%8E%A8%E8%BF%9F%E4%B8%80%E5%91%A8-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%91%BC%E5%90%81%E4%B8%8D%E8%A6%81%E6%94%BE%E5%BC%83%E5%8A%AA%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784137864000.webp","sourceId":"rfi"},{"id":1784137165000,"createdDate":"2026-07-15 17:39","name":"法国国际广播电台","title":"泽连斯基支持乌克兰国家石油天然气公司负责人出任总理","content":"乌克兰总统泽连斯基周三（7月15日）表示，乌克兰国有能源集团乌克兰国家石油天然气公司（Naftogaz)首席执行官谢尔希·科列茨基（SerguiïKoretsky）是出任乌克兰总理“最合适、准备最充分的人选”，以带领国家应对俄罗斯持续袭击下即将到来的又一个冬季。此前，泽连斯基周日（7月12日）宣布，将启动政府改组，并提议撤换就任未满一年的总理尤利娅·斯维里坚科，以配合乌克兰新的政治战略。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260715-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E6%94%AF%E6%8C%81%E4%B9%8C%E5%85%8B%E5%85%B0%E5%9B%BD%E6%9C%89%E8%83%BD%E6%BA%90%E9%9B%86%E5%9B%A2%E8%B4%9F%E8%B4%A3%E4%BA%BA%E5%87%BA%E4%BB%BB%E6%80%BB%E7%90%86","thumbnail":"","detailImage":"news/detail/rfi/2026/07/15/1784137165000.webp","sourceId":"rfi"}]