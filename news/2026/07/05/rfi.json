[{"id":1783210168000,"createdDate":"2026-07-05 00:09","name":"法国国际广播电台","title":"世界杯奇迹不断 32强赛惊险收官 16强争夺法国过关","content":"世界杯卫冕冠军阿根廷险些被佛得角掀翻，好不容易获得的胜利为32强赛收官。从周六开始，法国与巴拉圭，加拿大与摩洛哥为十六强决赛开幕，前者在费城顶着极端高温迎战，后者在休士顿配备空调的体育场开打，结果刚刚出炉，摩洛哥3比0大胜加拿大，第一个锁定八强席位。法国队1比0险胜巴拉圭，第二个晋级八强。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260705-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%A5%87%E8%BF%B9%E4%B8%8D%E6%96%AD-32%E5%BC%BA%E8%B5%9B%E6%83%8A%E9%99%A9%E6%94%B6%E5%AE%98-16%E5%BC%BA%E4%BA%89%E5%A4%BA%E6%B3%95%E5%9B%BD%E8%BF%87%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783210168000.webp","sourceId":"rfi"},{"id":1783240998000,"createdDate":"2026-07-05 08:43","name":"法国国际广播电台","title":"中国释放北京锡安教会创办人 金明日牧师：“获释是中美两国元首讨论的结果”","content":"法新社周日（7月5日）报道称，在家属与人权组织确认下，被中国当局羁押长达九个月的北京锡安教会创办人金明日（EzraJin）牧师已获释。据报道，中国官员曾告知金明日，他的获释是中美两国元首讨论的结果，旨在值美国独立日之际表达一份“善意”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260705-%E4%B8%AD%E5%9B%BD%E9%87%8A%E6%94%BE%E5%8C%97%E4%BA%AC%E9%94%A1%E5%AE%89%E6%95%99%E4%BC%9A%E5%88%9B%E5%8A%9E%E4%BA%BA-%E9%87%91%E6%98%8E%E6%97%A5%E7%89%A7%E5%B8%88-%E8%8E%B7%E9%87%8A%E6%98%AF%E4%B8%AD%E7%BE%8E%E4%B8%A4%E5%9B%BD%E5%85%83%E9%A6%96%E8%AE%A8%E8%AE%BA%E7%9A%84%E7%BB%93%E6%9E%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783240998000.webp","sourceId":"rfi"},{"id":1783271911000,"createdDate":"2026-07-05 17:18","name":"法国国际广播电台","title":"2026世界杯：法国对阵巴拉圭赛后 裁判成为争议焦点","content":"周六，法国队以1比0战胜了作风极其粗野的巴拉圭队，成功晋级世界杯八强。然而，乌兹别克斯坦籍裁判伊尔吉兹·坦塔舍夫（IlgizTantashev）对南美球员大量犯规的反竞技行为表现出的宽容态度，在周日引发了广泛争议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260705-2026%E4%B8%96%E7%95%8C%E6%9D%AF-%E6%B3%95%E5%9B%BD%E5%AF%B9%E9%98%B5%E5%B7%B4%E6%8B%89%E5%9C%AD%E8%B5%9B%E5%90%8E-%E8%A3%81%E5%88%A4%E6%88%90%E4%B8%BA%E4%BA%89%E8%AE%AE%E7%84%A6%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783271911000.webp","sourceId":"rfi"},{"id":1783270486000,"createdDate":"2026-07-05 16:54","name":"法国国际广播电台","title":"台学者侍建宇：《民族团结进步促进法》更是塑造中华民族法","content":"2026年中国人大政协两会期间通过的《民族团结进步促进法》于7月1日起正式生效执行，引发新一波国际人权组织以及美欧国家的批评。近年来，中国政府因为在新疆和西藏等地强力推行同化政策而一直遭到国际社会诟病。为何要在此时推出这项《民族团结进步促进法》？台湾国防部下属智库国防安全研究院副研究员侍建宇先生关注中国的民族政策数十年。他接受本台电话时，介绍了他的观察与分析。在他看来，这项以民族团结为名的法案更重要的内容是将中华民族这个学术概念变成法律概念，更是一部关于如何塑造一个“中华民族”的法律，并在“中华民族”这个概念框架下，将原本在中国国境内针对少数民族的统战逻辑，向海外延伸，塑造中华民族认同感。他认为北京当局针对少数民族的政策也会越来越多地从公领域，向私领域延伸。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%85%AC%E6%B0%91%E8%AE%BA%E5%9D%9B/20260705-%E5%8F%B0%E5%AD%A6%E8%80%85%E4%BE%8D%E5%BB%BA%E5%AE%87-%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E8%BF%9B%E6%AD%A5%E4%BF%83%E8%BF%9B%E6%B3%95-%E6%9B%B4%E6%98%AF%E5%A1%91%E9%80%A0%E4%B8%AD%E5%8D%8E%E6%B0%91%E6%97%8F%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783270486000.webp","sourceId":"rfi"},{"id":1783265064000,"createdDate":"2026-07-05 15:24","name":"法国国际广播电台","title":"2026世界杯：法国队展现了他们能踢另一种足球","content":"路透社说，自本届世界杯开赛以来，法国队在进攻端表现令人惊叹。而在周六八分之一决赛以1-0淘汰巴拉圭队的比赛中，他们展现出不同的品质，这场胜利或许将成为球队在本届赛事后续征程中的奠基之作。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260705-2026%E4%B8%96%E7%95%8C%E6%9D%AF-%E6%B3%95%E5%9B%BD%E9%98%9F%E5%B1%95%E7%8E%B0%E4%BA%86%E4%BB%96%E4%BB%AC%E8%83%BD%E8%B8%A2%E5%8F%A6%E4%B8%80%E7%A7%8D%E8%B6%B3%E7%90%83","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783265064000.webp","sourceId":"rfi"},{"id":1783263340000,"createdDate":"2026-07-05 14:55","name":"法国国际广播电台","title":"中国宣布将于7月与俄罗斯举行海军联合演习","content":"中国周日宣布，将于7月与俄罗斯举行年度联合海军演习，此次演习将首先在中国近海举行，然后在太平洋一个未指明海域进行联合巡逻。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260705-%E4%B8%AD%E5%9B%BD%E5%AE%A3%E5%B8%83%E5%B0%86%E4%BA%8E7%E6%9C%88%E4%B8%8E%E4%BF%84%E7%BD%97%E6%96%AF%E4%B8%BE%E8%A1%8C%E6%B5%B7%E5%86%9B%E8%81%94%E5%90%88%E6%BC%94%E4%B9%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783263340000.webp","sourceId":"rfi"},{"id":1783261309000,"createdDate":"2026-07-05 14:21","name":"法国国际广播电台","title":"世界报：中美围绕人工智能展开一场游击战","content":"7月5日出版的周末版法国《世界报》头版凸出两大主题，一是俄乌战场上，乌克兰军队正转为主动，而俄罗斯军队在地面上推进停滞，技术落后日益明显；二是美国建国250周年纪念凸显美国社会在特朗普总统任下日益分化。关于中国，该报驻旧金山记者和驻北京记者联合撰写的文章聚焦中美两国在人工智能领域的竞争，认为两国正围绕人工智能展开一场游击战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260705-%E4%B8%96%E7%95%8C%E6%8A%A5-%E4%B8%AD%E7%BE%8E%E4%B8%A4%E5%9B%BD%E5%9B%B4%E7%BB%95%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E5%B1%95%E5%BC%80%E4%B8%80%E5%9C%BA%E6%B8%B8%E5%87%BB%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783261309000.webp","sourceId":"rfi"},{"id":1783258852000,"createdDate":"2026-07-05 13:40","name":"法国国际广播电台","title":"王毅访瑞典:10年前被中国绑架监禁的出版商桂民海仍活着且身体健康","content":"中国外长王毅到访斯德哥尔摩。瑞典外交大臣说，她从中国外长王毅得知，十年前中国绑架监禁的出版商桂民海仍然活着且身体健康。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260705-%E7%8E%8B%E6%AF%85%E8%AE%BF%E7%91%9E%E5%85%B8-10%E5%B9%B4%E5%89%8D%E8%A2%AB%E4%B8%AD%E5%9B%BD%E7%BB%91%E6%9E%B6%E7%9B%91%E7%A6%81%E7%9A%84%E5%87%BA%E7%89%88%E5%95%86%E6%A1%82%E6%95%8F%E6%B5%B7%E4%BB%8D%E6%B4%BB%E7%9D%80%E4%B8%94%E8%BA%AB%E4%BD%93%E5%81%A5%E5%BA%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783258852000.webp","sourceId":"rfi"},{"id":1783254854000,"createdDate":"2026-07-05 12:34","name":"法国国际广播电台","title":"美国庆独立250周年 特朗普赞美国是“人类历史杰作” 再批共产主义","content":"在美国华盛顿举行的250周年国庆纪念活动因天气原因受到干扰。周六，唐纳德·特朗普在演讲中将美国赞誉为“人类历史的杰作”，并再次对“共产主义”政治对手发起了攻击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260705-%E7%BE%8E%E5%9B%BD%E5%BA%86%E7%8B%AC%E7%AB%8B250%E5%91%A8%E5%B9%B4-%E7%89%B9%E6%9C%97%E6%99%AE%E8%B5%9E%E7%BE%8E%E5%9B%BD%E6%98%AF-%E4%BA%BA%E7%B1%BB%E5%8E%86%E5%8F%B2%E6%9D%B0%E4%BD%9C-%E5%86%8D%E6%89%B9%E5%85%B1%E4%BA%A7%E4%B8%BB%E4%B9%89","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783254854000.webp","sourceId":"rfi"},{"id":1783252060000,"createdDate":"2026-07-05 11:47","name":"法国国际广播电台","title":"伊朗国葬第二天为阿里·哈梅内伊举行盛大祈祷会 其子莫杰塔巴仍未露面","content":"周日，伊朗国葬第二天，在德黑兰为前最高领袖阿亚图拉·阿里·哈梅内伊举行盛大祈祷会。伊朗大多数高官均齐聚德黑兰。但哈梅内伊的儿子莫杰塔巴仍未现身。他被任命为最高领袖以来，未曾在公开场合露面。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260705-%E4%BC%8A%E6%9C%97%E5%9B%BD%E8%91%AC%E7%AC%AC%E4%BA%8C%E5%A4%A9%E4%B8%BA%E9%98%BF%E9%87%8C%C2%B7%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E4%B8%BE%E8%A1%8C%E7%9B%9B%E5%A4%A7%E7%A5%88%E7%A5%B7%E4%BC%9A-%E5%85%B6%E5%AD%90%E8%8E%AB%E6%9D%B0%E5%A1%94%E5%B7%B4%E4%BB%8D%E6%9C%AA%E9%9C%B2%E9%9D%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783252060000.webp","sourceId":"rfi"},{"id":1783250670000,"createdDate":"2026-07-05 11:24","name":"法国国际广播电台","title":"法国队以点球险胜巴拉圭进入八强，摩洛哥以三比零淘汰加拿大","content":"2026世界杯7月4日进入八分之一决赛。法国队以一比零战胜巴拉圭队，进入八强，摩洛哥队成功击败加拿大，第二次闯入世界杯八强赛。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260705-%E6%B3%95%E5%9B%BD%E9%98%9F%E4%BB%A5%E7%82%B9%E7%90%83%E9%99%A9%E8%83%9C%E5%B7%B4%E6%8B%89%E5%9C%AD%E8%BF%9B%E5%85%A5%E5%85%AB%E5%BC%BA%EF%BC%8C%E6%91%A9%E6%B4%9B%E5%93%A5%E4%BB%A5%E4%B8%89%E6%AF%94%E9%9B%B6%E6%B7%98%E6%B1%B0%E5%8A%A0%E6%8B%BF%E5%A4%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783250670000.webp","sourceId":"rfi"},{"id":1783250051000,"createdDate":"2026-07-05 11:14","name":"法国国际广播电台","title":"日本向孟加拉海军提供5艘警备舰  孟加拉与中国发表反对军国主义复活公报","content":"日本时间7月3日下午，在日本外务大臣茂木敏充主持的记者会上，《日本经济新闻》记者问：当地时间2日，日本向孟加拉国举行了利用政府安全保障能力强化支援（OSA）框架提供5艘警备艇的交付仪式。虽然此次对孟加拉国的援助是在2023财年决定的，但孟加拉国今年6月与中国共同发表了“反对军国主义复活”的声明。外界认为这是针对日本而言。请问您如何看待与这类国家开展安全保障合作的方式，以及今后政府安全保障能力强化支援的发展方向？","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260705-%E6%97%A5%E6%9C%AC%E5%90%91%E5%AD%9F%E5%8A%A0%E6%8B%89%E6%B5%B7%E5%86%9B%E6%8F%90%E4%BE%9B5%E8%89%98%E8%AD%A6%E5%A4%87%E8%88%B0-%E5%AD%9F%E5%8A%A0%E6%8B%89%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%8F%91%E8%A1%A8%E5%8F%8D%E5%AF%B9%E5%86%9B%E5%9B%BD%E4%B8%BB%E4%B9%89%E5%A4%8D%E6%B4%BB%E5%85%AC%E6%8A%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783250051000.webp","sourceId":"rfi"},{"id":1783248591000,"createdDate":"2026-07-05 10:49","name":"法国国际广播电台","title":"IEA报告解析：中国为何能仅以法国或美国一半的成本建造核电站","content":"作为全球第二大经济体，中国拥有61座核反应堆，另有39座在建。据《回声报》援引国际能源署（IEA）报告指出，为了资助这些工程，中国国有银行提供了低息贷款。然后到 2030年时，中国核能装机容量将可达到110吉瓦（GW），几乎是目前的二倍……","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260705-iea%E6%8A%A5%E5%91%8A%E8%A7%A3%E6%9E%90-%E4%B8%AD%E5%9B%BD%E4%B8%BA%E4%BD%95%E8%83%BD%E4%BB%85%E4%BB%A5%E6%B3%95%E5%9B%BD%E6%88%96%E7%BE%8E%E5%9B%BD%E4%B8%80%E5%8D%8A%E7%9A%84%E6%88%90%E6%9C%AC%E5%BB%BA%E9%80%A0%E6%A0%B8%E7%94%B5%E7%AB%99","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783248591000.webp","sourceId":"rfi"},{"id":1783293666000,"createdDate":"2026-07-05 23:21","name":"法国国际广播电台","title":"继法国摩洛哥挪威之后 谁还梦想晋级八强","content":"八分之一决赛正在如火如荼地在美加墨大地展开，周日晚巴西与挪威展开决战，出乎预料的是，巴西队败北，挪威历史性晋级八强。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260705-%E7%BB%A7%E6%B3%95%E5%9B%BD%E6%91%A9%E6%B4%9B%E5%93%A5%E6%8C%AA%E5%A8%81%E4%B9%8B%E5%90%8E-%E8%B0%81%E8%BF%98%E6%A2%A6%E6%83%B3%E6%99%8B%E7%BA%A7%E5%85%AB%E5%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783293666000.webp","sourceId":"rfi"},{"id":1783291848000,"createdDate":"2026-07-05 22:50","name":"法国国际广播电台","title":"巴西队未能打破魔咒输挪威 后者历史性晋级世界杯八强","content":"第三场八分之一决赛周日在巴西队与挪威队之间打响!表现稳健的挪威队凭借哈兰德在比赛尾声的两粒进球，以2比1淘汰大热门巴西队历史性晋级世界杯八强。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260705-%E5%B7%B4%E8%A5%BF%E9%98%9F%E6%9C%AA%E8%83%BD%E6%89%93%E7%A0%B4%E9%AD%94%E5%92%92%E8%BE%93%E6%8C%AA%E5%A8%81-%E5%90%8E%E8%80%85%E5%8E%86%E5%8F%B2%E6%80%A7%E6%99%8B%E7%BA%A7%E4%B8%96%E7%95%8C%E6%9D%AF%E5%85%AB%E5%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783291848000.webp","sourceId":"rfi"},{"id":1783287846000,"createdDate":"2026-07-05 21:44","name":"法国国际广播电台","title":"法国拉利克博物馆遭窃 数百万欧元珍贵首饰被盗","content":"法国阿尔萨斯地区拉利克博物馆周日（7月5日）凌晨遭入室盗窃，馆内多件价值昂贵的首饰被盗，损失估计达数百万欧元。自2025年10月巴黎卢浮宫失窃案后，拉利克博物馆一直受到重点保护，但调查人员认为，现有安保措施仍不足以防范此次盗窃。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260705-%E6%B3%95%E5%9B%BD%E6%8B%89%E5%88%A9%E5%85%8B%E5%8D%9A%E7%89%A9%E9%A6%86%E9%81%AD%E7%AA%83-%E6%95%B0%E7%99%BE%E4%B8%87%E6%AC%A7%E5%85%83%E7%8F%8D%E8%B4%B5%E9%A6%96%E9%A5%B0%E8%A2%AB%E7%9B%97","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783287846000.webp","sourceId":"rfi"},{"id":1783287514000,"createdDate":"2026-07-05 21:38","name":"法国国际广播电台","title":"白宫：特朗普将在北约峰会期间会晤泽连斯基和叙利亚总统","content":"美国白宫周日（7月5日）宣布，美国总统特朗普将于下周在土耳其安卡拉举行的北约峰会期间，分别与乌克兰总统泽连斯基和叙利亚总统艾哈迈德·沙拉举行双边会谈。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260705-%E7%99%BD%E5%AE%AB-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B0%86%E5%9C%A8%E5%8C%97%E7%BA%A6%E5%B3%B0%E4%BC%9A%E6%9C%9F%E9%97%B4%E4%BC%9A%E6%99%A4%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%92%8C%E5%8F%99%E5%88%A9%E4%BA%9A%E6%80%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783287514000.webp","sourceId":"rfi"},{"id":1783287324000,"createdDate":"2026-07-05 21:35","name":"法国国际广播电台","title":"法国新一轮高温来袭 16省进入橙色高温预警 多地山火持续蔓延","content":"法国上一轮创纪录热浪刚刚结束，新一轮高温天气又接踵而至。法国气象局周日（7月5日）宣布，从7月6日中午起，全国进入橙色高温预警的省份将由7个增至16个，南部部分地区最高气温预计可达40摄氏度。与此同时，多地大型森林火灾仍在持续蔓延。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260705-%E6%B3%95%E5%9B%BD%E6%96%B0%E4%B8%80%E8%BD%AE%E9%AB%98%E6%B8%A9%E6%9D%A5%E8%A2%AD-16%E7%9C%81%E8%BF%9B%E5%85%A5%E6%A9%99%E8%89%B2%E9%AB%98%E6%B8%A9%E9%A2%84%E8%AD%A6-%E5%A4%9A%E5%9C%B0%E5%B1%B1%E7%81%AB%E6%8C%81%E7%BB%AD%E8%94%93%E5%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783287324000.webp","sourceId":"rfi"},{"id":1783287154000,"createdDate":"2026-07-05 21:32","name":"法国国际广播电台","title":"台湾军方恢复军官学校毕业生“反共爱国教育”课程 “应对大陆军事压力”","content":"台湾防务部门周日（7月5日）表示，在中断多年后，台湾军方今年恢复军官学校毕业生“反共爱国教育”课程，理由是来自中国大陆的军事威胁及渗透风险不断升高。台湾一名高级官员周日表示，大陆海军在第一岛链的活动进一步增加。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260705-%E5%8F%B0%E6%B9%BE%E5%86%9B%E6%96%B9%E6%81%A2%E5%A4%8D%E5%86%9B%E5%AE%98%E5%AD%A6%E6%A0%A1%E6%AF%95%E4%B8%9A%E7%94%9F-%E5%8F%8D%E5%85%B1%E7%88%B1%E5%9B%BD%E6%95%99%E8%82%B2-%E8%AF%BE%E7%A8%8B-%E5%BA%94%E5%AF%B9%E5%A4%A7%E9%99%86%E5%86%9B%E4%BA%8B%E5%8E%8B%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783287154000.webp","sourceId":"rfi"},{"id":1783286945000,"createdDate":"2026-07-05 21:29","name":"法国国际广播电台","title":"世界杯：国际足联撤销美国前锋巴洛贡自动停赛 特朗普致谢 比利时足协表示震惊","content":"国际足联（FIFA）纪律委员会决定撤销美国前锋弗拉林·巴洛贡的自动停赛处罚，使其得以出战7月6日世界杯十六强对阵比利时的比赛。美国总统特朗普对此公开表示感谢，而比利时足协则称这一决定“令人震惊”。《纽约时报》披露，特朗普早在国际足联改判前数日，就曾亲自致电国际足联主席因凡蒂诺，要求重新审查巴洛贡的停赛决定。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260705-%E4%B8%96%E7%95%8C%E6%9D%AF-%E5%9B%BD%E9%99%85%E8%B6%B3%E8%81%94%E6%92%A4%E9%94%80%E7%BE%8E%E5%9B%BD%E5%89%8D%E9%94%8B%E5%B7%B4%E6%B4%9B%E8%B4%A1%E8%87%AA%E5%8A%A8%E5%81%9C%E8%B5%9B-%E7%89%B9%E6%9C%97%E6%99%AE%E8%87%B4%E8%B0%A2-%E6%AF%94%E5%88%A9%E6%97%B6%E8%B6%B3%E5%8D%8F%E8%A1%A8%E7%A4%BA%E9%9C%87%E6%83%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783286945000.webp","sourceId":"rfi"},{"id":1783285912000,"createdDate":"2026-07-05 21:11","name":"法国国际广播电台","title":"塞内加尔总统法耶要自创新政党","content":"在塞内加尔，与议长松科（OusmaneSonko）之间发生严重分歧的现总统法耶（présidentsénégalaisBassirouDiomayeFaye），面对在（Pastef）党内遭到孤立，宣布要自创一个新政党。本台法广非洲组（RFIAfrique）法语通讯员发回报道说，这一决定是塞内加尔国家元首于本周五，在总统府召集与其结盟的300多名塞内加尔市长们与会时宣布的。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260705-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%A1%9E%E5%86%85%E5%8A%A0%E5%B0%94%E6%80%BB%E7%BB%9F%E6%B3%95%E8%80%B6%E8%A6%81%E8%87%AA%E5%88%9B%E6%96%B0%E6%94%BF%E5%85%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783285912000.webp","sourceId":"rfi"},{"id":1783281528000,"createdDate":"2026-07-05 19:58","name":"法国国际广播电台","title":"美军结束阿拉伯海失踪机组人员搜救行动","content":"美国海军5日宣布，正式结束在阿拉伯海针对一名失踪机组人员的搜救行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260705-%E7%BE%8E%E5%86%9B%E7%BB%93%E6%9D%9F%E9%98%BF%E6%8B%89%E4%BC%AF%E6%B5%B7%E5%A4%B1%E8%B8%AA%E6%9C%BA%E7%BB%84%E4%BA%BA%E5%91%98%E6%90%9C%E6%95%91%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783281528000.webp","sourceId":"rfi"},{"id":1783281510000,"createdDate":"2026-07-05 19:58","name":"法国国际广播电台","title":"德国选项党寻求执掌政权","content":"据德国电视一台和德国广播电台报道，德国选项党（AfD）在埃尔福特举行的为期两天的联邦党代表大会于周日结束。选项党两位联邦主席蒂诺·赫鲁帕拉和爱丽丝·魏德尔均于周六再次当选联合党主席。大会最后通过了多项党章修改。联合主席赫鲁帕拉表示，目前工作的重点是即将举行的州议会选举，选项党必须摆脱反对党的地位。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260705-%E5%BE%B7%E5%9B%BD%E9%80%89%E9%A1%B9%E5%85%9A%E5%AF%BB%E6%B1%82%E6%89%A7%E6%8E%8C%E6%94%BF%E6%9D%83","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783281510000.webp","sourceId":"rfi"},{"id":1783279798000,"createdDate":"2026-07-05 19:29","name":"法国国际广播电台","title":"南非政府上诉阻犀牛角出口失败","content":"南非拥有全球绝大多数现存的犀牛。该国政府试图通过法律程序取消一个私人公园业主拥有的犀牛角出口许可。不过，北开普（Cap-Nord）省高等法院刚刚驳回了政府的这一上诉。本台法广非洲组（RFIAfrique）法文报道说，南非环境事务部保留向更高级别司法机关继续上诉的权利。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260705-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%8D%97%E9%9D%9E%E6%94%BF%E5%BA%9C%E4%B8%8A%E8%AF%89%E9%98%BB%E7%8A%80%E7%89%9B%E8%A7%92%E5%87%BA%E5%8F%A3%E5%A4%B1%E8%B4%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783279798000.webp","sourceId":"rfi"},{"id":1783273854000,"createdDate":"2026-07-05 17:50","name":"法国国际广播电台","title":"北约峰会前:泽连斯基和普京都在美国独立250周年致电特朗普","content":"基辅周六晚宣布，泽连斯基在美国独立宣言纪念日与特朗普进行了电话交谈。克里姆林宫周日宣布，普京与特朗普就乌克兰问题及国际事务进行了电话交谈。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260705-%E5%8C%97%E7%BA%A6%E5%B3%B0%E4%BC%9A%E5%89%8D%EF%BC%8C%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%92%8C%E6%99%AE%E4%BA%AC%E9%83%BD%E5%9C%A8%E7%BE%8E%E5%9B%BD%E7%8B%AC%E7%AB%8B250%E5%91%A8%E5%B9%B4%E8%87%B4%E7%94%B5%E7%89%B9%E6%9C%97%E6%99%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/05/1783273854000.webp","sourceId":"rfi"}]