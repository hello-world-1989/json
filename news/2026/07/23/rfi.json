[{"id":1784795543000,"createdDate":"2026-07-23 08:32","name":"法国国际广播电台","title":"中菲黄岩岛再起摩擦 菲律宾：中国海警船向菲渔业公务船发射水炮","content":"中国与菲律宾船只南海再起摩擦。菲律宾海警官员称，一艘中国海警船周四（7月23日）在斯卡伯勒浅滩(中国称黄岩岛)向菲律宾渔业公务船发射水炮，“间接击中”。这是两国在南海争议海域本周内的第二起摩擦事件。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260723-%E9%BB%84%E5%B2%A9%E5%B2%9B%E5%86%B2%E7%AA%81%EF%BC%8C%E8%8F%B2%E5%BE%8B%E5%AE%BE-%E4%B8%AD%E5%9B%BD%E6%B5%B7%E8%AD%A6%E8%88%B9%E5%90%91%E8%8F%B2%E6%B8%94%E4%B8%9A%E5%85%AC%E5%8A%A1%E8%88%B9%E5%8F%91%E5%B0%84%E6%B0%B4%E7%82%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784795543000.webp","sourceId":"rfi"},{"id":1784794134000,"createdDate":"2026-07-23 08:08","name":"法国国际广播电台","title":"美国国务卿对日中关系恶化表示忧虑 日本表示将与中国继续沟通","content":"东盟（ASEAN）相关外长会议在马尼拉举行，日本外相茂木敏充、美国国务卿鲁比奥等人出席了会议。22日，鲁比奥在当地接受媒体采访时表示，他“对日中关系恶化感到担忧”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260723-%E7%BE%8E%E5%9B%BD%E5%9B%BD%E5%8A%A1%E5%8D%BF%E5%AF%B9%E6%97%A5%E4%B8%AD%E5%85%B3%E7%B3%BB%E6%81%B6%E5%8C%96%E8%A1%A8%E7%A4%BA%E5%BF%A7%E8%99%91-%E6%97%A5%E6%9C%AC%E8%A1%A8%E7%A4%BA%E5%B0%86%E4%B8%8E%E4%B8%AD%E5%9B%BD%E7%BB%A7%E7%BB%AD%E6%B2%9F%E9%80%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784794134000.webp","sourceId":"rfi"},{"id":1784793199000,"createdDate":"2026-07-23 07:53","name":"法国国际广播电台","title":"出狱后三周即赴英 香港前民主派领袖入境一度被扣 已入境与在英家人团聚","content":"香港前民主党主席胡志伟完成国家安全罪的刑期後，已於前(21日)晚离港，但在昨天入境英国时，一度被入境处人员扣查。但据本台了解，胡志伟在被扣查不足一天後，已获准入境，应该不会被遣返。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260723-%E5%87%BA%E7%8B%B1%E5%90%8E%E4%B8%89%E5%91%A8%E5%8D%B3%E8%B5%B4%E8%8B%B1-%E9%A6%99%E6%B8%AF%E5%89%8D%E6%B0%91%E4%B8%BB%E6%B4%BE%E9%A2%86%E8%A2%96%E5%85%A5%E5%A2%83%E4%B8%80%E5%BA%A6%E8%A2%AB%E6%89%A3-%E5%B7%B2%E5%85%A5%E5%A2%83%E4%B8%8E%E5%9C%A8%E8%8B%B1%E5%AE%B6%E4%BA%BA%E5%9B%A2%E8%81%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784793199000.webp","sourceId":"rfi"},{"id":1784792775000,"createdDate":"2026-07-23 07:46","name":"法国国际广播电台","title":"中国向联合国递网络治理立场 促各国不搞数智霸权 勿迫人站队搞破坏","content":"正当欧美国家为中国的人工智能发展感受到威胁之际，后者已向联合国提交《关於数智时代全球网络治理的立场文件》，希望为网络安全划定标准，当中包括不威胁使用武力丶避免网络军备竞赛丶各国可自行发展数智而不应被胁迫靠边站，以及不基于本国优先追求数智霸权等。部分行文予人有针对美国之感。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260723-%E4%B8%AD%E5%9B%BD%E5%90%91%E8%81%94%E5%90%88%E5%9B%BD%E9%80%92%E7%BD%91%E7%BB%9C%E6%B2%BB%E7%90%86%E7%AB%8B%E5%9C%BA-%E4%BF%83%E5%90%84%E5%9B%BD%E4%B8%8D%E6%90%9E%E6%95%B0%E6%99%BA%E9%9C%B8%E6%9D%83-%E5%8B%BF%E8%BF%AB%E4%BA%BA%E7%AB%99%E9%98%9F%E6%90%9E%E7%A0%B4%E5%9D%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784792775000.webp","sourceId":"rfi"}]