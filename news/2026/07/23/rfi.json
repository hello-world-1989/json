[{"id":1784795543000,"createdDate":"2026-07-23 08:32","name":"法国国际广播电台","title":"中菲黄岩岛再起摩擦 菲律宾：中国海警船向菲渔业公务船发射水炮","content":"中国与菲律宾船只南海再起摩擦。菲律宾海警官员称，一艘中国海警船周四（7月23日）在斯卡伯勒浅滩(中国称黄岩岛)向菲律宾渔业公务船发射水炮，“间接击中”。这是两国在南海争议海域本周内的第二起摩擦事件。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260723-%E9%BB%84%E5%B2%A9%E5%B2%9B%E5%86%B2%E7%AA%81%EF%BC%8C%E8%8F%B2%E5%BE%8B%E5%AE%BE-%E4%B8%AD%E5%9B%BD%E6%B5%B7%E8%AD%A6%E8%88%B9%E5%90%91%E8%8F%B2%E6%B8%94%E4%B8%9A%E5%85%AC%E5%8A%A1%E8%88%B9%E5%8F%91%E5%B0%84%E6%B0%B4%E7%82%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784795543000.webp","sourceId":"rfi"},{"id":1784794134000,"createdDate":"2026-07-23 08:08","name":"法国国际广播电台","title":"美国国务卿对日中关系恶化表示忧虑 日本表示将与中国继续沟通","content":"东盟（ASEAN）相关外长会议在马尼拉举行，日本外相茂木敏充、美国国务卿鲁比奥等人出席了会议。22日，鲁比奥在当地接受媒体采访时表示，他“对日中关系恶化感到担忧”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260723-%E7%BE%8E%E5%9B%BD%E5%9B%BD%E5%8A%A1%E5%8D%BF%E5%AF%B9%E6%97%A5%E4%B8%AD%E5%85%B3%E7%B3%BB%E6%81%B6%E5%8C%96%E8%A1%A8%E7%A4%BA%E5%BF%A7%E8%99%91-%E6%97%A5%E6%9C%AC%E8%A1%A8%E7%A4%BA%E5%B0%86%E4%B8%8E%E4%B8%AD%E5%9B%BD%E7%BB%A7%E7%BB%AD%E6%B2%9F%E9%80%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784794134000.webp","sourceId":"rfi"},{"id":1784793199000,"createdDate":"2026-07-23 07:53","name":"法国国际广播电台","title":"出狱后三周即赴英 香港前民主派领袖入境一度被扣 已入境与在英家人团聚","content":"香港前民主党主席胡志伟完成国家安全罪的刑期後，已於前(21日)晚离港，但在昨天入境英国时，一度被入境处人员扣查。但据本台了解，胡志伟在被扣查不足一天後，已获准入境，应该不会被遣返。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260723-%E5%87%BA%E7%8B%B1%E5%90%8E%E4%B8%89%E5%91%A8%E5%8D%B3%E8%B5%B4%E8%8B%B1-%E9%A6%99%E6%B8%AF%E5%89%8D%E6%B0%91%E4%B8%BB%E6%B4%BE%E9%A2%86%E8%A2%96%E5%85%A5%E5%A2%83%E4%B8%80%E5%BA%A6%E8%A2%AB%E6%89%A3-%E5%B7%B2%E5%85%A5%E5%A2%83%E4%B8%8E%E5%9C%A8%E8%8B%B1%E5%AE%B6%E4%BA%BA%E5%9B%A2%E8%81%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784793199000.webp","sourceId":"rfi"},{"id":1784792775000,"createdDate":"2026-07-23 07:46","name":"法国国际广播电台","title":"中国向联合国递网络治理立场 促各国不搞数智霸权 勿迫人站队搞破坏","content":"正当欧美国家为中国的人工智能发展感受到威胁之际，后者已向联合国提交《关於数智时代全球网络治理的立场文件》，希望为网络安全划定标准，当中包括不威胁使用武力丶避免网络军备竞赛丶各国可自行发展数智而不应被胁迫靠边站，以及不基于本国优先追求数智霸权等。部分行文予人有针对美国之感。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260723-%E4%B8%AD%E5%9B%BD%E5%90%91%E8%81%94%E5%90%88%E5%9B%BD%E9%80%92%E7%BD%91%E7%BB%9C%E6%B2%BB%E7%90%86%E7%AB%8B%E5%9C%BA-%E4%BF%83%E5%90%84%E5%9B%BD%E4%B8%8D%E6%90%9E%E6%95%B0%E6%99%BA%E9%9C%B8%E6%9D%83-%E5%8B%BF%E8%BF%AB%E4%BA%BA%E7%AB%99%E9%98%9F%E6%90%9E%E7%A0%B4%E5%9D%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784792775000.webp","sourceId":"rfi"},{"id":1784827759000,"createdDate":"2026-07-23 17:29","name":"法国国际广播电台","title":"韩国选举委员会因涉嫌操纵选举遭搜查","content":"周四，一支由检察官和警察组成的行动组搜查了韩国国家选举委员会（CNE）总部及其多名负责人的住所，原因是他们涉嫌在6月的地方选举中篡改投票率数据。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260723-%E9%9F%A9%E5%9B%BD%E9%80%89%E4%B8%BE%E5%A7%94%E5%91%98%E4%BC%9A%E5%9B%A0%E6%B6%89%E5%AB%8C%E6%93%8D%E7%BA%B5%E9%80%89%E4%B8%BE%E9%81%AD%E6%90%9C%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784827759000.webp","sourceId":"rfi"},{"id":1784822901000,"createdDate":"2026-07-23 16:08","name":"法国国际广播电台","title":"两名法国外交官在伊朗遭袭击后返回巴黎","content":"法国外长让-诺埃尔·巴罗周四表示，两名在德黑兰遭遇袭击的法国外交官已于周三返回巴黎，并强调他们之所以遭到袭击，是因执行法国支持伊朗民间社会的任务。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260723-%E4%B8%A4%E5%90%8D%E6%B3%95%E5%9B%BD%E5%A4%96%E4%BA%A4%E5%AE%98%E5%9C%A8%E4%BC%8A%E6%9C%97%E9%81%AD%E8%A2%AD%E5%87%BB%E5%90%8E%E8%BF%94%E5%9B%9E%E5%B7%B4%E9%BB%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784822901000.webp","sourceId":"rfi"},{"id":1784818701000,"createdDate":"2026-07-23 14:58","name":"法国国际广播电台","title":"马尼拉美俄会谈：拉夫罗夫就向乌克兰提供武器向卢比奥发出警告","content":"周四，在东盟马尼拉会议期间，美国国务卿与俄罗斯外长举行会晤。俄外长拉夫罗夫警告美国国务卿卢比奥称继续向乌克兰提供武器是“不可接受的”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260723-%E9%A9%AC%E5%B0%BC%E6%8B%89%E7%BE%8E%E4%BF%84%E4%BC%9A%E8%B0%88-%E6%8B%89%E5%A4%AB%E7%BD%97%E5%A4%AB%E5%B0%B1%E5%90%91%E4%B9%8C%E5%85%8B%E5%85%B0%E6%8F%90%E4%BE%9B%E6%AD%A6%E5%99%A8%E5%90%91%E5%8D%A2%E6%AF%94%E5%A5%A5%E5%8F%91%E5%87%BA%E8%AD%A6%E5%91%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784818701000.webp","sourceId":"rfi"},{"id":1784816725000,"createdDate":"2026-07-23 14:25","name":"法国国际广播电台","title":"中国解放军在台湾海峡举行实弹军演 持续两天","content":"中国官方周四宣布，北京已开始在中国福建省沿海和台湾海峡部分区域举行实弹演习，并透露演习将持续两天。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260723-%E4%B8%AD%E5%9B%BD%E5%9C%A8%E5%8F%B0%E6%B9%BE%E6%B5%B7%E5%B3%A1%E5%AE%9E%E5%BC%B9%E6%BC%94%E4%B9%A0-%E6%8C%81%E7%BB%AD%E4%B8%A4%E5%A4%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784816725000.webp","sourceId":"rfi"},{"id":1784816137000,"createdDate":"2026-07-23 14:15","name":"法国国际广播电台","title":"赞比亚系列报道之四 ： 赞比亚人眼中的中国人","content":"南部非洲的陆地国家赞比亚是中国在非洲的一大重要的合作伙伴国，两年前双方刚刚隆重庆祝了中赞建交六十周年。六十年来，中赞之间的双边经贸以及文化合作关系日益紧密，2007年，中国在赞比亚设立了非洲首个经贸合作区，目前已经汇聚了近百家的中国企业。根据中国外交部网站提供的数据，2025年两国贸易额为75.53亿美元，同比增长13.61%；其中中方进口额56.48亿美元，中国主要从赞进口铜、矿产和木制品，向赞出口电机、钢铁制品、电子产品等，而事实上，中国从赞比亚进口的产品绝大多数由在赞比亚的中资企业所声称。 在赞比亚，尤其是在首都卢萨卡以及北部的铜带省，中国工厂，中国超市，中国赌场随处可见。据当地人介绍，有些中国超市还禁止本地人出入，另外，他们说赞比亚的赌场也是随着中国人的到来而逐渐出现的，进出赌场的人，几乎都是中国人。中国投资为赞比亚经济带来活力，但是，个别中国企业以及商人的一些不良行为也受到当地人侧目。赞比亚街头的普通人对中国人的印象如何？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E5%A2%83%E4%B8%8E%E5%8F%91%E5%B1%95/20260723-%E8%B5%9E%E6%AF%94%E4%BA%9A%E7%B3%BB%E5%88%97%E6%8A%A5%E9%81%93%E4%B9%8B%E5%9B%9B-%E8%B5%9E%E6%AF%94%E4%BA%9A%E4%BA%BA%E7%9C%BC%E4%B8%AD%E7%9A%84%E4%B8%AD%E5%9B%BD%E4%B8%8E%E4%B8%AD%E5%9B%BD%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784816137000.webp","sourceId":"rfi"},{"id":1784815852000,"createdDate":"2026-07-23 14:10","name":"法国国际广播电台","title":"美军袭伊朗第12夜 伊朗再袭中东美国设施 胡塞开辟第二战场","content":"伊朗周四誓言，只要继续遭受攻击，就将对美国实施报复；与此同时，伊朗的盟友也门胡塞武装在地区战争中开辟了第二战场，宣称对红海两艘沙特油轮的袭击负责。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260723-%E7%BE%8E%E5%86%9B%E8%A2%AD%E4%BC%8A%E6%9C%97%E7%AC%AC12%E5%A4%9C-%E4%BC%8A%E6%9C%97%E5%86%8D%E8%A2%AD%E4%B8%AD%E4%B8%9C%E7%BE%8E%E5%9B%BD%E8%AE%BE%E6%96%BD-%E8%83%A1%E5%A1%9E%E5%BC%80%E8%BE%9F%E7%AC%AC%E4%BA%8C%E6%88%98%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784815852000.webp","sourceId":"rfi"},{"id":1784814399000,"createdDate":"2026-07-23 13:46","name":"法国国际广播电台","title":"美国沙特核能合作协议为何引发核扩散担忧","content":"美国政府周三（7月22日）宣布，已与沙特达成民用核能合作协议，这一被视为双方伙伴关系近年来最重要成果的协议，允许沙特利用美国技术建造核反应堆并浓缩铀，华盛顿强调协议设置了严格安全措施，保障核不扩散，而这正是美国发起对伊朗打击的核心目的所在，但协议的签署仍然引发对中东核军备竞赛的担忧。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260723-%E7%BE%8E%E5%9B%BD%E4%B8%8E%E6%B2%99%E7%89%B9%E7%AD%BE%E7%BD%B2%E6%B0%91%E7%94%A8%E6%A0%B8%E8%83%BD%E5%90%88%E4%BD%9C%E5%8D%8F%E8%AE%AE-%E5%BC%95%E5%8F%91%E4%B8%AD%E4%B8%9C%E6%A0%B8%E6%89%A9%E6%95%A3%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784814399000.webp","sourceId":"rfi"},{"id":1784814058000,"createdDate":"2026-07-23 13:40","name":"法国国际广播电台","title":"特朗普: 美沙民用核能协议条件是沙特承认以色列","content":"唐纳德·特朗普周四在其社交媒体平台“TruthSocial”上宣布，美国与沙特阿拉伯之间的民用核能协议“完全取决于”沙特王国批准《亚伯拉罕协议》，从而承认以色列国。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260723-%E7%89%B9%E6%9C%97%E6%99%AE-%E7%BE%8E%E6%B2%99%E6%B0%91%E7%94%A8%E6%A0%B8%E8%83%BD%E5%8D%8F%E8%AE%AE%E7%9A%84%E6%9D%A1%E4%BB%B6%E6%98%AF%E6%B2%99%E7%89%B9%E6%89%BF%E8%AE%A4%E4%BB%A5%E8%89%B2%E5%88%97","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784814058000.webp","sourceId":"rfi"},{"id":1784814050000,"createdDate":"2026-07-23 13:40","name":"法国国际广播电台","title":"视频 卢浮宫王室珠宝遭窃展厅关闭后 重新向游客开放","content":"卢浮宫博物馆于周三（7月22日）重新向游客开放了阿波罗展厅（Galeried'Apollon）。此前该馆曾发生一起轰动一时的法国王室珠宝失窃案，涉案价值估计达1.02亿美元，此次事件暴露了这座全球游客量最大的博物馆在安保方面存在薄弱环节。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260723-%E8%A7%86%E9%A2%91-%E5%8D%A2%E6%B5%AE%E5%AE%AB%E7%8E%8B%E5%AE%A4%E7%8F%A0%E5%AE%9D%E9%81%AD%E7%AA%83%E5%B1%95%E5%8E%85%E5%85%B3%E9%97%AD%E5%90%8E-%E9%87%8D%E6%96%B0%E5%90%91%E6%B8%B8%E5%AE%A2%E5%BC%80%E6%94%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784814050000.webp","sourceId":"rfi"},{"id":1784813025000,"createdDate":"2026-07-23 13:23","name":"法国国际广播电台","title":"东盟外长会议  上演大国博弈","content":"在当今世界和平被战争所破坏、国际地缘政治局势错综复杂、诸多国家在政治与经济层面遭遇重大挑战的背景下，正在菲律宾首都马尼拉召开的东盟外长会议罕见成为了中美俄大国展开地缘政治角逐的外交舞台，其中关于结束俄乌战争的美俄会谈尤其引人瞩目。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260723-%E4%B8%9C%E7%9B%9F%E5%A4%96%E9%95%BF%E4%BC%9A%E8%AE%AE-%E4%B8%8A%E6%BC%94%E5%A4%A7%E5%9B%BD%E5%8D%9A%E5%BC%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784813025000.webp","sourceId":"rfi"},{"id":1784812973000,"createdDate":"2026-07-23 13:22","name":"法国国际广播电台","title":"报摘：法国贩毒团伙猖獗；ChatGPT上演“越狱“，AI失控了吗？","content":"周四（7月23号）法国几份全国发行大报头版聚焦不同，但不约而同关注国内几大热点议题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260723-%E6%8A%A5%E6%91%98-%E6%B3%95%E5%9B%BD%E8%B4%A9%E6%AF%92%E5%9B%A2%E4%BC%99%E7%8C%96%E7%8D%97-chatgpt%E4%B8%8A%E6%BC%94-%E8%B6%8A%E7%8B%B1-%EF%BC%8Cai%E5%A4%B1%E6%8E%A7%E4%BA%86%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784812973000.webp","sourceId":"rfi"},{"id":1784811480000,"createdDate":"2026-07-23 12:58","name":"法国国际广播电台","title":"所罗门群岛将允许美国海岸警卫队在其海域巡逻","content":"所罗门群岛总理马修·韦尔在访问华盛顿时表示，该国将签署一项协议，允许美国海岸警卫队在当地警察随船的情况下，在其领海内执行巡逻任务。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260723-%E6%89%80%E7%BD%97%E9%97%A8%E7%BE%A4%E5%B2%9B%E5%B0%86%E5%85%81%E8%AE%B8%E7%BE%8E%E5%9B%BD%E6%B5%B7%E5%B2%B8%E8%AD%A6%E5%8D%AB%E9%98%9F%E5%9C%A8%E5%85%B6%E6%B5%B7%E5%9F%9F%E5%B7%A1%E9%80%BB-1","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784811480000.webp","sourceId":"rfi"},{"id":1784803260000,"createdDate":"2026-07-23 10:41","name":"法国国际广播电台","title":"东盟马尼拉安全论坛 聚焦中东安全和南海紧张局势等","content":"来自亚洲、欧洲和北美的资深外交官今天周四在马尼拉参加东盟地区安全论坛，呼吁通过和平方式解决中东冲突升级等问题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260723-%E4%B8%9C%E7%9B%9F%E9%A9%AC%E5%B0%BC%E6%8B%89%E5%AE%89%E5%85%A8%E8%AE%BA%E5%9D%9B-%E8%81%9A%E7%84%A6%E4%B8%AD%E4%B8%9C%E5%AE%89%E5%85%A8%E5%92%8C%E5%8D%97%E6%B5%B7%E7%B4%A7%E5%BC%A0%E5%B1%80%E5%8A%BF%E7%AD%89","thumbnail":"","detailImage":"news/detail/rfi/2026/07/23/1784803260000.webp","sourceId":"rfi"}]