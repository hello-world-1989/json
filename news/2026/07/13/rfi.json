[{"id":1783939027000,"createdDate":"2026-07-13 10:37","name":"法国国际广播电台","title":"400名苹果员工遭挖墙脚，面试时被要求携带未发布产品：苹果起诉 OpenAI大规模窃取商业机密","content":"近日，美国两家科技巨头反目成仇。苹果公司7月10日指控OpenAI为开发自己的ChatGPT硬件设备而窃取商业机密，这一指控基本标志着两家公司之间的合作关系彻底破裂。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E7%BB%8F%E6%B5%8E/20260713-%E8%B6%85400%E5%90%8D%E8%8B%B9%E6%9E%9C%E5%91%98%E5%B7%A5%E9%81%AD%E6%8C%96%E5%A2%99%E8%84%9A%EF%BC%8C%E9%9D%A2%E8%AF%95%E6%97%B6%E8%A2%AB%E8%A6%81%E6%B1%82%E6%90%BA%E5%B8%A6%E6%9C%AA%E5%8F%91%E5%B8%83%E4%BA%A7%E5%93%81-%E8%8B%B9%E6%9E%9C%E8%B5%B7%E8%AF%89-openai%E5%A4%A7%E8%A7%84%E6%A8%A1%E7%AA%83%E5%8F%96%E5%95%86%E4%B8%9A%E6%9C%BA%E5%AF%86","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783939027000.webp","sourceId":"rfi"},{"id":1783937474000,"createdDate":"2026-07-13 10:11","name":"法国国际广播电台","title":"美国怎将中国、伊朗和俄罗斯挤出委内瑞拉：整个拉美正走向“特朗普化”","content":"大家好，周一7月13日上市的法国全国性日报头版所关注的焦点各有不同，包括：克里米亚现状、尼斯恐袭十周年以及热浪引发的山火等。我们将集中介绍由《回声报》国际版资深记者伊夫·布尔迪永撰写分析“美国如何将中国、伊朗和俄罗斯排挤出委内瑞拉”的文章。文章开头表明，近几个月来，美国在委内瑞拉成功超越了其竞争对手（中国、俄罗斯、伊朗）。尽管加拉加斯长期以反美帝国主义作为其政治标志，但务实主义和石油利益推动了这一戏剧性的和解。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260713-%E7%BE%8E%E5%9B%BD%E6%80%8E%E5%B0%86%E4%B8%AD%E5%9B%BD-%E4%BC%8A%E6%9C%97%E5%92%8C%E4%BF%84%E7%BD%97%E6%96%AF%E6%8C%A4%E5%87%BA%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89-%E6%95%B4%E4%B8%AA%E6%8B%89%E7%BE%8E%E6%AD%A3%E8%B5%B0%E5%90%91-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783937474000.webp","sourceId":"rfi"},{"id":1783936906000,"createdDate":"2026-07-13 10:01","name":"法国国际广播电台","title":"刘晓波逝世九周年，首届刘晓波人权奖颁奖典礼在德国莱比锡举行","content":"7月13日是中国零八宪章发起人之一及2010年诺贝尔和平奖得主刘晓波逝世九周年。总部设在德国的媒体“欧洲之声”和总部设在英国的“中国研究”联合举办首届“刘晓波人权奖颁奖典礼及中国宪政民主研讨会。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260713-%E5%88%98%E6%99%93%E6%B3%A2%E9%80%9D%E4%B8%96%E4%B9%9D%E5%91%A8%E5%B9%B4%EF%BC%8C%E9%A6%96%E5%B1%8A%E5%88%98%E6%99%93%E6%B3%A2%E4%BA%BA%E6%9D%83%E5%A5%96%E9%A2%81%E5%A5%96%E5%85%B8%E7%A4%BC%E5%9C%A8%E5%BE%B7%E5%9B%BD%E8%8E%B1%E6%AF%94%E9%94%A1%E4%B8%BE%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783936906000.webp","sourceId":"rfi"},{"id":1783933260000,"createdDate":"2026-07-13 09:01","name":"法国国际广播电台","title":"支持乌克兰“自愿联盟”在巴黎举行峰会  500名成员国士兵将出席法国国庆阅兵","content":"法国总统马克龙将于7月13日（周一）主持召开“自愿联盟”峰会。该联盟由约30个国家组成，支持乌克兰。继2026年1月6日《巴黎宣言》之后，此次峰会将使各国领导人能够审查旨在确保乌克兰实现持久和平的安全保障行动计划。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260713-%E6%94%AF%E6%8C%81%E4%B9%8C%E5%85%8B%E5%85%B0-%E8%87%AA%E6%84%BF%E8%81%94%E7%9B%9F-%E5%9C%A8%E5%B7%B4%E9%BB%8E%E4%B8%BE%E8%A1%8C%E5%B3%B0%E4%BC%9A-500%E5%90%8D%E6%88%90%E5%91%98%E5%9B%BD%E5%A3%AB%E5%85%B5%E5%B0%86%E5%87%BA%E5%B8%AD%E6%B3%95%E5%9B%BD%E5%9B%BD%E5%BA%86%E9%98%85%E5%85%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783933260000.webp","sourceId":"rfi"},{"id":1783929489000,"createdDate":"2026-07-13 07:58","name":"法国国际广播电台","title":"日本官房长官对美伊再开火表示担忧 呼吁双方早日达成最终共识","content":"日本内阁官房长官木原稔，在13日上午的记者会上，针对美国与伊朗之间持续的军事紧张局势表示担忧，并称日本政府将全力确保仍停留在霍尔木兹海峡的日本相关船舶安全，同时再次呼吁美伊尽快达成最终协议。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260713-%E6%97%A5%E6%9C%AC%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E5%AF%B9%E7%BE%8E%E4%BC%8A%E5%86%8D%E5%BC%80%E7%81%AB%E8%A1%A8%E7%A4%BA%E6%8B%85%E5%BF%A7-%E5%91%BC%E5%90%81%E5%8F%8C%E6%96%B9%E6%97%A9%E6%97%A5%E8%BE%BE%E6%88%90%E6%9C%80%E7%BB%88%E5%85%B1%E8%AF%86","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783929489000.webp","sourceId":"rfi"},{"id":1783929479000,"createdDate":"2026-07-13 07:57","name":"法国国际广播电台","title":"2026世界杯接近尾声 2030年世界杯再增加16支球队的可能性提上议程","content":"国际足联主席詹尼·因凡蒂诺在一次采访中表示，国际足联官员将考虑在2030年世界杯之前再增加16支参赛队伍的可能性。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260713-2026%E4%B8%96%E7%95%8C%E6%9D%AF%E6%8E%A5%E8%BF%91%E5%B0%BE%E5%A3%B0-2030%E5%B9%B4%E4%B8%96%E7%95%8C%E6%9D%AF%E5%86%8D%E5%A2%9E%E5%8A%A016%E6%94%AF%E7%90%83%E9%98%9F%E7%9A%84%E5%8F%AF%E8%83%BD%E6%80%A7%E6%8F%90%E4%B8%8A%E8%AE%AE%E7%A8%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783929479000.webp","sourceId":"rfi"},{"id":1783925146000,"createdDate":"2026-07-13 06:45","name":"法国国际广播电台","title":"「香港议会」成员张信燕获加拿大庇护签证 起程时遭泰警拦截 议员吁加国介入","content":"与被港府定性为颠覆组织的「香港议会」丶并遭港府通缉的中国公民张信燕，在泰国被扣押期间获加拿大发出庇护签证，原定上周三(8日)由曼谷飞往加拿大温哥华时，在机场遭泰国警方拦截，未能离境。「香港议会」发起人之一的袁弓夷表示，已聘请人权律师协助张信燕，她的未婚夫亦已抵达泰国了解情况，以防她被泰国当局遣返中国。在香港出生的加拿大国会议员关慧贞更发表声明，呼吁加拿大政府采取行动，确保她能够安全前往加拿大。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260713-%E9%A6%99%E6%B8%AF%E8%AE%AE%E4%BC%9A-%E6%88%90%E5%91%98%E5%BC%A0%E4%BF%A1%E7%87%95%E8%8E%B7%E5%8A%A0%E6%8B%BF%E5%A4%A7%E5%BA%87%E6%8A%A4%E7%AD%BE%E8%AF%81-%E8%B5%B7%E7%A8%8B%E6%97%B6%E9%81%AD%E6%B3%B0%E8%AD%A6%E6%8B%A6%E6%88%AA-%E8%AE%AE%E5%91%98%E5%90%81%E5%8A%A0%E5%9B%BD%E4%BB%8B%E5%85%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783925146000.webp","sourceId":"rfi"},{"id":1783924240000,"createdDate":"2026-07-13 06:30","name":"法国国际广播电台","title":"黄锦辉涉醉驾辞任立法会议员 空缺议席是否补选令港府陷两难","content":"涉嫌酒后驾驶丶撞车后不顾而去，被质疑知法犯法的立法会议员黄锦辉，在北京安排全体立法会议员赴京考察前夕，辞任议员一职，虽为北京和立法会声誉受损「止血」，避免事件进一步引发尴尬，但其辞职后留下的议席是否需要填补，仍然引发争议。分析指事件令港府陷入两难，若为一个被视为可有可无的议席举办补选会被视指为浪费公帑，若放弃补选便可能版视为不守法。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260713-%E9%BB%84%E9%94%A6%E8%BE%89%E6%B6%89%E9%86%89%E9%A9%BE%E8%BE%9E%E4%BB%BB%E7%AB%8B%E6%B3%95%E4%BC%9A%E8%AE%AE%E5%91%98-%E7%A9%BA%E7%BC%BA%E8%AE%AE%E5%B8%AD%E6%98%AF%E5%90%A6%E8%A1%A5%E9%80%89%E4%BB%A4%E6%B8%AF%E5%BA%9C%E9%99%B7%E4%B8%A4%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783924240000.webp","sourceId":"rfi"},{"id":1783982946000,"createdDate":"2026-07-13 22:49","name":"法国国际广播电台","title":"普京的克里米亚之痛","content":"法国总统马克龙周一在巴黎召集37国“自愿联盟”开会，20余位国家元首和政府首脑以及十几国部长出席，旨在强化对乌克兰的军援，特别是防空领域，以彰显欧洲的“战略觉醒”，普京则痛斥这是一个“好战联盟”。峰会召开前几小时，法德英等9国联合乌克兰组建共同开发“反导导弹”联盟，以帮助基辅抵御俄罗斯的大规模导弹袭击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260713-%E6%99%AE%E4%BA%AC%E7%9A%84%E5%85%8B%E9%87%8C%E7%B1%B3%E4%BA%9A%E4%B9%8B%E7%97%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783982946000.webp","sourceId":"rfi"},{"id":1783982261000,"createdDate":"2026-07-13 22:37","name":"法国国际广播电台","title":"战胜西班牙不易 但法国手上也有王牌","content":"法国与西班牙队的一场“巨人之战”几小时后就要在达拉斯打响了，德尚指挥的法兰西军团想连续第三届进入世界杯决赛，首先必须扳倒亚马尔领衔的欧洲冠军西班牙。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260713-%E6%88%98%E8%83%9C%E8%A5%BF%E7%8F%AD%E7%89%99%E4%B8%8D%E6%98%93-%E4%BD%86%E6%B3%95%E5%9B%BD%E6%89%8B%E4%B8%8A%E4%B9%9F%E6%9C%89%E7%8E%8B%E7%89%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783982261000.webp","sourceId":"rfi"},{"id":1783978677000,"createdDate":"2026-07-13 21:37","name":"法国国际广播电台","title":"英国与欧盟联合宣布制裁俄罗斯 指责其发动网络攻击破坏欧洲安全","content":"英国和欧盟周一（7月13日）联合宣布对俄罗斯实施新一轮制裁，指责俄方发动网络攻击，企图“在欧洲制造混乱和分裂”。欧盟当天还宣布，就侵犯乌克兰战俘和被拘押平民人权问题，对俄罗斯追加实施制裁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260713-%E8%8B%B1%E5%9B%BD%E4%B8%8E%E6%AC%A7%E7%9B%9F%E8%81%94%E5%90%88%E5%AE%A3%E5%B8%83%E5%88%B6%E8%A3%81%E4%BF%84%E7%BD%97%E6%96%AF-%E6%8C%87%E8%B4%A3%E5%85%B6%E5%8F%91%E5%8A%A8%E7%BD%91%E7%BB%9C%E6%94%BB%E5%87%BB%E7%A0%B4%E5%9D%8F%E6%AC%A7%E6%B4%B2%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783978677000.webp","sourceId":"rfi"},{"id":1783978385000,"createdDate":"2026-07-13 21:33","name":"法国国际广播电台","title":"希音拟最快8月在香港上市 拟融资最高30亿美元","content":"据彭博新闻社13日报道，快时尚零售商希音（Shein）计划最快于8月在香港首次公开募股（IPO），拟融资约20亿至30亿美元。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260713-%E5%B8%8C%E9%9F%B3%E6%8B%9F%E6%9C%80%E5%BF%AB8%E6%9C%88%E5%9C%A8%E9%A6%99%E6%B8%AF%E4%B8%8A%E5%B8%82-%E8%9E%8D%E8%B5%84%E8%A7%84%E6%A8%A1%E6%88%96%E8%BE%BE30%E4%BA%BF%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783978385000.webp","sourceId":"rfi"},{"id":1783978363000,"createdDate":"2026-07-13 21:32","name":"法国国际广播电台","title":"公民记者张展狱中获刘晓波人权奖，作家严歌苓代为领奖","content":"刘晓波人权奖7月13日在德国城市莱比锡举办首届颁奖仪式。该奖由总部设在德国的媒体“欧洲之声“和总部设在英国的“中国研究”联合创办。首届奖项的两位获奖者分别是德国莱茵马斯职业高校教师、牧师罗兰德-库讷和中国公民记者张展。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260713-%E5%85%AC%E6%B0%91%E8%AE%B0%E8%80%85%E5%BC%A0%E5%B1%95%E7%8B%B1%E4%B8%AD%E8%8E%B7%E5%88%98%E6%99%93%E6%B3%A2%E4%BA%BA%E6%9D%83%E5%A5%96%EF%BC%8C%E4%BD%9C%E5%AE%B6%E4%B8%A5%E6%AD%8C%E8%8B%93%E4%BB%A3%E4%B8%BA%E9%A2%86%E5%A5%96","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783978363000.webp","sourceId":"rfi"},{"id":1783978099000,"createdDate":"2026-07-13 21:28","name":"法国国际广播电台","title":"欧洲九国与乌克兰组建反导合作机制 马克龙：将提升乌克兰防御能力","content":"欧洲九国周一（7月13日）在巴黎宣布，与乌克兰共同成立一个“纯防御性质”的合作机制，旨在联合研发欧洲急需的反弹道导弹能力，以应对俄罗斯持续空袭给乌克兰带来的安全挑战。法国总统马克龙表示，这一合作将整合各国现有能力和军工资源，加快提升乌克兰的反导防御能力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260713-%E6%AC%A7%E6%B4%B2%E4%B9%9D%E5%9B%BD%E4%B8%8E%E4%B9%8C%E5%85%8B%E5%85%B0%E7%BB%84%E5%BB%BA%E5%8F%8D%E5%AF%BC%E5%90%88%E4%BD%9C%E6%9C%BA%E5%88%B6-%E9%A9%AC%E5%85%8B%E9%BE%99-%E5%B0%86%E6%8F%90%E5%8D%87%E4%B9%8C%E5%85%8B%E5%85%B0%E9%98%B2%E5%BE%A1%E8%83%BD%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783978099000.webp","sourceId":"rfi"},{"id":1783977719000,"createdDate":"2026-07-13 21:21","name":"法国国际广播电台","title":"特朗普宣布恢复对伊朗海上封锁 美军公布实施时间","content":"美国总统特朗普周一（7月13日）宣布恢复对伊朗海上封锁，并表示美国将对经霍尔木兹海峡运输的货物征收相当于货值20%的费用。美军表示，封锁措施将于格林尼治时间15日20时正式生效。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260713-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AE%A3%E5%B8%83%E6%81%A2%E5%A4%8D%E5%AF%B9%E4%BC%8A%E6%9C%97%E6%B5%B7%E4%B8%8A%E5%B0%81%E9%94%81-%E7%BE%8E%E5%86%9B%E5%85%AC%E5%B8%83%E5%AE%9E%E6%96%BD%E6%97%B6%E9%97%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783977719000.webp","sourceId":"rfi"},{"id":1783976327000,"createdDate":"2026-07-13 20:58","name":"法国国际广播电台","title":"特朗普称美将接管霍尔木兹海峡拟征20%货运补偿费","content":"美国总统特朗普（DonaldTrump）周一宣布，美国将重新实施针对伊朗船只的海上封锁，并由美方负责霍尔木兹海峡安全，同时向所有通过这条全球重要能源航道的货物，征收20%补偿费，作为维护航道安全的成本。此举进一步升高美伊围绕霍尔木兹海峡控制权的对立。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260713-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E7%BE%8E%E5%B0%86%E6%8E%A5%E7%AE%A1%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%8B%9F%E5%BE%8120-%E8%B4%A7%E8%BF%90%E8%A1%A5%E5%81%BF%E8%B4%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783976327000.webp","sourceId":"rfi"},{"id":1783975751000,"createdDate":"2026-07-13 20:49","name":"法国国际广播电台","title":"法国全力扑救枫丹白露森林大火","content":"周一，法国全力扑救巴黎以南一片森林中的大火，过火面积达约1200公顷；与此同时，警方逮捕了两名涉嫌纵火的人员。这场大火于周日在广阔的枫丹白露森林爆发。这片森林位于首都东南约60公里处，曾经是皇家狩猎场，如今散布着一个个宁静的村庄。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260713-%E6%B3%95%E5%9B%BD%E5%85%A8%E5%8A%9B%E6%89%91%E6%95%91%E6%9E%AB%E4%B8%B9%E7%99%BD%E9%9C%B2%E6%A3%AE%E6%9E%97%E5%A4%A7%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783975751000.webp","sourceId":"rfi"},{"id":1783966312000,"createdDate":"2026-07-13 18:11","name":"法国国际广播电台","title":"马达加斯加首都集中爆发失踪潮","content":"在印度洋岛国马达加斯加（Madagascar），始于六月下旬的失踪潮造成首都安塔那那利佛（Antananarivo）陷入恐慌。该国警方公布的最新数据显示，目前仍有近百名儿童失踪，主要集中在首都。如此状况，马达加斯加总统米夏埃尔·兰德里亚尼里纳（PrésidentmalgacheMichaëlRandrianirina)予以谴责，并承诺要“摧毁幕后组织”。许多当地民众接受了本台法广非洲组（RFIAfrique）法语通讯员的现场采访。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260713-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E9%A9%AC%E8%BE%BE%E5%8A%A0%E6%96%AF%E5%8A%A0%E9%A6%96%E9%83%BD%E9%9B%86%E4%B8%AD%E7%88%86%E5%8F%91%E5%A4%B1%E8%B8%AA%E6%BD%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783966312000.webp","sourceId":"rfi"},{"id":1783964450000,"createdDate":"2026-07-13 17:40","name":"法国国际广播电台","title":"刚果(金)审计惊现近40%空饷警员","content":"在非洲国家刚果民主共和国（RDCongo），一份全国警力审计报告揭示，有近40%警员为虚报或在编不在岗。本台法广非洲组（RFIAfrique）法语通讯员发自金沙萨（Kinshasa）的消息说，如果不采取措施，每年可造成的财政损失超过2亿3千3百万美元。而可采取的措施建议包含暂时恢复手控的工资发放流程。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260713-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%88%9A%E6%9E%9C-%E9%87%91-%E5%AE%A1%E8%AE%A1%E6%83%8A%E7%8E%B0%E8%BF%9140-%E7%A9%BA%E9%A5%B7%E8%AD%A6%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783964450000.webp","sourceId":"rfi"},{"id":1783964056000,"createdDate":"2026-07-13 17:34","name":"法国国际广播电台","title":"身陷八起官司的韩国前总统尹锡悦因非法免费民调再获刑两年","content":"韩国一家法院周一判处前总统尹锡悦两年监禁，认定其非法从一名政治中间人处获益，接受了价值27亿韩元（约合157,502欧元）的免费民意调查服务。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260713-%E8%BA%AB%E9%99%B7%E5%85%AB%E8%B5%B7%E5%AE%98%E5%8F%B8%E7%9A%84%E9%9F%A9%E5%9B%BD%E5%89%8D%E6%80%BB%E7%BB%9F%E5%B0%B9%E9%94%A1%E6%82%A6%E5%9B%A0%E9%9D%9E%E6%B3%95%E5%85%8D%E8%B4%B9%E6%B0%91%E8%B0%83%E5%86%8D%E8%8E%B7%E5%88%91%E4%B8%A4%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783964056000.webp","sourceId":"rfi"},{"id":1783962341000,"createdDate":"2026-07-13 17:05","name":"法国国际广播电台","title":"曼谷酒吧火灾爆炸 至少28人遇难数十人伤","content":"据当局和目击者称，周日晚上，曼谷郊区一家酒吧发生火灾，造成至少28人死亡，数十人受伤，这是泰国近几十年来最严重的此类灾难。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260713-%E6%9B%BC%E8%B0%B7%E9%85%92%E5%90%A7%E7%81%AB%E7%81%BE%E7%88%86%E7%82%B8-%E8%87%B3%E5%B0%9128%E4%BA%BA%E9%81%87%E9%9A%BE%E6%95%B0%E5%8D%81%E4%BA%BA%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783962341000.webp","sourceId":"rfi"},{"id":1783956058000,"createdDate":"2026-07-13 15:20","name":"法国国际广播电台","title":"伊朗称将继续与调解方磋商 避免冲突局势升级","content":"伊朗周一表示，将继续与卡塔尔、巴基斯坦和阿曼等调解国进行外交磋商，以“防止局势升级”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260713-%E4%BC%8A%E6%9C%97%E7%A7%B0%E5%B0%86%E7%BB%A7%E7%BB%AD%E4%B8%8E%E8%B0%83%E8%A7%A3%E6%96%B9%E7%A3%8B%E5%95%86-%E9%81%BF%E5%85%8D%E5%86%B2%E7%AA%81%E5%B1%80%E5%8A%BF%E5%8D%87%E7%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783956058000.webp","sourceId":"rfi"},{"id":1783955878000,"createdDate":"2026-07-13 15:17","name":"法国国际广播电台","title":"法国国庆日遇世界杯半决赛，全国将部署约7万名警察和宪兵","content":"7月14日是法国国庆日，同时也是世界杯的半决赛日。届时法国队将对战西班牙队。法国警方表示，为确保国庆日庆祝活动安全举行，并防止当晚世界杯半决赛期间出现任何骚乱，巴黎及其周边地区将部署大规模安保力量，包括7000名警察和宪兵以及2000名消防员。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260713-%E6%B3%95%E5%9B%BD%E5%9B%BD%E5%BA%86%E6%97%A5%E9%81%87%E4%B8%96%E7%95%8C%E6%9D%AF%E5%8D%8A%E5%86%B3%E8%B5%9B%EF%BC%8C%E5%85%A8%E5%9B%BD%E5%B0%86%E9%83%A8%E7%BD%B2%E7%BA%A67%E4%B8%87%E5%90%8D%E8%AD%A6%E5%AF%9F%E5%92%8C%E5%AE%AA%E5%85%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783955878000.webp","sourceId":"rfi"},{"id":1783954123000,"createdDate":"2026-07-13 14:48","name":"法国国际广播电台","title":"法国枫丹白露森林火灾 800消防员扑救","content":"周一下午，塞纳-马恩省省长表示，在枫丹白露森林肆虐的森林大火尚未得到控制，目前已过火约5%的林区。该省长补充道，共有800名消防员以及大量空中灭火力量被调动以对抗火势。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260713-%E6%B3%95%E5%9B%BD%E6%9E%AB%E4%B8%B9%E7%99%BD%E9%9C%B2%E6%A3%AE%E6%9E%97%E7%81%AB%E7%81%BE-800%E6%B6%88%E9%98%B2%E5%91%98%E6%8A%95%E5%85%A5%E6%95%91%E6%8F%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783954123000.webp","sourceId":"rfi"},{"id":1783951626000,"createdDate":"2026-07-13 14:07","name":"法国国际广播电台","title":"日本：俄乌战争中的另一条“战”线","content":"随着俄乌战争持续，日本的角色正在发生变化。一直以来，日本更多以经济援助、人道主义支持以及对俄制裁等方式参与国际社会对乌克兰的支持。而近期，多项公开信息显示，日本正在无人机、防空系统、军工合作以及关键技术供应等多个领域，与乌克兰建立更加深入的联系。同时，一些调查报道也指出，日本制造的高端电子产品仍持续出现在俄罗斯武器装备中，日本也因此成为各方关注的焦点。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%8D%B0%E5%A4%AA%E7%BA%B5%E8%A7%88/20260713-%E6%97%A5%E6%9C%AC-%E4%BF%84%E4%B9%8C%E6%88%98%E4%BA%89%E4%B8%AD%E7%9A%84%E5%8F%A6%E4%B8%80%E6%9D%A1-%E6%88%98-%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783951626000.webp","sourceId":"rfi"},{"id":1783950323000,"createdDate":"2026-07-13 13:45","name":"法国国际广播电台","title":"美伊在最新冲突中争夺霍尔木兹海峡控制权","content":"美国周末再次轰炸伊朗后，德黑兰随即于周一对该地区与华盛顿结盟的国家进行报复性打击。自4月8日停火以来，这几天美伊再次爆发的互袭规模前所未有。而此次冲突的核心依然是全球战略水道是霍尔木兹海峡，德黑兰试图维持其在战争初期建立的控制权。美周一都分别声称控制了该战略要道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260713-%E7%BE%8E%E4%BC%8A%E5%9C%A8%E6%9C%80%E6%96%B0%E5%86%B2%E7%AA%81%E4%B8%AD%E4%BA%89%E5%A4%BA%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%8E%A7%E5%88%B6%E6%9D%83","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783950323000.webp","sourceId":"rfi"},{"id":1783950109000,"createdDate":"2026-07-13 13:41","name":"法国国际广播电台","title":"为什么中国发射潜射洲际导弹引起日本极度担忧？","content":"据中国央视新闻7月6日报道，6日12时01分，中国人民解放军海军1艘战略核潜艇向太平洋相关公海海域，成功发射1发携载训练模拟弹头的潜射战略导弹，准确落入预定海域。这次发射引起了日本的深度担忧和关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260713-%E4%B8%BA%E4%BB%80%E4%B9%88%E4%B8%AD%E5%9B%BD%E5%8F%91%E5%B0%84%E6%BD%9C%E5%B0%84%E6%B4%B2%E9%99%85%E5%AF%BC%E5%BC%B9%E5%BC%95%E8%B5%B7%E6%97%A5%E6%9C%AC%E6%9E%81%E5%BA%A6%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783950109000.webp","sourceId":"rfi"},{"id":1783946395000,"createdDate":"2026-07-13 12:39","name":"法国国际广播电台","title":"中国北方洪灾：河北宽城水位涨两米 沈阳街头有人游泳冲浪，全国46条河超警戒水位","content":"台风“巴威”降级后给中国北方带去强降雨，河北省宽城县水位上涨超两米，东北多地交通瘫痪，有人在被淹街道上游泳和冲浪。全国46条河超过警戒水位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260713-%E4%B8%AD%E5%9B%BD%E5%8C%97%E6%96%B9%E6%B4%AA%E7%81%BE-%E6%B2%B3%E5%8C%97%E5%AE%BD%E5%9F%8E%E6%B0%B4%E4%BD%8D%E6%B6%A8%E4%B8%A4%E7%B1%B3-%E6%B2%88%E9%98%B3%E8%A1%97%E5%A4%B4%E6%9C%89%E4%BA%BA%E6%B8%B8%E6%B3%B3%E5%86%B2%E6%B5%AA%EF%BC%8C%E5%85%A8%E5%9B%BD46%E6%9D%A1%E6%B2%B3%E8%B6%85%E8%AD%A6%E6%88%92%E6%B0%B4%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783946395000.webp","sourceId":"rfi"},{"id":1783944558000,"createdDate":"2026-07-13 12:09","name":"法国国际广播电台","title":"世界杯决赛首设中场秀 国际足联打造足球与音乐盛宴","content":"国际足联宣布，2026年世界杯决赛将首次引入中场表演，为这项全球最大足球赛事增添美式娱乐元素，也标志着世界杯决赛首次借鉴美国职业橄榄球“超级碗”中场秀的模式。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260713-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%86%B3%E8%B5%9B%E9%A6%96%E8%AE%BE%E4%B8%AD%E5%9C%BA%E7%A7%80-%E5%9B%BD%E9%99%85%E8%B6%B3%E8%81%94%E6%89%93%E9%80%A0%E8%B6%B3%E7%90%83%E4%B8%8E%E9%9F%B3%E4%B9%90%E7%9B%9B%E5%AE%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783944558000.webp","sourceId":"rfi"},{"id":1783942905000,"createdDate":"2026-07-13 11:41","name":"法国国际广播电台","title":"美国周一继续轰炸伊朗，伊朗再袭中东多国，油价上涨","content":"美国周一连续第二天对伊朗发动空袭，声称打击了“数十个目标”，旨在削弱伊朗对霍尔木兹海峡的控制；德黑兰方面则称其已打击了华盛顿在海湾地区使用的军事基地。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260713-%E7%BE%8E%E5%9B%BD%E5%91%A8%E4%B8%80%E7%BB%A7%E7%BB%AD%E8%BD%B0%E7%82%B8%E4%BC%8A%E6%9C%97%EF%BC%8C%E4%BC%8A%E6%9C%97%E5%86%8D%E8%A2%AD%E4%B8%AD%E4%B8%9C%E5%A4%9A%E5%9B%BD%EF%BC%8C%E6%B2%B9%E4%BB%B7%E4%B8%8A%E6%B6%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/07/13/1783942905000.webp","sourceId":"rfi"}]