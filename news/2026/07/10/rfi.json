[{"id":1783681966000,"createdDate":"2026-07-10 11:12","name":"法国国际广播电台","title":"回声报：华尔街“正义”交易员试将在中国的内线交易者揪出来","content":"大家好，今天周五7月10日法国主流日报的头版以法国又将迎来一个酷热的周末为主。据《十字架报》报道，面对热浪，政府将于周五在发布红色预警的省份启动一项史无前例的“极端高温应急预案”，并为弱势群体设立降温中心。周六，法国共有24个省被列为红色预警区域。《解放报》则提及，如何适应气候变化无疑地将成为2027年总统大选的一个议题。中东冲突也重回大众视野，《费加罗报》指出，仅在美伊双方签署结束敌对行动的谅解备忘录三周后，围绕霍尔木兹海峡控制权的争端又让军事行动升级。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260710-%E5%9B%9E%E5%A3%B0%E6%8A%A5-%E5%8D%8E%E5%B0%94%E8%A1%97-%E6%AD%A3%E4%B9%89-%E4%BA%A4%E6%98%93%E5%91%98%E6%AD%A3%E5%B0%86%E4%B8%AD%E5%9B%BD%E7%9A%84%E5%86%85%E5%B9%95%E4%BA%A4%E6%98%93%E8%80%85%E6%8F%AA%E5%87%BA%E6%9D%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783681966000.webp","sourceId":"rfi"},{"id":1783681466000,"createdDate":"2026-07-10 11:04","name":"法国国际广播电台","title":"特朗普从北约峰会带回什么？","content":"特朗普（DonaldTrump）在土耳其安卡拉举行的北约（NATO）峰会，带着外界预期可能引爆跨大西洋同盟新一轮危机的气氛而来，最后却带着一份可称为政治胜利的成绩单离开。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260710-%E7%89%B9%E6%9C%97%E6%99%AE%E4%BB%8E%E5%8C%97%E7%BA%A6%E5%B3%B0%E4%BC%9A%E5%B8%A6%E5%9B%9E%E4%BB%80%E4%B9%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783681466000.webp","sourceId":"rfi"},{"id":1783681404000,"createdDate":"2026-07-10 11:03","name":"法国国际广播电台","title":"回声报专访：中国美妆集合店Harmay本土业绩凭何赶上法国Sephora","content":"据《回声报》企业版报道，Harmay（中文名：话梅）这家美妆集合店凭借其时尚的门店和折扣商品在中国掀起了一股热潮。仅用27家门店，话梅在中国的收入就几乎占到了法国品牌丝芙兰（Sephora）的四分之一。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260710-%E5%9B%9E%E5%A3%B0%E6%8A%A5%E4%B8%93%E8%AE%BF-%E4%B8%AD%E5%9B%BD%E7%BE%8E%E5%A6%86%E9%9B%86%E5%90%88%E5%BA%97harmay%E6%9C%AC%E5%9C%9F%E4%B8%9A%E7%BB%A9%E5%87%AD%E4%BD%95%E8%B5%B6%E4%B8%8A%E6%B3%95%E5%9B%BDsephora","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783681404000.webp","sourceId":"rfi"},{"id":1783674619000,"createdDate":"2026-07-10 09:10","name":"法国国际广播电台","title":"中国将公布第二季度增长数据，专家预测增幅仅为4.5%","content":"中国统计局应于下周三公布第二季度经济成长数据。法新社采访11位专家，预测第二季度经济表现乏力，增幅可能仅为4.5%，明显低于第一季度的5%的水平。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260710-%E4%B8%AD%E5%9B%BD%E5%B0%86%E5%85%AC%E5%B8%83%E7%AC%AC%E4%BA%8C%E5%AD%A3%E5%BA%A6%E5%A2%9E%E9%95%BF%E6%95%B0%E6%8D%AE%EF%BC%8C%E4%B8%93%E5%AE%B6%E9%A2%84%E6%B5%8B%E5%A2%9E%E5%B9%85%E4%BB%85%E4%B8%BA4-5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783674619000.webp","sourceId":"rfi"},{"id":1783674111000,"createdDate":"2026-07-10 09:01","name":"法国国际广播电台","title":"以色列情报: 伊朗正试图暗杀特朗普","content":"据《华尔街日报》和CNN周四援引匿名消息人士报道，以色列已向华盛顿提供了其情报部门获得的情报，称伊朗正在策划一项新的暗杀唐纳德·特朗普的计划。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260710-%E4%BB%A5%E8%89%B2%E5%88%97%E6%83%85%E6%8A%A5-%E4%BC%8A%E6%9C%97%E6%AD%A3%E8%AF%95%E5%9B%BE%E6%9A%97%E6%9D%80%E7%89%B9%E6%9C%97%E6%99%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783674111000.webp","sourceId":"rfi"},{"id":1783673707000,"createdDate":"2026-07-10 08:55","name":"法国国际广播电台","title":"赛前采访：比利时主教练称有信心爆冷淘汰西班牙   哈兰德建议记者把压力给到英格兰","content":"在法国成为首支晋级半决赛的球队后，周五晚巴黎时间21点，北京时间周六凌晨3点，西班牙将对阵比利时，而周六即将迎来备受期待的挪威与英格兰之战。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260710-%E8%B5%9B%E5%89%8D%E9%87%87%E8%AE%BF-%E6%AF%94%E5%88%A9%E6%97%B6%E4%B8%BB%E6%95%99%E7%BB%83%E7%A7%B0%E6%9C%89%E4%BF%A1%E5%BF%83%E7%88%86%E5%86%B7%E6%B7%98%E6%B1%B0%E8%A5%BF%E7%8F%AD%E7%89%99-%E5%93%88%E5%85%B0%E5%BE%B7%E5%BB%BA%E8%AE%AE%E8%AE%B0%E8%80%85%E6%8A%8A%E5%8E%8B%E5%8A%9B%E7%BB%99%E5%88%B0%E8%8B%B1%E6%A0%BC%E5%85%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783673707000.webp","sourceId":"rfi"},{"id":1783673593000,"createdDate":"2026-07-10 08:53","name":"法国国际广播电台","title":"又有22艘日本相关船舶通过霍尔木兹海峡","content":"日本国土交通大臣金子恭之7月10日在内阁会议后的记者会上表示，在7日至9日期间滞留于波斯湾内的日本相关船舶中，已有22艘顺利通过霍尔木兹海峡。据称，船员的健康状况均无异常。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260710-%E5%8F%88%E6%9C%8922%E8%89%98%E6%97%A5%E6%9C%AC%E7%9B%B8%E5%85%B3%E8%88%B9%E8%88%B6%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783673593000.webp","sourceId":"rfi"},{"id":1783672796000,"createdDate":"2026-07-10 08:39","name":"法国国际广播电台","title":"台湾人赴陆失联、遭盘查案件快速攀升 陆委会警告公务员没事不要去中国","content":"陆委会公布，自6月底以来，新增10名台湾人赴中国后失联案件。更有台湾地方法院法官赴中国华北旅游时，遭3名公安人员进入下榻饭店盘查，甚至还被宣扬两岸交流。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260710-%E5%8F%B0%E6%B9%BE%E4%BA%BA%E8%B5%B4%E9%99%86%E5%A4%B1%E8%81%94-%E9%81%AD%E7%9B%98%E6%9F%A5%E6%A1%88%E4%BB%B6%E5%BF%AB%E9%80%9F%E6%94%80%E5%8D%87-%E9%99%86%E5%A7%94%E4%BC%9A%E8%AD%A6%E5%91%8A%E5%85%AC%E5%8A%A1%E5%91%98%E6%B2%A1%E4%BA%8B%E4%B8%8D%E8%A6%81%E5%8E%BB%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783672796000.webp","sourceId":"rfi"},{"id":1783666752000,"createdDate":"2026-07-10 06:59","name":"法国国际广播电台","title":"欧盟对中国鸭肉进口进行反倾销调查 贸易战蔓延到中国农产品","content":"继电动车和太阳版等工业用品之後，欧盟把针对中国的反倾销调查首次扩展到家禽业。欧盟决定，就北京鸭及其肉鸭生产与出口产业链展开反倾销调查；若指控成立，欧盟可能会对相关产业徵收惩罚性关税。另外，欧盟又作出指示，即日起，进口欧洲的北京鸭及其产品须强制进行海关登记。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260710-%E6%AC%A7%E7%9B%9F%E5%AF%B9%E4%B8%AD%E5%9B%BD%E9%B8%AD%E8%82%89%E8%BF%9B%E5%8F%A3%E8%BF%9B%E8%A1%8C%E5%8F%8D%E5%80%BE%E9%94%80%E8%B0%83%E6%9F%A5-%E8%B4%B8%E6%98%93%E6%88%98%E8%94%93%E5%BB%B6%E5%88%B0%E4%B8%AD%E5%9B%BD%E5%86%9C%E4%BA%A7%E5%93%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783666752000.webp","sourceId":"rfi"},{"id":1783705480000,"createdDate":"2026-07-10 17:44","name":"法国国际广播电台","title":"强台风“巴维”在菲律宾酿15人遇难后袭台湾日本和中国","content":"强台风“巴维”在菲律宾造成15人遇难后，周五晚在台湾登陆，数以千计的居民被疏散，当地许多学校和办公场所已关闭。","newsLink":"https://www.rfi.fr/cn/%E7%94%9F%E6%80%81/20260710-%E5%BC%BA%E5%8F%B0%E9%A3%8E-%E5%B7%B4%E7%BB%B4-%E5%9C%A8%E8%8F%B2%E5%BE%8B%E5%AE%BE%E9%85%BF15%E4%BA%BA%E9%81%87%E9%9A%BE%E5%90%8E%E8%A2%AD%E5%8F%B0%E6%B9%BE%E6%97%A5%E6%9C%AC%E5%92%8C%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783705480000.webp","sourceId":"rfi"},{"id":1783694229000,"createdDate":"2026-07-10 14:37","name":"法国国际广播电台","title":"西班牙南部森林大火中，至少12人被困身亡","content":"在西班牙南部阿尔梅里亚附近，至少12人（其中极有可能包括外国人）因被困在车内或在徒步逃生时被大火吞噬，成为这场森林大火的遇难者。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260710-%E8%A5%BF%E7%8F%AD%E7%89%99%E5%8D%97%E9%83%A8%E6%A3%AE%E6%9E%97%E5%A4%A7%E7%81%AB%E4%B8%AD%EF%BC%8C%E8%87%B3%E5%B0%9112%E4%BA%BA%E8%A2%AB%E5%9B%B0%E8%BA%AB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783694229000.webp","sourceId":"rfi"},{"id":1783692795000,"createdDate":"2026-07-10 14:13","name":"法国国际广播电台","title":"中国证券监会批准希音香港募股 巴黎法院暂停其网售仿鳄鱼牌商品","content":"中国证券监督管理委员会今天周五发布官方声明，快时尚巨头希音Shein已获得中国市场监管机构的批准，同意其在香港首次公开募股申请。另外涉嫌商标侵权，法国巴黎司法法院暂停希音网售仿鳄鱼牌商品。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260710-%E4%B8%AD%E5%9B%BD%E8%AF%81%E5%88%B8%E7%9B%91%E4%BC%9A%E6%89%B9%E5%87%86%E5%B8%8C%E9%9F%B3%E9%A6%99%E6%B8%AF%E5%8B%9F%E8%82%A1-%E5%B7%B4%E9%BB%8E%E6%B3%95%E9%99%A2%E6%9A%82%E5%81%9C%E5%85%B6%E7%BD%91%E5%94%AE%E4%BB%BF%E9%B3%84%E9%B1%BC%E7%89%8C%E5%95%86%E5%93%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783692795000.webp","sourceId":"rfi"},{"id":1783692250000,"createdDate":"2026-07-10 14:04","name":"法国国际广播电台","title":"乌克兰无人机袭俄罗斯南部炼油厂和港口","content":"周五，乌克兰无人机袭击俄罗斯南部的石油基础设施和塔甘罗格（Taganrog）港，当地当局宣布因火灾已疏散居民。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260710-%E4%B9%8C%E5%85%8B%E5%85%B0%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E4%BF%84%E7%BD%97%E6%96%AF%E5%8D%97%E9%83%A8%E7%82%BC%E6%B2%B9%E5%8E%82%E5%92%8C%E6%B8%AF%E5%8F%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783692250000.webp","sourceId":"rfi"},{"id":1783691611000,"createdDate":"2026-07-10 13:53","name":"法国国际广播电台","title":"德国华人团伙迷奸案:第四名罪犯被判五年监禁","content":"德国警方对一个在社交网站Telegram上活跃多年的网络性侵团伙展开调查，最终导致三名涉嫌团伙核心成员被定罪。本周三（7月8号），第四名嫌疑人，32岁的受过专业训练的医护人员ZhitingS.被判犯有强奸罪的从犯等多项罪名，并被判处五年监禁。辩方计划提起上诉。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260710-%E5%BE%B7%E5%9B%BD%E5%8D%8E%E4%BA%BA%E5%88%A9%E7%94%A8%E5%9B%A2%E4%BC%99%E8%BF%B7%E5%A5%B8%E6%A1%88-%E7%AC%AC%E5%9B%9B%E5%90%8D%E5%AB%8C%E7%8A%AF%E8%A2%AB%E5%88%A4%E4%BA%94%E5%B9%B4%E7%9B%91%E7%A6%81","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783691611000.webp","sourceId":"rfi"},{"id":1783685398000,"createdDate":"2026-07-10 12:09","name":"法国国际广播电台","title":"伊朗最高领袖哈梅内伊下葬 其子兼继承人似未露面 美伊继续交火","content":"据伊朗国家电视台报道，已故伊朗最高领袖阿里·哈梅内伊于周五清晨在马什哈德下葬，此前在为期6天的葬礼后期，因三艘商船遭袭，美伊两国之间的敌对行动再度升级。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260710-%E4%BC%8A%E6%9C%97%E6%9C%80%E9%AB%98%E9%A2%86%E8%A2%96%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E4%B8%8B%E8%91%AC-%E5%85%B6%E5%AD%90%E5%85%BC%E7%BB%A7%E6%89%BF%E4%BA%BA%E4%BC%BC%E6%9C%AA%E9%9C%B2%E9%9D%A2-%E7%BE%8E%E4%BC%8A%E7%BB%A7%E7%BB%AD%E4%BA%A4%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783685398000.webp","sourceId":"rfi"},{"id":1783683334000,"createdDate":"2026-07-10 11:35","name":"法国国际广播电台","title":"在加拿大，不会说法语就不能当大公司的CEO吗？","content":"因为不会说法语，就要被免职吗？这听起来似乎并不合理，但放在加拿大其实并不稀奇。就在本周三（7月8日），加拿大航空公司（AirCanada）正式宣布，任命北欧航空公司（SAS）首席执行官安科·范德韦尔夫担任新帅，以接替因法语能力不足引发争议而被迫离职的迈克尔·鲁索。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C/20260710-%E5%9C%A8%E5%8A%A0%E6%8B%BF%E5%A4%A7%EF%BC%8C%E4%B8%8D%E4%BC%9A%E8%AF%B4%E6%B3%95%E8%AF%AD%E5%B0%B1%E4%B8%8D%E8%83%BD%E5%BD%93%E5%A4%A7%E5%85%AC%E5%8F%B8%E7%9A%84ceo%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783683334000.webp","sourceId":"rfi"},{"id":1783724612000,"createdDate":"2026-07-10 23:03","name":"法国国际广播电台","title":"乌克兰战争的转折点是否出现了 ？","content":"巴黎将在这个周一将接待35个“志愿国”召开峰会，为乌克兰战争“善后”，即一旦战争结束，志愿国或直接派遣陆军、空军、海军、或以其它方式前往乌克兰维和。法国、英国、西班牙已明确表示派遣陆军及空军，峰会将发出一个这样的信号：地面形势对俄罗斯越来越不利，现在坐下来和平谈判还来得及 !而且，重返白宫以来一直对乌克兰抗俄持消极态度的美国总统特朗普态度明显转变，首次同意将允许在乌克兰直接生产美国爱国者反导导弹。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260710-%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E4%BA%89%E7%9A%84%E8%BD%AC%E6%8A%98%E7%82%B9%E6%98%AF%E5%90%A6%E5%87%BA%E7%8E%B0%E4%BA%86","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783724612000.webp","sourceId":"rfi"},{"id":1783724062000,"createdDate":"2026-07-10 22:54","name":"法国国际广播电台","title":"美议员吁彻查加州六四纪念馆遭破坏案 关注是否涉中国跨国镇压","content":"美国两名共和党籍联邦众议员近日要求司法部与联邦调查局（FBI）全面调查加州六四纪念馆遭闯入破坏事件，并厘清是否涉及中国政府或中国共产党的“跨国镇压”行动。他们表示，若证实有外国政府介入，事件将不只是单纯毁损案件，而是涉及美国境内言论自由、历史记忆及民主倡议人士安全。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260710-%E7%BE%8E%E8%AE%AE%E5%91%98%E5%90%81%E5%BD%BB%E6%9F%A5%E5%8A%A0%E5%B7%9E%E5%85%AD%E5%9B%9B%E7%BA%AA%E5%BF%B5%E9%A6%86%E9%81%AD%E7%A0%B4%E5%9D%8F%E6%A1%88-%E5%85%B3%E6%B3%A8%E6%98%AF%E5%90%A6%E6%B6%89%E4%B8%AD%E5%9B%BD%E8%B7%A8%E5%9B%BD%E9%95%87%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783724062000.webp","sourceId":"rfi"},{"id":1783722850000,"createdDate":"2026-07-10 22:34","name":"法国国际广播电台","title":"德国三大车企在华销量重挫 第二季度降幅均超30%","content":"德国主要汽车制造商第二季度在中国市场的销量进一步大幅下滑。在全球最大汽车市场持续低迷之际，大众、奔驰和宝马等传统车企正承受越来越大的压力，与中国本土竞争对手展开激烈角逐。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260710-%E5%BE%B7%E5%9B%BD%E4%B8%89%E5%A4%A7%E8%BD%A6%E4%BC%81%E5%9C%A8%E5%8D%8E%E9%94%80%E9%87%8F%E9%87%8D%E6%8C%AB-%E7%AC%AC%E4%BA%8C%E5%AD%A3%E5%BA%A6%E9%99%8D%E5%B9%85%E5%9D%87%E8%B6%8530","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783722850000.webp","sourceId":"rfi"},{"id":1783722652000,"createdDate":"2026-07-10 22:30","name":"法国国际广播电台","title":"西班牙力克比利时 将在半决赛与法国对决","content":"继法国队以2比0大胜摩洛哥次日，世界杯第二场八强赛周五在洛杉矶打响，西班牙与比利时狭路相逢。西班牙2比1胜出，将与法国队半决赛对决争夺一个决赛席位 !","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260710-%E8%A5%BF%E7%8F%AD%E7%89%99%E5%8A%9B%E5%85%8B%E6%AF%94%E5%88%A9%E6%97%B6-%E5%B0%86%E5%9C%A8%E5%8D%8A%E5%86%B3%E8%B5%9B%E4%B8%8E%E6%B3%95%E5%9B%BD%E5%AF%B9%E5%86%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783722652000.webp","sourceId":"rfi"},{"id":1783722512000,"createdDate":"2026-07-10 22:28","name":"法国国际广播电台","title":"马克龙会晤南非总统拉马福萨 双方对中东和非洲大湖地区局势看法高度一致","content":"法国总统马克龙与南非总统拉马福萨周五（7月10日）在巴黎爱丽舍宫举行会谈。法国外交消息人士称，双方在中东局势及刚果（金）危机等问题上展现出“高度一致”的立场，并决定建立两国外长年度双边对话机制。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260710-%E9%A9%AC%E5%85%8B%E9%BE%99%E4%BC%9A%E6%99%A4%E5%8D%97%E9%9D%9E%E6%80%BB%E7%BB%9F%E6%8B%89%E9%A9%AC%E7%A6%8F%E8%90%A8-%E5%8F%8C%E6%96%B9%E5%AF%B9%E4%B8%AD%E4%B8%9C%E5%92%8C%E9%9D%9E%E6%B4%B2%E5%A4%A7%E6%B9%96%E5%9C%B0%E5%8C%BA%E5%B1%80%E5%8A%BF%E7%9C%8B%E6%B3%95%E9%AB%98%E5%BA%A6%E4%B8%80%E8%87%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783722512000.webp","sourceId":"rfi"},{"id":1783722247000,"createdDate":"2026-07-10 22:24","name":"法国国际广播电台","title":"特朗普宣布美伊停火“已经结束” 美方仍同意继续谈判","content":"美国总统特朗普周五（7月10日）表示，美国同意继续与伊朗举行谈判，但他再次强调，在本周双方再度交火后，自4月以来维持的停火已经“彻底结束”。巴基斯坦总理周五敦促伊朗维护“来之不易的和平”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260710-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AE%A3%E5%B8%83%E7%BE%8E%E4%BC%8A%E5%81%9C%E7%81%AB-%E5%B7%B2%E7%BB%8F%E7%BB%93%E6%9D%9F-%E7%BE%8E%E6%96%B9%E4%BB%8D%E5%90%8C%E6%84%8F%E7%BB%A7%E7%BB%AD%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783722247000.webp","sourceId":"rfi"},{"id":1783720488000,"createdDate":"2026-07-10 21:54","name":"法国国际广播电台","title":"法国高温持续升级 红色预警扩大至24个省 政府启动极端高温应急预案","content":"法国今年第三轮热浪在周末来临前进一步加剧。法国气象局宣布，西北部四分之一地区共24个省将于周六(7月11日）进入最高级别的高温红色预警，部分地区最高气温可能达到40摄氏度。法国政府启动“极端高温ORSEC应急预案”，开放避暑中心、防护中心和降温场所，为老年人、无家可归者等脆弱群体提供帮助。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260710-%E6%B3%95%E5%9B%BD%E9%AB%98%E6%B8%A9%E6%8C%81%E7%BB%AD%E5%8D%87%E7%BA%A7-%E7%BA%A2%E8%89%B2%E9%A2%84%E8%AD%A6%E6%89%A9%E5%A4%A7%E8%87%B324%E4%B8%AA%E7%9C%81-%E6%94%BF%E5%BA%9C%E5%90%AF%E5%8A%A8%E6%9E%81%E7%AB%AF%E9%AB%98%E6%B8%A9%E5%BA%94%E6%80%A5%E9%A2%84%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783720488000.webp","sourceId":"rfi"},{"id":1783717053000,"createdDate":"2026-07-10 20:57","name":"法国国际广播电台","title":"中国与菲律宾围绕南海岛屿主权的争议为何再度升温？","content":"中国与菲律宾双边关系一度出现的些许缓和信号正重新被围绕岛屿主权的争议淹没。海牙国际仲裁法庭推翻中国的主权声索论据、做出对菲律宾有利的裁决十年之后，路透社近日报道，由于中国海警的强力干预，菲律宾渔民如今已经无法前往黄岩岛附近水域捕鱼。而主权争议的焦点近日又转移到菲律宾北部的巴丹岛。菲律宾外长10日在马尼拉回应记者提问时，驳斥了几天前一些中国学者提出的巴丹岛是台湾岛的延伸的说法。不过，在当前中美印太博弈的地缘政治背景下，这些紧张关系的实际意义远超出单纯的主权争议或渔业资源的分享或争夺。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260710-%E4%B8%AD%E5%9B%BD%E4%B8%8E%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%9B%B4%E7%BB%95%E5%8D%97%E6%B5%B7%E5%B2%9B%E5%B1%BF%E4%B8%BB%E6%9D%83%E4%BA%89%E8%AE%AE%E4%B8%BA%E4%BD%95%E5%86%8D%E5%BA%A6%E5%8D%87%E6%B8%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783717053000.webp","sourceId":"rfi"},{"id":1783709242000,"createdDate":"2026-07-10 18:47","name":"法国国际广播电台","title":"【视频】巴黎观光打卡地之一：兼具气候监测功能的高空热气球","content":"在巴黎西部，有一处观光打卡之地，巴黎热气球。这款热气球最高可升至300米高空，但通常保持在150米的飞行高度，每次可搭载最多30名乘客，带他们俯瞰巴黎——这座世界上最美丽的城市之一。本台英语组的同仁采访了热气球制造公司——Aérophile的总裁JérômeGiacomoni。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260710-%E8%A7%86%E9%A2%91-%E5%B7%B4%E9%BB%8E%E8%A7%82%E5%85%89%E6%89%93%E5%8D%A1%E5%9C%B0%E4%B9%8B%E4%B8%80-%E5%85%BC%E5%85%B7%E6%B0%94%E5%80%99%E7%9B%91%E6%B5%8B%E5%8A%9F%E8%83%BD%E7%9A%84%E9%AB%98%E7%A9%BA%E7%83%AD%E6%B0%94%E7%90%83","thumbnail":"","detailImage":"news/detail/rfi/2026/07/10/1783709242000.webp","sourceId":"rfi"}]