[{"id":1784713902000,"createdDate":"2026-07-22 09:51","name":"法国国际广播电台","title":"法国创欧盟首例15岁以下禁用社媒、“为何欧盟今秋肯定会与中国发生贸易战”","content":"法国国民议会和参议院周二（7月21日）晚通过禁止15岁以下未成年人使用社交媒体的法案，法国由此成为欧盟第一个通过青少年社交媒体禁令的国家，成为今天周三7月22日出刊的法国日报重点话题之一，甚至是重视青少年议题的《十字架报》封面专题。与此同时，财经时评人伯蒂勒·巴亚尔在《费加罗报》观点栏目发表文章阐释，“为什么我们几乎肯定会在今年秋天与中国爆发贸易战”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260722-%E6%B3%95%E5%9B%BD%E5%88%9B%E6%AC%A7%E7%9B%9F%E9%A6%96%E4%BE%8B15%E5%B2%81%E4%BB%A5%E4%B8%8B%E7%A6%81%E7%94%A8%E7%A4%BE%E5%AA%92-%E4%B8%BA%E4%BD%95%E6%AC%A7%E7%9B%9F%E4%BB%8A%E7%A7%8B%E8%82%AF%E5%AE%9A%E4%BC%9A%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%8F%91%E7%94%9F%E8%B4%B8%E6%98%93%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784713902000.webp","sourceId":"rfi"},{"id":1784713596000,"createdDate":"2026-07-22 09:46","name":"法国国际广播电台","title":"中国对台的「窒息手段」延伸到儿童合唱团与咖啡赛事 没有任何舞台小到能躲过中国打压","content":"中国以「窒息手段」来压缩台湾国际空间，从外交与国际组织延伸至民间活动，如今似乎没有任何舞台小到能躲过这场身分之争。台湾总统赖清德则在日前喊话，台湾绝不能让民主台湾走回头路，变成「中国的台湾」。因为台湾不仅仅是个名字，它更是一种身分认同。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260722-%E4%B8%AD%E5%9B%BD%E5%AF%B9%E5%8F%B0%E7%9A%84-%E7%AA%92%E6%81%AF%E6%89%8B%E6%AE%B5-%E5%BB%B6%E4%BC%B8%E5%88%B0%E5%84%BF%E7%AB%A5%E5%90%88%E5%94%B1%E5%9B%A2%E4%B8%8E%E5%92%96%E5%95%A1%E8%B5%9B%E4%BA%8B-%E6%B2%A1%E6%9C%89%E4%BB%BB%E4%BD%95%E8%88%9E%E5%8F%B0%E5%B0%8F%E5%88%B0%E8%83%BD%E8%BA%B2%E8%BF%87%E4%B8%AD%E5%9B%BD%E6%89%93%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784713596000.webp","sourceId":"rfi"},{"id":1784711581000,"createdDate":"2026-07-22 09:13","name":"法国国际广播电台","title":"特朗普希望国际足联主席因凡蒂诺出任联合国秘书长","content":"据《纽约邮报》7月21日透露，美国总统特朗普希望国际足联主席因凡蒂诺在世界杯结束后出任下一任联合国秘书长。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260722-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B8%8C%E6%9C%9B%E5%9B%BD%E9%99%85%E8%B6%B3%E8%81%94%E4%B8%BB%E5%B8%AD%E5%9B%A0%E5%87%A1%E8%92%82%E8%AF%BA%E5%87%BA%E4%BB%BB%E8%81%94%E5%90%88%E5%9B%BD%E7%A7%98%E4%B9%A6%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784711581000.webp","sourceId":"rfi"},{"id":1784711099000,"createdDate":"2026-07-22 09:04","name":"法国国际广播电台","title":"多家美国媒体报道，特朗普政府准备与沙特开展核能合作","content":"美国和伊朗再度发生武装冲突之际，美国多家媒体报道透露，华盛顿已接近与利雅得就沙特的核能开发展开合作。但核能开发的军民两用潜能也引发不安，美国朝野两党一些议员以及以色列方面的负责人都表达反对立场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260722-%E5%A4%9A%E5%AE%B6%E7%BE%8E%E5%9B%BD%E5%AA%92%E4%BD%93%E6%8A%A5%E9%81%93%EF%BC%8C%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E5%87%86%E5%A4%87%E4%B8%8E%E6%B2%99%E7%89%B9%E5%BC%80%E5%B1%95%E6%A0%B8%E8%83%BD%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784711099000.webp","sourceId":"rfi"},{"id":1784710223000,"createdDate":"2026-07-22 08:50","name":"法国国际广播电台","title":"台湾8月举行汉光演习首度模拟「断网」立委质疑制造战争恐惧","content":"台湾汉光42号演习将于8月5日至14日展开，这次首度将行动网路降速列入演练项目，在北部与中部实行30分钟的模拟断网。不少立委对此表达质疑，究竟要测试的目标、详细实行细节与法源依据为何？","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260722-%E5%8F%B0%E6%B9%BE8%E6%9C%88%E4%B8%BE%E8%A1%8C%E6%B1%89%E5%85%89%E6%BC%94%E4%B9%A0%E9%A6%96%E5%BA%A6%E6%A8%A1%E6%8B%9F-%E6%96%AD%E7%BD%91-%E7%AB%8B%E5%A7%94%E8%B4%A8%E7%96%91%E5%88%B6%E9%80%A0%E6%88%98%E4%BA%89%E6%81%90%E6%83%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784710223000.webp","sourceId":"rfi"},{"id":1784705213000,"createdDate":"2026-07-22 07:26","name":"法国国际广播电台","title":"法官陈嘉信至少三度司法抄袭 致案件重审 须接受再培训","content":"香港高等法院法官陈嘉信屡劝不改，在第三度被指司法抄袭後，终於成为与讼人上诉得直的原因，案件须由另一法官重审。作为法官之首的张举能法官除了第三度对他作出训诫之外，还首度敕令他须接受针对性培训。事件令强调香港法律枢纽地位无可替代的官员说词蒙上阴影。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260722-%E6%B3%95%E5%AE%98%E9%99%88%E5%98%89%E4%BF%A1%E8%87%B3%E5%B0%91%E4%B8%89%E5%BA%A6%E5%8F%B8%E6%B3%95%E6%8A%84%E8%A2%AD-%E8%87%B4%E6%A1%88%E4%BB%B6%E9%87%8D%E5%AE%A1-%E9%A1%BB%E6%8E%A5%E5%8F%97%E5%86%8D%E5%9F%B9%E8%AE%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784705213000.webp","sourceId":"rfi"},{"id":1784704946000,"createdDate":"2026-07-22 07:22","name":"法国国际广播电台","title":"称为配合香港国安法 台湾有物流公司拒运违法书籍兼要求备书单审查","content":"《港区国安法》的「域外效力」已不限於司法，而是在确实影响资讯流通自由，因为一家国际物流公司在台湾的分部近日发出公告，表明不会运送「违反法规」书籍，书本寄往香港前须先提供书单审查，而曾被香港警方调查的书店，包括田园书店丶留下书舍丶一拳书店及猎人书店等，其货品亦不会运送。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260722-%E7%A7%B0%E4%B8%BA%E9%85%8D%E5%90%88%E9%A6%99%E6%B8%AF%E5%9B%BD%E5%AE%89%E6%B3%95-%E5%8F%B0%E6%B9%BE%E6%9C%89%E7%89%A9%E6%B5%81%E5%85%AC%E5%8F%B8%E6%8B%92%E8%BF%90%E8%BF%9D%E6%B3%95%E4%B9%A6%E7%B1%8D%E5%85%BC%E8%A6%81%E6%B1%82%E5%A4%87%E4%B9%A6%E5%8D%95%E5%AE%A1%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784704946000.webp","sourceId":"rfi"},{"id":1784704614000,"createdDate":"2026-07-22 07:16","name":"法国国际广播电台","title":"最佳留学城市：香港排17 逊京台 QS指香港生员国际化不足","content":"锐意发展为教育枢纽的香港，虽然身负各所大学排名上升的优势，但在国际高等教育资讯机构QuacquarelliSymonds(QS)的最佳留学城市排名中，仅能维持全球第17位的成绩，未能回复十三年前排名全球第五位的佳绩。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260722-%E6%9C%80%E4%BD%B3%E7%95%99%E5%AD%A6%E5%9F%8E%E5%B8%82-%E9%A6%99%E6%B8%AF%E6%8E%9217-%E9%80%8A%E4%BA%AC%E5%8F%B0-qs%E6%8C%87%E9%A6%99%E6%B8%AF%E7%94%9F%E5%91%98%E5%9B%BD%E9%99%85%E5%8C%96%E4%B8%8D%E8%B6%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784704614000.webp","sourceId":"rfi"},{"id":1784704275000,"createdDate":"2026-07-22 07:11","name":"法国国际广播电台","title":"俄罗斯战略轰炸机在日本海飞行11小时 日本认为是恫吓","content":"据塔斯社报道，俄罗斯国防部21日宣布，俄罗斯空军的战略轰炸机“图-95MS”在日本海公海上空飞行了11个多小时。俄国防部还表示，当天，超音速战略轰炸机“图-22M3”也在波罗的海上空飞行了4个多小时。外界认为，此举旨在威慑持续向乌克兰提供援助的日本和欧洲国家。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260722-%E4%BF%84%E7%BD%97%E6%96%AF%E6%88%98%E7%95%A5%E8%BD%B0%E7%82%B8%E6%9C%BA%E5%9C%A8%E6%97%A5%E6%9C%AC%E6%B5%B7%E9%A3%9E%E8%A1%8C11%E5%B0%8F%E6%97%B6-%E6%97%A5%E6%9C%AC%E8%AE%A4%E4%B8%BA%E6%98%AF%E6%81%AB%E5%90%93","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784704275000.webp","sourceId":"rfi"},{"id":1784736115000,"createdDate":"2026-07-22 16:01","name":"法国国际广播电台","title":"回声报：在中国，当局正竭尽全力遏制股市暴跌","content":"据《回声报》财经记者科伦丁·查普隆周二21日晚报道，近几周，中国股市面临的压力与日俱增。北京当局正多管齐下，试图阻止市场进一步下滑。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260722-%E5%9B%9E%E5%A3%B0%E6%8A%A5-%E5%9C%A8%E4%B8%AD%E5%9B%BD%EF%BC%8C%E5%BD%93%E5%B1%80%E6%AD%A3%E7%AB%AD%E5%B0%BD%E5%85%A8%E5%8A%9B%E9%81%8F%E5%88%B6%E8%82%A1%E5%B8%82%E6%9A%B4%E8%B7%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784736115000.webp","sourceId":"rfi"},{"id":1784734579000,"createdDate":"2026-07-22 15:36","name":"法国国际广播电台","title":"卢比奥与王毅在马尼拉会晤谈习近平9月访美事宜","content":"美国国务卿马可·卢比奥与中国外长王毅周三在马尼拉东盟会议期间会面，讨论了中国国家主席习近平今年9月计划访美事宜。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260722-%E5%8D%A2%E6%AF%94%E5%A5%A5%E4%B8%8E%E7%8E%8B%E6%AF%85%E5%9C%A8%E9%A9%AC%E5%B0%BC%E6%8B%89%E4%BC%9A%E6%99%A4%E8%B0%88%E4%B9%A0%E8%BF%91%E5%B9%B39%E6%9C%88%E8%AE%BF%E7%BE%8E%E4%BA%8B%E5%AE%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784734579000.webp","sourceId":"rfi"},{"id":1784733671000,"createdDate":"2026-07-22 15:21","name":"法国国际广播电台","title":"屈于国内压力换帅？泽连斯基任命43岁少将德拉帕季为乌军总司令","content":"在解除人气国防部长引发民众抗议几天之后，泽连斯基7月21日宣布，43岁的少将米哈伊洛·德拉帕季接替60岁的瑟尔斯基，出任乌克兰武装部队总司令。这是自乌俄战争开始以来，乌军领导层最大的一次调整。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260722-%E5%B1%88%E4%BA%8E%E5%9B%BD%E5%86%85%E5%8E%8B%E5%8A%9B%E6%8D%A2%E5%B8%85-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E4%BB%BB%E5%91%BD43%E5%B2%81%E5%B0%91%E5%B0%86%E5%BE%B7%E6%8B%89%E5%B8%95%E5%AD%A3%E4%B8%BA%E4%B9%8C%E5%86%9B%E6%80%BB%E5%8F%B8%E4%BB%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784733671000.webp","sourceId":"rfi"},{"id":1784731765000,"createdDate":"2026-07-22 14:49","name":"法国国际广播电台","title":"超大规模2026世界杯圆满落幕预示规模还能再大？","content":"2026美加墨世界杯足球赛随西班牙队7月19日在决赛中胜出而落下帷幕。从目前的门票销售统计以及收视率预估来看，这次有48支球队参加、在美加墨三个不同国家的16座城市展开的史上最大规模足球世界杯可谓是一次全球共襄盛举的盛宴。下一届世界杯将是国际足联世界杯百年之赛，它将如何再创辉煌？规模是否还能继续扩大？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260722-%E8%B6%85%E5%A4%A7%E8%A7%84%E6%A8%A12026%E4%B8%96%E7%95%8C%E6%9D%AF%E5%9C%86%E6%BB%A1%E8%90%BD%E5%B9%95%E9%A2%84%E7%A4%BA%E8%A7%84%E6%A8%A1%E8%BF%98%E8%83%BD%E5%86%8D%E5%A4%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784731765000.webp","sourceId":"rfi"},{"id":1784730638000,"createdDate":"2026-07-22 14:30","name":"法国国际广播电台","title":"赞比亚系列报道之三：环境律师谈如何追究跨境企业的污染责任","content":"赞比亚是非洲第二大产铜国，该国财政收入近70%来自矿产出口，而数十年来的铜矿开采已经使该国的生态环境遭受重创，虽然在赞比亚运营的所有矿业集团都声称将遵守当地的环境法规，以可持续的方式开采铜矿，但事实上，任何亲临采矿现场的人都不难意识到即使是在正常工作前提下，可持续开采也只能是一个可望而不可及的目标，几十年来这里的安全以及环境事故屡屡发生，当地的非政府组织向法广表示，一旦发生事故试图追究企业的责任并非易事，而要追究中国企业的责任更是难上加难。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E5%A2%83%E4%B8%8E%E5%8F%91%E5%B1%95/20260722-%E8%B5%9E%E6%AF%94%E4%BA%9A%E7%B3%BB%E5%88%97%E6%8A%A5%E9%81%93%E4%B9%8B%E4%B8%89-%E7%8E%AF%E5%A2%83%E5%BE%8B%E5%B8%88%E5%BC%A0%E5%85%A2%E5%85%A2%E8%B0%88%E5%A6%82%E4%BD%95%E8%BF%BD%E7%A9%B6%E8%B7%A8%E5%A2%83%E4%BC%81%E4%B8%9A%E7%9A%84%E6%B1%A1%E6%9F%93%E8%B4%A3%E4%BB%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784730638000.webp","sourceId":"rfi"},{"id":1784722899000,"createdDate":"2026-07-22 12:21","name":"法国国际广播电台","title":"赞比亚 ： 采访NGO谈矿业公司与当地居民土地纠纷的症结","content":"赞比亚的铜矿吸引了来自全球各地的矿业集团，不过，无论是西方还是中国的矿业公司他们在赞比亚的运作往往伴随着土地纠纷，因为必须首先安置原先居住在当地的居民，对当地人来说，他们多年来居住在这里，这里的土地应该归他们所有，而对矿业集团来说，他们既然收购了整个矿区，那么，他们应该理所当然的拥有矿区的一村一尺。那么，造成上述纠纷的根源是什么？应该如何解决？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260722-%E8%B5%9E%E6%AF%94%E4%BA%9A-%E9%87%87%E8%AE%BFngo%E8%B0%88%E7%9F%BF%E4%B8%9A%E5%85%AC%E5%8F%B8%E4%B8%8E%E5%BD%93%E5%9C%B0%E5%B1%85%E6%B0%91%E5%9C%9F%E5%9C%B0%E7%BA%A0%E7%BA%B7%E7%9A%84%E7%97%87%E7%BB%93","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784722899000.webp","sourceId":"rfi"},{"id":1784721712000,"createdDate":"2026-07-22 12:01","name":"法国国际广播电台","title":"哈佛大学用来自中国捐款绑定中国项目或学生？美国司法部启动调查","content":"美国司法部本周一就哈佛大学助学金项目涉嫌与中国关联启动调查。该调查可能曝光某些中国人通过来自中国的捐款“购买”进入哈佛大学的违法操作。美国司法部要求哈佛校方提供有关助学金项目受益人的信息。总金额超过6.3亿美元。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260722-%E5%93%88%E4%BD%9B%E5%A4%A7%E5%AD%A6%E7%94%A8%E6%9D%A5%E8%87%AA%E4%B8%AD%E5%9B%BD%E6%8D%90%E6%AC%BE%E7%BB%91%E5%AE%9A%E4%B8%AD%E5%9B%BD%E9%A1%B9%E7%9B%AE%E6%88%96%E5%AD%A6%E7%94%9F-%E7%BE%8E%E5%9B%BD%E5%8F%B8%E6%B3%95%E9%83%A8%E5%90%AF%E5%8A%A8%E8%B0%83%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784721712000.webp","sourceId":"rfi"},{"id":1784721408000,"createdDate":"2026-07-22 11:56","name":"法国国际广播电台","title":"法媒点评：中国一名外卖员荣获国内最具声望的文学奖","content":"《费加罗报》21日报道说，一部在两次送餐间隙创作出来的诗集，为一名中国外卖员赢得了中国文学界的最高荣誉之一。7月18日，56岁的王计兵凭借其诗集《低处飞行》荣获鲁迅文学奖。这部作品通过数百位同行的证言，真实还原了普通劳动者日常奔波的轨迹。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260722-%E8%B4%B9%E5%8A%A0%E7%BD%97%E6%8A%A5-%E4%B8%AD%E5%9B%BD%E4%B8%80%E5%90%8D%E5%A4%96%E5%8D%96%E5%91%98%E8%8D%A3%E8%8E%B7%E5%9B%BD%E5%86%85%E6%9C%80%E5%85%B7%E5%A3%B0%E6%9C%9B%E7%9A%84%E6%96%87%E5%AD%A6%E5%A5%96","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784721408000.webp","sourceId":"rfi"},{"id":1784710531000,"createdDate":"2026-07-22 08:55","name":"法国国际广播电台","title":"澳中外长会谈 堪培拉批北京在南太平洋试射导弹“破环稳定”","content":"澳大利亚外交部长黄英贤周三（7月22号）表示，她在马尼拉与中国外交部长王毅举行了会晤，对北京7月初在南太平洋试射具备核弹头搭载能力的弹道导弹表达关切。她认为此次试射“具有破坏稳定性”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260722-%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E5%A4%96%E9%95%BF%E8%A7%81%E7%8E%8B%E6%AF%85-%E6%89%B9%E4%B8%AD%E5%9B%BD%E5%8D%97%E5%A4%AA%E5%B9%B3%E6%B4%8B%E8%AF%95%E5%B0%84%E5%AF%BC%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/07/22/1784710531000.webp","sourceId":"rfi"}]