[{"id":1781914642000,"createdDate":"2026-06-20 00:17","name":"法国国际广播电台","title":"日媒称中国恢复赴日团游，但“中旅旅行”官网同日团队游行程被下架","content":"日本媒体19日报导，中国国营旅行社已恢复推出日本团体旅游产品。不过，新加坡《联合早报》发现，隶属国营的“中旅旅行”官网同日紧急下架相关产品。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260620-%E6%97%A5%E5%AA%92%E7%A7%B0%E4%B8%AD%E5%9B%BD%E6%81%A2%E5%A4%8D%E8%B5%B4%E6%97%A5%E5%9B%A2%E6%B8%B8%EF%BC%8C%E4%BD%86-%E4%B8%AD%E6%97%85%E6%97%85%E8%A1%8C-%E5%AE%98%E7%BD%91%E5%90%8C%E6%97%A5%E5%9B%A2%E9%98%9F%E6%B8%B8%E8%A1%8C%E7%A8%8B%E8%A2%AB%E4%B8%8B%E6%9E%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781914642000.webp","sourceId":"rfi"},{"id":1781914466000,"createdDate":"2026-06-20 00:14","name":"法国国际广播电台","title":"伊朗战争暴露能源弱点：台湾是否将重新发展核能？","content":"美国和以色列对伊朗发动战争三个月后，台湾的一切似乎和平常没有两样。不过，霍尔木兹海峡危机还是暴露了台湾能源供应的脆弱性：台湾几乎所有天然气、石油和煤炭都依赖进口。尽管台湾政府原本决定在2025年全面废核，但如今为了满足高能耗的半导体产业的能源需求，正考虑重新发展核能。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260620-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%9A%B4%E9%9C%B2%E8%83%BD%E6%BA%90%E5%BC%B1%E7%82%B9-%E5%8F%B0%E6%B9%BE%E6%98%AF%E5%90%A6%E5%B0%86%E9%87%8D%E6%96%B0%E5%8F%91%E5%B1%95%E6%A0%B8%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781914466000.webp","sourceId":"rfi"},{"id":1781947495000,"createdDate":"2026-06-20 09:24","name":"法国国际广播电台","title":"2026世界杯：巴西3比0轻取海地 摩洛哥击败苏格兰 攻入本届最快进球","content":"2026年世界杯C组第二轮赛，巴西队展现出与首战截然不同的状态，以3比0轻取海地，拿下本届赛事首场胜利，并以净胜球数暂居小组第一。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260620-2026%E4%B8%96%E7%95%8C%E6%9D%AF-%E5%B7%B4%E8%A5%BF3%E6%AF%940%E8%BD%BB%E5%8F%96%E6%B5%B7%E5%9C%B0-%E6%91%A9%E6%B4%9B%E5%93%A5%E5%87%BB%E8%B4%A5%E8%8B%8F%E6%A0%BC%E5%85%B0-%E6%94%BB%E5%85%A5%E6%9C%AC%E5%B1%8A%E6%9C%80%E5%BF%AB%E8%BF%9B%E7%90%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781947495000.webp","sourceId":"rfi"},{"id":1781946803000,"createdDate":"2026-06-20 09:13","name":"法国国际广播电台","title":"美菲完成今年在南中国海的第四次双边“海事合作活动”","content":"菲律宾和美国海军及空军在西菲律宾海（菲方对其专属经济区内南中国海海域的称呼）举行了今年第四次双边海事合作活动（MCA），两国继续加强海上互操作性，为即将在夏威夷举行的多国海军演习做准备。菲律宾武装部队周六表示，此次活动于6月14日至19日举行。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260620-%E7%BE%8E%E8%8F%B2%E5%AE%8C%E6%88%90%E4%BB%8A%E5%B9%B4%E5%9C%A8%E5%8D%97%E4%B8%AD%E5%9B%BD%E6%B5%B7%E7%9A%84%E7%AC%AC%E5%9B%9B%E6%AC%A1%E5%8F%8C%E8%BE%B9-%E6%B5%B7%E4%BA%8B%E5%90%88%E4%BD%9C%E6%B4%BB%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781946803000.webp","sourceId":"rfi"},{"id":1781968192000,"createdDate":"2026-06-20 15:09","name":"法国国际广播电台","title":"埃博拉:刚果(金)患者死亡超二百","content":"埃博拉疫情在刚果民主共和国（RDCongo）东部持续蔓延。据非洲联盟卫生机构对外发布的数据，自05月15日以来，刚果（金）目前已查明近九百宗确诊病例，其中，死亡病例超过二百宗，确诊患者的病死率为23%；密切接触者人数多达3万5千人。刚果（金）东部伊图里省（Ituri）仍是疫情中心。邻近的北基伍省（NordKivu）和位于非洲中部大湖地区的邻国乌干达(l'Ouganda)的疫情形势严峻。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260620-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%9F%83%E5%8D%9A%E6%8B%89-%E5%88%9A%E6%9E%9C-%E9%87%91-%E6%82%A3%E8%80%85%E6%AD%BB%E4%BA%A1%E8%B6%85%E4%BA%8C%E7%99%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781968192000.webp","sourceId":"rfi"},{"id":1781967655000,"createdDate":"2026-06-20 15:00","name":"法国国际广播电台","title":"法官裁定，西班牙首相夫人须因腐败指控受审 交出护照不得离境","content":"西班牙首相桑切斯（PedroSanchez）的夫人戈麦斯（BegonaGomez）因涉嫌腐败必须接受审判，并被禁止离境，一名法官于周六作出此项裁决。戈麦斯正因涉嫌利用首相夫人的身份获取工作合同而接受调查。她否认有任何不当行为。此案由极右翼团体提起。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260620-%E6%B3%95%E5%AE%98%E8%A3%81%E5%AE%9A%EF%BC%8C%E8%A5%BF%E7%8F%AD%E7%89%99%E9%A6%96%E7%9B%B8%E5%A4%AB%E4%BA%BA%E9%A1%BB%E5%9B%A0%E8%85%90%E8%B4%A5%E6%8C%87%E6%8E%A7%E5%8F%97%E5%AE%A1-%E4%BA%A4%E5%87%BA%E6%8A%A4%E7%85%A7%E4%B8%8D%E5%BE%97%E7%A6%BB%E5%A2%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781967655000.webp","sourceId":"rfi"},{"id":1781964422000,"createdDate":"2026-06-20 14:07","name":"法国国际广播电台","title":"日美开启在九州和冲绳举行的岛屿防御演习“坚毅之龙26”","content":"日本陆上自卫队和美国海军陆战队于周六启动了代号为“坚毅之龙26”的岛屿防御技能联合演习，演习将持续至6月30日，演习范围覆盖日本西南部的九州地区和冲绳县。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260620-%E6%97%A5%E7%BE%8E%E5%BC%80%E5%90%AF%E5%9C%A8%E4%B9%9D%E5%B7%9E%E5%92%8C%E5%86%B2%E7%BB%B3%E4%B8%BE%E8%A1%8C%E7%9A%84%E5%B2%9B%E5%B1%BF%E9%98%B2%E5%BE%A1%E6%BC%94%E4%B9%A0-%E5%9D%9A%E6%AF%85%E4%B9%8B%E9%BE%9926","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781964422000.webp","sourceId":"rfi"},{"id":1781964215000,"createdDate":"2026-06-20 14:03","name":"法国国际广播电台","title":"« 离散之声 »:—第五届巴黎香港电影节开幕","content":"由一批旅法香港电影爱好者组成的文化协会CUBE，6月20日至21日，在巴黎市中心的CinémaSaint-AndrédesArts举办第五届巴黎香港电影节。本届电影节的主题是“离散之声”（Voixdeladiaspora）以一些自愿迁移或被迫流亡他乡的个人故事，呼应6月20日的世界难民日。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260620-%E7%A6%BB%E6%95%A3%E4%B9%8B%E5%A3%B0-%E7%AC%AC%E4%BA%94%E5%B1%8A%E5%B7%B4%E9%BB%8E%E9%A6%99%E6%B8%AF%E7%94%B5%E5%BD%B1%E8%8A%82%E5%BC%80%E5%B9%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781964215000.webp","sourceId":"rfi"},{"id":1781962975000,"createdDate":"2026-06-20 13:42","name":"法国国际广播电台","title":"美伊要谈判 难过黎巴嫩这一关？","content":"以色列和伊朗支持的黎巴嫩真主党周五（6月19号）同意在黎巴嫩停火后战火却一直不断。据黎巴嫩媒体报道，在以色列和真主党宣布停火不到24小时后，以色列周六对黎巴嫩南部发动空袭，造成5人死亡。黎巴嫩民防部门宣布，以色列周六对黎巴嫩南部纳巴提耶地区的空袭造成16人死亡。此次暴力冲突的再次爆发或危及伊朗和美国周三签署的谅解备忘录的进一步谈判。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260620-%E7%BE%8E%E4%BC%8A%E8%A6%81%E8%B0%88%E5%88%A4-%E9%9A%BE%E8%BF%87%E9%BB%8E%E5%B7%B4%E5%AB%A9%E8%BF%99%E4%B8%80%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781962975000.webp","sourceId":"rfi"},{"id":1781962216000,"createdDate":"2026-06-20 13:30","name":"法国国际广播电台","title":"欧委会将制定供应多元化工具 冯德莱恩：我们正加速去风险","content":"欧盟委员会主席冯德莱恩（UrsulavonderLeyen）表示，欧盟委员会将提议一项新法案，要求欧盟企业实现关键供应来源多元化。不过，如果企业积极主动地降低对中国的依赖，这项法案可能就显得多余了。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260620-%E6%AC%A7%E5%A7%94%E4%BC%9A%E5%B0%86%E5%88%B6%E5%AE%9A%E5%A4%9A%E5%85%83%E5%8C%96%E5%B7%A5%E5%85%B7-%E5%86%AF%E5%BE%B7%E8%8E%B1%E6%81%A9-%E6%88%91%E4%BB%AC%E6%AD%A3%E5%9C%A8%E5%8A%A0%E9%80%9F%E5%8E%BB%E9%A3%8E%E9%99%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781962216000.webp","sourceId":"rfi"},{"id":1781957150000,"createdDate":"2026-06-20 12:05","name":"法国国际广播电台","title":"孟加拉国总理首次出访去大马和中国 贸易和基础设施项目是北京之行重点","content":"孟加拉国外交部周六表示，该国总理拉赫曼（TariqueRahman）就任以来首次出访将访问马来西亚和中国，而非邻国印度作为其首访目的地。据孟加拉国通讯社援引外交部官员的话报导，拉赫曼将于周日访问马来西亚，次日前往中国。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260620-%E5%AD%9F%E5%8A%A0%E6%8B%89%E5%9B%BD%E6%80%BB%E7%90%86%E9%A6%96%E6%AC%A1%E5%87%BA%E8%AE%BF%E5%8E%BB%E5%A4%A7%E9%A9%AC%E5%92%8C%E4%B8%AD%E5%9B%BD-%E8%B4%B8%E6%98%93%E5%92%8C%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD%E9%A1%B9%E7%9B%AE%E5%B0%86%E6%98%AF%E5%8C%97%E4%BA%AC%E4%B9%8B%E9%87%8D%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781957150000.webp","sourceId":"rfi"},{"id":1781956086000,"createdDate":"2026-06-20 11:48","name":"法国国际广播电台","title":"赞防守队员舍身“堵枪眼” 前国脚李毅解说世界杯半场被换下","content":"据《明报》报导，中国前国脚李毅在担任世界杯解说时用“就像黄继光堵枪眼”形容奥地利球员用身体挡出约旦球员射门的防守动作，被质疑侮辱英烈，央视、小红书在球赛上半场结束即弃用李毅。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260620-%E8%B5%9E%E9%98%B2%E5%AE%88%E9%98%9F%E5%91%98%E8%88%8D%E8%BA%AB-%E5%A0%B5%E6%9E%AA%E7%9C%BC-%E5%89%8D%E5%9B%BD%E8%84%9A%E6%9D%8E%E6%AF%85%E8%A7%A3%E8%AF%B4%E4%B8%96%E7%95%8C%E6%9D%AF%E5%8D%8A%E5%9C%BA%E8%A2%AB%E6%8D%A2%E4%B8%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781956086000.webp","sourceId":"rfi"},{"id":1781952327000,"createdDate":"2026-06-20 10:45","name":"法国国际广播电台","title":"7月1日开始 日本将外国人签证手续费提高至5倍","content":"日本政府于5月19日通过内阁会议决定，提高面向外国人的签证（Visa）手续费。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260620-7%E6%9C%881%E6%97%A5%E5%BC%80%E5%A7%8B-%E6%97%A5%E6%9C%AC%E5%B0%86%E5%A4%96%E5%9B%BD%E4%BA%BA%E7%AD%BE%E8%AF%81%E6%89%8B%E7%BB%AD%E8%B4%B9%E6%8F%90%E9%AB%98%E8%87%B35%E5%80%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781952327000.webp","sourceId":"rfi"},{"id":1781951361000,"createdDate":"2026-06-20 10:29","name":"法国国际广播电台","title":"德总理默茨称人民币被低估了30% 并指中方通过高额补贴倾销产品","content":"德国总理默茨（FriedrichMerz）周五表示，中国货币被低估了30%，远高于国际货币基金组织估计的“约16%”，这表明柏林与北京的经济关系发生重大转变。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260620-%E5%BE%B7%E6%80%BB%E7%90%86%E9%BB%98%E8%8C%A8%E7%A7%B0%E4%BA%BA%E6%B0%91%E5%B8%81%E8%A2%AB%E4%BD%8E%E4%BC%B0%E4%BA%8630-%E5%B9%B6%E6%8C%87%E4%B8%AD%E6%96%B9%E9%80%9A%E8%BF%87%E9%AB%98%E9%A2%9D%E8%A1%A5%E8%B4%B4%E5%80%BE%E9%94%80%E4%BA%A7%E5%93%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781951361000.webp","sourceId":"rfi"},{"id":1781950003000,"createdDate":"2026-06-20 10:06","name":"法国国际广播电台","title":"立陶宛拟允中国设“临时代办处 ” 外长未予证实","content":"立陶宛国会外交委员会主席莫图扎斯日前表示，立方同意中国现阶段在立陶宛设立 “临时代办处 ”。立陶宛国家广播电视台报导，立陶宛外交部长布德里斯对此未给予证实，外委会副主席则批评此举为承认降低国家地位。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260620-%E7%AB%8B%E9%99%B6%E5%AE%9B%E6%8B%9F%E5%85%81%E4%B8%AD%E5%9B%BD%E8%AE%BE-%E4%B8%B4%E6%97%B6%E4%BB%A3%E5%8A%9E%E5%A4%84-%E5%A4%96%E9%95%BF%E6%9C%AA%E4%BA%88%E8%AF%81%E5%AE%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781950003000.webp","sourceId":"rfi"},{"id":1781949344000,"createdDate":"2026-06-20 09:55","name":"法国国际广播电台","title":"特朗普指今年某个时候还会再去中国，点名莫迪和习近平","content":"美国总统特朗普（DonaldTrump）周五表示，他将在年内访问土耳其，并再次访问中国。特朗普在马里兰州安德鲁斯联合基地说道，“我们将进行很多访问。我们将前往土耳其。今年某个时候，我们还会再去中国”。当时，他正在为卡塔尔赠送的波音747飞机揭幕，这架飞机将加入总统专机“空军一号”机队。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260620-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8C%87%E4%BB%8A%E5%B9%B4%E6%9F%90%E4%B8%AA%E6%97%B6%E5%80%99%E8%BF%98%E4%BC%9A%E5%86%8D%E5%8E%BB%E4%B8%AD%E5%9B%BD%EF%BC%8C%E7%82%B9%E5%90%8D%E8%8E%AB%E8%BF%AA%E5%92%8C%E4%B9%A0%E8%BF%91%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781949344000.webp","sourceId":"rfi"}]