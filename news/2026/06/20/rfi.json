[{"id":1781914642000,"createdDate":"2026-06-20 00:17","name":"法国国际广播电台","title":"日媒称中国恢复赴日团游，但“中旅旅行”官网同日团队游行程被下架","content":"日本媒体19日报导，中国国营旅行社已恢复推出日本团体旅游产品。不过，新加坡《联合早报》发现，隶属国营的“中旅旅行”官网同日紧急下架相关产品。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260620-%E6%97%A5%E5%AA%92%E7%A7%B0%E4%B8%AD%E5%9B%BD%E6%81%A2%E5%A4%8D%E8%B5%B4%E6%97%A5%E5%9B%A2%E6%B8%B8%EF%BC%8C%E4%BD%86-%E4%B8%AD%E6%97%85%E6%97%85%E8%A1%8C-%E5%AE%98%E7%BD%91%E5%90%8C%E6%97%A5%E5%9B%A2%E9%98%9F%E6%B8%B8%E8%A1%8C%E7%A8%8B%E8%A2%AB%E4%B8%8B%E6%9E%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781914642000.webp","sourceId":"rfi"},{"id":1781914466000,"createdDate":"2026-06-20 00:14","name":"法国国际广播电台","title":"伊朗战争暴露能源弱点：台湾是否将重新发展核能？","content":"美国和以色列对伊朗发动战争三个月后，台湾的一切似乎和平常没有两样。不过，霍尔木兹海峡危机还是暴露了台湾能源供应的脆弱性：台湾几乎所有天然气、石油和煤炭都依赖进口。尽管台湾政府原本决定在2025年全面废核，但如今为了满足高能耗的半导体产业的能源需求，正考虑重新发展核能。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260620-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%9A%B4%E9%9C%B2%E8%83%BD%E6%BA%90%E5%BC%B1%E7%82%B9-%E5%8F%B0%E6%B9%BE%E6%98%AF%E5%90%A6%E5%B0%86%E9%87%8D%E6%96%B0%E5%8F%91%E5%B1%95%E6%A0%B8%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781914466000.webp","sourceId":"rfi"},{"id":1781947495000,"createdDate":"2026-06-20 09:24","name":"法国国际广播电台","title":"2026世界杯：巴西3比0轻取海地 摩洛哥击败苏格兰 攻入本届最快进球","content":"2026年世界杯C组第二轮赛，巴西队展现出与首战截然不同的状态，以3比0轻取海地，拿下本届赛事首场胜利，并以净胜球数暂居小组第一。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260620-2026%E4%B8%96%E7%95%8C%E6%9D%AF-%E5%B7%B4%E8%A5%BF3%E6%AF%940%E8%BD%BB%E5%8F%96%E6%B5%B7%E5%9C%B0-%E6%91%A9%E6%B4%9B%E5%93%A5%E5%87%BB%E8%B4%A5%E8%8B%8F%E6%A0%BC%E5%85%B0-%E6%94%BB%E5%85%A5%E6%9C%AC%E5%B1%8A%E6%9C%80%E5%BF%AB%E8%BF%9B%E7%90%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781947495000.webp","sourceId":"rfi"},{"id":1781946803000,"createdDate":"2026-06-20 09:13","name":"法国国际广播电台","title":"美菲完成今年在南中国海的第四次双边“海事合作活动”","content":"菲律宾和美国海军及空军在西菲律宾海（菲方对其专属经济区内南中国海海域的称呼）举行了今年第四次双边海事合作活动（MCA），两国继续加强海上互操作性，为即将在夏威夷举行的多国海军演习做准备。菲律宾武装部队周六表示，此次活动于6月14日至19日举行。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260620-%E7%BE%8E%E8%8F%B2%E5%AE%8C%E6%88%90%E4%BB%8A%E5%B9%B4%E5%9C%A8%E5%8D%97%E4%B8%AD%E5%9B%BD%E6%B5%B7%E7%9A%84%E7%AC%AC%E5%9B%9B%E6%AC%A1%E5%8F%8C%E8%BE%B9-%E6%B5%B7%E4%BA%8B%E5%90%88%E4%BD%9C%E6%B4%BB%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781946803000.webp","sourceId":"rfi"}]