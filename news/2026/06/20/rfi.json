[{"id":1781914642000,"createdDate":"2026-06-20 00:17","name":"法国国际广播电台","title":"日媒称中国恢复赴日团游，但“中旅旅行”官网同日团队游行程被下架","content":"日本媒体19日报导，中国国营旅行社已恢复推出日本团体旅游产品。不过，新加坡《联合早报》发现，隶属国营的“中旅旅行”官网同日紧急下架相关产品。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260620-%E6%97%A5%E5%AA%92%E7%A7%B0%E4%B8%AD%E5%9B%BD%E6%81%A2%E5%A4%8D%E8%B5%B4%E6%97%A5%E5%9B%A2%E6%B8%B8%EF%BC%8C%E4%BD%86-%E4%B8%AD%E6%97%85%E6%97%85%E8%A1%8C-%E5%AE%98%E7%BD%91%E5%90%8C%E6%97%A5%E5%9B%A2%E9%98%9F%E6%B8%B8%E8%A1%8C%E7%A8%8B%E8%A2%AB%E4%B8%8B%E6%9E%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781914642000.webp","sourceId":"rfi"},{"id":1781914466000,"createdDate":"2026-06-20 00:14","name":"法国国际广播电台","title":"伊朗战争暴露能源弱点：台湾是否将重新发展核能？","content":"美国和以色列对伊朗发动战争三个月后，台湾的一切似乎和平常没有两样。不过，霍尔木兹海峡危机还是暴露了台湾能源供应的脆弱性：台湾几乎所有天然气、石油和煤炭都依赖进口。尽管台湾政府原本决定在2025年全面废核，但如今为了满足高能耗的半导体产业的能源需求，正考虑重新发展核能。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260620-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%9A%B4%E9%9C%B2%E8%83%BD%E6%BA%90%E5%BC%B1%E7%82%B9-%E5%8F%B0%E6%B9%BE%E6%98%AF%E5%90%A6%E5%B0%86%E9%87%8D%E6%96%B0%E5%8F%91%E5%B1%95%E6%A0%B8%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781914466000.webp","sourceId":"rfi"},{"id":1781947495000,"createdDate":"2026-06-20 09:24","name":"法国国际广播电台","title":"2026世界杯：巴西3比0轻取海地 摩洛哥击败苏格兰 攻入本届最快进球","content":"2026年世界杯C组第二轮赛，巴西队展现出与首战截然不同的状态，以3比0轻取海地，拿下本届赛事首场胜利，并以净胜球数暂居小组第一。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260620-2026%E4%B8%96%E7%95%8C%E6%9D%AF-%E5%B7%B4%E8%A5%BF3%E6%AF%940%E8%BD%BB%E5%8F%96%E6%B5%B7%E5%9C%B0-%E6%91%A9%E6%B4%9B%E5%93%A5%E5%87%BB%E8%B4%A5%E8%8B%8F%E6%A0%BC%E5%85%B0-%E6%94%BB%E5%85%A5%E6%9C%AC%E5%B1%8A%E6%9C%80%E5%BF%AB%E8%BF%9B%E7%90%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781947495000.webp","sourceId":"rfi"},{"id":1781946803000,"createdDate":"2026-06-20 09:13","name":"法国国际广播电台","title":"美菲完成今年在南中国海的第四次双边“海事合作活动”","content":"菲律宾和美国海军及空军在西菲律宾海（菲方对其专属经济区内南中国海海域的称呼）举行了今年第四次双边海事合作活动（MCA），两国继续加强海上互操作性，为即将在夏威夷举行的多国海军演习做准备。菲律宾武装部队周六表示，此次活动于6月14日至19日举行。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260620-%E7%BE%8E%E8%8F%B2%E5%AE%8C%E6%88%90%E4%BB%8A%E5%B9%B4%E5%9C%A8%E5%8D%97%E4%B8%AD%E5%9B%BD%E6%B5%B7%E7%9A%84%E7%AC%AC%E5%9B%9B%E6%AC%A1%E5%8F%8C%E8%BE%B9-%E6%B5%B7%E4%BA%8B%E5%90%88%E4%BD%9C%E6%B4%BB%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781946803000.webp","sourceId":"rfi"},{"id":1781968192000,"createdDate":"2026-06-20 15:09","name":"法国国际广播电台","title":"埃博拉:刚果(金)患者死亡超二百","content":"埃博拉疫情在刚果民主共和国（RDCongo）东部持续蔓延。据非洲联盟卫生机构对外发布的数据，自05月15日以来，刚果（金）目前已查明近九百宗确诊病例，其中，死亡病例超过二百宗，确诊患者的病死率为23%；密切接触者人数多达3万5千人。刚果（金）东部伊图里省（Ituri）仍是疫情中心。邻近的北基伍省（NordKivu）和位于非洲中部大湖地区的邻国乌干达(l'Ouganda)的疫情形势严峻。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260620-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%9F%83%E5%8D%9A%E6%8B%89-%E5%88%9A%E6%9E%9C-%E9%87%91-%E6%82%A3%E8%80%85%E6%AD%BB%E4%BA%A1%E8%B6%85%E4%BA%8C%E7%99%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781968192000.webp","sourceId":"rfi"},{"id":1781967655000,"createdDate":"2026-06-20 15:00","name":"法国国际广播电台","title":"法官裁定，西班牙首相夫人须因腐败指控受审 交出护照不得离境","content":"西班牙首相桑切斯（PedroSanchez）的夫人戈麦斯（BegonaGomez）因涉嫌腐败必须接受审判，并被禁止离境，一名法官于周六作出此项裁决。戈麦斯正因涉嫌利用首相夫人的身份获取工作合同而接受调查。她否认有任何不当行为。此案由极右翼团体提起。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260620-%E6%B3%95%E5%AE%98%E8%A3%81%E5%AE%9A%EF%BC%8C%E8%A5%BF%E7%8F%AD%E7%89%99%E9%A6%96%E7%9B%B8%E5%A4%AB%E4%BA%BA%E9%A1%BB%E5%9B%A0%E8%85%90%E8%B4%A5%E6%8C%87%E6%8E%A7%E5%8F%97%E5%AE%A1-%E4%BA%A4%E5%87%BA%E6%8A%A4%E7%85%A7%E4%B8%8D%E5%BE%97%E7%A6%BB%E5%A2%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781967655000.webp","sourceId":"rfi"},{"id":1781964422000,"createdDate":"2026-06-20 14:07","name":"法国国际广播电台","title":"日美开启在九州和冲绳举行的岛屿防御演习“坚毅之龙26”","content":"日本陆上自卫队和美国海军陆战队于周六启动了代号为“坚毅之龙26”的岛屿防御技能联合演习，演习将持续至6月30日，演习范围覆盖日本西南部的九州地区和冲绳县。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260620-%E6%97%A5%E7%BE%8E%E5%BC%80%E5%90%AF%E5%9C%A8%E4%B9%9D%E5%B7%9E%E5%92%8C%E5%86%B2%E7%BB%B3%E4%B8%BE%E8%A1%8C%E7%9A%84%E5%B2%9B%E5%B1%BF%E9%98%B2%E5%BE%A1%E6%BC%94%E4%B9%A0-%E5%9D%9A%E6%AF%85%E4%B9%8B%E9%BE%9926","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781964422000.webp","sourceId":"rfi"},{"id":1781964215000,"createdDate":"2026-06-20 14:03","name":"法国国际广播电台","title":"« 离散之声 »:—第五届巴黎香港电影节开幕","content":"由一批旅法香港电影爱好者组成的文化协会CUBE，6月20日至21日，在巴黎市中心的CinémaSaint-AndrédesArts举办第五届巴黎香港电影节。本届电影节的主题是“离散之声”（Voixdeladiaspora）以一些自愿迁移或被迫流亡他乡的个人故事，呼应6月20日的世界难民日。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260620-%E7%A6%BB%E6%95%A3%E4%B9%8B%E5%A3%B0-%E7%AC%AC%E4%BA%94%E5%B1%8A%E5%B7%B4%E9%BB%8E%E9%A6%99%E6%B8%AF%E7%94%B5%E5%BD%B1%E8%8A%82%E5%BC%80%E5%B9%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781964215000.webp","sourceId":"rfi"},{"id":1781962975000,"createdDate":"2026-06-20 13:42","name":"法国国际广播电台","title":"美伊要谈判 难过黎巴嫩这一关？","content":"以色列和伊朗支持的黎巴嫩真主党周五（6月19号）同意在黎巴嫩停火后战火却一直不断。据黎巴嫩媒体报道，在以色列和真主党宣布停火不到24小时后，以色列周六对黎巴嫩南部发动空袭，造成5人死亡。黎巴嫩民防部门宣布，以色列周六对黎巴嫩南部纳巴提耶地区的空袭造成16人死亡。此次暴力冲突的再次爆发或危及伊朗和美国周三签署的谅解备忘录的进一步谈判。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260620-%E7%BE%8E%E4%BC%8A%E8%A6%81%E8%B0%88%E5%88%A4-%E9%9A%BE%E8%BF%87%E9%BB%8E%E5%B7%B4%E5%AB%A9%E8%BF%99%E4%B8%80%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781962975000.webp","sourceId":"rfi"},{"id":1781962216000,"createdDate":"2026-06-20 13:30","name":"法国国际广播电台","title":"欧委会将制定供应多元化工具 冯德莱恩：我们正加速去风险","content":"欧盟委员会主席冯德莱恩（UrsulavonderLeyen）表示，欧盟委员会将提议一项新法案，要求欧盟企业实现关键供应来源多元化。不过，如果企业积极主动地降低对中国的依赖，这项法案可能就显得多余了。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260620-%E6%AC%A7%E5%A7%94%E4%BC%9A%E5%B0%86%E5%88%B6%E5%AE%9A%E5%A4%9A%E5%85%83%E5%8C%96%E5%B7%A5%E5%85%B7-%E5%86%AF%E5%BE%B7%E8%8E%B1%E6%81%A9-%E6%88%91%E4%BB%AC%E6%AD%A3%E5%9C%A8%E5%8A%A0%E9%80%9F%E5%8E%BB%E9%A3%8E%E9%99%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781962216000.webp","sourceId":"rfi"},{"id":1781957150000,"createdDate":"2026-06-20 12:05","name":"法国国际广播电台","title":"孟加拉国总理首次出访去大马和中国 贸易和基础设施项目是北京之行重点","content":"孟加拉国外交部周六表示，该国总理拉赫曼（TariqueRahman）就任以来首次出访将访问马来西亚和中国，而非邻国印度作为其首访目的地。据孟加拉国通讯社援引外交部官员的话报导，拉赫曼将于周日访问马来西亚，次日前往中国。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260620-%E5%AD%9F%E5%8A%A0%E6%8B%89%E5%9B%BD%E6%80%BB%E7%90%86%E9%A6%96%E6%AC%A1%E5%87%BA%E8%AE%BF%E5%8E%BB%E5%A4%A7%E9%A9%AC%E5%92%8C%E4%B8%AD%E5%9B%BD-%E8%B4%B8%E6%98%93%E5%92%8C%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD%E9%A1%B9%E7%9B%AE%E5%B0%86%E6%98%AF%E5%8C%97%E4%BA%AC%E4%B9%8B%E9%87%8D%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781957150000.webp","sourceId":"rfi"},{"id":1781956086000,"createdDate":"2026-06-20 11:48","name":"法国国际广播电台","title":"赞防守队员舍身“堵枪眼” 前国脚李毅解说世界杯半场被换下","content":"据《明报》报导，中国前国脚李毅在担任世界杯解说时用“就像黄继光堵枪眼”形容奥地利球员用身体挡出约旦球员射门的防守动作，被质疑侮辱英烈，央视、小红书在球赛上半场结束即弃用李毅。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260620-%E8%B5%9E%E9%98%B2%E5%AE%88%E9%98%9F%E5%91%98%E8%88%8D%E8%BA%AB-%E5%A0%B5%E6%9E%AA%E7%9C%BC-%E5%89%8D%E5%9B%BD%E8%84%9A%E6%9D%8E%E6%AF%85%E8%A7%A3%E8%AF%B4%E4%B8%96%E7%95%8C%E6%9D%AF%E5%8D%8A%E5%9C%BA%E8%A2%AB%E6%8D%A2%E4%B8%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781956086000.webp","sourceId":"rfi"},{"id":1781952327000,"createdDate":"2026-06-20 10:45","name":"法国国际广播电台","title":"7月1日开始 日本将外国人签证手续费提高至5倍","content":"日本政府于5月19日通过内阁会议决定，提高面向外国人的签证（Visa）手续费。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260620-7%E6%9C%881%E6%97%A5%E5%BC%80%E5%A7%8B-%E6%97%A5%E6%9C%AC%E5%B0%86%E5%A4%96%E5%9B%BD%E4%BA%BA%E7%AD%BE%E8%AF%81%E6%89%8B%E7%BB%AD%E8%B4%B9%E6%8F%90%E9%AB%98%E8%87%B35%E5%80%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781952327000.webp","sourceId":"rfi"},{"id":1781951361000,"createdDate":"2026-06-20 10:29","name":"法国国际广播电台","title":"德总理默茨称人民币被低估了30% 并指中方通过高额补贴倾销产品","content":"德国总理默茨（FriedrichMerz）周五表示，中国货币被低估了30%，远高于国际货币基金组织估计的“约16%”，这表明柏林与北京的经济关系发生重大转变。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260620-%E5%BE%B7%E6%80%BB%E7%90%86%E9%BB%98%E8%8C%A8%E7%A7%B0%E4%BA%BA%E6%B0%91%E5%B8%81%E8%A2%AB%E4%BD%8E%E4%BC%B0%E4%BA%8630-%E5%B9%B6%E6%8C%87%E4%B8%AD%E6%96%B9%E9%80%9A%E8%BF%87%E9%AB%98%E9%A2%9D%E8%A1%A5%E8%B4%B4%E5%80%BE%E9%94%80%E4%BA%A7%E5%93%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781951361000.webp","sourceId":"rfi"},{"id":1781950003000,"createdDate":"2026-06-20 10:06","name":"法国国际广播电台","title":"立陶宛拟允中国设“临时代办处 ” 外长未予证实","content":"立陶宛国会外交委员会主席莫图扎斯日前表示，立方同意中国现阶段在立陶宛设立 “临时代办处 ”。立陶宛国家广播电视台报导，立陶宛外交部长布德里斯对此未给予证实，外委会副主席则批评此举为承认降低国家地位。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260620-%E7%AB%8B%E9%99%B6%E5%AE%9B%E6%8B%9F%E5%85%81%E4%B8%AD%E5%9B%BD%E8%AE%BE-%E4%B8%B4%E6%97%B6%E4%BB%A3%E5%8A%9E%E5%A4%84-%E5%A4%96%E9%95%BF%E6%9C%AA%E4%BA%88%E8%AF%81%E5%AE%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781950003000.webp","sourceId":"rfi"},{"id":1781949344000,"createdDate":"2026-06-20 09:55","name":"法国国际广播电台","title":"特朗普指今年某个时候还会再去中国，点名莫迪和习近平","content":"美国总统特朗普（DonaldTrump）周五表示，他将在年内访问土耳其，并再次访问中国。特朗普在马里兰州安德鲁斯联合基地说道，“我们将进行很多访问。我们将前往土耳其。今年某个时候，我们还会再去中国”。当时，他正在为卡塔尔赠送的波音747飞机揭幕，这架飞机将加入总统专机“空军一号”机队。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260620-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8C%87%E4%BB%8A%E5%B9%B4%E6%9F%90%E4%B8%AA%E6%97%B6%E5%80%99%E8%BF%98%E4%BC%9A%E5%86%8D%E5%8E%BB%E4%B8%AD%E5%9B%BD%EF%BC%8C%E7%82%B9%E5%90%8D%E8%8E%AB%E8%BF%AA%E5%92%8C%E4%B9%A0%E8%BF%91%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781949344000.webp","sourceId":"rfi"},{"id":1781988268000,"createdDate":"2026-06-20 20:44","name":"法国国际广播电台","title":"美伊瑞士谈判前   伊朗宣布再次“关闭”霍尔木兹海峡","content":"伊朗周六宣布，将再次关闭具有战略意义的霍尔木兹海峡，以报复以色列在黎巴嫩发动的致命袭击。但伊朗并未中断旨在达成最终协议以结束中东冲突的谈判，谈判定于周日在瑞士举行。特朗普威胁称，如果与伊朗的谈判失败，美国将在霍尔木兹海峡征收通行费。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260620-%E7%BE%8E%E4%BC%8A%E7%91%9E%E5%A3%AB%E8%B0%88%E5%88%A4%E5%89%8D-%E4%BC%8A%E6%9C%97%E5%AE%A3%E5%B8%83%E5%86%8D%E6%AC%A1-%E5%85%B3%E9%97%AD-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781988268000.webp","sourceId":"rfi"},{"id":1781988103000,"createdDate":"2026-06-20 20:41","name":"法国国际广播电台","title":"特朗普坚称是梅洛尼央求与他合影","content":"周六，特朗普再次挑起与意大利的外交争端，坚称意大利总理乔治娅·梅洛尼几天前在七国集团峰会上“一而再再而三”地要求与他合影。梅洛尼回应称，这是“疯狂的”攻击。梅洛尼还称，特朗普“持续且毫无理由的攻击毫无意义”，他应“把注意力放在自己的支持率上”。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260620-%E7%89%B9%E6%9C%97%E6%99%AE%E5%9D%9A%E7%A7%B0%E6%98%AF%E6%A2%85%E6%B4%9B%E5%B0%BC%E5%A4%AE%E6%B1%82%E4%B8%8E%E4%BB%96%E5%90%88%E5%BD%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781988103000.webp","sourceId":"rfi"},{"id":1781987894000,"createdDate":"2026-06-20 20:38","name":"法国国际广播电台","title":"半岛电视台一记者在以空袭中被炸死","content":"总部位于卡塔尔的半岛电视台周六宣布，其一名记者在加沙地带的一次以色列空袭中丧生。卡塔尔半岛电视台发表声明，谴责其摄影师艾哈迈德·维沙（AhmedWishah）遭以色列军队“蓄意谋杀”。维沙于周六在加沙地带被以色列军队杀害，几个月前，他的兄弟兼同事也已遇害。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260620-%E5%8D%8A%E5%B2%9B%E7%94%B5%E8%A7%86%E5%8F%B0%E4%B8%80%E8%AE%B0%E8%80%85%E5%9C%A8%E4%BB%A5%E7%A9%BA%E8%A2%AD%E4%B8%AD%E8%A2%AB%E7%82%B8%E6%AD%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781987894000.webp","sourceId":"rfi"},{"id":1781987604000,"createdDate":"2026-06-20 20:33","name":"法国国际广播电台","title":"阿斯麦：从未向中国出口极紫外光刻机或部件","content":"荷兰光刻机制造商阿斯麦（ASML）6月19日表示，从未向中国出口过极紫外（EUV）光刻机及部件。美国商务部长霍华德·卢特尼克（HowardLutnick）在多次会晤中向ASML高管表达了他的担忧。路透社20日发布一篇题为“全球最受瞩目的机器是否已流入中国？华盛顿对此表示极大的担忧”。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260620-%E9%98%BF%E6%96%AF%E9%BA%A6-%E4%BB%8E%E6%9C%AA%E5%90%91%E4%B8%AD%E5%9B%BD%E5%87%BA%E5%8F%A3%E6%9E%81%E7%B4%AB%E5%A4%96%E5%85%89%E5%88%BB%E6%9C%BA%E6%88%96%E9%83%A8%E4%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781987604000.webp","sourceId":"rfi"},{"id":1781987146000,"createdDate":"2026-06-20 20:25","name":"法国国际广播电台","title":"特朗普发出威胁：如谈判失败  美将征收霍尔木兹海峡通行费","content":"美伊在瑞士在卢塞恩（Lucerne）湖附近的比尔根山（Bürgenstock）举行谈判之际，伊朗方面对外宣布关闭霍尔木兹海峡。瑞士方面不愿意透露双方参加谈判代表团的具体情况。谈判之前，伊朗宣布关闭霍尔木兹海峡。美国总统威胁说，如谈判失败，将由美国征收通行费。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260620-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%91%E5%87%BA%E5%A8%81%E8%83%81-%E5%A6%82%E8%B0%88%E5%88%A4%E5%A4%B1%E8%B4%A5-%E7%BE%8E%E5%B0%86%E5%BE%81%E6%94%B6%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%80%9A%E8%A1%8C%E8%B4%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781987146000.webp","sourceId":"rfi"},{"id":1781986516000,"createdDate":"2026-06-20 20:15","name":"法国国际广播电台","title":"2026年世界杯足球赛小组生死战过半","content":"2026年世界杯小组赛正酣。在过去的一周中，这届全新扩军的赛事给足球迷们带来了不间断的精彩对决。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260620-2026%E5%B9%B4%E4%B8%96%E7%95%8C%E6%9D%AF%E8%B6%B3%E7%90%83%E8%B5%9B%E5%B0%8F%E7%BB%84%E7%94%9F%E6%AD%BB%E6%88%98%E8%BF%87%E5%8D%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781986516000.webp","sourceId":"rfi"},{"id":1781982836000,"createdDate":"2026-06-20 19:13","name":"法国国际广播电台","title":"美国乔治亚州破获大麻种植案涉跨国资金　六名中国籍人士判刑将遣返","content":"美国乔治亚州南部一宗大型室内大麻种植与贩运案件近日宣判，6名涉案中国籍人士在联邦法院承认相关罪行后，分别被判处29至30个月不等有期徒刑，并将于刑满后移交移民暨海关执法局（ICE）进行遣返。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260620-%E7%BE%8E%E5%9B%BD%E4%B9%94%E6%B2%BB%E4%BA%9A%E5%B7%9E%E7%A0%B4%E8%8E%B7%E5%A4%A7%E9%BA%BB%E7%A7%8D%E6%A4%8D%E6%A1%88%E6%B6%89%E8%B7%A8%E5%9B%BD%E8%B5%84%E9%87%91-%E5%85%AD%E5%90%8D%E4%B8%AD%E5%9B%BD%E7%B1%8D%E4%BA%BA%E5%A3%AB%E5%88%A4%E5%88%91%E5%B0%86%E9%81%A3%E8%BF%94","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781982836000.webp","sourceId":"rfi"},{"id":1781982437000,"createdDate":"2026-06-20 19:07","name":"法国国际广播电台","title":"台湾外长：法国总统马克龙希望欧盟与台湾合作主权AI","content":"建立主权AI的议题已成为国际领袖间讨论的热门，也是刚结束的七国集团峰会的主题之一。而台湾外长林佳龙20日透露：法国总统马克龙表示期盼欧盟与台湾合作主权AI。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260620-%E5%8F%B0%E6%B9%BE%E5%A4%96%E9%95%BF-%E6%B3%95%E5%9B%BD%E6%80%BB%E7%BB%9F%E9%A9%AC%E5%85%8B%E9%BE%99%E5%B8%8C%E6%9C%9B%E6%AC%A7%E7%9B%9F%E4%B8%8E%E5%8F%B0%E6%B9%BE%E5%90%88%E4%BD%9C%E4%B8%BB%E6%9D%83ai","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781982437000.webp","sourceId":"rfi"},{"id":1781981707000,"createdDate":"2026-06-20 18:55","name":"法国国际广播电台","title":"法国35个省发布红色高温预警","content":"法国极端高温天气导致法国气象局和相关部门对至少35个省份发布了极端高温-红色预警。这是最高预警级别。政府宣布，由于高温天气，在被列入红色热浪预警的省份，本周日（6月21日）的音乐节期间不得出售酒精饮料。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260620-%E6%B3%95%E5%9B%BD35%E4%B8%AA%E7%9C%81%E5%8F%91%E5%B8%83%E7%BA%A2%E8%89%B2%E9%AB%98%E6%B8%A9%E9%A2%84%E8%AD%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781981707000.webp","sourceId":"rfi"},{"id":1781979034000,"createdDate":"2026-06-20 18:10","name":"法国国际广播电台","title":"法媒追问：在凡尔赛宴请特朗普花了纳税人多少钱？","content":"法国总统马克龙在凡尔赛宫宴请特朗普，《费加罗报》、《资本》等媒体追问：晚宴花了纳税人多少钱？而法国总统马克龙在举办G7接受电视1台采访时一再强调，主要的目的并不是搞一次奢华的宴请活动。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260620-%E6%B3%95%E5%AA%92%E8%BF%BD%E9%97%AE-%E5%9C%A8%E5%87%A1%E5%B0%94%E8%B5%9B%E5%AE%B4%E8%AF%B7%E7%89%B9%E6%9C%97%E6%99%AE%E8%8A%B1%E4%BA%86%E7%BA%B3%E7%A8%8E%E4%BA%BA%E5%A4%9A%E5%B0%91%E9%92%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781979034000.webp","sourceId":"rfi"},{"id":1781974800000,"createdDate":"2026-06-20 17:00","name":"法国国际广播电台","title":"南非对国际犀牛角走私大案处罚","content":"-南非一家法院于2026年06月18日星期四裁定对一名狩猎旅行团的组织方判处200万兰特（约合12.3万美元）的罚款。一名组织者被认为是庞大的国际犀牛角走私团伙的幕后首脑。这一裁决结束了这场始于2010年的司法程序，期间历经了多次延期和上诉。本台法广非洲组（RFIAfrique）的法文报导提到，在亚洲，犀牛角被错误地认为具有药用价值。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260620-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%8D%97%E9%9D%9E%E5%AF%B9%E5%9B%BD%E9%99%85%E7%8A%80%E7%89%9B%E8%A7%92%E8%B5%B0%E7%A7%81%E5%A4%A7%E6%A1%88%E5%A4%84%E7%BD%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781974800000.webp","sourceId":"rfi"}]