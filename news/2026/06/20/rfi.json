[{"id":1781914642000,"createdDate":"2026-06-20 00:17","name":"法国国际广播电台","title":"日媒称中国恢复赴日团游，但“中旅旅行”官网同日团队游行程被下架","content":"日本媒体19日报导，中国国营旅行社已恢复推出日本团体旅游产品。不过，新加坡《联合早报》发现，隶属国营的“中旅旅行”官网同日紧急下架相关产品。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260620-%E6%97%A5%E5%AA%92%E7%A7%B0%E4%B8%AD%E5%9B%BD%E6%81%A2%E5%A4%8D%E8%B5%B4%E6%97%A5%E5%9B%A2%E6%B8%B8%EF%BC%8C%E4%BD%86-%E4%B8%AD%E6%97%85%E6%97%85%E8%A1%8C-%E5%AE%98%E7%BD%91%E5%90%8C%E6%97%A5%E5%9B%A2%E9%98%9F%E6%B8%B8%E8%A1%8C%E7%A8%8B%E8%A2%AB%E4%B8%8B%E6%9E%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781914642000.webp","sourceId":"rfi"},{"id":1781914466000,"createdDate":"2026-06-20 00:14","name":"法国国际广播电台","title":"伊朗战争暴露能源弱点：台湾是否将重新发展核能？","content":"美国和以色列对伊朗发动战争三个月后，台湾的一切似乎和平常没有两样。不过，霍尔木兹海峡危机还是暴露了台湾能源供应的脆弱性：台湾几乎所有天然气、石油和煤炭都依赖进口。尽管台湾政府原本决定在2025年全面废核，但如今为了满足高能耗的半导体产业的能源需求，正考虑重新发展核能。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260620-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%9A%B4%E9%9C%B2%E8%83%BD%E6%BA%90%E5%BC%B1%E7%82%B9-%E5%8F%B0%E6%B9%BE%E6%98%AF%E5%90%A6%E5%B0%86%E9%87%8D%E6%96%B0%E5%8F%91%E5%B1%95%E6%A0%B8%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/20/1781914466000.webp","sourceId":"rfi"}]