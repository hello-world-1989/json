[{"id":1782380475000,"createdDate":"2026-06-25 09:41","name":"法国国际广播电台","title":"习近平的“足球梦”雄心勃勃，“龙之队”的表现却为何如此糟糕？","content":"大家好，欢迎收听法国报纸摘要，在华盛顿与德黑兰签署的谅解备忘录中，伊朗民众似乎被完全忽视了，成为今天6月25日《费加罗报》首页关注重点。据该报指出，伊朗民间社会将该协议视为一种背叛；战争加剧了伊朗人民的生活困境，德黑兰弥漫着“苦涩的情绪”，并同时提醒，制裁已经“迅速侵蚀了伊朗人的购买力”，并助长了抗议活动。与此同时，法国刚刚经历了有记录以来最闷热的两个夜晚，由于气候变暖，这种危险现象正日益频繁则是《解放报》的封面话题。此外继《十字架报》与《世界报》后，在世界杯小组赛收官之际《解放报》也将目光放到中国足球队上，登出报道解析，远大梦想之下奈何成绩惨不忍睹。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260625-%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%9A%84-%E8%B6%B3%E7%90%83%E6%A2%A6-%E9%9B%84%E5%BF%83%E5%8B%83%E5%8B%83%EF%BC%8C-%E9%BE%99%E4%B9%8B%E9%98%9F-%E7%9A%84%E8%A1%A8%E7%8E%B0%E5%8D%B4%E4%B8%BA%E4%BD%95%E5%A6%82%E6%AD%A4%E7%B3%9F%E7%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782380475000.webp","sourceId":"rfi"},{"id":1782379076000,"createdDate":"2026-06-25 09:17","name":"法国国际广播电台","title":"世界杯球赛 南非爆冷门1比0胜韩国队","content":"在世界杯A组赛中24日南非队爆冷门以1比0胜韩国队，让南非对首次普及32强，南非队将于6月28日星期日晚上7点迎战加拿大队。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260625-%E4%B8%96%E7%95%8C%E6%9D%AF%E7%90%83%E8%B5%9B-%E5%8D%97%E9%9D%9E%E7%88%86%E5%86%B7%E9%97%A81%E6%AF%940%E8%83%9C%E9%9F%A9%E5%9B%BD%E9%98%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782379076000.webp","sourceId":"rfi"},{"id":1782378641000,"createdDate":"2026-06-25 09:10","name":"法国国际广播电台","title":"中国商务部加强举报措施严控两用物项出口 被拘留两名日本人为富士电机职员","content":"中国商务部24日宣布，将设立关于战略矿产军民两用（Dual-Use）产品出口管制违法违规行为的举报窗口。商务部表示，此举旨在“发挥社会监督作用”，被认为是进一步加强严控稀土等出口的执法和监管力度的措施。而据多名相关人士透露，今年5月，在中国辽宁省大连市，当地海关部门拘留的两名日本人为日本大型电机企业富士电机的员工，其中至少一人在该公司中国当地法人任职。他们涉嫌试图将中国加强出口管制的稀土相关物品带出境外，因此可能被认定违反相关法律法规，涉嫌触犯“走私国家禁止进出口货物罪”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260625-%E4%B8%AD%E5%9B%BD%E5%95%86%E5%8A%A1%E9%83%A8%E5%8A%A0%E5%BC%BA%E4%B8%BE%E6%8A%A5%E6%8E%AA%E6%96%BD%E4%B8%A5%E6%8E%A7%E4%B8%A4%E7%94%A8%E7%89%A9%E9%A1%B9%E5%87%BA%E5%8F%A3-%E8%A2%AB%E6%8B%98%E7%95%99%E4%B8%A4%E5%90%8D%E6%97%A5%E6%9C%AC%E4%BA%BA%E4%B8%BA%E5%AF%8C%E5%A3%AB%E7%94%B5%E6%9C%BA%E8%81%8C%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782378641000.webp","sourceId":"rfi"},{"id":1782375481000,"createdDate":"2026-06-25 08:18","name":"法国国际广播电台","title":"美国政府致函各州和企业：警惕中国施压，鼓励深化对台合作","content":"路透社报道，美国国务院、农业部和商务部近日联合致函美国各州及企业，称尽管中国在试图阻止与台湾的接触，并歪曲美国的对台政策，但鼓励其仍应进一步扩大与台湾的交流合作。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260625-%E7%BE%8E%E5%9B%BD%E6%94%BF%E5%BA%9C%E8%87%B4%E5%87%BD%E5%90%84%E5%B7%9E%E5%92%8C%E4%BC%81%E4%B8%9A-%E8%AD%A6%E6%83%95%E4%B8%AD%E5%9B%BD%E6%96%BD%E5%8E%8B%EF%BC%8C%E9%BC%93%E5%8A%B1%E6%B7%B1%E5%8C%96%E5%AF%B9%E5%8F%B0%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782375481000.webp","sourceId":"rfi"},{"id":1782370764000,"createdDate":"2026-06-25 06:59","name":"法国国际广播电台","title":"三月内两宗 港独立书店被指售煽动書遭逮捕 创办人加控洗黑钱 人权观察批荒谬","content":"香港警队国安人员再次行动，搜查为独立书店提供另类书展场地的「猎人书店」，并拘捕书店创办人黄文萱和另一名男子，指他们涉嫌违反国安法例下的新煽动罪，是国安警继3月下旬以同样罪名拘捕另一独立书店「一拳书馆」负责人之後的第二宗。国际人权组织「人权观察」批评当局的拘捕行动荒谬，而北京加强对香港的管控，亦令香港失去其开放性和包容。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260625-%E4%B8%89%E6%9C%88%E5%86%85%E4%B8%A4%E5%AE%97-%E6%B8%AF%E7%8B%AC%E7%AB%8B%E4%B9%A6%E5%BA%97%E8%A2%AB%E6%8C%87%E5%94%AE%E7%85%BD%E5%8A%A8%E6%9B%B8%E9%81%AD%E9%80%AE%E6%8D%95-%E5%88%9B%E5%8A%9E%E4%BA%BA%E5%8A%A0%E6%8E%A7%E6%B4%97%E9%BB%91%E9%92%B1-%E4%BA%BA%E6%9D%83%E8%A7%82%E5%AF%9F%E6%89%B9%E8%8D%92%E8%B0%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782370764000.webp","sourceId":"rfi"},{"id":1782370452000,"createdDate":"2026-06-25 06:54","name":"法国国际广播电台","title":"美国杯葛澳门APEC旅游部长级会议 以示对领事签证规定的不满","content":"澳门现正举行亚太经济合作会议(APEC)的旅游部长会议及相关工作组会议，商讨旅游永续发展和合作交流，有来自21个成员国逾二百名代表参加。不过，美国杯葛会议，拒绝派员出席，藉此表达对中方拒绝让领事馆官员赶赴澳门为美国有需要的公民提供领事服务的不满。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260625-%E7%BE%8E%E5%9B%BD%E6%9D%AF%E8%91%9B%E6%BE%B3%E9%97%A8apec%E6%97%85%E6%B8%B8%E9%83%A8%E9%95%BF%E7%BA%A7%E4%BC%9A%E8%AE%AE-%E4%BB%A5%E7%A4%BA%E5%AF%B9%E9%A2%86%E4%BA%8B%E7%AD%BE%E8%AF%81%E8%A7%84%E5%AE%9A%E7%9A%84%E4%B8%8D%E6%BB%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782370452000.webp","sourceId":"rfi"},{"id":1782403664000,"createdDate":"2026-06-25 16:07","name":"法国国际广播电台","title":"中国多家国有银行涉逃税 官方审计报告结论","content":"法新社周三25日北京消息，一份官方审计报告显示，两家均跻身全球最大金融机构之列的中国国有银行通过违规手段逃避了数十亿元人民币的税款，并发放了非法贷款。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260625-%E4%B8%AD%E5%9B%BD%E5%A4%9A%E5%AE%B6%E5%9B%BD%E6%9C%89%E9%93%B6%E8%A1%8C%E6%B6%89%E9%80%83%E7%A8%8E-%E5%AE%98%E6%96%B9%E5%AE%A1%E8%AE%A1%E6%8A%A5%E5%91%8A%E7%BB%93%E8%AE%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782403664000.webp","sourceId":"rfi"},{"id":1782399655000,"createdDate":"2026-06-25 15:00","name":"法国国际广播电台","title":"中梵协议十问：一份秘密协议，如何搅动中国天主教会？","content":"大家好，欢迎收听中华世界专题节目，法国《十字架报》与《费加罗报》近期分别登出有关中国于梵蒂冈于2018年就主教任命问题签署的“秘密”协议的调查报道，以及对在中国秘密传道者的苦难的深入报道。这两篇报道共同的背景，是2026年4月人权观察发布的最新报告和5月24日“为中国受迫害基督徒祈祷日”。本期的中华世界，我们从这两篇报道取材，并以十问十答的方式介绍中国天主教界与教徒的真实情况。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%AD%E5%8D%8E%E4%B8%96%E7%95%8C/20260625-%E4%B8%AD%E6%A2%B5%E5%8D%8F%E8%AE%AE%E5%8D%81%E9%97%AE-%E4%B8%80%E4%BB%BD%E7%A7%98%E5%AF%86%E5%8D%8F%E8%AE%AE%EF%BC%8C%E5%A6%82%E4%BD%95%E6%90%85%E5%8A%A8%E4%B8%AD%E5%9B%BD%E5%A4%A9%E4%B8%BB%E6%95%99%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782399655000.webp","sourceId":"rfi"},{"id":1782398811000,"createdDate":"2026-06-25 14:46","name":"法国国际广播电台","title":"美国人工智能企业Anthropic指控阿里巴巴非法获取其Claude AI模型功能","content":"Anthropic指控阿里巴巴对其发起非法行动，在4月22日至6月5日通过近2.5万个欺诈账户与Claude进行了超过2880万次交互。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260625-%E7%BE%8E%E5%9B%BD%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E4%BC%81%E4%B8%9Aanthropic%E6%8C%87%E6%8E%A7%E9%98%BF%E9%87%8C%E5%B7%B4%E5%B7%B4%E9%9D%9E%E6%B3%95%E8%8E%B7%E5%8F%96%E5%85%B6claude-ai%E6%A8%A1%E5%9E%8B%E5%8A%9F%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782398811000.webp","sourceId":"rfi"},{"id":1782395910000,"createdDate":"2026-06-25 13:58","name":"法国国际广播电台","title":"卢比奥访巴林试图平息中东伙伴对美伊协议过于宽松的忧虑","content":"美国国务卿卢比奥周四在巴林首都麦纳麦与多位中东国家官员会晤，这是他此次“旨在推广特朗普政府与伊朗达成初步协议的最后一站行程，而海湾阿拉伯盟友对此协议持怀疑态度。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260625-%E5%8D%A2%E6%AF%94%E5%A5%A5%E8%AE%BF%E5%B7%B4%E6%9E%97%E8%AF%95%E5%9B%BE%E5%B9%B3%E6%81%AF%E4%B8%AD%E4%B8%9C%E4%BC%99%E4%BC%B4%E5%AF%B9%E7%BE%8E%E4%BC%8A%E5%8D%8F%E8%AE%AE%E8%BF%87%E4%BA%8E%E5%AE%BD%E6%9D%BE%E7%9A%84%E5%BF%A7%E8%99%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782395910000.webp","sourceId":"rfi"},{"id":1782395357000,"createdDate":"2026-06-25 13:49","name":"法国国际广播电台","title":"美参议院否决了遏制特朗普对伊朗战争的法案 特朗普赞这次投票向伊朗发出了警告！","content":"据美国justthenews网站报道，周三晚些时候，美国参议院否决了一项旨在遏制特朗普总统对伊朗开战的动议，这让总统取得了一场胜利。数小时之前，他与共和党参议员进行了一场激烈讨论最终演变成互相叫嚷的会议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260625-%E7%BE%8E%E5%8F%82%E8%AE%AE%E9%99%A2%E5%90%A6%E5%86%B3%E4%BA%86%E9%81%8F%E5%88%B6%E7%89%B9%E6%9C%97%E6%99%AE%E5%AF%B9%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E7%9A%84%E6%B3%95%E6%A1%88-%E7%89%B9%E6%9C%97%E6%99%AE%E8%B5%9E%E8%BF%99%E6%AC%A1%E6%8A%95%E7%A5%A8%E5%90%91%E4%BC%8A%E6%9C%97%E5%8F%91%E5%87%BA%E4%BA%86%E8%AD%A6%E5%91%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782395357000.webp","sourceId":"rfi"},{"id":1782395260000,"createdDate":"2026-06-25 13:47","name":"法国国际广播电台","title":"委内瑞拉遭遇百余年来最强地震 国际社会紧急驰援","content":"委内瑞拉周三（6月24日）遭遇两次7级以上强震，7.5级的主震为该国一百多年以来最强地震，重创该国。官方通报死亡人数目前已升至164人，971人受伤，委内瑞拉临时代总统罗德里格斯此前已宣布全国进入紧急状态，并向国际社会寻求援助。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260625-%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E9%81%AD%E9%81%87%E7%99%BE%E4%BD%99%E5%B9%B4%E6%9D%A5%E6%9C%80%E5%BC%BA%E5%9C%B0%E9%9C%87-%E5%9B%BD%E9%99%85%E7%A4%BE%E4%BC%9A%E7%B4%A7%E6%80%A5%E9%A9%B0%E6%8F%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782395260000.webp","sourceId":"rfi"},{"id":1782389973000,"createdDate":"2026-06-25 12:19","name":"法国国际广播电台","title":"委内瑞拉地震：瑞士80名救援者 8只搜救犬 18吨物资整装待发","content":"瑞士外交部周四宣布，在委内瑞拉遭遇造成人员伤亡的强烈双重地震后，已有80名救援人员和18吨救援物资准备好随时部署至该国。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260625-%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E5%9C%B0%E9%9C%87-%E7%91%9E%E5%A3%AB80%E5%90%8D%E6%95%91%E6%8F%B4%E8%80%85-8%E5%8F%AA%E6%90%9C%E6%95%91%E7%8A%AC-18%E5%90%A8%E7%89%A9%E8%B5%84%E6%95%B4%E8%A3%85%E5%BE%85%E5%8F%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782389973000.webp","sourceId":"rfi"},{"id":1782388304000,"createdDate":"2026-06-25 11:51","name":"法国国际广播电台","title":"委内瑞拉连发强震已知164人遇难 近1000人受伤","content":"一场百年未遇的强震接连在委内瑞拉发生，造成至少164人死亡，数十栋建筑倒塌。法新社记者周四在现场目睹了惨烈的破坏景象，这令人担忧死亡人数可能会远高于此。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260625-%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E8%BF%9E%E5%8F%91%E5%BC%BA%E9%9C%87%E5%B7%B2%E7%9F%A5164%E4%BA%BA%E9%81%87%E9%9A%BE-%E8%BF%911000%E4%BA%BA%E5%8F%97%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782388304000.webp","sourceId":"rfi"},{"id":1782385067000,"createdDate":"2026-06-25 10:57","name":"法国国际广播电台","title":"埃博拉:当前应对关键是接触者","content":"为了应对埃博拉（Ebola）病毒，非洲疾病预防控制中心（AfricaCDC）表示，急需14亿美元。刚果（金）当局希望邻国乌干达重新开放两国边境。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260625-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%9F%83%E5%8D%9A%E6%8B%89-%E5%BD%93%E5%89%8D%E5%BA%94%E5%AF%B9%E5%85%B3%E9%94%AE%E6%98%AF%E6%8E%A5%E8%A7%A6%E8%80%85","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782385067000.webp","sourceId":"rfi"},{"id":1782431279000,"createdDate":"2026-06-25 23:47","name":"法国国际广播电台","title":"热浪滚滚，法国政府将医疗应急机制提升至最高级别","content":"面对持续不断、强度空前的热浪，法国总理塞勒科尔尼周四在社交平台X上宣布，将“法国卫生应急计划Orsan”提升至三级，即最高级别。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260625-%E7%83%AD%E6%B5%AA%E6%BB%9A%E6%BB%9A%EF%BC%8C%E6%B3%95%E5%9B%BD%E6%94%BF%E5%BA%9C%E5%B0%86%E5%8C%BB%E7%96%97%E5%BA%94%E6%80%A5%E6%9C%BA%E5%88%B6%E6%8F%90%E5%8D%87%E8%87%B3%E6%9C%80%E9%AB%98%E7%BA%A7%E5%88%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782431279000.webp","sourceId":"rfi"},{"id":1782431057000,"createdDate":"2026-06-25 23:44","name":"法国国际广播电台","title":"中国再加强稀土管制，中日及中美紧张关系加剧","content":"法国世界报周四关注中国近期进一步加强对稀土及相关产品的出口管制，并以涉嫌非法出口稀土相关物资为理由拘留两名日本公民。据报道，这两名日本人就职于一家大型日本机械制造企业，今年5月在中国东北地区被逮捕。6月24日，中日两国政府先后证实了这一事件。这一事件再次加剧了中国与日本、以及中国与美国之间围绕稀土问题的紧张关系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260625-%E4%B8%AD%E5%9B%BD%E5%86%8D%E5%8A%A0%E5%BC%BA%E7%A8%80%E5%9C%9F%E7%AE%A1%E5%88%B6%EF%BC%8C%E4%B8%AD%E6%97%A5%E5%8F%8A%E4%B8%AD%E7%BE%8E%E7%B4%A7%E5%BC%A0%E5%85%B3%E7%B3%BB%E5%8A%A0%E5%89%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782431057000.webp","sourceId":"rfi"},{"id":1782427365000,"createdDate":"2026-06-25 22:42","name":"法国国际广播电台","title":"彼此需要：与特朗普公开争执后不久，意大利总理梅洛尼到法国与马克龙举行峰会","content":"意大利总理梅洛尼星期四与法国总统马克龙举行峰会，目的是巩固双方刚刚起步的和解姿态并加强联系。法国总统府表示，这次峰会将是一个深化国防、核能和航天等战略领域合作的契机。梅洛尼最近才与美国总统特朗普发生公开争执。现在她和马克龙的关系升温尤其引人注目。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260625-%E5%BD%BC%E6%AD%A4%E9%9C%80%E8%A6%81-%E4%B8%8E%E7%89%B9%E6%9C%97%E6%99%AE%E5%85%AC%E5%BC%80%E4%BA%89%E6%89%A7%E5%90%8E%E4%B8%8D%E4%B9%85%EF%BC%8C%E6%84%8F%E5%A4%A7%E5%88%A9%E6%80%BB%E7%90%86%E6%A2%85%E6%B4%9B%E5%B0%BC%E5%88%B0%E6%B3%95%E5%9B%BD%E4%B8%8E%E9%A9%AC%E5%85%8B%E9%BE%99%E4%B8%BE%E8%A1%8C%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782427365000.webp","sourceId":"rfi"},{"id":1782424016000,"createdDate":"2026-06-25 21:46","name":"法国国际广播电台","title":"中国呼吁奥地利发挥建设性作用 推动改善中欧关系","content":"在中欧因贸易、市场准入及俄罗斯问题关系趋紧之际，中国外长王毅周四（6月25日）在北京会见到访的奥地利外交部长赖辛格（BeateMeinl-Reisinger）时表示，中奥双方应相互尊重彼此核心利益，并共同推动中欧关系改善，希望奥地利继续为中欧关系发展发挥建设性作用。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260625-%E4%B8%AD%E5%9B%BD%E5%91%BC%E5%90%81%E5%A5%A5%E5%9C%B0%E5%88%A9%E5%8F%91%E6%8C%A5%E5%BB%BA%E8%AE%BE%E6%80%A7%E4%BD%9C%E7%94%A8-%E6%8E%A8%E5%8A%A8%E4%B8%AD%E6%AC%A7%E5%85%B3%E7%B3%BB%E6%94%B9%E5%96%84","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782424016000.webp","sourceId":"rfi"},{"id":1782423750000,"createdDate":"2026-06-25 21:42","name":"法国国际广播电台","title":"法国财政部暂停测试阿里AI模型 涉“中国倾向”引起争议","content":"法国经济与财政部（Bercy）周四（6月25日）向法新社证实，由中国互联网巨头阿里巴巴旗下人工智能模型Qwen（通义千问）支持、近期在法国财政部部分官员中试用的一款人工智能系统，因被发现部分涉及中国议题的回答存在“亲中倾向”而被停止使用，并已更换为法国人工智能初创企业MistralAI开发的模型。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260625-%E6%B3%95%E5%9B%BD%E8%B4%A2%E6%94%BF%E9%83%A8%E6%9A%82%E5%81%9C%E6%B5%8B%E8%AF%95%E9%98%BF%E9%87%8Cai%E6%A8%A1%E5%9E%8B-%E6%B6%89-%E4%B8%AD%E5%9B%BD%E5%80%BE%E5%90%91-%E5%BC%95%E8%B5%B7%E4%BA%89%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782423750000.webp","sourceId":"rfi"},{"id":1782423565000,"createdDate":"2026-06-25 21:39","name":"法国国际广播电台","title":"委内瑞拉强震死亡人数升至188人 美国宣布提供1.5亿美元援助","content":"委内瑞拉强震死亡人数已升至188人，另有1520人受伤、157人失踪。搜救行动周四（25日）继续展开，救援人员和当地居民仍在倒塌建筑废墟中争分夺秒搜寻幸存者和失踪者。美国宣布向委内瑞拉地震灾区提供1.5亿美元援助。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260625-%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E5%BC%BA%E9%9C%87%E6%AD%BB%E4%BA%A1%E4%BA%BA%E6%95%B0%E5%8D%87%E8%87%B3188%E4%BA%BA-%E7%BE%8E%E5%9B%BD%E5%AE%A3%E5%B8%83%E6%8F%90%E4%BE%9B1-5%E4%BA%BF%E7%BE%8E%E5%85%83%E6%8F%B4%E5%8A%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782423565000.webp","sourceId":"rfi"},{"id":1782422595000,"createdDate":"2026-06-25 21:23","name":"法国国际广播电台","title":"法意峰会聚焦深化战略合作 马克龙与梅洛尼淡化分歧","content":"法国总统马克龙与意大利总理梅洛尼周四（25日）在法国南部昂蒂布举行两人就任以来首次法意峰会。双方淡化近年来的分歧和紧张关系，强调法意伙伴关系的重要性，并宣布将在防务、航天、能源等领域深化战略合作。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260625-%E6%B3%95%E6%84%8F%E5%B3%B0%E4%BC%9A%E8%81%9A%E7%84%A6%E6%B7%B1%E5%8C%96%E6%88%98%E7%95%A5%E5%90%88%E4%BD%9C-%E9%A9%AC%E5%85%8B%E9%BE%99%E4%B8%8E%E6%A2%85%E6%B4%9B%E5%B0%BC%E6%B7%A1%E5%8C%96%E5%88%86%E6%AD%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782422595000.webp","sourceId":"rfi"},{"id":1782421042000,"createdDate":"2026-06-25 20:57","name":"法国国际广播电台","title":"美民调：逾7成认留在北约攸关国安","content":"最新公布的两项全国性民调显示，尽管美国总统特朗普（DonaldTrump）近年持续批评北大西洋公约组织（NATO）盟友未能承担足够防务责任，甚至多次暗示美国可能重新评估与北约的关系，但多数美国民众仍支持留在北约，并认为该联盟对美国安全与繁荣具有重要意义。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260625-%E7%BE%8E%E6%B0%91%E8%B0%83-%E9%80%BE7%E6%88%90%E8%AE%A4%E7%95%99%E5%9C%A8%E5%8C%97%E7%BA%A6%E6%94%B8%E5%85%B3%E5%9B%BD%E5%AE%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782421042000.webp","sourceId":"rfi"},{"id":1782417895000,"createdDate":"2026-06-25 20:04","name":"法国国际广播电台","title":"法广[视频] - 埃博拉：当务之急是密切接触者","content":"埃博拉（Ebola）病毒：在接受本台法语[非洲大咖嘉宾]（GrandInvitéAfrique）专栏主持人克里斯托夫(ChristopheBOISBOUVIER)的专访中，[非盟]（UA）卫生机构[非洲疾控中心](AfricaCDC)主任Dr.JeanKaseya指出，当前的真正问题在于密切接触者；必须尽快查明这些人的身份。他表示，现在急需14亿美元，以应对这一病毒。LaRiposteàl'Ebola:Dr.JeanKaseya,DirecteurGénérald’AfricaCDC,GrandInvitéAfriquedeRFI;EnRDCongo,l'autoritéveutrassurerl’Ougandavoisinquelasituationestsouscontrôleetqu’ilfautrouvrirlesfrontières,rapportePascalM,notreenvoyéspécialàlafrontièreentrelesdeuxpays.","newsLink":"https://www.rfi.fr/cn/%E8%A7%86%E9%A2%91/20260625-%E6%B3%95%E5%B9%BF-%E8%A7%86%E9%A2%91-%E5%9F%83%E5%8D%9A%E6%8B%89-%E5%BD%93%E5%8A%A1%E4%B9%8B%E6%80%A5%E6%98%AF%E5%AF%86%E5%88%87%E6%8E%A5%E8%A7%A6%E8%80%85","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782417895000.webp","sourceId":"rfi"},{"id":1782410293000,"createdDate":"2026-06-25 17:58","name":"法国国际广播电台","title":"秘鲁总统大选：藤森惠子胜选似乎“不可逆转”面临一个两级分裂的国家","content":"随着计票工作接近尾声，秘鲁右翼总统候选人藤森惠子周三表示，鉴于她目前对左翼对手的领先优势，她的胜选似乎“不可逆转”。但她意识到需要团结一个两级分裂的国家。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260625-%E7%A7%98%E9%B2%81%E6%80%BB%E7%BB%9F%E5%A4%A7%E9%80%89-%E8%97%A4%E6%A3%AE%E6%83%A0%E5%AD%90%E8%83%9C%E9%80%89%E4%BC%BC%E4%B9%8E-%E4%B8%8D%E5%8F%AF%E9%80%86%E8%BD%AC-%E9%9D%A2%E4%B8%B4%E4%B8%80%E4%B8%AA%E4%B8%A4%E7%BA%A7%E5%88%86%E8%A3%82%E7%9A%84%E5%9B%BD%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782410293000.webp","sourceId":"rfi"},{"id":1782408535000,"createdDate":"2026-06-25 17:28","name":"法国国际广播电台","title":"源自非洲的巨大热气团在西欧上空盘踞不散：超1亿人周四经受35度以上高温","content":"据法新社测算，周四25日，至少1.01亿欧洲人，其中包括法国5000多万人和德国1800万人处在超过35°C的高温中，与此同时，西班牙和法国当局已开始统计此次极端热浪造成的死亡人数。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260625-%E6%BA%90%E8%87%AA%E9%9D%9E%E6%B4%B2%E7%9A%84%E5%B7%A8%E5%A4%A7%E7%83%AD%E6%B0%94%E5%9B%A2%E5%9C%A8%E8%A5%BF%E6%AC%A7%E4%B8%8A%E7%A9%BA%E7%9B%98%E8%B8%9E%E4%B8%8D%E6%95%A3-%E8%B6%851%E4%BA%BF%E4%BA%BA%E5%91%A8%E5%9B%9B%E7%BB%8F%E5%8F%9735%E5%BA%A6%E4%BB%A5%E4%B8%8A%E9%AB%98%E6%B8%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782408535000.webp","sourceId":"rfi"},{"id":1782407627000,"createdDate":"2026-06-25 17:13","name":"法国国际广播电台","title":"酷暑难耐：即使我没点任何东西，酒吧咖啡馆是否有法律义务给我一杯水？","content":"各位听众，酷暑难耐，即使我没点任何东西，酒吧是否有法律义务给我一杯水？ 人们普遍误以为酒吧和餐厅有义务向任何索要水的顾客免费提供饮用水。这是完全错误的。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260625-%E9%85%B7%E6%9A%91%E9%9A%BE%E8%80%90-%E5%8D%B3%E4%BD%BF%E6%88%91%E6%B2%A1%E7%82%B9%E4%BB%BB%E4%BD%95%E4%B8%9C%E8%A5%BF%EF%BC%8C%E9%85%92%E5%90%A7%E5%92%96%E5%95%A1%E9%A6%86%E6%98%AF%E5%90%A6%E6%9C%89%E6%B3%95%E5%BE%8B%E4%B9%89%E5%8A%A1%E7%BB%99%E6%88%91%E4%B8%80%E6%9D%AF%E6%B0%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/25/1782407627000.webp","sourceId":"rfi"}]