[{"id":1780997154000,"createdDate":"2026-06-09 09:25","name":"法国国际广播电台","title":"美议员促收紧对台积电等代工商监管 防止为中企海外子公司生产定制芯片","content":"周一，两位来自美国两党的联邦参议员敦促特朗普政府收紧对台积电等芯片代工制造商的监管，以防止它们为中国企业的海外子公司生产先进的人工智能芯片。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260609-%E7%BE%8E%E8%AE%AE%E5%91%98%E4%BF%83%E6%94%B6%E7%B4%A7%E5%AF%B9%E5%8F%B0%E7%A7%AF%E7%94%B5%E7%AD%89%E4%BB%A3%E5%B7%A5%E5%95%86%E7%9B%91%E7%AE%A1-%E9%98%B2%E6%AD%A2%E4%B8%BA%E4%B8%AD%E4%BC%81%E6%B5%B7%E5%A4%96%E5%AD%90%E5%85%AC%E5%8F%B8%E7%94%9F%E4%BA%A7%E5%AE%9A%E5%88%B6%E8%8A%AF%E7%89%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1780997154000.webp","sourceId":"rfi"},{"id":1780995691000,"createdDate":"2026-06-09 09:01","name":"法国国际广播电台","title":"菲武装部队总参谋长证实黄岩岛发现载人漂浮结构 菲外交部向北京采取外交行动","content":"菲律宾西菲律宾海国家工作组（NTF-WPS、以下简称工作组）周二表示，菲外交部已就中国在争议环礁“非法存在”一处漂浮结构一事，对中方采取了适当的外交行动。工作组证实，在南中国海争议海域斯卡伯勒浅滩（中方称黄岩岛）附近发现了一处长6米、宽6米的漂浮结构，该结构上似乎装有天线。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260609-%E8%8F%B2%E6%AD%A6%E8%A3%85%E9%83%A8%E9%98%9F%E6%80%BB%E5%8F%82%E8%B0%8B%E9%95%BF%E8%AF%81%E5%AE%9E%E9%BB%84%E5%B2%A9%E5%B2%9B%E5%8F%91%E7%8E%B0%E8%BD%BD%E4%BA%BA%E6%BC%82%E6%B5%AE%E7%BB%93%E6%9E%84-%E8%8F%B2%E5%A4%96%E4%BA%A4%E9%83%A8%E5%90%91%E5%8C%97%E4%BA%AC%E9%87%87%E5%8F%96%E5%A4%96%E4%BA%A4%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1780995691000.webp","sourceId":"rfi"},{"id":1780993673000,"createdDate":"2026-06-09 08:27","name":"法国国际广播电台","title":"五角大楼扩充“黑名单”：阿里巴巴、百度与比亚迪及其他科技巨头都在协助中国军方","content":"据路透社报道，美国周一将中国电子商务巨头阿里巴巴、互联网搜索服务商百度以及汽车制造商比亚迪和蔚来列入了一份美国认为正在协助中国军方的企业名单。此举可能会加剧两国之间的紧张关系。随后，中国驻华盛顿大使馆表示，北京反对“搞歧视性清单来针对中国企业”，并指出其企业遵守当地法律法规。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260609-%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC%E6%89%A9%E5%85%85-%E9%BB%91%E5%90%8D%E5%8D%95-%E9%98%BF%E9%87%8C%E5%B7%B4%E5%B7%B4-%E7%99%BE%E5%BA%A6%E4%B8%8E%E6%AF%94%E4%BA%9A%E8%BF%AA%E5%8F%8A%E5%85%B6%E4%BB%96%E7%A7%91%E6%8A%80%E5%B7%A8%E5%A4%B4%E9%83%BD%E5%9C%A8%E5%8D%8F%E5%8A%A9%E4%B8%AD%E5%9B%BD%E5%86%9B%E6%96%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1780993673000.webp","sourceId":"rfi"},{"id":1780993185000,"createdDate":"2026-06-09 08:19","name":"法国国际广播电台","title":"郑丽文访美和平论述升级 更称若特朗普能化战争为和平将为21世纪最伟大领导人","content":"台湾国民党主席郑丽文访美并表示，此行要让美国理解国民党的重要战略角色。她不仅倡议东亚和平繁荣之链，更不断地深化国民党的两岸和平繁荣论述。而此论述正在接受美国政策圈的正式检验。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260609-%E9%83%91%E4%B8%BD%E6%96%87%E8%AE%BF%E7%BE%8E%E5%92%8C%E5%B9%B3%E8%AE%BA%E8%BF%B0%E5%8D%87%E7%BA%A7-%E6%9B%B4%E7%A7%B0%E8%8B%A5%E7%89%B9%E6%9C%97%E6%99%AE%E8%83%BD%E5%8C%96%E6%88%98%E4%BA%89%E4%B8%BA%E5%92%8C%E5%B9%B3%E5%B0%86%E4%B8%BA21%E4%B8%96%E7%BA%AA%E6%9C%80%E4%BC%9F%E5%A4%A7%E9%A2%86%E5%AF%BC%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1780993185000.webp","sourceId":"rfi"},{"id":1780992679000,"createdDate":"2026-06-09 08:11","name":"法国国际广播电台","title":"对抗日菲海洋划界 中国海警船进入日本专属经济区","content":"据日本海上保安厅等方面的消息，中国海警局船只于6月3日至8日在日本与那国岛以南海域等日本专属经济区（EEZ）内航行，8日当天也有两艘中国海警局船只在日本专属经济区周边航行，面对日本海上保安厅的喊话警告，这些船只回应称“这里属于中国的管辖海域，我们在正常巡逻”，日方认为，这是中国海警局船只首次在该海域主张拥有管辖权，日本海上保安厅正在持续加强警戒和监视，舆论认为这是针对日本与菲律宾5月28日决定启动正式谈判，以划定海洋边界的系列对抗措施中的一环。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260609-%E5%AF%B9%E6%8A%97%E6%97%A5%E8%8F%B2%E6%B5%B7%E6%B4%8B%E5%88%92%E7%95%8C-%E4%B8%AD%E5%9B%BD%E6%B5%B7%E8%AD%A6%E8%88%B9%E8%BF%9B%E5%85%A5%E6%97%A5%E6%9C%AC%E4%B8%93%E5%B1%9E%E7%BB%8F%E6%B5%8E%E5%8C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1780992679000.webp","sourceId":"rfi"},{"id":1780992228000,"createdDate":"2026-06-09 08:03","name":"法国国际广播电台","title":"一纸证明可将普通罪行变国安案处理 特首称会审慎 惟评论以过往签发个案提质疑","content":"香港特首李家超表示，就港府制订国家安全附属法例，赋权他发出证明书便可把某宗涉及国安的刑事案以国安类罪案件处理，目的是把现行法律清晰化，而他亦有较多不便公开的情报应对通常涉及「国家级高手」的危害国安图谋，并强调会审慎行事。不过，不少评论以特首过去发出国安证明书的案例对他的解说提出质疑。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260609-%E4%B8%80%E7%BA%B8%E8%AF%81%E6%98%8E%E5%8F%AF%E5%B0%86%E6%99%AE%E9%80%9A%E7%BD%AA%E8%A1%8C%E5%8F%98%E5%9B%BD%E5%AE%89%E6%A1%88%E5%A4%84%E7%90%86-%E7%89%B9%E9%A6%96%E7%A7%B0%E4%BC%9A%E5%AE%A1%E6%85%8E-%E6%83%9F%E8%AF%84%E8%AE%BA%E4%BB%A5%E8%BF%87%E5%BE%80%E7%AD%BE%E5%8F%91%E4%B8%AA%E6%A1%88%E6%8F%90%E8%B4%A8%E7%96%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1780992228000.webp","sourceId":"rfi"},{"id":1781023392000,"createdDate":"2026-06-09 16:43","name":"法国国际广播电台","title":"中国联通：美拟对中国电信采取的行动将会扰乱全球通信","content":"中国联通美国子公司6月9日警告称，特朗普政府一项禁止中国三大运营商的提案可能会严重扰乱全球通信网络。中国联通在提交给美国联邦通信委员会（FCC）的文件中指出，该提案“将损害在美国拥有重大商业利益和供应链的美国公司”。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260609-%E4%B8%AD%E5%9B%BD%E8%81%94%E9%80%9A-%E7%BE%8E%E6%8B%9F%E5%AF%B9%E4%B8%AD%E5%9B%BD%E7%94%B5%E4%BF%A1%E9%87%87%E5%8F%96%E7%9A%84%E8%A1%8C%E5%8A%A8%E5%B0%86%E4%BC%9A%E6%89%B0%E4%B9%B1%E5%85%A8%E7%90%83%E9%80%9A%E4%BF%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781023392000.webp","sourceId":"rfi"},{"id":1781020651000,"createdDate":"2026-06-09 15:57","name":"法国国际广播电台","title":"比利时首相谈欧盟峰会议题回避点名中国：我们太害怕了，甚至不敢这么做","content":"比利时首相德韦弗（BartDeWever）警告称，欧洲领导人对中国的警惕日益增强，必须紧急制定切实有效的战略，以抵御北京的经济主导企图。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260609-%E6%AF%94%E5%88%A9%E6%97%B6%E9%A6%96%E7%9B%B8%E8%B0%88%E6%AC%A7%E7%9B%9F%E5%B3%B0%E4%BC%9A%E8%AE%AE%E9%A2%98%E5%9B%9E%E9%81%BF%E7%82%B9%E5%90%8D%E4%B8%AD%E5%9B%BD-%E6%88%91%E4%BB%AC%E5%A4%AA%E5%AE%B3%E6%80%95%E4%BA%86%EF%BC%8C%E7%94%9A%E8%87%B3%E4%B8%8D%E6%95%A2%E8%BF%99%E4%B9%88%E5%81%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781020651000.webp","sourceId":"rfi"},{"id":1781018451000,"createdDate":"2026-06-09 15:20","name":"法国国际广播电台","title":"遏制中国在欧盟港口日益增长的影响力计划初见雏形","content":"欧洲新闻台看到的一份文件草案显示，欧盟成员国的交通部长们正在为该集团制定指导方针，指导如何评估外国对欧盟港口的投资，并采取管控措施，应对中国影响力在该领域的扩大。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260609-%E9%81%8F%E5%88%B6%E4%B8%AD%E5%9B%BD%E5%9C%A8%E6%AC%A7%E7%9B%9F%E6%B8%AF%E5%8F%A3%E6%97%A5%E7%9B%8A%E5%A2%9E%E9%95%BF%E7%9A%84%E5%BD%B1%E5%93%8D%E5%8A%9B%E8%AE%A1%E5%88%92%E5%88%9D%E8%A7%81%E9%9B%8F%E5%BD%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781018451000.webp","sourceId":"rfi"},{"id":1781016915000,"createdDate":"2026-06-09 14:55","name":"法国国际广播电台","title":"【视频】台湾在沿海演习中模拟摧毁入侵的中国军队","content":"台湾军方周二（6月9日）在沿海地区举行演习，模拟摧毁入侵的中国军队，发射火箭弹和大炮阻止两栖登陆作战。军方称此次演习模拟了更真实的战斗场景，准备时间更短。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260609-%E8%A7%86%E9%A2%91-%E5%8F%B0%E6%B9%BE%E5%9C%A8%E6%B2%BF%E6%B5%B7%E6%BC%94%E4%B9%A0%E4%B8%AD%E6%A8%A1%E6%8B%9F%E6%91%A7%E6%AF%81%E5%85%A5%E4%BE%B5%E7%9A%84%E4%B8%AD%E5%9B%BD%E5%86%9B%E9%98%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781016915000.webp","sourceId":"rfi"},{"id":1781016363000,"createdDate":"2026-06-09 14:46","name":"法国国际广播电台","title":"英内政部、住房部办公楼天花板发现隐藏摄像头引发安全担忧","content":"英国政府的一栋大楼的天花板面板中发现了一个隐藏摄像头。该电子设备是由在伦敦维多利亚区马沙姆街办公楼工作的安保人员发现的。马沙姆街有一栋大型办公楼，英国内政部和住房、社区和地方政府部均位于该大楼内。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260609-%E8%8B%B1%E5%86%85%E6%94%BF%E9%83%A8%E5%85%B1%E4%BA%AB%E5%8A%9E%E5%85%AC%E6%A5%BC%E5%A4%A9%E8%8A%B1%E6%9D%BF%E5%8F%91%E7%8E%B0%E9%9A%90%E8%97%8F%E6%91%84%E5%83%8F%E5%A4%B4%E5%BC%95%E5%8F%91%E5%AE%89%E5%85%A8%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781016363000.webp","sourceId":"rfi"},{"id":1781015808000,"createdDate":"2026-06-09 14:36","name":"法国国际广播电台","title":"习近平访问朝鲜体现了中国的影响力，但缺乏实质内容？","content":"中国国家主席习近平与朝鲜领导人金正恩的峰会凸显了北京和平壤之间日益深化的政治和象征性联盟，但分析人士警告称，尽管双方宣布双边关系处于“新的历史起点”，但实际进展恐仍然难以实现。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260609-%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%BF%E9%97%AE%E6%9C%9D%E9%B2%9C%E4%BD%93%E7%8E%B0%E4%BA%86%E4%B8%AD%E5%9B%BD%E7%9A%84%E5%BD%B1%E5%93%8D%E5%8A%9B%EF%BC%8C%E4%BD%86%E7%BC%BA%E4%B9%8F%E5%AE%9E%E8%B4%A8%E5%86%85%E5%AE%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781015808000.webp","sourceId":"rfi"},{"id":1781014029000,"createdDate":"2026-06-09 14:07","name":"法国国际广播电台","title":"郑旭光谈八九六四：“挖掘真历史，才能总结真经验”","content":"本次“六四”三十七周年特别节目，要专访的是目前居住在美国的郑旭光先生。他在八九民运期间参与发起北航学生自治会，并任“北高联”的常委，曾参与89年5月14号的对话，以及5月18号与李鹏的会面。在六四之后，他也名列当局全国通缉的二十一名学生领袖的名单上，1989年7月遭到逮捕，91年被判刑2年。对郑旭光而言，还原历史真相就是纪念六四的重要组成部分。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%89%B9%E5%88%AB%E8%8A%82%E7%9B%AE/20260609-%E9%83%91%E6%97%AD%E5%85%89%E8%B0%88%E5%85%AB%E4%B9%9D%E5%85%AD%E5%9B%9B-%E6%8C%96%E6%8E%98%E7%9C%9F%E5%8E%86%E5%8F%B2%EF%BC%8C%E6%89%8D%E8%83%BD%E6%80%BB%E7%BB%93%E7%9C%9F%E7%BB%8F%E9%AA%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781014029000.webp","sourceId":"rfi"},{"id":1781012625000,"createdDate":"2026-06-09 13:43","name":"法国国际广播电台","title":"偷盗普希金珍版图书的格鲁吉亚团伙在巴黎受审，法国法官认为盗窃与俄罗斯想追回文化遗产有关","content":"七名格鲁吉亚公民将于今天起在巴黎受审，他们被控从法国著名图书馆盗窃俄罗斯文学经典珍稀版本，其中包括普希金的作品。近年来，欧洲各地图书馆发生多起类似盗窃案，人们怀疑这些案件出自一个有组织的犯罪团伙之手。今天在巴黎的审判是其中最新的一起案件。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260609-%E5%81%B7%E7%9B%97%E6%99%AE%E5%B8%8C%E9%87%91%E7%8F%8D%E7%89%88%E5%9B%BE%E4%B9%A6%E7%9A%84%E6%A0%BC%E9%B2%81%E5%90%89%E4%BA%9A%E5%9B%A2%E4%BC%99%E5%9C%A8%E5%B7%B4%E9%BB%8E%E5%8F%97%E5%AE%A1%EF%BC%8C%E6%B3%95%E5%9B%BD%E6%B3%95%E5%AE%98%E8%AE%A4%E4%B8%BA%E7%9B%97%E7%AA%83%E4%B8%8E%E4%BF%84%E7%BD%97%E6%96%AF%E6%83%B3%E8%BF%BD%E5%9B%9E%E6%96%87%E5%8C%96%E9%81%97%E4%BA%A7%E6%9C%89%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781012625000.webp","sourceId":"rfi"},{"id":1781009198000,"createdDate":"2026-06-09 12:46","name":"法国国际广播电台","title":"德国《商报》看中国：欧洲汽车工业可能正在亲手培养自己最强大的竞争对手","content":"德国经济部长赖歇五月底访华时，让人们看到了德国经济对中国的很大依赖。中国使用了什么策略，让自己日益强大？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9F%8F%E6%9E%97%E9%A3%9E%E9%B8%BF/20260609-%E5%BE%B7%E5%9B%BD-%E5%95%86%E6%8A%A5-%E7%9C%8B%E4%B8%AD%E5%9B%BD-%E6%AC%A7%E6%B4%B2%E6%B1%BD%E8%BD%A6%E5%B7%A5%E4%B8%9A%E5%8F%AF%E8%83%BD%E6%AD%A3%E5%9C%A8%E4%BA%B2%E6%89%8B%E5%9F%B9%E5%85%BB%E8%87%AA%E5%B7%B1%E6%9C%80%E5%BC%BA%E5%A4%A7%E7%9A%84%E7%AB%9E%E4%BA%89%E5%AF%B9%E6%89%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781009198000.webp","sourceId":"rfi"},{"id":1781006102000,"createdDate":"2026-06-09 11:55","name":"法国国际广播电台","title":"【视频】中朝关系，北京市民如何看？","content":"中国国家主席习近平6月9日访问朝鲜，与朝鲜最高领导人金正恩举行会谈。这是习近平时隔七年再次访问朝鲜，正值双方签署《中朝友好合作互助条约》65周年。中国普通民众对中朝关系怎么看？路透社在北京采访了两位市民。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260609-%E8%A7%86%E9%A2%91-%E4%B8%AD%E6%9C%9D%E5%85%B3%E7%B3%BB%EF%BC%8C%E5%8C%97%E4%BA%AC%E5%B8%82%E6%B0%91%E5%A6%82%E4%BD%95%E7%9C%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781006102000.webp","sourceId":"rfi"},{"id":1781005551000,"createdDate":"2026-06-09 11:45","name":"法国国际广播电台","title":"台湾据报正考虑加强对销陆人工智能芯片出口限制","content":"据彭博社援引知情人士报导称，台湾当局正考虑对向中国大陆销售人工智能芯片实施更为严格的出口管制，以进一步与美国措施看起。此举旨在打击半导体走私，但可能招致北京方面的谴责报复。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260609-%E5%8F%B0%E6%B9%BE%E6%8D%AE%E6%8A%A5%E6%AD%A3%E8%80%83%E8%99%91%E5%8A%A0%E5%BC%BA%E5%AF%B9%E9%94%80%E9%99%86%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E8%8A%AF%E7%89%87%E5%87%BA%E5%8F%A3%E9%99%90%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781005551000.webp","sourceId":"rfi"},{"id":1781001970000,"createdDate":"2026-06-09 10:46","name":"法国国际广播电台","title":"习近平访朝成果如何？对金正恩又有何意义？法新社怎么说...","content":"中国国家主席习近平周一至周二对朝鲜进行罕见访问，与金正恩共同瞄准中朝关系“新高度”，却避谈核问题，而且是在朝俄关系升温的背景下展开。习近平与金正恩的上一次会面是去年秋天在北京举行的一场阅兵式上，这次是习近平自2019年以来首次访问朝鲜，而金正恩的国际地位近年来已显著提升。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260609-%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%BF%E6%9C%9D%E6%88%90%E6%9E%9C%E5%A6%82%E4%BD%95-%E5%AF%B9%E9%87%91%E6%AD%A3%E6%81%A9%E5%8F%88%E6%9C%89%E4%BD%95%E6%84%8F%E4%B9%89-%E6%B3%95%E6%96%B0%E7%A4%BE%E6%80%8E%E4%B9%88%E8%AF%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781001970000.webp","sourceId":"rfi"},{"id":1781000982000,"createdDate":"2026-06-09 10:29","name":"法国国际广播电台","title":"印度贯通喜马拉雅佐吉拉隧道 接近全天候直通中印边境","content":"周二，印度工程师成功贯通了穿越喜马拉雅山脉的战略要道佐吉拉隧道（Zojilatunnel）的最后一段岩石，这是实现全天候通行进入中印边境拉达克地区的一个里程碑。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260609-%E5%8D%B0%E5%BA%A6%E7%AA%81%E7%A0%B4%E5%96%9C%E9%A9%AC%E6%8B%89%E9%9B%85%E4%BD%90%E5%90%89%E6%8B%89%E9%9A%A7%E9%81%93-%E6%8E%A5%E8%BF%91%E5%85%A8%E5%A4%A9%E5%80%99%E7%9B%B4%E9%80%9A%E4%B8%AD%E5%8D%B0%E8%BE%B9%E5%A2%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781000982000.webp","sourceId":"rfi"},{"id":1781000939000,"createdDate":"2026-06-09 10:28","name":"法国国际广播电台","title":"金氏王朝划出红线：拥核不可逆，北京别插手","content":"今日出刊的费加罗报国际版大篇幅聚焦了郑丽文访问美国，以及习近平访问朝鲜。当中指出，习近平开始了其七年来对朝鲜的首次访问，他面对的是一位决心以“指数级”方式强化朝鲜武器库的最高领导人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260609-%E9%87%91%E6%B0%8F%E7%8E%8B%E6%9C%9D%E5%88%92%E5%87%BA%E7%BA%A2%E7%BA%BF-%E6%8B%A5%E6%A0%B8%E4%B8%8D%E5%8F%AF%E9%80%86%E8%BD%AC%EF%BC%8C%E5%8C%97%E4%BA%AC%E5%88%AB%E6%8F%92%E6%89%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781000939000.webp","sourceId":"rfi"},{"id":1781000399000,"createdDate":"2026-06-09 10:19","name":"法国国际广播电台","title":"应对中国 法国工业部长呼吁加快保护欧洲企业","content":"法国工业部长塞巴斯蒂安·马丁今天周二表示，欧洲在保护本土产业免受中国等国不公平竞争方面“行动迟缓”，并呼吁布鲁塞尔为此投入更多资源。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260609-%E6%B3%95%E5%9B%BD%E5%91%BC%E5%90%81%E5%8A%A0%E5%BF%AB%E4%BF%9D%E6%8A%A4%E6%AC%A7%E6%B4%B2%E5%B7%A5%E4%B8%9A%E5%85%8D%E5%8F%97%E4%B8%AD%E5%9B%BD%E4%BE%B5%E5%AE%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1781000399000.webp","sourceId":"rfi"},{"id":1780999208000,"createdDate":"2026-06-09 10:00","name":"法国国际广播电台","title":"当热浪来袭：女性主义视角下的气候危机","content":"2026年5月，法国遭遇异常早到且强度创纪录的热浪。与此同时，联合国与气象机构警告，厄尔尼诺现象可能在今年再次出现，使全球极端天气风险进一步上升。在这一背景下，本期特别节目聚焦一个问题：气候变化如何影响女性的日常生活与风险暴露。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%85%AC%E6%B0%91%E8%AE%BA%E5%9D%9B/20260609-%E5%BD%93%E7%83%AD%E6%B5%AA%E6%9D%A5%E8%A2%AD-%E5%A5%B3%E6%80%A7%E4%B8%BB%E4%B9%89%E8%A7%86%E8%A7%92%E4%B8%8B%E7%9A%84%E6%B0%94%E5%80%99%E5%8D%B1%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1780999208000.webp","sourceId":"rfi"},{"id":1780998896000,"createdDate":"2026-06-09 09:54","name":"法国国际广播电台","title":"马克龙周四将主持七国集团与中国的视频通话 在G7峰会前探讨全球贸易失衡","content":"据政客新闻网欧洲版援引四位熟悉会议筹备工作的来自七国集团（G7）三个成员国的官员报导称，法国总统马克龙将主持七国集团与中国之间的一次视频通话，以讨论全球贸易失衡问题。其中两位官员表示，通话将于本周四举行，在下周将于埃维昂莱班湖畔度假胜地举行的七国集团峰会前。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260609-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%91%A8%E5%9B%9B%E5%B0%86%E4%B8%BB%E6%8C%81%E4%B8%83%E5%9B%BD%E9%9B%86%E5%9B%A2%E4%B8%8E%E4%B8%AD%E5%9B%BD%E7%9A%84%E8%A7%86%E9%A2%91%E9%80%9A%E8%AF%9D-%E5%9C%A8g7%E5%B3%B0%E4%BC%9A%E5%89%8D%E6%8E%A2%E8%AE%A8%E5%85%A8%E7%90%83%E8%B4%B8%E6%98%93%E5%A4%B1%E8%A1%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/09/1780998896000.webp","sourceId":"rfi"}]