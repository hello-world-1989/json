[{"id":1781020441000,"createdDate":"2026-06-09 15:54","name":"美国之音","title":"美国陆军直升机在霍尔木兹海峡附近坠毁，两名飞行员获救，坠机原因不明","content":"美国军方说，一架美国陆军“阿帕奇”攻击直升机星期二(6月9日)凌晨在具有战略意义的霍尔木兹海峡附近坠毁，机上两名机组人员已被美军救起。","newsLink":"https://www.voachinese.com/a/two-pilots-rescued-after-us-army-helicopter-crashes-near-hormuz-strait-under-unspecified-circumstances-20260609/8158935.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/09/1781020441000.webp","sourceId":"voa"},{"id":1781048970000,"createdDate":"2026-06-09 23:49","name":"美国之音","title":" 美国植物园“尸花”盛开 吸引数千游客 ","content":"上星期，数千名游客涌入华盛顿的美国植物园，只为一睹两株巨花魔芋，也就是俗称的尸花，同时盛开的罕见景象。这种难得一见的植物以及它臭名昭著的气味，每三到五年才开花一次，而且每次花期只有两到三天。","newsLink":"https://www.voachinese.com/a/blooming-corpse-flowers-attract-thousands-at-us-botanic-garden-20260609/8159058.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/09/1781048970000.webp","sourceId":"voa"},{"id":1781041643000,"createdDate":"2026-06-09 21:47","name":"美国之音","title":"快讯：美国对伊朗发动“自卫”打击","content":"美军表示，已依据唐纳德·特朗普(DonaldTrump)总统指示，开始对伊朗发动“自卫”打击。","newsLink":"https://www.voachinese.com/a/us-military-says-it-began-launching-self-defense-strikes-against-iran-20260609/8159043.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/09/1781041643000.webp","sourceId":"voa"},{"id":1781034401000,"createdDate":"2026-06-09 19:46","name":"美国之音","title":"美国众议院通过关键矿产法案 强化盟友合作抗衡中国稀土主导地位","content":"美国国会众议院通过一项法案，旨在推动行政部门加强全球关键矿产供应链建设，提升美国能源安全，并积极应对北京在全球稀土开采和加工领域的主导地位。","newsLink":"https://www.voachinese.com/a/house-passes-critical-minerals-bill-to-bolster-alliances-and-reduce-reliance-on-china-20260609/8159024.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/09/1781034401000.webp","sourceId":"voa"},{"id":1781032263000,"createdDate":"2026-06-09 19:11","name":"美国之音","title":"台湾实施摧毁中国入侵部队的反登陆重炮实弹演习","content":"台湾陆军星期二(6月9日)起在台湾中部实施对抗中国可能入侵的反登陆实弹演习，在“作战地境内”演练重炮及新式武器联合攻击火力，验证阻止和压制敌军两栖登陆的训练成效。","newsLink":"https://www.voachinese.com/a/taiwan-simulates-destroying-an-invading-chinese-force-in-coastal-drill-20260609/8159012.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/09/1781032263000.webp","sourceId":"voa"},{"id":1781031434000,"createdDate":"2026-06-09 18:57","name":"美国之音","title":"特朗普总统说伊朗在霍尔木兹海峡上空击落美军直升机，誓言美国将作出回应","content":"唐纳德·特朗普(DonaldTrump)总统说，伊朗政权是星期二(6月9日)凌晨一架美国陆军直升机在霍尔木兹海峡上空巡逻时被击落的幕后黑手，并誓言美国将作出回应。","newsLink":"https://www.voachinese.com/a/president-trump-says-iran-shot-down-us-army-helicopter-over-strait-of-hormuz-vows-us-response-20260609/8159010.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/09/1781031434000.webp","sourceId":"voa"}]