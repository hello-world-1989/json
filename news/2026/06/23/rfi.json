[{"id":1782204634000,"createdDate":"2026-06-23 08:50","name":"法国国际广播电台","title":"欧盟加强在港经贸活动 传经贸部主管一职丢空两年後将有人填补","content":"在香港与欧盟关系渐趋稳定的情况下，欧盟驻香港及澳门办事处加强在港的经贸推广活动，今(23日)早便在香港合办一个可持续发展论坛，办事处主任卢效伟(HarveyRouse)致辞时鼓励欧洲企业乘北部都会区发展之利，在可持续城市规划丶智能基础设施及能源效率等方面提供专业技术。与此同时，有消息称，欧盟驻华代表团经济金融处公使参赞沙斌诺(SabinoForniesMartinez)可能在今年稍後时间由北京调迁或兼顾香港工作，被视为欧盟有意加强在港的金融商贸合作徵兆。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260623-%E6%AC%A7%E7%9B%9F%E5%8A%A0%E5%BC%BA%E5%9C%A8%E6%B8%AF%E7%BB%8F%E8%B4%B8%E6%B4%BB%E5%8A%A8-%E4%BC%A0%E7%BB%8F%E8%B4%B8%E9%83%A8%E4%B8%BB%E7%AE%A1%E4%B8%80%E8%81%8C%E4%B8%A2%E7%A9%BA%E4%B8%A4%E5%B9%B4%E5%BE%8C%E5%B0%86%E6%9C%89%E4%BA%BA%E5%A1%AB%E8%A1%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782204634000.webp","sourceId":"rfi"},{"id":1782204030000,"createdDate":"2026-06-23 08:40","name":"法国国际广播电台","title":"美国驰援菲军4艘太阳能无人艇：加强对南中国海监控，应对北京威胁","content":"路透社马尼拉消息，美国驻菲律宾大使馆周二（6月23日）表示，美国政府已向菲律宾军方交付了四艘由美国军工厂商OceanAero研发的“特立顿”（Triton）水面、水下两用无人艇，以增强马尼拉监测其水域和发现潜在威胁的能力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260623-%E7%BE%8E%E5%9B%BD%E9%A9%B0%E6%8F%B4%E8%8F%B2%E5%86%9B4%E8%89%98%E5%A4%AA%E9%98%B3%E8%83%BD%E6%97%A0%E4%BA%BA%E8%89%87-%E5%8A%A0%E5%BC%BA%E5%AF%B9%E5%8D%97%E4%B8%AD%E5%9B%BD%E6%B5%B7%E7%9B%91%E6%8E%A7%EF%BC%8C%E5%BA%94%E5%AF%B9%E5%8C%97%E4%BA%AC%E5%A8%81%E8%83%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782204030000.webp","sourceId":"rfi"},{"id":1782203983000,"createdDate":"2026-06-23 08:39","name":"法国国际广播电台","title":"中国现「毒纸尿裤」 四部门联合调查 陆客涌港抢购","content":"中国传媒调查发现，部份婴幼儿纸尿裤含有毒物质甲酰胺，遭相关品牌提供检测报告反驳，并声称已就个别自媒体的失实内容报警。争议发酵五天後，国家卫健委等四个部门成立联合调查组核查，将适时公布结果，但未有具体日期。一如往常，当中国内地传出有毒民生物品，内地人便会赶往物品质量较有保障的香港购买，导致与大陆接壤的新界北部地区在周末期间出现抢购纸尿裤，但未有如多年前般出现全港性抢购奶粉而须推出「限(购)奶令」的疯狂情况。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260623-%E4%B8%AD%E5%9B%BD%E7%8E%B0-%E6%AF%92%E7%BA%B8%E5%B0%BF%E8%A3%A4-%E5%9B%9B%E9%83%A8%E9%97%A8%E8%81%94%E5%90%88%E8%B0%83%E6%9F%A5-%E9%99%86%E5%AE%A2%E6%B6%8C%E6%B8%AF%E6%8A%A2%E8%B4%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782203983000.webp","sourceId":"rfi"},{"id":1782203275000,"createdDate":"2026-06-23 08:27","name":"法国国际广播电台","title":"2026年世界杯：姆巴佩开二度 法国3:0取胜伊拉克","content":"在美国费城6月22日周一举行世界杯的第二场小组赛中，法国队凭姆巴佩的两球和登贝莱的一球，以3比0战胜伊拉克队，法国队成功进入32强。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260623-2026%E5%B9%B4%E4%B8%96%E7%95%8C%E6%9D%AF-%E5%A7%86%E5%B7%B4%E4%BD%A9%E5%BC%80%E4%BA%8C%E5%BA%A6-%E6%B3%95%E5%9B%BD3-0%E5%8F%96%E8%83%9C%E4%BC%8A%E6%8B%89%E5%85%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782203275000.webp","sourceId":"rfi"},{"id":1782231497000,"createdDate":"2026-06-23 16:18","name":"法国国际广播电台","title":"伊朗穿梭外交：总统访巴基斯坦 议长访阿曼 外长跑两边","content":"美伊在瑞士首轮谈判结束后，伊朗表示要继续掌控霍尔木兹海峡，并拒绝对其核设施的国际核查。伊朗总统和议长及外长立即展开穿梭外交。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260623-%E4%BC%8A%E6%9C%97%E7%A9%BF%E6%A2%AD%E5%A4%96%E4%BA%A4-%E6%80%BB%E7%BB%9F%E8%AE%BF%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6-%E8%AE%AE%E9%95%BF%E8%AE%BF%E9%98%BF%E6%9B%BC-%E5%A4%96%E9%95%BF%E8%B7%91%E4%B8%A4%E8%BE%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782231497000.webp","sourceId":"rfi"},{"id":1782229344000,"createdDate":"2026-06-23 15:42","name":"法国国际广播电台","title":"脱欧十年， 如何影响了今天的英国？","content":"2016年6月23日，英国公投决定退出欧盟。十年后，脱欧对英国产生了哪些影响？英国伦敦国王学院经济学与公共政策教授乔纳森·波蒂斯（JonathanPortes）认为，在经济上，脱欧使英国经济规模较留在欧盟缩小了数个百分点。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260623-%E8%84%B1%E6%AC%A7%E5%8D%81%E5%B9%B4%EF%BC%8C-%E5%A6%82%E4%BD%95%E5%BD%B1%E5%93%8D%E4%BA%86%E4%BB%8A%E5%A4%A9%E7%9A%84%E8%8B%B1%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782229344000.webp","sourceId":"rfi"},{"id":1782229108000,"createdDate":"2026-06-23 15:38","name":"法国国际广播电台","title":"韩国星巴克因涉光州起义“坦克”广告风波暂关2000门店培训员工","content":"灯火熄灭，大门紧闭。本周，韩国各地的咖啡爱好者们有几个小时无法享用他们的每日必须的咖啡：在经历了一次广告风波后，超过2000家星巴克门店因员工培训而暂停营业。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260623-%E9%9F%A9%E5%9B%BD%E6%98%9F%E5%B7%B4%E5%85%8B%E5%9B%A0%E6%B6%89%E5%85%89%E5%B7%9E%E8%B5%B7%E4%B9%89-%E5%9D%A6%E5%85%8B-%E5%B9%BF%E5%91%8A%E9%A3%8E%E6%B3%A2%E6%9A%82%E5%85%B32000%E9%97%A8%E5%BA%97%E5%9F%B9%E8%AE%AD%E5%91%98%E5%B7%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782229108000.webp","sourceId":"rfi"},{"id":1782223678000,"createdDate":"2026-06-23 14:07","name":"法国国际广播电台","title":"印度塔塔电子公司遭遇网攻 据称苹果和特斯拉商业机密外泄","content":"印度塔塔电子周一表示，该公司最近发现了一起“网络安全事件”。此前有研究人员称，一个名叫“世界泄密”（WorldLeaks）的网站发布了该集团的客户苹果和特斯拉的组件设计和规格文件。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260623-%E5%8D%B0%E5%BA%A6%E5%A1%94%E5%A1%94%E7%94%B5%E5%AD%90%E5%85%AC%E5%8F%B8%E9%81%AD%E9%81%87%E7%BD%91%E6%94%BB-%E6%8D%AE%E7%A7%B0%E8%8B%B9%E6%9E%9C%E5%92%8C%E7%89%B9%E6%96%AF%E6%8B%89%E5%95%86%E4%B8%9A%E6%9C%BA%E5%AF%86%E5%A4%96%E6%B3%84","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782223678000.webp","sourceId":"rfi"},{"id":1782222343000,"createdDate":"2026-06-23 13:45","name":"法国国际广播电台","title":"美联储前主席艾伦·格林斯潘去世享年100岁","content":"据美国媒体援引其妻、NBC新闻记者安德烈娅·米切尔发布的声明称，美国联邦储备委员会（美联储）前主席艾伦·格林斯潘（AlanGreenspan）于6月22日周一去世，享年100岁。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260623-%E7%BE%8E%E8%81%94%E5%82%A8%E5%89%8D%E4%B8%BB%E5%B8%AD%E8%89%BE%E4%BC%A6%C2%B7%E6%A0%BC%E6%9E%97%E6%96%AF%E6%BD%98%E5%8E%BB%E4%B8%96-%E4%BA%AB%E5%B9%B4100%E5%B2%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782222343000.webp","sourceId":"rfi"},{"id":1782220264000,"createdDate":"2026-06-23 13:11","name":"法国国际广播电台","title":"加拿大蒙特利尔犹太社区枪击案致两人死亡 凶手被击毙 身份未知","content":"周一22日，加拿大蒙特利尔发生一起枪击事件，造成一名居民和一名警察死亡，一名作案动机不明的袭击者被警方击毙，凶手身份尚未被透露。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260623-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E8%92%99%E7%89%B9%E5%88%A9%E5%B0%94%E7%8A%B9%E5%A4%AA%E7%A4%BE%E5%8C%BA%E6%9E%AA%E5%87%BB%E6%A1%88%E8%87%B4%E4%B8%A4%E4%BA%BA%E6%AD%BB%E4%BA%A1-%E5%87%B6%E6%89%8B%E8%A2%AB%E5%87%BB%E6%AF%99-%E8%BA%AB%E4%BB%BD%E6%9C%AA%E7%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782220264000.webp","sourceId":"rfi"},{"id":1782219106000,"createdDate":"2026-06-23 12:51","name":"法国国际广播电台","title":"高温酷暑：研究预估2050年空调总碳排放将等同于美国","content":"法国刚刚度过了自1947年开始测量以来有记录以来最热的夜晚。根据国家气象预报６月２３日公布的纪录，30个参考站平均的最低气温国家热指标（ITN）为21。6°C。之前的记录是21。4°C,可以追溯到2019年7月25日。法国以及欧洲迎来了今年五月以来有一波热浪，气温连续多日创下历史最高纪录，今天周二巴黎的最高温度达到近摄氏40度，这在六月份是前所未有的，到目前为止巴黎气温的最高纪录是42.6度，不过，那是在2019年的7月24日。高温酷暑导致一百多家学校被迫关闭，家长不得不选择远程工作。连续高温使巴黎以及法国全国的民众争先恐后的购买空调，据统计，今天法国将近四分之一的家庭都装备了空调，然而，空调是否是应对酷暑的最佳选择？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260623-%E9%AB%98%E6%B8%A9%E9%85%B7%E6%9A%91-%E7%A0%94%E7%A9%B6%E9%A2%84%E4%BC%B02050%E5%B9%B4%E7%A9%BA%E8%B0%83%E6%80%BB%E7%A2%B3%E6%8E%92%E6%94%BE%E5%B0%86%E7%AD%89%E5%90%8C%E4%BA%8E%E7%BE%8E%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782219106000.webp","sourceId":"rfi"},{"id":1782216885000,"createdDate":"2026-06-23 12:14","name":"法国国际广播电台","title":"欧洲热浪加剧蔓延 法国5天40人溺水身亡 意英西红色预警","content":"席卷法国的极端热浪周二仍在蔓延，气象局警告红色预警范围周三可能进一步扩大。意大利西班牙英国多地发布酷暑红色预警...","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260623-%E6%AC%A7%E6%B4%B2%E7%83%AD%E6%B5%AA%E5%8A%A0%E5%89%A7%E8%94%93%E5%BB%B6-%E6%B3%95%E5%9B%BD5%E5%A4%A940%E4%BA%BA%E6%BA%BA%E6%B0%B4%E8%BA%AB%E4%BA%A1-%E6%84%8F%E8%8B%B1%E8%A5%BF%E7%BA%A2%E8%89%B2%E9%A2%84%E8%AD%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782216885000.webp","sourceId":"rfi"},{"id":1782215035000,"createdDate":"2026-06-23 11:43","name":"法国国际广播电台","title":"伊朗仍想控制霍尔木兹海峡 拒国际原子能署核查遭轰炸设施","content":"周二，德黑兰再次重申要保持对霍尔木兹海峡的控制权，并拒绝国际原子能署核查。据伊朗官媒消息，上周末在瑞士启动的美伊谈判和“技术性”磋商已结束。后续谈判将由各工作组继续进行。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260623-%E4%BC%8A%E6%9C%97%E4%BB%8D%E6%83%B3%E6%8E%A7%E5%88%B6%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E6%8B%92%E5%9B%BD%E9%99%85%E5%8E%9F%E5%AD%90%E8%83%BD%E7%BD%B2%E6%A0%B8%E6%9F%A5%E9%81%AD%E8%BD%B0%E7%82%B8%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782215035000.webp","sourceId":"rfi"},{"id":1782212033000,"createdDate":"2026-06-23 10:53","name":"法国国际广播电台","title":"英国脱欧十年后：是在沉默中“愿赌服输”，还是回头寻找出路？","content":"2016年6月23日，英国民众以51.9%的投票率支持脱离欧盟。然而公投过去十年后，伦敦与布鲁塞尔从未像现在这样频繁地谈论“靠拢”。这一词汇在英国政府的演讲、欧盟的公报，甚至是查尔斯三世国王的声明中反复出现：合作、重新结盟、伙伴关系……这些用词都反映出，2016年6月公投通过、并于2020年1月正式生效的“与布鲁塞尔彻底决裂”并没有取得预期结果。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260623-%E8%8B%B1%E5%9B%BD%E8%84%B1%E6%AC%A7%E5%8D%81%E5%B9%B4%E5%90%8E-%E6%98%AF%E5%9C%A8%E6%B2%89%E9%BB%98%E4%B8%AD-%E6%84%BF%E8%B5%8C%E6%9C%8D%E8%BE%93-%EF%BC%8C%E8%BF%98%E6%98%AF%E5%9B%9E%E5%A4%B4%E5%AF%BB%E6%89%BE%E5%87%BA%E8%B7%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782212033000.webp","sourceId":"rfi"},{"id":1782210038000,"createdDate":"2026-06-23 10:20","name":"法国国际广播电台","title":"韩国：愿接收所有在乌被俘的朝鲜士兵","content":"韩国外交部发言人朴一周二（6月23日）表示，凡是在为俄罗斯作战期间被乌克兰俘获、并且本人选择前往韩国的朝鲜战俘，韩国将全部接收。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260623-%E9%9F%A9%E5%9B%BD-%E6%84%BF%E6%8E%A5%E6%94%B6%E6%89%80%E6%9C%89%E5%9C%A8%E4%B9%8C%E8%A2%AB%E4%BF%98%E7%9A%84%E6%9C%9D%E9%B2%9C%E5%A3%AB%E5%85%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782210038000.webp","sourceId":"rfi"},{"id":1782210006000,"createdDate":"2026-06-23 10:20","name":"法国国际广播电台","title":"脱欧十年后，英国是否准备重返欧盟？","content":"各位好。6月23日出刊的法国主流日刊在国际版集中聚焦英国脱欧10周年，以及英国和欧盟的关系现状。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260623-%E8%84%B1%E6%AC%A7%E5%8D%81%E5%B9%B4%E5%90%8E%EF%BC%8C%E8%8B%B1%E5%9B%BD%E6%98%AF%E5%90%A6%E5%87%86%E5%A4%87%E9%87%8D%E8%BF%94%E6%AC%A7%E7%9B%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/23/1782210006000.webp","sourceId":"rfi"}]