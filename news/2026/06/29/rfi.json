[{"id":1782727533000,"createdDate":"2026-06-29 10:05","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第26：浪漫主义在现代世界的隐现第一节：袪魅与复魅","content":"现代世界有一个特征，那就是袪魅。随着经验科学的发展，世界的神秘面纱被一点点剥离，理性要求解释一切，人类真实的力量不再来自神而来自知识，“知识就是力量”的信条日益深入人心，而浪漫主义的追求被当作诗人心灵的梦呓，似乎只有冰冷的数字和机械的精确才是世界的本来面目。但终有智者对此质疑，他们指出，所谓知识的力量背后是冷血的权力和资本的利益，而一个缺乏诗意的世界不是人的世界。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260629-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC26-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E5%9C%A8%E7%8E%B0%E4%BB%A3%E4%B8%96%E7%95%8C%E7%9A%84%E9%9A%90%E7%8E%B0%E7%AC%AC%E4%B8%80%E8%8A%82-%E8%A2%AA%E9%AD%85%E4%B8%8E%E5%A4%8D%E9%AD%85","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782727533000.webp","sourceId":"rfi"},{"id":1782727253000,"createdDate":"2026-06-29 10:00","name":"法国国际广播电台","title":"美菲8天2度在南海举行海事合作活动 解放军南部战区海空力量进行例行巡航","content":"美国海军第七舰队周一通过新闻稿表示，“6月27日至28日，菲律宾武装部队与美国海岸警卫队在菲律宾专属经济区内开展了海事合作活动（MCA）。此次活动彰显了双方致力于加强区域及国际合作，以支持自由开放的印度-太平洋的共同承诺”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260629-%E7%BE%8E%E8%8F%B28%E5%A4%A92%E5%BA%A6%E5%9C%A8%E5%8D%97%E6%B5%B7%E4%B8%BE%E8%A1%8C%E6%B5%B7%E4%BA%8B%E5%90%88%E4%BD%9C%E6%B4%BB%E5%8A%A8-%E8%A7%A3%E6%94%BE%E5%86%9B%E5%8D%97%E9%83%A8%E6%88%98%E5%8C%BA%E6%B5%B7%E7%A9%BA%E5%8A%9B%E9%87%8F%E8%BF%9B%E8%A1%8C%E4%BE%8B%E8%A1%8C%E5%B7%A1%E8%88%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782727253000.webp","sourceId":"rfi"},{"id":1782725686000,"createdDate":"2026-06-29 09:34","name":"法国国际广播电台","title":"中国追加20家禁止出口军民两用物项的日本企业及团体","content":"中国商务部29日宣布，将日本20家企业和团体新增列入军民两用项出口管制名单。中方表示，此举的理由是日本存在“再军事化”的企图。今后，中国企业未经事先批准，不得向这些企业和团体出售相关物项。中国政府此前公布的受出口管制的军民两用物项中包括稀土。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260629-%E4%B8%AD%E5%9B%BD%E8%BF%BD%E5%8A%A020%E5%AE%B6%E7%A6%81%E6%AD%A2%E5%87%BA%E5%8F%A3%E5%86%9B%E6%B0%91%E4%B8%A4%E7%94%A8%E7%89%A9%E9%A1%B9%E7%9A%84%E6%97%A5%E6%9C%AC%E4%BC%81%E4%B8%9A%E5%8F%8A%E5%9B%A2%E4%BD%93","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782725686000.webp","sourceId":"rfi"},{"id":1782725049000,"createdDate":"2026-06-29 09:24","name":"法国国际广播电台","title":"“中国尊”遭小飞机撞击后 全国通用航空被指停飞","content":"北京市朝阳区官方信息平台“北京朝阳”微信公众号27日发布的“情况通报”称，“6月26日17时55分，在朝阳区东三环附近，一架单发双座轻型运动航空器在飞行中碰撞一高层建筑，机上仅驾驶员1人、已死亡，现场13人受伤”。该通报称，受伤人员在全力救治中。相关情况正由主管部门进一步调查。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260629-%E4%B8%AD%E5%9B%BD%E5%B0%8A-%E9%81%AD%E5%B0%8F%E9%A3%9E%E6%9C%BA%E6%92%9E%E5%87%BB%E5%90%8E-%E5%85%A8%E5%9B%BD%E9%80%9A%E7%94%A8%E8%88%AA%E7%A9%BA%E8%A2%AB%E6%8C%87%E5%81%9C%E9%A3%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782725049000.webp","sourceId":"rfi"},{"id":1782724478000,"createdDate":"2026-06-29 09:14","name":"法国国际广播电台","title":"中国商务部长赴欧盟总部会谈，谋求缓解中欧贸易紧张关系","content":"中国商务部长王文涛29日抵达布鲁塞尔，与欧盟委员会官员就当前紧张的贸易关系展开会谈。由于欧洲对华贸易逆差不断扩大，欧盟成员几乎一致认为有必要强化应对中国商品冲击的手段，而中方也一再警告，表示会对一切涉及中国企业的限制措施发起反制。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260629-%E4%B8%AD%E5%9B%BD%E5%95%86%E5%8A%A1%E9%83%A8%E9%95%BF%E8%B5%B4%E6%AC%A7%E7%9B%9F%E6%80%BB%E9%83%A8%E4%BC%9A%E8%B0%88%EF%BC%8C%E8%B0%8B%E6%B1%82%E7%BC%93%E8%A7%A3%E4%B8%AD%E6%AC%A7%E8%B4%B8%E6%98%93%E7%B4%A7%E5%BC%A0%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782724478000.webp","sourceId":"rfi"},{"id":1782723282000,"createdDate":"2026-06-29 08:54","name":"法国国际广播电台","title":"澳洲与瓦努阿图达成围绕关键基础设施免军事化的战略协定 北京：不应针对第三方","content":"经过数月漫长且有时激烈的谈判，澳大利亚与位于太平洋西南部的岛国瓦努阿图签署了一项具有里程碑意义的战略协定。瓦努阿图总理纳帕特（JothamNapat）与澳大利亚总理阿尔巴尼斯（AnthonyAlbanese）周一下午在堪培拉正式签署了《纳卡马尔协议》。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260629-%E6%BE%B3%E6%B4%B2%E4%B8%8E%E7%93%A6%E5%8A%AA%E9%98%BF%E5%9B%BE%E8%BE%BE%E6%88%90%E5%9B%B4%E7%BB%95%E5%85%B3%E9%94%AE%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD%E5%85%8D%E5%86%9B%E4%BA%8B%E5%8C%96%E7%9A%84%E6%88%98%E7%95%A5%E5%8D%8F%E5%AE%9A-%E5%8C%97%E4%BA%AC-%E4%B8%8D%E5%BA%94%E9%92%88%E5%AF%B9%E7%AC%AC%E4%B8%89%E6%96%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782723282000.webp","sourceId":"rfi"},{"id":1782714643000,"createdDate":"2026-06-29 06:30","name":"法国国际广播电台","title":"曾为香港人才培养摇篮　74年历史港大学生刊物《学苑》停运","content":"在学生会和表达自由备受打压的情况下，有74年历史的香港大学(港大)学生会刊物《学苑》，因未能召募新一届编辑委员会而须即日停运。《学苑》在停运启事中表示，时至今日，《学苑》在社会中担任的历史角色已走到尽头。对于这份曾多次卷入香港政治争议的刊物停运，曾任《学苑》编辑的学者感慨，港大痛失一个培养人才及训练学生思考的平台。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260629-%E6%9B%BE%E4%B8%BA%E9%A6%99%E6%B8%AF%E4%BA%BA%E6%89%8D%E5%9F%B9%E5%85%BB%E6%91%87%E7%AF%AE-74%E5%B9%B4%E5%8E%86%E5%8F%B2%E6%B8%AF%E5%A4%A7%E5%AD%A6%E7%94%9F%E5%88%8A%E7%89%A9-%E5%AD%A6%E8%8B%91-%E5%81%9C%E8%BF%90","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782714643000.webp","sourceId":"rfi"},{"id":1782752613000,"createdDate":"2026-06-29 17:03","name":"法国国际广播电台","title":"马克龙再次戴上太阳镜","content":"法国总统马克龙于周一中午在爱丽舍宫迎接阿曼苏丹。人们清晰地看到在爱丽舍宫迎接贵宾时，马克龙又戴上了被他带红的太阳镜。难道是灼热的太阳刺眼？随行人员称是眼部充血，但没有提供更多的细节。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260629-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%86%8D%E6%AC%A1%E6%88%B4%E4%B8%8A%E5%A4%AA%E9%98%B3%E9%95%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782752613000.webp","sourceId":"rfi"},{"id":1782747108000,"createdDate":"2026-06-29 15:31","name":"法国国际广播电台","title":"针对“Shein、Temu和AliExpress” 法国针对“超快时尚”法案完成立法程序","content":"该法案自提出至今已过去两年半，法国议会于周一最终批准了这项旨在遏制“快时尚”——以希音（Shein）为典型代表——兴起的法案；不过，为了保护“法国就业岗位”，法案的适用范围被缩小，重点针对“超快时尚”。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260629-%E9%92%88%E5%AF%B9-shein-temu%E5%92%8Caliexpress-%E6%B3%95%E5%9B%BD%E9%92%88%E5%AF%B9-%E8%B6%85%E5%BF%AB%E6%97%B6%E5%B0%9A-%E6%B3%95%E6%A1%88%E5%AE%8C%E6%88%90%E7%AB%8B%E6%B3%95%E7%A8%8B%E5%BA%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782747108000.webp","sourceId":"rfi"},{"id":1782744367000,"createdDate":"2026-06-29 14:46","name":"法国国际广播电台","title":"日本版CFIUS对日外国投资委员会启动 高市等出席首次会议","content":"为严格审查来自海外的投资，新设立的对日外国投资委员会召开了首次会议，高市早苗首相在会上强调，将加强各部委之间的协作，致力于提升审查能力。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260629-%E6%97%A5%E7%89%88cfius-%E5%AF%B9%E6%97%A5%E5%A4%96%E5%9B%BD%E6%8A%95%E8%B5%84%E5%A7%94%E5%91%98%E4%BC%9A%E5%90%AF%E5%8A%A8-%E9%AB%98%E5%B8%82%E7%AD%89%E5%87%BA%E5%B8%AD%E6%88%90%E7%AB%8B%E4%BB%AA%E5%BC%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782744367000.webp","sourceId":"rfi"},{"id":1782743552000,"createdDate":"2026-06-29 14:32","name":"法国国际广播电台","title":"澳大利亚加速巩固与太平洋岛国的合作，抗衡中国影响力扩张","content":"澳大利亚和太平洋岛国瓦努阿图29日宣布签订协议，禁止任何外国军队在瓦努阿图建立军事基地。这意味着澳大利亚在太平洋地区与中国争夺影响力的努力又向前推动了一步。中国方面也立即做出了反应。中国外交部发言人郭嘉昆当日在例行记者会上表示，希望相关各方“不应针对第三方，更不应借此搞地缘博弈。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260629-%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E5%8A%A0%E9%80%9F%E5%B7%A9%E5%9B%BA%E4%B8%8E%E5%A4%AA%E5%B9%B3%E6%B4%8B%E5%B2%9B%E5%9B%BD%E7%9A%84%E5%90%88%E4%BD%9C%EF%BC%8C%E6%8A%97%E8%A1%A1%E4%B8%AD%E5%9B%BD%E5%BD%B1%E5%93%8D%E5%8A%9B%E6%89%A9%E5%BC%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782743552000.webp","sourceId":"rfi"},{"id":1782742972000,"createdDate":"2026-06-29 14:22","name":"法国国际广播电台","title":"德经济部长在欧盟贸易委员前先会见王文涛 强调可靠供应链及平衡贸易关系等","content":"欧盟委员会贸易和经济安全委员谢夫乔维奇（MarošŠefčovič）周一在布鲁塞尔与中国商务部部长王文涛举行会谈。谢夫乔维奇对后者的来访表示欢迎，并指双方将迎接日程排得满满当当的一天，并指“议程紧凑，会谈实质性，目标明确”。此前，德国联邦经济和能源部部长赖歇（KatherinaReiche）周日在布鲁塞尔与王文涛举行了会谈。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260629-%E5%BE%B7%E7%BB%8F%E6%B5%8E%E9%83%A8%E9%95%BF%E5%9C%A8%E6%AC%A7%E7%9B%9F%E8%B4%B8%E6%98%93%E5%A7%94%E5%91%98%E5%89%8D%E5%85%88%E4%BC%9A%E8%A7%81%E7%8E%8B%E6%96%87%E6%B6%9B-%E5%BC%BA%E8%B0%83%E5%8F%AF%E9%9D%A0%E4%BE%9B%E5%BA%94%E9%93%BE%E5%8F%8A%E5%B9%B3%E8%A1%A1%E8%B4%B8%E6%98%93%E5%85%B3%E7%B3%BB%E7%AD%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782742972000.webp","sourceId":"rfi"},{"id":1782741742000,"createdDate":"2026-06-29 14:02","name":"法国国际广播电台","title":"马来西亚续签一年 搜寻2014年飞向北京失踪的MH370航班","content":"马来西亚政府今天宣布延长与英国海底勘探公司“海洋无限”（OceanInfinity）协议，再合作12个月，继续在南印度洋搜寻在2014年失联的马航MH370客机，并从2026年7月1日开始。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260629-%E9%A9%AC%E6%9D%A5%E8%A5%BF%E4%BA%9A%E7%BB%AD%E7%AD%BE%E4%B8%80%E5%B9%B4-%E6%90%9C%E5%AF%BB2014%E5%B9%B4%E9%A3%9E%E5%90%91%E5%8C%97%E4%BA%AC%E5%A4%B1%E8%B8%AA%E7%9A%84mh370%E8%88%AA%E7%8F%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782741742000.webp","sourceId":"rfi"},{"id":1782739882000,"createdDate":"2026-06-29 13:31","name":"法国国际广播电台","title":"德国突发枪击案 ：5人死亡","content":"周一，德国北部小镇施塔德一家青少年福利机构发生枪击事件，造成五人死亡。两人被捕，其中包括枪击嫌疑人。施塔德市约有5万居民，距离汉堡约40公里。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260629-%E5%BE%B7%E5%9B%BD%E7%AA%81%E5%8F%91%E6%9E%AA%E5%87%BB%E6%A1%88-5%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782739882000.webp","sourceId":"rfi"},{"id":1782739773000,"createdDate":"2026-06-29 13:29","name":"法国国际广播电台","title":"日中关系恶化 两国民间人士深受影响","content":"自从日本首相高市早苗在去年上台后，特别是11月7日举行的众议院预算委员会会议上，被问及在中国对台湾发动军事进攻的“台湾有事”的情况下，表示可构成可行使集体自卫权的“存立危机事态”以后，中国强烈反弹，日中关系急转直下，不仅两国政府几乎已经断绝官方交流，也危及到两国民间人士。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260629-%E6%97%A5%E4%B8%AD%E5%85%B3%E7%B3%BB%E6%81%B6%E5%8C%96-%E4%B8%A4%E5%9B%BD%E6%B0%91%E9%97%B4%E4%BA%BA%E5%A3%AB%E6%B7%B1%E5%8F%97%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782739773000.webp","sourceId":"rfi"},{"id":1782738178000,"createdDate":"2026-06-29 13:02","name":"法国国际广播电台","title":"中国共产党105年：从50多人到超过1亿党员","content":"中国共产党将在7月1日迎来成立105周年。从1921年成立时仅有50多名党员，到如今党员总数突破1亿人，中国共产党已发展成为世界规模最大的执政党之一。作为中国唯一的执政党，它领导着全球第二大经济体，也持续影响着中国的发展方向和国际格局。105年来，这个政党经历了怎样的发展历程？又是如何运作的？","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD%E5%85%B1%E4%BA%A7%E5%85%9A105%E5%B9%B4-%E4%BB%8E50%E5%A4%9A%E4%BA%BA%E5%88%B01%E4%BA%BF%E5%85%9A%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782738178000.webp","sourceId":"rfi"},{"id":1782737549000,"createdDate":"2026-06-29 12:52","name":"法国国际广播电台","title":"中方再次扩大对日出口管制 日内阁官房长官：绝不可接受，极令人遗憾","content":"中国商务部周一发布公告，决定将20家日本实体列入出口管制管控名单，将20家日本实体列入关注名单，日本政府当天向中方提出强烈抗议，并要求撤回措施。日本内阁官房长官木原稔在记者会上宣布了这一消息。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260629-%E4%B8%AD%E6%96%B9%E5%86%8D%E6%AC%A1%E6%89%A9%E5%A4%A7%E5%AF%B9%E6%97%A5%E5%87%BA%E5%8F%A3%E7%AE%A1%E5%88%B6-%E6%97%A5%E5%86%85%E9%98%81%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98-%E7%BB%9D%E4%B8%8D%E5%8F%AF%E6%8E%A5%E5%8F%97%EF%BC%8C%E6%9E%81%E4%BB%A4%E4%BA%BA%E9%81%97%E6%86%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782737549000.webp","sourceId":"rfi"},{"id":1782735783000,"createdDate":"2026-06-29 12:23","name":"法国国际广播电台","title":"董广平：“怕死也没有用，往前走，还有生的机会 ”","content":"乘坐一艘快没电的小艇，在海上航行了大约40个小时，抵达韩国后遭到拘留......这仅仅是中国异见人士董广平为了逃离祖国所经历的一部分苦难。董广平上周晚些时候已经从韩国抵达加拿大和家人团聚，这是他十多年来一直向往的目的地。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260629-%E8%91%A3%E5%B9%BF%E5%B9%B3-%E6%80%95%E6%AD%BB%E4%B9%9F%E6%B2%A1%E6%9C%89%E7%94%A8%EF%BC%8C%E5%BE%80%E5%89%8D%E8%B5%B0%EF%BC%8C%E8%BF%98%E6%9C%89%E7%94%9F%E7%9A%84%E6%9C%BA%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782735783000.webp","sourceId":"rfi"},{"id":1782733364000,"createdDate":"2026-06-29 11:42","name":"法国国际广播电台","title":"卢卡申科会见习近平打趣称就像到自己家一般 会后举行传统“友好家宴”","content":"当地时间周一上午，中国国家主席习近平在北京钓鱼台国宾馆会见了到访的白俄罗斯总统卢卡申科。卢卡申科在与习近平会晤时在镜头前开玩笑说，来华访问感觉就像“到自己家了”一般。这是卢卡申科第17次访问中国。此前，卢卡申科和俄罗斯总统普京于6月26日至27日在俄西北部诺夫哥罗德州的总统公邸会晤，就经济合作和地区安全等问题进行了磋商。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260629-%E5%8D%A2%E5%8D%A1%E7%94%B3%E7%A7%91%E4%BC%9A%E8%A7%81%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%89%93%E8%B6%A3%E7%A7%B0%E5%B0%B1%E5%83%8F%E5%88%B0%E8%87%AA%E5%B7%B1%E5%AE%B6%E4%B8%80%E8%88%AC-%E4%BC%9A%E5%90%8E%E4%B8%BE%E8%A1%8C%E4%BC%A0%E7%BB%9F-%E5%8F%8B%E5%A5%BD%E5%AE%B6%E5%AE%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782733364000.webp","sourceId":"rfi"},{"id":1782732207000,"createdDate":"2026-06-29 11:23","name":"法国国际广播电台","title":"2026年世界杯：加拿大历史性晋级、南非队遗憾出局","content":"2026年世界杯漫长的小组赛刚刚落下帷幕，观众的目光便立即转向了6月26日（星期日）在洛杉矶举行的首场16分之一决赛——加拿大对阵南非。最终，凭借中场斯蒂芬·欧斯塔基奥（StephenEustaquio）在补时阶段的进球，加拿大队以1比0取胜。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260629-2026%E5%B9%B4%E4%B8%96%E7%95%8C%E6%9D%AF-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E5%8E%86%E5%8F%B2%E6%80%A7%E6%99%8B%E7%BA%A7-%E5%8D%97%E9%9D%9E%E9%98%9F%E9%81%97%E6%86%BE%E5%87%BA%E5%B1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/06/29/1782732207000.webp","sourceId":"rfi"}]