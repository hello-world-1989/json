[{"id":1782118776000,"createdDate":"2026-06-22 08:59","name":"法国国际广播电台","title":"英国首相基尔·斯塔默宣布辞职","content":"英国首相基尔·斯塔默周一在伦敦唐宁街发表讲话时宣布辞职，并表示将在工党选出新领导人之前继续留任。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260622-%E8%8B%B1%E5%9B%BD%E9%A6%96%E7%9B%B8%E5%9F%BA%E5%B0%94%C2%B7%E6%96%AF%E5%A1%94%E9%BB%98%E5%AE%A3%E5%B8%83%E8%BE%9E%E8%81%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782118776000.webp","sourceId":"rfi"},{"id":1782118764000,"createdDate":"2026-06-22 08:59","name":"法国国际广播电台","title":"环太平洋军演24日登场 韩国首度担任海上指挥官","content":"全球规模最大的海上跨国军事演习“环太平洋军演”（RIMPAC）6月24日起登场，适逢美国建国250周年，规模创新高；韩国军官将首度担任海上指挥官，写下55年来首例。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260622-%E7%8E%AF%E5%A4%AA%E5%B9%B3%E6%B4%8B%E5%86%9B%E6%BC%9424%E6%97%A5%E7%99%BB%E5%9C%BA-%E9%9F%A9%E5%9B%BD%E9%A6%96%E5%BA%A6%E6%8B%85%E4%BB%BB%E6%B5%B7%E4%B8%8A%E6%8C%87%E6%8C%A5%E5%AE%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782118764000.webp","sourceId":"rfi"},{"id":1782117307000,"createdDate":"2026-06-22 08:35","name":"法国国际广播电台","title":"美日等联合军演部署中程导弹发射系统 与中国展开中导竞争","content":"从22日开始举行的由美国主导的多国联合演习“勇敢之盾”（ValiantShield），美国陆军的中程导弹系统“提丰”（Typhon）临时部署在鹿儿岛县海上自卫队鹿屋航空基地。提丰系统能够发射射程最远达1600公里的“战斧”巡航导弹，是日本国内发射最远距离导弹的发射系统，上海等中国东部沿海主要城市均处于其射程范围之内,自美国于2019年退出《中导条约》（INF）后，一直试图通过在日本和菲律宾部署中程导弹系统，缩小与中国在中程导弹领域的差距。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260622-%E7%BE%8E%E6%97%A5%E7%AD%89%E8%81%94%E5%90%88%E5%86%9B%E6%BC%94%E9%83%A8%E7%BD%B2%E4%B8%AD%E7%A8%8B%E5%AF%BC%E5%BC%B9%E5%8F%91%E5%B0%84%E7%B3%BB%E7%BB%9F-%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%B1%95%E5%BC%80%E4%B8%AD%E5%AF%BC%E7%AB%9E%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782117307000.webp","sourceId":"rfi"},{"id":1782115965000,"createdDate":"2026-06-22 08:12","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第25：浪漫主义群星之二：浪漫派中萌生的现代之花 - 幽灵霍夫曼","content":"德国浪漫主义的诉求之一就是把对世界的看法从有用性中解放出来。席勒美学的理想：自由游戏说，为浪漫派作家的想象空间提供了无限的可能性。于是，在童话世界中梦想，在魔幻世界中创造幽灵是浪漫派作家喜欢使用的手法，其中最具代表性的人是霍夫曼。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260622-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC25-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%BA%8C-%E6%B5%AA%E6%BC%AB%E6%B4%BE%E4%B8%AD%E8%90%8C%E7%94%9F%E7%9A%84%E7%8E%B0%E4%BB%A3%E4%B9%8B%E8%8A%B1-%E5%B9%BD%E7%81%B5%E9%9C%8D%E5%A4%AB%E6%9B%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782115965000.webp","sourceId":"rfi"},{"id":1782113995000,"createdDate":"2026-06-22 07:39","name":"法国国际广播电台","title":"中国反制：禁向56家美企出口产品或采购物品 多涉国防丶航太及稀土企业","content":"中美的制裁和报复行动升级，中国政府公布，即日起，禁止向十家美国实体出口或转口军民两用物资，另外又禁止全国政府机构采购波音和洛克希德·马丁等46家企业的产品。上述56家企业与国防丶稀土及航太业有关，明显是为报复美国月初将多达188家中国龙头公司在内的企业列入军工黑名单的制裁行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260622-%E4%B8%AD%E5%9B%BD%E5%8F%8D%E5%88%B6-%E7%A6%81%E5%90%9156%E5%AE%B6%E7%BE%8E%E4%BC%81%E5%87%BA%E5%8F%A3%E4%BA%A7%E5%93%81%E6%88%96%E9%87%87%E8%B4%AD%E7%89%A9%E5%93%81-%E5%A4%9A%E6%B6%89%E5%9B%BD%E9%98%B2%E4%B8%B6%E8%88%AA%E5%A4%AA%E5%8F%8A%E7%A8%80%E5%9C%9F%E4%BC%81%E4%B8%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782113995000.webp","sourceId":"rfi"}]