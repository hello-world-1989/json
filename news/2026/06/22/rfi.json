[{"id":1782118776000,"createdDate":"2026-06-22 08:59","name":"法国国际广播电台","title":"英国首相基尔·斯塔默宣布辞职","content":"英国首相基尔·斯塔默周一在伦敦唐宁街发表讲话时宣布辞职，并表示将在工党选出新领导人之前继续留任。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260622-%E8%8B%B1%E5%9B%BD%E9%A6%96%E7%9B%B8%E5%9F%BA%E5%B0%94%C2%B7%E6%96%AF%E5%A1%94%E9%BB%98%E5%AE%A3%E5%B8%83%E8%BE%9E%E8%81%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782118776000.webp","sourceId":"rfi"},{"id":1782118764000,"createdDate":"2026-06-22 08:59","name":"法国国际广播电台","title":"环太平洋军演24日登场 韩国首度担任海上指挥官","content":"全球规模最大的海上跨国军事演习“环太平洋军演”（RIMPAC）6月24日起登场，适逢美国建国250周年，规模创新高；韩国军官将首度担任海上指挥官，写下55年来首例。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260622-%E7%8E%AF%E5%A4%AA%E5%B9%B3%E6%B4%8B%E5%86%9B%E6%BC%9424%E6%97%A5%E7%99%BB%E5%9C%BA-%E9%9F%A9%E5%9B%BD%E9%A6%96%E5%BA%A6%E6%8B%85%E4%BB%BB%E6%B5%B7%E4%B8%8A%E6%8C%87%E6%8C%A5%E5%AE%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782118764000.webp","sourceId":"rfi"},{"id":1782117307000,"createdDate":"2026-06-22 08:35","name":"法国国际广播电台","title":"美日等联合军演部署中程导弹发射系统 与中国展开中导竞争","content":"从22日开始举行的由美国主导的多国联合演习“勇敢之盾”（ValiantShield），美国陆军的中程导弹系统“提丰”（Typhon）临时部署在鹿儿岛县海上自卫队鹿屋航空基地。提丰系统能够发射射程最远达1600公里的“战斧”巡航导弹，是日本国内发射最远距离导弹的发射系统，上海等中国东部沿海主要城市均处于其射程范围之内,自美国于2019年退出《中导条约》（INF）后，一直试图通过在日本和菲律宾部署中程导弹系统，缩小与中国在中程导弹领域的差距。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260622-%E7%BE%8E%E6%97%A5%E7%AD%89%E8%81%94%E5%90%88%E5%86%9B%E6%BC%94%E9%83%A8%E7%BD%B2%E4%B8%AD%E7%A8%8B%E5%AF%BC%E5%BC%B9%E5%8F%91%E5%B0%84%E7%B3%BB%E7%BB%9F-%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%B1%95%E5%BC%80%E4%B8%AD%E5%AF%BC%E7%AB%9E%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782117307000.webp","sourceId":"rfi"},{"id":1782115965000,"createdDate":"2026-06-22 08:12","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第25：浪漫主义群星之二：浪漫派中萌生的现代之花 - 幽灵霍夫曼","content":"德国浪漫主义的诉求之一就是把对世界的看法从有用性中解放出来。席勒美学的理想：自由游戏说，为浪漫派作家的想象空间提供了无限的可能性。于是，在童话世界中梦想，在魔幻世界中创造幽灵是浪漫派作家喜欢使用的手法，其中最具代表性的人是霍夫曼。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260622-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC25-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%BA%8C-%E6%B5%AA%E6%BC%AB%E6%B4%BE%E4%B8%AD%E8%90%8C%E7%94%9F%E7%9A%84%E7%8E%B0%E4%BB%A3%E4%B9%8B%E8%8A%B1-%E5%B9%BD%E7%81%B5%E9%9C%8D%E5%A4%AB%E6%9B%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782115965000.webp","sourceId":"rfi"},{"id":1782113995000,"createdDate":"2026-06-22 07:39","name":"法国国际广播电台","title":"中国反制：禁向56家美企出口产品或采购物品 多涉国防丶航太及稀土企业","content":"中美的制裁和报复行动升级，中国政府公布，即日起，禁止向十家美国实体出口或转口军民两用物资，另外又禁止全国政府机构采购波音和洛克希德·马丁等46家企业的产品。上述56家企业与国防丶稀土及航太业有关，明显是为报复美国月初将多达188家中国龙头公司在内的企业列入军工黑名单的制裁行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260622-%E4%B8%AD%E5%9B%BD%E5%8F%8D%E5%88%B6-%E7%A6%81%E5%90%9156%E5%AE%B6%E7%BE%8E%E4%BC%81%E5%87%BA%E5%8F%A3%E4%BA%A7%E5%93%81%E6%88%96%E9%87%87%E8%B4%AD%E7%89%A9%E5%93%81-%E5%A4%9A%E6%B6%89%E5%9B%BD%E9%98%B2%E4%B8%B6%E8%88%AA%E5%A4%AA%E5%8F%8A%E7%A8%80%E5%9C%9F%E4%BC%81%E4%B8%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782113995000.webp","sourceId":"rfi"},{"id":1782151133000,"createdDate":"2026-06-22 17:58","name":"法国国际广播电台","title":"西班牙首相桑切斯前得力助手因腐败被判处24年监禁","content":"西班牙前交通部长何塞·路易斯·阿巴洛斯（JoséLuisÁbalos）因腐败罪被判处24年监禁。他曾是西班牙社会党内重量级领袖、也是首相佩德罗·桑切斯政治崛起的关键人物。此案对正经受反对党巨大压力的桑切斯而言，又是一记重锤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260622-%E8%A5%BF%E7%8F%AD%E7%89%99%E9%A6%96%E7%9B%B8%E6%A1%91%E5%88%87%E6%96%AF%E5%89%8D%E5%BE%97%E5%8A%9B%E5%8A%A9%E6%89%8B%E5%9B%A0%E8%85%90%E8%B4%A5%E8%A2%AB%E5%88%A4%E5%A4%8424%E5%B9%B4%E7%9B%91%E7%A6%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782151133000.webp","sourceId":"rfi"},{"id":1782147848000,"createdDate":"2026-06-22 17:04","name":"法国国际广播电台","title":"哥伦比亚亲特朗普候选人赢总统大选 该国政治右转 美国务卿祝贺","content":"周日，美国支持的反建制律师阿韦拉多·德拉·埃斯普里利亚赢得了哥伦比亚总统选举第二轮投票，使这个饱受武装团体暴力困扰的国家大幅向右转。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260622-%E5%93%A5%E4%BC%A6%E6%AF%94%E4%BA%9A%E4%BA%B2%E7%89%B9%E6%9C%97%E6%99%AE%E5%80%99%E9%80%89%E4%BA%BA%E8%B5%A2%E6%80%BB%E7%BB%9F%E5%A4%A7%E9%80%89-%E8%AF%A5%E5%9B%BD%E6%94%BF%E6%B2%BB%E5%8F%B3%E8%BD%AC-%E7%BE%8E%E5%9B%BD%E5%8A%A1%E5%8D%BF%E7%A5%9D%E8%B4%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782147848000.webp","sourceId":"rfi"},{"id":1782145740000,"createdDate":"2026-06-22 16:29","name":"法国国际广播电台","title":"被美英制裁 柬埔寨太子集团高管藏身日本被捕","content":"共同社6月22日采访办案人员获悉，被认为是柬埔寨中资组织“太子集团”高管的胡姓男等3人，因在电子公证书原件作不实记录并提供该证书的嫌疑，被东京警视厅逮捕，理由是在日本提交虚假迁入报告。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260622-%E8%A2%AB%E7%BE%8E%E8%8B%B1%E5%88%B6%E8%A3%81-%E6%9F%AC%E5%9F%94%E5%AF%A8%E5%A4%AA%E5%AD%90%E9%9B%86%E5%9B%A2%E9%AB%98%E7%AE%A1%E8%97%8F%E8%BA%AB%E6%97%A5%E6%9C%AC%E8%A2%AB%E6%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782145740000.webp","sourceId":"rfi"},{"id":1782142066000,"createdDate":"2026-06-22 15:27","name":"法国国际广播电台","title":"斯塔默将卸任英国首相 伦敦人怎么看？","content":"英国首相斯塔默周一（6月22日）宣布将辞去首相职务，并承诺最迟于今年9月完成权力交接，以确保政府平稳过渡。消息公布后，伦敦街头不少民众表示支持这一决定，认为英国需要新的领导人带来改变。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260622-%E6%96%AF%E5%A1%94%E9%BB%98%E5%B0%86%E5%8D%B8%E4%BB%BB%E8%8B%B1%E5%9B%BD%E9%A6%96%E7%9B%B8-%E4%BC%A6%E6%95%A6%E4%BA%BA%E6%80%8E%E4%B9%88%E7%9C%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782142066000.webp","sourceId":"rfi"},{"id":1782141998000,"createdDate":"2026-06-22 15:26","name":"法国国际广播电台","title":"非洲人被骗加入俄军：肯尼亚一名部长成为众矢之的","content":"虽然内罗毕官方统计的俄罗斯“违规征兵”事件受害者为291人，其中19人死亡、32人失踪，但肯尼亚情报部门评估受害者超过1000人，并指政府内部存在同谋。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260622-%E9%9D%9E%E6%B4%B2%E4%BA%BA%E8%A2%AB%E9%AA%97%E5%8A%A0%E5%85%A5%E4%BF%84%E5%86%9B-%E8%82%AF%E5%B0%BC%E4%BA%9A%E4%B8%80%E5%90%8D%E9%83%A8%E9%95%BF%E6%88%90%E4%B8%BA%E4%BC%97%E7%9F%A2%E4%B9%8B%E7%9A%84","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782141998000.webp","sourceId":"rfi"},{"id":1782141660000,"createdDate":"2026-06-22 15:21","name":"法国国际广播电台","title":"热浪席卷法国：圣马丁运河成为巴黎“天然泳池”","content":"欧洲多国正遭遇今年以来最强烈的高温天气。法国、西班牙、意大利、德国和英国近日持续受到热浪影响，多地气温逼近或超过40摄氏度，公共交通、教育、文化和体育活动均受到不同程度冲击。法国气象部门已将最高级别的红色高温预警扩大至法国西部全境、中部大部分地区以及巴黎周边地区。全国约三分之一地区处于红色预警之下，部分地区气温达到40摄氏度，6月22日更是进一步升温。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260622-%E7%83%AD%E6%B5%AA%E5%B8%AD%E5%8D%B7%E6%B3%95%E5%9B%BD-%E5%9C%A3%E9%A9%AC%E4%B8%81%E8%BF%90%E6%B2%B3%E6%88%90%E4%B8%BA%E5%B7%B4%E9%BB%8E-%E5%A4%A9%E7%84%B6%E6%B3%B3%E6%B1%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782141660000.webp","sourceId":"rfi"},{"id":1782141449000,"createdDate":"2026-06-22 15:17","name":"法国国际广播电台","title":"中国618电商购物节期销售乏力消费者反应冷淡","content":"中国年中大型电商“618”购物节今年表现平淡，消费者们信心低迷。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260622-%E4%B8%AD%E5%9B%BD618%E7%94%B5%E5%95%86%E8%B4%AD%E7%89%A9%E8%8A%82%E6%9C%9F%E9%94%80%E5%94%AE%E4%B9%8F%E5%8A%9B%E6%B6%88%E8%B4%B9%E8%80%85%E5%8F%8D%E5%BA%94%E5%86%B7%E6%B7%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782141449000.webp","sourceId":"rfi"},{"id":1782132786000,"createdDate":"2026-06-22 12:53","name":"法国国际广播电台","title":"西班牙状态回升、比利时身陷低迷、佛得角表现惊艳、埃及亮眼刷新队史","content":"2026年美加墨世界杯小组赛继续进行。在当地时间6月22日结束的比赛中，西班牙队强势反弹，埃及队则创造历史，而比利时队则继续陷入低迷。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260622-%E8%A5%BF%E7%8F%AD%E7%89%99%E7%8A%B6%E6%80%81%E5%9B%9E%E5%8D%87-%E6%AF%94%E5%88%A9%E6%97%B6%E8%BA%AB%E9%99%B7%E4%BD%8E%E8%BF%B7-%E4%BD%9B%E5%BE%97%E8%A7%92%E8%A1%A8%E7%8E%B0%E6%83%8A%E8%89%B3-%E5%9F%83%E5%8F%8A%E4%BA%AE%E7%9C%BC%E5%88%B7%E6%96%B0%E9%98%9F%E5%8F%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782132786000.webp","sourceId":"rfi"},{"id":1782130840000,"createdDate":"2026-06-22 12:20","name":"法国国际广播电台","title":"专访台湾学者马准威：从金正恩到敏昂莱，中国本月与印太国家走动频繁释放出什么信号？","content":"川习会（特习会）结束后，中国国家主席习近平随即展开一系列密集的外交活动。从与俄罗斯总统普京会晤，到加强与朝鲜领导人金正恩的互动，再到会见缅甸军政府领导人敏昂莱，北京近期的一连串外交动作引发了外界的广泛关注。与此同时，俄乌战争仍在继续，中东局势不断升级，印太地区的安全格局也正在发生新的变化。在美中战略竞争长期化的背景下，中国周边外交的重心是否正在发生调整？这些密集的高层互动，究竟是针对当前国际局势的回应，还是北京更大战略布局的一部分？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%8D%B0%E5%A4%AA%E7%BA%B5%E8%A7%88/20260622-%E4%B8%93%E8%AE%BF%E5%8F%B0%E6%B9%BE%E5%AD%A6%E8%80%85%E9%A9%AC%E5%87%86%E5%A8%81-%E4%BB%8E%E9%87%91%E6%AD%A3%E6%81%A9%E5%88%B0%E6%95%8F%E6%98%82%E8%8E%B1%EF%BC%8C%E4%B8%AD%E5%9B%BD%E6%9C%AC%E6%9C%88%E4%B8%8E%E5%8D%B0%E5%A4%AA%E5%9B%BD%E5%AE%B6%E8%B5%B0%E5%8A%A8%E9%A2%91%E7%B9%81%E9%87%8A%E6%94%BE%E5%87%BA%E4%BB%80%E4%B9%88%E4%BF%A1%E5%8F%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782130840000.webp","sourceId":"rfi"},{"id":1782129235000,"createdDate":"2026-06-22 11:53","name":"法国国际广播电台","title":"美伊谈判就黎巴嫩和霍尔木兹海峡取得进展 将“立即重启”技术性磋商","content":"巴基斯坦和卡塔尔的调解方周一宣布，在瑞士举行的旨在结束中东战争的首轮谈判结束后，伊朗和美国就旨在停止黎巴嫩冲突并确保霍尔木兹海峡安全的机制达成一致。美国副总统JD·万斯周一表示，与伊朗的和平谈判为“达成最终协议以结束这场始于2月底的战争奠定了良好的基础”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260622-%E7%BE%8E%E4%BC%8A%E8%B0%88%E5%88%A4%E5%B0%B1%E9%BB%8E%E5%B7%B4%E5%AB%A9%E5%92%8C%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%8F%96%E5%BE%97%E8%BF%9B%E5%B1%95-%E5%B0%86-%E7%AB%8B%E5%8D%B3%E9%87%8D%E5%90%AF-%E6%8A%80%E6%9C%AF%E6%80%A7%E7%A3%8B%E5%95%86","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782129235000.webp","sourceId":"rfi"},{"id":1782126112000,"createdDate":"2026-06-22 11:01","name":"法国国际广播电台","title":"伊朗“负隅顽抗”让北京对台战略从中借鉴：与其冒进不如“慢性绞杀”","content":"大家好，从周末以来令人窒息的高温、愈来愈多的早前于62岁退休人员重返职场等法国话题攻占周一6月22日法国主要日报的头版。接下来我们为听友们详细介绍《费加罗报》亚洲通讯员法勒迪SébastienFalletti发来与中国相关的报道。这篇报道指出，从中国的视角来看，伊朗的顽强御敌为其对台战略提供了新的思路：与其冒险发动军事入侵，不如采取“慢性绞杀”的方式逐步压制台湾。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260622-%E4%BC%8A%E6%9C%97-%E8%B4%9F%E9%9A%85%E6%8A%B5%E6%8A%97-%E8%AE%A9%E4%B8%AD%E5%9B%BD%E5%AF%B9%E5%8F%B0%E6%88%98%E7%95%A5%E4%BB%8E%E4%B8%AD%E5%80%9F%E9%89%B4-%E4%B8%8E%E5%85%B6%E5%86%92%E8%BF%9B%E4%B8%8D%E5%A6%82-%E6%85%A2%E6%80%A7%E7%BB%9E%E6%9D%80","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782126112000.webp","sourceId":"rfi"},{"id":1782125818000,"createdDate":"2026-06-22 10:56","name":"法国国际广播电台","title":"高市首相在G7点名批判中国引起参与国分歧","content":"在七国集团（G7）首脑峰会期间，日本首相高市早苗6月16日在七国集团及受邀国参加的题为“构建新的伙伴关系与重建国际团结”的会议上表示：“对于中国针对日本采取的措施可能影响七国集团（G7）及理念相近国家供应链的状况，日本深感担忧。”她点名提及中国，强调有必要协调步调，共同应对中国通过限制稀土出口实施的经济胁迫的行为。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260622-%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E5%9C%A8g7%E7%82%B9%E5%90%8D%E6%89%B9%E5%88%A4%E4%B8%AD%E5%9B%BD%E5%BC%95%E8%B5%B7%E5%8F%82%E4%B8%8E%E5%9B%BD%E5%88%86%E6%AD%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782125818000.webp","sourceId":"rfi"},{"id":1782124865000,"createdDate":"2026-06-22 10:41","name":"法国国际广播电台","title":"台湾启动五天战备演习 装甲部队桃园战备巡逻","content":"台湾军方周一（6月22日）启动为期五天的战备演习，旨在提升部队应对来自中国潜在军事威胁时的快速反应能力。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260622-%E5%8F%B0%E6%B9%BE%E5%90%AF%E5%8A%A8%E4%BA%94%E5%A4%A9%E6%88%98%E5%A4%87%E6%BC%94%E4%B9%A0-%E8%A3%85%E7%94%B2%E9%83%A8%E9%98%9F%E6%A1%83%E5%9B%AD%E8%BF%9B%E8%A1%8C%E6%88%98%E5%A4%87%E5%B7%A1%E9%80%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782124865000.webp","sourceId":"rfi"},{"id":1782171692000,"createdDate":"2026-06-22 23:41","name":"法国国际广播电台","title":"法国：应对热浪，空调是否已成为不可或缺的解决方案？","content":"法国正在遭遇的前所未有的持续性酷暑，是法国世界报周一的头版头条内容。周一，法国有49个省被列入高温红色警报，另外40个省被列入橙色警报。从周二中午起，被列入高温红色警报的省份将增加到创纪录的54个，被列入橙色警报的将是35个省。面对持续的高温，如何应对呢？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260622-%E6%B3%95%E5%9B%BD-%E5%BA%94%E5%AF%B9%E7%83%AD%E6%B5%AA%EF%BC%8C%E7%A9%BA%E8%B0%83%E6%98%AF%E5%90%A6%E5%B7%B2%E6%88%90%E4%B8%BA%E4%B8%8D%E5%8F%AF%E6%88%96%E7%BC%BA%E7%9A%84%E8%A7%A3%E5%86%B3%E6%96%B9%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782171692000.webp","sourceId":"rfi"},{"id":1782171505000,"createdDate":"2026-06-22 23:38","name":"法国国际广播电台","title":"法国医院严阵以待，准备接收酷暑病人","content":"酷暑持续，法国急救电话“15”（SAMU）接线中心接到的来电量显著上升。预计，未来几天，医院急诊科将真正迎来患者潮。巴黎公立医院集团（AP-HP）表示，其下属各急诊部门已经做好准备并全面动员，以接收可能增加的患者。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260622-%E6%B3%95%E5%9B%BD%E5%8C%BB%E9%99%A2%E4%B8%A5%E9%98%B5%E4%BB%A5%E5%BE%85%EF%BC%8C%E5%87%86%E5%A4%87%E6%8E%A5%E6%94%B6%E9%85%B7%E6%9A%91%E7%97%85%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782171505000.webp","sourceId":"rfi"},{"id":1782168823000,"createdDate":"2026-06-22 22:53","name":"法国国际广播电台","title":"从非洲到巴西 中国打算打破马斯克和星链的全球垄断","content":"各位听众：从非洲到巴西，中国打算打破埃隆·马斯克和星链（Starlink）的全球垄断。当马斯克的SpaceX的市值达到1.8万亿美元时，中国公司千帆星座（Spacesail）正在与星链Starlink曾得罪过的三大洲国家签署合作协议。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260622-%E4%BB%8E%E9%9D%9E%E6%B4%B2%E5%88%B0%E5%B7%B4%E8%A5%BF-%E4%B8%AD%E5%9B%BD%E6%89%93%E7%AE%97%E6%89%93%E7%A0%B4%E9%A9%AC%E6%96%AF%E5%85%8B%E5%92%8C%E6%98%9F%E9%93%BE%E7%9A%84%E5%85%A8%E7%90%83%E5%9E%84%E6%96%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782168823000.webp","sourceId":"rfi"},{"id":1782164042000,"createdDate":"2026-06-22 21:34","name":"法国国际广播电台","title":"中国航母编队从西太平洋返回 称遭到日方的干扰和挑衅","content":"中国官方媒体报道称，航空母舰“辽宁舰”截至22日在西太平洋等海域进行了实战化训练，并声称在训练期间遭到日方的干扰和挑衅行为，而辽宁舰编队全程保持高度戒备状态，连续组织舰载机战斗起飞，灵活变换战斗队形，专业稳妥处置应对日方危险行径。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260622-%E4%B8%AD%E5%9B%BD%E8%88%AA%E6%AF%8D%E7%BC%96%E9%98%9F%E4%BB%8E%E8%A5%BF%E5%A4%AA%E5%B9%B3%E6%B4%8B%E8%BF%94%E5%9B%9E-%E7%A7%B0%E9%81%AD%E5%88%B0%E6%97%A5%E6%96%B9%E7%9A%84%E5%B9%B2%E6%89%B0%E5%92%8C%E6%8C%91%E8%A1%85","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782164042000.webp","sourceId":"rfi"},{"id":1782163678000,"createdDate":"2026-06-22 21:27","name":"法国国际广播电台","title":"法德就KNDS达成股权协议 为欧洲军工巨头上市铺路","content":"法国和德国周一（6月22日）就欧洲防务集团KNDS的战略发展及“对等治理”原则达成协议，为这家法德联合军工企业未来上市扫清关键障碍，并为两国联合研发下一代主战坦克项目（MGCS）提供新的政治支持。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260622-%E6%B3%95%E5%BE%B7%E5%B0%B1knds%E8%BE%BE%E6%88%90%E8%82%A1%E6%9D%83%E5%8D%8F%E8%AE%AE-%E4%B8%BA%E6%AC%A7%E6%B4%B2%E5%86%9B%E5%B7%A5%E5%B7%A8%E5%A4%B4%E4%B8%8A%E5%B8%82%E9%93%BA%E8%B7%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782163678000.webp","sourceId":"rfi"},{"id":1782163466000,"createdDate":"2026-06-22 21:24","name":"法国国际广播电台","title":"中国商务部长王文涛月底访欧 欧盟对华贸易逆差扩大引发担忧","content":"欧盟委员会发言人周一（6月22日）表示，中国商务部长王文涛将于6月29日在布鲁塞尔与欧盟贸易委员谢夫乔维奇举行会谈。在欧中经贸摩擦持续升温之际，此次会晤受到外界广泛关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260622-%E4%B8%AD%E5%9B%BD%E5%95%86%E5%8A%A1%E9%83%A8%E9%95%BF%E7%8E%8B%E6%96%87%E6%B6%9B%E6%9C%88%E5%BA%95%E8%AE%BF%E6%AC%A7-%E6%AC%A7%E7%9B%9F%E5%AF%B9%E5%8D%8E%E8%B4%B8%E6%98%93%E9%80%86%E5%B7%AE%E6%89%A9%E5%A4%A7%E5%BC%95%E5%8F%91%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782163466000.webp","sourceId":"rfi"},{"id":1782162731000,"createdDate":"2026-06-22 21:12","name":"法国国际广播电台","title":"美国暂停对伊朗石油制裁 伊朗同意重启国际核查","content":"美国政府周一（6月22日）宣布，暂停执行针对伊朗石油产业的制裁措施两个月，并表示伊朗已同意重新接纳国际核查人员。华盛顿称，美伊最新一轮会谈已为中东冲突最终结束奠定“非常坚实的基础”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260622-%E7%BE%8E%E5%9B%BD%E6%9A%82%E5%81%9C%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%9F%B3%E6%B2%B9%E5%88%B6%E8%A3%81-%E4%BC%8A%E6%9C%97%E5%90%8C%E6%84%8F%E9%87%8D%E5%90%AF%E5%9B%BD%E9%99%85%E6%A0%B8%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782162731000.webp","sourceId":"rfi"},{"id":1782162453000,"createdDate":"2026-06-22 21:07","name":"法国国际广播电台","title":"欧洲遭遇强烈热浪袭击 法国创6月历史最高温纪录","content":"欧洲大部分地区正遭受强烈热浪侵袭。法国周一（6月22日）创下多项高温纪录，其中全国平均气温达到有记录以来6月份最高水平，多地刷新历史最高气温纪录。与此同时，西班牙、德国、英国等国纷纷启动应急措施，以减轻极端高温带来的影响。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260622-%E6%AC%A7%E6%B4%B2%E9%81%AD%E9%81%87%E5%BC%BA%E7%83%88%E7%83%AD%E6%B5%AA%E8%A2%AD%E5%87%BB-%E6%B3%95%E5%9B%BD%E5%88%9B6%E6%9C%88%E5%8E%86%E5%8F%B2%E6%9C%80%E9%AB%98%E6%B8%A9%E7%BA%AA%E5%BD%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782162453000.webp","sourceId":"rfi"},{"id":1782160701000,"createdDate":"2026-06-22 20:38","name":"法国国际广播电台","title":"伯纳姆有望在7月17日或18日出任英国首相","content":"英国工党领袖斯塔默周一宣布辞职，此前他已承受了数月的压力。资深工党政治家安迪·伯纳姆成为最有可能成为英国十年来第七位首相的人选。伯纳姆可能在不到三个多星期的时间里入主首相府唐宁街10号。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260622-%E4%BC%AF%E7%BA%B3%E5%A7%86%E6%9C%89%E6%9C%9B%E5%9C%A87%E6%9C%8817%E6%97%A5%E6%88%9618%E6%97%A5%E5%87%BA%E4%BB%BB%E8%8B%B1%E5%9B%BD%E9%A6%96%E7%9B%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782160701000.webp","sourceId":"rfi"},{"id":1782154654000,"createdDate":"2026-06-22 18:57","name":"法国国际广播电台","title":"鲁比奥将访问海湾三国会晤盟友","content":"美国国务卿马可·鲁比奥（MarcoRubio）本周将展开上任后首次重要中东出访，前往阿拉伯联合大公国、科威特与巴林，与多个海湾盟友进行密集会谈，重点包括美国与伊朗之间最新停火框架、区域安全安排，以及全球能源命脉霍尔木兹海峡（StraitofHormuz）的航运安全问题。此次访问被视为美国总统特朗普（DonaldTrump）政府在推动与伊朗达成临时协议后，巩固外交成果并安抚区域盟友的重要行动。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260622-%E9%B2%81%E6%AF%94%E5%A5%A5%E5%B0%86%E8%AE%BF%E9%97%AE%E6%B5%B7%E6%B9%BE%E4%B8%89%E5%9B%BD%E4%BC%9A%E6%99%A4%E7%9B%9F%E5%8F%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782154654000.webp","sourceId":"rfi"},{"id":1782126780000,"createdDate":"2026-06-22 11:13","name":"法国国际广播电台","title":"喀麦隆揭露影子油轮悬挂其国旗","content":"非洲国家喀麦隆当局抗议影子油轮悬挂其旗帜的行为。本台法广非洲组（RFIAfrique）报道说，雅温得当局于两年前承诺，要查明帮助俄罗斯规避欧洲对其石油产品制裁的船只。欧盟为此拨款1500万欧元。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260622-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%96%80%E9%BA%A6%E9%9A%86%E6%8F%AD%E9%9C%B2%E5%BD%B1%E5%AD%90%E6%B2%B9%E8%BD%AE%E6%82%AC%E6%8C%82%E5%85%B6%E5%9B%BD%E6%97%97","thumbnail":"","detailImage":"news/detail/rfi/2026/06/22/1782126780000.webp","sourceId":"rfi"}]