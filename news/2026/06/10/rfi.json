[{"id":1781085265000,"createdDate":"2026-06-10 09:54","name":"法国国际广播电台","title":"乌扩大对俄纵深打击，近千公里外行动涉俄军工设施及“影子船队”油轮，国防预算创新高","content":"2026年6月10日，乌克兰武装部队总参谋部发布消息称，当天夜间，乌克兰国防力量对俄境内多个与军事工业及燃料能源体系相关的重要目标实施打击，其中包括俄罗斯“影子船队”的一艘油轮。乌克兰武装部队总参谋部在通报中表示，将继续削弱俄罗斯发动对乌战争的能力，并对其军事潜力进行打击。同一天，乌克兰议会批准了对2026年预算的修订，为创纪录的国防开支铺路。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260610-%E4%B9%8C%E6%89%A9%E5%A4%A7%E5%AF%B9%E4%BF%84%E7%BA%B5%E6%B7%B1%E6%89%93%E5%87%BB%EF%BC%8C%E8%BF%91%E5%8D%83%E5%85%AC%E9%87%8C%E5%A4%96%E8%A1%8C%E5%8A%A8%E6%B6%89%E4%BF%84%E5%86%9B%E5%B7%A5%E8%AE%BE%E6%96%BD%E5%8F%8A-%E5%BD%B1%E5%AD%90%E8%88%B9%E9%98%9F-%E6%B2%B9%E8%BD%AE%EF%BC%8C%E5%9B%BD%E9%98%B2%E9%A2%84%E7%AE%97%E5%88%9B%E6%96%B0%E9%AB%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781085265000.webp","sourceId":"rfi"},{"id":1781084145000,"createdDate":"2026-06-10 09:35","name":"法国国际广播电台","title":"五角大楼将天合光能和亿纬锂能等太阳能、电池企业同列入“中国军事公司”名单","content":"美国已将一些全球最大的太阳能和电池制造商列入其认为正在协助中国军方的公司名单中。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260610-%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC%E5%B0%86%E5%A4%A9%E5%90%88%E5%85%89%E8%83%BD%E5%92%8C%E4%BA%BF%E7%BA%AC%E9%94%82%E8%83%BD%E7%AD%89%E5%A4%AA%E9%98%B3%E8%83%BD-%E7%94%B5%E6%B1%A0%E4%BC%81%E4%B8%9A%E5%90%8C%E5%88%97%E5%85%A5-%E4%B8%AD%E5%9B%BD%E5%86%9B%E4%BA%8B%E5%85%AC%E5%8F%B8-%E5%90%8D%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781084145000.webp","sourceId":"rfi"},{"id":1781082251000,"createdDate":"2026-06-10 09:04","name":"法国国际广播电台","title":"欧盟对俄新制裁将限制多家中企 北京：密切关注有关动向","content":"欧盟委员会主席冯德莱恩（UrsulavonderLeyen）周二表示，已向各成员国提交了第21轮对俄罗斯制裁方案，主要涉及能源、金融服务和加密货币、贸易——首次将渔业纳入制裁范围，并且禁止前俄罗斯战斗人员进入欧盟等方面。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260610-%E6%AC%A7%E7%9B%9F%E5%AF%B9%E4%BF%84%E6%96%B0%E5%88%B6%E8%A3%81%E5%B0%86%E9%99%90%E5%88%B6%E5%A4%9A%E5%AE%B6%E4%B8%AD%E4%BC%81-%E5%8C%97%E4%BA%AC-%E5%AF%86%E5%88%87%E5%85%B3%E6%B3%A8%E6%9C%89%E5%85%B3%E5%8A%A8%E5%90%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781082251000.webp","sourceId":"rfi"},{"id":1781081204000,"createdDate":"2026-06-10 08:46","name":"法国国际广播电台","title":"习近平访问后 平壤提及两国关系“雄心勃勃的路线图”","content":"据朝鲜官方通讯社朝中社周三（6月10号）报道，中国国家主席习近平本周访问朝鲜期间，北京和平壤制定了双边关系“雄心勃勃的路线图”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260610-%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%BF%E9%97%AE%E5%90%8E-%E5%B9%B3%E5%A3%A4%E6%8F%90%E5%8F%8A%E4%B8%AD%E6%9C%9D%E5%85%B3%E7%B3%BB-%E9%9B%84%E5%BF%83%E5%8B%83%E5%8B%83%E7%9A%84%E8%B7%AF%E7%BA%BF%E5%9B%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781081204000.webp","sourceId":"rfi"},{"id":1781080073000,"createdDate":"2026-06-10 08:27","name":"法国国际广播电台","title":"日本首相与马来西亚总理举行会谈 就能源与安保合作达成共识","content":"6月8日至10日，马来西亚总理安瓦尔·易卜拉欣（AnwarIbrahim）作为工作访问宾客访问日本。日本时间6月10日上午11时45分起约30分钟，日本首相高市早苗与易卜拉欣举行了日马首脑会谈，随后举行了联合记者会和工作午餐会。会谈结束后，两国领导人发表了《日马联合声明》,两国政府还签署了两国海上保安机构之间的合作谅解备忘录，双方就能源合作及强化对包括马六甲海峡在内海上交通线（SeaLanes）的安全保障达成共识。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260610-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E4%B8%8E%E8%8F%B2%E5%BE%8B%E5%AE%BE%E6%80%BB%E7%90%86%E4%B8%BE%E8%A1%8C%E4%BC%9A%E8%B0%88-%E5%B0%B1%E8%83%BD%E6%BA%90%E4%B8%8E%E5%AE%89%E4%BF%9D%E5%90%88%E4%BD%9C%E8%BE%BE%E6%88%90%E5%85%B1%E8%AF%86","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781080073000.webp","sourceId":"rfi"},{"id":1781079493000,"createdDate":"2026-06-10 08:18","name":"法国国际广播电台","title":"中国把日本定位为“新军国主义” 日中关系举步维艰","content":"自从日本首相高市早苗在去年11月7日举行的众议院预算委员会会议上，被问及在中国对台湾发动军事进攻的“台湾有事”的情况下，此事是否会根据《安全保障相关法》的规定，构成可行使集体自卫权的“存立危机事态”时表示：“如果涉及武力行使，我认为这可能属于‘存立危机事态’的情形。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260610-%E4%B8%AD%E5%9B%BD%E6%8A%8A%E6%97%A5%E6%9C%AC%E5%AE%9A%E4%BD%8D%E4%B8%BA-%E6%96%B0%E5%86%9B%E5%9B%BD%E4%B8%BB%E4%B9%89-%E6%97%A5%E4%B8%AD%E5%85%B3%E7%B3%BB%E4%B8%BE%E6%AD%A5%E7%BB%B4%E8%89%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781079493000.webp","sourceId":"rfi"},{"id":1781074351000,"createdDate":"2026-06-10 06:52","name":"法国国际广播电台","title":"两天急过法例 赋权特首把任何刑事行为以国安案处理 且可追溯国安法前行为","content":"港府赋权行政长官(又称特首)可以将任何刑事行为列为「国家安全案件」处理的附属法例，昨(9日)天经行政会议通过後，已刊登宪报即日生效，意味该条例由公布至生效只有短短两天。而宪报刊登的条文显示，特首的相关权力可追溯至《港区国安法》生效前的行为或检控。法律学者认为，新例涉宪制问题，须深究；国际特赦组织香港海外分会亦发声明，忧虑港府有意大规模动用此广泛权力，以致被告在法律程序上的每一阶段权利将受到严重损害。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260610-%E4%B8%A4%E5%A4%A9%E6%80%A5%E8%BF%87%E6%B3%95%E4%BE%8B-%E8%B5%8B%E6%9D%83%E7%89%B9%E9%A6%96%E6%8A%8A%E4%BB%BB%E4%BD%95%E5%88%91%E4%BA%8B%E8%A1%8C%E4%B8%BA%E4%BB%A5%E5%9B%BD%E5%AE%89%E6%A1%88%E5%A4%84%E7%90%86-%E4%B8%94%E5%8F%AF%E8%BF%BD%E6%BA%AF%E5%9B%BD%E5%AE%89%E6%B3%95%E5%89%8D%E8%A1%8C%E4%B8%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781074351000.webp","sourceId":"rfi"},{"id":1781073904000,"createdDate":"2026-06-10 06:45","name":"法国国际广播电台","title":"著名电影人黄百鸣内幕交易罪成 判囚五个月","content":"制作人香港著名导演兼制作人黄百鸣，多年前在出售公司控股前，怂使胞妹购入公司股票进行内幕交易，经审讯後裁定罪名成立，昨(9日)被法庭判监五个月，并须付罚款及调查费47.4万港元(下同，折算约5.3万欧元)。黄百鸣一方不服裁决，获法官批准保释出外等候上诉。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260610-%E8%91%97%E5%90%8D%E7%94%B5%E5%BD%B1%E4%BA%BA%E9%BB%84%E7%99%BE%E9%B8%A3%E5%86%85%E5%B9%95%E4%BA%A4%E6%98%93%E7%BD%AA%E6%88%90-%E5%88%A4%E5%9B%9A%E4%BA%94%E4%B8%AA%E6%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781073904000.webp","sourceId":"rfi"}]