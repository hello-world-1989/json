[{"id":1781085265000,"createdDate":"2026-06-10 09:54","name":"法国国际广播电台","title":"乌扩大对俄纵深打击，近千公里外行动涉俄军工设施及“影子船队”油轮，国防预算创新高","content":"2026年6月10日，乌克兰武装部队总参谋部发布消息称，当天夜间，乌克兰国防力量对俄境内多个与军事工业及燃料能源体系相关的重要目标实施打击，其中包括俄罗斯“影子船队”的一艘油轮。乌克兰武装部队总参谋部在通报中表示，将继续削弱俄罗斯发动对乌战争的能力，并对其军事潜力进行打击。同一天，乌克兰议会批准了对2026年预算的修订，为创纪录的国防开支铺路。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260610-%E4%B9%8C%E6%89%A9%E5%A4%A7%E5%AF%B9%E4%BF%84%E7%BA%B5%E6%B7%B1%E6%89%93%E5%87%BB%EF%BC%8C%E8%BF%91%E5%8D%83%E5%85%AC%E9%87%8C%E5%A4%96%E8%A1%8C%E5%8A%A8%E6%B6%89%E4%BF%84%E5%86%9B%E5%B7%A5%E8%AE%BE%E6%96%BD%E5%8F%8A-%E5%BD%B1%E5%AD%90%E8%88%B9%E9%98%9F-%E6%B2%B9%E8%BD%AE%EF%BC%8C%E5%9B%BD%E9%98%B2%E9%A2%84%E7%AE%97%E5%88%9B%E6%96%B0%E9%AB%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781085265000.webp","sourceId":"rfi"},{"id":1781084145000,"createdDate":"2026-06-10 09:35","name":"法国国际广播电台","title":"五角大楼将天合光能和亿纬锂能等太阳能、电池企业同列入“中国军事公司”名单","content":"美国已将一些全球最大的太阳能和电池制造商列入其认为正在协助中国军方的公司名单中。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260610-%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC%E5%B0%86%E5%A4%A9%E5%90%88%E5%85%89%E8%83%BD%E5%92%8C%E4%BA%BF%E7%BA%AC%E9%94%82%E8%83%BD%E7%AD%89%E5%A4%AA%E9%98%B3%E8%83%BD-%E7%94%B5%E6%B1%A0%E4%BC%81%E4%B8%9A%E5%90%8C%E5%88%97%E5%85%A5-%E4%B8%AD%E5%9B%BD%E5%86%9B%E4%BA%8B%E5%85%AC%E5%8F%B8-%E5%90%8D%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781084145000.webp","sourceId":"rfi"},{"id":1781082251000,"createdDate":"2026-06-10 09:04","name":"法国国际广播电台","title":"欧盟对俄新制裁将限制多家中企 北京：密切关注有关动向","content":"欧盟委员会主席冯德莱恩（UrsulavonderLeyen）周二表示，已向各成员国提交了第21轮对俄罗斯制裁方案，主要涉及能源、金融服务和加密货币、贸易——首次将渔业纳入制裁范围，并且禁止前俄罗斯战斗人员进入欧盟等方面。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260610-%E6%AC%A7%E7%9B%9F%E5%AF%B9%E4%BF%84%E6%96%B0%E5%88%B6%E8%A3%81%E5%B0%86%E9%99%90%E5%88%B6%E5%A4%9A%E5%AE%B6%E4%B8%AD%E4%BC%81-%E5%8C%97%E4%BA%AC-%E5%AF%86%E5%88%87%E5%85%B3%E6%B3%A8%E6%9C%89%E5%85%B3%E5%8A%A8%E5%90%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781082251000.webp","sourceId":"rfi"},{"id":1781081204000,"createdDate":"2026-06-10 08:46","name":"法国国际广播电台","title":"习近平访问后 平壤提及两国关系“雄心勃勃的路线图”","content":"据朝鲜官方通讯社朝中社周三（6月10号）报道，中国国家主席习近平本周访问朝鲜期间，北京和平壤制定了双边关系“雄心勃勃的路线图”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260610-%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%BF%E9%97%AE%E5%90%8E-%E5%B9%B3%E5%A3%A4%E6%8F%90%E5%8F%8A%E4%B8%AD%E6%9C%9D%E5%85%B3%E7%B3%BB-%E9%9B%84%E5%BF%83%E5%8B%83%E5%8B%83%E7%9A%84%E8%B7%AF%E7%BA%BF%E5%9B%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781081204000.webp","sourceId":"rfi"},{"id":1781080073000,"createdDate":"2026-06-10 08:27","name":"法国国际广播电台","title":"日本首相与马来西亚总理举行会谈 就能源与安保合作达成共识","content":"6月8日至10日，马来西亚总理安瓦尔·易卜拉欣（AnwarIbrahim）作为工作访问宾客访问日本。日本时间6月10日上午11时45分起约30分钟，日本首相高市早苗与易卜拉欣举行了日马首脑会谈，随后举行了联合记者会和工作午餐会。会谈结束后，两国领导人发表了《日马联合声明》,两国政府还签署了两国海上保安机构之间的合作谅解备忘录，双方就能源合作及强化对包括马六甲海峡在内海上交通线（SeaLanes）的安全保障达成共识。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260610-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E4%B8%8E%E8%8F%B2%E5%BE%8B%E5%AE%BE%E6%80%BB%E7%90%86%E4%B8%BE%E8%A1%8C%E4%BC%9A%E8%B0%88-%E5%B0%B1%E8%83%BD%E6%BA%90%E4%B8%8E%E5%AE%89%E4%BF%9D%E5%90%88%E4%BD%9C%E8%BE%BE%E6%88%90%E5%85%B1%E8%AF%86","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781080073000.webp","sourceId":"rfi"},{"id":1781079493000,"createdDate":"2026-06-10 08:18","name":"法国国际广播电台","title":"中国把日本定位为“新军国主义” 日中关系举步维艰","content":"自从日本首相高市早苗在去年11月7日举行的众议院预算委员会会议上，被问及在中国对台湾发动军事进攻的“台湾有事”的情况下，此事是否会根据《安全保障相关法》的规定，构成可行使集体自卫权的“存立危机事态”时表示：“如果涉及武力行使，我认为这可能属于‘存立危机事态’的情形。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260610-%E4%B8%AD%E5%9B%BD%E6%8A%8A%E6%97%A5%E6%9C%AC%E5%AE%9A%E4%BD%8D%E4%B8%BA-%E6%96%B0%E5%86%9B%E5%9B%BD%E4%B8%BB%E4%B9%89-%E6%97%A5%E4%B8%AD%E5%85%B3%E7%B3%BB%E4%B8%BE%E6%AD%A5%E7%BB%B4%E8%89%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781079493000.webp","sourceId":"rfi"},{"id":1781074351000,"createdDate":"2026-06-10 06:52","name":"法国国际广播电台","title":"两天急过法例 赋权特首把任何刑事行为以国安案处理 且可追溯国安法前行为","content":"港府赋权行政长官(又称特首)可以将任何刑事行为列为「国家安全案件」处理的附属法例，昨(9日)天经行政会议通过後，已刊登宪报即日生效，意味该条例由公布至生效只有短短两天。而宪报刊登的条文显示，特首的相关权力可追溯至《港区国安法》生效前的行为或检控。法律学者认为，新例涉宪制问题，须深究；国际特赦组织香港海外分会亦发声明，忧虑港府有意大规模动用此广泛权力，以致被告在法律程序上的每一阶段权利将受到严重损害。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260610-%E4%B8%A4%E5%A4%A9%E6%80%A5%E8%BF%87%E6%B3%95%E4%BE%8B-%E8%B5%8B%E6%9D%83%E7%89%B9%E9%A6%96%E6%8A%8A%E4%BB%BB%E4%BD%95%E5%88%91%E4%BA%8B%E8%A1%8C%E4%B8%BA%E4%BB%A5%E5%9B%BD%E5%AE%89%E6%A1%88%E5%A4%84%E7%90%86-%E4%B8%94%E5%8F%AF%E8%BF%BD%E6%BA%AF%E5%9B%BD%E5%AE%89%E6%B3%95%E5%89%8D%E8%A1%8C%E4%B8%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781074351000.webp","sourceId":"rfi"},{"id":1781073904000,"createdDate":"2026-06-10 06:45","name":"法国国际广播电台","title":"著名电影人黄百鸣内幕交易罪成 判囚五个月","content":"制作人香港著名导演兼制作人黄百鸣，多年前在出售公司控股前，怂使胞妹购入公司股票进行内幕交易，经审讯後裁定罪名成立，昨(9日)被法庭判监五个月，并须付罚款及调查费47.4万港元(下同，折算约5.3万欧元)。黄百鸣一方不服裁决，获法官批准保释出外等候上诉。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260610-%E8%91%97%E5%90%8D%E7%94%B5%E5%BD%B1%E4%BA%BA%E9%BB%84%E7%99%BE%E9%B8%A3%E5%86%85%E5%B9%95%E4%BA%A4%E6%98%93%E7%BD%AA%E6%88%90-%E5%88%A4%E5%9B%9A%E4%BA%94%E4%B8%AA%E6%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781073904000.webp","sourceId":"rfi"},{"id":1781110319000,"createdDate":"2026-06-10 16:51","name":"法国国际广播电台","title":"巴亚尔观点：“中国第二次拯救了世界经济”","content":"2008年危机后，中国经济复苏支撑了全球经济。这一次，中国正凭借其庞大的储备来缓冲石油冲击。《费加罗报》各界之声栏目于周三6月10日推出这篇由该报资深经济主编BertilleBayart执笔的观点文章。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260610-%E5%B7%B4%E4%BA%9A%E5%B0%94%E8%A7%82%E7%82%B9-%E4%B8%AD%E5%9B%BD%E7%AC%AC%E4%BA%8C%E6%AC%A1%E6%8B%AF%E6%95%91%E4%BA%86%E4%B8%96%E7%95%8C%E7%BB%8F%E6%B5%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781110319000.webp","sourceId":"rfi"},{"id":1781106700000,"createdDate":"2026-06-10 15:51","name":"法国国际广播电台","title":"国际原子能机构通过决议要伊朗申报剩余浓缩铀储量 中俄尼日尔三票反对","content":"由35个成员国组成的国际原子能机构理事会周三通过了一项由美国支持的决议，要求伊朗申报其剩余的浓缩铀库存，并接受核查人员的核实。此举可能会使华盛顿与德黑兰的谈判复杂化。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260610-%E5%9B%BD%E9%99%85%E5%8E%9F%E5%AD%90%E8%83%BD%E6%9C%BA%E6%9E%84%E9%80%9A%E8%BF%87%E5%86%B3%E8%AE%AE%E8%A6%81%E4%BC%8A%E6%9C%97%E7%94%B3%E6%8A%A5%E5%89%A9%E4%BD%99%E6%B5%93%E7%BC%A9%E9%93%80%E5%82%A8%E9%87%8F-%E4%BF%84%E4%B8%AD%E5%B0%BC%E6%97%A5%E5%B0%94%E4%B8%89%E7%A5%A8%E5%8F%8D%E5%AF%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781106700000.webp","sourceId":"rfi"},{"id":1781105333000,"createdDate":"2026-06-10 15:28","name":"法国国际广播电台","title":"捷克国防部限制中国汽车进入敏感军事区域","content":"据捷克媒体《新闻列表》（SeznamZprávy）报导称，捷克国防部与总参谋部合作，已下令限制中国制造的汽车进入敏感军事区域。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260610-%E6%8D%B7%E5%85%8B%E5%9B%BD%E9%98%B2%E9%83%A8%E9%99%90%E5%88%B6%E4%B8%AD%E5%9B%BD%E6%B1%BD%E8%BD%A6%E8%BF%9B%E5%85%A5%E6%95%8F%E6%84%9F%E5%86%9B%E4%BA%8B%E5%8C%BA%E5%9F%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781105333000.webp","sourceId":"rfi"},{"id":1781103754000,"createdDate":"2026-06-10 15:02","name":"法国国际广播电台","title":"欧洲加紧防御俄罗斯，空客牵头的8家企业6月11日在柏林展示下一代战斗机计划","content":"由空客公司牵头的一组企业将于周四在柏林展示其下一代战斗机计划，希望取代本周被取消的法德联合未来空中作战系统（FCAS）项目。德国政府发言人周三表示，“一扇门关上了，另一扇门就会打开”。空客公司周三告诉法新社，这个名为“第六代团队”（TeamGen6）的八家公司联盟计划在柏林郊外的国际航空航天展览会（ILA）上举行签约仪式。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260610-%E6%AC%A7%E6%B4%B2%E5%8A%A0%E7%B4%A7%E9%98%B2%E5%BE%A1%E4%BF%84%E7%BD%97%E6%96%AF%EF%BC%8C%E7%A9%BA%E5%AE%A2%E7%89%B5%E5%A4%B4%E7%9A%848%E5%AE%B6%E4%BC%81%E4%B8%9A6%E6%9C%8811%E6%97%A5%E5%9C%A8%E6%9F%8F%E6%9E%97%E5%B1%95%E7%A4%BA%E4%B8%8B%E4%B8%80%E4%BB%A3%E6%88%98%E6%96%97%E6%9C%BA%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781103754000.webp","sourceId":"rfi"},{"id":1781102565000,"createdDate":"2026-06-10 14:42","name":"法国国际广播电台","title":"战争纪念馆活动海报提“抗美援朝”引争议 韩防长下令彻查 在野党表愤怒震惊","content":"韩国国防部下属战争纪念事业会运营的首尔龙山战争纪念馆，为迎接6月护国报勋月，原计划推出对比韩战韩中视角的专项讲解项目，引发巨大争议，原因是其在一张宣传海报中使用了中方对韩战的宣传叙事。该活动宣传材料配图为身穿韩国校服的韩国儿童与身穿现代式红色运动服的中国儿童，上方配文分别为“6·25战争”与中方参战宣传用语“抗美援朝”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260610-%E6%88%98%E4%BA%89%E7%BA%AA%E5%BF%B5%E9%A6%86%E6%B4%BB%E5%8A%A8%E6%B5%B7%E6%8A%A5%E6%8F%90-%E6%8A%97%E7%BE%8E%E6%8F%B4%E6%9C%9D-%E5%BC%95%E5%B7%A8%E5%A4%A7%E4%BA%89%E8%AE%AE-%E9%9F%A9%E9%98%B2%E9%95%BF%E4%B8%8B%E4%BB%A4%E5%BD%BB%E6%9F%A5-%E5%9C%A8%E9%87%8E%E5%85%9A%E8%A1%A8%E6%84%A4%E6%80%92%E9%9C%87%E6%83%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781102565000.webp","sourceId":"rfi"},{"id":1781097309000,"createdDate":"2026-06-10 13:15","name":"法国国际广播电台","title":"日防卫省新版《防卫白皮书》再指中国是最大战略挑战 提加强与志同道合国家合作","content":"日本防务省在2026年版《防卫白皮书》（以下简称白皮书）中明确指出，将加强与美国等盟友和志同道合国家的合作，以提升威慑和应对能力来“确保地区稳定”。白皮书还将阐述中国和朝鲜等国的军事发展动态。关于中国，白皮书将指出，中国是“一个令人深刻忧虑的问题，也是最大的战略挑战”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260610-%E6%97%A5%E9%98%B2%E5%8D%AB%E7%9C%81%E6%96%B0%E7%89%88-%E9%98%B2%E5%8D%AB%E7%99%BD%E7%9A%AE%E4%B9%A6-%E5%86%8D%E6%8C%87%E4%B8%AD%E5%9B%BD%E6%98%AF%E6%9C%80%E5%A4%A7%E6%88%98%E7%95%A5%E6%8C%91%E6%88%98-%E6%8F%90%E5%8A%A0%E5%BC%BA%E4%B8%8E%E5%BF%97%E5%90%8C%E9%81%93%E5%90%88%E5%9B%BD%E5%AE%B6%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781097309000.webp","sourceId":"rfi"},{"id":1781093972000,"createdDate":"2026-06-10 12:19","name":"法国国际广播电台","title":"当中国等贸易顺差国与美国等贸易逆差国之间缺乏合作时，全球经济风险是......","content":"大家好，今天是6月10日星期三，欢迎收听法国报纸摘要。《解放报》持续关注在法国对于妇女与儿童的暴力问题，据该报指出从难以承受的悲剧到政治危机，或者说一名11岁女孩的离世，既是一面镜子，恐怕也成了不断加深的互不信任的催化剂。同时在大西洋岸的另一头特朗普正面临伊朗、通胀、支持率等接踵而至的困境，美国建国250周年纪念日正与他的80岁生日同为6月14日，这一巧合则成为《费加罗报》头版焦点；中国方面该报报道马克龙将于周四主持召开视频会议，中国也将参与其中，旨在七国集团峰会前加强全球经济“合作”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260610-%E5%BD%93%E4%B8%AD%E5%9B%BD%E7%AD%89%E8%B4%B8%E6%98%93%E9%A1%BA%E5%B7%AE%E5%9B%BD%E4%B8%8E%E7%BE%8E%E5%9B%BD%E7%AD%89%E8%B4%B8%E6%98%93%E9%80%86%E5%B7%AE%E5%9B%BD%E4%B9%8B%E9%97%B4%E7%BC%BA%E4%B9%8F%E5%90%88%E4%BD%9C%E6%97%B6-%E5%85%A8%E7%90%83%E7%BB%8F%E6%B5%8E%E6%9C%89%E4%BD%95%E9%A3%8E%E9%99%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781093972000.webp","sourceId":"rfi"},{"id":1781092102000,"createdDate":"2026-06-10 11:48","name":"法国国际广播电台","title":"韩国泰安海警已将董广平移送检方","content":"韩国泰安海洋警察署周三表示，已将因乘橡皮艇擅自进入韩国领海被拘留的中国异见人士董广平移送检方，但未对其实施逮捕。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260610-%E9%9F%A9%E5%9B%BD%E6%B3%B0%E5%AE%89%E6%B5%B7%E8%AD%A6%E5%B0%86%E8%91%A3%E5%B9%BF%E5%B9%B3%E7%A7%BB%E9%80%81%E6%A3%80%E6%96%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781092102000.webp","sourceId":"rfi"},{"id":1781087600000,"createdDate":"2026-06-10 10:33","name":"法国国际广播电台","title":"美菲日三方对话深化海事和安全关系 菲外长：须继续与日本进行划界谈判","content":"美国国务院表示，美国、菲律宾和日本正寻求深化海事和安全关系，包括通过“三方协同”对外援助。6月8日，美菲日代表在马尼拉举行了第二次三方海事对话。会上，美菲日高级官员重申了在当前地区形势下三国伙伴关系的重要性。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260610-%E7%BE%8E%E8%8F%B2%E6%97%A5%E4%B8%89%E6%96%B9%E5%AF%B9%E8%AF%9D%E6%B7%B1%E5%8C%96%E6%B5%B7%E4%BA%8B%E5%92%8C%E5%AE%89%E5%85%A8%E5%85%B3%E7%B3%BB-%E8%8F%B2%E5%A4%96%E9%95%BF-%E9%A1%BB%E7%BB%A7%E7%BB%AD%E4%B8%8E%E6%97%A5%E6%9C%AC%E8%BF%9B%E8%A1%8C%E5%88%92%E7%95%8C%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781087600000.webp","sourceId":"rfi"},{"id":1781086691000,"createdDate":"2026-06-10 10:18","name":"法国国际广播电台","title":"台湾举行反入侵演习 用海马士多管火箭进行实弹射击","content":"台湾军方今天周三试射了其新型机动式海马士多管火箭炮系统，该系统也被乌克兰广泛使用，台湾本次进行的实弹演习模拟了对入侵台湾的中国军队的攻击进行了试射，展示了该系统可以“打了就跑”的能力，即通过规避反击来迅速撤离。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260610-%E5%8F%B0%E6%B9%BE%E4%B8%BE%E8%A1%8C%E5%8F%8D%E5%85%A5%E4%BE%B5%E6%BC%94%E4%B9%A0-%E7%94%A8%E6%B5%B7%E9%A9%AC%E5%A3%AB%E5%A4%9A%E7%AE%A1%E7%81%AB%E7%AE%AD%E8%BF%9B%E8%A1%8C%E5%AE%9E%E5%BC%B9%E5%B0%84%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781086691000.webp","sourceId":"rfi"},{"id":1781086683000,"createdDate":"2026-06-10 10:18","name":"法国国际广播电台","title":"11小时盘问后遭遣返：首位世界杯索马里裁判持合法美签，却无缘赛场","content":"2026年世界杯开赛前夕，一起涉及索马里裁判被美国拒绝入境的事件在国际足坛引发关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260610-11%E5%B0%8F%E6%97%B6%E7%9B%98%E9%97%AE%E5%90%8E%E9%81%AD%E9%81%A3%E8%BF%94-%E9%A6%96%E4%BD%8D%E4%B8%96%E7%95%8C%E6%9D%AF%E7%B4%A2%E9%A9%AC%E9%87%8C%E8%A3%81%E5%88%A4%E6%8C%81%E5%90%88%E6%B3%95%E7%AD%BE%E8%AF%81%EF%BC%8C%E5%8D%B4%E6%97%A0%E7%BC%98%E8%B5%9B%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/10/1781086683000.webp","sourceId":"rfi"}]