[{"id":1782464089000,"createdDate":"2026-06-26 08:54","name":"法国国际广播电台","title":"新西兰警告：中国在太平洋地区军事部署恐“常态化”","content":"据法新社获得的一份内部文件显示，新西兰官员警告称，随着北京加强其在太平洋地区的军事存在，中国海军的弹道导弹试验和行动将成为太平洋地区的“常态性”特征。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260626-%E6%96%B0%E8%A5%BF%E5%85%B0%E8%AD%A6%E5%91%8A-%E4%B8%AD%E5%9B%BD%E5%9C%A8%E5%A4%AA%E5%B9%B3%E6%B4%8B%E5%9C%B0%E5%8C%BA%E5%86%9B%E4%BA%8B%E9%83%A8%E7%BD%B2%E6%81%90-%E5%B8%B8%E6%80%81%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782464089000.webp","sourceId":"rfi"},{"id":1782463961000,"createdDate":"2026-06-26 08:52","name":"法国国际广播电台","title":"美国务院高官：美中会谈中方必提军售问题，未背离“六项保证”","content":"尽管特朗普总统曾有此暗示，但美国国务院负责东亚事务的高级外交官周四表示，向美国国会提交的对台军售通知并不取决于与北京方面的磋商。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260626-%E7%BE%8E%E5%9B%BD%E5%8A%A1%E9%99%A2%E9%AB%98%E5%AE%98-%E7%BE%8E%E4%B8%AD%E4%BC%9A%E8%B0%88%E4%B8%AD%E6%96%B9%E5%BF%85%E6%8F%90%E5%86%9B%E5%94%AE%E9%97%AE%E9%A2%98%EF%BC%8C%E6%9C%AA%E8%83%8C%E7%A6%BB-%E5%85%AD%E9%A1%B9%E4%BF%9D%E8%AF%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782463961000.webp","sourceId":"rfi"},{"id":1782463688000,"createdDate":"2026-06-26 08:48","name":"法国国际广播电台","title":"热浪天：易怒情绪加剧、抑郁症和精神病病例增加、精神崩溃……人们的心理健康受考验","content":"热浪酷暑天会对我们的心理健康造成了严重影响，尤其是对精神疾病患者而言，他们更容易受到高温的影响；根据一名精神科医生指，“气温变化就像压垮骆驼的最后一根稻草。”","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260626-%E7%83%AD%E6%B5%AA%E5%A4%A9-%E6%98%93%E6%80%92%E6%83%85%E7%BB%AA%E5%8A%A0%E5%89%A7-%E6%8A%91%E9%83%81%E7%97%87%E5%92%8C%E7%B2%BE%E7%A5%9E%E7%97%85%E7%97%85%E4%BE%8B%E5%A2%9E%E5%8A%A0-%E7%B2%BE%E7%A5%9E%E5%B4%A9%E6%BA%83-%E4%BA%BA%E4%BB%AC%E7%9A%84%E5%BF%83%E7%90%86%E5%81%A5%E5%BA%B7%E5%8F%97%E8%80%83%E9%AA%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782463688000.webp","sourceId":"rfi"},{"id":1782463060000,"createdDate":"2026-06-26 08:37","name":"法国国际广播电台","title":"日本通过法律 航空自卫队改为“航空宇宙自卫队”","content":"包含将航空自卫队重新改编为“航空宇宙自卫队”等内容的《防卫省设置法》等修正案，已于6月26日在日本参议院全体会议上获得通过并正式成立。这是自航空自卫队于1954年成立以来，首次更改组织名称。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260626-%E6%97%A5%E6%9C%AC%E9%80%9A%E8%BF%87%E6%B3%95%E5%BE%8B-%E8%88%AA%E7%A9%BA%E8%87%AA%E5%8D%AB%E9%98%9F%E6%94%B9%E4%B8%BA-%E8%88%AA%E7%A9%BA%E5%AE%87%E5%AE%99%E8%87%AA%E5%8D%AB%E9%98%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782463060000.webp","sourceId":"rfi"},{"id":1782458855000,"createdDate":"2026-06-26 07:27","name":"法国国际广播电台","title":"调查：中国跨境镇压遍布五洲41国 印度香港多人受压","content":"备受跨境镇压指控困扰的中国，今日再添一笔。一个针对全球的人权调查显示，中国在41个国家或地区有实行跨境镇压，最受影响的，是不丹丶印度及香港等地人民，当中尤以身处海外丶倡导民主的中国公民最能肯定成为目标。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260626-%E8%B0%83%E6%9F%A5-%E4%B8%AD%E5%9B%BD%E8%B7%A8%E5%A2%83%E9%95%87%E5%8E%8B%E9%81%8D%E5%B8%83%E4%BA%94%E6%B4%B241%E5%9B%BD-%E5%8D%B0%E5%BA%A6%E9%A6%99%E6%B8%AF%E5%A4%9A%E4%BA%BA%E5%8F%97%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782458855000.webp","sourceId":"rfi"},{"id":1782458604000,"createdDate":"2026-06-26 07:23","name":"法国国际广播电台","title":"人权评量：台湾去年领先 中港自由享受同属最差 负责人料今年再差","content":"根据位於纽西兰的人权组织的年度报告显示，中国在人身完整性方面的人权评分於2025年虽略有改善，但基本仍然处於「很差」的区间；而受中国影响日深的香港，相关评分虽仍留在「一般」级别，但评分已较之前微降至7.2分。组织的东亚区负责人潘嘉伟向本台指出，中港两地在享受自由方面的人权赋权只有2到3分，属「很差」，加上今年上半年已发生不少拘捕和打压事件，预料今年的人权评分会再差。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260626-%E4%BA%BA%E6%9D%83%E8%AF%84%E9%87%8F-%E5%8F%B0%E6%B9%BE%E5%8E%BB%E5%B9%B4%E9%A2%86%E5%85%88-%E4%B8%AD%E6%B8%AF%E8%87%AA%E7%94%B1%E4%BA%AB%E5%8F%97%E5%90%8C%E5%B1%9E%E6%9C%80%E5%B7%AE-%E8%B4%9F%E8%B4%A3%E4%BA%BA%E6%96%99%E4%BB%8A%E5%B9%B4%E5%86%8D%E5%B7%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782458604000.webp","sourceId":"rfi"},{"id":1782490068000,"createdDate":"2026-06-26 16:07","name":"法国国际广播电台","title":"被指处理密件不当   美前国家安全顾问波尔顿认罪","content":"博尔顿曾于2018年4月至2019年9月期间担任特朗普的国家安全顾问，多年来一直是特朗普的公开批评者。博尔顿被指控18项罪名，原本每项最高可判囚10年。据路透社报道，他与检方达成协议，以认罪换取无需坐牢或最高5年监禁的较轻量刑，最终刑期将由法官决定。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260626-%E8%A2%AB%E6%8C%87%E5%A4%84%E7%90%86%E5%AF%86%E4%BB%B6%E4%B8%8D%E5%BD%93-%E7%BE%8E%E5%89%8D%E5%9B%BD%E5%AE%B6%E5%AE%89%E5%85%A8%E9%A1%BE%E9%97%AE%E6%B3%A2%E5%B0%94%E9%A1%BF%E8%AE%A4%E7%BD%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782490068000.webp","sourceId":"rfi"},{"id":1782485261000,"createdDate":"2026-06-26 14:47","name":"法国国际广播电台","title":"美伊谈判：中国用何“利器”削弱美国制裁伊朗的杀伤力？","content":"当前，华盛顿寄希望于通过减轻对伊朗的制裁，换取德黑兰在核问题上的让步。但一个关键因素正在改变这场博弈的格局，那就是中国。因为，多年来，北京通过各种方式帮助伊朗绕开美国的金融封锁，让华盛顿的制裁威力大打折扣。今天5月26日的法国报摘节目，我们为您深入介绍这篇刊登在《快报》周刊国际版亚太栏目上的文章。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260626-%E7%BE%8E%E4%BC%8A%E8%B0%88%E5%88%A4-%E4%B8%AD%E5%9B%BD%E7%94%A8%E4%BD%95-%E5%88%A9%E5%99%A8-%E5%89%8A%E5%BC%B1%E7%BE%8E%E5%9B%BD%E5%88%B6%E8%A3%81%E4%BC%8A%E6%9C%97%E7%9A%84%E6%9D%80%E4%BC%A4%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782485261000.webp","sourceId":"rfi"},{"id":1782483515000,"createdDate":"2026-06-26 14:18","name":"法国国际广播电台","title":"大众汽车正考虑裁员多达10万人，关闭四家在德工厂，迄今规模最大重组","content":"据路透社援引两名知情人士周五报导称，大众汽车（Volkswagen）正考虑关闭四家德国工厂，并将裁员规模扩大至多达10万人；此举若落实，可能成为该行业有史以来规模最大的重组行动。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260626-%E5%A4%A7%E4%BC%97%E6%B1%BD%E8%BD%A6%E6%AD%A3%E8%80%83%E8%99%91%E8%A3%81%E5%91%98%E5%A4%9A%E8%BE%BE10%E4%B8%87%E4%BA%BA%EF%BC%8C%E5%85%B3%E9%97%AD%E5%9B%9B%E5%AE%B6%E5%B7%A5%E5%8E%82%EF%BC%8C%E8%BF%84%E4%BB%8A%E8%A7%84%E6%A8%A1%E6%9C%80%E5%A4%A7%E9%87%8D%E7%BB%84","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782483515000.webp","sourceId":"rfi"},{"id":1782482300000,"createdDate":"2026-06-26 13:58","name":"法国国际广播电台","title":"5月，中国汽车在欧洲新车销量中的占比首超十分之一","content":"上月，中国汽车在欧洲新车销量中的占比首次超过十分之一，这主要归功于消费者纷纷选购那些“物美价优”的车型，即价格更低但配置更丰富的车型。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260626-5%E6%9C%88%EF%BC%8C%E4%B8%AD%E5%9B%BD%E6%B1%BD%E8%BD%A6%E5%9C%A8%E6%AC%A7%E6%B4%B2%E6%96%B0%E8%BD%A6%E9%94%80%E9%87%8F%E4%B8%AD%E7%9A%84%E5%8D%A0%E6%AF%94%E9%A6%96%E8%B6%85%E5%8D%81%E5%88%86%E4%B9%8B%E4%B8%80","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782482300000.webp","sourceId":"rfi"},{"id":1782481405000,"createdDate":"2026-06-26 13:43","name":"法国国际广播电台","title":"美报告：密苏里州立大学25年培训逾1500名中国国企干部","content":"美国智库与地缘政治风险研究机构StrategyRisks最新发布调查报告指出，美国密苏里州立大学（MissouriStateUniversity，MSU）过去25年来持续为中国政府官员、国有企业管理层及中国共产党体系培训商学院人才，累计培养超过1500名中国国企与政府机构管理干部，其中不少毕业生日后进入中国国防工业、战略供应链及监控科技领域担任高阶职务，部分任职企业更受到美国政府制裁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260626-%E7%BE%8E%E6%8A%A5%E5%91%8A-%E5%AF%86%E8%8B%8F%E9%87%8C%E5%B7%9E%E7%AB%8B%E5%A4%A7%E5%AD%A625%E5%B9%B4%E5%9F%B9%E8%AE%AD%E9%80%BE1500%E5%90%8D%E4%B8%AD%E5%9B%BD%E5%9B%BD%E4%BC%81%E5%B9%B2%E9%83%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782481405000.webp","sourceId":"rfi"},{"id":1782478146000,"createdDate":"2026-06-26 12:49","name":"法国国际广播电台","title":"视频 科学家 :气候变化引发极端热浪袭击欧洲","content":"伦敦帝国理工学院环境政策中心的气候科学家西奥多·基平(TheodoreKeeping)指出气候变化引发极端热浪袭击欧洲，而且濒临加快，请看视频报道。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260626-%E8%A7%86%E9%A2%91-%E7%A7%91%E5%AD%A6%E5%AE%B6-%E6%B0%94%E5%80%99%E5%8F%98%E5%8C%96%E5%BC%95%E5%8F%91%E6%9E%81%E7%AB%AF%E7%83%AD%E6%B5%AA%E8%A2%AD%E5%87%BB%E6%AC%A7%E6%B4%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782478146000.webp","sourceId":"rfi"},{"id":1782477832000,"createdDate":"2026-06-26 12:43","name":"法国国际广播电台","title":"北京“中国尊”疑遭小飞机撞击 事发周边警力部署加强","content":"北京警方封闭了通往该市中央商务区（CBD）最高建筑的部分道路；路透社目击者发现，该建筑高层一侧的一块玻璃幕墙缺失。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260626-%E5%8C%97%E4%BA%AC-%E4%B8%AD%E5%9B%BD%E5%B0%8A-%E7%96%91%E9%81%AD%E5%B0%8F%E9%A3%9E%E6%9C%BA%E6%92%9E%E5%87%BB-%E4%BA%8B%E5%8F%91%E5%91%A8%E8%BE%B9%E8%AD%A6%E5%8A%9B%E9%83%A8%E7%BD%B2%E5%8A%A0%E5%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782477832000.webp","sourceId":"rfi"},{"id":1782475390000,"createdDate":"2026-06-26 12:03","name":"法国国际广播电台","title":"美联邦通信委员会收紧海底通信电缆相关规定 中企更难提供设备","content":"美国联邦通信委员会（FCC）周四投票决定加强对承载99%国际互联网流量的海底通信电缆的监管，提议出台相关规定，使中国企业更难提供设备，同时为值得信赖的美国科技公司提供审批快车道。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260626-%E7%BE%8E%E8%81%94%E9%82%A6%E9%80%9A%E4%BF%A1%E5%A7%94%E5%91%98%E4%BC%9A%E6%94%B6%E7%B4%A7%E6%B5%B7%E5%BA%95%E9%80%9A%E4%BF%A1%E7%94%B5%E7%BC%86%E7%9B%B8%E5%85%B3%E8%A7%84%E5%AE%9A-%E4%B8%AD%E4%BC%81%E6%9B%B4%E9%9A%BE%E6%8F%90%E4%BE%9B%E8%AE%BE%E5%A4%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782475390000.webp","sourceId":"rfi"},{"id":1782473843000,"createdDate":"2026-06-26 11:37","name":"法国国际广播电台","title":"视频 美国两党众议院议员在国会大厦欢迎台湾代表团访问","content":"数十名美国国会两党众议院议员于6月24日在国会山欢迎台湾立法院长韩国瑜率团来访，并表示欢迎台湾对美国经济史无前例的投资，请看视频报道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260626-%E8%A7%86%E9%A2%91-%E7%BE%8E%E5%9B%BD%E4%B8%A4%E5%85%9A%E4%BC%97%E8%AE%AE%E9%99%A2%E8%AE%AE%E5%91%98%E5%9C%A8%E5%9B%BD%E4%BC%9A%E5%A4%A7%E5%8E%A6%E6%AC%A2%E8%BF%8E%E5%8F%B0%E6%B9%BE%E4%BB%A3%E8%A1%A8%E5%9B%A2%E8%AE%BF%E9%97%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782473843000.webp","sourceId":"rfi"},{"id":1782469550000,"createdDate":"2026-06-26 10:25","name":"法国国际广播电台","title":"大马海关本月在吉隆坡机场查获价值1300万美元的转运AI芯片","content":"马来西亚海关周五表示，其本月挫败了一起试图经由该国主要机场走私价值5290万林吉特（约合1293万美元）先进人工智能芯片的企图。此前，在华盛顿施压要求遏制对华出口人工智能发展关键芯片的背景下，马来西亚于去年对美国产高性能芯片的流通实施了出口管制。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260626-%E5%A4%A7%E9%A9%AC%E6%B5%B7%E5%85%B3%E6%9C%AC%E6%9C%88%E5%9C%A8%E5%90%89%E9%9A%86%E5%9D%A1%E6%9C%BA%E5%9C%BA%E6%9F%A5%E8%8E%B7%E4%BB%B7%E5%80%BC1300%E4%B8%87%E7%BE%8E%E5%85%83%E7%9A%84%E8%BD%AC%E8%BF%90ai%E8%8A%AF%E7%89%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782469550000.webp","sourceId":"rfi"},{"id":1782468368000,"createdDate":"2026-06-26 10:06","name":"法国国际广播电台","title":"法媒大哉问：世界杯增至48国队伍参赛，但中国和印度在哪里？","content":"我们正值世界杯期间。全世界目前都在为基利安·姆巴佩、利昂内尔·梅西或者埃尔林·哈兰德的靓丽表现而疯狂。全世界吗？不！据法国《观点》周刊电子版25日刊文表示，近30亿人口只是远远关注着这项被认为是最全球化的体育运动中最负盛名的赛事。依这篇由资深体育记者ClémentAubry执笔的长文解释，中国和印度总人口虽已接近30亿，却依然缺席世界杯。这一双重谜题表明，足球首先是文化的产物，而非人口的产物。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260626-%E6%B3%95%E5%AA%92%E5%A4%A7%E5%93%89%E9%97%AE-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%A2%9E%E8%87%B348%E5%9B%BD%E9%98%9F%E4%BC%8D%E5%8F%82%E8%B5%9B%EF%BC%8C%E4%BD%86%E4%B8%AD%E5%9B%BD%E5%92%8C%E5%8D%B0%E5%BA%A6%E5%9C%A8%E5%93%AA%E9%87%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782468368000.webp","sourceId":"rfi"},{"id":1782467720000,"createdDate":"2026-06-26 09:55","name":"法国国际广播电台","title":"视频 中国厦门机场海关查获了近年来最大宗毒品","content":"中国厦门机场海关官员近日从一名入境旅客的行李中查获了30.41克MDMA，俗称摇头丸，也是近年来查获的最大宗毒品走私，请看视频报道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260626-%E8%A7%86%E9%A2%91-%E4%B8%AD%E5%9B%BD%E5%8E%A6%E9%97%A8%E6%9C%BA%E5%9C%BA%E6%B5%B7%E5%85%B3%E6%9F%A5%E8%8E%B7%E4%BA%86%E8%BF%91%E5%B9%B4%E6%9D%A5%E6%9C%80%E5%A4%A7%E5%AE%97%E6%AF%92%E5%93%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782467720000.webp","sourceId":"rfi"},{"id":1782467567000,"createdDate":"2026-06-26 09:52","name":"法国国际广播电台","title":"美商务部禁止吉利控股旗下极星在美销售2027年及后续车型","content":"随着华盛顿方面加大对中国汽车的打压力度，极星（Polestar）周四表示，特朗普政府正迫使这家电动汽车制造商停止在美销售2027年及以后的车型。当天下午，极星在纳斯达克的股价下跌了6.3%。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260626-%E7%BE%8E%E5%9B%BD%E7%A6%81%E6%AD%A2%E5%90%89%E5%88%A9%E6%8E%A7%E8%82%A1%E6%97%97%E4%B8%8B%E6%9E%81%E6%98%9F%E5%9C%A8%E7%BE%8E%E9%94%80%E5%94%AE2027%E5%B9%B4%E5%8F%8A%E5%90%8E%E7%BB%AD%E8%BD%A6%E5%9E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782467567000.webp","sourceId":"rfi"}]