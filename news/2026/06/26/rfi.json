[{"id":1782464089000,"createdDate":"2026-06-26 08:54","name":"法国国际广播电台","title":"新西兰警告：中国在太平洋地区军事部署恐“常态化”","content":"据法新社获得的一份内部文件显示，新西兰官员警告称，随着北京加强其在太平洋地区的军事存在，中国海军的弹道导弹试验和行动将成为太平洋地区的“常态性”特征。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260626-%E6%96%B0%E8%A5%BF%E5%85%B0%E8%AD%A6%E5%91%8A-%E4%B8%AD%E5%9B%BD%E5%9C%A8%E5%A4%AA%E5%B9%B3%E6%B4%8B%E5%9C%B0%E5%8C%BA%E5%86%9B%E4%BA%8B%E9%83%A8%E7%BD%B2%E6%81%90-%E5%B8%B8%E6%80%81%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782464089000.webp","sourceId":"rfi"},{"id":1782463961000,"createdDate":"2026-06-26 08:52","name":"法国国际广播电台","title":"美国务院高官：美中会谈中方必提军售问题，未背离“六项保证”","content":"尽管特朗普总统曾有此暗示，但美国国务院负责东亚事务的高级外交官周四表示，向美国国会提交的对台军售通知并不取决于与北京方面的磋商。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260626-%E7%BE%8E%E5%9B%BD%E5%8A%A1%E9%99%A2%E9%AB%98%E5%AE%98-%E7%BE%8E%E4%B8%AD%E4%BC%9A%E8%B0%88%E4%B8%AD%E6%96%B9%E5%BF%85%E6%8F%90%E5%86%9B%E5%94%AE%E9%97%AE%E9%A2%98%EF%BC%8C%E6%9C%AA%E8%83%8C%E7%A6%BB-%E5%85%AD%E9%A1%B9%E4%BF%9D%E8%AF%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782463961000.webp","sourceId":"rfi"},{"id":1782463688000,"createdDate":"2026-06-26 08:48","name":"法国国际广播电台","title":"热浪天：易怒情绪加剧、抑郁症和精神病病例增加、精神崩溃……人们的心理健康受考验","content":"热浪酷暑天会对我们的心理健康造成了严重影响，尤其是对精神疾病患者而言，他们更容易受到高温的影响；根据一名精神科医生指，“气温变化就像压垮骆驼的最后一根稻草。”","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260626-%E7%83%AD%E6%B5%AA%E5%A4%A9-%E6%98%93%E6%80%92%E6%83%85%E7%BB%AA%E5%8A%A0%E5%89%A7-%E6%8A%91%E9%83%81%E7%97%87%E5%92%8C%E7%B2%BE%E7%A5%9E%E7%97%85%E7%97%85%E4%BE%8B%E5%A2%9E%E5%8A%A0-%E7%B2%BE%E7%A5%9E%E5%B4%A9%E6%BA%83-%E4%BA%BA%E4%BB%AC%E7%9A%84%E5%BF%83%E7%90%86%E5%81%A5%E5%BA%B7%E5%8F%97%E8%80%83%E9%AA%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782463688000.webp","sourceId":"rfi"},{"id":1782463060000,"createdDate":"2026-06-26 08:37","name":"法国国际广播电台","title":"日本通过法律 航空自卫队改为“航空宇宙自卫队”","content":"包含将航空自卫队重新改编为“航空宇宙自卫队”等内容的《防卫省设置法》等修正案，已于6月26日在日本参议院全体会议上获得通过并正式成立。这是自航空自卫队于1954年成立以来，首次更改组织名称。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260626-%E6%97%A5%E6%9C%AC%E9%80%9A%E8%BF%87%E6%B3%95%E5%BE%8B-%E8%88%AA%E7%A9%BA%E8%87%AA%E5%8D%AB%E9%98%9F%E6%94%B9%E4%B8%BA-%E8%88%AA%E7%A9%BA%E5%AE%87%E5%AE%99%E8%87%AA%E5%8D%AB%E9%98%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782463060000.webp","sourceId":"rfi"},{"id":1782458855000,"createdDate":"2026-06-26 07:27","name":"法国国际广播电台","title":"调查：中国跨境镇压遍布五洲41国 印度香港多人受压","content":"备受跨境镇压指控困扰的中国，今日再添一笔。一个针对全球的人权调查显示，中国在41个国家或地区有实行跨境镇压，最受影响的，是不丹丶印度及香港等地人民，当中尤以身处海外丶倡导民主的中国公民最能肯定成为目标。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260626-%E8%B0%83%E6%9F%A5-%E4%B8%AD%E5%9B%BD%E8%B7%A8%E5%A2%83%E9%95%87%E5%8E%8B%E9%81%8D%E5%B8%83%E4%BA%94%E6%B4%B241%E5%9B%BD-%E5%8D%B0%E5%BA%A6%E9%A6%99%E6%B8%AF%E5%A4%9A%E4%BA%BA%E5%8F%97%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782458855000.webp","sourceId":"rfi"},{"id":1782458604000,"createdDate":"2026-06-26 07:23","name":"法国国际广播电台","title":"人权评量：台湾去年领先 中港自由享受同属最差 负责人料今年再差","content":"根据位於纽西兰的人权组织的年度报告显示，中国在人身完整性方面的人权评分於2025年虽略有改善，但基本仍然处於「很差」的区间；而受中国影响日深的香港，相关评分虽仍留在「一般」级别，但评分已较之前微降至7.2分。组织的东亚区负责人潘嘉伟向本台指出，中港两地在享受自由方面的人权赋权只有2到3分，属「很差」，加上今年上半年已发生不少拘捕和打压事件，预料今年的人权评分会再差。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260626-%E4%BA%BA%E6%9D%83%E8%AF%84%E9%87%8F-%E5%8F%B0%E6%B9%BE%E5%8E%BB%E5%B9%B4%E9%A2%86%E5%85%88-%E4%B8%AD%E6%B8%AF%E8%87%AA%E7%94%B1%E4%BA%AB%E5%8F%97%E5%90%8C%E5%B1%9E%E6%9C%80%E5%B7%AE-%E8%B4%9F%E8%B4%A3%E4%BA%BA%E6%96%99%E4%BB%8A%E5%B9%B4%E5%86%8D%E5%B7%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/26/1782458604000.webp","sourceId":"rfi"}]