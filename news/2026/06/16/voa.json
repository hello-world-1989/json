[{"id":1781627751000,"createdDate":"2026-06-16 16:35","name":"美国之音","title":"特朗普：他已达成一项“好协议”，规定伊朗政权在美国“最终后果”的威胁下不会获得核武器","content":"美国总统唐纳德·特朗普说，美国已与伊朗政权签署了一项“良好的协议”，而且在美国的“最终”后果威胁下，伊朗政权承诺不会获取核武器。","newsLink":"https://www.voachinese.com/a/trump-says-he-has-reached-good-deal-in-which-iranian-regime-will-not-acquire-nuclear-weapons-20260616/8161480.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/16/1781627751000.webp","sourceId":"voa"},{"id":1781627211000,"createdDate":"2026-06-16 16:26","name":"美国之音","title":"美空军一架轰炸机在加州坠毁，八人丧生\n\n","content":"美国空军正在调查一架B-52轰炸机在加利福尼亚州的坠毁事故，机上八人全部遇难。","newsLink":"https://www.voachinese.com/a/us-air-force-bomber-crashes-in-california-killing-8-20260616/8161484.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/16/1781627211000.webp","sourceId":"voa"},{"id":1781642217000,"createdDate":"2026-06-16 20:36","name":"美国之音","title":"美众议员访台交流美台安全、半导体及科技议题","content":"两位美国民主党籍联邦众议员星期二(6月16日)抵达台北进行为期五天的访问。她们都是美国国会非裔美国人连线(CBC)成员。","newsLink":"https://www.voachinese.com/a/members-of-u-s-congress-visit-taiwan-to-exchange-views-on-bilateral-security-and-semiconductor-issues-20260616/8161535.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/16/1781642217000.webp","sourceId":"voa"},{"id":1781638359000,"createdDate":"2026-06-16 19:32","name":"美国之音","title":"台湾防务预算遭在野党删减，赖清德表示将另寻途径强化国防支出","content":"台湾总统赖清德星期二(6月16日)说，他“不会放弃”增加防务开支以确保台湾的防卫装备和建设能顺利推动。在国防预算遭反对党删减约三分之一后，赖清德说，他将另提特别条或透过追加预算和提高年度公务预算等方式来提高防卫开支。","newsLink":"https://www.voachinese.com/a/taiwan-president-says-will-increase-defense-spending-despite-parliament-cuts-20260616/8161505.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/16/1781638359000.webp","sourceId":"voa"}]