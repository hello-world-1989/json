[{"id":1781600742000,"createdDate":"2026-06-16 09:05","name":"法国国际广播电台","title":"特朗普家族在阿尔巴尼亚的旅游项目遭抗议","content":"最近两周以来，数万名阿尔巴尼亚人每天傍晚6点在全国多个城市以及海外举行示威游行。他们抗议的是一项与特朗普家族有关的豪华旅游项目，该项目计划在维约萨河 (Vjosa)三角洲的一处自然保护区内兴建。批评者认为，这座预计耗资46亿美元、计划建在亚得里亚海沿岸保护区内的豪华酒店综合体将构成环境风险。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260616-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AE%B6%E6%97%8F%E5%9C%A8%E9%98%BF%E5%B0%94%E5%B7%B4%E5%B0%BC%E4%BA%9A%E7%9A%84%E6%97%85%E6%B8%B8%E9%A1%B9%E7%9B%AE%E9%81%AD%E6%8A%97%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781600742000.webp","sourceId":"rfi"},{"id":1781600536000,"createdDate":"2026-06-16 09:02","name":"法国国际广播电台","title":"世界杯第6日：佛得角队40岁门将一战封神 法国与阿根廷即将分别亮相","content":"2026年美加墨世界杯开幕第五日，爆出了首个大冷门。作为欧洲冠军、同时也是夺冠热门之一的西班牙队，竟然在遭遇佛得角队时意外受挫，仅收获一场平局。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260616-%E4%B8%96%E7%95%8C%E6%9D%AF%E7%AC%AC6%E6%97%A5-40%E5%B2%81%E4%BD%9B%E5%BE%97%E8%A7%92%E9%98%9F%E9%97%A8%E5%B0%86%E4%B8%80%E6%88%98%E5%B0%81%E7%A5%9E-%E6%B3%95%E5%9B%BD%E4%B8%8E%E9%98%BF%E6%A0%B9%E5%BB%B7%E5%8D%B3%E5%B0%86%E4%BA%AE%E7%9B%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781600536000.webp","sourceId":"rfi"},{"id":1781599043000,"createdDate":"2026-06-16 08:37","name":"法国国际广播电台","title":"打破传统：官媒播出逾6分钟影片强化“人民领袖”形象“巧妙”替习近平庆生","content":"中国全国党建工作座谈会于昨日周一（6月15日）在北京召开。会议首次明确提出“习近平党建思想”，并将其确立为全党当前及今后一段时间的重要政治任务。另据中央社报道，在中国不为领导人公开庆生的传统下，官媒央视昨天刻意播出时长逾6分钟的「共产党员习近平」影片，以凸显其党性的方式“变相”为习近平庆生。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260616-%E6%89%93%E7%A0%B4%E4%BC%A0%E7%BB%9F-%E5%AE%98%E5%AA%92%E6%92%AD%E5%87%BA%E9%80%BE6%E5%88%86%E9%92%9F%E5%BD%B1%E7%89%87%E5%BC%BA%E5%8C%96-%E4%BA%BA%E6%B0%91%E9%A2%86%E8%A2%96-%E5%BD%A2%E8%B1%A1-%E5%B7%A7%E5%A6%99-%E6%9B%BF%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%BA%86%E7%94%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781599043000.webp","sourceId":"rfi"},{"id":1781598213000,"createdDate":"2026-06-16 08:23","name":"法国国际广播电台","title":"国民党主席郑丽文白宫会面无疾而终低调返台 立法院长韩国瑜将接棒访华盛顿","content":"郑丽文历史性的16天访美行程被国际媒体评论为高开低收，白宫会面也无疾而终，整趟行程被指含金量有限。同时，立法院长韩国瑜收到美方邀请21日访美，预计将以高规格的接待。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260616-%E5%9B%BD%E6%B0%91%E5%85%9A%E4%B8%BB%E5%B8%AD%E9%83%91%E4%B8%BD%E6%96%87%E7%99%BD%E5%AE%AB%E4%BC%9A%E9%9D%A2%E6%97%A0%E7%96%BE%E8%80%8C%E7%BB%88%E4%BD%8E%E8%B0%83%E8%BF%94%E5%8F%B0-%E7%AB%8B%E6%B3%95%E9%99%A2%E9%95%BF%E9%9F%A9%E5%9B%BD%E7%91%9C%E5%B0%86%E6%8E%A5%E6%A3%92%E8%AE%BF%E5%8D%8E%E7%9B%9B%E9%A1%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781598213000.webp","sourceId":"rfi"},{"id":1781596755000,"createdDate":"2026-06-16 07:59","name":"法国国际广播电台","title":"日本意大利举行首脑会谈  发表开发宇宙合作联合声明","content":"日本首相高市早苗于15日（日本时间同日）在罗马与意大利总理梅洛尼举行日意首脑会谈，针对美国总统特朗普宣布美国与伊朗已就结束战斗达成协议一事，双方就今后的应对措施进行了磋商。此外，日意两国还发表了关于加强宇宙开发等尖端技术领域合作的联合声明。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260616-%E6%97%A5%E6%9C%AC%E6%84%8F%E5%A4%A7%E5%88%A9%E4%B8%BE%E8%A1%8C%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88-%E5%8F%91%E8%A1%A8%E5%BC%80%E5%8F%91%E5%AE%87%E5%AE%99%E5%90%88%E4%BD%9C%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781596755000.webp","sourceId":"rfi"},{"id":1781595342000,"createdDate":"2026-06-16 07:35","name":"法国国际广播电台","title":"香港武官治港架构再多一员 退休警队二把手转跑道任食环署长","content":"长期服务警队的李家超成为特首後，有学者已指香港将进入「警察治港」年代，继近期委任警队高层掌管政府新闻处後，今(16日)天又再破天荒让退休警队高层取代文官出任政府要职，外聘前警务处副处长袁旭健，掌管香港的食物环境卫生工作，使李家超任内，由前纪律部队高层转任为港府要职的人数增至九人。评论指，这将进一步巩固香港警察治港的局面，更谑称，这应可令2019年後不受欢迎而令警队招募困难的现象，成为匪夷所思。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260616-%E9%A6%99%E6%B8%AF%E6%AD%A6%E5%AE%98%E6%B2%BB%E6%B8%AF%E6%9E%B6%E6%9E%84%E5%86%8D%E5%A4%9A%E4%B8%80%E5%91%98-%E9%80%80%E4%BC%91%E8%AD%A6%E9%98%9F%E4%BA%8C%E6%8A%8A%E6%89%8B%E8%BD%AC%E8%B7%91%E9%81%93%E4%BB%BB%E9%A3%9F%E7%8E%AF%E7%BD%B2%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781595342000.webp","sourceId":"rfi"},{"id":1781629365000,"createdDate":"2026-06-16 17:02","name":"法国国际广播电台","title":"越南警方破获窃猫集团解救数百只猫咪 9人被捕","content":"一家动物保护组织周二表示，在警方破获一个犯罪团伙后，约40只被盗捕用于制作猫肉的猫咪已归还原主人。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260616-%E8%B6%8A%E5%8D%97%E8%AD%A6%E6%96%B9%E7%A0%B4%E8%8E%B7%E7%AA%83%E7%8C%AB%E9%9B%86%E5%9B%A2%E8%A7%A3%E6%95%91%E6%95%B0%E7%99%BE%E5%8F%AA%E7%8C%AB%E5%92%AA-9%E4%BA%BA%E8%A2%AB%E6%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781629365000.webp","sourceId":"rfi"},{"id":1781626404000,"createdDate":"2026-06-16 16:13","name":"法国国际广播电台","title":"敏昂莱访问北京 中国如何介入缅甸内战？","content":"缅甸总统敏昂莱本周对中国展开为期五天的国事访问，并将会晤中国国家主席习近平、国务院总理李强和全国人大委员长赵乐际。这是敏昂莱今年4月就任总统后首次访华。在缅甸内战持续、军政府面临国际孤立之际，此次访问被视为中缅关系的重要节点，也凸显中国在缅甸政治、安全和经济事务中的关键影响力。","newsLink":"https://www.rfi.fr/cn/%E7%BC%85%E7%94%B8%E9%A6%96%E9%A2%86%E8%AE%BF%E9%97%AE%E5%8C%97%E4%BA%AC-%E4%B8%AD%E5%9B%BD%E5%A6%82%E4%BD%95%E4%BB%8B%E5%85%A5%E7%BC%85%E7%94%B8%E5%86%85%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781626404000.webp","sourceId":"rfi"},{"id":1781625631000,"createdDate":"2026-06-16 16:00","name":"法国国际广播电台","title":"法国议会即将批准延长羁押被认定危险的非法居留的外国人","content":"法国议会定于周二正式通过一项法案，延长对被认定为危险的非法居留的外国人的行政羁留期限。该措施虽遭到左翼阵营的批评，但被右翼和中间派视为对2024年那名菲律宾年轻女子遇害案的回应。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260616-%E6%B3%95%E5%9B%BD%E8%AE%AE%E4%BC%9A%E5%8D%B3%E5%B0%86%E6%89%B9%E5%87%86%E5%BB%B6%E9%95%BF%E7%BE%81%E6%8A%BC%E8%A2%AB%E8%AE%A4%E5%AE%9A%E5%8D%B1%E9%99%A9%E7%9A%84%E9%9D%9E%E6%B3%95%E6%8B%98%E7%95%99%E7%9A%84%E5%A4%96%E5%9B%BD%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781625631000.webp","sourceId":"rfi"},{"id":1781623578000,"createdDate":"2026-06-16 15:26","name":"法国国际广播电台","title":"欧洲议会最终批准欧盟与特朗普达成的贸易协议","content":"欧洲议会周二以压倒多数，最终批准了欧盟与唐纳德·特朗普政府去年达成的贸易协议，希望借此在经历数月紧张局势后，缓和跨大西洋关系。特朗普给出的最后期限是7月4日，议员们争到了“落日条款”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260616-%E6%AC%A7%E6%B4%B2%E8%AE%AE%E4%BC%9A%E6%9C%80%E7%BB%88%E6%89%B9%E5%87%86%E6%AC%A7%E7%9B%9F%E4%B8%8E%E7%89%B9%E6%9C%97%E6%99%AE%E8%BE%BE%E6%88%90%E7%9A%84%E8%B4%B8%E6%98%93%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781623578000.webp","sourceId":"rfi"},{"id":1781617505000,"createdDate":"2026-06-16 13:45","name":"法国国际广播电台","title":"视频 刚果（金）埃博拉疫情激增引发担忧","content":"据刚果（金）卫生部近日发布新数据称已经确诊埃博拉病例已增至808例，其中192例死亡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260616-%E8%A7%86%E9%A2%91-%E5%88%9A%E6%9E%9C-%E9%87%91-%E5%9F%83%E5%8D%9A%E6%8B%89%E7%96%AB%E6%83%85%E6%BF%80%E5%A2%9E%E5%BC%95%E5%8F%91%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781617505000.webp","sourceId":"rfi"},{"id":1781614535000,"createdDate":"2026-06-16 12:55","name":"法国国际广播电台","title":"台湾总统赖清德表示他“不放弃”增加国防开支","content":"路透社新北消息，台湾总统赖清德周二在新北市某个军事基地表示：他“不放弃”增加国防开支。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260616-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E8%B5%96%E6%B8%85%E5%BE%B7%E8%A1%A8%E7%A4%BA%E4%BB%96-%E4%B8%8D%E6%94%BE%E5%BC%83-%E5%A2%9E%E5%8A%A0%E5%9B%BD%E9%98%B2%E5%BC%80%E6%94%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781614535000.webp","sourceId":"rfi"},{"id":1781612022000,"createdDate":"2026-06-16 12:13","name":"法国国际广播电台","title":"临近联合审查节点的美墨加协定","content":"随着7月1日《美墨加协定》（USMCA）首次三方联合审查节点的临近，墨西哥经济部长6月1日致函美国和加拿大的贸易代表，正式提议将协定直接续签16年，第二天加拿大加美事务部长多米尼克·勒布朗（DominicLeBlanc）在华盛顿与美国贸易代表会晤时也正式表达了与墨西哥相同的立场，美国总统特朗普6月10日回应称“我没打算续签它”，并重申美国“不需要加拿大和墨西哥的任何东西，但他们需要我们的一切”。特朗普的态度很有可能令《美墨加协定》错过7月1日直接续签的截止日期，而在未来年复一年的审查和谈判中，美国退出的威胁将如影随形。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%8C%97%E7%BE%8E%E6%9D%A5%E9%B8%BF/20260616-%E4%B8%B4%E8%BF%91%E8%81%94%E5%90%88%E5%AE%A1%E6%9F%A5%E8%8A%82%E7%82%B9%E7%9A%84%E7%BE%8E%E5%A2%A8%E5%8A%A0%E5%8D%8F%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781612022000.webp","sourceId":"rfi"},{"id":1781611688000,"createdDate":"2026-06-16 12:08","name":"法国国际广播电台","title":"俄军袭击自身文化源头与东正教圣地，欧洲斯拉夫学界发生信念地震","content":"2026年6月16日出刊的法国主流日刊国际版多关注两个热点，一个是美国和伊朗达成的协议让伊朗政权与士气得到了空前的强化，再一个就是俄罗斯对乌克兰的袭击造成有近千年历史的东正教圣地基辅洞窟修道院部分损毁，引发来自世界各地信徒的声讨。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260616-%E4%BF%84%E5%86%9B%E8%A2%AD%E5%87%BB%E8%87%AA%E8%BA%AB%E6%96%87%E5%8C%96%E6%BA%90%E5%A4%B4%E4%B8%8E%E4%B8%9C%E6%AD%A3%E6%95%99%E5%9C%A3%E5%9C%B0%EF%BC%8C%E6%AC%A7%E6%B4%B2%E6%96%AF%E6%8B%89%E5%A4%AB%E5%AD%A6%E7%95%8C%E5%8F%91%E7%94%9F%E4%BF%A1%E5%BF%B5%E5%9C%B0%E9%9C%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781611688000.webp","sourceId":"rfi"},{"id":1781611685000,"createdDate":"2026-06-16 12:08","name":"法国国际广播电台","title":"乌克兰成为G7峰会焦点，但其关注度被伊朗问题遮盖","content":"周二16日，在七大工业国集团峰会上，六国的首脑都希望美国统特朗普在面对普京时，能站在被俄罗斯侵略的乌克兰一边。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260616-%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%90%E4%B8%BAg7%E5%B3%B0%E4%BC%9A%E7%84%A6%E7%82%B9%EF%BC%8C%E4%BD%86%E5%85%B6%E5%85%B3%E6%B3%A8%E5%BA%A6%E8%A2%AB%E4%BC%8A%E6%9C%97%E9%97%AE%E9%A2%98%E9%81%AE%E7%9B%96","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781611685000.webp","sourceId":"rfi"},{"id":1781610147000,"createdDate":"2026-06-16 11:42","name":"法国国际广播电台","title":"美伊“踢平”一场“无效”比赛：无论战前还是战后任何争端毫无实质性解决","content":"一场持续近4个月的中东战争将以一种近乎讽刺的方式落下帷幕。美国总统特朗普周一（6月15日）在埃维昂表示，与伊朗达成初步协议，内容包括重开霍尔木兹海峡、解除美国对伊朗港口封锁，双方在60天内谈判处理伊朗核计划、制裁解除等等。两国预计19日于日内瓦签署协议，换句话说，美国和以色列联手发动的军事行动，最终却以一纸协议告终，其结果与战争爆发前的局势几乎别无二致：霍尔木兹海峡重新开放，伊朗核谈判重启，部分制裁被解除。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260616-%E7%BE%8E%E4%BC%8A-%E8%B8%A2%E5%B9%B3-%E6%89%93%E4%BA%86%E5%9C%BA-%E6%97%A0%E6%95%88-%E6%AF%94%E8%B5%9B-%E6%97%A0%E8%AE%BA%E6%88%98%E5%89%8D%E8%BF%98%E6%98%AF%E6%88%98%E5%90%8E%E4%BB%BB%E4%BD%95%E4%BA%89%E7%AB%AF%E6%AF%AB%E6%97%A0%E5%AE%9E%E8%B4%A8%E6%80%A7%E8%A7%A3%E5%86%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781610147000.webp","sourceId":"rfi"},{"id":1781609627000,"createdDate":"2026-06-16 11:33","name":"法国国际广播电台","title":"特朗普称旨在结束美伊战争的谅解备忘录已由双方签署 霍尔木兹海峡即将重开","content":"路透社6月16日消息，美国总统唐纳德·特朗普周一表示，旨在结束伊朗与美国之间战争的谅解备忘录“已经”由双方签署，并承诺霍尔木兹海峡即将重新开放。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260616-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E6%97%A8%E5%9C%A8%E7%BB%93%E6%9D%9F%E7%BE%8E%E4%BC%8A%E6%88%98%E4%BA%89%E7%9A%84%E8%B0%85%E8%A7%A3%E5%A4%87%E5%BF%98%E5%BD%95%E5%B7%B2%E7%94%B1%E5%8F%8C%E6%96%B9%E7%AD%BE%E7%BD%B2-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%8D%B3%E5%B0%86%E9%87%8D%E5%BC%80","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781609627000.webp","sourceId":"rfi"},{"id":1781609348000,"createdDate":"2026-06-16 11:29","name":"法国国际广播电台","title":"视频 美媒称：美伊签署电子谅解备忘录","content":"美国媒体报道美国和伊朗已签署一份旨在结束战争的电子谅解备忘录。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260616-%E8%A7%86%E9%A2%91-%E7%BE%8E%E5%AA%92%E7%A7%B0-%E7%BE%8E%E4%BC%8A%E7%AD%BE%E7%BD%B2%E7%94%B5%E5%AD%90%E8%B0%85%E8%A7%A3%E5%A4%87%E5%BF%98%E5%BD%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781609348000.webp","sourceId":"rfi"},{"id":1781607411000,"createdDate":"2026-06-16 10:56","name":"法国国际广播电台","title":"特朗普又一次搬起石头砸自己的脚？  Anthropic出口禁令或可刺激全球市场对中国AI的需求","content":"今天的科技专题节目，我们将探讨美国近日宣布的AI禁令。上周五(6月12日)，特朗普禁止美国以外的地区使用Anthropic的先进人工智能模型Fable5和Mythos5，在全球各地的开发者中引发哀声一片。毕竟，这两个模型是当前公认的世界最先进的人工智能模型之一。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%A7%91%E6%8A%80%E6%97%B6%E7%A9%BA/20260616-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%88%E4%B8%80%E6%AC%A1%E6%90%AC%E8%B5%B7%E7%9F%B3%E5%A4%B4%E7%A0%B8%E8%87%AA%E5%B7%B1%E7%9A%84%E8%84%9A-anthropic%E5%87%BA%E5%8F%A3%E7%A6%81%E4%BB%A4%E6%88%96%E5%8F%AF%E5%88%BA%E6%BF%80%E5%85%A8%E7%90%83%E5%B8%82%E5%9C%BA%E5%AF%B9%E4%B8%AD%E5%9B%BDai%E7%9A%84%E9%9C%80%E6%B1%82","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781607411000.webp","sourceId":"rfi"},{"id":1781651434000,"createdDate":"2026-06-16 23:10","name":"法国国际广播电台","title":"特朗普批以色列空袭黎巴嫩“太过份” 忧冲击美伊停火协议","content":"正在法国出席七大工业国集团（G7）峰会的美国总统特朗普（DonaldTrump）16日公开批评以色列近期对黎巴嫩的军事行动，直言以军周末针对黎巴嫩首都贝鲁特的空袭“非常恶劣”、“太过份”，并要求以色列总理内塔尼亚胡（BenjaminNetanyahu）在处理黎巴嫩问题上“必须更加负责任”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260616-%E7%89%B9%E6%9C%97%E6%99%AE%E6%89%B9%E4%BB%A5%E8%89%B2%E5%88%97%E7%A9%BA%E8%A2%AD%E9%BB%8E%E5%B7%B4%E5%AB%A9-%E5%A4%AA%E8%BF%87%E4%BB%BD-%E5%BF%A7%E5%86%B2%E5%87%BB%E7%BE%8E%E4%BC%8A%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781651434000.webp","sourceId":"rfi"},{"id":1781651124000,"createdDate":"2026-06-16 23:05","name":"法国国际广播电台","title":"重庆的高官们为什么一个接着一个倒下","content":"重庆官场动荡之烈，薄熙来以降，在中国官场也算一个奇特的现象。现任重庆市委书记、中共政治局委员袁家军周一似乎给出了一个解释：出问题的官员在于没有把忠诚摆在首位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260616-%E9%87%8D%E5%BA%86%E7%9A%84%E9%AB%98%E5%AE%98%E4%BB%AC%E4%B8%BA%E4%BB%80%E4%B9%88%E4%B8%80%E4%B8%AA%E6%8E%A5%E7%9D%80%E4%B8%80%E4%B8%AA%E5%80%92%E4%B8%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781651124000.webp","sourceId":"rfi"},{"id":1781650407000,"createdDate":"2026-06-16 22:53","name":"法国国际广播电台","title":"美伊停战框架协议：伊朗国内并不是铁板一块都支持这一协议","content":"就伊朗和美国刚刚达成的停战框架协议，伊朗国内的反应如何呢？伊朗国内是铁板一块都支持这一协议吗？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260616-%E7%BE%8E%E4%BC%8A%E5%81%9C%E6%88%98%E6%A1%86%E6%9E%B6%E5%8D%8F%E8%AE%AE-%E4%BC%8A%E6%9C%97%E5%9B%BD%E5%86%85%E5%B9%B6%E4%B8%8D%E6%98%AF%E9%93%81%E6%9D%BF%E4%B8%80%E5%9D%97%E9%83%BD%E6%94%AF%E6%8C%81%E8%BF%99%E4%B8%80%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781650407000.webp","sourceId":"rfi"},{"id":1781650266000,"createdDate":"2026-06-16 22:51","name":"法国国际广播电台","title":"中国领途汽车公司进军欧洲无驾照微型车市场","content":"中国山东魏桥集团旗下的领途（Linktour）公司周二在多个欧洲国家正式推出一款名为“Alumi”的纯电动无驾照微型车。这款小车造型独特，瞄准的是近年来快速增长的欧洲微型车市场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260616-%E4%B8%AD%E5%9B%BD%E9%A2%86%E9%80%94%E6%B1%BD%E8%BD%A6%E5%85%AC%E5%8F%B8%E8%BF%9B%E5%86%9B%E6%AC%A7%E6%B4%B2%E6%97%A0%E9%A9%BE%E7%85%A7%E5%BE%AE%E5%9E%8B%E8%BD%A6%E5%B8%82%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781650266000.webp","sourceId":"rfi"},{"id":1781649964000,"createdDate":"2026-06-16 22:46","name":"法国国际广播电台","title":"姆巴佩梅开二度 法国队开门红","content":"上届世界杯亚军法国队周二在世界杯小组赛首战中以3比1战胜塞内加尔，取得开门红。同时，姆巴佩也以58球，成为法国队史射手王。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260616-%E5%A7%86%E5%B7%B4%E4%BD%A9%E6%A2%85%E5%BC%80%E4%BA%8C%E5%BA%A6-%E6%B3%95%E5%9B%BD%E9%98%9F%E5%BC%80%E9%97%A8%E7%BA%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781649964000.webp","sourceId":"rfi"},{"id":1781649562000,"createdDate":"2026-06-16 22:39","name":"法国国际广播电台","title":"巴黎老牌百货BHV终止与希音合作 新管理层称其为“战略错误”","content":"中国快时尚电商平台希音（Shein）周二（6月16日）宣布，其与巴黎老牌百货公司BHV的合作即将结束，证实了法国媒体此前的报道。接手BHV的新管理团队将这项合作称为“战略错误”，并计划重新聚焦传统零售业务。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260616-%E5%B7%B4%E9%BB%8E%E8%80%81%E7%89%8C%E7%99%BE%E8%B4%A7bhv%E7%BB%88%E6%AD%A2%E4%B8%8E%E5%B8%8C%E9%9F%B3%E5%90%88%E4%BD%9C-%E6%96%B0%E7%AE%A1%E7%90%86%E5%B1%82%E7%A7%B0%E5%85%B6%E4%B8%BA-%E6%88%98%E7%95%A5%E9%94%99%E8%AF%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781649562000.webp","sourceId":"rfi"},{"id":1781649268000,"createdDate":"2026-06-16 22:34","name":"法国国际广播电台","title":"G7就加大对俄施压展现一致立场　特朗普拟恢复对俄石油制裁","content":"正在法国埃维昂举行峰会的七国集团（G7）领导人周二（6月16日）就加大对俄罗斯施压、推动结束乌克兰战争展现出一致立场。美国总统特朗普表示，希望恢复此前因中东局势而暂停的部分俄罗斯石油制裁措施。特朗普周二与泽连斯基举行约20分钟单独会谈，这是两人自去年12月以来首次面对面接触。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260616-g7%E5%B0%B1%E5%8A%A0%E5%A4%A7%E5%AF%B9%E4%BF%84%E6%96%BD%E5%8E%8B%E5%B1%95%E7%8E%B0%E4%B8%80%E8%87%B4%E7%AB%8B%E5%9C%BA-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8B%9F%E6%81%A2%E5%A4%8D%E5%AF%B9%E4%BF%84%E7%9F%B3%E6%B2%B9%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781649268000.webp","sourceId":"rfi"},{"id":1781648876000,"createdDate":"2026-06-16 22:27","name":"法国国际广播电台","title":"法国推动AI战略自主 以本土企业取代美国数据分析系统","content":"法国政府周二（6月16日）宣布，将逐步减少对美国数据分析巨头帕兰泰尔（Palantir）的依赖，转而采用法国本土企业解决方案，以推动建立AI领域“真正的战略自主”，强化法国数字主权。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260616-%E6%B3%95%E5%9B%BD%E6%8E%A8%E5%8A%A8ai%E6%88%98%E7%95%A5%E8%87%AA%E4%B8%BB-%E4%BB%A5%E6%9C%AC%E5%9C%9F%E4%BC%81%E4%B8%9A%E5%8F%96%E4%BB%A3%E7%BE%8E%E5%9B%BD%E6%95%B0%E6%8D%AE%E5%88%86%E6%9E%90%E7%B3%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781648876000.webp","sourceId":"rfi"},{"id":1781645959000,"createdDate":"2026-06-16 21:39","name":"法国国际广播电台","title":"美伊将签署结束中东战争框架协议 核问题与制裁谈判进入关键阶段","content":"美国和伊朗将于本周五(6月19日）在瑞士签署一项旨在结束中东战争的框架协议，并启动为期60天的正式谈判。双方计划首先推动备受关注的霍尔木兹海峡恢复通航。伊朗首席谈判代表加利巴夫和美国副总统万斯将出席签字仪式。万斯表示，美国总统特朗普也有可能出席。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260616-%E7%BE%8E%E4%BC%8A%E5%B0%86%E7%AD%BE%E7%BD%B2%E7%BB%93%E6%9D%9F%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E6%A1%86%E6%9E%B6%E5%8D%8F%E8%AE%AE-%E6%A0%B8%E9%97%AE%E9%A2%98%E4%B8%8E%E5%88%B6%E8%A3%81%E8%B0%88%E5%88%A4%E8%BF%9B%E5%85%A5%E5%85%B3%E9%94%AE%E9%98%B6%E6%AE%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781645959000.webp","sourceId":"rfi"}]