[{"id":1781600742000,"createdDate":"2026-06-16 09:05","name":"法国国际广播电台","title":"特朗普家族在阿尔巴尼亚的旅游项目遭抗议","content":"最近两周以来，数万名阿尔巴尼亚人每天傍晚6点在全国多个城市以及海外举行示威游行。他们抗议的是一项与特朗普家族有关的豪华旅游项目，该项目计划在维约萨河 (Vjosa)三角洲的一处自然保护区内兴建。批评者认为，这座预计耗资46亿美元、计划建在亚得里亚海沿岸保护区内的豪华酒店综合体将构成环境风险。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260616-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AE%B6%E6%97%8F%E5%9C%A8%E9%98%BF%E5%B0%94%E5%B7%B4%E5%B0%BC%E4%BA%9A%E7%9A%84%E6%97%85%E6%B8%B8%E9%A1%B9%E7%9B%AE%E9%81%AD%E6%8A%97%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781600742000.webp","sourceId":"rfi"},{"id":1781600536000,"createdDate":"2026-06-16 09:02","name":"法国国际广播电台","title":"世界杯第6日：佛得角队40岁门将一战封神 法国与阿根廷即将分别亮相","content":"2026年美加墨世界杯开幕第五日，爆出了首个大冷门。作为欧洲冠军、同时也是夺冠热门之一的西班牙队，竟然在遭遇佛得角队时意外受挫，仅收获一场平局。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260616-%E4%B8%96%E7%95%8C%E6%9D%AF%E7%AC%AC6%E6%97%A5-40%E5%B2%81%E4%BD%9B%E5%BE%97%E8%A7%92%E9%98%9F%E9%97%A8%E5%B0%86%E4%B8%80%E6%88%98%E5%B0%81%E7%A5%9E-%E6%B3%95%E5%9B%BD%E4%B8%8E%E9%98%BF%E6%A0%B9%E5%BB%B7%E5%8D%B3%E5%B0%86%E4%BA%AE%E7%9B%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781600536000.webp","sourceId":"rfi"},{"id":1781599043000,"createdDate":"2026-06-16 08:37","name":"法国国际广播电台","title":"打破传统：官媒播出逾6分钟影片强化“人民领袖”形象“巧妙”替习近平庆生","content":"中国全国党建工作座谈会于昨日周一（6月15日）在北京召开。会议首次明确提出“习近平党建思想”，并将其确立为全党当前及今后一段时间的重要政治任务。另据中央社报道，在中国不为领导人公开庆生的传统下，官媒央视昨天刻意播出时长逾6分钟的「共产党员习近平」影片，以凸显其党性的方式“变相”为习近平庆生。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260616-%E6%89%93%E7%A0%B4%E4%BC%A0%E7%BB%9F-%E5%AE%98%E5%AA%92%E6%92%AD%E5%87%BA%E9%80%BE6%E5%88%86%E9%92%9F%E5%BD%B1%E7%89%87%E5%BC%BA%E5%8C%96-%E4%BA%BA%E6%B0%91%E9%A2%86%E8%A2%96-%E5%BD%A2%E8%B1%A1-%E5%B7%A7%E5%A6%99-%E6%9B%BF%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%BA%86%E7%94%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781599043000.webp","sourceId":"rfi"},{"id":1781598213000,"createdDate":"2026-06-16 08:23","name":"法国国际广播电台","title":"国民党主席郑丽文白宫会面无疾而终低调返台 立法院长韩国瑜将接棒访华盛顿","content":"郑丽文历史性的16天访美行程被国际媒体评论为高开低收，白宫会面也无疾而终，整趟行程被指含金量有限。同时，立法院长韩国瑜收到美方邀请21日访美，预计将以高规格的接待。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260616-%E5%9B%BD%E6%B0%91%E5%85%9A%E4%B8%BB%E5%B8%AD%E9%83%91%E4%B8%BD%E6%96%87%E7%99%BD%E5%AE%AB%E4%BC%9A%E9%9D%A2%E6%97%A0%E7%96%BE%E8%80%8C%E7%BB%88%E4%BD%8E%E8%B0%83%E8%BF%94%E5%8F%B0-%E7%AB%8B%E6%B3%95%E9%99%A2%E9%95%BF%E9%9F%A9%E5%9B%BD%E7%91%9C%E5%B0%86%E6%8E%A5%E6%A3%92%E8%AE%BF%E5%8D%8E%E7%9B%9B%E9%A1%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781598213000.webp","sourceId":"rfi"},{"id":1781596755000,"createdDate":"2026-06-16 07:59","name":"法国国际广播电台","title":"日本意大利举行首脑会谈  发表开发宇宙合作联合声明","content":"日本首相高市早苗于15日（日本时间同日）在罗马与意大利总理梅洛尼举行日意首脑会谈，针对美国总统特朗普宣布美国与伊朗已就结束战斗达成协议一事，双方就今后的应对措施进行了磋商。此外，日意两国还发表了关于加强宇宙开发等尖端技术领域合作的联合声明。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260616-%E6%97%A5%E6%9C%AC%E6%84%8F%E5%A4%A7%E5%88%A9%E4%B8%BE%E8%A1%8C%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88-%E5%8F%91%E8%A1%A8%E5%BC%80%E5%8F%91%E5%AE%87%E5%AE%99%E5%90%88%E4%BD%9C%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781596755000.webp","sourceId":"rfi"},{"id":1781595342000,"createdDate":"2026-06-16 07:35","name":"法国国际广播电台","title":"香港武官治港架构再多一员 退休警队二把手转跑道任食环署长","content":"长期服务警队的李家超成为特首後，有学者已指香港将进入「警察治港」年代，继近期委任警队高层掌管政府新闻处後，今(16日)天又再破天荒让退休警队高层取代文官出任政府要职，外聘前警务处副处长袁旭健，掌管香港的食物环境卫生工作，使李家超任内，由前纪律部队高层转任为港府要职的人数增至九人。评论指，这将进一步巩固香港警察治港的局面，更谑称，这应可令2019年後不受欢迎而令警队招募困难的现象，成为匪夷所思。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260616-%E9%A6%99%E6%B8%AF%E6%AD%A6%E5%AE%98%E6%B2%BB%E6%B8%AF%E6%9E%B6%E6%9E%84%E5%86%8D%E5%A4%9A%E4%B8%80%E5%91%98-%E9%80%80%E4%BC%91%E8%AD%A6%E9%98%9F%E4%BA%8C%E6%8A%8A%E6%89%8B%E8%BD%AC%E8%B7%91%E9%81%93%E4%BB%BB%E9%A3%9F%E7%8E%AF%E7%BD%B2%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/16/1781595342000.webp","sourceId":"rfi"}]