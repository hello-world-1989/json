[{"id":1781796220000,"createdDate":"2026-06-18 15:23","name":"美国之音","title":"赖清德：台湾维护自身安全不应被视为挑衅","content":"台湾守护自身安全“不应被视为对中国的挑衅”，台湾总统赖清德星期四(6月18日)在台北宾馆与国际媒体茶叙时表示。他同时呼吁中国放弃武力攻打台湾，并希望美国能够尽快批准新的对台军售。赖清德还重申将加强防务建设，并与美国保持密切沟通。","newsLink":"https://www.voachinese.com/a/taiwan-should-not-be-seen-as-a-provocation-for-safeguarding-its-security-20260618/8162284.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/18/1781796220000.webp","sourceId":"voa"},{"id":1781796058000,"createdDate":"2026-06-18 15:20","name":"美国之音","title":"美军恢复美国太平洋司令部名称","content":"美国战争部宣布将美国印太司令部(USINDOPACOM)的名称恢复为之前的美国太平洋司令部(USPACOM)。","newsLink":"https://www.voachinese.com/a/department-of-war-announced-that-usindopacom-will-officially-restore-its-name-to-uspacom-20260618/8162279.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/18/1781796058000.webp","sourceId":"voa"},{"id":1781817143000,"createdDate":"2026-06-18 21:12","name":"美国之音","title":"美众议员提出新法案，拟议取消对被指控与中共有关联的美国高校的联邦资助","content":"美国一名共和党议员近日提出一项新的法案，要求取消涉嫌与中国共产党有关联的组织合作的美国高校的联邦拨款。这名议员说，这项法案旨在保护美国大学免受外国情报威胁。","newsLink":"https://www.voachinese.com/a/u-s-representative-introduces-bill-to-bar-federal-funds-for-colleges-with-alleged-ccp-ties-20260618/8162349.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/18/1781817143000.webp","sourceId":"voa"},{"id":1781816198000,"createdDate":"2026-06-18 20:56","name":"美国之音","title":"台湾总统赖清德：特朗普两个任期军售皆满足台湾需求，对后续军售寄予厚望","content":"台湾总统赖清德星期四(6月18日)说，他可以确认美国对台安全承诺没有改变，美台对于强化安全及加速强化台湾自我防卫力量目标一致，因此他对特朗普总统后续对台军售也“寄予厚望”。","newsLink":"https://www.voachinese.com/a/taiwan-president-says-highly-hopeful-u-s-arms-sales-would-go-forward-20260618/8162327.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/18/1781816198000.webp","sourceId":"voa"},{"id":1781807957000,"createdDate":"2026-06-18 18:39","name":"美国之音","title":"乌克兰无人机袭击莫斯科，击中炼油厂","content":"乌克兰星期四(6月18日)对莫斯科发动了一次重大无人机袭击，本星期以来第二次击中一处炼油厂。","newsLink":"https://www.voachinese.com/a/ukrainian-drone-attack-targets-moscow-hits-oil-refinery-20260618/8162313.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/18/1781807957000.webp","sourceId":"voa"},{"id":1781806237000,"createdDate":"2026-06-18 18:10","name":"美国之音","title":"美国推动北约盟国承担更多防务责任并开始审议驻欧美军规模","content":"美国战争部长皮特·海格塞斯宣布对美国在欧洲的军事部署进行为期六个月的审议，他同时呼吁北约的欧洲盟国为其防务“承担主要责任”。","newsLink":"https://www.voachinese.com/a/us-announces-review-of-us-troop-presence-in-europe-amid-push-for-nato-allies-to-take-on-more-defense-responsibility-20260618/8162306.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/18/1781806237000.webp","sourceId":"voa"}]