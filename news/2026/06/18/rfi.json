[{"id":1781775585000,"createdDate":"2026-06-18 09:39","name":"法国国际广播电台","title":"联邦法官裁定：孟晚舟的供述可用于华为刑事诉讼","content":"根据周二提交给布鲁克林联邦法院的一份法官裁决，华为一位高管承认该公司在伊朗非法开展业务，这一供述可能在即将开庭的美国对华为的审判中被用作证据。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260618-%E8%81%94%E9%82%A6%E6%B3%95%E5%AE%98%E8%A3%81%E5%AE%9A-%E5%9C%A8%E5%88%91%E4%BA%8B%E5%AE%A1%E5%88%A4%E4%B8%AD%EF%BC%8C%E5%AD%9F%E6%99%9A%E8%88%9F%E7%9A%84%E4%BE%9B%E8%BF%B0%E5%8F%AF%E4%BD%9C%E4%B8%BA%E5%AF%B9%E5%8D%8E%E4%B8%BA%E7%9A%84%E8%AF%81%E6%8D%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781775585000.webp","sourceId":"rfi"},{"id":1781774065000,"createdDate":"2026-06-18 09:14","name":"法国国际广播电台","title":"赖清德：呼吁中国放弃在三海扩军，也放弃武力攻台；望美对台军售顺利通过","content":"台湾总统赖清德周四在台北宾馆与国际媒体茶叙，致词时感谢七国集团（G7）再次声明印太地区“不允许任何一方改变现状”。七国集团领导人在周三公布的“就地缘政治问题”的联合声明中表示，“我们强调建立在法治基础上的自由开放的印度-太平洋的重要性。我们重申反对任何单方面改变现状的企图，特别是以武力或胁迫手段改变东中国海、南中国海和台湾海峡两岸的现状，这些问题只应通过对话和平解决”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260618-%E8%B5%96%E6%B8%85%E5%BE%B7-%E5%91%BC%E5%90%81%E4%B8%AD%E5%9B%BD%E6%94%BE%E5%BC%83%E5%9C%A8%E4%B8%89%E6%B5%B7%E6%89%A9%E5%86%9B%EF%BC%8C%E4%B9%9F%E6%94%BE%E5%BC%83%E6%AD%A6%E5%8A%9B%E6%94%BB%E5%8F%B0-%E6%9C%9B%E7%BE%8E%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E9%A1%BA%E5%88%A9%E9%80%9A%E8%BF%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781774065000.webp","sourceId":"rfi"},{"id":1781772268000,"createdDate":"2026-06-18 08:44","name":"法国国际广播电台","title":"未经许可向华为出口手机传感器和软件 博世同意向美支付3600万美元","content":"美国商务部周三表示，德国科技公司博世同意向美国当局支付3600万美元，原因是该公司曾向华为出口了价值超过7000万美元的手机传感器产品和软件。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260618-%E6%9C%AA%E7%BB%8F%E8%AE%B8%E5%8F%AF%E5%90%91%E5%8D%8E%E4%B8%BA%E5%87%BA%E5%8F%A3%E6%89%8B%E6%9C%BA%E4%BC%A0%E6%84%9F%E5%99%A8%E5%92%8C%E8%BD%AF%E4%BB%B6-%E5%8D%9A%E4%B8%96%E5%90%8C%E6%84%8F%E5%90%91%E7%BE%8E%E6%94%AF%E4%BB%983600%E4%B8%87%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781772268000.webp","sourceId":"rfi"},{"id":1781771631000,"createdDate":"2026-06-18 08:33","name":"法国国际广播电台","title":"中国官方拟整治外卖行业“内卷式”竞争","content":"中国官媒新华社周三（6月17日）称，中国正准备加强外卖平台不正当竞争行为的监管，本周起，相关新规已向社会公开征求意见（《外卖平台补贴行为规范十条（征求意见稿）》）。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260618-%E4%B8%AD%E5%9B%BD%E5%AE%98%E6%96%B9%E6%8B%9F%E6%95%B4%E6%B2%BB%E5%A4%96%E5%8D%96%E8%A1%8C%E4%B8%9A-%E5%86%85%E5%8D%B7%E5%BC%8F-%E7%AB%9E%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781771631000.webp","sourceId":"rfi"},{"id":1781767764000,"createdDate":"2026-06-18 07:29","name":"法国国际广播电台","title":"京官夏宝龙结束访港　肯定港府工作向李家超竖大拇指引发联想","content":"在距离香港特首换届还有一年时间之际，早前以「时间一到便会知道」来回应会否连任问题的特首李家超，获主管港澳事务的京官夏宝龙离港前竖大拇指，引发北京为李家超连任「开绿灯」的联想。有学者认为，京官释放对港府和李家超予以肯定的讯息，是要表明北京属意让李家超连任；但亦有意见关注，夏宝龙提及宏福苑追责问题，可能对李家超能否连任带来影响。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260618-%E4%BA%AC%E5%AE%98%E5%A4%8F%E5%AE%9D%E9%BE%99%E7%BB%93%E6%9D%9F%E8%AE%BF%E6%B8%AF-%E8%82%AF%E5%AE%9A%E6%B8%AF%E5%BA%9C%E5%B7%A5%E4%BD%9C%E5%90%91%E6%9D%8E%E5%AE%B6%E8%B6%85%E7%AB%96%E5%A4%A7%E6%8B%87%E6%8C%87%E5%BC%95%E5%8F%91%E8%81%94%E6%83%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781767764000.webp","sourceId":"rfi"}]