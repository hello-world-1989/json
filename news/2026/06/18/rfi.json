[{"id":1781775585000,"createdDate":"2026-06-18 09:39","name":"法国国际广播电台","title":"联邦法官裁定：孟晚舟的供述可用于华为刑事诉讼","content":"根据周二提交给布鲁克林联邦法院的一份法官裁决，华为一位高管承认该公司在伊朗非法开展业务，这一供述可能在即将开庭的美国对华为的审判中被用作证据。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260618-%E8%81%94%E9%82%A6%E6%B3%95%E5%AE%98%E8%A3%81%E5%AE%9A-%E5%9C%A8%E5%88%91%E4%BA%8B%E5%AE%A1%E5%88%A4%E4%B8%AD%EF%BC%8C%E5%AD%9F%E6%99%9A%E8%88%9F%E7%9A%84%E4%BE%9B%E8%BF%B0%E5%8F%AF%E4%BD%9C%E4%B8%BA%E5%AF%B9%E5%8D%8E%E4%B8%BA%E7%9A%84%E8%AF%81%E6%8D%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781775585000.webp","sourceId":"rfi"},{"id":1781774065000,"createdDate":"2026-06-18 09:14","name":"法国国际广播电台","title":"赖清德：呼吁中国放弃在三海扩军，也放弃武力攻台；望美对台军售顺利通过","content":"台湾总统赖清德周四在台北宾馆与国际媒体茶叙，致词时感谢七国集团（G7）再次声明印太地区“不允许任何一方改变现状”。七国集团领导人在周三公布的“就地缘政治问题”的联合声明中表示，“我们强调建立在法治基础上的自由开放的印度-太平洋的重要性。我们重申反对任何单方面改变现状的企图，特别是以武力或胁迫手段改变东中国海、南中国海和台湾海峡两岸的现状，这些问题只应通过对话和平解决”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260618-%E8%B5%96%E6%B8%85%E5%BE%B7-%E5%91%BC%E5%90%81%E4%B8%AD%E5%9B%BD%E6%94%BE%E5%BC%83%E5%9C%A8%E4%B8%89%E6%B5%B7%E6%89%A9%E5%86%9B%EF%BC%8C%E4%B9%9F%E6%94%BE%E5%BC%83%E6%AD%A6%E5%8A%9B%E6%94%BB%E5%8F%B0-%E6%9C%9B%E7%BE%8E%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E9%A1%BA%E5%88%A9%E9%80%9A%E8%BF%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781774065000.webp","sourceId":"rfi"},{"id":1781772268000,"createdDate":"2026-06-18 08:44","name":"法国国际广播电台","title":"未经许可向华为出口手机传感器和软件 博世同意向美支付3600万美元","content":"美国商务部周三表示，德国科技公司博世同意向美国当局支付3600万美元，原因是该公司曾向华为出口了价值超过7000万美元的手机传感器产品和软件。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260618-%E6%9C%AA%E7%BB%8F%E8%AE%B8%E5%8F%AF%E5%90%91%E5%8D%8E%E4%B8%BA%E5%87%BA%E5%8F%A3%E6%89%8B%E6%9C%BA%E4%BC%A0%E6%84%9F%E5%99%A8%E5%92%8C%E8%BD%AF%E4%BB%B6-%E5%8D%9A%E4%B8%96%E5%90%8C%E6%84%8F%E5%90%91%E7%BE%8E%E6%94%AF%E4%BB%983600%E4%B8%87%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781772268000.webp","sourceId":"rfi"},{"id":1781771631000,"createdDate":"2026-06-18 08:33","name":"法国国际广播电台","title":"中国官方拟整治外卖行业“内卷式”竞争","content":"中国官媒新华社周三（6月17日）称，中国正准备加强外卖平台不正当竞争行为的监管，本周起，相关新规已向社会公开征求意见（《外卖平台补贴行为规范十条（征求意见稿）》）。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260618-%E4%B8%AD%E5%9B%BD%E5%AE%98%E6%96%B9%E6%8B%9F%E6%95%B4%E6%B2%BB%E5%A4%96%E5%8D%96%E8%A1%8C%E4%B8%9A-%E5%86%85%E5%8D%B7%E5%BC%8F-%E7%AB%9E%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781771631000.webp","sourceId":"rfi"},{"id":1781767764000,"createdDate":"2026-06-18 07:29","name":"法国国际广播电台","title":"京官夏宝龙结束访港　肯定港府工作向李家超竖大拇指引发联想","content":"在距离香港特首换届还有一年时间之际，早前以「时间一到便会知道」来回应会否连任问题的特首李家超，获主管港澳事务的京官夏宝龙离港前竖大拇指，引发北京为李家超连任「开绿灯」的联想。有学者认为，京官释放对港府和李家超予以肯定的讯息，是要表明北京属意让李家超连任；但亦有意见关注，夏宝龙提及宏福苑追责问题，可能对李家超能否连任带来影响。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260618-%E4%BA%AC%E5%AE%98%E5%A4%8F%E5%AE%9D%E9%BE%99%E7%BB%93%E6%9D%9F%E8%AE%BF%E6%B8%AF-%E8%82%AF%E5%AE%9A%E6%B8%AF%E5%BA%9C%E5%B7%A5%E4%BD%9C%E5%90%91%E6%9D%8E%E5%AE%B6%E8%B6%85%E7%AB%96%E5%A4%A7%E6%8B%87%E6%8C%87%E5%BC%95%E5%8F%91%E8%81%94%E6%83%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781767764000.webp","sourceId":"rfi"},{"id":1781803657000,"createdDate":"2026-06-18 17:27","name":"法国国际广播电台","title":"万斯：美解除部分对伊朗海上封锁","content":"美国副总统万斯（JDVance）18日表示，美国海军已依据美国与伊朗达成的停火协议，允许超过12艘船舶进入伊朗港口，并解除部分海上封锁措施。随着全球能源运输要道霍尔木兹海峡恢复通行，超过1250万桶石油已于17日晚间经由该航道运输，创下今年2月底冲突爆发以来最高单日流量。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260618-%E4%B8%87%E6%96%AF-%E7%BE%8E%E8%A7%A3%E9%99%A4%E9%83%A8%E5%88%86%E5%AF%B9%E4%BC%8A%E6%9C%97%E6%B5%B7%E4%B8%8A%E5%B0%81%E9%94%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781803657000.webp","sourceId":"rfi"},{"id":1781799439000,"createdDate":"2026-06-18 16:17","name":"法国国际广播电台","title":"北京指责外国情报机构：用“间谍龟”或“间谍鱼”在其水域采集数据","content":"据法国周刊《快报》电子版周二16日登出由阿尔班·德·特雷米奥勒署名的报道，中国国家安全部指责外国情报机构利用“间谍乌龟”或者“间谍鱼”来收集海底数据。在报道此一消息的同时时，《快报》也提醒读者反思“是否应该全然相信北京的说法？”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260618-%E5%8C%97%E4%BA%AC%E6%8C%87%E8%B4%A3%E5%A4%96%E5%9B%BD%E6%83%85%E6%8A%A5%E6%9C%BA%E6%9E%84-%E7%94%A8-%E9%97%B4%E8%B0%8D%E9%BE%9F-%E6%88%96-%E9%97%B4%E8%B0%8D%E9%B1%BC-%E5%9C%A8%E5%85%B6%E6%B0%B4%E5%9F%9F%E9%87%87%E9%9B%86%E6%95%B0%E6%8D%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781799439000.webp","sourceId":"rfi"},{"id":1781796641000,"createdDate":"2026-06-18 15:30","name":"法国国际广播电台","title":"欧盟峰会：成员国认为须采取紧急行动 防止中国驱动下的欧洲去工业化","content":"据《南华早报》报导，多位消息人士周三表示，从自由市场主义者到长期干预主义者，欧盟各派国家在关键的欧盟布鲁塞尔峰会召开前夕，都趋同认为必须采取紧急行动，防止中国驱动下的欧洲去工业化。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260618-%E6%AC%A7%E7%9B%9F%E5%B3%B0%E4%BC%9A-%E6%88%90%E5%91%98%E5%9B%BD%E8%AE%A4%E4%B8%BA%E9%A1%BB%E9%87%87%E5%8F%96%E7%B4%A7%E6%80%A5%E8%A1%8C%E5%8A%A8-%E9%98%B2%E6%AD%A2%E4%B8%AD%E5%9B%BD%E9%A9%B1%E5%8A%A8%E4%B8%8B%E7%9A%84%E6%AC%A7%E6%B4%B2%E5%8E%BB%E5%B7%A5%E4%B8%9A%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781796641000.webp","sourceId":"rfi"},{"id":1781795639000,"createdDate":"2026-06-18 15:13","name":"法国国际广播电台","title":"法国今夏第二波热浪来袭，酷暑高温下加强自我防护","content":"法国多地本周进入新一波高温酷暑天气。自18日起，气象部门向包括巴黎大区在内的26个省发出了橙色酷暑警报。气温在未来几天仍会不断升高，个别区域最高温度可能会达到摄氏40度。这已经是今年入夏以来，法国境内的第二波热浪。而此时也正值包括音乐节在内的各种文体活动赶在暑期休假前举行的高峰期。卫生部门接连发出提示，提醒国人注意防暑。而热浪频繁提早来袭也迫使政府面对必须加快让城市基建规划适应气候变化的压力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%81%A5%E5%BA%B7%E6%97%B6%E9%97%B4/20260618-%E6%B3%95%E5%9B%BD%E4%BB%8A%E5%A4%8F%E7%AC%AC%E4%BA%8C%E6%B3%A2%E7%83%AD%E6%B5%AA%E6%9D%A5%E8%A2%AD%EF%BC%8C%E9%85%B7%E6%9A%91%E9%AB%98%E6%B8%A9%E4%B8%8B%E5%8A%A0%E5%BC%BA%E8%87%AA%E6%88%91%E9%98%B2%E6%8A%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781795639000.webp","sourceId":"rfi"},{"id":1781792992000,"createdDate":"2026-06-18 14:29","name":"法国国际广播电台","title":"台湾高层密集发声：谈军售、区域安全与台湾的国际生存空间","content":"近期台湾方面连续就两岸关系、区域安全以及对美军售问题发表相关表态，并再次指责中国大陆持续加大对台压力。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260618-%E5%8F%B0%E6%B9%BE%E9%AB%98%E5%B1%82%E5%AF%86%E9%9B%86%E5%8F%91%E5%A3%B0-%E8%B0%88%E5%86%9B%E5%94%AE-%E5%8C%BA%E5%9F%9F%E5%AE%89%E5%85%A8%E4%B8%8E%E5%8F%B0%E6%B9%BE%E7%9A%84%E5%9B%BD%E9%99%85%E7%94%9F%E5%AD%98%E7%A9%BA%E9%97%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781792992000.webp","sourceId":"rfi"},{"id":1781791604000,"createdDate":"2026-06-18 14:06","name":"法国国际广播电台","title":"敬业钢铁要求赔偿后 英政府：意志坚定在未来将英国钢铁公司收归国有","content":"英国政府周四发表声明称，英国“意志坚定”将英国钢铁公司国有化。此前数周，英国政府宣布计划赋予其新的权力，以便将其实现。一份部长级书面声明称：“本届政府意志坚定利用该法案赋予的权力，在未来将英国钢铁公司收归国有，前提是符合公共利益”。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260618-%E6%95%AC%E4%B8%9A%E9%92%A2%E9%93%81%E8%A6%81%E6%B1%82%E8%B5%94%E5%81%BF%E5%90%8E-%E8%8B%B1%E6%94%BF%E5%BA%9C-%E6%84%8F%E5%BF%97%E5%9D%9A%E5%AE%9A%E5%9C%A8%E6%9C%AA%E6%9D%A5%E5%B0%86%E8%8B%B1%E5%9B%BD%E9%92%A2%E9%93%81%E5%85%AC%E5%8F%B8%E6%94%B6%E5%BD%92%E5%9B%BD%E6%9C%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781791604000.webp","sourceId":"rfi"},{"id":1781791157000,"createdDate":"2026-06-18 13:59","name":"法国国际广播电台","title":"刚果（金）52年后重返世界杯，首战与葡萄牙对踢成平局","content":"6月17日，美国休斯顿体育场上，时隔52年重返世界杯比赛的非洲国家刚果民主共和国，简称刚果（金）首场比赛就对阵足球劲旅葡萄牙队，竟以1：1踢成平局，为该国本届比赛赢得首个积分，这也是刚果金球队首次在世界杯上成功进球。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260618-%E5%88%9A%E6%9E%9C-%E9%87%91-52%E5%B9%B4%E5%90%8E%E9%87%8D%E8%BF%94%E4%B8%96%E7%95%8C%E6%9D%AF%EF%BC%8C%E9%A6%96%E6%88%98%E4%B8%8E%E8%91%A1%E8%90%84%E7%89%99%E5%AF%B9%E8%B8%A2%E6%88%90%E5%B9%B3%E5%B1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781791157000.webp","sourceId":"rfi"},{"id":1781789288000,"createdDate":"2026-06-18 13:28","name":"法国国际广播电台","title":"Manus中国投资人据报拟以20亿美元价格从Meta手中回购公司","content":"据科技媒体《TheInformation》周四援引两位直接知情人士报导称，人工智能初创公司Manus的早期中国投资人计划以脸书母公司Meta当初支付的20亿美元价格回购该公司。报导称，此举是为了回应中国政府要求撤销这笔交易的命令。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260618-manus%E4%B8%AD%E5%9B%BD%E6%8A%95%E8%B5%84%E4%BA%BA%E6%8D%AE%E6%8A%A5%E6%8B%9F%E4%BB%A520%E4%BA%BF%E7%BE%8E%E5%85%83%E4%BB%B7%E6%A0%BC%E4%BB%8Emeta%E6%89%8B%E4%B8%AD%E5%9B%9E%E8%B4%AD%E5%85%AC%E5%8F%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781789288000.webp","sourceId":"rfi"},{"id":1781789088000,"createdDate":"2026-06-18 13:24","name":"法国国际广播电台","title":"东盟强调战略自主 伙伴关系多样化","content":"继七大工业国集团峰会在法国拉开序幕后，俄罗斯-东盟关系35周年纪念峰会在喀山市隆重登场。前者焦点汇聚如何结束俄乌和中东战争。后者探讨在全球地缘政治和能源压力下如何寻求能源合作。分析意见认为，东盟多国领导人在当前复杂国际局势下赴俄参会，凸显了东盟的战略自主性且有意对外释放保持伙伴关系多样化的信号。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260618-%E4%B8%9C%E7%9B%9F%E5%BC%BA%E8%B0%83%E6%88%98%E7%95%A5%E8%87%AA%E4%B8%BB-%E4%BC%99%E4%BC%B4%E5%85%B3%E7%B3%BB%E5%A4%9A%E6%A0%B7%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781789088000.webp","sourceId":"rfi"},{"id":1781788087000,"createdDate":"2026-06-18 13:08","name":"法国国际广播电台","title":"香港驻伦敦经贸办间谍案 两人判囚8年和10年","content":"两名男子，其中一人曾担任英国移民官员，周四被判入狱，罪名是代表香港，最终是代表中国，监视目前居住在英国的著名民主异见人士。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260618-%E9%A6%99%E6%B8%AF%E9%A9%BB%E4%BC%A6%E6%95%A6%E7%BB%8F%E8%B4%B8%E5%8A%9E%E9%97%B4%E8%B0%8D%E6%A1%88-%E4%B8%A4%E4%BA%BA%E5%88%A4%E5%9B%9A8%E5%B9%B4%E5%92%8C10%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781788087000.webp","sourceId":"rfi"},{"id":1781786481000,"createdDate":"2026-06-18 12:41","name":"法国国际广播电台","title":"陆委会发言人：世界杯在台转播至少有40年，国台办是多管闲事","content":"针对国台办发言人陈斌华周三表示，欢迎台湾民众用大陆APP与网路观看世界杯，台湾陆委会副主委兼发言人梁文杰周四说，台湾人已经看世界杯40几年都没问题，认为国台办多管闲事。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260618-%E9%99%86%E5%A7%94%E4%BC%9A%E5%8F%91%E8%A8%80%E4%BA%BA-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%9C%A8%E5%8F%B0%E8%BD%AC%E6%92%AD%E8%87%B3%E5%B0%91%E6%9C%8940%E5%B9%B4%EF%BC%8C%E5%9B%BD%E5%8F%B0%E5%8A%9E%E6%98%AF%E5%A4%9A%E7%AE%A1%E9%97%B2%E4%BA%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781786481000.webp","sourceId":"rfi"},{"id":1781783488000,"createdDate":"2026-06-18 11:51","name":"法国国际广播电台","title":"本周第二次击中俄首都炼油厂 泽连斯基：若乌克兰战火纷飞，莫斯科也将会燃烧","content":"乌克兰总统泽连斯基（VolodymyrZelenskyy）周四表示，对俄罗斯发动的大规模无人机袭击是对本周基辅一座历史悠久的修道院遭袭的报复，并称如果袭击继续下去，“莫斯科将会燃烧”。数十架无人机连夜袭击了莫斯科，本周第二次击中了俄罗斯首都的炼油厂。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260618-%E6%9C%AC%E5%91%A8%E7%AC%AC%E4%BA%8C%E6%AC%A1%E5%87%BB%E4%B8%AD%E4%BF%84%E9%A6%96%E9%83%BD%E7%82%BC%E6%B2%B9%E5%8E%82-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E8%8B%A5%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E7%81%AB%E7%BA%B7%E9%A3%9E%EF%BC%8C%E8%8E%AB%E6%96%AF%E7%A7%91%E4%B9%9F%E5%B0%86%E4%BC%9A%E7%87%83%E7%83%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781783488000.webp","sourceId":"rfi"},{"id":1781782032000,"createdDate":"2026-06-18 11:27","name":"法国国际广播电台","title":"陈希不再担任国家行政学院院长职务 蔡奇兼任","content":"中国官媒新华社周四报导指，国务院任免国家工作人员。蔡奇兼任国家行政学院院长。陈希不再担任国家行政学院院长职务；免去王志勇的国家中医药管理局副局长职务。消息来自人力资源和社会保障部网站。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260618-%E9%99%88%E5%B8%8C%E4%B8%8D%E5%86%8D%E6%8B%85%E4%BB%BB%E5%9B%BD%E5%AE%B6%E8%A1%8C%E6%94%BF%E5%AD%A6%E9%99%A2%E9%99%A2%E9%95%BF%E8%81%8C%E5%8A%A1-%E8%94%A1%E5%A5%87%E5%85%BC%E4%BB%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781782032000.webp","sourceId":"rfi"},{"id":1781780851000,"createdDate":"2026-06-18 11:07","name":"法国国际广播电台","title":"欧洲议会改革非法移民遣返政策","content":"欧洲议会于昨天（2026年06月17日周三）表决通过有关难民申请的改革。未来庇护申请被拒的人有可能会被送往非洲中部大湖区国家。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260618-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E6%AC%A7%E6%B4%B2%E8%AE%AE%E4%BC%9A%E8%A1%A8%E5%86%B3%E9%A9%B1%E9%80%90%E9%9D%9E%E6%B3%95%E7%A7%BB%E6%B0%91%E6%94%B9%E9%9D%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781780851000.webp","sourceId":"rfi"},{"id":1781779847000,"createdDate":"2026-06-18 10:50","name":"法国国际广播电台","title":"从谅解备忘录呈现出的美伊较量看，能笑到最后的是德黑兰！","content":"大家好，欢迎收听法国报纸摘要，周三17日晚，在凡尔赛，美国总统特朗普签署了一份旨在结束战争包含14项条款的谅解备忘录，成为周四6月18日法国各大日报的首页关注重点。根据该文本，无论是右翼大报《费加罗报》还是左翼大报《解放报》都注意到美国向伊朗作出了重大让步。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260618-%E4%BB%8E%E8%B0%85%E8%A7%A3%E5%A4%87%E5%BF%98%E5%BD%95%E5%91%88%E7%8E%B0%E5%87%BA%E7%9A%84%E7%BE%8E%E4%BC%8A%E8%BE%83%E9%87%8F%E7%9C%8B%EF%BC%8C%E8%83%BD%E7%AC%91%E5%88%B0%E6%9C%80%E5%90%8E%E7%9A%84%E6%98%AF%E5%BE%B7%E9%BB%91%E5%85%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781779847000.webp","sourceId":"rfi"},{"id":1781779288000,"createdDate":"2026-06-18 10:41","name":"法国国际广播电台","title":"特朗普在G7记者会上透露：希望日本参加对伊朗战争遭拒绝","content":"美国总统特朗普6月17日在法国举行的七国集团（G7）峰会全部日程结束后，在当地举行记者会。他表示，美国曾就参与对伊朗军事行动一事征询日本意见，但日本以“不想卷入其中”为由予以拒绝。此外，对于在与伊朗达成停战协议后，包括日本在内的各国是否会提供军事支援的问题，特朗普表示：“没有这个必要。”","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260618-%E7%89%B9%E6%9C%97%E6%99%AE%E5%9C%A8g7%E8%AE%B0%E8%80%85%E4%BC%9A%E4%B8%8A%E9%80%8F%E9%9C%B2-%E5%B8%8C%E6%9C%9B%E6%97%A5%E6%9C%AC%E5%8F%82%E5%8A%A0%E5%AF%B9%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E9%81%AD%E6%8B%92%E7%BB%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781779288000.webp","sourceId":"rfi"},{"id":1781778267000,"createdDate":"2026-06-18 10:24","name":"法国国际广播电台","title":"伊朗议长：伊朗不仅是中国客户更是真正伙伴，伊中将成为新区域集团的核心轴心","content":"伊朗伊斯兰议会议长兼伊朗中国事务特别代表卡利巴夫周三出席了“中国事务特别代表与伊朗商会共识研讨会”。伊通社报导指，卡利巴夫在阐述中国对伊朗的独特地位时表示，中国不仅仅是伊朗的客户或贸易伙伴，更是我方真正的战略伙伴，伊朗与中国必将成为新区域集团的核心轴心。此次会议有各行业组织代表、商会经济委员会成员及国家经济高级主管参加。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260618-%E4%BC%8A%E6%9C%97%E8%AE%AE%E9%95%BF-%E4%BC%8A%E6%9C%97%E4%B8%8D%E4%BB%85%E6%98%AF%E4%B8%AD%E5%9B%BD%E5%AE%A2%E6%88%B7%E6%9B%B4%E6%98%AF%E7%9C%9F%E6%AD%A3%E4%BC%99%E4%BC%B4%EF%BC%8C%E4%BB%BB%E4%BD%95%E6%96%B0%E9%9B%86%E5%9B%A2%E4%BC%8A%E4%B8%AD%E9%83%BD%E5%85%B7%E6%9C%89%E5%86%B3%E5%AE%9A%E6%80%A7%E4%B8%94%E4%B8%8D%E5%8F%AF%E6%9B%BF%E4%BB%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/18/1781778267000.webp","sourceId":"rfi"}]