[{"id":1782291437000,"createdDate":"2026-06-24 08:57","name":"法国国际广播电台","title":"德尚因母亲去世缺席世界杯小组赛末轮 法国队由助教斯特凡临时执教","content":"2026年世界杯小组赛继续进行，多支球队在关键战中分出胜负，部分球队已经提前晋级，部分球队则将在最后一轮决定命运。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260624-%E5%BE%B7%E5%B0%9A%E5%9B%A0%E6%AF%8D%E4%BA%B2%E5%8E%BB%E4%B8%96%E7%BC%BA%E5%B8%AD%E4%B8%96%E7%95%8C%E6%9D%AF%E5%B0%8F%E7%BB%84%E8%B5%9B%E6%9C%AB%E8%BD%AE-%E6%B3%95%E5%9B%BD%E9%98%9F%E7%94%B1%E5%8A%A9%E6%95%99%E6%96%AF%E7%89%B9%E5%87%A1%E4%B8%B4%E6%97%B6%E6%89%A7%E6%95%99","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782291437000.webp","sourceId":"rfi"},{"id":1782291026000,"createdDate":"2026-06-24 08:50","name":"法国国际广播电台","title":"中国拘捕两名日本在华员工 传涉嫌出口稀土制品","content":"在中国东北部的大连，两名日资企业的日本籍员工上个月相继被中国当局拘留。消息称，两人涉嫌试图将含有中国实施对日出口管制的稀土加工产品出口至中国境外，因此遭拘留。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260624-%E4%B8%AD%E5%9B%BD%E6%8B%98%E6%8D%95%E4%B8%A4%E5%90%8D%E6%97%A5%E6%9C%AC%E5%9C%A8%E5%8D%8E%E5%91%98%E5%B7%A5-%E4%BC%A0%E6%B6%89%E5%AB%8C%E5%87%BA%E5%8F%A3%E7%A8%80%E5%9C%9F%E5%88%B6%E5%93%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782291026000.webp","sourceId":"rfi"},{"id":1782290799000,"createdDate":"2026-06-24 08:46","name":"法国国际广播电台","title":"阿里巴巴起诉五角大楼 要求撤销其涉军工企业认定","content":"中国电商巨头阿里巴巴已向美国法院提起诉讼，挑战美国国防部将其列入黑名单的决定。该公司周三(6月24日)表示，对被认定为“中国军工企业”提出异议。要求美国国防部撤销其与中国军方存在关联的“中国军工企业”的认定。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260624-%E9%98%BF%E9%87%8C%E5%B7%B4%E5%B7%B4%E8%B5%B7%E8%AF%89%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC-%E8%A6%81%E6%B1%82%E6%92%A4%E9%94%80%E6%B6%89%E5%86%9B%E5%B7%A5%E4%BC%81%E4%B8%9A%E8%AE%A4%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782290799000.webp","sourceId":"rfi"},{"id":1782289783000,"createdDate":"2026-06-24 08:29","name":"法国国际广播电台","title":"世界杯小组赛进入收官阶段 C罗创纪录哥伦比亚提前出线","content":"2026年世界杯小组赛进入收官阶段。巴黎时间6月24日，A组、B组和C组将展开最后一轮较量，多个晋级席位和小组排名悬念有望在这一比赛日揭晓。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260624-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%B0%8F%E7%BB%84%E8%B5%9B%E8%BF%9B%E5%85%A5%E6%94%B6%E5%AE%98%E9%98%B6%E6%AE%B5-c%E7%BD%97%E5%88%9B%E7%BA%AA%E5%BD%95%E5%93%A5%E4%BC%A6%E6%AF%94%E4%BA%9A%E6%8F%90%E5%89%8D%E5%87%BA%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782289783000.webp","sourceId":"rfi"},{"id":1782285298000,"createdDate":"2026-06-24 07:14","name":"法国国际广播电台","title":"黎智英入狱丶公司受禁 无阻办《苹果》展 数百港人飞台观展 重温香港自由年代","content":"今天是《苹果日报》受压结业五周年的日子，但不少香港人显然并未忘记这份曾经敢言的畅销报章，特意前往台北观赏该报走过的26年足迹，一方面缅怀曾是媒体百花齐放的香港，另一方面亦藉重温来让受压的情怀得以抒泄，不少人更是当场抽泣。当年雨伞运动发起人「占中三子」之一的朱耀明牧师表示，展览的报刊头版有如让他重温香港发展史，而他最难忘记的，是警方大举搜查该报大楼的一幕，形容是港府「消灭新闻言论自由的粗暴行动」。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260624-%E9%BB%8E%E6%99%BA%E8%8B%B1%E5%85%A5%E7%8B%B1%E4%B8%B6%E5%85%AC%E5%8F%B8%E5%8F%97%E7%A6%81-%E6%97%A0%E9%98%BB%E5%8A%9E-%E8%8B%B9%E6%9E%9C-%E5%B1%95-%E6%95%B0%E7%99%BE%E6%B8%AF%E4%BA%BA%E9%A3%9E%E5%8F%B0%E8%A7%82%E5%B1%95-%E9%87%8D%E6%B8%A9%E9%A6%99%E6%B8%AF%E8%87%AA%E7%94%B1%E5%B9%B4%E4%BB%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782285298000.webp","sourceId":"rfi"},{"id":1782317719000,"createdDate":"2026-06-24 16:15","name":"法国国际广播电台","title":"市值跻身亚洲三强后，韩国SK海力士拟赴美上市融资290亿美元","content":"韩国芯片巨头SK海力士乘胜追击。周三（6月24日）该企业宣布，计划最早于7月10日在美国纳斯达克上市融资45.45万亿韩元（约合290亿美元），计划发行1779万股新股。若顺利完成上市，规模有望跻身全球历史上最大规模IPO（首次公开募股）之一。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260624-%E5%B8%82%E5%80%BC%E8%B6%85%E8%B6%8A%E4%B8%89%E6%98%9F%E7%94%B5%E5%AD%90%E5%90%8E%EF%BC%8C%E9%9F%A9%E5%9B%BDsk%E6%B5%B7%E5%8A%9B%E5%A3%AB%E6%8B%9F%E8%B5%B4%E7%BE%8E%E4%B8%8A%E5%B8%82%E8%9E%8D%E8%B5%84290%E4%BA%BF%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782317719000.webp","sourceId":"rfi"},{"id":1782317149000,"createdDate":"2026-06-24 16:05","name":"法国国际广播电台","title":"法国新一轮热浪来袭 专家叹：气温终会下降，我们以后就不再会谈论它了","content":"目前席卷法国的热浪再次凸显了法国应对气候变化准备不足的问题。也是研究员的气候专家弗朗索瓦·热梅内(FrançoisGemenne,)感叹道：气候问题只有在热浪来袭时才会被提及。他认为，当务之急是解决建筑翻新问题，并就空调的使用展开讨论。但他也叹道：法国新一轮热浪来袭：“气温终会下降，我们以后就不再会谈论它了。每次都会上演同样的戏码！”","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260624-%E6%B3%95%E5%9B%BD%E6%96%B0%E4%B8%80%E8%BD%AE%E7%83%AD%E6%B5%AA%E6%9D%A5%E8%A2%AD-%E4%B8%93%E5%AE%B6%E5%8F%B9-%E6%B0%94%E6%B8%A9%E7%BB%88%E4%BC%9A%E4%B8%8B%E9%99%8D%EF%BC%8C%E6%88%91%E4%BB%AC%E4%BB%A5%E5%90%8E%E5%B0%B1%E4%B8%8D%E5%86%8D%E4%BC%9A%E8%B0%88%E8%AE%BA%E5%AE%83%E4%BA%86","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782317149000.webp","sourceId":"rfi"},{"id":1782317080000,"createdDate":"2026-06-24 16:04","name":"法国国际广播电台","title":"伊朗与哈马斯就华盛顿与德黑兰的谈判通电话磋商","content":"据伊朗国家电视台周三报道，在为结束中东战争而进行的外交斡旋背景下，伊朗外长就伊朗与美国之间的谈判与巴勒斯坦哈马斯组织一名高官通了电话。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260624-%E4%BC%8A%E6%9C%97%E4%B8%8E%E5%93%88%E9%A9%AC%E6%96%AF%E5%B0%B1%E5%8D%8E%E7%9B%9B%E9%A1%BF%E4%B8%8E%E5%BE%B7%E9%BB%91%E5%85%B0%E7%9A%84%E8%B0%88%E5%88%A4%E9%80%9A%E7%94%B5%E8%AF%9D%E7%A3%8B%E5%95%86","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782317080000.webp","sourceId":"rfi"},{"id":1782310855000,"createdDate":"2026-06-24 14:20","name":"法国国际广播电台","title":"英法德发布联合声明  对中国在台湾东部海域的活动表达关切","content":"英国、法国和德国周三（6月24号）罕见发布联合声明，对中国近期在台湾东海岸的活动发出警告，称中国已在该地区部署海警巡逻，这些活动威胁到地区稳定和航行自由。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260624-%E8%8B%B1%E6%B3%95%E5%BE%B7%E5%8F%91%E5%B8%83%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E-%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%9C%A8%E5%8F%B0%E6%B9%BE%E4%B8%9C%E9%83%A8%E6%B5%B7%E5%9F%9F%E7%9A%84%E6%B4%BB%E5%8A%A8%E8%A1%A8%E8%BE%BE%E5%85%B3%E5%88%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782310855000.webp","sourceId":"rfi"},{"id":1782310594000,"createdDate":"2026-06-24 14:16","name":"法国国际广播电台","title":"金正恩表示正“为海军配备核武器”并计划建造万吨级军舰","content":"朝鲜官方媒体周三报道，朝鲜领导人金正恩表示，该国将为海军配备核武器并建造更大的军舰，与此同时，平壤继续推进其军事扩张计划。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260624-%E9%87%91%E6%AD%A3%E6%81%A9%E8%A1%A8%E7%A4%BA%E6%AD%A3-%E4%B8%BA%E6%B5%B7%E5%86%9B%E9%85%8D%E5%A4%87%E6%A0%B8%E6%AD%A6%E5%99%A8-%E5%B9%B6%E8%AE%A1%E5%88%92%E5%BB%BA%E9%80%A0%E4%B8%87%E5%90%A8%E7%BA%A7%E5%86%9B%E8%88%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782310594000.webp","sourceId":"rfi"},{"id":1782306433000,"createdDate":"2026-06-24 13:07","name":"法国国际广播电台","title":"国际刑事法院首席检察官卡里姆·汗因与下属不当性关系而被解职","content":"路透社海牙6月24日电：国际刑事法院负责监管机构的外交官们认为，首席检察官卡里姆·汗与一名下属女职员存在不当性关系，应被免职，两份决定书副本披露了这一情况。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260624-%E5%9B%BD%E9%99%85%E5%88%91%E4%BA%8B%E6%B3%95%E9%99%A2%E9%A6%96%E5%B8%AD%E6%A3%80%E5%AF%9F%E5%AE%98%E5%8D%A1%E9%87%8C%E5%A7%86%C2%B7%E6%B1%97%E5%9B%A0%E4%B8%8E%E4%B8%8B%E5%B1%9E%E4%B8%8D%E5%BD%93%E6%80%A7%E5%85%B3%E7%B3%BB%E8%80%8C%E8%A2%AB%E8%A7%A3%E9%9B%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782306433000.webp","sourceId":"rfi"},{"id":1782305614000,"createdDate":"2026-06-24 12:53","name":"法国国际广播电台","title":"台湾专家评新转基因植物是否存在环境隐患","content":"欧洲议会6月16日批准了广受争议的有关种植新转基因植物的议案，批评者担心毫无限制的种植新转基因植物将对欧洲的生态环境以及民众的健康产生负面影响，而支持者则强调新转基因植物涉及基因编辑，而并没有引入外来植物的DNA，因此有别于传统转基因植物，应该对两者区别对待，而且，支持者强调欧洲必须在该领域加强研究，应应对来自美国与中国的竞争。新转基因植物究竟是否存在环境隐患？它们今天在亚洲乃至全球的开发状况如何？法广就此采访了台湾大学园艺暨景观学系教授湾杜宜殷教授，欧盟的新转基因植物在台湾被叫做基因编辑作物。","newsLink":"https://www.rfi.fr/cn/%E7%94%9F%E6%80%81/20260624-%E5%8F%B0%E6%B9%BE%E4%B8%93%E5%AE%B6%E8%AF%84%E6%96%B0%E8%BD%AC%E5%9F%BA%E5%9B%A0%E6%A4%8D%E7%89%A9%E6%98%AF%E5%90%A6%E5%AD%98%E5%9C%A8%E7%8E%AF%E5%A2%83%E9%9A%90%E6%82%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782305614000.webp","sourceId":"rfi"},{"id":1782303215000,"createdDate":"2026-06-24 12:13","name":"法国国际广播电台","title":"美伊对霍尔木兹海峡及核问题分歧凸显 卢比奥抵阿联酋开启海湾行程","content":"美国国务卿卢比奥周二再次排除了伊朗在霍尔木兹海峡征收过境费的可能性，该问题与核计划及解冻伊朗资产的条件一样，是美伊两国谈判中的症结所在。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260624-%E7%BE%8E%E4%BC%8A%E5%AF%B9%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%8F%8A%E6%A0%B8%E9%97%AE%E9%A2%98%E5%88%86%E6%AD%A7%E5%87%B8%E6%98%BE-%E5%8D%A2%E6%AF%94%E5%A5%A5%E6%8A%B5%E9%98%BF%E8%81%94%E9%85%8B%E5%BC%80%E5%90%AF%E6%B5%B7%E6%B9%BE%E8%A1%8C%E7%A8%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782303215000.webp","sourceId":"rfi"},{"id":1782302271000,"createdDate":"2026-06-24 11:57","name":"法国国际广播电台","title":"哥伦比亚变天: 圣玛尔塔气候谈判模式何去何从 ?","content":"法国6月24日又迎来气温创纪录的一天，高温天气目前正从欧洲的西南部向东北部推进，今后的几天内，热浪将波及奥地利，德国以及巴尔干半岛地区。昨天联合国秘书长古特雷斯特别就欧洲的新一波热浪以及因雐尔目兹海峡的关闭而引发的能源危机警告说，能源危机与气候危机的原因来自同一个源头，那就是化石能源。确实，虽然这一点早已是巴黎协定签署国的共识，然而，协定签署十多年来，各国却依然无法共同推出一个走出化石能源的路线图，在联合国气候峰会无法取得突破的背景下，今年四月，气候领军国家哥伦比亚牵头邀请了近60个国家在该国的圣玛尔塔(SaintMarta)召开会议，试图绕过联合国的决策模式，为走出化石能源另辟蹊径，此举曾经为气候活动人士带来了新的希望，圣玛尔塔气候谈判模式受到了广泛的好评，尤其是哥伦比亚本国也是一个产油国，这就更加显得难能可贵。然而，刚刚结束的哥伦比亚总统选举却很可能使此一新的希望成为泡影， 圣玛尔塔气候谈判模式面临考研。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260624-%E5%93%A5%E4%BC%A6%E6%AF%94%E4%BA%9A%E5%8F%98%E5%A4%A9-%E5%9C%A3%E7%8E%9B%E5%B0%94%E5%A1%94%E6%B0%94%E5%80%99%E8%B0%88%E5%88%A4%E6%A8%A1%E5%BC%8F%E4%BD%95%E5%8E%BB%E4%BD%95%E4%BB%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782302271000.webp","sourceId":"rfi"},{"id":1782297030000,"createdDate":"2026-06-24 10:30","name":"法国国际广播电台","title":"视频 全球40位市长签署协议 反对人工智能数据中心扩散","content":"来自世界各地的四十位市长于6月23日伦敦举行气候周期间签署了一项协议，旨在规划城市中数据中心的建设和运营方式，请看视频报道。","newsLink":"https://www.rfi.fr/cn/%E7%94%9F%E6%80%81/20260624-%E8%A7%86%E9%A2%91-%E5%85%A8%E7%90%8340%E4%BD%8D%E5%B8%82%E9%95%BF%E7%AD%BE%E7%BD%B2%E5%8D%8F%E8%AE%AE-%E5%8F%8D%E5%AF%B9%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E6%95%B0%E6%8D%AE%E4%B8%AD%E5%BF%83%E6%89%A9%E6%95%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782297030000.webp","sourceId":"rfi"},{"id":1782295765000,"createdDate":"2026-06-24 10:09","name":"法国国际广播电台","title":"夏季达沃斯上李强向美欧发起攻势：否定“第二次中国冲击” 反推“第二次机遇”","content":"今天6月24日，法国58个省发布红色预警，4400万法国人受到影响。昨天23日朗德省皮索斯地区的气温一度升至44.3度，录得法国六月史上截至目前最热的一天，法国各大日报无不聚焦于此。据《解放报》表示，右翼和极右翼势力现将民众所遭受的高温困境归咎于绿党，绿党则反在各市镇政府中展示自己的政策提案和执政成绩。同在今天《回声报》大连特派记者发来报道称，中国国务院总理李强周三在大连举行的夏季达沃斯论坛开幕式上发表了针对美国和欧洲的强硬讲话。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260624-%E5%A4%8F%E5%AD%A3%E8%BE%BE%E6%B2%83%E6%96%AF%E4%B8%8A%E6%9D%8E%E5%BC%BA%E5%90%91%E7%BE%8E%E6%AC%A7%E5%8F%91%E8%B5%B7%E6%94%BB%E5%8A%BF-%E5%90%A6%E5%AE%9A-%E7%AC%AC%E4%BA%8C%E6%AC%A1%E4%B8%AD%E5%9B%BD%E5%86%B2%E5%87%BB-%E5%8F%8D%E6%8F%90-%E7%AC%AC%E4%BA%8C%E6%AC%A1%E6%9C%BA%E9%81%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782295765000.webp","sourceId":"rfi"},{"id":1782295563000,"createdDate":"2026-06-24 10:06","name":"法国国际广播电台","title":"海峡论坛中共重提采购台湾农产品 但农业部认为中国市场易对农民形成「养套杀」一颗凤梨释迦如何引爆抗中保台争议？","content":"一颗比手掌大的凤梨释迦成了在台湾与中国当前的内外政经结构下引爆抗中保台争议的一个手榴弹。民进党认为，中国在政治前提下买台湾农产品就是统战行为。但国民党则反驳，这是要断农民生路。而各县市长候选人对此议题也持不同看法，台湾年底地方选举选战是否已开打？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260624-%E6%B5%B7%E5%B3%A1%E8%AE%BA%E5%9D%9B%E4%B8%AD%E5%85%B1%E9%87%8D%E6%8F%90%E9%87%87%E8%B4%AD%E5%8F%B0%E6%B9%BE%E5%86%9C%E4%BA%A7%E5%93%81-%E4%BD%86%E5%86%9C%E4%B8%9A%E9%83%A8%E8%AE%A4%E4%B8%BA%E4%B8%AD%E5%9B%BD%E5%B8%82%E5%9C%BA%E6%98%93%E5%AF%B9%E5%86%9C%E6%B0%91%E5%BD%A2%E6%88%90-%E5%85%BB%E5%A5%97%E6%9D%80-%E4%B8%80%E9%A2%97%E5%87%A4%E6%A2%A8%E9%87%8A%E8%BF%A6%E5%A6%82%E4%BD%95%E5%BC%95%E7%88%86%E6%8A%97%E4%B8%AD%E4%BF%9D%E5%8F%B0%E4%BA%89%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782295563000.webp","sourceId":"rfi"}]