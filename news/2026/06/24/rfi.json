[{"id":1782291437000,"createdDate":"2026-06-24 08:57","name":"法国国际广播电台","title":"德尚因母亲去世缺席世界杯小组赛末轮 法国队由助教斯特凡临时执教","content":"2026年世界杯小组赛继续进行，多支球队在关键战中分出胜负，部分球队已经提前晋级，部分球队则将在最后一轮决定命运。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260624-%E5%BE%B7%E5%B0%9A%E5%9B%A0%E6%AF%8D%E4%BA%B2%E5%8E%BB%E4%B8%96%E7%BC%BA%E5%B8%AD%E4%B8%96%E7%95%8C%E6%9D%AF%E5%B0%8F%E7%BB%84%E8%B5%9B%E6%9C%AB%E8%BD%AE-%E6%B3%95%E5%9B%BD%E9%98%9F%E7%94%B1%E5%8A%A9%E6%95%99%E6%96%AF%E7%89%B9%E5%87%A1%E4%B8%B4%E6%97%B6%E6%89%A7%E6%95%99","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782291437000.webp","sourceId":"rfi"},{"id":1782291026000,"createdDate":"2026-06-24 08:50","name":"法国国际广播电台","title":"中国拘捕两名日本在华员工 传涉嫌出口稀土制品","content":"在中国东北部的大连，两名日资企业的日本籍员工上个月相继被中国当局拘留。消息称，两人涉嫌试图将含有中国实施对日出口管制的稀土加工产品出口至中国境外，因此遭拘留。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260624-%E4%B8%AD%E5%9B%BD%E6%8B%98%E6%8D%95%E4%B8%A4%E5%90%8D%E6%97%A5%E6%9C%AC%E5%9C%A8%E5%8D%8E%E5%91%98%E5%B7%A5-%E4%BC%A0%E6%B6%89%E5%AB%8C%E5%87%BA%E5%8F%A3%E7%A8%80%E5%9C%9F%E5%88%B6%E5%93%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782291026000.webp","sourceId":"rfi"},{"id":1782290799000,"createdDate":"2026-06-24 08:46","name":"法国国际广播电台","title":"阿里巴巴起诉五角大楼 要求撤销其涉军工企业认定","content":"中国电商巨头阿里巴巴已向美国法院提起诉讼，挑战美国国防部将其列入黑名单的决定。该公司周三(6月24日)表示，对被认定为“中国军工企业”提出异议。要求美国国防部撤销其与中国军方存在关联的“中国军工企业”的认定。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260624-%E9%98%BF%E9%87%8C%E5%B7%B4%E5%B7%B4%E8%B5%B7%E8%AF%89%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC-%E8%A6%81%E6%B1%82%E6%92%A4%E9%94%80%E6%B6%89%E5%86%9B%E5%B7%A5%E4%BC%81%E4%B8%9A%E8%AE%A4%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782290799000.webp","sourceId":"rfi"},{"id":1782289783000,"createdDate":"2026-06-24 08:29","name":"法国国际广播电台","title":"世界杯小组赛进入收官阶段 C罗创纪录哥伦比亚提前出线","content":"2026年世界杯小组赛进入收官阶段。巴黎时间6月24日，A组、B组和C组将展开最后一轮较量，多个晋级席位和小组排名悬念有望在这一比赛日揭晓。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260624-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%B0%8F%E7%BB%84%E8%B5%9B%E8%BF%9B%E5%85%A5%E6%94%B6%E5%AE%98%E9%98%B6%E6%AE%B5-c%E7%BD%97%E5%88%9B%E7%BA%AA%E5%BD%95%E5%93%A5%E4%BC%A6%E6%AF%94%E4%BA%9A%E6%8F%90%E5%89%8D%E5%87%BA%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782289783000.webp","sourceId":"rfi"},{"id":1782285298000,"createdDate":"2026-06-24 07:14","name":"法国国际广播电台","title":"黎智英入狱丶公司受禁 无阻办《苹果》展 数百港人飞台观展 重温香港自由年代","content":"今天是《苹果日报》受压结业五周年的日子，但不少香港人显然并未忘记这份曾经敢言的畅销报章，特意前往台北观赏该报走过的26年足迹，一方面缅怀曾是媒体百花齐放的香港，另一方面亦藉重温来让受压的情怀得以抒泄，不少人更是当场抽泣。当年雨伞运动发起人「占中三子」之一的朱耀明牧师表示，展览的报刊头版有如让他重温香港发展史，而他最难忘记的，是警方大举搜查该报大楼的一幕，形容是港府「消灭新闻言论自由的粗暴行动」。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260624-%E9%BB%8E%E6%99%BA%E8%8B%B1%E5%85%A5%E7%8B%B1%E4%B8%B6%E5%85%AC%E5%8F%B8%E5%8F%97%E7%A6%81-%E6%97%A0%E9%98%BB%E5%8A%9E-%E8%8B%B9%E6%9E%9C-%E5%B1%95-%E6%95%B0%E7%99%BE%E6%B8%AF%E4%BA%BA%E9%A3%9E%E5%8F%B0%E8%A7%82%E5%B1%95-%E9%87%8D%E6%B8%A9%E9%A6%99%E6%B8%AF%E8%87%AA%E7%94%B1%E5%B9%B4%E4%BB%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/24/1782285298000.webp","sourceId":"rfi"}]