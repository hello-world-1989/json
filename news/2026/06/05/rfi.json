[{"id":1780650580000,"createdDate":"2026-06-05 09:09","name":"法国国际广播电台","title":"美国对古巴总统及卡斯特罗家族实施制裁 特朗普拟在伊朗之后解决古巴","content":"美国政府周四加大了对古巴的施压力度，对总统米格尔·迪亚斯-卡内尔和古巴前领导人卡斯特罗家族成员等多名政要实施经济制裁。特朗普表示处理完当前事务，就会着手解决古巴问题。他说“我喜欢一次只做一件事”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260605-%E7%BE%8E%E5%9B%BD%E5%AF%B9%E5%8F%A4%E5%B7%B4%E6%80%BB%E7%BB%9F%E5%8F%8A%E5%8D%A1%E6%96%AF%E7%89%B9%E7%BD%97%E5%AE%B6%E6%97%8F%E5%AE%9E%E6%96%BD%E5%88%B6%E8%A3%81-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8B%9F%E5%9C%A8%E4%BC%8A%E6%9C%97%E4%B9%8B%E5%90%8E%E8%A7%A3%E5%86%B3%E5%8F%A4%E5%B7%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780650580000.webp","sourceId":"rfi"},{"id":1780647942000,"createdDate":"2026-06-05 08:25","name":"法国国际广播电台","title":"台湾称中国海警船蛮横闯入东沙限制海域 双方对峙激烈言辞交锋","content":"台湾海巡署周五（6月5日）表示，一艘中国海警船当天强行闯入东沙岛周边限制海域，与台方海巡舰对峙并发生“激烈言辞交锋”，这是两周以来第二次发生类似事件。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260605-%E5%8F%B0%E6%B9%BE%E7%A7%B0%E4%B8%AD%E5%9B%BD%E6%B5%B7%E8%AD%A6%E8%88%B9%E8%9B%AE%E6%A8%AA%E9%97%AF%E5%85%A5%E4%B8%9C%E6%B2%99%E9%99%90%E5%88%B6%E6%B5%B7%E5%9F%9F-%E5%8F%8C%E6%96%B9%E5%AF%B9%E5%B3%99%E6%BF%80%E7%83%88%E8%A8%80%E8%BE%9E%E4%BA%A4%E9%94%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780647942000.webp","sourceId":"rfi"},{"id":1780647359000,"createdDate":"2026-06-05 08:15","name":"法国国际广播电台","title":"高市早苗首相将于7月访问印度与莫迪首相举行会谈","content":"据悉，日本首相高市早苗正在协调于7月上旬访问印度，并与印度总理莫迪举行会谈。美国国务卿鲁比奥于3日在众议院外交委员会表示，正协调在今年内召开由日本、美国、澳大利亚和印度组成的四国合作机制“QUAD（四方安全对话）”首脑会议，高市首相与莫迪总理届时也可能就日美澳印四国首脑会议进行磋商。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260605-%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E9%A6%96%E7%9B%B8%E5%B0%86%E4%BA%8E7%E6%9C%88%E8%AE%BF%E9%97%AE%E5%8D%B0%E5%BA%A6%E4%B8%8E%E8%8E%AB%E8%BF%AA%E9%A6%96%E7%9B%B8%E4%B8%BE%E8%A1%8C%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780647359000.webp","sourceId":"rfi"},{"id":1780647265000,"createdDate":"2026-06-05 08:14","name":"法国国际广播电台","title":"离散港人接力悼六四　《自由花》海外再响起","content":"香港六四烛光晚会随着《港区国安法》来临而消失，但流散海外的港人则继续接力传承悼念。在六四事件37周年当日，由英国丶台湾丶加拿大丶澳洲等地港人举办的悼念活动遍地开花，不但延续讲述六四真相和见证历史的使命，更重现昔日香港六四晚会的元素，包括高唱《自由花》丶手持烛光悼念，以及声援因悼念六四而被关押的前支联会正副主席李卓人丶邹幸彤和何俊仁，让已在香港熄灭的烛光，继续在世界各地燃亮。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260605-%E7%A6%BB%E6%95%A3%E6%B8%AF%E4%BA%BA%E6%8E%A5%E5%8A%9B%E6%82%BC%E5%85%AD%E5%9B%9B-%E8%87%AA%E7%94%B1%E8%8A%B1-%E6%B5%B7%E5%A4%96%E5%86%8D%E5%93%8D%E8%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780647265000.webp","sourceId":"rfi"},{"id":1780625569000,"createdDate":"2026-06-05 02:12","name":"法国国际广播电台","title":"中国梦想利用人工智能识别未来可能的政治对手","content":"中国信息技术公司GeedgeNetwork被指控已将中国的数字审查系统出售给其他国家，该企业还在研究如何利用人工智能来识别未来可能成为政治对手的人。这岂不也是所有专制政权所梦想的，也是那些人权捍卫者的噩梦？","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260605-%E4%B8%AD%E5%9B%BD%E6%A2%A6%E6%83%B3%E5%88%A9%E7%94%A8%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E8%AF%86%E5%88%AB%E6%9C%AA%E6%9D%A5%E5%8F%AF%E8%83%BD%E7%9A%84%E6%94%BF%E6%B2%BB%E5%AF%B9%E6%89%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780625569000.webp","sourceId":"rfi"}]