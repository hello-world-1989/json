[{"id":1780650580000,"createdDate":"2026-06-05 09:09","name":"法国国际广播电台","title":"美国对古巴总统及卡斯特罗家族实施制裁 特朗普拟在伊朗之后解决古巴","content":"美国政府周四加大了对古巴的施压力度，对总统米格尔·迪亚斯-卡内尔和古巴前领导人卡斯特罗家族成员等多名政要实施经济制裁。特朗普表示处理完当前事务，就会着手解决古巴问题。他说“我喜欢一次只做一件事”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260605-%E7%BE%8E%E5%9B%BD%E5%AF%B9%E5%8F%A4%E5%B7%B4%E6%80%BB%E7%BB%9F%E5%8F%8A%E5%8D%A1%E6%96%AF%E7%89%B9%E7%BD%97%E5%AE%B6%E6%97%8F%E5%AE%9E%E6%96%BD%E5%88%B6%E8%A3%81-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8B%9F%E5%9C%A8%E4%BC%8A%E6%9C%97%E4%B9%8B%E5%90%8E%E8%A7%A3%E5%86%B3%E5%8F%A4%E5%B7%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780650580000.webp","sourceId":"rfi"},{"id":1780647942000,"createdDate":"2026-06-05 08:25","name":"法国国际广播电台","title":"台湾称中国海警船蛮横闯入东沙限制海域 双方对峙激烈言辞交锋","content":"台湾海巡署周五（6月5日）表示，一艘中国海警船当天强行闯入东沙岛周边限制海域，与台方海巡舰对峙并发生“激烈言辞交锋”，这是两周以来第二次发生类似事件。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260605-%E5%8F%B0%E6%B9%BE%E7%A7%B0%E4%B8%AD%E5%9B%BD%E6%B5%B7%E8%AD%A6%E8%88%B9%E8%9B%AE%E6%A8%AA%E9%97%AF%E5%85%A5%E4%B8%9C%E6%B2%99%E9%99%90%E5%88%B6%E6%B5%B7%E5%9F%9F-%E5%8F%8C%E6%96%B9%E5%AF%B9%E5%B3%99%E6%BF%80%E7%83%88%E8%A8%80%E8%BE%9E%E4%BA%A4%E9%94%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780647942000.webp","sourceId":"rfi"},{"id":1780647359000,"createdDate":"2026-06-05 08:15","name":"法国国际广播电台","title":"高市早苗首相将于7月访问印度与莫迪首相举行会谈","content":"据悉，日本首相高市早苗正在协调于7月上旬访问印度，并与印度总理莫迪举行会谈。美国国务卿鲁比奥于3日在众议院外交委员会表示，正协调在今年内召开由日本、美国、澳大利亚和印度组成的四国合作机制“QUAD（四方安全对话）”首脑会议，高市首相与莫迪总理届时也可能就日美澳印四国首脑会议进行磋商。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260605-%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E9%A6%96%E7%9B%B8%E5%B0%86%E4%BA%8E7%E6%9C%88%E8%AE%BF%E9%97%AE%E5%8D%B0%E5%BA%A6%E4%B8%8E%E8%8E%AB%E8%BF%AA%E9%A6%96%E7%9B%B8%E4%B8%BE%E8%A1%8C%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780647359000.webp","sourceId":"rfi"},{"id":1780647265000,"createdDate":"2026-06-05 08:14","name":"法国国际广播电台","title":"离散港人接力悼六四　《自由花》海外再响起","content":"香港六四烛光晚会随着《港区国安法》来临而消失，但流散海外的港人则继续接力传承悼念。在六四事件37周年当日，由英国丶台湾丶加拿大丶澳洲等地港人举办的悼念活动遍地开花，不但延续讲述六四真相和见证历史的使命，更重现昔日香港六四晚会的元素，包括高唱《自由花》丶手持烛光悼念，以及声援因悼念六四而被关押的前支联会正副主席李卓人丶邹幸彤和何俊仁，让已在香港熄灭的烛光，继续在世界各地燃亮。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260605-%E7%A6%BB%E6%95%A3%E6%B8%AF%E4%BA%BA%E6%8E%A5%E5%8A%9B%E6%82%BC%E5%85%AD%E5%9B%9B-%E8%87%AA%E7%94%B1%E8%8A%B1-%E6%B5%B7%E5%A4%96%E5%86%8D%E5%93%8D%E8%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780647265000.webp","sourceId":"rfi"},{"id":1780625569000,"createdDate":"2026-06-05 02:12","name":"法国国际广播电台","title":"中国梦想利用人工智能识别未来可能的政治对手","content":"中国信息技术公司GeedgeNetwork被指控已将中国的数字审查系统出售给其他国家，该企业还在研究如何利用人工智能来识别未来可能成为政治对手的人。这岂不也是所有专制政权所梦想的，也是那些人权捍卫者的噩梦？","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260605-%E4%B8%AD%E5%9B%BD%E6%A2%A6%E6%83%B3%E5%88%A9%E7%94%A8%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E8%AF%86%E5%88%AB%E6%9C%AA%E6%9D%A5%E5%8F%AF%E8%83%BD%E7%9A%84%E6%94%BF%E6%B2%BB%E5%AF%B9%E6%89%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780625569000.webp","sourceId":"rfi"},{"id":1780678335000,"createdDate":"2026-06-05 16:52","name":"法国国际广播电台","title":"德国总理表示：在欧洲、中国与俄罗斯之间，塞尔维亚“必须明确决定它未来走向”","content":"德国总理默茨周五在欧盟与巴尔干候选国峰会上表示，塞尔维亚“必须明确决定它未来走向”。默茨在黑山举行的峰会上说：“不能在俄罗斯、中国和欧洲之间摇摆不定。”他补充道：“如果塞尔维亚的答案是走向‘欧洲’，那么欧洲的答案也将是走向‘塞尔维亚’。”","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260605-%E5%BE%B7%E5%9B%BD%E6%80%BB%E7%90%86%E8%A1%A8%E7%A4%BA-%E5%9C%A8%E6%AC%A7%E6%B4%B2%EF%BC%8C%E4%B8%AD%E5%9B%BD%E4%B8%8E%E4%BF%84%E7%BD%97%E6%96%AF%E4%B9%8B%E9%97%B4-%E5%A1%9E%E5%B0%94%E7%BB%B4%E4%BA%9A-%E5%BF%85%E9%A1%BB%E6%98%8E%E7%A1%AE%E5%86%B3%E5%AE%9A%E5%AE%83%E6%9C%AA%E6%9D%A5%E8%B5%B0%E5%90%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780678335000.webp","sourceId":"rfi"},{"id":1780676232000,"createdDate":"2026-06-05 16:17","name":"法国国际广播电台","title":"在人工智能疯狂竞赛中 Anthropic提议共同暂停","content":"美国人工智能（AI）领域的领军企业之一Anthropic周四提出构想，建议建立一套机制，使该技术领域的顶尖公司能够达成共识，在人类社会做出适应调整期间，放缓或暂停人工智能的研发进度。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260605-%E5%9C%A8%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E7%96%AF%E7%8B%82%E7%AB%9E%E8%B5%9B%E4%B8%AD-anthropic%E6%8F%90%E8%AE%AE%E5%85%B1%E5%90%8C%E6%9A%82%E5%81%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780676232000.webp","sourceId":"rfi"},{"id":1780674407000,"createdDate":"2026-06-05 15:46","name":"法国国际广播电台","title":"以色列对黎巴嫩发动新一轮空袭 真主党拒绝新停火协议","content":"华盛顿刚宣布以黎新停火协议后，以色列军队周五上午就宣布仍准备对黎巴嫩南部沿海城市萨拉凡德（Sarafand）的真主党目标发动空袭。而拒绝新停火协议的真主党是德黑兰嵌在黎巴嫩的武装力量，也是影响伊美谈判的重要砝码。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260605-%E4%BB%A5%E8%89%B2%E5%88%97%E5%AF%B9%E9%BB%8E%E5%B7%B4%E5%AB%A9%E5%8F%91%E5%8A%A8%E6%96%B0%E4%B8%80%E8%BD%AE%E7%A9%BA%E8%A2%AD-%E7%9C%9F%E4%B8%BB%E5%85%9A%E6%8B%92%E7%BB%9D%E6%96%B0%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780674407000.webp","sourceId":"rfi"},{"id":1780667856000,"createdDate":"2026-06-05 13:57","name":"法国国际广播电台","title":"习近平时隔七年再访朝鲜 促双边关系“与时俱进”更大发展","content":"中国官媒报道，中国国家主席习近平将于6月8日至9日访问朝鲜，这是习近平在时隔7年后再次访问这一邻国和传统盟友，分析认为，中国将借此次访问重申两国友好关系，并展示北京在解决朝鲜半岛问题上的影响力。此次访问之前，习近平5月已先后在北京接待了美国总统特朗普和俄罗斯总统普京，凸显了中国在外交舞台上重要的地位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260605-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%97%B6%E9%9A%94%E4%B8%83%E5%B9%B4%E5%86%8D%E8%AE%BF%E6%9C%9D%E9%B2%9C-%E4%BF%83%E5%8F%8C%E8%BE%B9%E5%85%B3%E7%B3%BB-%E4%B8%8E%E6%97%B6%E4%BF%B1%E8%BF%9B-%E6%9B%B4%E5%A4%A7%E5%8F%91%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780667856000.webp","sourceId":"rfi"},{"id":1780666936000,"createdDate":"2026-06-05 13:42","name":"法国国际广播电台","title":"习近平即将访朝今年首次出访献给金正恩","content":"习近平将于下周一和周二访问朝鲜。此访将是习近平今年首次出访，正值朝鲜领导人金正恩大力发展核武，频繁发射弹道导弹之际。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260605-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%8D%B3%E5%B0%86%E8%AE%BF%E6%9C%9D-%E5%B0%86%E4%BB%8A%E5%B9%B4%E9%A6%96%E6%AC%A1%E5%87%BA%E8%AE%BF%E7%8C%AE%E7%BB%99%E9%87%91%E6%AD%A3%E6%81%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780666936000.webp","sourceId":"rfi"},{"id":1780665912000,"createdDate":"2026-06-05 13:25","name":"法国国际广播电台","title":"中国人购岛引国安担忧 日本拟调查1.3万无人岛所有权","content":"日本政府将首度全面调查全国超过1万3000座无人离岛的所有权，并考虑将部分无主岛屿收归国有。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260605-%E4%B8%AD%E5%9B%BD%E4%BA%BA%E8%B4%AD%E5%B2%9B%E5%BC%95%E5%9B%BD%E5%AE%89%E6%8B%85%E5%BF%A7-%E6%97%A5%E6%9C%AC%E6%8B%9F%E8%B0%83%E6%9F%A51-3%E4%B8%87%E6%97%A0%E4%BA%BA%E5%B2%9B%E6%89%80%E6%9C%89%E6%9D%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780665912000.webp","sourceId":"rfi"},{"id":1780662828000,"createdDate":"2026-06-05 12:33","name":"法国国际广播电台","title":"西藏自治区政府原主席被判处终身监禁","content":"西藏自治区政府原主席齐扎拉6月5日被重庆市第一中级人民法院一审判处无期徒刑。他被指控“非法收受财物”共计折合人民币1.58亿元。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260605-%E8%A5%BF%E8%97%8F%E8%87%AA%E6%B2%BB%E5%8C%BA%E6%94%BF%E5%BA%9C%E5%8E%9F%E4%B8%BB%E5%B8%AD%E8%A2%AB%E5%88%A4%E5%A4%84%E7%BB%88%E8%BA%AB%E7%9B%91%E7%A6%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780662828000.webp","sourceId":"rfi"},{"id":1780661292000,"createdDate":"2026-06-05 12:08","name":"法国国际广播电台","title":"美国国会报告指中国跨国镇压升级 从天安门到AI监控 北京被控将恐吓与审查输出全球","content":"美国国会及行政当局中国委员会（CECC）在6月4日当日，发布最新研究报告，指控中国共产党近年持续将政治控制、言论审查与恐吓手段输出海外，透过实体威胁、数位监控、法律施压及政治渗透等方式，打压海外异议人士、影响民主国家政策制定，并试图塑造有利于北京的国际舆论环境。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E5%8A%A8%E5%90%91/20260605-%E7%BE%8E%E5%9B%BD%E5%9B%BD%E4%BC%9A%E6%8A%A5%E5%91%8A%E6%8C%87%E4%B8%AD%E5%9B%BD%E8%B7%A8%E5%9B%BD%E9%95%87%E5%8E%8B%E5%8D%87%E7%BA%A7-%E4%BB%8E%E5%A4%A9%E5%AE%89%E9%97%A8%E5%88%B0ai%E7%9B%91%E6%8E%A7-%E5%8C%97%E4%BA%AC%E8%A2%AB%E6%8E%A7%E5%B0%86%E6%81%90%E5%90%93%E4%B8%8E%E5%AE%A1%E6%9F%A5%E8%BE%93%E5%87%BA%E5%85%A8%E7%90%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780661292000.webp","sourceId":"rfi"},{"id":1780660890000,"createdDate":"2026-06-05 12:01","name":"法国国际广播电台","title":"斯大林主义3.0：普京治下俄罗斯的控制与民怨","content":"本期出刊的费加罗报在社论、国际版、争鸣版分别以大篇幅关注了陷入长期战争陷阱的俄罗斯。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260605-%E6%96%AF%E5%A4%A7%E6%9E%97%E4%B8%BB%E4%B9%893-0-%E6%99%AE%E4%BA%AC%E6%B2%BB%E4%B8%8B%E4%BF%84%E7%BD%97%E6%96%AF%E7%9A%84%E6%8E%A7%E5%88%B6%E4%B8%8E%E6%B0%91%E6%80%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780660890000.webp","sourceId":"rfi"},{"id":1780660130000,"createdDate":"2026-06-05 11:48","name":"法国国际广播电台","title":"经济停滞：普京将在圣彼得堡投资论坛发言 泽连斯基提议与普京一对一会面","content":"外界对俄罗斯经济停滞的担忧日益加剧之际，俄罗斯总统普京今天周五将在圣彼得堡举行的、汇聚了俄国内外官员的重要投资论坛上发表讲话。前一天，乌克兰总统泽连斯基向普京发出公开信提议一对一会谈。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260605-%E7%BB%8F%E6%B5%8E%E5%81%9C%E6%BB%9E-%E6%99%AE%E4%BA%AC%E5%B0%86%E5%9C%A8%E5%9C%A3%E5%BD%BC%E5%BE%97%E5%A0%A1%E6%8A%95%E8%B5%84%E8%AE%BA%E5%9D%9B%E5%8F%91%E8%A8%80-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E6%8F%90%E8%AE%AE%E4%B8%8E%E6%99%AE%E4%BA%AC%E4%B8%80%E5%AF%B9%E4%B8%80%E4%BC%9A%E9%9D%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780660130000.webp","sourceId":"rfi"},{"id":1780658200000,"createdDate":"2026-06-05 11:16","name":"法国国际广播电台","title":"经合组织：中东战争让全球经济面临衰退威胁","content":"经合组织（OCDE）近日发布最新经济预测已下调今年全球经济增长预测，并指出全球经济放缓实际上已经开始，如果中东冲突持续，许多国家可能出现经济衰退。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260605-%E7%BB%8F%E5%90%88%E7%BB%84%E7%BB%87-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E8%AE%A9%E5%85%A8%E7%90%83%E7%BB%8F%E6%B5%8E%E9%9D%A2%E4%B8%B4%E8%A1%B0%E9%80%80%E5%A8%81%E8%83%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/05/1780658200000.webp","sourceId":"rfi"}]