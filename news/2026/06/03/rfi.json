[{"id":1780480140000,"createdDate":"2026-06-03 09:49","name":"法国国际广播电台","title":"回声报：“如果油价没有涨到120美元，那是因为中国现在买得少了”","content":"大家好，今天是6月3日星期三，法国全国性日报头版焦点不一：“特朗普深陷伊朗的泥潭”重登《费加罗报》首页；“厄尔尼诺”极端气候现象成为《解放报》封面探讨主题。与此同时《回声报》关注中国成功地在不动用战略石油储备的前提下减少了石油进口。这一独一无二的战略不仅帮助中国稳定了国内经济，还平抑了全球油价。具体是如何做到的呢？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260603-%E5%9B%9E%E5%A3%B0%E6%8A%A5-%E5%A6%82%E6%9E%9C%E6%B2%B9%E4%BB%B7%E6%B2%A1%E6%9C%89%E6%B6%A8%E5%88%B0120%E7%BE%8E%E5%85%83%EF%BC%8C%E9%82%A3%E6%98%AF%E5%9B%A0%E4%B8%BA%E4%B8%AD%E5%9B%BD%E7%8E%B0%E5%9C%A8%E4%B9%B0%E5%BE%97%E5%B0%91%E4%BA%86","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780480140000.webp","sourceId":"rfi"},{"id":1780478572000,"createdDate":"2026-06-03 09:22","name":"法国国际广播电台","title":"伊朗袭击科威特机场致1死多伤 巴林遭导弹和无人机攻击 美军打击格什姆岛目标","content":"6月3日，科威特宣布暂停商业航班运营。此前伊朗发动的袭击对科威特国际机场造成严重破坏，并导致至少1人死亡、多人受伤。除科威特外，巴林也遭到袭击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260603-%E4%BC%8A%E6%9C%97%E8%A2%AD%E5%87%BB%E7%A7%91%E5%A8%81%E7%89%B9%E6%9C%BA%E5%9C%BA%E8%87%B41%E6%AD%BB%E5%A4%9A%E4%BC%A4-%E5%B7%B4%E6%9E%97%E9%81%AD%E5%AF%BC%E5%BC%B9%E5%92%8C%E6%97%A0%E4%BA%BA%E6%9C%BA%E6%94%BB%E5%87%BB-%E7%BE%8E%E5%86%9B%E6%89%93%E5%87%BB%E6%A0%BC%E4%BB%80%E5%A7%86%E5%B2%9B%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780478572000.webp","sourceId":"rfi"},{"id":1780477695000,"createdDate":"2026-06-03 09:08","name":"法国国际广播电台","title":"当欧美政府大力推动晶片回流政策 黄仁勋却称台湾是未来AI革命的核心基地 为何台湾仍是AI世界主场？","content":"台湾不只是晶片代工基地，更是全球AI硬体供应链密度最高、摩擦成本最低的地方。全球市值最高公司辉达，不仅在台北建立新总部，更用一笔惊人的投资1500亿美元，把AI晶片真正核心基地指向台湾。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260603-%E5%BD%93%E6%AC%A7%E7%BE%8E%E6%94%BF%E5%BA%9C%E5%A4%A7%E5%8A%9B%E6%8E%A8%E5%8A%A8%E6%99%B6%E7%89%87%E5%9B%9E%E6%B5%81%E6%94%BF%E7%AD%96-%E9%BB%84%E4%BB%81%E5%8B%8B%E5%8D%B4%E7%A7%B0%E5%8F%B0%E6%B9%BE%E6%98%AF%E6%9C%AA%E6%9D%A5ai%E9%9D%A9%E5%91%BD%E7%9A%84%E6%A0%B8%E5%BF%83%E5%9F%BA%E5%9C%B0-%E4%B8%BA%E4%BD%95%E5%8F%B0%E6%B9%BE%E4%BB%8D%E6%98%AFai%E4%B8%96%E7%95%8C%E4%B8%BB%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780477695000.webp","sourceId":"rfi"},{"id":1780476636000,"createdDate":"2026-06-03 08:50","name":"法国国际广播电台","title":"卢比奥称美对台军售案审核中 民进党盼立法院支持1.25兆国防预算被删部分","content":"美国国务卿卢比奥在2日表示，美国对台140亿美元的军售案，目前仍在审核中。台湾国内两党回应大不相同，国民党认为在特朗普签署前都无法确定。民进党则认为美国重申对台立场不变，台湾应尽速支持1.25兆国防预算被删部分以回应。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260603-%E5%8D%A2%E6%AF%94%E5%A5%A5%E7%A7%B0%E7%BE%8E%E5%AF%B9%E5%8F%B0%E5%86%9B%E5%94%AE%E6%A1%88%E5%AE%A1%E6%A0%B8%E4%B8%AD-%E6%B0%91%E8%BF%9B%E5%85%9A%E7%9B%BC%E7%AB%8B%E6%B3%95%E9%99%A2%E6%94%AF%E6%8C%811-25%E5%85%86%E5%9B%BD%E9%98%B2%E9%A2%84%E7%AE%97%E8%A2%AB%E5%88%A0%E9%83%A8%E5%88%86","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780476636000.webp","sourceId":"rfi"},{"id":1780476546000,"createdDate":"2026-06-03 08:49","name":"法国国际广播电台","title":"美国商务部考虑以强迫劳动为由  向60个经济体加征至少10%关税","content":"美国政府正在考虑对来自60个经济体的进口商品加征10%或12.5%的额外关税。华盛顿指责这些经济体未能有效打击使用强迫劳动生产的商品贸易，并且限制了美国的商业活动。针对强迫劳动的调查只是特朗普政府重启关税政策的一部分。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260603-%E7%BE%8E%E5%9B%BD%E5%95%86%E5%8A%A1%E9%83%A8%E8%80%83%E8%99%91%E4%BB%A5%E5%BC%BA%E8%BF%AB%E5%8A%B3%E5%8A%A8%E4%B8%BA%E7%94%B1-%E5%90%9160%E4%B8%AA%E7%BB%8F%E6%B5%8E%E4%BD%93%E5%8A%A0%E5%BE%81%E8%87%B3%E5%B0%9110-%E5%85%B3%E7%A8%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780476546000.webp","sourceId":"rfi"},{"id":1780472171000,"createdDate":"2026-06-03 07:36","name":"法国国际广播电台","title":"“台湾需要更多的电力！”：能源将是英伟达1500亿美元投资面临的主要障碍","content":"据《费加罗报》科技版周二（6月2日）报道称，在黄仁勋计划每年增加1500亿美元投资的背景下，台湾是否有能力满足AI基础设施建设带来的飞速增长的需求，引发了各界的诸多质疑。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260603-%E5%8F%B0%E6%B9%BE%E9%9C%80%E8%A6%81%E6%9B%B4%E5%A4%9A%E7%9A%84%E7%94%B5%E5%8A%9B-%E8%83%BD%E6%BA%90%E6%98%AF%E8%8B%B1%E4%BC%9F%E8%BE%BE%E5%BA%9E%E5%A4%A7%E9%9C%80%E6%B1%82%E9%9D%A2%E4%B8%B4%E7%9A%84%E4%B8%BB%E8%A6%81%E9%9A%9C%E7%A2%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780472171000.webp","sourceId":"rfi"},{"id":1780469251000,"createdDate":"2026-06-03 06:47","name":"法国国际广播电台","title":"30多个国家领导人与政府高官聚集东京研讨海洋问题","content":"“世界岛国海洋会议”（讨论海洋资源保护和气候变化对策）于2026年6月3日至4日在东京举行，来自岛国的国家领导人、政府高级官员以及海洋领域专家齐聚一堂，旨在推动基于科学依据、兼具气候变化韧性和可持续性的“海洋规划”的制定与管理实践，并将其推广至全球范围。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260603-%E5%8F%9730%E5%A4%9A%E4%B8%AA%E5%9B%BD%E5%AE%B6%E9%A2%86%E5%AF%BC%E4%BA%BA%E4%B8%8E%E6%94%BF%E5%BA%9C%E9%AB%98%E5%AE%98%E8%81%9A%E9%9B%86%E4%B8%9C%E4%BA%AC%E7%A0%94%E8%AE%A8%E6%B5%B7%E6%B4%8B%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780469251000.webp","sourceId":"rfi"},{"id":1780464844000,"createdDate":"2026-06-03 05:34","name":"法国国际广播电台","title":"中国升级打压 首禁「天安门母亲」六四赴公墓祭奠至亲 王丹斥是践踏做人底线","content":"明天是六四事件37周年纪念日，中国政府正进一步封禁与六四相关的纪念活动，更首度不允许「天安门母亲」群体成员明(4日)天到遇难至亲下葬的万安公墓祭祀，更派人看管在北京的成员，警告她们不得对外联络。当年的学生领袖王丹表示，不允许祭祀不仅是对「天安门母亲」的残酷对待，剥夺难属悼念至亲的权利，更是践踏做人底线的行为。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260603-%E4%B8%AD%E5%9B%BD%E5%8D%87%E7%BA%A7%E6%89%93%E5%8E%8B-%E9%A6%96%E7%A6%81-%E5%A4%A9%E5%AE%89%E9%97%A8%E6%AF%8D%E4%BA%B2-%E5%85%AD%E5%9B%9B%E8%B5%B4%E5%85%AC%E5%A2%93%E7%A5%AD%E5%A5%A0%E8%87%B3%E4%BA%B2-%E7%8E%8B%E4%B8%B9%E6%96%A5%E6%98%AF%E8%B7%B5%E8%B8%8F%E5%81%9A%E4%BA%BA%E5%BA%95%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780464844000.webp","sourceId":"rfi"},{"id":1780508117000,"createdDate":"2026-06-03 17:35","name":"法国国际广播电台","title":"郑丽文访美：“美中和解合作”是她到美国要带来的最重要讯息","content":"台湾国民党主席郑丽文访美在旧金山发表演说指出，台海和平不能只看两岸，这样的和平无法永续和稳固，必须把美国纳入战略地图，她希望看到的是，美中和解、美中合作，「这是我到美国要带来的最重要的讯息」。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260603-%E9%83%91%E4%B8%BD%E6%96%87%E8%AE%BF%E7%BE%8E-%E7%BE%8E%E4%B8%AD%E5%92%8C%E8%A7%A3%E5%90%88%E4%BD%9C-%E6%98%AF%E5%A5%B9%E5%88%B0%E7%BE%8E%E5%9B%BD%E8%A6%81%E5%B8%A6%E6%9D%A5%E7%9A%84%E6%9C%80%E9%87%8D%E8%A6%81%E8%AE%AF%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780508117000.webp","sourceId":"rfi"},{"id":1780507216000,"createdDate":"2026-06-03 17:20","name":"法国国际广播电台","title":"吕特警告俄罗斯年轻人：若在乌克兰参战将面临死亡","content":"北约秘书长马克·吕特周三警告俄罗斯年轻人，如果他们参军参与莫斯科在乌克兰发动的战争，很可能面临死亡。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260603-%E5%90%95%E7%89%B9%E8%AD%A6%E5%91%8A%E4%BF%84%E7%BD%97%E6%96%AF%E5%B9%B4%E8%BD%BB%E4%BA%BA-%E8%8B%A5%E5%9C%A8%E4%B9%8C%E5%85%8B%E5%85%B0%E5%8F%82%E6%88%98%E5%B0%86%E9%9D%A2%E4%B8%B4%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780507216000.webp","sourceId":"rfi"},{"id":1780505431000,"createdDate":"2026-06-03 16:50","name":"法国国际广播电台","title":"北约秘书长访基辅称“俄罗斯越来越绝望”","content":"北约秘书长马克·吕特周三在访问基辅时表示，面对乌克兰，俄罗斯正变得“越来越绝望”，而乌克兰在俄罗斯入侵开始四年多后“依然坚守阵地”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260603-%E5%8C%97%E7%BA%A6%E7%A7%98%E4%B9%A6%E9%95%BF%E8%AE%BF%E5%9F%BA%E8%BE%85%E7%A7%B0-%E4%BF%84%E7%BD%97%E6%96%AF%E8%B6%8A%E6%9D%A5%E8%B6%8A%E7%BB%9D%E6%9C%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780505431000.webp","sourceId":"rfi"},{"id":1780500650000,"createdDate":"2026-06-03 15:30","name":"法国国际广播电台","title":"六四天安门事件：民主运动与历史伤痕","content":"1989年春天，数以万计的学生和市民聚集在北京天安门广场，要求反贪腐、政治改革及更大的言论自由。数周后，中国政府出动军队和装甲部队进入北京市中心，以武力清场。确切死亡人数至今仍无法确认。三十多年过去，六四天安门事件仍是中国当代历史中最敏感的议题之一。","newsLink":"https://www.rfi.fr/cn/%E8%A7%86%E9%A2%91/20260603-%E5%85%AD%E5%9B%9B%E5%A4%A9%E5%AE%89%E9%97%A8%E4%BA%8B%E4%BB%B6-%E6%B0%91%E4%B8%BB%E8%BF%90%E5%8A%A8%E4%B8%8E%E5%8E%86%E5%8F%B2%E4%BC%A4%E7%97%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780500650000.webp","sourceId":"rfi"},{"id":1780500472000,"createdDate":"2026-06-03 15:27","name":"法国国际广播电台","title":"所罗门群岛新政府谋求改善与澳洲关系并重审与中国的安全协议","content":"所罗门群岛不久前才上任的新总理马修-威尔6月3日前往澳大利亚访问，希望能密切与澳大利亚的合作。鉴于所罗门群岛2022年与中国签署的秘密安全协议引发的不安，马修-威尔上任后首次出访就选择澳大利亚因此也格外吸引国际社会关注。访澳期间，马修-威尔宣布，所罗门新政府将重审这项与中国签订的安全协议。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260603-%E6%89%80%E7%BD%97%E9%97%A8%E7%BE%A4%E5%B2%9B%E6%96%B0%E6%94%BF%E5%BA%9C%E8%B0%8B%E6%B1%82%E6%94%B9%E5%96%84%E4%B8%8E%E6%BE%B3%E6%B4%B2%E5%85%B3%E7%B3%BB%E5%B9%B6%E9%87%8D%E5%AE%A1%E4%B8%8E%E4%B8%AD%E5%9B%BD%E7%9A%84%E5%AE%89%E5%85%A8%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780500472000.webp","sourceId":"rfi"},{"id":1780499471000,"createdDate":"2026-06-03 15:11","name":"法国国际广播电台","title":"港媒爆王岐山多名嫡系受查落马 台媒：下一个是王岐山？","content":"中央社6月3日香港电，中国前国家副主席王岐山多名嫡系官员先后落马。台湾新头壳引消息推测习近平为确保二十一大连任，下一个目标可能是王岐山。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260603-%E6%B8%AF%E5%AA%92%E7%88%86%E7%8E%8B%E5%B2%90%E5%B1%B1%E5%A4%9A%E5%90%8D%E5%AB%A1%E7%B3%BB%E5%8F%97%E6%9F%A5%E8%90%BD%E9%A9%AC-%E5%8F%B0%E5%AA%92-%E4%B8%8B%E4%B8%80%E4%B8%AA%E6%98%AF%E7%8E%8B%E5%B2%90%E5%B1%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780499471000.webp","sourceId":"rfi"},{"id":1780499111000,"createdDate":"2026-06-03 15:05","name":"法国国际广播电台","title":"鲁比奥：美国对台政策没有变化 140亿美元军售仍在审议中","content":"美国国务卿鲁比奥6月2日在美国参议院外交关系委员会听证会上表示，美国对台湾的政策没有发生变化，华盛顿希望维持当前的现状。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260603-%E9%B2%81%E6%AF%94%E5%A5%A5-%E7%BE%8E%E5%9B%BD%E5%AF%B9%E5%8F%B0%E6%94%BF%E7%AD%96%E6%B2%A1%E6%9C%89%E5%8F%98%E5%8C%96-140%E4%BA%BF%E7%BE%8E%E5%85%83%E5%86%9B%E5%94%AE%E4%BB%8D%E5%9C%A8%E5%AE%A1%E8%AE%AE%E4%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780499111000.webp","sourceId":"rfi"},{"id":1780496809000,"createdDate":"2026-06-03 14:26","name":"法国国际广播电台","title":"中国海员抱怨被困霍尔木兹海峡94天 网民出谋划策“将吴京照片贴脸上”","content":"据李老师不是你老师X账号消息，6月1日，滞留在霍尔木兹海峡的航海公司的海员说，他目前所在的中国船只已经滞留在海峡上第94天了。中国著名电影人吴京再次受到关注。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260603-%E4%B8%AD%E5%9B%BD%E6%B5%B7%E5%91%98%E6%8A%B1%E6%80%A8%E8%A2%AB%E5%9B%B0%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A194%E5%A4%A9-%E7%BD%91%E6%B0%91%E5%87%BA%E8%B0%8B%E5%88%92%E7%AD%96-%E5%B0%86%E5%90%B4%E4%BA%AC%E7%85%A7%E7%89%87%E8%B4%B4%E8%84%B8%E4%B8%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780496809000.webp","sourceId":"rfi"},{"id":1780494055000,"createdDate":"2026-06-03 13:40","name":"法国国际广播电台","title":"联合国秘书长赴圣彼得堡出席“俄罗斯达沃斯”","content":"联合国秘书长安东尼奥·古特雷斯将出席圣彼得堡经济论坛，并计划于周五在环境专题讨论会上发表讲话。他周二刚刚谴责俄罗斯对乌克兰发动的致命空袭。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260603-%E8%81%94%E5%90%88%E5%9B%BD%E7%A7%98%E4%B9%A6%E9%95%BF%E8%B5%B4%E5%9C%A3%E5%BD%BC%E5%BE%97%E5%A0%A1%E5%87%BA%E5%B8%AD-%E4%BF%84%E7%BD%97%E6%96%AF%E8%BE%BE%E6%B2%83%E6%96%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780494055000.webp","sourceId":"rfi"},{"id":1780491846000,"createdDate":"2026-06-03 13:04","name":"法国国际广播电台","title":"乌克兰无人机袭击基础设施 圣彼得堡经济论坛在黑烟背景下拉开帷幕","content":"6月3日早晨，乌克兰无人机袭击了俄罗斯圣彼得堡的能源和军事设施。众多俄罗斯导人跟国际宾客汇聚在那里准备出席当天开幕的圣彼得堡经济论坛。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260603-%E4%B9%8C%E5%85%8B%E5%85%B0%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD-%E5%9C%A3%E5%BD%BC%E5%BE%97%E5%A0%A1%E7%BB%8F%E6%B5%8E%E8%AE%BA%E5%9D%9B%E5%9C%A8%E9%BB%91%E7%83%9F%E8%83%8C%E6%99%AF%E4%B8%8B%E6%8B%89%E5%BC%80%E5%B8%B7%E5%B9%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780491846000.webp","sourceId":"rfi"},{"id":1780487009000,"createdDate":"2026-06-03 11:43","name":"法国国际广播电台","title":"数千项德国专利转为中国企业所有","content":"据德国《时代周报》报道：在过去二十年里，超过一万项德国专利转入中国企业所有。尤其是在机械工程领域，德国专利向海外流失的现象十分明显。与此同时，中国却对本国市场实行严格保护。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260603-%E6%95%B0%E5%8D%83%E9%A1%B9%E5%BE%B7%E5%9B%BD%E4%B8%93%E5%88%A9%E8%BD%AC%E4%B8%BA%E4%B8%AD%E5%9B%BD%E4%BC%81%E4%B8%9A%E6%89%80%E6%9C%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780487009000.webp","sourceId":"rfi"},{"id":1780528396000,"createdDate":"2026-06-03 23:13","name":"法国国际广播电台","title":"卢比奥：任何审查都无法抹杀六四事件","content":"六四事件37周年前夜，美国国务卿卢比奥周三在一份致中国的声明中表示：“任何审查都无法抹去历史”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260603-%E5%8D%A2%E6%AF%94%E5%A5%A5-%E4%BB%BB%E4%BD%95%E5%AE%A1%E6%9F%A5%E9%83%BD%E6%97%A0%E6%B3%95%E6%8A%B9%E6%9D%80%E5%85%AD%E5%9B%9B%E4%BA%8B%E4%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780528396000.webp","sourceId":"rfi"},{"id":1780525730000,"createdDate":"2026-06-03 22:28","name":"法国国际广播电台","title":"人权观察：中国加紧抹去记忆 天安门事件37年后 正义仍未得到伸张","content":"人权观察组织6月1日发表公报指出，中国政府正在加紧努力抹去1989年天安门事件的记忆，同时加强在全国范围内的社会控制。人权观察并提出敬告，明白敦促中国政府应采取六项措施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260603-%E4%BA%BA%E6%9D%83%E8%A7%82%E5%AF%9F-%E4%B8%AD%E5%9B%BD%E5%8A%A0%E7%B4%A7%E6%8A%B9%E5%8E%BB%E8%AE%B0%E5%BF%86-%E5%A4%A9%E5%AE%89%E9%97%A8%E4%BA%8B%E4%BB%B637%E5%B9%B4%E5%90%8E-%E6%AD%A3%E4%B9%89%E4%BB%8D%E6%9C%AA%E5%BE%97%E5%88%B0%E4%BC%B8%E5%BC%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780525730000.webp","sourceId":"rfi"},{"id":1780525230000,"createdDate":"2026-06-03 22:20","name":"法国国际广播电台","title":"王岐山手下打虎将何以近乎覆灭","content":"这是不是有如台媒所言：下一个是王岐山 !有待时日决定，但前中共纪委书记、习近平的“反腐大臣”王岐山，手下亲信，一个接着一个被“以其人之道还治其人之身”的方式拉下马，意味深长。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260603-%E7%8E%8B%E5%B2%90%E5%B1%B1%E6%89%8B%E4%B8%8B%E6%89%93%E8%99%8E%E5%B0%86%E4%BD%95%E4%BB%A5%E8%BF%91%E4%B9%8E%E8%A6%86%E7%81%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780525230000.webp","sourceId":"rfi"},{"id":1780523593000,"createdDate":"2026-06-03 21:53","name":"法国国际广播电台","title":"法国 谁是富人 他们住在哪里","content":"法国究竟有多少富人？他们是谁，住在哪里？到什么程度才会被视为富人？以下是法国“不平等观察协会”眼中的富人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260603-%E6%B3%95%E5%9B%BD-%E8%B0%81%E6%98%AF%E5%AF%8C%E4%BA%BA-%E4%BB%96%E4%BB%AC%E4%BD%8F%E5%9C%A8%E5%93%AA%E9%87%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780523593000.webp","sourceId":"rfi"},{"id":1780522362000,"createdDate":"2026-06-03 21:32","name":"法国国际广播电台","title":"美财长贝森特称美中关系进入稳定期","content":"美国财政部长贝森特（ScottBessent）3日表示，在经历数年紧张与波折后，美国与中国关系已进入一个“稳定”阶段，双方近期透过贸易合作取得具体成果，其中中国同意采购200架波音客机，被视为两国重新推动经贸关系的重要象征，也成为美国总统特朗普（DonaldTrump）政府对中经济政策的重要成果之一。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260603-%E7%BE%8E%E8%B4%A2%E9%95%BF%E8%B4%9D%E6%A3%AE%E7%89%B9%E7%A7%B0%E7%BE%8E%E4%B8%AD%E5%85%B3%E7%B3%BB%E8%BF%9B%E5%85%A5%E7%A8%B3%E5%AE%9A%E6%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780522362000.webp","sourceId":"rfi"},{"id":1780522131000,"createdDate":"2026-06-03 21:28","name":"法国国际广播电台","title":"数千项德国专利转为中国企业所有","content":"据德国《时代周报》报道：在过去二十年里，超过一万项德国专利转入中国企业所有。尤其是在机械工程领域，德国专利向海外流失的现象十分明显。与此同时，中国却对本国市场实行严格保护。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260603-%E6%95%B0%E5%8D%83%E9%A1%B9%E5%BE%B7%E5%9B%BD%E4%B8%93%E5%88%A9%E8%BD%AC%E4%B8%BA%E4%B8%AD%E5%9B%BD%E4%BC%81%E4%B8%9A%E6%89%80%E6%9C%89-1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780522131000.webp","sourceId":"rfi"},{"id":1780522104000,"createdDate":"2026-06-03 21:28","name":"法国国际广播电台","title":"德国竞选安理会席位首次失利 柏林指责俄罗斯阻挠","content":"德国周三(6月3日）在联合国安理会非常任理事国选举中失利，首次未能获得安理会席位。德国外长瓦德富尔将这一结果形容为“一次苦涩的失败”，并指责俄罗斯在选举期间游说各国反对德国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260603-%E5%BE%B7%E5%9B%BD%E7%AB%9E%E9%80%89%E5%AE%89%E7%90%86%E4%BC%9A%E5%B8%AD%E4%BD%8D%E9%A6%96%E6%AC%A1%E5%A4%B1%E5%88%A9-%E6%9F%8F%E6%9E%97%E6%8C%87%E8%B4%A3%E4%BF%84%E7%BD%97%E6%96%AF%E9%98%BB%E6%8C%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780522104000.webp","sourceId":"rfi"},{"id":1780521889000,"createdDate":"2026-06-03 21:24","name":"法国国际广播电台","title":"法国再罚希音2200万欧元 欧洲加大整顿跨境电商力度","content":"因违反消费者权益保护规定，法国监管部门再次对快时尚电商平台希音(Shein）开出巨额罚单。根据法国竞争、消费者事务与反欺诈总局周三(6月3日）公布的决定，这家创立于中国、总部现设于新加坡的电商企业被处以总额2200万欧元罚款。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260603-%E6%B3%95%E5%9B%BD%E5%86%8D%E7%BD%9A%E5%B8%8C%E9%9F%B32200%E4%B8%87%E6%AC%A7%E5%85%83-%E6%AC%A7%E6%B4%B2%E5%8A%A0%E5%A4%A7%E6%95%B4%E9%A1%BF%E8%B7%A8%E5%A2%83%E7%94%B5%E5%95%86%E5%8A%9B%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780521889000.webp","sourceId":"rfi"},{"id":1780521674000,"createdDate":"2026-06-03 21:21","name":"法国国际广播电台","title":"鲁比奥坚称\"美国赢得对伊战争\" 伊朗强调谈判“毫无实质进展”","content":"尽管美国与伊朗近日再次发生军事冲突，美国国务卿鲁比奥周三(6月3日）仍坚称，\"美国已经实现针对伊朗军事行动的既定目标\"。伊朗方面当天则表示，与美国的谈判“没有取得任何实质性进展”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260603-%E9%B2%81%E6%AF%94%E5%A5%A5%E5%9D%9A%E7%A7%B0-%E7%BE%8E%E5%9B%BD%E8%B5%A2%E5%BE%97%E5%AF%B9%E4%BC%8A%E6%88%98%E4%BA%89-%E4%BC%8A%E6%9C%97%E5%BC%BA%E8%B0%83%E8%B0%88%E5%88%A4-%E6%AF%AB%E6%97%A0%E5%AE%9E%E8%B4%A8%E8%BF%9B%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780521674000.webp","sourceId":"rfi"},{"id":1780521508000,"createdDate":"2026-06-03 21:18","name":"法国国际广播电台","title":"韩国地方选举：李在明阵营大获全胜 保守派再遭重挫","content":"韩国周三(6月3日）举行的地方选举初步结果显示，总统李在明领导的共同民主党取得压倒性胜利，而保守派国民力量党则继续受到前总统尹锡悦戒严风波影响，遭遇严重挫败。官方数据显示，本次地方选举投票率达到61%。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260603-%E9%9F%A9%E5%9B%BD%E5%9C%B0%E6%96%B9%E9%80%89%E4%B8%BE-%E6%9D%8E%E5%9C%A8%E6%98%8E%E9%98%B5%E8%90%A5%E5%A4%A7%E8%8E%B7%E5%85%A8%E8%83%9C-%E4%BF%9D%E5%AE%88%E6%B4%BE%E5%86%8D%E9%81%AD%E9%87%8D%E6%8C%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780521508000.webp","sourceId":"rfi"},{"id":1780515959000,"createdDate":"2026-06-03 19:45","name":"法国国际广播电台","title":"法国和英国之间“进一个出一个”的移民交换协议延长到至10月初","content":"法国欧洲事务部长级代表哈达德周三表示，法国和英国已将“进一个出一个”的移民交换协议延长至10月初。这份协议是去年9月生效的。协议允许英国遣返部分被认为无权在他们海岸停留的移民。作为交换，英国接收等量的来自法国的移民，这些移民的庇护申请很可能获得批准，优先考虑最容易受人口走私贩子侵害的国籍以及与英国有联系的国籍。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260603-%E6%B3%95%E5%9B%BD%E5%92%8C%E8%8B%B1%E5%9B%BD%E4%B9%8B%E9%97%B4-%E8%BF%9B%E4%B8%80%E4%B8%AA%E5%87%BA%E4%B8%80%E4%B8%AA-%E7%9A%84%E7%A7%BB%E6%B0%91%E4%BA%A4%E6%8D%A2%E5%8D%8F%E8%AE%AE%E5%BB%B6%E9%95%BF%E5%88%B0%E8%87%B310%E6%9C%88%E5%88%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780515959000.webp","sourceId":"rfi"},{"id":1780515733000,"createdDate":"2026-06-03 19:42","name":"法国国际广播电台","title":"欧盟委员会寻求技术主权","content":"各位好，我是安东尼，欢迎收听法国世界报摘要。欧盟委员会希望赋予欧盟在芯片、云计算和人工智能等领域实现技术主权的能力。这是今天法国世界报的一个重点标题。报纸说，这可能会激怒北京和华盛顿，这两个国家向来以迅速反击著称。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260603-%E6%AC%A7%E7%9B%9F%E5%A7%94%E5%91%98%E4%BC%9A%E5%AF%BB%E6%B1%82%E6%8A%80%E6%9C%AF%E4%B8%BB%E6%9D%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/03/1780515733000.webp","sourceId":"rfi"}]