[{"id":1780732765000,"createdDate":"2026-06-06 07:59","name":"法国国际广播电台","title":"联合国组织建议将日本“飞鸟·藤原宫都”列入世界文化遗产","content":"联合国教科文组织（UNESCO）的咨询机构——国际古迹遗址理事会（ICOMOS）于6月6日建议将“飞鸟·藤原宫都”列入世界文化遗产名录。如果成功列入（世界文化遗产名录），日本国内的世界文化遗产数量将继2024年登录的佐渡岛金山之后，增至22项。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260606-%E8%81%94%E5%90%88%E5%9B%BD%E7%BB%84%E7%BB%87%E5%BB%BA%E8%AE%AE%E5%B0%86%E6%97%A5%E6%9C%AC-%E9%A3%9E%E9%B8%9F%C2%B7%E8%97%A4%E5%8E%9F%E5%AE%AB%E9%83%BD-%E5%88%97%E5%85%A5%E4%B8%96%E7%95%8C%E6%96%87%E5%8C%96%E9%81%97%E4%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780732765000.webp","sourceId":"rfi"},{"id":1780726251000,"createdDate":"2026-06-06 06:10","name":"法国国际广播电台","title":"马斯克旗下SpaceX高达750亿美元IPO：将禁有监管风险的中国和香港投资者认购","content":"据彭博社引述知情人士透露，特斯拉创办人马斯克旗下太空探索技术公司SpaceX的750亿美元首次公开招股（IPO）发行，其承销商已被告知不要接受来自香港和中国投资者的订单，理由是美国对关键技术出口有限制。而此次IPO预计将成为全球规模最大的公开募股。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260606-spacex%E9%AB%98%E8%BE%BE750%E4%BA%BF%E7%BE%8E%E5%85%83ipo-%E5%B0%86%E7%A6%81%E6%9C%89%E7%9B%91%E7%AE%A1%E9%A3%8E%E9%99%A9%E7%9A%84%E4%B8%AD%E5%9B%BD%E5%92%8C%E9%A6%99%E6%B8%AF%E6%8A%95%E8%B5%84%E8%80%85%E8%AE%A4%E8%B4%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780726251000.webp","sourceId":"rfi"},{"id":1780761676000,"createdDate":"2026-06-06 16:01","name":"法国国际广播电台","title":"俄乌战场持续僵持，普京再次拒绝泽连斯基的直接对话倡议","content":"正在圣彼得堡出席经济论坛活动的俄罗斯总统普京5日回绝了乌克兰总统泽连斯基日前提出的与他直接会谈，以便结束战争的提议。泽连斯基也立即对普京的拒绝做出反应，指出，俄罗斯方面再次选择了战争。如果说普京的拒绝再次凸显这场俄乌战争眼前的僵局的话，泽连斯基致信普京提议面谈则是在很大程度上向世界宣示乌克兰谋求和平的意愿，凸出发起这场战争的俄罗斯对战争持续的责任。对于已经因为持续四年有余的战争而经济面对重重困境的俄罗斯来说，乌克兰总统这项提议无疑也是面向俄罗斯普罗大众的一种心理战、舆论战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260606-%E4%BF%84%E4%B9%8C%E6%88%98%E5%9C%BA%E6%8C%81%E7%BB%AD%E5%83%B5%E6%8C%81%EF%BC%8C%E6%99%AE%E4%BA%AC%E5%86%8D%E6%AC%A1%E6%8B%92%E7%BB%9D%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E7%9A%84%E7%9B%B4%E6%8E%A5%E5%AF%B9%E8%AF%9D%E5%80%A1%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780761676000.webp","sourceId":"rfi"},{"id":1780760541000,"createdDate":"2026-06-06 15:42","name":"法国国际广播电台","title":"法国前总统希拉克遗孀贝尔纳黛特·希拉克去世 享年93岁","content":"法国前总统雅克·希拉克的遗孀贝尔纳黛特·希拉克于6月5日周五晚间去世，享年93岁。其女儿克劳德·希拉克周六上午向法新社证实了这一消息。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260606-%E6%B3%95%E5%9B%BD%E5%89%8D%E6%80%BB%E7%BB%9F%E5%B8%8C%E6%8B%89%E5%85%8B%E9%81%97%E5%AD%80%E8%B4%9D%E5%B0%94%E7%BA%B3%E9%BB%9B%E7%89%B9%C2%B7%E5%B8%8C%E6%8B%89%E5%85%8B%E5%8E%BB%E4%B8%96-%E4%BA%AB%E5%B9%B493%E5%B2%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780760541000.webp","sourceId":"rfi"},{"id":1780758028000,"createdDate":"2026-06-06 15:00","name":"法国国际广播电台","title":"美军：伊朗向科威特和巴林发射了7枚导弹 6枚被拦截","content":"美国军方周六宣布，伊朗向科威特和巴林发射了七枚导弹，其中六枚被拦截，最后一枚未击中目标。德黑兰指控美军袭击了伊朗的雷达设施。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260606-%E7%BE%8E%E5%86%9B-%E4%BC%8A%E6%9C%97%E5%90%91%E7%A7%91%E5%A8%81%E7%89%B9%E5%92%8C%E5%B7%B4%E6%9E%97%E5%8F%91%E5%B0%84%E4%BA%867%E6%9E%9A%E5%AF%BC%E5%BC%B9-6%E6%9E%9A%E8%A2%AB%E6%8B%A6%E6%88%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780758028000.webp","sourceId":"rfi"},{"id":1780754829000,"createdDate":"2026-06-06 14:07","name":"法国国际广播电台","title":"俄罗斯圣彼得堡论坛闭幕前夕再遭大规模无人机攻击","content":"圣彼得堡论坛周六闭幕前夕再次遭到大规模无人机攻击。普京周五拒绝了泽连斯基提出双方会面的建议。本周三开幕的圣彼得堡投资论坛预计周六闭幕。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260606-%E4%BF%84%E7%BD%97%E6%96%AF%E5%9C%A3%E5%BD%BC%E5%BE%97%E5%A0%A1%E8%AE%BA%E5%9D%9B%E9%97%AD%E5%B9%95%E5%89%8D%E5%A4%95%E5%86%8D%E9%81%AD%E5%A4%A7%E8%A7%84%E6%A8%A1%E6%97%A0%E4%BA%BA%E6%9C%BA%E6%94%BB%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780754829000.webp","sourceId":"rfi"},{"id":1780751151000,"createdDate":"2026-06-06 13:05","name":"法国国际广播电台","title":"诺曼底登陆82周年 美防长退出国际纪念仪式 专注美军纪念 吁欧洲重新武装","content":"今天周六是诺曼底盟军登陆82周年，美国防长皮特-海格塞斯（PeteHegseth）周六上午在法国科勒维尔滨海（Colleville-sur-mer）的美军公墓再次呼吁欧洲各国在国防方面付出更多努力。此前数小时，他刚刚宣布将退出在法国诺曼底举行的国际纪念登陆仪式。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260606-%E8%AF%BA%E6%9B%BC%E5%BA%95%E7%99%BB%E9%99%8682%E5%91%A8%E5%B9%B4-%E7%BE%8E%E9%98%B2%E9%95%BF%E9%80%80%E5%87%BA%E5%9B%BD%E9%99%85%E7%BA%AA%E5%BF%B5%E4%BB%AA%E5%BC%8F-%E4%B8%93%E6%B3%A8%E7%BE%8E%E5%86%9B%E7%BA%AA%E5%BF%B5-%E5%90%81%E6%AC%A7%E6%B4%B2%E9%87%8D%E6%96%B0%E6%AD%A6%E8%A3%85","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780751151000.webp","sourceId":"rfi"},{"id":1780751111000,"createdDate":"2026-06-06 13:05","name":"法国国际广播电台","title":"习近平访朝在即，金正恩首次提及建造万吨级驱逐舰计划","content":"就在中国国家主席习近平即将再度出访平壤之际，根据朝鲜官方媒体6日发布的消息，朝鲜领导人金正恩4日与女儿一道亲临现场，监督海军“姜健号”驱逐舰下水测试，再次强调发展海军力量对于核威慑战略的必要性，并首次提出准备建造万吨级驱逐舰。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260606-%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%BF%E6%9C%9D%E5%9C%A8%E5%8D%B3%EF%BC%8C%E9%87%91%E6%AD%A3%E6%81%A9%E9%A6%96%E6%AC%A1%E6%8F%90%E5%8F%8A%E5%BB%BA%E9%80%A0%E4%B8%87%E5%90%A8%E7%BA%A7%E9%A9%B1%E9%80%90%E8%88%B0%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780751111000.webp","sourceId":"rfi"},{"id":1780738383000,"createdDate":"2026-06-06 09:33","name":"法国国际广播电台","title":"中国规避美国芯片制裁的非常规策略：不是追求最先进，而是把成熟技术做到极致","content":"大家好，今天是6月6日星期六，法国一名11岁女童失踪后疑遭杀害，不仅震惊全国，也引发社会对司法体系失灵的批评，成为法国主流日报周末版头版焦点。此外，在美国制裁下，对北京而言，关键并不在于生产出“完美”的半导体，而在于生产一种国产芯片，并且能在未来数年中持续改进——这是科技专家Stonal首席执行官罗宾·里瓦东发表在法国周刊《快报》经济专栏的分析。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260606-%E4%B8%AD%E5%9B%BD%E8%A7%84%E9%81%BF%E7%BE%8E%E5%9B%BD%E8%8A%AF%E7%89%87%E5%88%B6%E8%A3%81%E7%9A%84%E9%9D%9E%E5%B8%B8%E8%A7%84%E7%AD%96%E7%95%A5-%E4%B8%8D%E6%98%AF%E8%BF%BD%E6%B1%82%E6%9C%80%E5%85%88%E8%BF%9B%EF%BC%8C%E8%80%8C%E6%98%AF%E6%8A%8A%E6%88%90%E7%86%9F%E6%8A%80%E6%9C%AF%E5%81%9A%E5%88%B0%E6%9E%81%E8%87%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780738383000.webp","sourceId":"rfi"},{"id":1780784638000,"createdDate":"2026-06-06 22:23","name":"法国国际广播电台","title":"蔡奇的权力已大到危险的地步？","content":"中共政治局常委蔡奇兼任中央党校校长后，海外有许多议论，比较严肃的说法，说如此一来，他在中共党内影响力大增，比较严厉的说法，则指其权力过大，虽然是习近平赋予的，但伴君如伴虎，蔡奇正不由自主地滑向危险的边缘。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260606-%E8%94%A1%E5%A5%87%E7%9A%84%E6%9D%83%E5%8A%9B%E5%B7%B2%E5%A4%A7%E5%88%B0%E5%8D%B1%E9%99%A9%E7%9A%84%E5%9C%B0%E6%AD%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780784638000.webp","sourceId":"rfi"},{"id":1780783688000,"createdDate":"2026-06-06 22:08","name":"法国国际广播电台","title":"特朗普外交政策引共和党内部分裂　伊朗与俄乌议题成国会反弹焦点","content":"美国总统特朗普（DonaldTrump）正因外交政策争议，在共和党内部面临近年少见的挑战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260606-%E7%89%B9%E6%9C%97%E4%BA%A4%E6%94%BF%E7%AD%96%E5%BC%95%E5%85%B1%E5%92%8C%E5%85%9A%E5%86%85%E9%83%A8%E5%88%86%E8%A3%82-%E4%BC%8A%E6%9C%97%E4%B8%8E%E4%BF%84%E4%B9%8C%E8%AE%AE%E9%A2%98%E6%88%90%E5%9B%BD%E4%BC%9A%E5%8F%8D%E5%BC%B9%E7%84%A6%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780783688000.webp","sourceId":"rfi"},{"id":1780783273000,"createdDate":"2026-06-06 22:01","name":"法国国际广播电台","title":"法国查明一批专事宣传中国的虚假新闻网站","content":"法国负责防范外国数字干预的国家监管机构---警惕数字干预安全局(Viginum)6月4日披露，查明一个多语言虚假新闻网站网络，与中国官媒---环球电视网（CGTN）有直接关联。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260606-%E6%B3%95%E5%9B%BD%E6%9F%A5%E6%98%8E%E4%B8%80%E6%89%B9%E4%B8%93%E4%BA%8B%E5%AE%A3%E4%BC%A0%E4%B8%AD%E5%9B%BD%E7%9A%84%E8%99%9A%E5%81%87%E6%96%B0%E9%97%BB%E7%BD%91%E7%AB%99","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780783273000.webp","sourceId":"rfi"},{"id":1780782354000,"createdDate":"2026-06-06 21:45","name":"法国国际广播电台","title":"世界杯临近 法国查获大批假球衣 多数来自中国","content":"随着2026年世界杯足球赛将于6月11日开幕，球衣需求迅速升温。法国海关近日查获大批仿冒足球球衣，并表示相关产品大多来自中国。法国媒体指出，在正版球衣价格持续上涨的背景下，价格低廉且仿真度越来越高的假球衣正吸引越来越多消费者。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260606-%E4%B8%96%E7%95%8C%E6%9D%AF%E4%B8%B4%E8%BF%91-%E6%B3%95%E5%9B%BD%E6%9F%A5%E8%8E%B7%E5%A4%A7%E6%89%B9%E5%81%87%E7%90%83%E8%A1%A3-%E5%A4%9A%E6%95%B0%E6%9D%A5%E8%87%AA%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780782354000.webp","sourceId":"rfi"},{"id":1780782050000,"createdDate":"2026-06-06 21:40","name":"法国国际广播电台","title":"美国呼吁台湾增加防务投入 强调无人机对维持军力平衡至关重要","content":"美国驻台最高级别代表周六（6月6日）表示，台湾不仅需要增加防务投入，更应“更聪明地花钱”，并借鉴乌克兰战争和中东冲突的经验，通过发展无人机等不对称作战能力维持台海军事平衡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260606-%E7%BE%8E%E5%9B%BD%E5%91%BC%E5%90%81%E5%8F%B0%E6%B9%BE%E5%A2%9E%E5%8A%A0%E9%98%B2%E5%8A%A1%E6%8A%95%E5%85%A5-%E5%BC%BA%E8%B0%83%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%AF%B9%E7%BB%B4%E6%8C%81%E5%86%9B%E5%8A%9B%E5%B9%B3%E8%A1%A1%E8%87%B3%E5%85%B3%E9%87%8D%E8%A6%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780782050000.webp","sourceId":"rfi"},{"id":1780781811000,"createdDate":"2026-06-06 21:36","name":"法国国际广播电台","title":"中国证监会要求基金业加大创新支持力度 警惕概念炒作","content":"中国证监会主席吴清周六（6月6日）表示，中国规模达13万亿美元的基金行业应进一步支持科技创新和新兴产业发展，同时警惕概念炒作、过度投机等市场乱象。中国监管部门近期持续加强对私募基金行业及跨境投资活动的监管。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260606-%E4%B8%AD%E5%9B%BD%E8%AF%81%E7%9B%91%E4%BC%9A%E8%A6%81%E6%B1%82%E5%9F%BA%E9%87%91%E4%B8%9A%E5%8A%A0%E5%A4%A7%E5%88%9B%E6%96%B0%E6%94%AF%E6%8C%81%E5%8A%9B%E5%BA%A6-%E8%AD%A6%E6%83%95%E6%A6%82%E5%BF%B5%E7%82%92%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780781811000.webp","sourceId":"rfi"},{"id":1780781593000,"createdDate":"2026-06-06 21:33","name":"法国国际广播电台","title":"世界杯：伊朗队赴墨西哥备战 德黑兰谴责美国拒发部分人员签证","content":"伊朗国家足球队周六（6月6日）启程前往墨西哥，准备参加即将开幕的2026年世界杯足球赛。不过，由于美国拒绝向部分伊朗队官员和工作人员发放签证，德黑兰谴责美方对其实施“歧视性待遇”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260606-%E4%B8%96%E7%95%8C%E6%9D%AF-%E4%BC%8A%E6%9C%97%E9%98%9F%E8%B5%B4%E5%A2%A8%E8%A5%BF%E5%93%A5%E5%A4%87%E6%88%98-%E5%BE%B7%E9%BB%91%E5%85%B0%E8%B0%B4%E8%B4%A3%E7%BE%8E%E5%9B%BD%E6%8B%92%E5%8F%91%E9%83%A8%E5%88%86%E4%BA%BA%E5%91%98%E7%AD%BE%E8%AF%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780781593000.webp","sourceId":"rfi"},{"id":1780781324000,"createdDate":"2026-06-06 21:28","name":"法国国际广播电台","title":"诺曼底登陆纪念日：赫格塞思称欧洲遭遇“移民入侵” 呼吁强化防务","content":"美国国防部长赫格塞思周六（6月6日）在法国举行的诺曼底登陆82周年纪念活动上表示，欧洲正面临“移民入侵”，他再次敦促欧洲国家增强自身防务能力。数小时前，赫格塞斯宣布退出当天举行的国际纪念仪式，仅参加美方纪念活动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260606-%E8%AF%BA%E6%9B%BC%E5%BA%95%E7%99%BB%E9%99%86%E7%BA%AA%E5%BF%B5%E6%97%A5-%E8%B5%AB%E6%A0%BC%E5%A1%9E%E6%80%9D%E7%A7%B0%E6%AC%A7%E6%B4%B2%E9%81%AD%E9%81%87-%E7%A7%BB%E6%B0%91%E5%85%A5%E4%BE%B5-%E5%91%BC%E5%90%81%E5%BC%BA%E5%8C%96%E9%98%B2%E5%8A%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780781324000.webp","sourceId":"rfi"},{"id":1780768488000,"createdDate":"2026-06-06 17:54","name":"法国国际广播电台","title":"台湾：东沙附近首次中国海警船和勘测船协同行动挑衅台湾","content":"路透社6月6日台北消息，台湾周六表示，中国海警船和勘测船在南海战略要地岛屿附近水域进行了首次协同行动，意图“挑衅”台湾。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260606-%E5%8F%B0%E6%B9%BE-%E4%B8%9C%E6%B2%99%E9%99%84%E8%BF%91%E9%A6%96%E6%AC%A1%E4%B8%AD%E5%9B%BD%E6%B5%B7%E8%AD%A6%E8%88%B9%E5%92%8C%E5%8B%98%E6%B5%8B%E8%88%B9%E5%8D%8F%E5%90%8C%E8%A1%8C%E5%8A%A8%E6%8C%91%E8%A1%85%E5%8F%B0%E6%B9%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780768488000.webp","sourceId":"rfi"},{"id":1780767658000,"createdDate":"2026-06-06 17:40","name":"法国国际广播电台","title":"黎巴嫩三名军人车内遇袭身亡 贝鲁特谴责以色列“无休止”袭击","content":"黎巴嫩军方周六表示，尽管理论上停火协议仍在生效，以色列的空袭造成三名黎巴嫩军人丧生，此次袭击的目标是一辆行驶在哈尔达利与纳巴提耶之间公路上的军用车辆。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260606-%E9%BB%8E%E5%B7%B4%E5%AB%A9%E4%B8%89%E5%90%8D%E5%86%9B%E4%BA%BA%E8%BD%A6%E5%86%85%E9%81%87%E8%A2%AD%E8%BA%AB%E4%BA%A1-%E8%B4%9D%E9%B2%81%E7%89%B9%E8%B0%B4%E8%B4%A3%E4%BB%A5%E8%89%B2%E5%88%97-%E6%97%A0%E4%BC%91%E6%AD%A2-%E8%A2%AD%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/06/1780767658000.webp","sourceId":"rfi"}]