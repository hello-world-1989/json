[{"id":1782519761000,"createdDate":"2026-06-27 00:22","name":"法国国际广播电台","title":"AI时代：中国高校掀起大规模专业调整，外语专业需要“拥抱理工科”","content":"法国世界报周五关注中国高校在人工智能时代正在经历的新一轮大规模专业调整。该报表示，为了配合中国政府的以人工智能为核心的经济发展重点，同时也为了培养的毕业生在就业市场上有竞争力，中国各地高校正在掀起一轮专业改革。一些传统专业，尤其是外语专业，如果想继续生存，必须与理工科深度融合。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260627-ai%E6%97%B6%E4%BB%A3-%E4%B8%AD%E5%9B%BD%E9%AB%98%E6%A0%A1%E6%8E%80%E8%B5%B7%E5%A4%A7%E8%A7%84%E6%A8%A1%E4%B8%93%E4%B8%9A%E8%B0%83%E6%95%B4%EF%BC%8C%E5%A4%96%E8%AF%AD%E4%B8%93%E4%B8%9A%E9%9C%80%E8%A6%81-%E6%8B%A5%E6%8A%B1%E7%90%86%E5%B7%A5%E7%A7%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782519761000.webp","sourceId":"rfi"}]