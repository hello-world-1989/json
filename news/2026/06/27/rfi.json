[{"id":1782519761000,"createdDate":"2026-06-27 00:22","name":"法国国际广播电台","title":"AI时代：中国高校掀起大规模专业调整，外语专业需要“拥抱理工科”","content":"法国世界报周五关注中国高校在人工智能时代正在经历的新一轮大规模专业调整。该报表示，为了配合中国政府的以人工智能为核心的经济发展重点，同时也为了培养的毕业生在就业市场上有竞争力，中国各地高校正在掀起一轮专业改革。一些传统专业，尤其是外语专业，如果想继续生存，必须与理工科深度融合。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260627-ai%E6%97%B6%E4%BB%A3-%E4%B8%AD%E5%9B%BD%E9%AB%98%E6%A0%A1%E6%8E%80%E8%B5%B7%E5%A4%A7%E8%A7%84%E6%A8%A1%E4%B8%93%E4%B8%9A%E8%B0%83%E6%95%B4%EF%BC%8C%E5%A4%96%E8%AF%AD%E4%B8%93%E4%B8%9A%E9%9C%80%E8%A6%81-%E6%8B%A5%E6%8A%B1%E7%90%86%E5%B7%A5%E7%A7%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782519761000.webp","sourceId":"rfi"},{"id":1782550454000,"createdDate":"2026-06-27 08:54","name":"法国国际广播电台","title":"马兴瑞、解放军6将军等15人 终止中国人大代表资格","content":"中国十四届全国人大常委会第二十三次会议周五（26日）下午在北京人民大会堂闭幕。会后公告显示，计15人被终止人大代表资格，包括中共中央政治局委员马兴瑞、重庆市委原副书记、原市长胡衡华、中国国家金融监督管理总局局长李云泽，及解放军三名上将、三名中将等。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260627-%E9%A9%AC%E5%85%B4%E7%91%9E-%E8%A7%A3%E6%94%BE%E5%86%9B6%E5%B0%86%E5%86%9B%E7%AD%8915%E4%BA%BA-%E7%BB%88%E6%AD%A2%E4%B8%AD%E5%9B%BD%E4%BA%BA%E5%A4%A7%E4%BB%A3%E8%A1%A8%E8%B5%84%E6%A0%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782550454000.webp","sourceId":"rfi"},{"id":1782550265000,"createdDate":"2026-06-27 08:51","name":"法国国际广播电台","title":"十余架中俄军机进入韩国防空区后，韩国紧急出动战斗机","content":"韩国政府周六（6月27日）表示，当天上午10余架中俄军机一度进入韩国防空识别区（KADIZ），与此同时，韩国空军紧急出动战斗机应对。不过，韩国方面同时也指出，这些军机并未侵犯韩国领空。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260627-%E5%8D%81%E4%BD%99%E6%9E%B6%E4%B8%AD%E4%BF%84%E5%86%9B%E6%9C%BA%E8%BF%9B%E5%85%A5%E9%9F%A9%E5%9B%BD%E9%98%B2%E7%A9%BA%E5%8C%BA%E5%90%8E%EF%BC%8C%E9%9F%A9%E5%9B%BD%E7%B4%A7%E6%80%A5%E5%87%BA%E5%8A%A8%E6%88%98%E6%96%97%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782550265000.webp","sourceId":"rfi"},{"id":1782548764000,"createdDate":"2026-06-27 08:26","name":"法国国际广播电台","title":"热浪：50亿年后，太阳将变成一颗被称为“白矮星”的恒星残骸","content":"热浪当前，科学家指出，50亿年后，太阳将变成一颗被称为“白矮星”的恒星残骸。研究人员最近发现，当恒星达到红巨星阶段时，它们会逐渐膨胀，最终抛射出外层物质，只留下一个密度极高的恒星残骸，称为“白矮星”。太阳大约在50亿年后也会经历这种转变。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260627-%E7%83%AD%E6%B5%AA-50%E4%BA%BF%E5%B9%B4%E5%90%8E%EF%BC%8C%E5%A4%AA%E9%98%B3%E5%B0%86%E5%8F%98%E6%88%90%E4%B8%80%E9%A2%97%E8%A2%AB%E7%A7%B0%E4%B8%BA-%E7%99%BD%E7%9F%AE%E6%98%9F-%E7%9A%84%E6%81%92%E6%98%9F%E6%AE%8B%E9%AA%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782548764000.webp","sourceId":"rfi"},{"id":1782548569000,"createdDate":"2026-06-27 08:22","name":"法国国际广播电台","title":"日本在美伊交战后首次向伊朗等提供援助","content":"日本外相茂木敏充6月26日在记者会上宣布，鉴于伊朗、黎巴嫩和巴勒斯坦的人道主义状况恶化，日本将提供总额1500万美元（约合24亿日元）的紧急无偿资金援助。这是自今年2月美国与伊朗等方面爆发战斗以来，日本首次向相关国家和地区提供新的援助。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260627-%E6%97%A5%E6%9C%AC%E5%9C%A8%E7%BE%8E%E4%BC%8A%E4%BA%A4%E6%88%98%E5%90%8E%E9%A6%96%E6%AC%A1%E5%90%91%E4%BC%8A%E6%9C%97%E7%AD%89%E6%8F%90%E4%BE%9B%E6%8F%B4%E5%8A%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782548569000.webp","sourceId":"rfi"},{"id":1782573081000,"createdDate":"2026-06-27 15:11","name":"法国国际广播电台","title":"真主党总书记称黎以安全协议“无效” 霍尔木兹海峡一油轮遇袭","content":"真主党总书记卡西姆（NaimQassem）周六拒绝了黎巴嫩与以色列之间一项由美国斡旋达成的安全协议——该协议签署仅一天——并称其为向以色列投降。尽管此前已多次达成停火与协议，敌对行动仍在持续；作为最新一例，以色列在黎巴嫩南部发动了无人机袭击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260627-%E7%9C%9F%E4%B8%BB%E5%85%9A%E6%80%BB%E4%B9%A6%E8%AE%B0%E7%A7%B0%E9%BB%8E%E4%BB%A5%E5%AE%89%E5%85%A8%E5%8D%8F%E8%AE%AE-%E6%97%A0%E6%95%88-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E4%B8%80%E6%B2%B9%E8%BD%AE%E9%81%87%E8%A2%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782573081000.webp","sourceId":"rfi"},{"id":1782570511000,"createdDate":"2026-06-27 14:28","name":"法国国际广播电台","title":"华盛顿允许Anthropic向受信任美机构发布Mythos 5模型 Fable 5最早下周解禁","content":"人工智能公司Anthropic周五表示，美国政府已允许其向部分“受信任”的美国机构发布功能强大的ClaudeMythos5人工智能模型；此举部分撤销了两周前因国家安全风险而下达的暂停访问指令。一位知情人士透露，目前将有超过100家企业和机构能够使用Mythos5，其中包括许多财富500强公司。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260627-%E5%8D%8E%E7%9B%9B%E9%A1%BF%E5%85%81%E8%AE%B8anthropic%E5%90%91%E5%8F%97%E4%BF%A1%E4%BB%BB%E7%BE%8E%E6%9C%BA%E6%9E%84%E5%8F%91%E5%B8%83mythos-5%E6%A8%A1%E5%9E%8B-fable-5%E6%9C%80%E6%97%A9%E4%B8%8B%E5%91%A8%E8%A7%A3%E7%A6%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782570511000.webp","sourceId":"rfi"},{"id":1782567651000,"createdDate":"2026-06-27 13:40","name":"法国国际广播电台","title":"日本拟获得具反舰攻击能力无人潜艇 考虑在小笠原群岛上空设防识区","content":"据共同社援引多名相关人士报导称，作为加强太平洋沿岸防卫体制的一环，日本政府已着手研究正式开发和引进具备反舰攻击等能力的无人潜艇。在太平洋广阔的海域，中国正不断加强海洋扩张，而日本的防卫体制却被指出存在“空白”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260627-%E6%97%A5%E6%9C%AC%E6%8B%9F%E8%8E%B7%E5%BE%97%E5%85%B7%E5%8F%8D%E8%88%B0%E6%94%BB%E5%87%BB%E8%83%BD%E5%8A%9B%E6%97%A0%E4%BA%BA%E6%BD%9C%E8%89%87-%E8%80%83%E8%99%91%E5%9C%A8%E5%B0%8F%E7%AC%A0%E5%8E%9F%E7%BE%A4%E5%B2%9B%E4%B8%8A%E7%A9%BA%E8%AE%BE%E9%98%B2%E8%AF%86%E5%8C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782567651000.webp","sourceId":"rfi"},{"id":1782561563000,"createdDate":"2026-06-27 11:59","name":"法国国际广播电台","title":"面对涨价 苹果正游说特朗普政府 寻求获准从长鑫存储采购芯片","content":"据英国《金融时报》援引六位知情人士报导称，苹果公司正游说特朗普政府，寻求获准从中企长鑫存储（CXMT）处采购存储芯片。长鑫存储因被指与解放军有关联，已被五角大楼列入黑名单。苹果已开展游说活动，旨在获得白宫的许可，从而缓解存储芯片价格上涨带来的财务压力。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260627-%E9%9D%A2%E5%AF%B9%E6%B6%A8%E4%BB%B7-%E8%8B%B9%E6%9E%9C%E6%AD%A3%E6%B8%B8%E8%AF%B4%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C-%E5%AF%BB%E6%B1%82%E8%8E%B7%E5%87%86%E4%BB%8E%E9%95%BF%E9%91%AB%E5%AD%98%E5%82%A8%E9%87%87%E8%B4%AD%E8%8A%AF%E7%89%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782561563000.webp","sourceId":"rfi"},{"id":1782557061000,"createdDate":"2026-06-27 10:44","name":"法国国际广播电台","title":"美联邦通信委员会扩大禁令封杀华为中兴等中企国安用途产品","content":"美国联邦通信委员会（FCC）周五宣布，将禁止进口更多来自中国制造商的设备。这是华盛顿方面封杀中国制造的电子设备的最新举措。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260627-%E7%BE%8E%E8%81%94%E9%82%A6%E9%80%9A%E4%BF%A1%E5%A7%94%E5%91%98%E4%BC%9A%E6%89%A9%E5%A4%A7%E7%A6%81%E4%BB%A4%E5%B0%81%E6%9D%80%E5%8D%8E%E4%B8%BA%E4%B8%AD%E5%85%B4%E7%AD%89%E4%B8%AD%E4%BC%81%E5%9B%BD%E5%AE%89%E7%94%A8%E9%80%94%E4%BA%A7%E5%93%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782557061000.webp","sourceId":"rfi"},{"id":1782556757000,"createdDate":"2026-06-27 10:39","name":"法国国际广播电台","title":"法国历史性高温考验马克龙生态政绩，中央政府和地方政府被指“互推责任”","content":"6月27日出刊的法国主流日刊集中讨论了法国高温热浪和政府的反应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260627-%E6%B3%95%E5%9B%BD%E5%8E%86%E5%8F%B2%E6%80%A7%E9%AB%98%E6%B8%A9%E8%80%83%E9%AA%8C%E9%A9%AC%E5%85%8B%E9%BE%99%E7%94%9F%E6%80%81%E6%94%BF%E7%BB%A9%EF%BC%8C%E4%B8%AD%E5%A4%AE%E6%94%BF%E5%BA%9C%E5%92%8C%E5%9C%B0%E6%96%B9%E6%94%BF%E5%BA%9C-%E4%BA%92%E6%8E%A8%E8%B4%A3%E4%BB%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782556757000.webp","sourceId":"rfi"},{"id":1782555727000,"createdDate":"2026-06-27 10:22","name":"法国国际广播电台","title":"世界杯小组赛进入最后阶段：法国锁定头名 佛得角首次晋级淘汰赛 英葡提前出线","content":"2026年世界杯小组赛已经进入最后阶段，最后一轮比赛将于6月27日全部结束。目前，多支球队已经提前确定晋级席位，但部分小组的头名归属仍然存在悬念。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260627-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%B0%8F%E7%BB%84%E8%B5%9B%E8%BF%9B%E5%85%A5%E6%9C%80%E5%90%8E%E9%98%B6%E6%AE%B5-%E6%B3%95%E5%9B%BD%E9%94%81%E5%AE%9A%E5%A4%B4%E5%90%8D-%E4%BD%9B%E5%BE%97%E8%A7%92%E9%A6%96%E6%AC%A1%E6%99%8B%E7%BA%A7%E6%B7%98%E6%B1%B0%E8%B5%9B-%E8%8B%B1%E8%91%A1%E6%8F%90%E5%89%8D%E5%87%BA%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782555727000.webp","sourceId":"rfi"},{"id":1782551831000,"createdDate":"2026-06-27 09:17","name":"法国国际广播电台","title":"北京中信大厦“中国尊”遭小飞机撞击 官方通报驾驶员死亡13人受伤","content":"根据北京市朝阳区官方信息平台“北京朝阳”微信公众号周六发布的“情况通报”指，“6月26日17时55分，在朝阳区东三环附近，一架单发双座轻型运动航空器在飞行中碰撞一高层建筑，机上仅驾驶员1人、已死亡，现场13人受伤”。该通报称，受伤人员在全力救治中。相关情况正由主管部门进一步调查。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260627-%E5%8C%97%E4%BA%AC%E4%B8%AD%E4%BF%A1%E5%A4%A7%E5%8E%A6-%E4%B8%AD%E5%9B%BD%E5%B0%8A-%E9%81%AD%E5%B0%8F%E9%A3%9E%E6%9C%BA%E6%92%9E%E5%87%BB-%E5%AE%98%E6%96%B9%E9%80%9A%E6%8A%A5%E9%A9%BE%E9%A9%B6%E5%91%98%E6%AD%BB%E4%BA%A113%E4%BA%BA%E5%8F%97%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782551831000.webp","sourceId":"rfi"}]