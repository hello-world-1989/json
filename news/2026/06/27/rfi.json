[{"id":1782519761000,"createdDate":"2026-06-27 00:22","name":"法国国际广播电台","title":"AI时代：中国高校掀起大规模专业调整，外语专业需要“拥抱理工科”","content":"法国世界报周五关注中国高校在人工智能时代正在经历的新一轮大规模专业调整。该报表示，为了配合中国政府的以人工智能为核心的经济发展重点，同时也为了培养的毕业生在就业市场上有竞争力，中国各地高校正在掀起一轮专业改革。一些传统专业，尤其是外语专业，如果想继续生存，必须与理工科深度融合。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260627-ai%E6%97%B6%E4%BB%A3-%E4%B8%AD%E5%9B%BD%E9%AB%98%E6%A0%A1%E6%8E%80%E8%B5%B7%E5%A4%A7%E8%A7%84%E6%A8%A1%E4%B8%93%E4%B8%9A%E8%B0%83%E6%95%B4%EF%BC%8C%E5%A4%96%E8%AF%AD%E4%B8%93%E4%B8%9A%E9%9C%80%E8%A6%81-%E6%8B%A5%E6%8A%B1%E7%90%86%E5%B7%A5%E7%A7%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782519761000.webp","sourceId":"rfi"},{"id":1782550454000,"createdDate":"2026-06-27 08:54","name":"法国国际广播电台","title":"马兴瑞、解放军6将军等15人 终止中国人大代表资格","content":"中国十四届全国人大常委会第二十三次会议周五（26日）下午在北京人民大会堂闭幕。会后公告显示，计15人被终止人大代表资格，包括中共中央政治局委员马兴瑞、重庆市委原副书记、原市长胡衡华、中国国家金融监督管理总局局长李云泽，及解放军三名上将、三名中将等。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260627-%E9%A9%AC%E5%85%B4%E7%91%9E-%E8%A7%A3%E6%94%BE%E5%86%9B6%E5%B0%86%E5%86%9B%E7%AD%8915%E4%BA%BA-%E7%BB%88%E6%AD%A2%E4%B8%AD%E5%9B%BD%E4%BA%BA%E5%A4%A7%E4%BB%A3%E8%A1%A8%E8%B5%84%E6%A0%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782550454000.webp","sourceId":"rfi"},{"id":1782550265000,"createdDate":"2026-06-27 08:51","name":"法国国际广播电台","title":"十余架中俄军机进入韩国防空区后，韩国紧急出动战斗机","content":"韩国政府周六（6月27日）表示，当天上午10余架中俄军机一度进入韩国防空识别区（KADIZ），与此同时，韩国空军紧急出动战斗机应对。不过，韩国方面同时也指出，这些军机并未侵犯韩国领空。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260627-%E5%8D%81%E4%BD%99%E6%9E%B6%E4%B8%AD%E4%BF%84%E5%86%9B%E6%9C%BA%E8%BF%9B%E5%85%A5%E9%9F%A9%E5%9B%BD%E9%98%B2%E7%A9%BA%E5%8C%BA%E5%90%8E%EF%BC%8C%E9%9F%A9%E5%9B%BD%E7%B4%A7%E6%80%A5%E5%87%BA%E5%8A%A8%E6%88%98%E6%96%97%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782550265000.webp","sourceId":"rfi"},{"id":1782548764000,"createdDate":"2026-06-27 08:26","name":"法国国际广播电台","title":"热浪：50亿年后，太阳将变成一颗被称为“白矮星”的恒星残骸","content":"热浪当前，科学家指出，50亿年后，太阳将变成一颗被称为“白矮星”的恒星残骸。研究人员最近发现，当恒星达到红巨星阶段时，它们会逐渐膨胀，最终抛射出外层物质，只留下一个密度极高的恒星残骸，称为“白矮星”。太阳大约在50亿年后也会经历这种转变。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260627-%E7%83%AD%E6%B5%AA-50%E4%BA%BF%E5%B9%B4%E5%90%8E%EF%BC%8C%E5%A4%AA%E9%98%B3%E5%B0%86%E5%8F%98%E6%88%90%E4%B8%80%E9%A2%97%E8%A2%AB%E7%A7%B0%E4%B8%BA-%E7%99%BD%E7%9F%AE%E6%98%9F-%E7%9A%84%E6%81%92%E6%98%9F%E6%AE%8B%E9%AA%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782548764000.webp","sourceId":"rfi"},{"id":1782548569000,"createdDate":"2026-06-27 08:22","name":"法国国际广播电台","title":"日本在美伊交战后首次向伊朗等提供援助","content":"日本外相茂木敏充6月26日在记者会上宣布，鉴于伊朗、黎巴嫩和巴勒斯坦的人道主义状况恶化，日本将提供总额1500万美元（约合24亿日元）的紧急无偿资金援助。这是自今年2月美国与伊朗等方面爆发战斗以来，日本首次向相关国家和地区提供新的援助。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260627-%E6%97%A5%E6%9C%AC%E5%9C%A8%E7%BE%8E%E4%BC%8A%E4%BA%A4%E6%88%98%E5%90%8E%E9%A6%96%E6%AC%A1%E5%90%91%E4%BC%8A%E6%9C%97%E7%AD%89%E6%8F%90%E4%BE%9B%E6%8F%B4%E5%8A%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/27/1782548569000.webp","sourceId":"rfi"}]