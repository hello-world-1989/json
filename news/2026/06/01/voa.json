[{"id":1780331041000,"createdDate":"2026-06-01 16:24","name":"美国之音","title":"美军称，在对伊朗南部实施更多防御性打击后，美军拦截了伊朗对驻科威特美军的最新导弹袭击","content":"美国军方表示，在上周末因伊朗政权的挑衅行动而对伊朗实施自卫打击后，美军星期一(6月1日)凌晨击退了伊朗针对驻科威特美军的导弹袭击。","newsLink":"https://www.voachinese.com/a/us-military-says-it-intercepted-latest-iranian-missile-attack-on-us-forces-in-kuwait-20260601/8156111.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/01/1780331041000.webp","sourceId":"voa"},{"id":1780354714000,"createdDate":"2026-06-01 22:58","name":"美国之音","title":"美伊最新冲突考验停火之际，特朗普表示与伊朗政权的谈判正以“快速步伐”继续","content":"在美伊双方最新一轮军事冲突考验自4月以来一直维持的停火之际，唐纳德·特朗普总统说，他的政府正在以“快速步伐”继续与伊朗政权进行谈判。","newsLink":"https://www.voachinese.com/a/trump-says-talks-with-iranian-regime-continuing-at-rapid-pace-as-latest-us-iran-skirmishes-test-april-8-ceasefire-20260601/8156193.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/01/1780354714000.webp","sourceId":"voa"},{"id":1780349762000,"createdDate":"2026-06-01 21:36","name":"美国之音","title":"美伊停火协议再次经受考验：美国对伊朗实施防御性打击，伊朗则以导弹袭击驻科威特美军作为报复","content":"美伊之间的停火协议再次受到考验：在美国军方对伊朗境内实施其所谓“防御性”军事打击后，伊朗予以报复，向驻科威特的美军基地发射弹道导弹。","newsLink":"https://www.voachinese.com/a/us-carries-out-defensive-strikes-on-iranian-targets-and-regime-retaliates-with-missile-strike-targeting-us-troops-in-kuwait-20260601/8156180.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/01/1780349762000.webp","sourceId":"voa"},{"id":1780343274000,"createdDate":"2026-06-01 19:47","name":"美国之音","title":"特朗普宣布：以军从贝鲁特折返，真主党同意“射击将会停止”","content":"美国总统唐纳德·特朗普说，在他与以色列总理本雅明·内塔尼亚胡通了电话之后，以色列将不再向贝鲁特派兵。向贝鲁特派兵是以色列与真主党恐怖组织冲突的一部分。","newsLink":"https://www.voachinese.com/a/trump-announces-israeli-troops-turned-back-from-beirut-and-hezbollah-agreed-that-shooting-will-stop-20260601/8156167.html","thumbnail":"","detailImage":"news/detail/voa/2026/06/01/1780343274000.webp","sourceId":"voa"}]