[{"id":1780305208000,"createdDate":"2026-06-01 09:13","name":"法国国际广播电台","title":"鲁比奥与小马科斯通话：讨论经济和安全事项，包括促进南中国海和平安全","content":"菲律宾总统小马科斯（FerdinandMarcosJr.）周一与美国国务卿鲁比奥（MarcoRubio）通电话，讨论了地区局势、经济优先事项和双边贸易问题。小马科斯在社交媒体上发文称，此次通话“富有成效”，并表示其重申了菲美之间的牢固同盟关系。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260601-%E9%B2%81%E6%AF%94%E5%A5%A5%E4%B8%8E%E5%B0%8F%E9%A9%AC%E7%A7%91%E6%96%AF%E9%80%9A%E8%AF%9D-%E8%AE%A8%E8%AE%BA%E7%BB%8F%E6%B5%8E%E5%92%8C%E5%AE%89%E5%85%A8%E4%BA%8B%E9%A1%B9%EF%BC%8C%E5%8C%85%E6%8B%AC%E4%BF%83%E8%BF%9B%E5%8D%97%E4%B8%AD%E5%9B%BD%E6%B5%B7%E5%92%8C%E5%B9%B3%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780305208000.webp","sourceId":"rfi"},{"id":1780304141000,"createdDate":"2026-06-01 08:55","name":"法国国际广播电台","title":"「六四」前夕 纪念馆遭破坏 王丹：作案动机不难想像","content":"在六四事件37周年前夕，位处美国洛杉矶的六四纪念馆遭人潜入馆内破坏，馆长王丹表示，破坏情况严重，而在“六四”纪念前夕出现此事，「作案动机不难想象」。该馆已经报警处理。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260601-%E5%85%AD%E5%9B%9B-%E5%89%8D%E5%A4%95-%E7%BA%AA%E5%BF%B5%E9%A6%86%E9%81%AD%E7%A0%B4%E5%9D%8F-%E7%8E%8B%E4%B8%B9-%E4%BD%9C%E6%A1%88%E5%8A%A8%E6%9C%BA%E4%B8%8D%E9%9A%BE%E6%83%B3%E5%83%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780304141000.webp","sourceId":"rfi"},{"id":1780303882000,"createdDate":"2026-06-01 08:51","name":"法国国际广播电台","title":"英澳加多地悼念六四 邹幸彤狱中续绝食37小时","content":"今年是中国武力镇压八九民运37周年，全球有三十多项纪念活动悼念当年的死难者，当中九项已於刚过去的周末和周日举行，包括台北声援被羁押的香港烛光晚会组织者李卓人和邹幸彤，而在狱中的邹幸彤已表明，她会继续在狱中绝食37小时，呼吁大家续写六四故事，拒绝遗忘，以免让遗忘把民主带向衰亡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260601-%E8%8B%B1%E6%BE%B3%E5%8A%A0%E5%A4%9A%E5%9C%B0%E6%82%BC%E5%BF%B5%E5%85%AD%E5%9B%9B-%E9%82%B9%E5%B9%B8%E5%BD%A4%E7%8B%B1%E4%B8%AD%E7%BB%AD%E7%BB%9D%E9%A3%9F37%E5%B0%8F%E6%97%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780303882000.webp","sourceId":"rfi"},{"id":1780303391000,"createdDate":"2026-06-01 08:43","name":"法国国际广播电台","title":"美商务部封堵允许向中企海外子公司出口尖端AI芯片漏洞","content":"美国商务部周日采取行动，堵上一个潜在的漏洞，该漏洞可能导致一些公司将全球最先进的芯片——例如英伟达最先进的Blackwell处理器——出口到位于中国境外的中企子公司。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260601-%E7%BE%8E%E5%95%86%E5%8A%A1%E9%83%A8%E5%B0%81%E5%A0%B5%E5%85%81%E8%AE%B8%E5%90%91%E4%B8%AD%E4%BC%81%E6%B5%B7%E5%A4%96%E5%AD%90%E5%85%AC%E5%8F%B8%E5%87%BA%E5%8F%A3ai%E8%8A%AF%E7%89%87%E6%BC%8F%E6%B4%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780303391000.webp","sourceId":"rfi"},{"id":1780329692000,"createdDate":"2026-06-01 16:01","name":"法国国际广播电台","title":"欧盟即将正式加入美“硅和平倡议” 涉AI、半导体和供应链安全等领域","content":"欧盟即将正式加入“硅和平倡议”（PaxSilica），这是一项由美国主导的战略倡议，旨在协调人工智能芯片供应链和出口管制，以对抗中国。此前，欧盟内部就此进行了数周的讨论，担心该倡议可能会损害欧盟的监管自主权。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260601-%E6%AC%A7%E7%9B%9F%E5%8D%B3%E5%B0%86%E6%AD%A3%E5%BC%8F%E5%8A%A0%E5%85%A5%E7%BE%8E-%E7%A1%85%E5%92%8C%E5%B9%B3%E5%80%A1%E8%AE%AE-%E6%B6%89ai-%E5%8D%8A%E5%AF%BC%E4%BD%93%E5%92%8C%E4%BE%9B%E5%BA%94%E9%93%BE%E5%AE%89%E5%85%A8%E7%AD%89%E9%A2%86%E5%9F%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780329692000.webp","sourceId":"rfi"},{"id":1780327646000,"createdDate":"2026-06-01 15:27","name":"法国国际广播电台","title":"特朗普据报促习近平使普京重返谈判桌以结束俄乌战争","content":"据《南华早报》援引多位知情人士报导称，美国总统特朗普在北京峰会期间曾亲自敦促中国国家主席习近平帮助结束乌克兰战争，试图利用北京对莫斯科的影响力来解决这场已持续五年的冲突。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260601-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8D%AE%E6%8A%A5%E4%BF%83%E4%B9%A0%E8%BF%91%E5%B9%B3%E4%BD%BF%E6%99%AE%E4%BA%AC%E9%87%8D%E8%BF%94%E8%B0%88%E5%88%A4%E6%A1%8C%E4%BB%A5%E7%BB%93%E6%9D%9F%E4%BF%84%E4%B9%8C%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780327646000.webp","sourceId":"rfi"},{"id":1780324386000,"createdDate":"2026-06-01 14:33","name":"法国国际广播电台","title":"为抗衡中国 日本和菲律宾将展开哪些军事合作？","content":"5月26日至29日，菲律宾总统马科斯二世及夫人作为国宾访问日本，双方在海洋问题上都承受着来自中国的压力，管辖包括钓鱼岛在内的日本第11管区海上保安本部（那霸）2025年12月30日发布消息称，在位于钓鱼岛（尖阁诸岛）周边、处于日本领海外侧的毗连区内，确认中国海警舰全年航行天数累计达356天，刷新了自2012年钓鱼岛“国有化”以来的最高纪录，中菲围绕菲律宾专属经济区（EEZ）内的部分海域和岛礁的主权和海洋权益问题争端不断，双方在黄岩岛、仁爱礁等争议海域多次发生对峙、水炮喷射和船只擦碰等摩擦，因此日菲双方都有强烈的合纵连横，制衡中国的意向，这次马科斯访日，双方讨论了多项在军事上合作事项。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260601-%E4%B8%BA%E6%8A%97%E8%A1%A1%E4%B8%AD%E5%9B%BD-%E6%97%A5%E6%9C%AC%E5%92%8C%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%B0%86%E5%B1%95%E5%BC%80%E5%93%AA%E4%BA%9B%E5%86%9B%E4%BA%8B%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780324386000.webp","sourceId":"rfi"},{"id":1780324379000,"createdDate":"2026-06-01 14:32","name":"法国国际广播电台","title":"越南和菲律宾提升为增强型战略伙伴关系 小马科斯：南海和平稳定及航行飞越自由不容谈判","content":"菲律宾和越南周一续签了防务合作协议，加强了在海事安全、军事教育和灾害应对等领域的合作，并将两国关系提升为增强型战略伙伴关系。菲律宾总统小马科斯（FerdinandMarcosJr.）和到访的越共中央总书记、国家主席苏林在马拉坎南宫见证了菲越两国国防部签署谅解备忘录。此前，双方举行了双边会谈。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260601-%E8%B6%8A%E5%8D%97%E5%92%8C%E8%8F%B2%E5%BE%8B%E5%AE%BE%E6%8F%90%E5%8D%87%E4%B8%BA%E5%A2%9E%E5%BC%BA%E5%9E%8B%E6%88%98%E7%95%A5%E4%BC%99%E4%BC%B4%E5%85%B3%E7%B3%BB-%E5%B0%8F%E9%A9%AC%E7%A7%91%E6%96%AF-%E5%8D%97%E6%B5%B7%E5%92%8C%E5%B9%B3%E7%A8%B3%E5%AE%9A%E5%8F%8A%E8%88%AA%E8%A1%8C%E9%A3%9E%E8%B6%8A%E8%87%AA%E7%94%B1%E4%B8%8D%E5%AE%B9%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780324379000.webp","sourceId":"rfi"},{"id":1780324186000,"createdDate":"2026-06-01 14:29","name":"法国国际广播电台","title":"今年发生厄尔尼诺现象的可能性有多大？会是“超级”的吗？","content":"科学家们最近曾警告称，气候变化导致今年非洲、亚洲及其他地区发生破纪录的火灾，随着北半球夏季临近和可能的厄尔尼诺（ElNiño）现象发生，预计情况将进一步恶化。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260601-%E4%BB%8A%E5%B9%B4%E5%8F%91%E7%94%9F%E5%8E%84%E5%B0%94%E5%B0%BC%E8%AF%BA%E7%8E%B0%E8%B1%A1%E7%9A%84%E5%8F%AF%E8%83%BD%E6%80%A7%E6%9C%89%E5%A4%9A%E5%A4%A7-%E4%BC%9A%E6%98%AF-%E8%B6%85%E7%BA%A7-%E7%9A%84%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780324186000.webp","sourceId":"rfi"},{"id":1780324003000,"createdDate":"2026-06-01 14:26","name":"法国国际广播电台","title":"经合组织 :中国对特定工业产业巨额补贴改变全球经济格局","content":"经合组织OCDE今天推出最新报告指出，过去二十年来中国对特定工业产业如太阳能电池板和汽车制造商等提供巨额公共财政补贴，这改变了全球经济格局。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260601-%E7%BB%8F%E5%90%88%E7%BB%84%E7%BB%87-%E4%B8%AD%E5%9B%BD%E5%AF%B9%E7%89%B9%E5%AE%9A%E5%B7%A5%E4%B8%9A%E4%BA%A7%E4%B8%9A%E5%B7%A8%E9%A2%9D%E8%A1%A5%E8%B4%B4%E6%94%B9%E5%8F%98%E5%85%A8%E7%90%83%E7%BB%8F%E6%B5%8E%E6%A0%BC%E5%B1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780324003000.webp","sourceId":"rfi"},{"id":1780322915000,"createdDate":"2026-06-01 14:08","name":"法国国际广播电台","title":"法国阵风战斗机即将与中国超音速导弹一同部署 为何塞尔维亚是欧洲唯一购买中国武器的国家？引发欧盟紧张关系","content":"各位听众，法国的阵风战斗机即将与中国超音速导弹一同部署：为何塞尔维亚是欧洲唯一购买中国武器的国家？甚至引发了欧盟内部及其邻国之间的紧张关系！塞尔维亚总统亚历山大·武契奇（AleksandarVučić）访问了中国。近年来，塞尔维亚从中国购买的武器数量不断增加，这在欧洲是一种“独特的情况”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260601-%E6%B3%95%E5%9B%BD%E9%98%B5%E9%A3%8E%E6%88%98%E6%96%97%E6%9C%BA%E5%8D%B3%E5%B0%86%E4%B8%8E%E4%B8%AD%E5%9B%BD%E8%B6%85%E9%9F%B3%E9%80%9F%E5%AF%BC%E5%BC%B9%E4%B8%80%E5%90%8C%E9%83%A8%E7%BD%B2-%E4%B8%BA%E4%BD%95%E5%A1%9E%E5%B0%94%E7%BB%B4%E4%BA%9A%E6%98%AF%E6%AC%A7%E6%B4%B2%E5%94%AF%E4%B8%80%E8%B4%AD%E4%B9%B0%E4%B8%AD%E5%9B%BD%E6%AD%A6%E5%99%A8%E7%9A%84%E5%9B%BD%E5%AE%B6-%E5%BC%95%E5%8F%91%E6%AC%A7%E7%9B%9F%E7%B4%A7%E5%BC%A0%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780322915000.webp","sourceId":"rfi"},{"id":1780321581000,"createdDate":"2026-06-01 13:46","name":"法国国际广播电台","title":"北京对日方推进同北约合作表示严重关切 北约：欧洲-大西洋和印太安全挑战密切相关","content":"日本防卫省、自卫队首次向北约对乌克兰安全援助和训练机构派遣4名自卫官。对此，中国外交部发言人林剑周一在例行记者会上表示，“我们对日方推进同北约合作的动向表示严重关切”。同日，北约发言人哈特（AllisonHart）通过社媒平台X指出，“这再次宝贵地展现了日本与北约的长期伙伴关系以及我们在支持乌克兰方面开展的共同努力”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260601-%E5%8C%97%E4%BA%AC%E5%AF%B9%E6%97%A5%E6%96%B9%E6%8E%A8%E8%BF%9B%E5%90%8C%E5%8C%97%E7%BA%A6%E5%90%88%E4%BD%9C%E8%A1%A8%E7%A4%BA%E4%B8%A5%E9%87%8D%E5%85%B3%E5%88%87-%E5%8C%97%E7%BA%A6-%E6%AC%A7%E6%B4%B2-%E5%A4%A7%E8%A5%BF%E6%B4%8B%E5%92%8C%E5%8D%B0%E5%A4%AA%E5%AE%89%E5%85%A8%E6%8C%91%E6%88%98%E5%AF%86%E5%88%87%E7%9B%B8%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780321581000.webp","sourceId":"rfi"},{"id":1780318302000,"createdDate":"2026-06-01 12:51","name":"法国国际广播电台","title":"消息人士：在已有诸多外交安排下 习近平月初访朝可能性不大","content":"有观察人士指出，考虑到中国当局已安排的外交行程，中国国家主席习近平6月初对朝鲜的访问似乎不太可能易进行，这与之前的预期相反。此前，有报道称，习近平很可能在5月底或6月初访问朝鲜。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260601-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB-%E5%9C%A8%E5%B7%B2%E6%9C%89%E8%AF%B8%E5%A4%9A%E5%A4%96%E4%BA%A4%E5%AE%89%E6%8E%92%E4%B8%8B-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%9C%88%E5%88%9D%E8%AE%BF%E6%9C%9D%E5%8F%AF%E8%83%BD%E6%80%A7%E4%B8%8D%E5%A4%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780318302000.webp","sourceId":"rfi"},{"id":1780315176000,"createdDate":"2026-06-01 11:59","name":"法国国际广播电台","title":"国际工会联合会最新报告：全球劳动者权益面对系统性危机","content":"国际工会联合会6月1日在巴黎公布2026全球各国劳动者权益状况评估报告，认为劳动者权益在世界各地都呈现恶化，包括在像法国或美国这些民主国家，这意味着劳动者权益正面对一场系统性的危机，工会运动面对越来越大的挑战。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260601-%E5%9B%BD%E9%99%85%E5%B7%A5%E4%BC%9A%E8%81%94%E5%90%88%E4%BC%9A%E6%9C%80%E6%96%B0%E6%8A%A5%E5%91%8A%E7%A7%B0%EF%BC%8C%E5%85%A8%E7%90%83%E5%8A%B3%E5%8A%A8%E8%80%85%E6%9D%83%E7%9B%8A%E9%9D%A2%E5%AF%B9%E7%B3%BB%E7%BB%9F%E6%80%A7%E5%8D%B1%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780315176000.webp","sourceId":"rfi"},{"id":1780314302000,"createdDate":"2026-06-01 11:45","name":"法国国际广播电台","title":"选择法国第九届商业峰会  外国投资创纪录","content":"法国总统马克龙今天主持第九届也是在其任内最后一次选择法国商业峰会(ChooseFrance)开幕式，数百位外国顶级商业领袖齐聚凡尔赛，宣布主要集中在法国工业领域的投资，目前人工智能和低碳产业仍然是最大投资项目。去年投资总额达200亿欧元，今年已经宣布71个国际投资项目，总价值达930亿欧元。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E7%BB%8F%E6%B5%8E/20260601-%E9%80%89%E6%8B%A9%E6%B3%95%E5%9B%BD%E7%AC%AC%E4%B9%9D%E5%B1%8A%E5%95%86%E4%B8%9A%E5%B3%B0%E4%BC%9A-%E5%A4%96%E5%9B%BD%E6%8A%95%E8%B5%84%E4%B8%8D%E5%86%8D%E6%98%AF%E7%A6%81%E5%BF%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780314302000.webp","sourceId":"rfi"},{"id":1780314294000,"createdDate":"2026-06-01 11:44","name":"法国国际广播电台","title":"中国科学院院士周成虎官宣被查","content":"中央纪委国家监委网站周一发布消息指，据中央纪委国家监委驻中国科学院纪检监察组、湖南省纪委监委消息：中国科学院地理科学与资源研究所原副所长周成虎涉嫌严重职务违法，目前正接受中央纪委国家监委驻中国科学院纪检监察组和湖南省郴州市监察委员会监察调查。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260601-%E4%B8%AD%E5%9B%BD%E7%A7%91%E5%AD%A6%E9%99%A2%E9%99%A2%E5%A3%AB%E5%91%A8%E6%88%90%E8%99%8E%E5%AE%98%E5%AE%A3%E8%A2%AB%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780314294000.webp","sourceId":"rfi"},{"id":1780313797000,"createdDate":"2026-06-01 11:36","name":"法国国际广播电台","title":"俄罗斯幽灵舰队：法国在大西洋再次拦截一艘油轮","content":"法国总统马克龙周一宣布，法国海军周日（5月31日）在大西洋公海开展行动，在“包括英国在内的多个伙伴的支持下”，再次拦截了一艘来自俄罗斯的油轮。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260601-%E4%BF%84%E7%BD%97%E6%96%AF%E5%B9%BD%E7%81%B5%E8%88%B0%E9%98%9F-%E6%B3%95%E5%9B%BD%E5%9C%A8%E5%A4%A7%E8%A5%BF%E6%B4%8B%E5%86%8D%E6%AC%A1%E6%8B%A6%E6%88%AA%E4%B8%80%E8%89%98%E6%B2%B9%E8%BD%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780313797000.webp","sourceId":"rfi"},{"id":1780311626000,"createdDate":"2026-06-01 11:00","name":"法国国际广播电台","title":"台湾半导体经济起飞传今年GDP成长率可能接近10% 但却存在「乞丐超人」年轻世代经济困境现象","content":"韩媒《东亚日报》刊登「台湾病与乞丐超人」文章，在台湾引起热论。探讨台湾经济随AI及半导体热潮起飞，看似风光却出现贫富不均问题。薪资停滞加上居住成本高涨，台湾开始出现「乞丐超人」现象。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260601-%E5%8F%B0%E6%B9%BE%E5%8D%8A%E5%AF%BC%E4%BD%93%E7%BB%8F%E6%B5%8E%E8%B5%B7%E9%A3%9E%E4%BC%A0%E4%BB%8A%E5%B9%B4gdp%E6%88%90%E9%95%BF%E7%8E%87%E5%8F%AF%E8%83%BD%E6%8E%A5%E8%BF%9110-%E4%BD%86%E5%8D%B4%E5%AD%98%E5%9C%A8-%E4%B9%9E%E4%B8%90%E8%B6%85%E4%BA%BA-%E5%B9%B4%E8%BD%BB%E4%B8%96%E4%BB%A3%E7%BB%8F%E6%B5%8E%E5%9B%B0%E5%A2%83%E7%8E%B0%E8%B1%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780311626000.webp","sourceId":"rfi"},{"id":1780310659000,"createdDate":"2026-06-01 10:44","name":"法国国际广播电台","title":"日本官房长官针对美防长要求盟国增加军费表示：日本将自己做主","content":"日本内阁官房长官木原稔在日本时间6月1日上午的记者会上，就美国国防部长赫格塞斯于5月30日在新加坡举行的香格里拉对话会上发表演讲时表示期待亚洲盟国将国防开支提高至国内生产总值（GDP）的3.5%一事回应称：日本将自己做主。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260601-%E6%97%A5%E6%9C%AC%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E9%92%88%E5%AF%B9%E7%BE%8E%E9%98%B2%E9%95%BF%E8%A6%81%E6%B1%82%E7%9B%9F%E5%9B%BD%E5%A2%9E%E5%8A%A0%E5%86%9B%E8%B4%B9%E8%A1%A8%E7%A4%BA-%E6%97%A5%E6%9C%AC%E5%B0%86%E8%87%AA%E5%B7%B1%E5%81%9A%E4%B8%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780310659000.webp","sourceId":"rfi"},{"id":1780310048000,"createdDate":"2026-06-01 10:34","name":"法国国际广播电台","title":"中国公布《国务院关于对外投资的规定》 7月1日起施行","content":"周一，中国出台新规，旨在加强对涉及中国投资者、技术、数据和国家安全的海外交易的管控。此前，4月27日，国家发展改革委对脸书母公司Meta收购人工智能初创公司Manus项目作出禁止投资决定，要求当事人撤销该收购交易。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260601-%E4%B8%AD%E5%9B%BD%E5%85%AC%E5%B8%83-%E5%9B%BD%E5%8A%A1%E9%99%A2%E5%85%B3%E4%BA%8E%E5%AF%B9%E5%A4%96%E6%8A%95%E8%B5%84%E7%9A%84%E8%A7%84%E5%AE%9A-7%E6%9C%881%E6%97%A5%E8%B5%B7%E6%96%BD%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/01/1780310048000.webp","sourceId":"rfi"}]