[{"id":1780912046000,"createdDate":"2026-06-08 09:47","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第24:浪漫主义群星之六:阿尼姆与布伦塔诺:男童的神奇魔号","content":"在德国浪漫主义滥觞之时，赫尔德就大力倡导发掘德意志民歌资源，他深信一旦打开那些流传于德意志乡村、集鎭、山林、田野中的民谣宝库，人们就能认识到真正的德意志精神。这个理想终于在阿尼姆和布伦塔诺的手中实现了。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260608-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E5%85%AD-%E9%98%BF%E5%B0%BC%E5%A7%86%E4%B8%8E%E5%B8%83%E4%BC%A6%E5%A1%94%E8%AF%BA-%E7%94%B7%E7%AB%A5%E7%9A%84%E7%A5%9E%E5%A5%87%E9%AD%94%E5%8F%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780912046000.webp","sourceId":"rfi"},{"id":1780911538000,"createdDate":"2026-06-08 09:38","name":"法国国际广播电台","title":"澳门拘犯罪组织12人 副警察局长在列  涉亚洲及东欧女子卖淫","content":"澳门警方破获一宗以桑拿场作掩护的操控卖淫犯罪集团案件中发现，在拘捕的26人中，有五名现役和退休的警务人员，当中包括拥有决策权力的现任治安警察局副局长梁庆康，以及一名现役处长和前线警员。这三人连同两名港人等一共12人，被控涉嫌触犯「黑社会的罪」和「受贿作不法行为罪」等四项罪名，正被羁押候审。馀下14人则被采取其他法定强制措施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E6%BE%B3%E9%97%A8%E6%8B%98%E7%8A%AF%E7%BD%AA%E7%BB%84%E7%BB%8712%E4%BA%BA-%E5%89%AF%E8%AD%A6%E5%AF%9F%E5%B1%80%E9%95%BF%E5%9C%A8%E5%88%97-%E6%B6%89%E4%BA%9A%E6%B4%B2%E5%8F%8A%E4%B8%9C%E6%AC%A7%E5%A5%B3%E5%AD%90%E5%8D%96%E6%B7%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780911538000.webp","sourceId":"rfi"},{"id":1780911178000,"createdDate":"2026-06-08 09:32","name":"法国国际广播电台","title":"习近平访朝 日本表示高度关注并持续收集信息","content":"中国国家主席习近平8日乘坐专机离开北京，对朝鲜进行国事访问。此次是习近平自2019年以来、时隔7年再次访问朝鲜。预计双方将围绕加强中朝关系、两国在东北亚的合作方案、对应美国和日本等问题展开集中讨论。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%BF%E6%9C%9D-%E6%97%A5%E6%9C%AC%E8%A1%A8%E7%A4%BA%E9%AB%98%E5%BA%A6%E5%85%B3%E6%B3%A8%E5%B9%B6%E6%8C%81%E7%BB%AD%E6%94%B6%E9%9B%86%E4%BF%A1%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780911178000.webp","sourceId":"rfi"},{"id":1780910767000,"createdDate":"2026-06-08 09:26","name":"法国国际广播电台","title":"郑丽文访美称两岸同属一中不会永久分裂 民进党批评其自甘堕落成习近平特使","content":"国民党主席郑丽文访美期间再度提及，九二共识、反对台独与两岸同属一中等言论。更被质疑与中共统战部旗下官员聚餐交换资讯。民进党批，台湾国会最大党党主席，已经自甘堕落为习近平特使。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E9%83%91%E4%B8%BD%E6%96%87%E8%AE%BF%E7%BE%8E%E7%A7%B0%E4%B8%A4%E5%B2%B8%E5%90%8C%E5%B1%9E%E4%B8%80%E4%B8%AD%E4%B8%8D%E4%BC%9A%E6%B0%B8%E4%B9%85%E5%88%86%E8%A3%82-%E6%B0%91%E8%BF%9B%E5%85%9A%E6%89%B9%E8%AF%84%E5%85%B6%E8%87%AA%E7%94%98%E5%A0%95%E8%90%BD%E6%88%90%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%89%B9%E4%BD%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780910767000.webp","sourceId":"rfi"},{"id":1780910428000,"createdDate":"2026-06-08 09:20","name":"法国国际广播电台","title":"习近平时隔七年再访朝鲜：要加强战略沟通和协调配合","content":"当地时间周一中午，中国国家主席习近平乘专机抵达平壤，开始对朝鲜进行国事访问。朝鲜最高领导人金正恩携夫人李雪主到机场迎接。习近平和夫人彭丽媛步出舱门，走下舷梯，与金正恩握手。习近平此次为期两天的访问是他七年来首次访问朝鲜，预计将与金正恩举行峰会。这将是自​​去年9月以来，两人在北京与俄罗斯总统普京等外国领导人一同观看九三阅兵式及举行双边会谈后首次会面。蔡奇、王毅等陪同人员同机抵达。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260608-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%97%B6%E9%9A%94%E4%B8%83%E5%B9%B4%E5%86%8D%E8%AE%BF%E6%9C%9D%E9%B2%9C-%E8%A6%81%E5%8A%A0%E5%BC%BA%E6%88%98%E7%95%A5%E6%B2%9F%E9%80%9A%E5%92%8C%E5%8D%8F%E8%B0%83%E9%85%8D%E5%90%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780910428000.webp","sourceId":"rfi"},{"id":1780910405000,"createdDate":"2026-06-08 09:20","name":"法国国际广播电台","title":"香港国安法加码：特首可将任何罪行订为国安罪行 限制人权程序随之适用","content":"香港政府将进一步扩大被指侵害人权的国安法例的管辖和适用范围，拟议中的《维护国家安全条例》附属法例订明，即使相关行为不是法例订明的国安罪行，但只要行政长官(又称特首)就某些涉及国家安全的刑事罪行发出证明书，则相关案件便属于国安案件，当局可以国安法例的规定去处理相关案件的侦查丶拘捕丶检控及审讯程序。香港人权资讯中心发言人指出，新修订赋予特首无上权力去把香港任何罪行订为国安罪行，已受侵蚀的香港人权和司法独立势将进一步被弱化。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E9%A6%99%E6%B8%AF%E5%9B%BD%E5%AE%89%E6%B3%95%E5%8A%A0%E7%A0%81-%E7%89%B9%E9%A6%96%E5%8F%AF%E5%B0%86%E4%BB%BB%E4%BD%95%E7%BD%AA%E8%A1%8C%E8%AE%A2%E4%B8%BA%E5%9B%BD%E5%AE%89%E7%BD%AA%E8%A1%8C-%E9%99%90%E5%88%B6%E4%BA%BA%E6%9D%83%E7%A8%8B%E5%BA%8F%E9%9A%8F%E4%B9%8B%E9%80%82%E7%94%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780910405000.webp","sourceId":"rfi"},{"id":1780907122000,"createdDate":"2026-06-08 08:25","name":"法国国际广播电台","title":"中国宣布在台湾东部海域执法 台湾称其为“挑衅”和“认知战”","content":"台湾周一（6月8日）对中国宣布在台湾东部海域开展“海上交通专项执法行动”表示，这是“挑衅行为”和认知战，是经过伪装的扩张主义，威胁地区的和平与稳定。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260608-%E4%B8%AD%E5%9B%BD%E5%9C%A8%E5%8F%B0%E6%B9%BE%E4%B8%9C%E9%83%A8%E6%B5%B7%E5%9F%9F%E6%89%A7%E6%B3%95-%E5%8F%B0%E6%B9%BE%E7%A7%B0%E5%85%B6%E4%B8%BA-%E6%8C%91%E8%A1%85-%E5%92%8C-%E8%AE%A4%E7%9F%A5%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780907122000.webp","sourceId":"rfi"}]