[{"id":1780912046000,"createdDate":"2026-06-08 09:47","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第24:浪漫主义群星之六:阿尼姆与布伦塔诺:男童的神奇魔号","content":"在德国浪漫主义滥觞之时，赫尔德就大力倡导发掘德意志民歌资源，他深信一旦打开那些流传于德意志乡村、集鎭、山林、田野中的民谣宝库，人们就能认识到真正的德意志精神。这个理想终于在阿尼姆和布伦塔诺的手中实现了。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260608-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E5%85%AD-%E9%98%BF%E5%B0%BC%E5%A7%86%E4%B8%8E%E5%B8%83%E4%BC%A6%E5%A1%94%E8%AF%BA-%E7%94%B7%E7%AB%A5%E7%9A%84%E7%A5%9E%E5%A5%87%E9%AD%94%E5%8F%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780912046000.webp","sourceId":"rfi"},{"id":1780911538000,"createdDate":"2026-06-08 09:38","name":"法国国际广播电台","title":"澳门拘犯罪组织12人 副警察局长在列  涉亚洲及东欧女子卖淫","content":"澳门警方破获一宗以桑拿场作掩护的操控卖淫犯罪集团案件中发现，在拘捕的26人中，有五名现役和退休的警务人员，当中包括拥有决策权力的现任治安警察局副局长梁庆康，以及一名现役处长和前线警员。这三人连同两名港人等一共12人，被控涉嫌触犯「黑社会的罪」和「受贿作不法行为罪」等四项罪名，正被羁押候审。馀下14人则被采取其他法定强制措施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E6%BE%B3%E9%97%A8%E6%8B%98%E7%8A%AF%E7%BD%AA%E7%BB%84%E7%BB%8712%E4%BA%BA-%E5%89%AF%E8%AD%A6%E5%AF%9F%E5%B1%80%E9%95%BF%E5%9C%A8%E5%88%97-%E6%B6%89%E4%BA%9A%E6%B4%B2%E5%8F%8A%E4%B8%9C%E6%AC%A7%E5%A5%B3%E5%AD%90%E5%8D%96%E6%B7%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780911538000.webp","sourceId":"rfi"},{"id":1780911178000,"createdDate":"2026-06-08 09:32","name":"法国国际广播电台","title":"习近平访朝 日本表示高度关注并持续收集信息","content":"中国国家主席习近平8日乘坐专机离开北京，对朝鲜进行国事访问。此次是习近平自2019年以来、时隔7年再次访问朝鲜。预计双方将围绕加强中朝关系、两国在东北亚的合作方案、对应美国和日本等问题展开集中讨论。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%BF%E6%9C%9D-%E6%97%A5%E6%9C%AC%E8%A1%A8%E7%A4%BA%E9%AB%98%E5%BA%A6%E5%85%B3%E6%B3%A8%E5%B9%B6%E6%8C%81%E7%BB%AD%E6%94%B6%E9%9B%86%E4%BF%A1%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780911178000.webp","sourceId":"rfi"},{"id":1780910767000,"createdDate":"2026-06-08 09:26","name":"法国国际广播电台","title":"郑丽文访美称两岸同属一中不会永久分裂 民进党批评其自甘堕落成习近平特使","content":"国民党主席郑丽文访美期间再度提及，九二共识、反对台独与两岸同属一中等言论。更被质疑与中共统战部旗下官员聚餐交换资讯。民进党批，台湾国会最大党党主席，已经自甘堕落为习近平特使。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E9%83%91%E4%B8%BD%E6%96%87%E8%AE%BF%E7%BE%8E%E7%A7%B0%E4%B8%A4%E5%B2%B8%E5%90%8C%E5%B1%9E%E4%B8%80%E4%B8%AD%E4%B8%8D%E4%BC%9A%E6%B0%B8%E4%B9%85%E5%88%86%E8%A3%82-%E6%B0%91%E8%BF%9B%E5%85%9A%E6%89%B9%E8%AF%84%E5%85%B6%E8%87%AA%E7%94%98%E5%A0%95%E8%90%BD%E6%88%90%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%89%B9%E4%BD%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780910767000.webp","sourceId":"rfi"},{"id":1780910428000,"createdDate":"2026-06-08 09:20","name":"法国国际广播电台","title":"习近平时隔七年再访朝鲜：要加强战略沟通和协调配合","content":"当地时间周一中午，中国国家主席习近平乘专机抵达平壤，开始对朝鲜进行国事访问。朝鲜最高领导人金正恩携夫人李雪主到机场迎接。习近平和夫人彭丽媛步出舱门，走下舷梯，与金正恩握手。习近平此次为期两天的访问是他七年来首次访问朝鲜，预计将与金正恩举行峰会。这将是自​​去年9月以来，两人在北京与俄罗斯总统普京等外国领导人一同观看九三阅兵式及举行双边会谈后首次会面。蔡奇、王毅等陪同人员同机抵达。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260608-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%97%B6%E9%9A%94%E4%B8%83%E5%B9%B4%E5%86%8D%E8%AE%BF%E6%9C%9D%E9%B2%9C-%E8%A6%81%E5%8A%A0%E5%BC%BA%E6%88%98%E7%95%A5%E6%B2%9F%E9%80%9A%E5%92%8C%E5%8D%8F%E8%B0%83%E9%85%8D%E5%90%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780910428000.webp","sourceId":"rfi"},{"id":1780910405000,"createdDate":"2026-06-08 09:20","name":"法国国际广播电台","title":"香港国安法加码：特首可将任何罪行订为国安罪行 限制人权程序随之适用","content":"香港政府将进一步扩大被指侵害人权的国安法例的管辖和适用范围，拟议中的《维护国家安全条例》附属法例订明，即使相关行为不是法例订明的国安罪行，但只要行政长官(又称特首)就某些涉及国家安全的刑事罪行发出证明书，则相关案件便属于国安案件，当局可以国安法例的规定去处理相关案件的侦查丶拘捕丶检控及审讯程序。香港人权资讯中心发言人指出，新修订赋予特首无上权力去把香港任何罪行订为国安罪行，已受侵蚀的香港人权和司法独立势将进一步被弱化。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E9%A6%99%E6%B8%AF%E5%9B%BD%E5%AE%89%E6%B3%95%E5%8A%A0%E7%A0%81-%E7%89%B9%E9%A6%96%E5%8F%AF%E5%B0%86%E4%BB%BB%E4%BD%95%E7%BD%AA%E8%A1%8C%E8%AE%A2%E4%B8%BA%E5%9B%BD%E5%AE%89%E7%BD%AA%E8%A1%8C-%E9%99%90%E5%88%B6%E4%BA%BA%E6%9D%83%E7%A8%8B%E5%BA%8F%E9%9A%8F%E4%B9%8B%E9%80%82%E7%94%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780910405000.webp","sourceId":"rfi"},{"id":1780907122000,"createdDate":"2026-06-08 08:25","name":"法国国际广播电台","title":"中国宣布在台湾东部海域执法 台湾称其为“挑衅”和“认知战”","content":"台湾周一（6月8日）对中国宣布在台湾东部海域开展“海上交通专项执法行动”表示，这是“挑衅行为”和认知战，是经过伪装的扩张主义，威胁地区的和平与稳定。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260608-%E4%B8%AD%E5%9B%BD%E5%9C%A8%E5%8F%B0%E6%B9%BE%E4%B8%9C%E9%83%A8%E6%B5%B7%E5%9F%9F%E6%89%A7%E6%B3%95-%E5%8F%B0%E6%B9%BE%E7%A7%B0%E5%85%B6%E4%B8%BA-%E6%8C%91%E8%A1%85-%E5%92%8C-%E8%AE%A4%E7%9F%A5%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780907122000.webp","sourceId":"rfi"},{"id":1780934729000,"createdDate":"2026-06-08 16:05","name":"法国国际广播电台","title":"哈梅内伊遇袭身亡后 俄安全部门据报彻查、隔离普京摄像头","content":"据英国《金融时报》援引两位知情人士报导称，在伊朗前最高领袖哈梅内伊于德黑兰遇袭身亡后，俄罗斯安全部门关闭了部分用于保护总统普京及其最亲密助手的特殊监控系统。其中一位知情人士表示，该系统独立于近30万个监控莫斯科市民的摄像头之外，在工程师彻底检查并试图将其与互联网完全隔离后才重新启动。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260608-%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E9%81%87%E8%A2%AD%E8%BA%AB%E4%BA%A1%E5%90%8E-%E4%BF%84%E5%AE%89%E5%85%A8%E9%83%A8%E9%97%A8%E6%8D%AE%E6%8A%A5%E5%BD%BB%E6%9F%A5-%E9%9A%94%E7%A6%BB%E6%99%AE%E4%BA%AC%E6%91%84%E5%83%8F%E5%A4%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780934729000.webp","sourceId":"rfi"},{"id":1780933775000,"createdDate":"2026-06-08 15:49","name":"法国国际广播电台","title":"安琪巴黎「自由谈」沙龙纪要与述评：艺术自由与存在者的存在 ――法、德、中、台艺术家跨疆域探讨","content":"在人工智能制造的信息洪流中，艺术何为？当算法日益渗透人类的感知与表达，艺术家如何守住意识的自主，安放灵魂的“本在”？这不是一个抽象的哲学追问，而是每一个创作者当下必须直面的现实处境。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260608-%E5%AE%89%E7%90%AA%E5%B7%B4%E9%BB%8E-%E8%87%AA%E7%94%B1%E8%B0%88-%E6%B2%99%E9%BE%99%E7%BA%AA%E8%A6%81%E4%B8%8E%E8%BF%B0%E8%AF%84-%E8%89%BA%E6%9C%AF%E8%87%AA%E7%94%B1%E4%B8%8E%E5%AD%98%E5%9C%A8%E8%80%85%E7%9A%84%E5%AD%98%E5%9C%A8-%E2%80%95%E2%80%95%E6%B3%95-%E5%BE%B7-%E4%B8%AD-%E5%8F%B0%E8%89%BA%E6%9C%AF%E5%AE%B6%E8%B7%A8%E7%96%86%E5%9F%9F%E6%8E%A2%E8%AE%A8","thumbnail":"","detailImage":"","sourceId":"rfi"},{"id":1780933211000,"createdDate":"2026-06-08 15:40","name":"法国国际广播电台","title":"教皇良十四世为何前往西班牙？此行的意义何在？","content":"各位听众，本次教皇良十四世访问西班牙的行程安排为2026年6月6日至12日，前往马德里、巴塞罗那和加那利群岛。本次罗马教皇访问西班牙距离上次已15年。此次教皇对于这个西欧重要天主教国家的国事访问将融合民间风情、政治事件、基督教历史以及移民问题。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260608-%E6%95%99%E7%9A%87%E8%89%AF%E5%8D%81%E5%9B%9B%E4%B8%96%E4%B8%BA%E4%BD%95%E5%89%8D%E5%BE%80%E8%A5%BF%E7%8F%AD%E7%89%99-%E6%AD%A4%E8%A1%8C%E7%9A%84%E6%84%8F%E4%B9%89%E4%BD%95%E5%9C%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780933211000.webp","sourceId":"rfi"},{"id":1780932677000,"createdDate":"2026-06-08 15:31","name":"法国国际广播电台","title":"北约下令 法战机在拉脱维亚领空击落一架从俄罗斯进入的无人机","content":"周一，一架法国“阵风”战斗机击落了一架从俄罗斯进入北约成员国拉脱维亚领空的无人机。这是近期欧洲东部边境地区发生的一系列类似安全事件中的最新一起。拉脱维亚军方并未透露该无人机的发射方，仅表示涉事无人机是从俄罗斯“通过俄方电磁战”入侵的。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260608-%E5%8C%97%E7%BA%A6%E4%B8%8B%E4%BB%A4-%E6%B3%95%E6%88%98%E6%9C%BA%E5%9C%A8%E6%8B%89%E8%84%B1%E7%BB%B4%E4%BA%9A%E9%A2%86%E7%A9%BA%E5%87%BB%E8%90%BD%E4%B8%80%E6%9E%B6%E4%BB%8E%E4%BF%84%E7%BD%97%E6%96%AF%E8%BF%9B%E5%85%A5%E7%9A%84%E6%97%A0%E4%BA%BA%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780932677000.webp","sourceId":"rfi"},{"id":1780931481000,"createdDate":"2026-06-08 15:11","name":"法国国际广播电台","title":"日防相拟12日访问雅加达会见印尼防长 探讨朝雾级护卫舰出口事宜","content":"据共同社援引消息人士报导，日本防卫大臣小泉进次郎正安排于12日访问印尼首都雅加达，与印尼国防部长夏弗里（SjafrieSjamsoeddin）会面。预计此次会晤将讨论向印尼军方出口日本海上自卫队“朝雾”级护卫舰的事宜。他还将安排礼节性拜会印尼总统普拉博沃，并计划于13日返日。最终决定将在考虑日本国会日程后尽快作出。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260608-%E6%97%A5%E9%98%B2%E7%9B%B8%E6%8B%9F12%E6%97%A5%E8%AE%BF%E9%97%AE%E9%9B%85%E5%8A%A0%E8%BE%BE%E4%BC%9A%E8%A7%81%E5%8D%B0%E5%B0%BC%E9%98%B2%E9%95%BF-%E6%8E%A2%E8%AE%A8%E6%9C%9D%E9%9B%BE%E7%BA%A7%E6%8A%A4%E5%8D%AB%E8%88%B0%E5%87%BA%E5%8F%A3%E4%BA%8B%E5%AE%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780931481000.webp","sourceId":"rfi"},{"id":1780931164000,"createdDate":"2026-06-08 15:06","name":"法国国际广播电台","title":"伊朗战争爆发100天：德黑兰人怎么说？","content":"美国和以色列军队于2月28日开始对伊朗发动空袭。在战争爆发100天之际，德黑兰居民于周日（6月7日）表达了既坚韧又不安的复杂情绪。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260608-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E7%88%86%E5%8F%91100%E5%A4%A9-%E5%BE%B7%E9%BB%91%E5%85%B0%E4%BA%BA%E6%80%8E%E4%B9%88%E8%AF%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780931164000.webp","sourceId":"rfi"},{"id":1780929093000,"createdDate":"2026-06-08 14:31","name":"法国国际广播电台","title":"韩国警方：没有外国警察或假警察 李在明：未能保障投票权是严重事件","content":"韩国警方周一公开呼吁民众停止对被派往投票站和计票站的警员进行猜测和诽谤，此前因6月3日地方选举选票短缺而引发了此类事件。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260608-%E9%9F%A9%E5%9B%BD%E8%AD%A6%E6%96%B9-%E6%B2%A1%E6%9C%89%E5%A4%96%E5%9B%BD%E8%AD%A6%E5%AF%9F%E6%88%96%E5%81%87%E8%AD%A6%E5%AF%9F-%E6%9D%8E%E5%9C%A8%E6%98%8E-%E6%9C%AA%E8%83%BD%E4%BF%9D%E9%9A%9C%E6%8A%95%E7%A5%A8%E6%9D%83%E6%98%AF%E4%B8%A5%E9%87%8D%E4%BA%8B%E4%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780929093000.webp","sourceId":"rfi"},{"id":1780927485000,"createdDate":"2026-06-08 14:04","name":"法国国际广播电台","title":"习近平时隔七年访问朝鲜，中朝关系站上“历史新起点”","content":"2026年6月8日，中国国家主席习近平抵达朝鲜首都平壤，开始对朝鲜进行为期两天的国事访问，并将与朝鲜劳动党总书记、国务委员长金正恩举行会谈。这是习近平今年首次出访，也是他七年来首次访问朝鲜。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260608-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%97%B6%E9%9A%94%E4%B8%83%E5%B9%B4%E8%AE%BF%E9%97%AE%E6%9C%9D%E9%B2%9C%EF%BC%8C%E4%B8%AD%E6%9C%9D%E5%85%B3%E7%B3%BB%E7%AB%99%E4%B8%8A-%E5%8E%86%E5%8F%B2%E6%96%B0%E8%B5%B7%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780927485000.webp","sourceId":"rfi"},{"id":1780926532000,"createdDate":"2026-06-08 13:48","name":"法国国际广播电台","title":"倍耐力股东中企橡胶公司就意大利政府“黄金权力”限制提上诉","content":"意大利轮胎公司倍耐力（Pirelli）周一表示，中国化工橡胶有限公司（CNRC）及其子公司马可波罗国际已分别向意大利一地方行政法院提起上诉，反对意政府对其持有的倍耐力股份附加的限制条件。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260608-%E5%80%8D%E8%80%90%E5%8A%9B%E8%82%A1%E4%B8%9C%E4%B8%AD%E4%BC%81%E6%A9%A1%E8%83%B6%E5%85%AC%E5%8F%B8%E5%B0%B1%E6%84%8F%E5%A4%A7%E5%88%A9%E6%94%BF%E5%BA%9C-%E9%BB%84%E9%87%91%E6%9D%83%E5%8A%9B-%E9%99%90%E5%88%B6%E6%8F%90%E4%B8%8A%E8%AF%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780926532000.webp","sourceId":"rfi"},{"id":1780924565000,"createdDate":"2026-06-08 13:16","name":"法国国际广播电台","title":"美外交官敦促北约盟国动用国防开支来更换华为设备","content":"据彭博社援引知情人士报导称，美国特朗普（DonaldTrump）政府敦促北约盟国将国防开支用于替换其网络和关键基础设施中来自华为的零部件。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260608-%E7%BE%8E%E5%A4%96%E4%BA%A4%E5%AE%98%E4%BF%83%E5%8C%97%E7%BA%A6%E7%9B%9F%E5%9B%BD%E5%8A%A8%E7%94%A8%E5%9B%BD%E9%98%B2%E5%BC%80%E6%94%AF%E6%9D%A5%E6%9B%B4%E6%8D%A2%E5%8D%8E%E4%B8%BA%E8%AE%BE%E5%A4%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780924565000.webp","sourceId":"rfi"},{"id":1780921911000,"createdDate":"2026-06-08 12:31","name":"法国国际广播电台","title":"传富察已出狱 台陆委会：尊重家属意见不进行说明","content":"台湾“八旗文化”出版社总编辑“富察”李延贺被控犯下“煽动分裂国家罪”，遭上海市第一中级人民法院判处有期徒刑3年、剥夺政治权利1年。《自由时报》报导称，据透露，富察已在今年5月出狱，因为仍有附加刑1年，遭中共当局限制出境，无法离开中国大陆回台。对此，据台央广报导，陆委会周一回应表示，为尊重家属意见，不对本案进行说明。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260608-%E4%BC%A0%E5%AF%8C%E5%AF%9F%E5%B7%B2%E5%87%BA%E7%8B%B1-%E5%8F%B0%E9%99%86%E5%A7%94%E4%BC%9A-%E5%B0%8A%E9%87%8D%E5%AE%B6%E5%B1%9E%E6%84%8F%E8%A7%81%E4%B8%8D%E8%BF%9B%E8%A1%8C%E8%AF%B4%E6%98%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780921911000.webp","sourceId":"rfi"},{"id":1780921321000,"createdDate":"2026-06-08 12:22","name":"法国国际广播电台","title":"北京法国文化中心突撤6月所有电影放映场次","content":"北京法国文化中心近日突然取消6月所有电影放映活动。北京微信购票小程序的购票页面和影片详情页面均显示北京法国文化中心放映的法国影片是“商品下架”或“暂无商品”的状态，“同志骄傲月”主题的活动已不可见，多名观众称已经收到退款。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E5%8C%97%E4%BA%AC%E6%B3%95%E5%9B%BD%E6%96%87%E5%8C%96%E4%B8%AD%E5%BF%83%E7%AA%81%E6%92%A46%E6%9C%88%E6%89%80%E6%9C%89%E7%94%B5%E5%BD%B1%E6%94%BE%E6%98%A0%E5%9C%BA%E6%AC%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780921321000.webp","sourceId":"rfi"},{"id":1780916533000,"createdDate":"2026-06-08 11:02","name":"法国国际广播电台","title":"帕希尼扬领导的政党赢得了亚美尼亚议会选举， 欧盟和马克龙祝贺","content":"亚美尼亚总理尼科尔·帕希尼扬领导的政党赢得了议会选举，初步结果于周一公布。帕希尼扬致力于与西方建立更紧密的联系，并使亚美尼亚摆脱其前帝国统治者的影响，这激怒了克里姆林宫。这次选举的胜利被看作是亚美尼亚指控俄罗斯威胁和干预之后选民认可转向亲西方。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260608-%E5%B8%95%E5%B8%8C%E5%B0%BC%E6%89%AC%E9%A2%86%E5%AF%BC%E7%9A%84%E6%94%BF%E5%85%9A%E8%B5%A2%E5%BE%97%E4%BA%86%E4%BA%9A%E7%BE%8E%E5%B0%BC%E4%BA%9A%E8%AE%AE%E4%BC%9A%E9%80%89%E4%B8%BE%EF%BC%8C-%E6%AC%A7%E7%9B%9F%E5%92%8C%E9%A9%AC%E5%85%8B%E9%BE%99%E7%A5%9D%E8%B4%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780916533000.webp","sourceId":"rfi"},{"id":1780914533000,"createdDate":"2026-06-08 10:28","name":"法国国际广播电台","title":"美方据报正考虑从毛里求斯手中购买查戈斯群岛 英政府发言人回应","content":"据《每日电讯报》报导称，美国总统特朗普（DonaldTrump）正在考虑从毛里求斯手中购买查戈斯群岛，而英国放弃该群岛主权的计划目前陷入僵局。白宫尚未回应《卫报》就此潜在计划提出的置评请求。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260608-%E7%BE%8E%E6%96%B9%E6%8D%AE%E6%8A%A5%E6%AD%A3%E8%80%83%E8%99%91%E4%BB%8E%E6%AF%9B%E9%87%8C%E6%B1%82%E6%96%AF%E6%89%8B%E4%B8%AD%E8%B4%AD%E4%B9%B0%E6%9F%A5%E6%88%88%E6%96%AF%E7%BE%A4%E5%B2%9B-%E8%8B%B1%E6%94%BF%E5%BA%9C%E5%8F%91%E8%A8%80%E4%BA%BA%E5%9B%9E%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780914533000.webp","sourceId":"rfi"}]