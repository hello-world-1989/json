[{"id":1780912046000,"createdDate":"2026-06-08 09:47","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第24:浪漫主义群星之六:阿尼姆与布伦塔诺:男童的神奇魔号","content":"在德国浪漫主义滥觞之时，赫尔德就大力倡导发掘德意志民歌资源，他深信一旦打开那些流传于德意志乡村、集鎭、山林、田野中的民谣宝库，人们就能认识到真正的德意志精神。这个理想终于在阿尼姆和布伦塔诺的手中实现了。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260608-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E5%85%AD-%E9%98%BF%E5%B0%BC%E5%A7%86%E4%B8%8E%E5%B8%83%E4%BC%A6%E5%A1%94%E8%AF%BA-%E7%94%B7%E7%AB%A5%E7%9A%84%E7%A5%9E%E5%A5%87%E9%AD%94%E5%8F%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780912046000.webp","sourceId":"rfi"},{"id":1780911538000,"createdDate":"2026-06-08 09:38","name":"法国国际广播电台","title":"澳门拘犯罪组织12人 副警察局长在列  涉亚洲及东欧女子卖淫","content":"澳门警方破获一宗以桑拿场作掩护的操控卖淫犯罪集团案件中发现，在拘捕的26人中，有五名现役和退休的警务人员，当中包括拥有决策权力的现任治安警察局副局长梁庆康，以及一名现役处长和前线警员。这三人连同两名港人等一共12人，被控涉嫌触犯「黑社会的罪」和「受贿作不法行为罪」等四项罪名，正被羁押候审。馀下14人则被采取其他法定强制措施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E6%BE%B3%E9%97%A8%E6%8B%98%E7%8A%AF%E7%BD%AA%E7%BB%84%E7%BB%8712%E4%BA%BA-%E5%89%AF%E8%AD%A6%E5%AF%9F%E5%B1%80%E9%95%BF%E5%9C%A8%E5%88%97-%E6%B6%89%E4%BA%9A%E6%B4%B2%E5%8F%8A%E4%B8%9C%E6%AC%A7%E5%A5%B3%E5%AD%90%E5%8D%96%E6%B7%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780911538000.webp","sourceId":"rfi"},{"id":1780911178000,"createdDate":"2026-06-08 09:32","name":"法国国际广播电台","title":"习近平访朝 日本表示高度关注并持续收集信息","content":"中国国家主席习近平8日乘坐专机离开北京，对朝鲜进行国事访问。此次是习近平自2019年以来、时隔7年再次访问朝鲜。预计双方将围绕加强中朝关系、两国在东北亚的合作方案、对应美国和日本等问题展开集中讨论。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%BF%E6%9C%9D-%E6%97%A5%E6%9C%AC%E8%A1%A8%E7%A4%BA%E9%AB%98%E5%BA%A6%E5%85%B3%E6%B3%A8%E5%B9%B6%E6%8C%81%E7%BB%AD%E6%94%B6%E9%9B%86%E4%BF%A1%E6%81%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780911178000.webp","sourceId":"rfi"},{"id":1780910767000,"createdDate":"2026-06-08 09:26","name":"法国国际广播电台","title":"郑丽文访美称两岸同属一中不会永久分裂 民进党批评其自甘堕落成习近平特使","content":"国民党主席郑丽文访美期间再度提及，九二共识、反对台独与两岸同属一中等言论。更被质疑与中共统战部旗下官员聚餐交换资讯。民进党批，台湾国会最大党党主席，已经自甘堕落为习近平特使。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E9%83%91%E4%B8%BD%E6%96%87%E8%AE%BF%E7%BE%8E%E7%A7%B0%E4%B8%A4%E5%B2%B8%E5%90%8C%E5%B1%9E%E4%B8%80%E4%B8%AD%E4%B8%8D%E4%BC%9A%E6%B0%B8%E4%B9%85%E5%88%86%E8%A3%82-%E6%B0%91%E8%BF%9B%E5%85%9A%E6%89%B9%E8%AF%84%E5%85%B6%E8%87%AA%E7%94%98%E5%A0%95%E8%90%BD%E6%88%90%E4%B9%A0%E8%BF%91%E5%B9%B3%E7%89%B9%E4%BD%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780910767000.webp","sourceId":"rfi"},{"id":1780910428000,"createdDate":"2026-06-08 09:20","name":"法国国际广播电台","title":"习近平时隔七年再访朝鲜：要加强战略沟通和协调配合","content":"当地时间周一中午，中国国家主席习近平乘专机抵达平壤，开始对朝鲜进行国事访问。朝鲜最高领导人金正恩携夫人李雪主到机场迎接。习近平和夫人彭丽媛步出舱门，走下舷梯，与金正恩握手。习近平此次为期两天的访问是他七年来首次访问朝鲜，预计将与金正恩举行峰会。这将是自​​去年9月以来，两人在北京与俄罗斯总统普京等外国领导人一同观看九三阅兵式及举行双边会谈后首次会面。蔡奇、王毅等陪同人员同机抵达。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260608-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%97%B6%E9%9A%94%E4%B8%83%E5%B9%B4%E5%86%8D%E8%AE%BF%E6%9C%9D%E9%B2%9C-%E8%A6%81%E5%8A%A0%E5%BC%BA%E6%88%98%E7%95%A5%E6%B2%9F%E9%80%9A%E5%92%8C%E5%8D%8F%E8%B0%83%E9%85%8D%E5%90%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780910428000.webp","sourceId":"rfi"},{"id":1780910405000,"createdDate":"2026-06-08 09:20","name":"法国国际广播电台","title":"香港国安法加码：特首可将任何罪行订为国安罪行 限制人权程序随之适用","content":"香港政府将进一步扩大被指侵害人权的国安法例的管辖和适用范围，拟议中的《维护国家安全条例》附属法例订明，即使相关行为不是法例订明的国安罪行，但只要行政长官(又称特首)就某些涉及国家安全的刑事罪行发出证明书，则相关案件便属于国安案件，当局可以国安法例的规定去处理相关案件的侦查丶拘捕丶检控及审讯程序。香港人权资讯中心发言人指出，新修订赋予特首无上权力去把香港任何罪行订为国安罪行，已受侵蚀的香港人权和司法独立势将进一步被弱化。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E9%A6%99%E6%B8%AF%E5%9B%BD%E5%AE%89%E6%B3%95%E5%8A%A0%E7%A0%81-%E7%89%B9%E9%A6%96%E5%8F%AF%E5%B0%86%E4%BB%BB%E4%BD%95%E7%BD%AA%E8%A1%8C%E8%AE%A2%E4%B8%BA%E5%9B%BD%E5%AE%89%E7%BD%AA%E8%A1%8C-%E9%99%90%E5%88%B6%E4%BA%BA%E6%9D%83%E7%A8%8B%E5%BA%8F%E9%9A%8F%E4%B9%8B%E9%80%82%E7%94%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780910405000.webp","sourceId":"rfi"},{"id":1780907122000,"createdDate":"2026-06-08 08:25","name":"法国国际广播电台","title":"中国宣布在台湾东部海域执法 台湾称其为“挑衅”和“认知战”","content":"台湾周一（6月8日）对中国宣布在台湾东部海域开展“海上交通专项执法行动”表示，这是“挑衅行为”和认知战，是经过伪装的扩张主义，威胁地区的和平与稳定。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260608-%E4%B8%AD%E5%9B%BD%E5%9C%A8%E5%8F%B0%E6%B9%BE%E4%B8%9C%E9%83%A8%E6%B5%B7%E5%9F%9F%E6%89%A7%E6%B3%95-%E5%8F%B0%E6%B9%BE%E7%A7%B0%E5%85%B6%E4%B8%BA-%E6%8C%91%E8%A1%85-%E5%92%8C-%E8%AE%A4%E7%9F%A5%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780907122000.webp","sourceId":"rfi"},{"id":1780934729000,"createdDate":"2026-06-08 16:05","name":"法国国际广播电台","title":"哈梅内伊遇袭身亡后 俄安全部门据报彻查、隔离普京摄像头","content":"据英国《金融时报》援引两位知情人士报导称，在伊朗前最高领袖哈梅内伊于德黑兰遇袭身亡后，俄罗斯安全部门关闭了部分用于保护总统普京及其最亲密助手的特殊监控系统。其中一位知情人士表示，该系统独立于近30万个监控莫斯科市民的摄像头之外，在工程师彻底检查并试图将其与互联网完全隔离后才重新启动。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260608-%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E9%81%87%E8%A2%AD%E8%BA%AB%E4%BA%A1%E5%90%8E-%E4%BF%84%E5%AE%89%E5%85%A8%E9%83%A8%E9%97%A8%E6%8D%AE%E6%8A%A5%E5%BD%BB%E6%9F%A5-%E9%9A%94%E7%A6%BB%E6%99%AE%E4%BA%AC%E6%91%84%E5%83%8F%E5%A4%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780934729000.webp","sourceId":"rfi"},{"id":1780933775000,"createdDate":"2026-06-08 15:49","name":"法国国际广播电台","title":"安琪巴黎「自由谈」沙龙纪要与述评：艺术自由与存在者的存在 ――法、德、中、台艺术家跨疆域探讨","content":"在人工智能制造的信息洪流中，艺术何为？当算法日益渗透人类的感知与表达，艺术家如何守住意识的自主，安放灵魂的“本在”？这不是一个抽象的哲学追问，而是每一个创作者当下必须直面的现实处境。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260608-%E5%AE%89%E7%90%AA%E5%B7%B4%E9%BB%8E-%E8%87%AA%E7%94%B1%E8%B0%88-%E6%B2%99%E9%BE%99%E7%BA%AA%E8%A6%81%E4%B8%8E%E8%BF%B0%E8%AF%84-%E8%89%BA%E6%9C%AF%E8%87%AA%E7%94%B1%E4%B8%8E%E5%AD%98%E5%9C%A8%E8%80%85%E7%9A%84%E5%AD%98%E5%9C%A8-%E2%80%95%E2%80%95%E6%B3%95-%E5%BE%B7-%E4%B8%AD-%E5%8F%B0%E8%89%BA%E6%9C%AF%E5%AE%B6%E8%B7%A8%E7%96%86%E5%9F%9F%E6%8E%A2%E8%AE%A8","thumbnail":"","detailImage":"","sourceId":"rfi"},{"id":1780933211000,"createdDate":"2026-06-08 15:40","name":"法国国际广播电台","title":"教皇良十四世为何前往西班牙？此行的意义何在？","content":"各位听众，本次教皇良十四世访问西班牙的行程安排为2026年6月6日至12日，前往马德里、巴塞罗那和加那利群岛。本次罗马教皇访问西班牙距离上次已15年。此次教皇对于这个西欧重要天主教国家的国事访问将融合民间风情、政治事件、基督教历史以及移民问题。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260608-%E6%95%99%E7%9A%87%E8%89%AF%E5%8D%81%E5%9B%9B%E4%B8%96%E4%B8%BA%E4%BD%95%E5%89%8D%E5%BE%80%E8%A5%BF%E7%8F%AD%E7%89%99-%E6%AD%A4%E8%A1%8C%E7%9A%84%E6%84%8F%E4%B9%89%E4%BD%95%E5%9C%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780933211000.webp","sourceId":"rfi"},{"id":1780932677000,"createdDate":"2026-06-08 15:31","name":"法国国际广播电台","title":"北约下令 法战机在拉脱维亚领空击落一架从俄罗斯进入的无人机","content":"周一，一架法国“阵风”战斗机击落了一架从俄罗斯进入北约成员国拉脱维亚领空的无人机。这是近期欧洲东部边境地区发生的一系列类似安全事件中的最新一起。拉脱维亚军方并未透露该无人机的发射方，仅表示涉事无人机是从俄罗斯“通过俄方电磁战”入侵的。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260608-%E5%8C%97%E7%BA%A6%E4%B8%8B%E4%BB%A4-%E6%B3%95%E6%88%98%E6%9C%BA%E5%9C%A8%E6%8B%89%E8%84%B1%E7%BB%B4%E4%BA%9A%E9%A2%86%E7%A9%BA%E5%87%BB%E8%90%BD%E4%B8%80%E6%9E%B6%E4%BB%8E%E4%BF%84%E7%BD%97%E6%96%AF%E8%BF%9B%E5%85%A5%E7%9A%84%E6%97%A0%E4%BA%BA%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780932677000.webp","sourceId":"rfi"},{"id":1780931481000,"createdDate":"2026-06-08 15:11","name":"法国国际广播电台","title":"日防相拟12日访问雅加达会见印尼防长 探讨朝雾级护卫舰出口事宜","content":"据共同社援引消息人士报导，日本防卫大臣小泉进次郎正安排于12日访问印尼首都雅加达，与印尼国防部长夏弗里（SjafrieSjamsoeddin）会面。预计此次会晤将讨论向印尼军方出口日本海上自卫队“朝雾”级护卫舰的事宜。他还将安排礼节性拜会印尼总统普拉博沃，并计划于13日返日。最终决定将在考虑日本国会日程后尽快作出。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260608-%E6%97%A5%E9%98%B2%E7%9B%B8%E6%8B%9F12%E6%97%A5%E8%AE%BF%E9%97%AE%E9%9B%85%E5%8A%A0%E8%BE%BE%E4%BC%9A%E8%A7%81%E5%8D%B0%E5%B0%BC%E9%98%B2%E9%95%BF-%E6%8E%A2%E8%AE%A8%E6%9C%9D%E9%9B%BE%E7%BA%A7%E6%8A%A4%E5%8D%AB%E8%88%B0%E5%87%BA%E5%8F%A3%E4%BA%8B%E5%AE%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780931481000.webp","sourceId":"rfi"},{"id":1780931164000,"createdDate":"2026-06-08 15:06","name":"法国国际广播电台","title":"伊朗战争爆发100天：德黑兰人怎么说？","content":"美国和以色列军队于2月28日开始对伊朗发动空袭。在战争爆发100天之际，德黑兰居民于周日（6月7日）表达了既坚韧又不安的复杂情绪。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260608-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E7%88%86%E5%8F%91100%E5%A4%A9-%E5%BE%B7%E9%BB%91%E5%85%B0%E4%BA%BA%E6%80%8E%E4%B9%88%E8%AF%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780931164000.webp","sourceId":"rfi"},{"id":1780929093000,"createdDate":"2026-06-08 14:31","name":"法国国际广播电台","title":"韩国警方：没有外国警察或假警察 李在明：未能保障投票权是严重事件","content":"韩国警方周一公开呼吁民众停止对被派往投票站和计票站的警员进行猜测和诽谤，此前因6月3日地方选举选票短缺而引发了此类事件。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260608-%E9%9F%A9%E5%9B%BD%E8%AD%A6%E6%96%B9-%E6%B2%A1%E6%9C%89%E5%A4%96%E5%9B%BD%E8%AD%A6%E5%AF%9F%E6%88%96%E5%81%87%E8%AD%A6%E5%AF%9F-%E6%9D%8E%E5%9C%A8%E6%98%8E-%E6%9C%AA%E8%83%BD%E4%BF%9D%E9%9A%9C%E6%8A%95%E7%A5%A8%E6%9D%83%E6%98%AF%E4%B8%A5%E9%87%8D%E4%BA%8B%E4%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780929093000.webp","sourceId":"rfi"},{"id":1780927485000,"createdDate":"2026-06-08 14:04","name":"法国国际广播电台","title":"习近平时隔七年访问朝鲜，中朝关系站上“历史新起点”","content":"2026年6月8日，中国国家主席习近平抵达朝鲜首都平壤，开始对朝鲜进行为期两天的国事访问，并将与朝鲜劳动党总书记、国务委员长金正恩举行会谈。这是习近平今年首次出访，也是他七年来首次访问朝鲜。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260608-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%97%B6%E9%9A%94%E4%B8%83%E5%B9%B4%E8%AE%BF%E9%97%AE%E6%9C%9D%E9%B2%9C%EF%BC%8C%E4%B8%AD%E6%9C%9D%E5%85%B3%E7%B3%BB%E7%AB%99%E4%B8%8A-%E5%8E%86%E5%8F%B2%E6%96%B0%E8%B5%B7%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780927485000.webp","sourceId":"rfi"},{"id":1780926532000,"createdDate":"2026-06-08 13:48","name":"法国国际广播电台","title":"倍耐力股东中企橡胶公司就意大利政府“黄金权力”限制提上诉","content":"意大利轮胎公司倍耐力（Pirelli）周一表示，中国化工橡胶有限公司（CNRC）及其子公司马可波罗国际已分别向意大利一地方行政法院提起上诉，反对意政府对其持有的倍耐力股份附加的限制条件。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260608-%E5%80%8D%E8%80%90%E5%8A%9B%E8%82%A1%E4%B8%9C%E4%B8%AD%E4%BC%81%E6%A9%A1%E8%83%B6%E5%85%AC%E5%8F%B8%E5%B0%B1%E6%84%8F%E5%A4%A7%E5%88%A9%E6%94%BF%E5%BA%9C-%E9%BB%84%E9%87%91%E6%9D%83%E5%8A%9B-%E9%99%90%E5%88%B6%E6%8F%90%E4%B8%8A%E8%AF%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780926532000.webp","sourceId":"rfi"},{"id":1780924565000,"createdDate":"2026-06-08 13:16","name":"法国国际广播电台","title":"美外交官敦促北约盟国动用国防开支来更换华为设备","content":"据彭博社援引知情人士报导称，美国特朗普（DonaldTrump）政府敦促北约盟国将国防开支用于替换其网络和关键基础设施中来自华为的零部件。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260608-%E7%BE%8E%E5%A4%96%E4%BA%A4%E5%AE%98%E4%BF%83%E5%8C%97%E7%BA%A6%E7%9B%9F%E5%9B%BD%E5%8A%A8%E7%94%A8%E5%9B%BD%E9%98%B2%E5%BC%80%E6%94%AF%E6%9D%A5%E6%9B%B4%E6%8D%A2%E5%8D%8E%E4%B8%BA%E8%AE%BE%E5%A4%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780924565000.webp","sourceId":"rfi"},{"id":1780921911000,"createdDate":"2026-06-08 12:31","name":"法国国际广播电台","title":"传富察已出狱 台陆委会：尊重家属意见不进行说明","content":"台湾“八旗文化”出版社总编辑“富察”李延贺被控犯下“煽动分裂国家罪”，遭上海市第一中级人民法院判处有期徒刑3年、剥夺政治权利1年。《自由时报》报导称，据透露，富察已在今年5月出狱，因为仍有附加刑1年，遭中共当局限制出境，无法离开中国大陆回台。对此，据台央广报导，陆委会周一回应表示，为尊重家属意见，不对本案进行说明。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260608-%E4%BC%A0%E5%AF%8C%E5%AF%9F%E5%B7%B2%E5%87%BA%E7%8B%B1-%E5%8F%B0%E9%99%86%E5%A7%94%E4%BC%9A-%E5%B0%8A%E9%87%8D%E5%AE%B6%E5%B1%9E%E6%84%8F%E8%A7%81%E4%B8%8D%E8%BF%9B%E8%A1%8C%E8%AF%B4%E6%98%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780921911000.webp","sourceId":"rfi"},{"id":1780921321000,"createdDate":"2026-06-08 12:22","name":"法国国际广播电台","title":"北京法国文化中心突撤6月所有电影放映场次","content":"北京法国文化中心近日突然取消6月所有电影放映活动。北京微信购票小程序的购票页面和影片详情页面均显示北京法国文化中心放映的法国影片是“商品下架”或“暂无商品”的状态，“同志骄傲月”主题的活动已不可见，多名观众称已经收到退款。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E5%8C%97%E4%BA%AC%E6%B3%95%E5%9B%BD%E6%96%87%E5%8C%96%E4%B8%AD%E5%BF%83%E7%AA%81%E6%92%A46%E6%9C%88%E6%89%80%E6%9C%89%E7%94%B5%E5%BD%B1%E6%94%BE%E6%98%A0%E5%9C%BA%E6%AC%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780921321000.webp","sourceId":"rfi"},{"id":1780916533000,"createdDate":"2026-06-08 11:02","name":"法国国际广播电台","title":"帕希尼扬领导的政党赢得了亚美尼亚议会选举， 欧盟和马克龙祝贺","content":"亚美尼亚总理尼科尔·帕希尼扬领导的政党赢得了议会选举，初步结果于周一公布。帕希尼扬致力于与西方建立更紧密的联系，并使亚美尼亚摆脱其前帝国统治者的影响，这激怒了克里姆林宫。这次选举的胜利被看作是亚美尼亚指控俄罗斯威胁和干预之后选民认可转向亲西方。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260608-%E5%B8%95%E5%B8%8C%E5%B0%BC%E6%89%AC%E9%A2%86%E5%AF%BC%E7%9A%84%E6%94%BF%E5%85%9A%E8%B5%A2%E5%BE%97%E4%BA%86%E4%BA%9A%E7%BE%8E%E5%B0%BC%E4%BA%9A%E8%AE%AE%E4%BC%9A%E9%80%89%E4%B8%BE%EF%BC%8C-%E6%AC%A7%E7%9B%9F%E5%92%8C%E9%A9%AC%E5%85%8B%E9%BE%99%E7%A5%9D%E8%B4%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780916533000.webp","sourceId":"rfi"},{"id":1780914533000,"createdDate":"2026-06-08 10:28","name":"法国国际广播电台","title":"美方据报正考虑从毛里求斯手中购买查戈斯群岛 英政府发言人回应","content":"据《每日电讯报》报导称，美国总统特朗普（DonaldTrump）正在考虑从毛里求斯手中购买查戈斯群岛，而英国放弃该群岛主权的计划目前陷入僵局。白宫尚未回应《卫报》就此潜在计划提出的置评请求。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260608-%E7%BE%8E%E6%96%B9%E6%8D%AE%E6%8A%A5%E6%AD%A3%E8%80%83%E8%99%91%E4%BB%8E%E6%AF%9B%E9%87%8C%E6%B1%82%E6%96%AF%E6%89%8B%E4%B8%AD%E8%B4%AD%E4%B9%B0%E6%9F%A5%E6%88%88%E6%96%AF%E7%BE%A4%E5%B2%9B-%E8%8B%B1%E6%94%BF%E5%BA%9C%E5%8F%91%E8%A8%80%E4%BA%BA%E5%9B%9E%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780914533000.webp","sourceId":"rfi"},{"id":1780961565000,"createdDate":"2026-06-08 23:32","name":"法国国际广播电台","title":"青岛启用全球首个专门用于人工智能数据中心的预制式电站","content":"近日中国绿色能源预制舱式变电站--“特锐德”自主研发的全球首创算力中心高压交直流预制舱供电站（简称“算电岛”）在青岛市崂山区发布。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E9%9D%92%E5%B2%9B%E5%90%AF%E7%94%A8%E5%85%A8%E7%90%83%E9%A6%96%E4%B8%AA%E4%B8%93%E9%97%A8%E7%94%A8%E4%BA%8E%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E6%95%B0%E6%8D%AE%E4%B8%AD%E5%BF%83%E7%9A%84%E9%A2%84%E5%88%B6%E5%BC%8F%E7%94%B5%E7%AB%99","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780961565000.webp","sourceId":"rfi"},{"id":1780961225000,"createdDate":"2026-06-08 23:27","name":"法国国际广播电台","title":"朝鲜与俄罗斯越走越近，习近平如何保持对朝鲜的影响力？","content":"中国国家主席习近平6月8日至9日对朝鲜进行国事访问。法国世界报周一就此发表长篇文章分析习近平访问朝鲜的背景及其地缘政治意义。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260608-%E6%9C%9D%E9%B2%9C%E4%B8%8E%E4%BF%84%E7%BD%97%E6%96%AF%E8%B6%8A%E8%B5%B0%E8%B6%8A%E8%BF%91%EF%BC%8C%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%A6%82%E4%BD%95%E4%BF%9D%E6%8C%81%E5%AF%B9%E6%9C%9D%E9%B2%9C%E7%9A%84%E5%BD%B1%E5%93%8D%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780961225000.webp","sourceId":"rfi"},{"id":1780957972000,"createdDate":"2026-06-08 22:32","name":"法国国际广播电台","title":"塞内加尔:法耶总统失去党内支持","content":"西非国家塞内加尔政治危机的变化迷雾在度过了刚刚过去的周末（2026年06月06号周六和06月07号周日）两天后，现已更加明朗。巴西鲁·迪奥马耶·法耶总统（leprésidentsénégalaisBassirouDiomayeFaye）在其党内遭正式边缘化。这是本台法广非洲组（RFIAfrique）过去48小时里法文报导的关注焦点之一。在两周前被解职的前政府总理奥斯曼·松科（OusmaneSonko），如今不仅已经成功当选塞内加尔国民议会的新议长，而且在06月06日上周六晚召开的塞内加尔[争取工作、道德和博爱非洲爱国者]党（lePastef）的党代会上，全票重新当选党魁，并随即在06月07日星期天举行了声势浩大的就职典礼。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260608-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%A1%9E%E5%86%85%E5%8A%A0%E5%B0%94-%E6%B3%95%E8%80%B6%E6%80%BB%E7%BB%9F%E5%A4%B1%E5%8E%BB%E5%85%9A%E5%86%85%E6%94%AF%E6%8C%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780957972000.webp","sourceId":"rfi"},{"id":1780952744000,"createdDate":"2026-06-08 21:05","name":"法国国际广播电台","title":"法德牵头启动的“未来空中作战系统”搁浅","content":"柏林航空航天展（ILABerlin）即将开幕。在此一盛事前传来不好的消息，法国总统马克龙和德国总理默茨8日一致认为，法德联合研发的未来战斗机（SCAF）项目无法完成。法国总统府在一份新闻稿中表示：“双方都对业界未能就继续推进该项目达成一致表示遗憾。”","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260608-%E6%B3%95%E5%BE%B7%E7%89%B5%E5%A4%B4%E5%90%AF%E5%8A%A8%E7%9A%84-%E6%9C%AA%E6%9D%A5%E7%A9%BA%E4%B8%AD%E4%BD%9C%E6%88%98%E7%B3%BB%E7%BB%9F-%E6%90%81%E6%B5%85","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780952744000.webp","sourceId":"rfi"},{"id":1780952238000,"createdDate":"2026-06-08 20:57","name":"法国国际广播电台","title":"中国各式各样的付费陪伴服务越来越常见","content":"中国近年兴起“陪伴经济”，从陪晨练、陪就诊、陪旅游到陪吃火锅，各式各样的付费陪伴服务越来越常见。路透社引述中国官媒人民网去年报导估计，2025年“陪伴经济”的市场规模可能约达到500亿元人民币（约74亿美元）。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260608-%E4%B8%AD%E5%9B%BD%E5%90%84%E5%BC%8F%E5%90%84%E6%A0%B7%E7%9A%84%E4%BB%98%E8%B4%B9%E9%99%AA%E4%BC%B4%E6%9C%8D%E5%8A%A1%E8%B6%8A%E6%9D%A5%E8%B6%8A%E5%B8%B8%E8%A7%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780952238000.webp","sourceId":"rfi"},{"id":1780952021000,"createdDate":"2026-06-08 20:53","name":"法国国际广播电台","title":"法国和塞浦路斯签署一项驻军地位协定","content":"法国和塞浦路斯周一签署一项驻军地位协定，允许法国在地中海岛屿塞浦路斯驻扎军队。协议内容将涵盖军事协调与互操作性、国防技术和产业联系、联合军事演习和教育活动、人员交流以及在对方领土上行动的部队的行政安排。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260608-%E6%B3%95%E5%9B%BD%E5%92%8C%E5%A1%9E%E6%B5%A6%E8%B7%AF%E6%96%AF%E7%AD%BE%E7%BD%B2%E4%B8%80%E9%A1%B9%E9%A9%BB%E5%86%9B%E5%9C%B0%E4%BD%8D%E5%8D%8F%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780952021000.webp","sourceId":"rfi"},{"id":1780951712000,"createdDate":"2026-06-08 20:48","name":"法国国际广播电台","title":"菲律宾发生7.8级强震   已知至少32人死亡","content":"菲律宾南部棉兰老岛（Mindanao）6月8日发生7.8级地震，目前已知造成至少32人死亡，另有数十人受伤。印尼苏拉威西岛（Sulawesi）等地有震感，海啸预警发出后6个小时被解除。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260608-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%8F%91%E7%94%9F7-8%E7%BA%A7%E5%BC%BA%E9%9C%87-%E5%B7%B2%E7%9F%A5%E8%87%B3%E5%B0%9132%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780951712000.webp","sourceId":"rfi"},{"id":1780951159000,"createdDate":"2026-06-08 20:39","name":"法国国际广播电台","title":"联合国：世界必须“摆脱化石燃料“","content":"联合国气候峰会主席西蒙·斯蒂尔（ChrisBowen）6月8日告诉法新社，中东战争表明，世界必须“摆脱化石燃料“。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260608-%E8%81%94%E5%90%88%E5%9B%BD-%E4%B8%96%E7%95%8C%E5%BF%85%E9%A1%BB-%E6%91%86%E8%84%B1%E5%8C%96%E7%9F%B3%E7%87%83%E6%96%99","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780951159000.webp","sourceId":"rfi"},{"id":1780950871000,"createdDate":"2026-06-08 20:34","name":"法国国际广播电台","title":"最新气候报告：海洋状况正在“恶化","content":"联合国在一份科学报告中警告称，海洋状况正在“恶化”。数百名科学家呼吁各国面对加速变暖、污染和海洋生物濒危等问题采取“紧急行动”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260608-%E6%9C%80%E6%96%B0%E6%B0%94%E5%80%99%E6%8A%A5%E5%91%8A-%E6%B5%B7%E6%B4%8B%E7%8A%B6%E5%86%B5%E6%AD%A3%E5%9C%A8-%E6%81%B6%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780950871000.webp","sourceId":"rfi"},{"id":1780950550000,"createdDate":"2026-06-08 20:29","name":"法国国际广播电台","title":"玻利维亚爆发警方与反政府示威者冲突","content":"时局对玻利维亚总统罗德里戈·帕斯·佩雷拉（RodrigoPaz）非常不利。面对持续了一个多月的抗议浪潮，总统8日表示，这些抗议活动是由“毒品恐怖分子”煽动的，而这些“恐怖分子的末日已至”。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260608-%E7%8E%BB%E5%88%A9%E7%BB%B4%E4%BA%9A%E7%88%86%E5%8F%91%E8%AD%A6%E6%96%B9%E4%B8%8E%E5%8F%8D%E6%94%BF%E5%BA%9C%E7%A4%BA%E5%A8%81%E8%80%85%E5%86%B2%E7%AA%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780950550000.webp","sourceId":"rfi"},{"id":1780950311000,"createdDate":"2026-06-08 20:25","name":"法国国际广播电台","title":"“她本可以不死”  法11岁少女遇害引发公愤","content":"法国西南部一个名为莉亚娜（Lyhanna）的初中生不明不白地死亡，主嫌JérômeBarella7次被控，其中4个案例是对少女性侵，但就这么一个魔鬼逍遥法外近10年。法国的家长们愤怒了；发生悲剧的小镇弗洛朗斯（Fleurance）的镇长愤怒了；在举办了有6000人参加的静走默哀活动之后，6月8日要求调查真相、惩罚凶手、加强法治的男男女女聚集在巴黎、斯特拉斯堡、尼斯等城市的法院前。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260608-%E5%A5%B9%E6%9C%AC%E5%8F%AF%E4%BB%A5%E4%B8%8D%E6%AD%BB-%E6%B3%9511%E5%B2%81%E5%B0%91%E5%A5%B3%E9%81%87%E5%AE%B3%E5%BC%95%E5%8F%91%E5%85%AC%E6%84%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780950311000.webp","sourceId":"rfi"},{"id":1780950274000,"createdDate":"2026-06-08 20:24","name":"法国国际广播电台","title":"英伟达老板与韩国科技巨头共商开发人形机器人资料中心等课题","content":"被誉为人工智能（AI）晶片重要推手的英伟达公司（Nvidia）执行长黄仁勋6月8日在韩国表示，英伟达将与韩国科技集团乐金（LG）合作，携手开发人形机器人与资料中心。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260608-%E8%8B%B1%E4%BC%9F%E8%BE%BE%E8%80%81%E6%9D%BF%E4%B8%8E%E9%9F%A9%E5%9B%BD%E7%A7%91%E6%8A%80%E5%B7%A8%E5%A4%B4%E5%85%B1%E5%95%86%E5%BC%80%E5%8F%91%E4%BA%BA%E5%BD%A2%E6%9C%BA%E5%99%A8%E4%BA%BA%E8%B5%84%E6%96%99%E4%B8%AD%E5%BF%83%E7%AD%89%E8%AF%BE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780950274000.webp","sourceId":"rfi"},{"id":1780950042000,"createdDate":"2026-06-08 20:20","name":"法国国际广播电台","title":"肯尼迪中心从其网站上删除特朗普的名字","content":"肯尼迪中心周一从其网站上删除了唐纳德·特朗普总统的名字，但尚未从华盛顿著名表演厅的正面删除。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260608-%E8%82%AF%E5%B0%BC%E8%BF%AA%E4%B8%AD%E5%BF%83%E4%BB%8E%E5%85%B6%E7%BD%91%E7%AB%99%E4%B8%8A%E5%88%A0%E9%99%A4%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84%E5%90%8D%E5%AD%97","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780950042000.webp","sourceId":"rfi"},{"id":1780947986000,"createdDate":"2026-06-08 19:46","name":"法国国际广播电台","title":"特朗普致电内塔尼亚胡要求克制 以伊互射飞弹后同意暂停攻击","content":"美国总统特朗普（DonaldTrump）8日与以色列总理内塔尼亚胡（BenjaminNetanyahu）通电话，敦促以色列与伊朗停止军事冲突。白宫证实两位领导人已直接通话。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260608-%E7%89%B9%E6%9C%97%E6%99%AE%E8%87%B4%E7%94%B5%E5%86%85%E5%A1%94%E5%B0%BC%E4%BA%9A%E8%83%A1%E8%A6%81%E6%B1%82%E5%85%8B%E5%88%B6-%E4%BB%A5%E4%BC%8A%E4%BA%92%E5%B0%84%E9%A3%9E%E5%BC%B9%E5%90%8E%E5%90%8C%E6%84%8F%E6%9A%82%E5%81%9C%E6%94%BB%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780947986000.webp","sourceId":"rfi"},{"id":1780947507000,"createdDate":"2026-06-08 19:38","name":"法国国际广播电台","title":"伊朗挑战但不恋战 再次警告黎巴嫩是红线","content":"伊朗军方6月8日周一宣布，自4月停火以来对以色列发动的首波攻势现已停止，但伊朗同时也警告：如果以色列再度攻击黎巴嫩，德黑兰将恢复打击行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260608-%E4%BC%8A%E6%9C%97%E6%8C%91%E6%88%98%E4%BD%86%E4%B8%8D%E6%81%8B%E6%88%98-%E5%86%8D%E6%AC%A1%E8%AD%A6%E5%91%8A%E9%BB%8E%E5%B7%B4%E5%AB%A9%E6%98%AF%E7%BA%A2%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/08/1780947507000.webp","sourceId":"rfi"}]