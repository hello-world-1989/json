[{"id":1782638383000,"createdDate":"2026-06-28 09:19","name":"法国国际广播电台","title":"武契奇称将在数周内辞去总统职位提前选举 有意重当总理？","content":"塞尔维亚总统武契奇（AleksandarVučić）周六表示，在经历了长达18个月的反政府抗议活动后，他将在数周内辞职，该国也将提前举行总统和议会选举。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260628-%E6%AD%A6%E5%A5%91%E5%A5%87%E7%A7%B0%E5%B0%86%E5%9C%A8%E6%95%B0%E5%91%A8%E5%86%85%E8%BE%9E%E5%8E%BB%E6%80%BB%E7%BB%9F%E8%81%8C%E4%BD%8D%E6%8F%90%E5%89%8D%E9%80%89%E4%B8%BE-%E6%9C%89%E6%84%8F%E5%86%8D%E5%BD%93%E6%80%BB%E7%90%86","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782638383000.webp","sourceId":"rfi"},{"id":1782637919000,"createdDate":"2026-06-28 09:11","name":"法国国际广播电台","title":"世界杯小组赛结束，16强淘汰赛周日拉开帷幕","content":"截至国际标准时间周六（6月27日）晚，世界杯小组赛72场比赛已全部结束。这也意味着真正的较量开始了，南非与加拿大将于国际标准时间19点率先登场，为16强淘汰赛揭开序幕。赛程过半，让我们一起盘点一下过去两周最值得关注的看点都有什么？","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260628-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%B0%8F%E7%BB%84%E8%B5%9B%E7%BB%93%E6%9D%9F%EF%BC%8C16%E5%BC%BA%E6%B7%98%E6%B1%B0%E8%B5%9B%E5%91%A8%E6%97%A5%E6%8B%89%E5%BC%80%E5%B8%B7%E5%B9%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782637919000.webp","sourceId":"rfi"},{"id":1782633313000,"createdDate":"2026-06-28 07:55","name":"法国国际广播电台","title":"中俄战机在日本周边联合飞行示威 日战机紧急起飞应对","content":"日本防卫省表示，已确认中国军队和俄罗斯军队的轰炸机于27日在日本周边进行了联合飞行，飞行范围从东海上空延伸至四国近海的太平洋上空等区域，对此，日本航空自卫队西部航空方面队等部队紧急出动战斗机进行应对，防卫省认为，此次行动“明显试图对日本进行示威”，已通过外交渠道向中俄两国表达严重关切，并持续保持警戒监视。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260628-%E4%B8%AD%E4%BF%84%E6%88%98%E6%9C%BA%E5%9C%A8%E6%97%A5%E6%9C%AC%E5%91%A8%E8%BE%B9%E8%81%94%E5%90%88%E9%A3%9E%E8%A1%8C%E7%A4%BA%E5%A8%81-%E6%97%A5%E6%88%98%E6%9C%BA%E7%B4%A7%E6%80%A5%E8%B5%B7%E9%A3%9E%E5%BA%94%E5%AF%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782633313000.webp","sourceId":"rfi"},{"id":1782662946000,"createdDate":"2026-06-28 16:09","name":"法国国际广播电台","title":"法满载跳伞学员和教练的轻型飞机坠毁  击毁人亡","content":"法国东北部城市南锡（Nancy）郊外28日出现一起民用飞机伤亡最惨重的航空事故，机上11人全部遇难。巴黎时间11点25分，一架用于跳伞训练的飞机在南锡郊外通布莱讷（Tomblaine）坠毁，法国内政部长、交通部长在当天下午抵达事故现场。坠机原因还在调查之中。5名跳伞学员都是第一次尝试，结果葬送了性命。机上还有一名飞行员和5名教练。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260628-%E6%B3%95%E6%BB%A1%E8%BD%BD%E8%B7%B3%E4%BC%9E%E5%AD%A6%E5%91%98%E5%92%8C%E6%95%99%E7%BB%83%E7%9A%84%E8%BD%BB%E5%9E%8B%E9%A3%9E%E6%9C%BA%E5%9D%A0%E6%AF%81-%E5%87%BB%E6%AF%81%E4%BA%BA%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782662946000.webp","sourceId":"rfi"},{"id":1782659390000,"createdDate":"2026-06-28 15:09","name":"法国国际广播电台","title":"4任司令员落马 火箭军党委刊文：永远忠于党，坚决同各种错误思想作斗争","content":"解放军战略导弹部队组建60周年前夕，火箭军党委26日刊文强调：“火箭军永远忠于党”，誓言“从思想上肃毒除弊、从组织上去腐生肌”。火箭军党委当天在中共中央党校主办的《学习时报》头版发表了题为《努力建设一支强大的现代化火箭军》的文章。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260628-4%E4%BB%BB%E5%8F%B8%E4%BB%A4%E5%91%98%E8%90%BD%E9%A9%AC-%E7%81%AB%E7%AE%AD%E5%86%9B%E5%85%9A%E5%A7%94%E5%88%8A%E6%96%87-%E6%B0%B8%E8%BF%9C%E5%BF%A0%E4%BA%8E%E5%85%9A%EF%BC%8C%E5%9D%9A%E5%86%B3%E5%90%8C%E5%90%84%E7%A7%8D%E9%94%99%E8%AF%AF%E6%80%9D%E6%83%B3%E4%BD%9C%E6%96%97%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782659390000.webp","sourceId":"rfi"},{"id":1782656147000,"createdDate":"2026-06-28 14:15","name":"法国国际广播电台","title":"下萨克森州州长：若大众在德国生产在华制造车型，有望保住就业岗位","content":"大众集团第二大股东、德国下萨克森州的州长利斯（OlafLies）表示，如果大众汽车将目前在中国研发的车型在本国生产，就有望保住在德国的就业岗位。周五有报道称，这家陷入困境的汽车制造巨头正在考虑关闭四家在德国的工厂，并将裁员幅度扩大至多达10万人。利斯向德新社发表了上述言论。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260628-%E4%B8%8B%E8%90%A8%E5%85%8B%E6%A3%AE%E5%B7%9E%E5%B7%9E%E9%95%BF-%E8%8B%A5%E5%A4%A7%E4%BC%97%E5%9C%A8%E5%BE%B7%E5%9B%BD%E7%94%9F%E4%BA%A7%E5%9C%A8%E5%8D%8E%E5%88%B6%E9%80%A0%E8%BD%A6%E5%9E%8B%EF%BC%8C%E6%9C%89%E6%9C%9B%E4%BF%9D%E4%BD%8F%E5%B0%B1%E4%B8%9A%E5%B2%97%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782656147000.webp","sourceId":"rfi"},{"id":1782653690000,"createdDate":"2026-06-28 13:34","name":"法国国际广播电台","title":"日防相指中俄联合巡航不得不被视为对日示威行动 韩国防部向中俄武官提严正抗议","content":"正在首尔进行访问的日本防卫大臣小泉进次郎周日对记者表示，“昨天中俄轰炸机进行了联合飞行。两国轰炸机一再进行联合飞行，不仅意味着两国在日本周边的活动范围扩大、频率增加，而且不得不被视为针对我国的示威行动”。小泉续称，“我认为，能够就此类事件及时与（韩国国防部长官安圭伯）安部长交换意见和信息，是此次访问的重要意义之一”。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260628-%E6%97%A5%E9%98%B2%E7%9B%B8%E6%8C%87%E4%B8%AD%E4%BF%84%E8%81%94%E5%90%88%E5%B7%A1%E8%88%AA%E4%B8%8D%E5%BE%97%E4%B8%8D%E8%A2%AB%E8%A7%86%E4%B8%BA%E5%AF%B9%E6%97%A5%E7%A4%BA%E5%A8%81%E8%A1%8C%E5%8A%A8-%E9%9F%A9%E5%9B%BD%E9%98%B2%E9%83%A8%E5%90%91%E4%B8%AD%E4%BF%84%E6%AD%A6%E5%AE%98%E6%8F%90%E4%B8%A5%E6%AD%A3%E6%8A%97%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782653690000.webp","sourceId":"rfi"},{"id":1782649722000,"createdDate":"2026-06-28 12:28","name":"法国国际广播电台","title":"“中国尊”周围实施严格封锁撞击痕迹远处仍可见 民航界料北京将迎来最严禁空令","content":"北京市朝阳区官方信息平台“北京朝阳”微信公众号周六发布的“情况通报”称，“6月26日17时55分，在朝阳区东三环附近，一架单发双座轻型运动航空器在飞行中碰撞一高层建筑，机上仅驾驶员1人、已死亡，现场13人受伤”。该通报称，受伤人员在全力救治中。相关情况正由主管部门进一步调查。当地时间周日（28日）中午，韩联社记者试图接近事发地，被告知“您不能进入此区域，这里正在施工”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260628-%E4%B8%AD%E5%9B%BD%E5%B0%8A-%E5%91%A8%E5%9B%B4%E5%AE%9E%E6%96%BD%E4%B8%A5%E6%A0%BC%E5%B0%81%E9%94%81%E6%92%9E%E5%87%BB%E7%97%95%E8%BF%B9%E8%BF%9C%E5%A4%84%E4%BB%8D%E5%8F%AF%E8%A7%81-%E6%B0%91%E8%88%AA%E7%95%8C%E6%96%99%E5%8C%97%E4%BA%AC%E5%B0%86%E8%BF%8E%E6%9D%A5%E6%9C%80%E4%B8%A5%E7%A6%81%E7%A9%BA%E4%BB%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782649722000.webp","sourceId":"rfi"},{"id":1782648656000,"createdDate":"2026-06-28 12:10","name":"法国国际广播电台","title":"本周末美伊紧张局势再度升级，暂时停火协议是否会就此宣告结束？","content":"这个周末，美伊之间的紧张局势再度升级。在美国对伊朗发动新一轮空袭之后，伊朗周日（6月28日）开始向巴林和科威特发射无人机和导弹进行报复，并警告称，如果美方继续发动攻击，可能会“全面中止”谈判。既然都签署了临时协议，为什么双方还要屡屡互相袭击？这是否意味着之前达成的暂时停火会就此宣告结束？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260628-%E6%9C%AC%E5%91%A8%E6%9C%AB%E7%BE%8E%E4%BC%8A%E7%B4%A7%E5%BC%A0%E5%B1%80%E5%8A%BF%E5%86%8D%E5%BA%A6%E5%8D%87%E7%BA%A7%EF%BC%8C%E6%9A%82%E6%97%B6%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E6%98%AF%E5%90%A6%E4%BC%9A%E5%B0%B1%E6%AD%A4%E5%AE%A3%E5%91%8A%E7%BB%93%E6%9D%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782648656000.webp","sourceId":"rfi"},{"id":1782645976000,"createdDate":"2026-06-28 11:26","name":"法国国际广播电台","title":"印外交部促前往西藏朝圣的公民备齐所有必要证件 以避免行程受阻","content":"印度外交部周六提醒，计划通过私人旅行社参加冈仁波齐—玛旁雍错朝圣之旅的印度公民，在未办妥所有必要旅行证件之前，切勿从印度启程。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260628-%E5%8D%B0%E5%A4%96%E4%BA%A4%E9%83%A8%E4%BF%83%E5%89%8D%E5%BE%80%E8%A5%BF%E8%97%8F%E6%9C%9D%E5%9C%A3%E7%9A%84%E5%85%AC%E6%B0%91%E5%A4%87%E9%BD%90%E6%89%80%E6%9C%89%E5%BF%85%E8%A6%81%E8%AF%81%E4%BB%B6-%E4%BB%A5%E9%81%BF%E5%85%8D%E8%A1%8C%E7%A8%8B%E5%8F%97%E9%98%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782645976000.webp","sourceId":"rfi"},{"id":1782641852000,"createdDate":"2026-06-28 10:17","name":"法国国际广播电台","title":"中使馆与菲外交部就南海仲裁案争执 菲防长斥使馆官员无诚意与欺骗","content":"菲律宾国防部长特奥多罗（GilbertoTeodoro）周日宣称，中国驻菲大使馆驳斥菲律宾外交部关于2016年南海仲裁案裁决的声明，这凸显了其官员“缺乏诚意与欺骗”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260628-%E4%B8%AD%E4%BD%BF%E9%A6%86%E4%B8%8E%E8%8F%B2%E5%A4%96%E4%BA%A4%E9%83%A8%E5%B0%B1%E5%8D%97%E6%B5%B7%E4%BB%B2%E8%A3%81%E6%A1%88%E4%BA%89%E6%89%A7-%E8%8F%B2%E9%98%B2%E9%95%BF%E6%96%A5%E4%BD%BF%E9%A6%86%E5%AE%98%E5%91%98%E6%97%A0%E8%AF%9A%E6%84%8F%E4%B8%8E%E6%AC%BA%E9%AA%97","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782641852000.webp","sourceId":"rfi"},{"id":1782640636000,"createdDate":"2026-06-28 09:57","name":"法国国际广播电台","title":"黑马突围，传统强队表现起伏，32强全部出炉，淘汰赛周日正式打响","content":"2026年世界杯小组赛全部结束，48支参赛球队经过三轮较量后，已有32支球队晋级淘汰赛，十六分之一决赛于6月28日正式打响，由东道主之一加拿大迎战南非。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260628-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%B0%8F%E7%BB%84%E8%B5%9B%E6%94%B6%E5%AE%98-%E9%BB%91%E9%A9%AC%E7%AA%81%E5%9B%B4%EF%BC%8C%E4%BC%A0%E7%BB%9F%E5%BC%BA%E9%98%9F%E8%A1%A8%E7%8E%B0%E8%B5%B7%E4%BC%8F%EF%BC%8C32%E5%BC%BA%E5%85%A8%E9%83%A8%E5%87%BA%E7%82%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782640636000.webp","sourceId":"rfi"},{"id":1782689721000,"createdDate":"2026-06-28 23:35","name":"法国国际广播电台","title":"董广平抵达加拿大结束十年逃亡生涯","content":"曾多次被监禁的中国人权活动人士董广平在三次不同方式逃离大陆失败后，今年5月底第四次用一艘橡皮艇在海上漂泊了“三十个小时”后抵达韩国海岸。最新消息显示：董广平已于6月26日搭机抵达加拿大的多伦多，结束长达十年的逃亡生涯。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260628-%E8%91%A3%E5%B9%BF%E5%B9%B3%E6%8A%B5%E8%BE%BE%E5%8A%A0%E6%8B%BF%E5%A4%A7%E7%BB%93%E6%9D%9F%E5%8D%81%E5%B9%B4%E9%80%83%E4%BA%A1%E7%94%9F%E6%B6%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782689721000.webp","sourceId":"rfi"},{"id":1782680667000,"createdDate":"2026-06-28 21:04","name":"法国国际广播电台","title":"中国安徽省合肥民众抗议兴建垃圾场","content":"据社群媒体平台X帐号“李老师不是你老师”发布的消息，中国安徽省合肥市27日爆发民众抗议兴建垃圾场的大规模集结抗议，进而发生警民冲突并引发交通瘫痪。在民众强大压力下，当地政府少见地取消建立垃圾场的计划。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260628-%E4%B8%AD%E5%9B%BD%E5%AE%89%E5%BE%BD%E7%9C%81%E5%90%88%E8%82%A5%E6%B0%91%E4%BC%97%E6%8A%97%E8%AE%AE%E5%85%B4%E5%BB%BA%E5%9E%83%E5%9C%BE%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782680667000.webp","sourceId":"rfi"},{"id":1782678851000,"createdDate":"2026-06-28 20:34","name":"法国国际广播电台","title":"法媒：中央电视台对“中国尊”撞机事件只字未提","content":"小型飞机撞上北京最高楼“中国尊”，官方时隔近一天后才做了证实。法国《快报》（l'Express）28日发表一篇题为“飞机撞入北京最高摩天大楼，事故原因成谜“的文章。文章表示，中国官方对社交媒体迅速实施审查；而此事很可能再次引发中共中央政治局内部的焦虑。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260628-%E6%B3%95%E5%AA%92-%E4%B8%AD%E5%A4%AE%E7%94%B5%E8%A7%86%E5%8F%B0%E5%AF%B9-%E4%B8%AD%E5%9B%BD%E5%B0%8A-%E6%92%9E%E6%9C%BA%E4%BA%8B%E4%BB%B6%E5%8F%AA%E5%AD%97%E6%9C%AA%E6%8F%90","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782678851000.webp","sourceId":"rfi"},{"id":1782678132000,"createdDate":"2026-06-28 20:22","name":"法国国际广播电台","title":"德黑兰 - 迪拜航线周一起恢复运营","content":"据伊朗媒体周日报道，继因中东战事及伊朗在海湾地区的军事打击行动而停飞数周后，德黑兰与迪拜之间的航班将于周一（6月29日）恢复。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260628-%E5%BE%B7%E9%BB%91%E5%85%B0-%E8%BF%AA%E6%8B%9C%E8%88%AA%E7%BA%BF%E5%91%A8%E4%B8%80%E8%B5%B7%E6%81%A2%E5%A4%8D%E8%BF%90%E8%90%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782678132000.webp","sourceId":"rfi"},{"id":1782677861000,"createdDate":"2026-06-28 20:17","name":"法国国际广播电台","title":"伊朗强争霍尔木兹管辖权","content":"继近期与美国的敌对行动升级后，伊朗周日发出警告称，任何试图选择霍尔木兹海峡内非沿伊朗海岸航线的行为，都有可能导致该地区“紧张局势加剧”。不过，德黑兰仅允许船只使用沿其海岸的一条特定航道，并威胁称将打击任何偏离该航道的船只。伊朗外交部长阿巴斯·阿拉格希（AbbasAraghchi）周日坚称，除伊朗外，“没有任何其他机构或国家”有权“负责”管理该海峡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260628-%E4%BC%8A%E6%9C%97%E5%BC%BA%E4%BA%89%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E7%AE%A1%E8%BE%96%E6%9D%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782677861000.webp","sourceId":"rfi"},{"id":1782677684000,"createdDate":"2026-06-28 20:14","name":"法国国际广播电台","title":"马克龙将与阿曼苏丹会面","content":"阿曼苏丹国苏丹海赛姆·本·塔里克·阿勒赛义德陛下28日已抵达法国，进行为期两天的正式访问。据爱丽舍宫消息，马克龙总统将于周一中午在爱丽舍宫迎接苏丹。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260628-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%B0%86%E4%B8%8E%E9%98%BF%E6%9B%BC%E8%8B%8F%E4%B8%B9%E4%BC%9A%E9%9D%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782677684000.webp","sourceId":"rfi"},{"id":1782677355000,"createdDate":"2026-06-28 20:09","name":"法国国际广播电台","title":"普京：由于乌的袭击     燃料存在“一定程度的短缺”","content":"俄罗斯总统普京周日在克里姆林宫发布的一段采访中承认，由于基辅反复袭击俄罗斯的碳氢化合物基础设施——旨在削弱莫斯科的战争能力——导致了燃料“一定程度的短缺”。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260628-%E6%99%AE%E4%BA%AC-%E7%94%B1%E4%BA%8E%E4%B9%8C%E7%9A%84%E8%A2%AD%E5%87%BB-%E7%87%83%E6%96%99%E5%AD%98%E5%9C%A8-%E4%B8%80%E5%AE%9A%E7%A8%8B%E5%BA%A6%E7%9A%84%E7%9F%AD%E7%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782677355000.webp","sourceId":"rfi"},{"id":1782673486000,"createdDate":"2026-06-28 19:04","name":"法国国际广播电台","title":"普京被指与前线脱节，俄军单月兵员损失或超苏联十年阿富汗战争","content":"由于本台订阅的法国主流日刊周日大多不出刊，我们在本期法国报纸摘要节目中为您选取出刊的法国世界报的重点内容做综述。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260628-%E6%99%AE%E4%BA%AC%E8%A2%AB%E6%8C%87%E4%B8%8E%E5%89%8D%E7%BA%BF%E8%84%B1%E8%8A%82%EF%BC%8C%E4%BF%84%E5%86%9B%E5%8D%95%E6%9C%88%E5%85%B5%E5%91%98%E6%8D%9F%E5%A4%B1%E6%88%96%E8%B6%85%E8%8B%8F%E8%81%94%E5%8D%81%E5%B9%B4%E9%98%BF%E5%AF%8C%E6%B1%97%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782673486000.webp","sourceId":"rfi"},{"id":1782670438000,"createdDate":"2026-06-28 18:13","name":"法国国际广播电台","title":"2026世界杯1/16决赛有9支非洲队","content":"2026年世界杯1/16决赛于06月28日星期天拉开帷战幕。32支国家级足球队中，有9支出自非洲。这轮赛事预计为期一个星期。其中，本周日的首场和下周六的最后一场赛事均有出自非洲的国家足球队参赛。06月28日星期天的首场比赛由南非（AfriqueduSud）对阵加拿大(Canada)。对决结果是南非（AfriqueduSud）以0：1败北。07月04日下星期六的收官赛，则由加纳(Ghana)迎战哥伦比亚(Colombie)。2022年上届世界杯的卫冕冠军阿根廷（Argentine）将对阵本届赛事的黑马佛得角（Cap-Vert）。上届亚军法国队（France）则将迎战瑞典队(Suède)。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260628-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-2026%E4%B8%96%E7%95%8C%E6%9D%AF1-16%E5%86%B3%E8%B5%9B%E6%9C%899%E6%94%AF%E9%9D%9E%E6%B4%B2%E9%98%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782670438000.webp","sourceId":"rfi"},{"id":1782668948000,"createdDate":"2026-06-28 17:49","name":"法国国际广播电台","title":"特朗普警告“伊朗将不复存在”　沃尔兹称美军将持续打击基础设施","content":"美国与伊朗脆弱的停火协议持续恶化，双方连日互控对方率先违反协议，波斯湾及霍尔木兹海峡（StraitofHormuz）再度爆发军事冲突。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260628-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AD%A6%E5%91%8A-%E4%BC%8A%E6%9C%97%E5%B0%86%E4%B8%8D%E5%A4%8D%E5%AD%98%E5%9C%A8-%E6%B2%83%E5%B0%94%E5%85%B9%E7%A7%B0%E7%BE%8E%E5%86%9B%E5%B0%86%E6%8C%81%E7%BB%AD%E6%89%93%E5%87%BB%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782668948000.webp","sourceId":"rfi"},{"id":1782667308000,"createdDate":"2026-06-28 17:21","name":"法国国际广播电台","title":"刚果(金)首都邻省传出疟疾疫情","content":"刚果（金）东北部地区埃博拉疫情仍在持续之际，该国西部与首都金沙萨毗邻的奎卢省(Kwilu)自05月底以来出现一种疾病，造成十多人死亡。当局一度担心发生最糟糕的状况。但最终经刚果（金）[国家生物医学研究所]（INRB-L'institutnationalderecherchebiomédicale）确认，病源不是埃博拉疫情（Ebola）,而是疟疾（Paludisme）。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260628-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%88%9A%E6%9E%9C-%E9%87%91-%E9%A6%96%E9%83%BD%E9%82%BB%E7%9C%81%E4%BC%A0%E5%87%BA%E7%96%9F%E7%96%BE%E7%96%AB%E6%83%85","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782667308000.webp","sourceId":"rfi"},{"id":1782667301000,"createdDate":"2026-06-28 17:21","name":"法国国际广播电台","title":"尼斯市由于炎热的天气取消铁人三项比赛","content":"法国受持续高温天气的影响，取消了部分文化活动和体育赛事。据《尼斯晨报》（Nice-Matin）报道，尼斯铁人三项比赛被取消之后，一些报名爱好者表示不理解，他们自行组织起来，准备按原线路自行参赛。一名男子选手违反禁令，骑车时和迎面驶来的摩托车相撞后不幸身亡。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260628-%E5%B0%BC%E6%96%AF%E5%B8%82%E7%94%B1%E4%BA%8E%E7%82%8E%E7%83%AD%E7%9A%84%E5%A4%A9%E6%B0%94%E5%8F%96%E6%B6%88%E9%93%81%E4%BA%BA%E4%B8%89%E9%A1%B9%E6%AF%94%E8%B5%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782667301000.webp","sourceId":"rfi"},{"id":1782665988000,"createdDate":"2026-06-28 16:59","name":"法国国际广播电台","title":"乌干达军政权强行关闭独立媒体","content":"乌干达的军事首席官，穆胡佐·凯纳鲁加巴（MuhooziKainerugaba）下令28日凌晨开始关闭电视台、报社和广播电台。《每日观察报》（DailyMonitor）还透露说，新闻媒体受军管，武装士兵已驻扎在首都坎帕拉的总部外，NTV和SparkTV均已停播。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260628-%E4%B9%8C%E5%B9%B2%E8%BE%BE%E5%86%9B%E6%94%BF%E6%9D%83%E5%BC%BA%E8%A1%8C%E5%85%B3%E9%97%AD%E7%8B%AC%E7%AB%8B%E5%AA%92%E4%BD%93","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782665988000.webp","sourceId":"rfi"}]