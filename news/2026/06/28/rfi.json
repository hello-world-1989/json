[{"id":1782638383000,"createdDate":"2026-06-28 09:19","name":"法国国际广播电台","title":"武契奇称将在数周内辞去总统职位提前选举 有意重当总理？","content":"塞尔维亚总统武契奇（AleksandarVučić）周六表示，在经历了长达18个月的反政府抗议活动后，他将在数周内辞职，该国也将提前举行总统和议会选举。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260628-%E6%AD%A6%E5%A5%91%E5%A5%87%E7%A7%B0%E5%B0%86%E5%9C%A8%E6%95%B0%E5%91%A8%E5%86%85%E8%BE%9E%E5%8E%BB%E6%80%BB%E7%BB%9F%E8%81%8C%E4%BD%8D%E6%8F%90%E5%89%8D%E9%80%89%E4%B8%BE-%E6%9C%89%E6%84%8F%E5%86%8D%E5%BD%93%E6%80%BB%E7%90%86","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782638383000.webp","sourceId":"rfi"},{"id":1782637919000,"createdDate":"2026-06-28 09:11","name":"法国国际广播电台","title":"世界杯小组赛结束，16强淘汰赛周日拉开帷幕","content":"截至国际标准时间周六（6月27日）晚，世界杯小组赛72场比赛已全部结束。这也意味着真正的较量开始了，南非与加拿大将于国际标准时间19点率先登场，为16强淘汰赛揭开序幕。赛程过半，让我们一起盘点一下过去两周最值得关注的看点都有什么？","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260628-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%B0%8F%E7%BB%84%E8%B5%9B%E7%BB%93%E6%9D%9F%EF%BC%8C16%E5%BC%BA%E6%B7%98%E6%B1%B0%E8%B5%9B%E5%91%A8%E6%97%A5%E6%8B%89%E5%BC%80%E5%B8%B7%E5%B9%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782637919000.webp","sourceId":"rfi"},{"id":1782633313000,"createdDate":"2026-06-28 07:55","name":"法国国际广播电台","title":"中俄战机在日本周边联合飞行示威 日战机紧急起飞应对","content":"日本防卫省表示，已确认中国军队和俄罗斯军队的轰炸机于27日在日本周边进行了联合飞行，飞行范围从东海上空延伸至四国近海的太平洋上空等区域，对此，日本航空自卫队西部航空方面队等部队紧急出动战斗机进行应对，防卫省认为，此次行动“明显试图对日本进行示威”，已通过外交渠道向中俄两国表达严重关切，并持续保持警戒监视。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260628-%E4%B8%AD%E4%BF%84%E6%88%98%E6%9C%BA%E5%9C%A8%E6%97%A5%E6%9C%AC%E5%91%A8%E8%BE%B9%E8%81%94%E5%90%88%E9%A3%9E%E8%A1%8C%E7%A4%BA%E5%A8%81-%E6%97%A5%E6%88%98%E6%9C%BA%E7%B4%A7%E6%80%A5%E8%B5%B7%E9%A3%9E%E5%BA%94%E5%AF%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/28/1782633313000.webp","sourceId":"rfi"}]