[{"id":1781427248000,"createdDate":"2026-06-14 08:54","name":"法国国际广播电台","title":"台湾国安局设网路平台 供中国民众提供情报线索","content":"台湾国家安全局15日宣布，正式启用「中国民众联繫窗口」网站，鼓励中国民众透过安全管道向台湾提供政治、军事、经济及社会等相关情报。此举正值两岸关係持续紧张之际，引发外界关注。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260614-%E5%8F%B0%E6%B9%BE%E5%9B%BD%E5%AE%89%E5%B1%80%E8%AE%BE%E7%BD%91%E8%B7%AF%E5%B9%B3%E5%8F%B0-%E4%BE%9B%E4%B8%AD%E5%9B%BD%E6%B0%91%E4%BC%97%E6%8F%90%E4%BE%9B%E6%83%85%E6%8A%A5%E7%BA%BF%E7%B4%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781427248000.webp","sourceId":"rfi"},{"id":1781427231000,"createdDate":"2026-06-14 08:53","name":"法国国际广播电台","title":"巴西世界杯首战踢平非洲劲旅摩洛哥 苏格兰1比0险胜海地","content":"世界杯C组首轮迎来一场焦点对战，巴西队在纽约大都会人寿体育场1比1战平摩洛哥队。维尼修斯打入关键进球，让“桑巴军团”避免了首战失利，而表现出色的摩洛哥则遗憾错失爆冷取胜的机会。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260614-%E5%B7%B4%E8%A5%BF%E4%B8%96%E7%95%8C%E6%9D%AF%E9%A6%96%E6%88%98%E8%B8%A2%E5%B9%B3%E9%9D%9E%E6%B4%B2%E5%8A%B2%E6%97%85%E6%91%A9%E6%B4%9B%E5%93%A5-%E8%8B%8F%E6%A0%BC%E5%85%B01%E6%AF%940%E9%99%A9%E8%83%9C%E6%B5%B7%E5%9C%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781427231000.webp","sourceId":"rfi"},{"id":1781455675000,"createdDate":"2026-06-14 16:47","name":"法国国际广播电台","title":"2026欧洲国际防务展：乌克兰展商暴增 无人机导弹技术备受瞩目","content":"欧洲国际防务展（Eurosatory）6月15日-19日在巴黎北郊维勒班特（Villepinte）举行。法新社说，乌克兰的无人机，机器人和远程打击系统的实战经验将成为各国争相取经的重点。此外，以色列公司也获准在今年的展会上展示其防御性武器。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260614-2026%E6%AC%A7%E6%B4%B2%E5%9B%BD%E9%99%85%E9%98%B2%E5%8A%A1%E5%B1%95-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%B1%95%E5%95%86%E6%9A%B4%E5%A2%9E-%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%AF%BC%E5%BC%B9%E6%8A%80%E6%9C%AF%E5%A4%87%E5%8F%97%E7%9E%A9%E7%9B%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781455675000.webp","sourceId":"rfi"},{"id":1781449618000,"createdDate":"2026-06-14 15:06","name":"法国国际广播电台","title":"反G7示威在日内瓦登场: 反法西斯、反帝国主义","content":"法国埃维昂G7峰会前夕，左翼反G7联盟（NO-G7）在日内瓦举行抗议示威，警方严阵以待，尽管此刻距2003年G8峰会期间发生的暴力事件已过去二十余年。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260614-%E5%8F%8Dg7%E7%A4%BA%E5%A8%81%E5%9C%A8%E6%97%A5%E5%86%85%E7%93%A6%E7%99%BB%E5%9C%BA-%E5%8F%8D%E6%B3%95%E8%A5%BF%E6%96%AF-%E5%8F%8D%E5%B8%9D%E5%9B%BD%E4%B8%BB%E4%B9%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781449618000.webp","sourceId":"rfi"},{"id":1781445290000,"createdDate":"2026-06-14 13:54","name":"法国国际广播电台","title":"菲律宾地震后 海床抬升两米 珊瑚生态遭灭顶之灾","content":"菲律宾环境部周日宣布，本周初袭击菲律宾南部的强烈致命地震，导致部分沿海地区的海床抬升了高达两米。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260614-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%9C%B0%E9%9C%87%E5%90%8E-%E6%B5%B7%E5%BA%8A%E6%8A%AC%E5%8D%87%E4%B8%A4%E7%B1%B3-%E7%8F%8A%E7%91%9A%E7%94%9F%E6%80%81%E9%81%AD%E7%81%AD%E9%A1%B6%E4%B9%8B%E7%81%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781445290000.webp","sourceId":"rfi"},{"id":1781441295000,"createdDate":"2026-06-14 12:48","name":"法国国际广播电台","title":"美伊停战协议周日即将签署？","content":"美国与伊朗似乎再次接近达成协议，结束已为时三个多月的中东战争，但签署时间依旧各有说辞。美国总统特朗普和协调国之一的巴基斯坦都表示，协议将于本周日（6月14日）签署，然而，伊朗外交方面并未给予证实，其发言人提到未来几天签署的可能，但明确不会是周日。而在伊朗国内，强硬派示威者也公开表达反对与美国达成协议。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260614-%E7%BE%8E%E4%BC%8A%E5%81%9C%E6%88%98%E5%8D%8F%E8%AE%AE%E5%91%A8%E6%97%A5%E7%AD%BE%E7%BD%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781441295000.webp","sourceId":"rfi"},{"id":1781439644000,"createdDate":"2026-06-14 12:20","name":"法国国际广播电台","title":"美国继续与伊朗“即将”达成协议 卡塔尔代表团抵达德黑兰","content":"唐纳德·特朗普表示，美国将于周日与伊朗签署一项协议，以结束中东战争，并计划立即重新开放霍尔木兹海峡，但德黑兰方面目前尚未证实这一消息。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260614-%E7%BE%8E%E5%9B%BD%E7%BB%A7%E7%BB%AD%E4%B8%8E%E4%BC%8A%E6%9C%97-%E5%8D%B3%E5%B0%86-%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE-%E5%8D%A1%E5%A1%94%E5%B0%94%E4%BB%A3%E8%A1%A8%E5%9B%A2%E6%8A%B5%E8%BE%BE%E5%BE%B7%E9%BB%91%E5%85%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781439644000.webp","sourceId":"rfi"},{"id":1781433146000,"createdDate":"2026-06-14 10:32","name":"法国国际广播电台","title":"中国在缅甸打造“中华和平” 《世界报》解析北京的战略盘算","content":"今天法国媒体关注三个截然不同却同样引人注目的话题：瑞士就是否限制人口增长举行全民公投；中国如何透过调停缅甸内战巩固自身地缘战略利益；以及美国总统特朗普以一场综合格斗赛来庆祝自己80岁生日。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260614-%E4%B8%AD%E5%9B%BD%E8%B0%83%E5%81%9C%E7%BC%85%E7%94%B8%E5%86%B2%E7%AA%81-%E4%B8%96%E7%95%8C%E6%8A%A5-%E5%8C%97%E4%BA%AC%E6%89%93%E9%80%A0-%E4%B8%AD%E5%8D%8E%E5%92%8C%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781433146000.webp","sourceId":"rfi"},{"id":1781432804000,"createdDate":"2026-06-14 10:26","name":"法国国际广播电台","title":"日英首脑宣言草案曝光 对恣意限制稀土等出口表示“严重关切”","content":"日本首相高市早苗于日本时间14日乘坐政府转机抵达英国伦敦郊外的斯坦斯特德机场。她将于日本时间14日夜在伦敦与斯塔默首相举行会谈。双方拟发表的有关经济安全保障的首脑宣言草案内容已经曝光。高市首相表示，为将作为“强化后的全球战略伙伴”的日英合作提升至新的高度，双方计划就经济安全保障（包括能源领域）、尖端技术以及安全保障领域的合作展开讨论。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260614-%E6%97%A5%E8%8B%B1%E9%A6%96%E8%84%91%E5%AE%A3%E8%A8%80%E8%8D%89%E6%A1%88%E6%9B%9D%E5%85%89-%E5%AF%B9%E6%81%A3%E6%84%8F%E9%99%90%E5%88%B6%E7%A8%80%E5%9C%9F%E7%AD%89%E5%87%BA%E5%8F%A3%E8%A1%A8%E7%A4%BA-%E4%B8%A5%E9%87%8D%E5%85%B3%E5%88%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781432804000.webp","sourceId":"rfi"},{"id":1781429178000,"createdDate":"2026-06-14 09:26","name":"法国国际广播电台","title":"伦敦宣布英军与法国合作拦截了一艘俄罗斯“幽灵舰队”油轮","content":"英国国防部宣布，周日，英军在英吉利海峡拦截了一艘隶属于俄罗斯“幽灵船队”的油轮，此次行动是与法国“密切合作”进行的。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260614-%E4%BC%A6%E6%95%A6%E5%AE%A3%E5%B8%83%E8%8B%B1%E5%86%9B%E4%B8%8E%E6%B3%95%E5%9B%BD%E5%90%88%E4%BD%9C%E6%8B%A6%E6%88%AA%E4%BA%86%E4%B8%80%E8%89%98%E4%BF%84%E7%BD%97%E6%96%AF-%E5%B9%BD%E7%81%B5%E8%88%B0%E9%98%9F-%E6%B2%B9%E8%BD%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781429178000.webp","sourceId":"rfi"},{"id":1781479059000,"createdDate":"2026-06-14 23:17","name":"法国国际广播电台","title":"七国集团还有多大影响力？","content":"七国集团峰会周一在法国阿尔卑斯山麓的埃维昂开幕，峰会持续三天，特朗普在内的七国领袖悉数与会，主席国法国为峰会确定了两大优先事项：重振国际伙伴关系和国家间团结，以及缓解全球宏观经济失衡。下面我们介绍一下七国集团的现状和影响力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260614-%E4%B8%83%E5%9B%BD%E9%9B%86%E5%9B%A2%E8%BF%98%E6%9C%89%E5%A4%9A%E5%A4%A7%E5%BD%B1%E5%93%8D%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781479059000.webp","sourceId":"rfi"},{"id":1781478556000,"createdDate":"2026-06-14 23:09","name":"法国国际广播电台","title":"世界杯：荷兰日本强强对决 2比2战平","content":"世界杯足球赛周日晚迎来非常精彩的一场对抗，F组欧洲劲旅与亚洲强队日本对抗，荷兰队下半场率先破门，赛前痛失队长远藤航的日本队奋起直追，最终与大部分时间保持领先的荷兰战平。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260614-%E4%B8%96%E7%95%8C%E6%9D%AF-%E8%8D%B7%E5%85%B0%E6%97%A5%E6%9C%AC%E5%BC%BA%E5%BC%BA%E5%AF%B9%E5%86%B3-2%E6%AF%942%E6%88%98%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781478556000.webp","sourceId":"rfi"},{"id":1781477861000,"createdDate":"2026-06-14 22:57","name":"法国国际广播电台","title":"美伊停战协议是否像明斯克协议一样糟糕","content":"美国总统特朗普说：美伊停战协议要签了，要签了，周六说周日签，周日还剩几小时了，特朗普称，尽管签字进程被以色列轰炸贝鲁特打断了，但是，再过几个小时肯定签 !特朗普刚刚宣布，签了 !正式签字仪式19日在瑞士举行。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260614-%E7%BE%8E%E4%BC%8A%E5%81%9C%E6%88%98%E5%8D%8F%E8%AE%AE%E6%98%AF%E5%90%A6%E5%83%8F%E6%98%8E%E6%96%AF%E5%85%8B%E5%8D%8F%E8%AE%AE%E4%B8%80%E6%A0%B7%E7%B3%9F%E7%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781477861000.webp","sourceId":"rfi"},{"id":1781476272000,"createdDate":"2026-06-14 22:31","name":"法国国际广播电台","title":"法国将迎新一轮酷热天气 巴黎气温预计升至37摄氏度","content":"法国气象局预测，法国本周将迎来新一轮高温天气，气温水平可能超过5月底，并有可能出现2026年以来首场符合官方定义的”热浪“。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260614-%E6%B3%95%E5%9B%BD%E5%B0%86%E8%BF%8E%E6%96%B0%E4%B8%80%E8%BD%AE%E9%85%B7%E7%83%AD%E5%A4%A9%E6%B0%94-%E5%B7%B4%E9%BB%8E%E6%B0%94%E6%B8%A9%E9%A2%84%E8%AE%A1%E5%8D%87%E8%87%B337%E6%91%84%E6%B0%8F%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781476272000.webp","sourceId":"rfi"},{"id":1781476008000,"createdDate":"2026-06-14 22:26","name":"法国国际广播电台","title":"瑞士公投否决人口上限提案","content":"瑞士选民周日(6月14日）在全民公投中否决了一项旨在将全国人口控制在1000万人以内的提案。选民最终选择维护经济稳定和与欧盟的关系，而非支持限制移民以缓解公共服务和住房压力的主张。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260614-%E7%91%9E%E5%A3%AB%E5%85%AC%E6%8A%95%E5%90%A6%E5%86%B3%E4%BA%BA%E5%8F%A3%E4%B8%8A%E9%99%90%E6%8F%90%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781476008000.webp","sourceId":"rfi"},{"id":1781475666000,"createdDate":"2026-06-14 22:21","name":"法国国际广播电台","title":"特朗普称美伊协议即将签署 伊朗威胁报复贝鲁特空袭","content":"美国总统特朗普周日（6月14日）表示，美国与伊朗旨在结束中东战争的协议将在“数小时内”签署，特朗普称，以色列当天对黎巴嫩首都贝鲁特南郊发动空袭，导致协议进程受到延误。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260614-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E7%BE%8E%E4%BC%8A%E5%8D%8F%E8%AE%AE%E5%8D%B3%E5%B0%86%E7%AD%BE%E7%BD%B2-%E4%BC%8A%E6%9C%97%E5%A8%81%E8%83%81%E6%8A%A5%E5%A4%8D%E8%B4%9D%E9%B2%81%E7%89%B9%E7%A9%BA%E8%A2%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781475666000.webp","sourceId":"rfi"},{"id":1781474382000,"createdDate":"2026-06-14 21:59","name":"法国国际广播电台","title":"美国强拉硬拽，正在把拉美国家重新纳入自己的势力范围","content":"自特朗普第二任期以来，从加勒比海到南美大陆，美国政府对拉丁美洲国家频频祭出制裁、吊销签证等措施，如今，大多数拉丁美洲国家虽然没有公开站队美国，但也不得不配合特朗普政府的要求。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%9B%BD%E9%99%85%E7%BA%B5%E6%A8%AA/20260614-%E7%BE%8E%E5%9B%BD%E5%BC%BA%E6%8B%89%E7%A1%AC%E6%8B%BD%EF%BC%8C%E6%AD%A3%E5%9C%A8%E6%8A%8A%E6%8B%89%E7%BE%8E%E5%9B%BD%E5%AE%B6%E9%87%8D%E6%96%B0%E7%BA%B3%E5%85%A5%E8%87%AA%E5%B7%B1%E7%9A%84%E5%8A%BF%E5%8A%9B%E8%8C%83%E5%9B%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781474382000.webp","sourceId":"rfi"},{"id":1781474139000,"createdDate":"2026-06-14 21:55","name":"法国国际广播电台","title":"特朗普：美伊协议已最终敲定 霍尔木兹海峡恢复开放","content":"美国总统特朗普周日（6月14日）确认，与伊朗达成的旨在结束中东冲突的协议已“最终敲定”，特朗普并宣布重新开放霍尔木兹海峡，同时立即解除美国实施的海上封锁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260614-%E7%89%B9%E6%9C%97%E6%99%AE-%E7%BE%8E%E4%BC%8A%E5%8D%8F%E8%AE%AE%E5%B7%B2%E6%9C%80%E7%BB%88%E6%95%B2%E5%AE%9A-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%81%A2%E5%A4%8D%E5%BC%80%E6%94%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781474139000.webp","sourceId":"rfi"},{"id":1781473007000,"createdDate":"2026-06-14 21:36","name":"法国国际广播电台","title":"普京和泽连斯基分别与特朗普通话讨论乌克兰问题","content":"乌克兰总统泽连斯基和俄罗斯总统普京周日（6月14日）分别与美国总统特朗普通电话，祝贺他80岁生日，并就乌克兰冲突交换意见。与此同时，俄罗斯方面透露，美国特使即将再次访问俄罗斯。克里姆林宫公布了普京致特朗普生日贺词，普京盛赞特朗普为“杰出而卓越的人物和政治家”，并表示希望俄美关系迈上新台阶。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260614-%E6%99%AE%E4%BA%AC%E5%92%8C%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%88%86%E5%88%AB%E4%B8%8E%E7%94%B5%E7%89%B9%E6%9C%97%E6%99%AE%E9%80%9A%E8%AF%9D%E8%AE%A8%E8%AE%BA%E4%B9%8C%E5%85%8B%E5%85%B0%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781473007000.webp","sourceId":"rfi"},{"id":1781472640000,"createdDate":"2026-06-14 21:30","name":"法国国际广播电台","title":"马克龙抵达埃维昂 G7峰会聚焦乌克兰与中东局势","content":"法国总统马克龙周日（6月14日）抵达法国东部温泉小镇埃维昂，准备主持七国集团（G7）峰会。与此同时，在毗邻法国边境的瑞士日内瓦，反G7示威者与警方在联合国总部附近爆发冲突。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260614-%E9%A9%AC%E5%85%8B%E9%BE%99%E6%8A%B5%E8%BE%BE%E5%9F%83%E7%BB%B4%E6%98%82-g7%E5%B3%B0%E4%BC%9A%E8%81%9A%E7%84%A6%E4%B9%8C%E5%85%8B%E5%85%B0%E4%B8%8E%E4%B8%AD%E4%B8%9C%E5%B1%80%E5%8A%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781472640000.webp","sourceId":"rfi"},{"id":1781467686000,"createdDate":"2026-06-14 20:08","name":"法国国际广播电台","title":"2026世界杯:摩洛哥国足首战增色","content":"2026年世界杯（CoupeduMonde）足球赛不负众望，摩洛哥国家队首战表现出色，以1比1战平颇有盛名的巴西国足。这场比赛不仅让广大观众们大饱眼福，也受到国际舆论的普遍好评。本台法广（RFI）[非洲足球]（AfriqueFoot）在今天（2026年06月14号星期日）刊出法语特派记者（Envoyéspécial）发自纽约（NewYork）的一篇最新球评。这篇文章的标题为[2026世界杯：富有魅力，摩洛哥撼动巴西]（CoupeduMonde2026:séduisant,leMarocbousculeleBrésil）。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260614-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2%E4%BD%93%E8%82%B2-2026%E4%B8%96%E7%95%8C%E6%9D%AF-%E6%91%A9%E6%B4%9B%E5%93%A5%E5%9B%BD%E8%B6%B3%E9%A6%96%E6%88%98%E7%94%9F%E8%89%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781467686000.webp","sourceId":"rfi"},{"id":1781466777000,"createdDate":"2026-06-14 19:52","name":"法国国际广播电台","title":"马达加斯加暂停征收机动车税","content":"印度洋中的非洲岛国马达加斯加（Madagascar），面对[Z世代](GenZ)运动的示威号召，肩负[重筑]（refondation）之责的现政府宣布暂停实施在前政府执政期间拟定的机动车新税征收计划。这是本台法广非洲组（RFIAfrique）2026年06月14日星期天的最新法文消息之一。马达加斯加的两大车手俱乐部原计划要在周日举行另一场集会。","newsLink":"https://www.rfi.fr/cn/rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E9%A9%AC%E8%BE%BE%E5%8A%A0%E6%96%AF%E5%8A%A0%E6%9A%82%E5%81%9C%E5%BE%81%E6%94%B6%E6%9C%BA%E5%8A%A8%E8%BD%A6%E7%A8%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/14/1781466777000.webp","sourceId":"rfi"}]