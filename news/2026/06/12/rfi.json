[{"id":1781255846000,"createdDate":"2026-06-12 09:17","name":"法国国际广播电台","title":"世界杯首日战况：墨西哥2-0取胜南非  韩国2-1逆转捷克","content":"周四（6月12日）美加墨世界杯首日，在气氛热烈的阿兹特克体育场，墨西哥国家队于以2-0的成绩击败南非队，赢得了2026年世界杯的开幕战。而在阿克伦体育场，情况则相对胶着，但最终韩国队战胜捷克队，逆转晋级。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260612-%E4%B8%96%E7%95%8C%E6%9D%AF%E9%A6%96%E6%97%A5%E6%88%98%E5%86%B5-%E5%A2%A8%E8%A5%BF%E5%93%A52-0%E5%8F%96%E8%83%9C%E5%8D%97%E9%9D%9E-%E9%9F%A9%E5%9B%BD2-1%E9%80%86%E8%BD%AC%E6%8D%B7%E5%85%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781255846000.webp","sourceId":"rfi"},{"id":1781254191000,"createdDate":"2026-06-12 08:49","name":"法国国际广播电台","title":"洪都拉斯议会宣布全面监管与中国相关企业检讨与中关系 台洪复交声音再起","content":"洪都拉斯2023年与台湾断交转向中国后，却面临白虾出口暴跌、对中贸易逆差扩大等现实挑战。亲中路线成效备受质疑、重返台湾的声音再起，洪都拉斯正站在外交十字路口。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260612-%E6%B4%AA%E9%83%BD%E6%8B%89%E6%96%AF%E8%AE%AE%E4%BC%9A%E5%AE%A3%E5%B8%83%E5%85%A8%E9%9D%A2%E7%9B%91%E7%AE%A1%E4%B8%8E%E4%B8%AD%E5%9B%BD%E7%9B%B8%E5%85%B3%E4%BC%81%E4%B8%9A%E6%A3%80%E8%AE%A8%E4%B8%8E%E4%B8%AD%E5%85%B3%E7%B3%BB-%E5%8F%B0%E6%B4%AA%E5%A4%8D%E4%BA%A4%E5%A3%B0%E9%9F%B3%E5%86%8D%E8%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781254191000.webp","sourceId":"rfi"},{"id":1781253264000,"createdDate":"2026-06-12 08:34","name":"法国国际广播电台","title":"特朗普取消空袭：德黑兰称尚未对美方提出的协议做出决定","content":"德黑兰周五表示，尚未就美国总统宣布的旨在结束战争的协议作出决定，此举缓和了唐纳德·特朗普此前关于“本周末”即可签署协议的言论。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260612-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%96%E6%B6%88%E7%A9%BA%E8%A2%AD-%E5%BE%B7%E9%BB%91%E5%85%B0%E7%A7%B0%E5%B0%9A%E6%9C%AA%E5%AF%B9%E7%BE%8E%E6%96%B9%E6%8F%90%E5%87%BA%E7%9A%84%E5%8D%8F%E8%AE%AE%E5%81%9A%E5%87%BA%E5%86%B3%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781253264000.webp","sourceId":"rfi"},{"id":1781248724000,"createdDate":"2026-06-12 07:18","name":"法国国际广播电台","title":"日本首相访问欧洲各国 参加G7峰会","content":"日本内阁官房长官木原稔在12日的记者会上宣布，日本首相高市早苗将于13日至18日访问欧洲，并出席在法国埃维昂举行的七国集团（G7）首脑峰会。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260612-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E8%AE%BF%E9%97%AE%E6%AC%A7%E6%B4%B2%E5%90%84%E5%9B%BD-%E5%8F%82%E5%8A%A0g7%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781248724000.webp","sourceId":"rfi"},{"id":1781248353000,"createdDate":"2026-06-12 07:12","name":"法国国际广播电台","title":"时差影响香港世界杯经济熱度 商家各出奇謀吸客","content":"今届世界杯经济除了受到冒牌货品大增威胁之馀，更须面对球赛时间与港人作息时间不合拍的影响，酒吧和商场虽仍然会直播或转播赛事，但对营业额可以增加多少，不少抱观望态度或预计只能有轻微上升；相反，一些以早市为主的茶楼食肆，则破例转播赛事以吸客。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260612-%E6%97%B6%E5%B7%AE%E5%BD%B1%E5%93%8D%E9%A6%99%E6%B8%AF%E4%B8%96%E7%95%8C%E6%9D%AF%E7%BB%8F%E6%B5%8E%E7%86%B1%E5%BA%A6-%E5%95%86%E5%AE%B6%E5%90%84%E5%87%BA%E5%A5%87%E8%AC%80%E5%90%B8%E5%AE%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781248353000.webp","sourceId":"rfi"},{"id":1781248057000,"createdDate":"2026-06-12 07:07","name":"法国国际广播电台","title":"世界杯开锣 香港共截1.62亿元冒牌球衣等货品 较上届颷升1.6倍 多出口美洲","content":"四年一度的世界杯刚於香港时间今(12日)天凌晨开锣，海关於开锣前夕公布打击世界杯相关的冒牌货品行动成绩，在过去两星期内一共侦破34宗案件，检获约23万件怀疑冒牌物品，估计总市值高达1.56亿港元(下同，折算约为1722万欧元)，并拘捕六名男子。但与过往不同，检获的怀疑冒牌货品中，近八成将运往美洲地区。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260612-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%BC%80%E9%94%A3-%E9%A6%99%E6%B8%AF%E5%85%B1%E6%88%AA1-62%E4%BA%BF%E5%85%83%E5%86%92%E7%89%8C%E7%90%83%E8%A1%A3%E7%AD%89%E8%B4%A7%E5%93%81-%E8%BE%83%E4%B8%8A%E5%B1%8A%E9%A2%B7%E5%8D%871-6%E5%80%8D-%E5%A4%9A%E5%87%BA%E5%8F%A3%E7%BE%8E%E6%B4%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781248057000.webp","sourceId":"rfi"},{"id":1781283713000,"createdDate":"2026-06-12 17:01","name":"法国国际广播电台","title":"[法语世界]:巴黎举办[非洲时尚]展","content":"欢迎您进入法国国际广播电台（RadioFranceInternationale）中文节目[法语世界]（Chroniquefrancophonie）专栏2026年06月12日星期五第159集。本次节目我们简介正在法国首都巴黎凯布朗利博物馆（lemuséeduQuaiBranly-JacquesChirac）举办的[非洲时尚]展（AfricaFashion）。借此契机，联合国教科文组织(UNESCO)和平、创新与创作大使(l’ambassadeurdel’Unescopourlapaix,l’innovationetlacréation)、非洲著名时装设计师阿尔法迪（Alphadi）接受了本台法广（RFI）法语[百分之百创作]（100%création）专栏记者的采访。另外，凯布朗利博物馆主管非洲文化遗产的女负责人MmeHélèneJoubert也接受本台法广文化组（RFICulture）记者的现场采访。这集节目由尼古拉编译和播报，感谢收听。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C/20260612-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C-%E7%AC%AC159%E9%9B%86-%E6%B3%95%E5%9B%BD%E9%A6%96%E9%83%BD%E5%B7%B4%E9%BB%8E%E4%B8%BE%E5%8A%9E-%E9%9D%9E%E6%B4%B2%E6%97%B6%E5%B0%9A-%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781283713000.webp","sourceId":"rfi"},{"id":1781280618000,"createdDate":"2026-06-12 16:10","name":"法国国际广播电台","title":"2026世界杯亚洲区前瞻：新军亮相 强队争辉","content":"本届世界杯，亚洲足球迎来了两张全新的面孔。乌兹别克斯坦和约旦首次晋级，将迎来属于自己的世界杯首秀。这不仅是两国足球发展的重要里程碑，也展现出亚洲足球版图正在不断扩展，越来越多球队开始向世界舞台发起冲击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260612-2026%E4%B8%96%E7%95%8C%E6%9D%AF%E4%BA%9A%E6%B4%B2%E5%8C%BA%E5%89%8D%E7%9E%BB-%E6%96%B0%E5%86%9B%E4%BA%AE%E7%9B%B8-%E5%BC%BA%E9%98%9F%E4%BA%89%E8%BE%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781280618000.webp","sourceId":"rfi"},{"id":1781280247000,"createdDate":"2026-06-12 16:04","name":"法国国际广播电台","title":"乌克兰袭俄境至少两人死 普京称基辅加剧袭击旨在“分裂”俄罗斯社会","content":"据当地当局称，周四至周五夜间，乌克兰的袭击在与乌克兰接壤的俄罗斯布良斯克州造成两人死亡、两人受伤。普京会见士兵时表示乌克兰加剧无人机袭击旨在分裂俄罗斯社会。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260612-%E4%B9%8C%E5%85%8B%E5%85%B0%E8%A2%AD%E4%BF%84%E5%A2%83%E8%87%B3%E5%B0%91%E4%B8%A4%E4%BA%BA%E6%AD%BB-%E6%99%AE%E4%BA%AC%E7%A7%B0%E5%9F%BA%E8%BE%85%E5%8A%A0%E5%89%A7%E8%A2%AD%E5%87%BB%E6%97%A8%E5%9C%A8-%E5%88%86%E8%A3%82-%E4%BF%84%E7%BD%97%E6%96%AF%E7%A4%BE%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781280247000.webp","sourceId":"rfi"},{"id":1781278635000,"createdDate":"2026-06-12 15:37","name":"法国国际广播电台","title":"中国正在青海山区建设“世界最大天文基地”","content":"位于太平洋的夏威夷州夏威夷岛上的莫纳克亚山(MaunaKea)火山脚下的世界最闻名的天文台，今后其大噪的名声极其光彩可能会被遮蔽吗？ 因目前中国政府正在青藏高原上建造“世界最大天文台”。它将配备两台新型光学望远镜，而这两台望远镜已被誉为地球上最强大的望远镜。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260612-%E4%B8%AD%E5%9B%BD%E6%AD%A3%E5%9C%A8%E9%9D%92%E6%B5%B7%E5%B1%B1%E5%8C%BA%E5%BB%BA%E8%AE%BE-%E4%B8%96%E7%95%8C%E6%9C%80%E5%A4%A7%E5%A4%A9%E6%96%87%E5%9F%BA%E5%9C%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781278635000.webp","sourceId":"rfi"},{"id":1781278435000,"createdDate":"2026-06-12 15:33","name":"法国国际广播电台","title":"亚美尼亚亲俄反对派要求推翻议会选举的结果，国际选举观察组织表示大多数投票站的投票过程都很顺利","content":"亚美尼亚亲俄反对派周五要求推翻6月7日议会选举的结果，他们向国家选举委员会提交了请愿书。6月7日的选举由执政的亲西方“公民契约党”赢得。“强大亚美尼亚党”成员瓦尔德瓦尼扬说，请愿书由他们的党提交。与此同时，反对派团体谴责投票过程中存在违规行为。一个国际选举观察组织注意到了有关违规行为的指控，并表示大多数投票站的投票过程都很顺利。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260612-%E4%BA%9A%E7%BE%8E%E5%B0%BC%E4%BA%9A%E4%BA%B2%E4%BF%84%E5%8F%8D%E5%AF%B9%E6%B4%BE%E8%A6%81%E6%B1%82%E6%8E%A8%E7%BF%BB%E8%AE%AE%E4%BC%9A%E9%80%89%E4%B8%BE%E7%9A%84%E7%BB%93%E6%9E%9C%EF%BC%8C%E5%9B%BD%E9%99%85%E9%80%89%E4%B8%BE%E8%A7%82%E5%AF%9F%E7%BB%84%E7%BB%87%E8%A1%A8%E7%A4%BA%E5%A4%A7%E5%A4%9A%E6%95%B0%E6%8A%95%E7%A5%A8%E7%AB%99%E7%9A%84%E6%8A%95%E7%A5%A8%E8%BF%87%E7%A8%8B%E9%83%BD%E5%BE%88%E9%A1%BA%E5%88%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781278435000.webp","sourceId":"rfi"},{"id":1781274425000,"createdDate":"2026-06-12 14:27","name":"法国国际广播电台","title":"美国多艘核动力潜艇将于今年部署至澳大利亚","content":"澳大利亚国防部长周五表示，美国海军今年将在澳大利亚海军的一个战略港口部署多艘核动力潜艇。据美官员称，潜艇将驻扎珀斯附近，使美国海军能够更接近南中国海。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260612-%E7%BE%8E%E5%9B%BD%E5%A4%9A%E8%89%98%E6%A0%B8%E5%8A%A8%E5%8A%9B%E6%BD%9C%E8%89%87%E5%B0%86%E4%BA%8E%E4%BB%8A%E5%B9%B4%E9%83%A8%E7%BD%B2%E8%87%B3%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781274425000.webp","sourceId":"rfi"},{"id":1781274184000,"createdDate":"2026-06-12 14:23","name":"法国国际广播电台","title":"伊朗国足在地缘政治漩涡中的两难选择","content":"去年底今年初伊朗国内大规模的民间抗争运动早已被当局铁腕镇压。美国和以色列试图推翻伊朗神权政权的战争尚没有结束。伊朗国家足球队则已经奔赴美洲，准备参赛。围绕入境签证、赛场国旗等诸多争议之外，伊朗球队最艰难的选择是他们究竟为谁而战？是为近年来不断勇敢抗争的伊朗同胞，还是为不惜铁腕镇压民间不满的神权政府？","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260612-%E4%BC%8A%E6%9C%97%E5%9B%BD%E8%B6%B3%E5%9C%A8%E5%9C%B0%E7%BC%98%E6%94%BF%E6%B2%BB%E6%BC%A9%E6%B6%A1%E4%B8%AD%E7%9A%84%E4%B8%A4%E9%9A%BE%E9%80%89%E6%8B%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781274184000.webp","sourceId":"rfi"},{"id":1781271728000,"createdDate":"2026-06-12 13:42","name":"法国国际广播电台","title":"缅甸总统敏昂莱下周访问中国","content":"中国外交部周五宣布，缅甸新任总统敏昂莱(MinAungHlaing)将于下周对中国进行正式访问。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260612-%E7%BC%85%E7%94%B8%E6%80%BB%E7%BB%9F%E6%95%8F%E6%98%82%E8%8E%B1%E4%B8%8B%E5%91%A8%E8%AE%BF%E9%97%AE%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781271728000.webp","sourceId":"rfi"},{"id":1781270280000,"createdDate":"2026-06-12 13:18","name":"法国国际广播电台","title":"G7商界领袖在巴黎称：面对中国“不能简单地加征关税”，世贸改革却有必要","content":"继法国企业联合会主席帕特里克·马丁周三在法国外交部大楼主持了七国集团商界领袖会议后，据《回声报》周四晚报道，尽管承认中国制造商存在不公平贸易行为，七国集团的商界领袖却极不愿征收关税。相反地，他们主张改革世界贸易组织。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260612-g7%E5%95%86%E7%95%8C%E9%A2%86%E8%A2%96%E5%9C%A8%E5%B7%B4%E9%BB%8E%E7%A7%B0-%E9%9D%A2%E5%AF%B9%E4%B8%AD%E5%9B%BD-%E4%B8%8D%E8%83%BD%E7%AE%80%E5%8D%95%E5%9C%B0%E5%8A%A0%E5%BE%81%E5%85%B3%E7%A8%8E-%EF%BC%8C%E4%B8%96%E8%B4%B8%E6%94%B9%E9%9D%A9%E5%8D%B4%E6%9C%89%E5%BF%85%E8%A6%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781270280000.webp","sourceId":"rfi"},{"id":1781268014000,"createdDate":"2026-06-12 12:40","name":"法国国际广播电台","title":"中国法院正在推翻因采人工智能导致的裁员：但企业仍悄悄进行裁员","content":"各位听众，近来在中国，一些法院正在推翻企业因采用人工智能而导致的裁员；但企业仍继续悄悄地进行裁员。根据中国法律，企业裁员超过员工总数的10%必须获得政府批准。然而，花旗银行在最近的一份报告中估计，由于人工智能的影响，中国近10%的工作岗位面临着被取代的高风险；数据显示约7000万个。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260612-%E4%B8%AD%E5%9B%BD%E6%B3%95%E9%99%A2%E6%AD%A3%E5%9C%A8%E6%8E%A8%E7%BF%BB%E5%9B%A0%E9%87%87%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E5%AF%BC%E8%87%B4%E7%9A%84%E8%A3%81%E5%91%98-%E4%BD%86%E4%BC%81%E4%B8%9A%E4%BB%8D%E6%82%84%E6%82%84%E8%BF%9B%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781268014000.webp","sourceId":"rfi"},{"id":1781267069000,"createdDate":"2026-06-12 12:24","name":"法国国际广播电台","title":"美伊局势再转弯 特朗普宣布与伊朗接近达成协议","content":"美国与伊朗持续数月的军事对峙与外交角力，可能正迎来重大转折。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260612-%E7%BE%8E%E4%BC%8A%E5%B1%80%E5%8A%BF%E5%86%8D%E8%BD%AC%E5%BC%AF-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AE%A3%E5%B8%83%E4%B8%8E%E4%BC%8A%E6%9C%97%E6%8E%A5%E8%BF%91%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781267069000.webp","sourceId":"rfi"},{"id":1781266746000,"createdDate":"2026-06-12 12:19","name":"法国国际广播电台","title":"强制遣返、边境拘留、第三国安置  欧洲正式开启非法移民大遣返时代","content":"从本周五（6月12日）开始，欧盟将正式实施一套新的规则，这条名为《欧洲移民与庇护公约》（EuropeanMigrationandAsylumPact）的文件将规范27个成员国如何处理非法移民和寻求庇护者的问题。如果从现有数据来看，在欧盟，目前平均只有20%的遣返决定真正得到执行，也就是说80%的决定最终没有落实。因此，强制执行驱逐非法移民是这项新公约的核心。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260612-%E5%BC%BA%E5%88%B6%E9%81%A3%E8%BF%94-%E8%BE%B9%E5%A2%83%E6%8B%98%E7%95%99-%E7%AC%AC%E4%B8%89%E5%9B%BD%E5%AE%89%E7%BD%AE-%E6%AC%A7%E6%B4%B2%E6%AD%A3%E5%BC%8F%E5%BC%80%E5%90%AF%E9%9D%9E%E6%B3%95%E7%A7%BB%E6%B0%91%E5%A4%A7%E9%81%A3%E8%BF%94%E6%97%B6%E4%BB%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781266746000.webp","sourceId":"rfi"},{"id":1781266671000,"createdDate":"2026-06-12 12:17","name":"法国国际广播电台","title":"中国证实扣留一名“涉谍”美国公民 美媒称系研究缅甸问题的学者","content":"中国周五证实，因涉嫌从事间谍活动，扣留了一名美国公民。法新社说，该美国公民系某个缅甸问题研究机构的分析师吴敏辛(UMinZin)，他于6月3日在云南省昆明机场被捕。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260612-%E4%B8%AD%E5%9B%BD%E8%AF%81%E5%AE%9E%E6%89%A3%E7%95%99%E4%B8%80%E5%90%8D-%E6%B6%89%E8%B0%8D-%E7%BE%8E%E5%9B%BD%E5%85%AC%E6%B0%91-%E7%BE%8E%E5%AA%92%E7%A7%B0%E7%B3%BB%E7%A0%94%E7%A9%B6%E7%BC%85%E7%94%B8%E9%97%AE%E9%A2%98%E7%9A%84%E5%AD%A6%E8%80%85","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781266671000.webp","sourceId":"rfi"},{"id":1781264843000,"createdDate":"2026-06-12 11:47","name":"法国国际广播电台","title":"马斯克旗下SpaceX在华尔街IPO蓄势“一飞冲天” 有人横插一杠","content":"马斯克旗下的SpaceX今天周五完成史上规模最大IPO（首次公开募），大小投资者对该公司热情高涨，预示此次上市将大获成功。但有美国参议员叫停此次上市...","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260612-spacex%E5%9C%A8%E5%8D%8E%E5%B0%94%E8%A1%97ipo%E8%93%84%E5%8A%BF-%E4%B8%80%E9%A3%9E%E5%86%B2%E5%A4%A9-%E6%9C%89%E4%BA%BA%E6%A8%AA%E6%8F%92%E4%B8%80%E6%9D%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781264843000.webp","sourceId":"rfi"},{"id":1781260696000,"createdDate":"2026-06-12 10:38","name":"法国国际广播电台","title":"不止是腐败：为何中国奥运总能夺金，却一再无缘世界杯？","content":"大家好，欢迎收听法国报纸摘要，针对周四登场的世界杯与赛事新闻继续成为周五6月12日法国各大日报的关注焦点。《十字架报》体育版登出一篇解析中国为何又错过了世界杯的报道：尽管投入了数十亿人民币，且习近平曾雄心勃勃地提出要在2050年前将中国打造为“足球超级大国”，但国家队再次未能获得2026年世界杯的参赛资格。报道指出，中国足球正在为腐败付出的代价，这种腐败不仅蚕食了这项运动，也严重损害了其形象。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260612-%E4%B8%8D%E6%AD%A2%E6%98%AF%E8%85%90%E8%B4%A5-%E4%B8%BA%E4%BD%95%E4%B8%AD%E5%9B%BD%E5%A5%A5%E8%BF%90%E6%80%BB%E8%83%BD%E5%A4%BA%E9%87%91%EF%BC%8C%E5%8D%B4%E4%B8%80%E5%86%8D%E6%97%A0%E7%BC%98%E4%B8%96%E7%95%8C%E6%9D%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781260696000.webp","sourceId":"rfi"}]