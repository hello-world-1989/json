[{"id":1781255846000,"createdDate":"2026-06-12 09:17","name":"法国国际广播电台","title":"世界杯首日战况：墨西哥2-0取胜南非  韩国2-1逆转捷克","content":"周四（6月12日）美加墨世界杯首日，在气氛热烈的阿兹特克体育场，墨西哥国家队于以2-0的成绩击败南非队，赢得了2026年世界杯的开幕战。而在阿克伦体育场，情况则相对胶着，但最终韩国队战胜捷克队，逆转晋级。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260612-%E4%B8%96%E7%95%8C%E6%9D%AF%E9%A6%96%E6%97%A5%E6%88%98%E5%86%B5-%E5%A2%A8%E8%A5%BF%E5%93%A52-0%E5%8F%96%E8%83%9C%E5%8D%97%E9%9D%9E-%E9%9F%A9%E5%9B%BD2-1%E9%80%86%E8%BD%AC%E6%8D%B7%E5%85%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781255846000.webp","sourceId":"rfi"},{"id":1781254191000,"createdDate":"2026-06-12 08:49","name":"法国国际广播电台","title":"洪都拉斯议会宣布全面监管与中国相关企业检讨与中关系 台洪复交声音再起","content":"洪都拉斯2023年与台湾断交转向中国后，却面临白虾出口暴跌、对中贸易逆差扩大等现实挑战。亲中路线成效备受质疑、重返台湾的声音再起，洪都拉斯正站在外交十字路口。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260612-%E6%B4%AA%E9%83%BD%E6%8B%89%E6%96%AF%E8%AE%AE%E4%BC%9A%E5%AE%A3%E5%B8%83%E5%85%A8%E9%9D%A2%E7%9B%91%E7%AE%A1%E4%B8%8E%E4%B8%AD%E5%9B%BD%E7%9B%B8%E5%85%B3%E4%BC%81%E4%B8%9A%E6%A3%80%E8%AE%A8%E4%B8%8E%E4%B8%AD%E5%85%B3%E7%B3%BB-%E5%8F%B0%E6%B4%AA%E5%A4%8D%E4%BA%A4%E5%A3%B0%E9%9F%B3%E5%86%8D%E8%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781254191000.webp","sourceId":"rfi"},{"id":1781253264000,"createdDate":"2026-06-12 08:34","name":"法国国际广播电台","title":"特朗普取消空袭：德黑兰称尚未对美方提出的协议做出决定","content":"德黑兰周五表示，尚未就美国总统宣布的旨在结束战争的协议作出决定，此举缓和了唐纳德·特朗普此前关于“本周末”即可签署协议的言论。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260612-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%96%E6%B6%88%E7%A9%BA%E8%A2%AD-%E5%BE%B7%E9%BB%91%E5%85%B0%E7%A7%B0%E5%B0%9A%E6%9C%AA%E5%AF%B9%E7%BE%8E%E6%96%B9%E6%8F%90%E5%87%BA%E7%9A%84%E5%8D%8F%E8%AE%AE%E5%81%9A%E5%87%BA%E5%86%B3%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781253264000.webp","sourceId":"rfi"},{"id":1781248724000,"createdDate":"2026-06-12 07:18","name":"法国国际广播电台","title":"日本首相访问欧洲各国 参加G7峰会","content":"日本内阁官房长官木原稔在12日的记者会上宣布，日本首相高市早苗将于13日至18日访问欧洲，并出席在法国埃维昂举行的七国集团（G7）首脑峰会。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260612-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E8%AE%BF%E9%97%AE%E6%AC%A7%E6%B4%B2%E5%90%84%E5%9B%BD-%E5%8F%82%E5%8A%A0g7%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781248724000.webp","sourceId":"rfi"},{"id":1781248353000,"createdDate":"2026-06-12 07:12","name":"法国国际广播电台","title":"时差影响香港世界杯经济熱度 商家各出奇謀吸客","content":"今届世界杯经济除了受到冒牌货品大增威胁之馀，更须面对球赛时间与港人作息时间不合拍的影响，酒吧和商场虽仍然会直播或转播赛事，但对营业额可以增加多少，不少抱观望态度或预计只能有轻微上升；相反，一些以早市为主的茶楼食肆，则破例转播赛事以吸客。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260612-%E6%97%B6%E5%B7%AE%E5%BD%B1%E5%93%8D%E9%A6%99%E6%B8%AF%E4%B8%96%E7%95%8C%E6%9D%AF%E7%BB%8F%E6%B5%8E%E7%86%B1%E5%BA%A6-%E5%95%86%E5%AE%B6%E5%90%84%E5%87%BA%E5%A5%87%E8%AC%80%E5%90%B8%E5%AE%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781248353000.webp","sourceId":"rfi"},{"id":1781248057000,"createdDate":"2026-06-12 07:07","name":"法国国际广播电台","title":"世界杯开锣 香港共截1.62亿元冒牌球衣等货品 较上届颷升1.6倍 多出口美洲","content":"四年一度的世界杯刚於香港时间今(12日)天凌晨开锣，海关於开锣前夕公布打击世界杯相关的冒牌货品行动成绩，在过去两星期内一共侦破34宗案件，检获约23万件怀疑冒牌物品，估计总市值高达1.56亿港元(下同，折算约为1722万欧元)，并拘捕六名男子。但与过往不同，检获的怀疑冒牌货品中，近八成将运往美洲地区。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260612-%E4%B8%96%E7%95%8C%E6%9D%AF%E5%BC%80%E9%94%A3-%E9%A6%99%E6%B8%AF%E5%85%B1%E6%88%AA1-62%E4%BA%BF%E5%85%83%E5%86%92%E7%89%8C%E7%90%83%E8%A1%A3%E7%AD%89%E8%B4%A7%E5%93%81-%E8%BE%83%E4%B8%8A%E5%B1%8A%E9%A2%B7%E5%8D%871-6%E5%80%8D-%E5%A4%9A%E5%87%BA%E5%8F%A3%E7%BE%8E%E6%B4%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/12/1781248057000.webp","sourceId":"rfi"}]