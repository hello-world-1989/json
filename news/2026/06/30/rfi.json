[{"id":1782812342000,"createdDate":"2026-06-30 09:39","name":"法国国际广播电台","title":"涉以不实文件将英伟达芯片服务器销中港澳 台检方搜超微电脑等3公司声押3人","content":"台湾基隆地检署侦办厂商涉嫌以不实文件，转卖搭载英伟达高阶芯片的服务器至中港澳，周一搜索超微电脑（Supermicro、台湾称美超微电脑）台湾亚太总部、青云科技、是方电讯，并约谈6人，经检察官复讯，周二凌晨声押3人。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260630-%E6%B6%89%E4%BB%A5%E4%B8%8D%E5%AE%9E%E6%96%87%E4%BB%B6%E5%B0%86%E8%8B%B1%E4%BC%9F%E8%BE%BE%E8%8A%AF%E7%89%87%E6%9C%8D%E5%8A%A1%E5%99%A8%E9%94%80%E4%B8%AD%E6%B8%AF%E6%BE%B3-%E5%8F%B0%E6%A3%80%E6%96%B9%E6%90%9C%E8%B6%85%E5%BE%AE%E7%94%B5%E8%84%91%E7%AD%893%E5%85%AC%E5%8F%B8%E5%A3%B0%E6%8A%BC3%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782812342000.webp","sourceId":"rfi"},{"id":1782810734000,"createdDate":"2026-06-30 09:12","name":"法国国际广播电台","title":"世界杯：摩洛哥点球大战淘汰荷兰率先晋级  日本1比2惜败巴西 无缘16强","content":"周一美加墨世界杯32强淘汰赛，“北非雄狮”摩洛哥队通过点球大战爆冷淘汰“橙子军团”荷兰队，成为本届世界杯首支晋级16强的非洲队。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260630-%E4%B8%96%E7%95%8C%E6%9D%AF-%E6%91%A9%E6%B4%9B%E5%93%A5%E7%82%B9%E7%90%83%E6%B7%98%E6%B1%B0%E8%8D%B7%E5%85%B0%E7%8E%87%E5%85%88%E6%99%8B%E7%BA%A716%E5%BC%BA-%E6%97%A5%E6%9C%AC1%E6%AF%942%E6%83%9C%E8%B4%A5%E5%B7%B4%E8%A5%BF-%E6%AD%A2%E6%AD%A532%E5%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782810734000.webp","sourceId":"rfi"},{"id":1782809753000,"createdDate":"2026-06-30 08:55","name":"法国国际广播电台","title":"摩纳哥发生包裹炸弹爆炸 一乌克兰寡头及两名亲属受重伤","content":"当地时间周二上午，摩纳哥及其周边地区出动了大量执法力量，试图缉拿周一晚间在该公国引发包裹炸弹爆炸案的嫌疑人。该事件造成一名乌克兰寡头及其两名亲属重伤。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260630-%E6%91%A9%E7%BA%B3%E5%93%A5%E5%8F%91%E7%94%9F%E5%8C%85%E8%A3%B9%E7%82%B8%E5%BC%B9%E7%88%86%E7%82%B8-%E4%B8%80%E4%B9%8C%E5%85%8B%E5%85%B0%E5%AF%A1%E5%A4%B4%E5%8F%8A%E4%B8%A4%E5%90%8D%E4%BA%B2%E5%B1%9E%E9%87%8D%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782809753000.webp","sourceId":"rfi"},{"id":1782808405000,"createdDate":"2026-06-30 08:33","name":"法国国际广播电台","title":"日本众议院通过增设“国旗损毁罪”法案","content":"日本为增设处罚损毁日本国旗行为的“国旗损毁罪”而提出的法案，于30日在日本众议院全体会议上进行表决，并以自民党、日本维新会等多数赞成获得通过。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260630-%E6%97%A5%E6%9C%AC%E4%BC%97%E8%AE%AE%E9%99%A2%E9%80%9A%E8%BF%87%E5%A2%9E%E8%AE%BE-%E5%9B%BD%E6%97%97%E6%8D%9F%E6%AF%81%E7%BD%AA-%E6%B3%95%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782808405000.webp","sourceId":"rfi"},{"id":1782806966000,"createdDate":"2026-06-30 08:09","name":"法国国际广播电台","title":"郭文贵欺诈上千支持中国民主人士被判30年，美国法官指其毫无悔意！","content":"曾和特朗普阵营关系紧密的中国流亡富豪郭文贵因欺诈上千人，周一29日在美国遭判刑30年。法官指控郭文贵利用支持中国民主的人士诈骗牟利，涉案金额高达10亿美元，且毫无悔意。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260630-%E9%83%AD%E6%96%87%E8%B4%B5%E6%AC%BA%E8%AF%88%E4%B8%8A%E5%8D%83%E6%94%AF%E6%8C%81%E4%B8%AD%E5%9B%BD%E6%B0%91%E4%B8%BB%E4%BA%BA%E5%A3%AB%E8%A2%AB%E5%88%A430%E5%B9%B4%EF%BC%8C%E7%BE%8E%E5%9B%BD%E6%B3%95%E5%AE%98%E6%8C%87%E5%85%B6%E6%AF%AB%E6%97%A0%E6%82%94%E6%84%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782806966000.webp","sourceId":"rfi"},{"id":1782805933000,"createdDate":"2026-06-30 07:52","name":"法国国际广播电台","title":"国安六周年：403人被捕 前民主党主席胡志伟出狱 评论批港府变得只向北京负责","content":"今(30日)天是《港区国安法》生效六周年的日子，港府至今已以国安法律拘捕403人，当中包括今日刑满出狱的前民主党主席兼议员胡志伟，他因参与涉及三代民主派人士为争取更大机会获得立法会过半议席而举行的民间初选丶但却被指触犯国安法中的串谋颠覆国家政权罪而入狱四年五个月。国际人权组织「人权观察」发表声明，指高压的国安法生效六年，加上官僚机构，已抹去港人过往一直受保护的权利，亦为香港的未来投下了令人深感不安的阴影。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260630-%E5%9B%BD%E5%AE%89%E5%85%AD%E5%91%A8%E5%B9%B4-403%E4%BA%BA%E8%A2%AB%E6%8D%95-%E5%89%8D%E6%B0%91%E4%B8%BB%E5%85%9A%E4%B8%BB%E5%B8%AD%E8%83%A1%E5%BF%97%E4%BC%9F%E5%87%BA%E7%8B%B1-%E8%AF%84%E8%AE%BA%E6%89%B9%E6%B8%AF%E5%BA%9C%E5%8F%98%E5%BE%97%E5%8F%AA%E5%90%91%E5%8C%97%E4%BA%AC%E8%B4%9F%E8%B4%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782805933000.webp","sourceId":"rfi"},{"id":1782802465000,"createdDate":"2026-06-30 06:54","name":"法国国际广播电台","title":"涉港国安案获释后首游日本遭扣查逾20小时 岑子杰：像被二次惩罚","content":"香港民主派初选「47人案」中，被判囚51个月的前民阵召集人岑子杰，已于去年刑满获释。他本月中与家人赴日旅游，在入境时遭日方扣查约20小时，旅游计划大受影响。他忆述事件时称，尊重日方的政策，但前线人员的应对，与日本政界支援香港民主派的立场存在差异，期望日方建立让政治犯申报的制度，使他们不会遭受像被二次惩罚的待遇。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260630-%E6%B6%89%E6%B8%AF%E5%9B%BD%E5%AE%89%E6%A1%88%E8%8E%B7%E9%87%8A%E5%90%8E%E9%A6%96%E6%B8%B8%E6%97%A5%E6%9C%AC%E9%81%AD%E6%89%A3%E6%9F%A5%E9%80%BE20%E5%B0%8F%E6%97%B6-%E5%B2%91%E5%AD%90%E6%9D%B0-%E5%83%8F%E8%A2%AB%E4%BA%8C%E6%AC%A1%E6%83%A9%E7%BD%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782802465000.webp","sourceId":"rfi"}]