[{"id":1782812342000,"createdDate":"2026-06-30 09:39","name":"法国国际广播电台","title":"涉以不实文件将英伟达芯片服务器销中港澳 台检方搜超微电脑等3公司声押3人","content":"台湾基隆地检署侦办厂商涉嫌以不实文件，转卖搭载英伟达高阶芯片的服务器至中港澳，周一搜索超微电脑（Supermicro、台湾称美超微电脑）台湾亚太总部、青云科技、是方电讯，并约谈6人，经检察官复讯，周二凌晨声押3人。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260630-%E6%B6%89%E4%BB%A5%E4%B8%8D%E5%AE%9E%E6%96%87%E4%BB%B6%E5%B0%86%E8%8B%B1%E4%BC%9F%E8%BE%BE%E8%8A%AF%E7%89%87%E6%9C%8D%E5%8A%A1%E5%99%A8%E9%94%80%E4%B8%AD%E6%B8%AF%E6%BE%B3-%E5%8F%B0%E6%A3%80%E6%96%B9%E6%90%9C%E8%B6%85%E5%BE%AE%E7%94%B5%E8%84%91%E7%AD%893%E5%85%AC%E5%8F%B8%E5%A3%B0%E6%8A%BC3%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782812342000.webp","sourceId":"rfi"},{"id":1782810734000,"createdDate":"2026-06-30 09:12","name":"法国国际广播电台","title":"世界杯：摩洛哥点球大战淘汰荷兰率先晋级  日本1比2惜败巴西 无缘16强","content":"周一美加墨世界杯32强淘汰赛，“北非雄狮”摩洛哥队通过点球大战爆冷淘汰“橙子军团”荷兰队，成为本届世界杯首支晋级16强的非洲队。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260630-%E4%B8%96%E7%95%8C%E6%9D%AF-%E6%91%A9%E6%B4%9B%E5%93%A5%E7%82%B9%E7%90%83%E6%B7%98%E6%B1%B0%E8%8D%B7%E5%85%B0%E7%8E%87%E5%85%88%E6%99%8B%E7%BA%A716%E5%BC%BA-%E6%97%A5%E6%9C%AC1%E6%AF%942%E6%83%9C%E8%B4%A5%E5%B7%B4%E8%A5%BF-%E6%AD%A2%E6%AD%A532%E5%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782810734000.webp","sourceId":"rfi"},{"id":1782809753000,"createdDate":"2026-06-30 08:55","name":"法国国际广播电台","title":"摩纳哥发生包裹炸弹爆炸 一乌克兰寡头及两名亲属受重伤","content":"当地时间周二上午，摩纳哥及其周边地区出动了大量执法力量，试图缉拿周一晚间在该公国引发包裹炸弹爆炸案的嫌疑人。该事件造成一名乌克兰寡头及其两名亲属重伤。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260630-%E6%91%A9%E7%BA%B3%E5%93%A5%E5%8F%91%E7%94%9F%E5%8C%85%E8%A3%B9%E7%82%B8%E5%BC%B9%E7%88%86%E7%82%B8-%E4%B8%80%E4%B9%8C%E5%85%8B%E5%85%B0%E5%AF%A1%E5%A4%B4%E5%8F%8A%E4%B8%A4%E5%90%8D%E4%BA%B2%E5%B1%9E%E9%87%8D%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782809753000.webp","sourceId":"rfi"},{"id":1782808405000,"createdDate":"2026-06-30 08:33","name":"法国国际广播电台","title":"日本众议院通过增设“国旗损毁罪”法案","content":"日本为增设处罚损毁日本国旗行为的“国旗损毁罪”而提出的法案，于30日在日本众议院全体会议上进行表决，并以自民党、日本维新会等多数赞成获得通过。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260630-%E6%97%A5%E6%9C%AC%E4%BC%97%E8%AE%AE%E9%99%A2%E9%80%9A%E8%BF%87%E5%A2%9E%E8%AE%BE-%E5%9B%BD%E6%97%97%E6%8D%9F%E6%AF%81%E7%BD%AA-%E6%B3%95%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782808405000.webp","sourceId":"rfi"},{"id":1782806966000,"createdDate":"2026-06-30 08:09","name":"法国国际广播电台","title":"郭文贵欺诈上千支持中国民主人士被判30年，美国法官指其毫无悔意！","content":"曾和特朗普阵营关系紧密的中国流亡富豪郭文贵因欺诈上千人，周一29日在美国遭判刑30年。法官指控郭文贵利用支持中国民主的人士诈骗牟利，涉案金额高达10亿美元，且毫无悔意。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260630-%E9%83%AD%E6%96%87%E8%B4%B5%E6%AC%BA%E8%AF%88%E4%B8%8A%E5%8D%83%E6%94%AF%E6%8C%81%E4%B8%AD%E5%9B%BD%E6%B0%91%E4%B8%BB%E4%BA%BA%E5%A3%AB%E8%A2%AB%E5%88%A430%E5%B9%B4%EF%BC%8C%E7%BE%8E%E5%9B%BD%E6%B3%95%E5%AE%98%E6%8C%87%E5%85%B6%E6%AF%AB%E6%97%A0%E6%82%94%E6%84%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782806966000.webp","sourceId":"rfi"},{"id":1782805933000,"createdDate":"2026-06-30 07:52","name":"法国国际广播电台","title":"国安六周年：403人被捕 前民主党主席胡志伟出狱 评论批港府变得只向北京负责","content":"今(30日)天是《港区国安法》生效六周年的日子，港府至今已以国安法律拘捕403人，当中包括今日刑满出狱的前民主党主席兼议员胡志伟，他因参与涉及三代民主派人士为争取更大机会获得立法会过半议席而举行的民间初选丶但却被指触犯国安法中的串谋颠覆国家政权罪而入狱四年五个月。国际人权组织「人权观察」发表声明，指高压的国安法生效六年，加上官僚机构，已抹去港人过往一直受保护的权利，亦为香港的未来投下了令人深感不安的阴影。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260630-%E5%9B%BD%E5%AE%89%E5%85%AD%E5%91%A8%E5%B9%B4-403%E4%BA%BA%E8%A2%AB%E6%8D%95-%E5%89%8D%E6%B0%91%E4%B8%BB%E5%85%9A%E4%B8%BB%E5%B8%AD%E8%83%A1%E5%BF%97%E4%BC%9F%E5%87%BA%E7%8B%B1-%E8%AF%84%E8%AE%BA%E6%89%B9%E6%B8%AF%E5%BA%9C%E5%8F%98%E5%BE%97%E5%8F%AA%E5%90%91%E5%8C%97%E4%BA%AC%E8%B4%9F%E8%B4%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782805933000.webp","sourceId":"rfi"},{"id":1782802465000,"createdDate":"2026-06-30 06:54","name":"法国国际广播电台","title":"涉港国安案获释后首游日本遭扣查逾20小时 岑子杰：像被二次惩罚","content":"香港民主派初选「47人案」中，被判囚51个月的前民阵召集人岑子杰，已于去年刑满获释。他本月中与家人赴日旅游，在入境时遭日方扣查约20小时，旅游计划大受影响。他忆述事件时称，尊重日方的政策，但前线人员的应对，与日本政界支援香港民主派的立场存在差异，期望日方建立让政治犯申报的制度，使他们不会遭受像被二次惩罚的待遇。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260630-%E6%B6%89%E6%B8%AF%E5%9B%BD%E5%AE%89%E6%A1%88%E8%8E%B7%E9%87%8A%E5%90%8E%E9%A6%96%E6%B8%B8%E6%97%A5%E6%9C%AC%E9%81%AD%E6%89%A3%E6%9F%A5%E9%80%BE20%E5%B0%8F%E6%97%B6-%E5%B2%91%E5%AD%90%E6%9D%B0-%E5%83%8F%E8%A2%AB%E4%BA%8C%E6%AC%A1%E6%83%A9%E7%BD%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782802465000.webp","sourceId":"rfi"},{"id":1782832589000,"createdDate":"2026-06-30 15:16","name":"法国国际广播电台","title":"保护本土钢铁行业：欧盟出台新的钢铁进口配额措施 周三起实施","content":"欧盟委员会周二公布了旨在限制免税钢铁进口至欧盟的新配额制度，此举意在保护欧盟钢铁行业并提高其产能利用率。根据新规，欧盟的年度免税进口配额被大幅削减47%，降至1830万吨；同时，针对进口至欧盟的26类钢铁产品，将对超出配额的部分征收50%的关税。欧盟委员会称，这项定于7月1日生效的规定旨在将欧盟钢铁行业的产能利用率提升至80%。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260630-%E4%BF%9D%E6%8A%A4%E6%9C%AC%E5%9C%9F%E9%92%A2%E9%93%81%E8%A1%8C%E4%B8%9A-%E6%AC%A7%E7%9B%9F%E5%87%BA%E5%8F%B0%E6%96%B0%E7%9A%84%E9%92%A2%E9%93%81%E8%BF%9B%E5%8F%A3%E9%85%8D%E9%A2%9D%E6%8E%AA%E6%96%BD-%E5%91%A8%E4%B8%89%E8%B5%B7%E5%AE%9E%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782832589000.webp","sourceId":"rfi"},{"id":1782831361000,"createdDate":"2026-06-30 14:56","name":"法国国际广播电台","title":"视频 中国最北端光热电站投入运营","content":"中国东北首座太阳能热电站开始运营，这也是中国最北第一座集中的热电太阳能发电厂（CSP），该项目位于吉林省大安，容量为100兆瓦，请看视频报道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260630-%E8%A7%86%E9%A2%91-%E4%B8%AD%E5%9B%BD%E6%9C%80%E5%8C%97%E7%AB%AF%E5%85%89%E7%83%AD%E7%94%B5%E7%AB%99%E6%8A%95%E5%85%A5%E8%BF%90%E8%90%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782831361000.webp","sourceId":"rfi"},{"id":1782830717000,"createdDate":"2026-06-30 14:45","name":"法国国际广播电台","title":"欧盟对价值低于150欧元的小包裹征收3欧元关税 周三起实施","content":"欧盟即将针对小额进口商品征收新税，这将对SHEIN、Temu和AliExpress等中国电商巨头产生重大影响。7月1日起，针对低值电商进口商品征收3欧元统一关税的规定将正式生效。在前，进口至欧盟且价值低于150欧元的商品均免征关税。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260630-%E6%AC%A7%E7%9B%9F%E5%AF%B9%E4%BB%B7%E5%80%BC%E4%BD%8E%E4%BA%8E150%E6%AC%A7%E5%85%83%E7%9A%84%E5%B0%8F%E5%8C%85%E8%A3%B9%E5%BE%81%E6%94%B63%E6%AC%A7%E5%85%83%E5%85%B3%E7%A8%8E-%E5%91%A8%E4%B8%89%E8%B5%B7%E5%AE%9E%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782830717000.webp","sourceId":"rfi"},{"id":1782827903000,"createdDate":"2026-06-30 13:58","name":"法国国际广播电台","title":"贝森特指对制裁的担忧使潜在买家避开伊朗石油：仍只有中国在购买","content":"美国财政部长贝森特（ScottBessent）周二在受访时表示，中国仍是伊朗石油的唯一买家，而其他国家则因担心华盛顿可能重新实施制裁而持谨慎态度。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260630-%E8%B4%9D%E6%A3%AE%E7%89%B9%E6%8C%87%E5%AF%B9%E5%88%B6%E8%A3%81%E7%9A%84%E6%8B%85%E5%BF%A7%E8%87%B4%E4%BD%BF%E6%BD%9C%E5%9C%A8%E4%B9%B0%E5%AE%B6%E9%81%BF%E5%BC%80%E4%BC%8A%E6%9C%97%E7%9F%B3%E6%B2%B9-%E4%BB%8D%E5%8F%AA%E6%9C%89%E4%B8%AD%E5%9B%BD%E5%9C%A8%E8%B4%AD%E4%B9%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782827903000.webp","sourceId":"rfi"},{"id":1782826793000,"createdDate":"2026-06-30 13:39","name":"法国国际广播电台","title":"美两党议员小组对制药商默克和艾伯维在华临床试验展开国安调查","content":"据路透社查阅的信函显示，美国国会一个跨党派议员小组已针对制药商默克（Merck）和艾伯维（AbbVie）展开国家安全调查，以查明这两家公司在华进行的临床试验是否助推了中国的军事能力。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260630-%E7%BE%8E%E4%B8%A4%E5%85%9A%E8%AE%AE%E5%91%98%E5%B0%8F%E7%BB%84%E5%AF%B9%E5%88%B6%E8%8D%AF%E5%95%86%E9%BB%98%E5%85%8B%E5%92%8C%E8%89%BE%E4%BC%AF%E7%BB%B4%E5%9C%A8%E5%8D%8E%E4%B8%B4%E5%BA%8A%E8%AF%95%E9%AA%8C%E5%B1%95%E5%BC%80%E5%9B%BD%E5%AE%89%E8%B0%83%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782826793000.webp","sourceId":"rfi"},{"id":1782825706000,"createdDate":"2026-06-30 13:21","name":"法国国际广播电台","title":"中国《民族团结法》7月上路将跨境镇压法律化 台湾内政部长：留意是否变统战","content":"台湾内政部长刘世芳29日警告，中共所推出的「宗教中国化」是由统战部处理，应多注意是否变成认知作战的一种。她指出，中共三不五时就告诉台湾「妈祖是中国人」，以及天上圣母、天公等。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260630-%E4%B8%AD%E5%9B%BD-%E6%B0%91%E6%97%8F%E5%9B%A2%E7%BB%93%E6%B3%95-7%E6%9C%88%E4%B8%8A%E8%B7%AF%E5%B0%86%E8%B7%A8%E5%A2%83%E9%95%87%E5%8E%8B%E6%B3%95%E5%BE%8B%E5%8C%96-%E5%8F%B0%E6%B9%BE%E5%86%85%E6%94%BF%E9%83%A8%E9%95%BF-%E7%95%99%E6%84%8F%E6%98%AF%E5%90%A6%E5%8F%98%E7%BB%9F%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782825706000.webp","sourceId":"rfi"},{"id":1782824938000,"createdDate":"2026-06-30 13:08","name":"法国国际广播电台","title":"卡塔尔称“未来几天美伊双方未排直接会晤” 内部先乱？革命卫队两成员命丧“恐袭”","content":"国际关注美伊多哈谈判究竟会不会如期举行？到本文截稿前，据来自德黑兰的消息，伊朗宣布今天30日将派遣代表团前往多哈，与美国进行技术性会晤，但不会与对方直接谈判。另一方面，华盛顿方面表示，特使维特科夫和库什纳将于“本周前往当地参加高级别会议”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260630-%E5%8D%A1%E5%A1%94%E5%B0%94%E7%A7%B0-%E6%9C%AA%E6%9D%A5%E5%87%A0%E5%A4%A9%E7%BE%8E%E4%BC%8A%E5%8F%8C%E6%96%B9%E6%9C%AA%E6%8E%92%E7%9B%B4%E6%8E%A5%E4%BC%9A%E6%99%A4-%E5%86%85%E9%83%A8%E5%85%88%E4%B9%B1-%E9%9D%A9%E5%91%BD%E5%8D%AB%E9%98%9F%E4%B8%A4%E6%88%90%E5%91%98%E5%91%BD%E4%B8%A7-%E6%81%90%E6%80%96%E8%A2%AD%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782824938000.webp","sourceId":"rfi"},{"id":1782823134000,"createdDate":"2026-06-30 12:38","name":"法国国际广播电台","title":"历史性气候判决 ：道达尔须对其顾客的碳排放承责","content":"巴黎法院在上周四6月25日，也就是法国在新一波热浪中气温最高的一天，宣布了道达尔集团的判决结果，法院裁定道达尔能源集团未能履行其在应对气候变化方面的义务，构成违法行为。这场延续了八年的诉讼案终于被画上了句号。  该案是法国首次对一家公司进行重大气候审判,必须指出的是，道达尔集团是世界第六大石油和天然气生产商，其开采以及产品使用所导致的碳排放仅在2025年就超过 3.35亿吨，八年前，巴黎市政府以及三家在法国的非政府组织将道达尔集团状告法庭，周四的裁决被气候活动人士认为是一次历史性的裁决，对其他企业具有参照意义，而道达尔集团也在判决的当天发表声明表示将研究法院判决的后续行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260630-%E5%8E%86%E5%8F%B2%E6%80%A7%E6%B0%94%E5%80%99%E5%AE%A1%E5%88%A4-%E9%81%93%E8%BE%BE%E5%B0%94%E9%A1%BB%E5%AF%B9%E5%85%B6%E9%A1%BE%E5%AE%A2%E7%9A%84%E7%A2%B3%E6%8E%92%E6%94%BE%E6%89%BF%E8%B4%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782823134000.webp","sourceId":"rfi"},{"id":1782823054000,"createdDate":"2026-06-30 12:37","name":"法国国际广播电台","title":"厄尔尼诺现象还是全球变暖 ？","content":"太平洋的热量正迅速释放，持续升温，可能在未来数月触发异常强烈的厄尔尼诺，或将增强并改变全球多地的天气，让一些地区将出现洪水与暴雨，另一些地区将经历干旱与火灾，而全球变暖的总体步伐可能因此加速，请看视频报道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260630-%E8%A7%86%E9%A2%91-%E5%8E%84%E5%B0%94%E5%B0%BC%E8%AF%BA%E7%8E%B0%E8%B1%A1%E8%BF%98%E6%98%AF%E5%85%A8%E7%90%83%E5%8F%98%E6%9A%96","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782823054000.webp","sourceId":"rfi"},{"id":1782823034000,"createdDate":"2026-06-30 12:37","name":"法国国际广播电台","title":"小儿子获北大本科毕业证书 卢卡申科：没想到家里会出生物技术专家","content":"白俄罗斯总统亚卢卡申科的小儿子尼古拉周二（30日）在北京大学获得了毕业证书。这一消息来自白俄罗斯国立大学与北京大学生物技术本科联合培养项目毕业生的毕业典礼视频。典礼视频由与白俄罗斯总统新闻处有关的“电报”频道发布。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260630-%E5%B0%8F%E5%84%BF%E5%AD%90%E8%8E%B7%E5%8C%97%E5%A4%A7%E6%9C%AC%E7%A7%91%E6%AF%95%E4%B8%9A%E8%AF%81%E4%B9%A6-%E5%8D%A2%E5%8D%A1%E7%94%B3%E7%A7%91-%E6%B2%A1%E6%83%B3%E5%88%B0%E5%AE%B6%E9%87%8C%E4%BC%9A%E5%87%BA%E4%B8%80%E4%BD%8D%E7%94%9F%E7%89%A9%E6%8A%80%E6%9C%AF%E4%B8%93%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782823034000.webp","sourceId":"rfi"},{"id":1782820084000,"createdDate":"2026-06-30 11:48","name":"法国国际广播电台","title":"美游说机构放弃代理阿里、腾讯等上五角大楼清单巨头 遵守限游说新规","content":"华盛顿最具影响力的游说公司正竞相切断与阿里巴巴和腾讯等中国科技巨头的联系，因为美国出台的新限制措施正在重塑许多中国企业在华盛顿的影响力格局。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260630-%E7%BE%8E%E6%B8%B8%E8%AF%B4%E6%9C%BA%E6%9E%84%E6%94%BE%E5%BC%83%E4%BB%A3%E7%90%86%E9%98%BF%E9%87%8C-%E8%85%BE%E8%AE%AF%E7%AD%89%E4%B8%8A%E4%BA%94%E8%A7%92%E5%A4%A7%E6%A5%BC%E6%B8%85%E5%8D%95%E5%B7%A8%E5%A4%B4-%E9%81%B5%E5%AE%88%E9%99%90%E6%B8%B8%E8%AF%B4%E6%96%B0%E8%A7%84","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782820084000.webp","sourceId":"rfi"},{"id":1782814677000,"createdDate":"2026-06-30 10:17","name":"法国国际广播电台","title":"美做市商海纳起诉百人 指借中国整治跨境券商内幕信息获利逾1亿美元","content":"海纳投资集团（SusquehannaInvestmentGroup）正试图查明一批涉事人员的身份；该集团声称，这些人利用有关中国政府于5月打击跨境券商的内幕信息进行交易，获利至少1亿美元。","newsLink":"https://www.rfi.fr/cn/%E7%A4%BE%E4%BC%9A/20260630-%E7%BE%8E%E5%81%9A%E5%B8%82%E5%95%86%E6%B5%B7%E7%BA%B3%E8%B5%B7%E8%AF%89%E7%99%BE%E4%BA%BA-%E6%8C%87%E5%80%9F%E4%B8%AD%E5%9B%BD%E6%95%B4%E6%B2%BB%E8%B7%A8%E5%A2%83%E5%88%B8%E5%95%86%E5%86%85%E5%B9%95%E4%BF%A1%E6%81%AF%E8%8E%B7%E5%88%A9%E9%80%BE1%E4%BA%BF%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/30/1782814677000.webp","sourceId":"rfi"}]