[{"id":1781690998000,"createdDate":"2026-06-17 10:09","name":"法国国际广播电台","title":"世界杯首轮收官：纪录诞生、强队亮相，签证限制阴云笼罩","content":"2026年世界杯小组赛首轮全部结束，多支夺冠热门球队相继亮相，梅西、姆巴佩和哈兰德在首秀中集体爆发。第七个比赛日，葡萄牙队在K组迎来首场比赛，对手是刚果民主共和国。比赛在巴黎时间19时进行。另一场K组比赛中，首次参加世界杯的乌兹别克斯坦队于凌晨4时对阵哥伦比亚队。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260617-%E4%B8%96%E7%95%8C%E6%9D%AF%E9%A6%96%E8%BD%AE%E6%94%B6%E5%AE%98-%E7%BA%AA%E5%BD%95%E8%AF%9E%E7%94%9F-%E5%BC%BA%E9%98%9F%E4%BA%AE%E7%9B%B8%EF%BC%8C%E7%AD%BE%E8%AF%81%E9%99%90%E5%88%B6%E9%98%B4%E4%BA%91%E7%AC%BC%E7%BD%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781690998000.webp","sourceId":"rfi"},{"id":1781689415000,"createdDate":"2026-06-17 09:43","name":"法国国际广播电台","title":"美伊停战协议即将签署，黎巴嫩撤军问题成最大变数","content":"美国与伊朗即将签署止战协议，但在协议正式落地前，黎巴嫩问题正成为最大的争议焦点。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260617-%E7%BE%8E%E4%BC%8A%E5%81%9C%E6%88%98%E5%8D%8F%E8%AE%AE%E5%8D%B3%E5%B0%86%E7%AD%BE%E7%BD%B2%EF%BC%8C%E9%BB%8E%E5%B7%B4%E5%AB%A9%E6%92%A4%E5%86%9B%E9%97%AE%E9%A2%98%E6%88%90%E6%9C%80%E5%A4%A7%E5%8F%98%E6%95%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781689415000.webp","sourceId":"rfi"},{"id":1781687704000,"createdDate":"2026-06-17 09:15","name":"法国国际广播电台","title":"中国和欧盟会爆发贸易战吗？","content":"电动汽车、电池、太阳能电池板以及来自拼多多海外版Temu和全球速卖通（AliExpress）等电商平台的产品导致欧盟对华贸易逆差不断扩大，迫使布鲁塞尔寻求保护性措施，引发可能导致贸易战的疑虑。欧洲领导人将于周四召开峰会，预计讨论保护欧洲产业的解决方案。北京方面主张对话，但也表示已做好反制准备。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260617-%E4%B8%AD%E5%9B%BD%E5%92%8C%E6%AC%A7%E7%9B%9F%E4%BC%9A%E7%88%86%E5%8F%91%E8%B4%B8%E6%98%93%E6%88%98%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781687704000.webp","sourceId":"rfi"},{"id":1781687576000,"createdDate":"2026-06-17 09:12","name":"法国国际广播电台","title":"美联邦通信委员会改变政策 允许进口中国新款玩具无人机","content":"美国联邦通信委员会（FCC）周二表示，将允许进口中国新款玩具无人机。去年12月，FCC曾宣布禁止进口所有外国制造的新款无人机及其关键部件，包括来自大疆创新和道通智能的产品，理由是这些产品对美国国家安全构成不可接受的风险。此后，FCC已允许进口部分新款无人机。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260617-%E7%BE%8E%E8%81%94%E9%82%A6%E9%80%9A%E4%BF%A1%E5%A7%94%E5%91%98%E4%BC%9A%E6%94%B9%E5%8F%98%E6%94%BF%E7%AD%96-%E5%85%81%E8%AE%B8%E8%BF%9B%E5%8F%A3%E4%B8%AD%E5%9B%BD%E6%96%B0%E6%AC%BE%E7%8E%A9%E5%85%B7%E6%97%A0%E4%BA%BA%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781687576000.webp","sourceId":"rfi"},{"id":1781685936000,"createdDate":"2026-06-17 08:45","name":"法国国际广播电台","title":"美暂缓将DeepSeek、长鑫存储等逾100家企业列入出口管制实体清单","content":"据路透社援引两位知情人士报导称，美国暂缓将中国人工智能初创公司DeepSeek、存储芯片制造商长鑫存储以及其他100多家被列为国家安全风险的公司列入贸易黑名单，此举正值特朗普政府试图避免与北京的紧张关系升级。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260617-%E7%BE%8E%E6%9A%82%E7%BC%93%E5%B0%86deepseek-%E9%95%BF%E9%91%AB%E5%AD%98%E5%82%A8%E7%AD%89%E9%80%BE100%E5%AE%B6%E4%B8%AD%E4%BC%81%E5%88%97%E5%85%A5%E5%87%BA%E5%8F%A3%E7%AE%A1%E5%88%B6%E5%AE%9E%E4%BD%93%E6%B8%85%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781685936000.webp","sourceId":"rfi"},{"id":1781684912000,"createdDate":"2026-06-17 08:28","name":"法国国际广播电台","title":"台东县长录影参加中共海峡论坛宣传释迦踩红线 陆委会：将依两岸条例查处","content":"陆委会主邱垂正强调，海峡论坛是中共对台的统战平台，农渔产品变成统战工具。政府已说明好几次，禁止中央与地方公务人员以任何形式参加，并将以两岸关系条例查处。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260617-%E5%8F%B0%E4%B8%9C%E5%8E%BF%E9%95%BF%E5%BD%95%E5%BD%B1%E5%8F%82%E5%8A%A0%E4%B8%AD%E5%85%B1%E6%B5%B7%E5%B3%A1%E8%AE%BA%E5%9D%9B%E5%AE%A3%E4%BC%A0%E9%87%8A%E8%BF%A6%E8%B8%A9%E7%BA%A2%E7%BA%BF-%E9%99%86%E5%A7%94%E4%BC%9A-%E5%B0%86%E4%BE%9D%E4%B8%A4%E5%B2%B8%E6%9D%A1%E4%BE%8B%E6%9F%A5%E5%A4%84","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781684912000.webp","sourceId":"rfi"},{"id":1781680274000,"createdDate":"2026-06-17 07:11","name":"法国国际广播电台","title":"日法首脑会谈 高市早苗在G7峰会点名批判中国","content":"当地时间6月16日下午5时15分（日本时间17日凌晨0时15分）起约20分钟，为出席G7埃维昂峰会而访问法国的日本首相高市早苗，与法国总统埃马纽埃尔·马克龙举行了日法首脑会谈。当天，高市首相在包括印度、韩国等受邀国家参加的会议上表示：“对于中国针对日本采取的相关措施可能对七国集团（G7）及理念相近国家的供应链造成影响的局面，日本深感忧虑。”","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260617-%E6%97%A5%E6%B3%95%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88-%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E5%9C%A8g7%E5%B3%B0%E4%BC%9A%E7%82%B9%E5%90%8D%E6%89%B9%E5%88%A4%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781680274000.webp","sourceId":"rfi"},{"id":1781679646000,"createdDate":"2026-06-17 07:00","name":"法国国际广播电台","title":"保钓行动委员会前主席罗堪就病逝 香港保钓力量更凋零","content":"曾于2012年乘坐「启丰二号」登上钓鱼台的保钓行动委员会前主席罗堪就（又名罗就），昨(16日)晨病逝，终年77岁。这是继社运老将古思尧之后，再有一名曾登上钓鱼台的香港保钓人士离世。这位因为保钓而与港府诉讼并因此破产的社运人士，即使是亲中的政协人士，亦赞赏他对保钓的执着反映出其爱国精神。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260617-%E4%BF%9D%E9%92%93%E8%A1%8C%E5%8A%A8%E5%A7%94%E5%91%98%E4%BC%9A%E5%89%8D%E4%B8%BB%E5%B8%AD%E7%BD%97%E5%A0%AA%E5%B0%B1%E7%97%85%E9%80%9D-%E9%A6%99%E6%B8%AF%E4%BF%9D%E9%92%93%E5%8A%9B%E9%87%8F%E6%9B%B4%E5%87%8B%E9%9B%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781679646000.webp","sourceId":"rfi"},{"id":1781679393000,"createdDate":"2026-06-17 06:56","name":"法国国际广播电台","title":"香港贪污举报跌14% 惟宏福苑大火引发涉大维修工程贪污投诉反增1.6倍","content":"香港去年的清廉指数在「透明国际」的全球排行榜上名列第12位，而负责反贪腐的廉政公署数据亦显示，该署去年整体贪污举报数字下跌14%，不过，有关跌幅并非全面下跌的结果，涉及与宏福苑大火有关的楼宇维修工程贪污举报，在今年首四个月便较去年同期大增1.6倍，但有宏福苑居民认为，数字仅属冰山一角。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260617-%E9%A6%99%E6%B8%AF%E8%B4%AA%E6%B1%A1%E4%B8%BE%E6%8A%A5%E8%B7%8C14-%E6%83%9F%E5%AE%8F%E7%A6%8F%E8%8B%91%E5%A4%A7%E7%81%AB%E5%BC%95%E5%8F%91%E6%B6%89%E5%A4%A7%E7%BB%B4%E4%BF%AE%E5%B7%A5%E7%A8%8B%E8%B4%AA%E6%B1%A1%E6%8A%95%E8%AF%89%E5%8F%8D%E5%A2%9E1-6%E5%80%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781679393000.webp","sourceId":"rfi"}]