[{"id":1781690998000,"createdDate":"2026-06-17 10:09","name":"法国国际广播电台","title":"世界杯首轮收官：纪录诞生、强队亮相，签证限制阴云笼罩","content":"2026年世界杯小组赛首轮全部结束，多支夺冠热门球队相继亮相，梅西、姆巴佩和哈兰德在首秀中集体爆发。第七个比赛日，葡萄牙队在K组迎来首场比赛，对手是刚果民主共和国。比赛在巴黎时间19时进行。另一场K组比赛中，首次参加世界杯的乌兹别克斯坦队于凌晨4时对阵哥伦比亚队。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260617-%E4%B8%96%E7%95%8C%E6%9D%AF%E9%A6%96%E8%BD%AE%E6%94%B6%E5%AE%98-%E7%BA%AA%E5%BD%95%E8%AF%9E%E7%94%9F-%E5%BC%BA%E9%98%9F%E4%BA%AE%E7%9B%B8%EF%BC%8C%E7%AD%BE%E8%AF%81%E9%99%90%E5%88%B6%E9%98%B4%E4%BA%91%E7%AC%BC%E7%BD%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781690998000.webp","sourceId":"rfi"},{"id":1781689415000,"createdDate":"2026-06-17 09:43","name":"法国国际广播电台","title":"美伊停战协议即将签署，黎巴嫩撤军问题成最大变数","content":"美国与伊朗即将签署止战协议，但在协议正式落地前，黎巴嫩问题正成为最大的争议焦点。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260617-%E7%BE%8E%E4%BC%8A%E5%81%9C%E6%88%98%E5%8D%8F%E8%AE%AE%E5%8D%B3%E5%B0%86%E7%AD%BE%E7%BD%B2%EF%BC%8C%E9%BB%8E%E5%B7%B4%E5%AB%A9%E6%92%A4%E5%86%9B%E9%97%AE%E9%A2%98%E6%88%90%E6%9C%80%E5%A4%A7%E5%8F%98%E6%95%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781689415000.webp","sourceId":"rfi"},{"id":1781687704000,"createdDate":"2026-06-17 09:15","name":"法国国际广播电台","title":"中国和欧盟会爆发贸易战吗？","content":"电动汽车、电池、太阳能电池板以及来自拼多多海外版Temu和全球速卖通（AliExpress）等电商平台的产品导致欧盟对华贸易逆差不断扩大，迫使布鲁塞尔寻求保护性措施，引发可能导致贸易战的疑虑。欧洲领导人将于周四召开峰会，预计讨论保护欧洲产业的解决方案。北京方面主张对话，但也表示已做好反制准备。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260617-%E4%B8%AD%E5%9B%BD%E5%92%8C%E6%AC%A7%E7%9B%9F%E4%BC%9A%E7%88%86%E5%8F%91%E8%B4%B8%E6%98%93%E6%88%98%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781687704000.webp","sourceId":"rfi"},{"id":1781687576000,"createdDate":"2026-06-17 09:12","name":"法国国际广播电台","title":"美联邦通信委员会改变政策 允许进口中国新款玩具无人机","content":"美国联邦通信委员会（FCC）周二表示，将允许进口中国新款玩具无人机。去年12月，FCC曾宣布禁止进口所有外国制造的新款无人机及其关键部件，包括来自大疆创新和道通智能的产品，理由是这些产品对美国国家安全构成不可接受的风险。此后，FCC已允许进口部分新款无人机。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260617-%E7%BE%8E%E8%81%94%E9%82%A6%E9%80%9A%E4%BF%A1%E5%A7%94%E5%91%98%E4%BC%9A%E6%94%B9%E5%8F%98%E6%94%BF%E7%AD%96-%E5%85%81%E8%AE%B8%E8%BF%9B%E5%8F%A3%E4%B8%AD%E5%9B%BD%E6%96%B0%E6%AC%BE%E7%8E%A9%E5%85%B7%E6%97%A0%E4%BA%BA%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781687576000.webp","sourceId":"rfi"},{"id":1781685936000,"createdDate":"2026-06-17 08:45","name":"法国国际广播电台","title":"美暂缓将DeepSeek、长鑫存储等逾100家企业列入出口管制实体清单","content":"据路透社援引两位知情人士报导称，美国暂缓将中国人工智能初创公司DeepSeek、存储芯片制造商长鑫存储以及其他100多家被列为国家安全风险的公司列入贸易黑名单，此举正值特朗普政府试图避免与北京的紧张关系升级。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260617-%E7%BE%8E%E6%9A%82%E7%BC%93%E5%B0%86deepseek-%E9%95%BF%E9%91%AB%E5%AD%98%E5%82%A8%E7%AD%89%E9%80%BE100%E5%AE%B6%E4%B8%AD%E4%BC%81%E5%88%97%E5%85%A5%E5%87%BA%E5%8F%A3%E7%AE%A1%E5%88%B6%E5%AE%9E%E4%BD%93%E6%B8%85%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781685936000.webp","sourceId":"rfi"},{"id":1781684912000,"createdDate":"2026-06-17 08:28","name":"法国国际广播电台","title":"台东县长录影参加中共海峡论坛宣传释迦踩红线 陆委会：将依两岸条例查处","content":"陆委会主邱垂正强调，海峡论坛是中共对台的统战平台，农渔产品变成统战工具。政府已说明好几次，禁止中央与地方公务人员以任何形式参加，并将以两岸关系条例查处。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260617-%E5%8F%B0%E4%B8%9C%E5%8E%BF%E9%95%BF%E5%BD%95%E5%BD%B1%E5%8F%82%E5%8A%A0%E4%B8%AD%E5%85%B1%E6%B5%B7%E5%B3%A1%E8%AE%BA%E5%9D%9B%E5%AE%A3%E4%BC%A0%E9%87%8A%E8%BF%A6%E8%B8%A9%E7%BA%A2%E7%BA%BF-%E9%99%86%E5%A7%94%E4%BC%9A-%E5%B0%86%E4%BE%9D%E4%B8%A4%E5%B2%B8%E6%9D%A1%E4%BE%8B%E6%9F%A5%E5%A4%84","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781684912000.webp","sourceId":"rfi"},{"id":1781680274000,"createdDate":"2026-06-17 07:11","name":"法国国际广播电台","title":"日法首脑会谈 高市早苗在G7峰会点名批判中国","content":"当地时间6月16日下午5时15分（日本时间17日凌晨0时15分）起约20分钟，为出席G7埃维昂峰会而访问法国的日本首相高市早苗，与法国总统埃马纽埃尔·马克龙举行了日法首脑会谈。当天，高市首相在包括印度、韩国等受邀国家参加的会议上表示：“对于中国针对日本采取的相关措施可能对七国集团（G7）及理念相近国家的供应链造成影响的局面，日本深感忧虑。”","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260617-%E6%97%A5%E6%B3%95%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88-%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E5%9C%A8g7%E5%B3%B0%E4%BC%9A%E7%82%B9%E5%90%8D%E6%89%B9%E5%88%A4%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781680274000.webp","sourceId":"rfi"},{"id":1781679646000,"createdDate":"2026-06-17 07:00","name":"法国国际广播电台","title":"保钓行动委员会前主席罗堪就病逝 香港保钓力量更凋零","content":"曾于2012年乘坐「启丰二号」登上钓鱼台的保钓行动委员会前主席罗堪就（又名罗就），昨(16日)晨病逝，终年77岁。这是继社运老将古思尧之后，再有一名曾登上钓鱼台的香港保钓人士离世。这位因为保钓而与港府诉讼并因此破产的社运人士，即使是亲中的政协人士，亦赞赏他对保钓的执着反映出其爱国精神。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260617-%E4%BF%9D%E9%92%93%E8%A1%8C%E5%8A%A8%E5%A7%94%E5%91%98%E4%BC%9A%E5%89%8D%E4%B8%BB%E5%B8%AD%E7%BD%97%E5%A0%AA%E5%B0%B1%E7%97%85%E9%80%9D-%E9%A6%99%E6%B8%AF%E4%BF%9D%E9%92%93%E5%8A%9B%E9%87%8F%E6%9B%B4%E5%87%8B%E9%9B%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781679646000.webp","sourceId":"rfi"},{"id":1781679393000,"createdDate":"2026-06-17 06:56","name":"法国国际广播电台","title":"香港贪污举报跌14% 惟宏福苑大火引发涉大维修工程贪污投诉反增1.6倍","content":"香港去年的清廉指数在「透明国际」的全球排行榜上名列第12位，而负责反贪腐的廉政公署数据亦显示，该署去年整体贪污举报数字下跌14%，不过，有关跌幅并非全面下跌的结果，涉及与宏福苑大火有关的楼宇维修工程贪污举报，在今年首四个月便较去年同期大增1.6倍，但有宏福苑居民认为，数字仅属冰山一角。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260617-%E9%A6%99%E6%B8%AF%E8%B4%AA%E6%B1%A1%E4%B8%BE%E6%8A%A5%E8%B7%8C14-%E6%83%9F%E5%AE%8F%E7%A6%8F%E8%8B%91%E5%A4%A7%E7%81%AB%E5%BC%95%E5%8F%91%E6%B6%89%E5%A4%A7%E7%BB%B4%E4%BF%AE%E5%B7%A5%E7%A8%8B%E8%B4%AA%E6%B1%A1%E6%8A%95%E8%AF%89%E5%8F%8D%E5%A2%9E1-6%E5%80%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781679393000.webp","sourceId":"rfi"},{"id":1781713833000,"createdDate":"2026-06-17 16:30","name":"法国国际广播电台","title":"被麦克风捕捉到私下对话后 加总理称特朗普喜欢加中电动车协议的结构","content":"加拿大总理卡尼（MarkCarney）表示，美国总统特朗普（DonaldTrump）对加方允许以低关税进口限定数量中国电动汽车的协议感到满意。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260617-%E8%A2%AB%E9%BA%A6%E5%85%8B%E9%A3%8E%E6%8D%95%E6%8D%89%E5%88%B0%E7%A7%81%E4%B8%8B%E5%AF%B9%E8%AF%9D%E5%90%8E-%E5%8A%A0%E6%80%BB%E7%90%86%E7%A7%B0%E7%89%B9%E6%9C%97%E6%99%AE%E5%96%9C%E6%AC%A2%E5%8A%A0%E4%B8%AD%E7%94%B5%E5%8A%A8%E6%B1%BD%E8%BD%A6%E5%8D%8F%E8%AE%AE%E7%9A%84%E7%BB%93%E6%9E%84","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781713833000.webp","sourceId":"rfi"},{"id":1781710977000,"createdDate":"2026-06-17 15:42","name":"法国国际广播电台","title":"日防相质疑中国军费开支数据：是否真基于事实、有证据支持且高度透明","content":"日本防卫大臣小泉进次郎近日在受访时质疑中国官方公布的军费开支数据，这再次表明东京方面正对北京指责日本奉行“新军国主义”的言论采取更强硬的立场。小泉称，与中方形成鲜明对比的是，日本将以透明的方式投资于无人机和人工智能等新型作战手段，以适应不断变化的冲突性质。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260617-%E6%97%A5%E9%98%B2%E7%9B%B8%E8%B4%A8%E7%96%91%E4%B8%AD%E5%9B%BD%E5%9B%BD%E9%98%B2%E6%94%AF%E5%87%BA%E6%95%B0%E6%8D%AE-%E6%98%AF%E5%90%A6%E7%9C%9F%E5%9F%BA%E4%BA%8E%E4%BA%8B%E5%AE%9E-%E6%9C%89%E8%AF%81%E6%8D%AE%E6%94%AF%E6%8C%81%E4%B8%94%E9%AB%98%E5%BA%A6%E9%80%8F%E6%98%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781710977000.webp","sourceId":"rfi"},{"id":1781707027000,"createdDate":"2026-06-17 14:37","name":"法国国际广播电台","title":"黄仁勋：必须去适应新一代技术革命，发现新的机遇","content":"人工智能技术正快速发展，也日益广泛地应用于人类生活的方方面面。以设计和销售图形处理器著称的美国科技公司英伟达如今在该领域扮演者至关重要的角色。但人们对人工智能技术可能取代人工，导致就业岗位流失的担忧也令英伟达面对不少批评。英伟达公司首席执行官英伟达6月16日在美国德克萨斯州接受美联社专访时表示，社会没有选择，必须适应以人工智能为核心的新一波技术革命，去发现新的机遇。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260617-%E9%BB%84%E4%BB%81%E5%8B%8B-%E5%BF%85%E9%A1%BB%E5%8E%BB%E9%80%82%E5%BA%94%E6%96%B0%E4%B8%80%E4%BB%A3%E6%8A%80%E6%9C%AF%E9%9D%A9%E5%91%BD%EF%BC%8C%E5%8F%91%E7%8E%B0%E6%96%B0%E7%9A%84%E6%9C%BA%E9%81%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781707027000.webp","sourceId":"rfi"},{"id":1781705965000,"createdDate":"2026-06-17 14:19","name":"法国国际广播电台","title":"G7达成共识：力争到2030年将对华稀土和永磁体依赖度降至60%以下","content":"据彭博社援引知情人士报导称，七国集团国家已达成一致，到2030年，任何单一国家供应的稀土均不应超过七国集团总进口量的60%，以此减少对中国的依赖。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260617-g7%E8%BE%BE%E6%88%90%E5%85%B1%E8%AF%86-%E4%BB%BB%E4%BD%95%E5%8D%95%E4%B8%80%E5%9B%BD%E5%AE%B6%E4%BE%9B%E5%BA%94%E7%9A%84%E7%A8%80%E5%9C%9F%E5%9D%87%E4%B8%8D%E5%BA%94%E8%B6%85%E8%BF%87%E5%85%B6%E6%80%BB%E8%BF%9B%E5%8F%A3%E9%87%8F%E7%9A%8460","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781705965000.webp","sourceId":"rfi"},{"id":1781703251000,"createdDate":"2026-06-17 13:34","name":"法国国际广播电台","title":"缅甸战略与政策研究所称其创办人去中国仅是为参加学术研讨会 呼吁立即释放","content":"一名美籍缅甸问题学者于6月初在中国被拘留，这名学者创办的智库周三表示，他当时前往昆明是为了参加一个学术研讨会，并呼吁将其释放。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260617-%E7%BC%85%E7%94%B8%E6%88%98%E7%95%A5%E4%B8%8E%E6%94%BF%E7%AD%96%E7%A0%94%E7%A9%B6%E6%89%80%E7%A7%B0%E5%85%B6%E5%88%9B%E5%8A%9E%E4%BA%BA%E5%8E%BB%E4%B8%AD%E5%9B%BD%E4%BB%85%E6%98%AF%E4%B8%BA%E5%8F%82%E5%8A%A0%E5%AD%A6%E6%9C%AF%E7%A0%94%E8%AE%A8%E4%BC%9A-%E5%91%BC%E5%90%81%E7%AB%8B%E5%8D%B3%E9%87%8A%E6%94%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781703251000.webp","sourceId":"rfi"},{"id":1781701724000,"createdDate":"2026-06-17 13:08","name":"法国国际广播电台","title":"中国如何将北京打造成“新华盛顿”：习近平今几每周迎来一位外国新贵客","content":"大家好，欢迎收听法国报纸摘要。埃维昂峰会进入关键议程，特邀出席的乌克兰总统泽连斯基周二16日与G7领导人共同讨论乌战局势，并与美国总统特朗普举行会谈。特朗普将此次会面形容为“一次非常好的会谈”，并表示俄罗斯应当达成和平协议以结束持续数年的战事，成为周三6月17日出刊的法国主要日报头版或者国际版的头条之一。与此同时《回声报》关注，自特朗普重返白宫和伊朗战争爆发以来，外国领导人纷纷前往北京进行国事访问，并受到中国的盛情接待。在新冠疫情期间备受孤立和批评的中国，正享受着重返世界事务的时刻。但在实质问题上，北京却很少做出让步。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260617-%E4%B8%AD%E5%9B%BD%E5%A6%82%E4%BD%95%E5%B0%86%E5%8C%97%E4%BA%AC%E6%89%93%E9%80%A0%E6%88%90-%E6%96%B0%E5%8D%8E%E7%9B%9B%E9%A1%BF-%E4%B9%A0%E8%BF%91%E5%B9%B3%E4%BB%8A%E5%87%A0%E6%AF%8F%E5%91%A8%E8%BF%8E%E6%9D%A5%E4%B8%80%E4%BD%8D%E5%A4%96%E5%9B%BD%E6%96%B0%E8%B4%B5%E5%AE%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781701724000.webp","sourceId":"rfi"},{"id":1781696139000,"createdDate":"2026-06-17 11:35","name":"法国国际广播电台","title":"G7领导人声明：重申反对任何单方面改变台海等现状企图 只应通过对话和平解决","content":"七国集团峰会15日到17日在法国东部小城埃维昂莱班举办。七国集团领导人在周三公布的“就地缘政治问题”的联合声明中表示，“我们强调建立在法治基础上的自由开放的印度-太平洋的重要性。我们重申反对任何单方面改变现状的企图，特别是以武力或胁迫手段改变东中国海、南中国海和台湾海峡两岸的现状，这些问题只应通过对话和平解决”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260617-g7%E9%A2%86%E5%AF%BC%E4%BA%BA%E5%A3%B0%E6%98%8E-%E9%87%8D%E7%94%B3%E5%8F%8D%E5%AF%B9%E4%BB%BB%E4%BD%95%E5%8D%95%E6%96%B9%E9%9D%A2%E6%94%B9%E5%8F%98%E5%8F%B0%E6%B5%B7%E7%AD%89%E7%8E%B0%E7%8A%B6%E4%BC%81%E5%9B%BE-%E5%8F%AA%E5%BA%94%E9%80%9A%E8%BF%87%E5%AF%B9%E8%AF%9D%E5%92%8C%E5%B9%B3%E8%A7%A3%E5%86%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781696139000.webp","sourceId":"rfi"},{"id":1781695647000,"createdDate":"2026-06-17 11:27","name":"法国国际广播电台","title":"美军计划在澳大利亚建立战备武器库","content":"美国军方计划在澳大利亚东南海岸为其海军陆战队建立一个永久性的战备武器库，该武器库位于大多数中国导弹的射程之外。澳大利亚国防长马尔斯今天表示，此举有助于维护该国的国家安全。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260617-%E7%BE%8E%E5%86%9B%E8%AE%A1%E5%88%92%E5%9C%A8%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E5%BB%BA%E7%AB%8B%E6%88%98%E5%A4%87%E6%AD%A6%E5%99%A8%E5%BA%93","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781695647000.webp","sourceId":"rfi"},{"id":1781693948000,"createdDate":"2026-06-17 10:59","name":"法国国际广播电台","title":"解放报阐释：习近平治下的中国为何要高调接待缅甸前军头","content":"缅甸前军政府首脑现已转身为“民选总统”的敏昂莱，正在对中国展开国事访问。《解放报》亚太版周二16日晚登出由资深记者沃克蓝执笔的文章分析称，中国是缅甸最重要的经济与安全伙伴。这次访问也意味着，北京正在以实际行动为缅甸政权背书。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260617-%E8%A7%A3%E6%94%BE%E6%8A%A5%E9%98%90%E9%87%8A-%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%B2%BB%E4%B8%8B%E7%9A%84%E4%B8%AD%E5%9B%BD%E4%B8%BA%E4%BD%95%E8%A6%81%E9%AB%98%E8%B0%83%E6%8E%A5%E5%BE%85%E7%BC%85%E7%94%B8%E5%89%8D%E5%86%9B%E5%A4%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781693948000.webp","sourceId":"rfi"},{"id":1781691054000,"createdDate":"2026-06-17 10:10","name":"法国国际广播电台","title":"菲总统府称中方制裁不会影响防长履行职责 菲海警通报中方已移除浮动平台","content":"菲律宾西菲律宾海国家工作组（NTF-WPS、以下简称工作组）周三证实，自5月下旬以来在马辛洛克浅滩（中方称黄岩岛、西方文献称斯卡伯勒浅滩）潟湖中发现的中国浮动平台已被移除。工作组称，这一结论是基于菲律宾当局当天早些时候进行的最新海域态势感知巡逻。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260617-%E8%8F%B2%E6%80%BB%E7%BB%9F%E5%BA%9C%E7%A7%B0%E4%B8%AD%E6%96%B9%E5%88%B6%E8%A3%81%E4%B8%8D%E4%BC%9A%E5%BD%B1%E5%93%8D%E8%8F%B2%E9%98%B2%E9%95%BF%E5%B1%A5%E8%A1%8C%E8%81%8C%E8%B4%A3-%E8%8F%B2%E6%B5%B7%E8%AD%A6%E9%80%9A%E6%8A%A5%E4%B8%AD%E6%96%B9%E5%B7%B2%E7%A7%BB%E9%99%A4%E6%B5%AE%E5%8A%A8%E5%B9%B3%E5%8F%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781691054000.webp","sourceId":"rfi"},{"id":1781689597000,"createdDate":"2026-06-17 09:46","name":"法国国际广播电台","title":"郑丽文结束16天访美行程 美国白宫外交圈对其评价有抱负但或许有点天真","content":"国民党主席郑丽文结束16天历史性访美行程，但国际媒体对郑丽文此行普遍评价不高，英国媒体《BBC》认为此行高开低收，含金量不高。新加坡《海峡时报》报导，华盛顿外交圈对郑丽文此行的普遍评价是，有抱负但或许有点天真，虽有魅力但未打动美国。郑丽文此行访美亮点或许是她获得海外台湾侨民的热烈欢迎。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260617-%E9%83%91%E4%B8%BD%E6%96%87%E7%BB%93%E6%9D%9F16%E5%A4%A9%E8%AE%BF%E7%BE%8E%E8%A1%8C%E7%A8%8B-%E7%BE%8E%E5%9B%BD%E7%99%BD%E5%AE%AB%E5%A4%96%E4%BA%A4%E5%9C%88%E5%AF%B9%E5%85%B6%E8%AF%84%E4%BB%B7%E6%9C%89%E6%8A%B1%E8%B4%9F%E4%BD%86%E6%88%96%E8%AE%B8%E6%9C%89%E7%82%B9%E5%A4%A9%E7%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/17/1781689597000.webp","sourceId":"rfi"}]