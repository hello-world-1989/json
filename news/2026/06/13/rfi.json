[{"id":1781369463000,"createdDate":"2026-06-13 16:51","name":"法国国际广播电台","title":"第18届海峡论坛厦门登场 重申一中原则九二共识","content":"中央社消息，第18届海峡论坛大会今天周六在厦门举行，中国大陆全国政协主席王沪宁重申坚持「一个中国原则」与「九二共识」，坚决反对台独。台湾国民党副主席张荣恭出席了大会，他肯定了海峡论坛对两岸民间交流的意义。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260613-%E7%AC%AC18%E5%B1%8A%E6%B5%B7%E5%B3%A1%E8%AE%BA%E5%9D%9B%E5%8E%A6%E9%97%A8%E7%99%BB%E5%9C%BA-%E9%87%8D%E7%94%B3%E4%B8%80%E4%B8%AD%E5%8E%9F%E5%88%99%E4%B9%9D%E4%BA%8C%E5%85%B1%E8%AF%86","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781369463000.webp","sourceId":"rfi"},{"id":1781365785000,"createdDate":"2026-06-13 15:49","name":"法国国际广播电台","title":"黎巴嫩总统吁国人不要再给真主党“民兵逻辑”当人质","content":"黎巴嫩总统在X平台呼吁国人团结在“主权国家”周围，勿继续当“民兵逻辑的人质”。真主党议员反驳称“必须摒弃在以色列人面前被压垮、屈从美国的政策”。以军周六在警告后对黎南真主党目标展开了空袭。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260613-%E9%BB%8E%E5%B7%B4%E5%AB%A9%E6%80%BB%E7%BB%9F%E5%90%81%E5%9B%BD%E4%BA%BA%E4%B8%8D%E8%A6%81%E5%86%8D%E7%BB%99%E7%9C%9F%E4%B8%BB%E5%85%9A-%E6%B0%91%E5%85%B5%E9%80%BB%E8%BE%91-%E5%BD%93%E4%BA%BA%E8%B4%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781365785000.webp","sourceId":"rfi"},{"id":1781356982000,"createdDate":"2026-06-13 13:23","name":"法国国际广播电台","title":"美国顶级人工智能公司Anthropic应政府要求暂停最强大AI系统访问","content":"美国人工智能领军企业Anthropic周五应其政府要求，切断了对其最强大模型的访问权限。此时距离这些模型发布仅过去三天。华盛顿方面以国家安全风险为由，做出了这一史无前例的决定。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260613-%E7%BE%8E%E5%9B%BD%E9%A1%B6%E7%BA%A7%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E5%85%AC%E5%8F%B8anthropic%E5%BA%94%E6%94%BF%E5%BA%9C%E8%A6%81%E6%B1%82%E6%9A%82%E5%81%9C%E6%9C%80%E5%BC%BA%E5%A4%A7ai%E7%B3%BB%E7%BB%9F%E8%AE%BF%E9%97%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781356982000.webp","sourceId":"rfi"},{"id":1781354690000,"createdDate":"2026-06-13 12:44","name":"法国国际广播电台","title":"美军击落伊朗多架无人机尽管接近达成协议","content":"美国称在周六上午击落了数架在霍尔木兹海峡针对商船的伊朗无人机，尽管双方均表示即将达成一项旨在结束中东战争的协议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260613-%E7%BE%8E%E5%86%9B%E5%87%BB%E8%90%BD%E4%BC%8A%E6%9C%97%E5%A4%9A%E6%9E%B6%E6%97%A0%E4%BA%BA%E6%9C%BA-%E5%B0%BD%E7%AE%A1%E6%8E%A5%E8%BF%91%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781354690000.webp","sourceId":"rfi"},{"id":1781352842000,"createdDate":"2026-06-13 12:14","name":"法国国际广播电台","title":"泰国民众悼念长公主 全国举哀15天","content":"法新社曼谷消息，周六，泰国民众身着黑衣、神情肃穆，向国王的长女帕差拉吉帝雅帕公主（BajrakitiyabhaMahidol）致哀。此前一天，官方宣布这位泰国长公主在昏迷三年后去世，享年47岁。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260613-%E6%B3%B0%E5%9B%BD%E6%B0%91%E4%BC%97%E6%82%BC%E5%BF%B5%E9%95%BF%E5%85%AC%E4%B8%BB-%E5%85%A8%E5%9B%BD%E4%B8%BE%E5%93%8015%E5%A4%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781352842000.webp","sourceId":"rfi"},{"id":1781352469000,"createdDate":"2026-06-13 12:07","name":"法国国际广播电台","title":"乌克兰战争：欧盟称数百名俄罗斯士兵曾在中国接受军训","content":"周六出版的法国各大全国性报纸头版关注的重点各不相同。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260613-%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E4%BA%89-%E6%AC%A7%E7%9B%9F%E7%A7%B0%E6%95%B0%E7%99%BE%E5%90%8D%E4%BF%84%E7%BD%97%E6%96%AF%E5%A3%AB%E5%85%B5%E6%9B%BE%E5%9C%A8%E4%B8%AD%E5%9B%BD%E6%8E%A5%E5%8F%97%E5%86%9B%E8%AE%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781352469000.webp","sourceId":"rfi"},{"id":1781349061000,"createdDate":"2026-06-13 11:11","name":"法国国际广播电台","title":"珍贵馆藏遭“调包” 法国判决跨国古籍盗窃网络成员","content":"据法新社报道，法国法院日前就一起横跨欧洲的珍贵古籍盗窃案作出判决，六名格鲁吉亚人被告因涉嫌盗窃俄罗斯文学经典珍本，被判处最高七年监禁。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260613-%E7%8F%8D%E8%B4%B5%E9%A6%86%E8%97%8F%E9%81%AD-%E8%B0%83%E5%8C%85-%E6%B3%95%E5%9B%BD%E5%88%A4%E5%86%B3%E8%B7%A8%E5%9B%BD%E5%8F%A4%E7%B1%8D%E7%9B%97%E7%AA%83%E7%BD%91%E7%BB%9C%E6%88%90%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781349061000.webp","sourceId":"rfi"},{"id":1781346677000,"createdDate":"2026-06-13 10:31","name":"法国国际广播电台","title":"高市首相向《金融时报》投稿 自比“铁娘子”撒切尔","content":"日本首相高市早苗于日本时间13日下午从羽田机场启程，访问英国和意大利，并分别与两国领导人举行会谈。此外，她还将赴法国出席七国集团（G7）峰会。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260613-%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E5%90%91-%E9%87%91%E8%9E%8D%E6%97%B6%E6%8A%A5-%E6%8A%95%E7%A8%BF-%E8%87%AA%E6%AF%94-%E9%93%81%E5%A8%98%E5%AD%90-%E6%92%92%E5%88%87%E5%B0%94","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781346677000.webp","sourceId":"rfi"},{"id":1781346419000,"createdDate":"2026-06-13 10:26","name":"法国国际广播电台","title":"2026世界杯美加东道主首秀： 美大胜开门红、加终结六连败","content":"2026年美加墨世界杯继续展开小组赛争夺，两支东道主球队加拿大和美国先后亮相。美国队在与南美巴拉圭的比赛中火力全开，最终以4比1大胜；和美国队相比加拿大队的表现则平平，在自己的主场上，只以1比1战平波黑队，不过这是加拿大队在世界杯比赛中最好的成绩，首次拿到了积分。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260613-2026%E4%B8%96%E7%95%8C%E6%9D%AF%E7%BE%8E%E5%8A%A0%E4%B8%9C%E9%81%93%E4%B8%BB%E9%A6%96%E7%A7%80-%E7%BE%8E%E5%A4%A7%E8%83%9C%E5%BC%80%E9%97%A8%E7%BA%A2-%E5%8A%A0%E7%BB%88%E7%BB%93%E5%85%AD%E8%BF%9E%E8%B4%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781346419000.webp","sourceId":"rfi"}]