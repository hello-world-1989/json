[{"id":1781369463000,"createdDate":"2026-06-13 16:51","name":"法国国际广播电台","title":"第18届海峡论坛厦门登场 重申一中原则九二共识","content":"中央社消息，第18届海峡论坛大会今天周六在厦门举行，中国大陆全国政协主席王沪宁重申坚持「一个中国原则」与「九二共识」，坚决反对台独。台湾国民党副主席张荣恭出席了大会，他肯定了海峡论坛对两岸民间交流的意义。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260613-%E7%AC%AC18%E5%B1%8A%E6%B5%B7%E5%B3%A1%E8%AE%BA%E5%9D%9B%E5%8E%A6%E9%97%A8%E7%99%BB%E5%9C%BA-%E9%87%8D%E7%94%B3%E4%B8%80%E4%B8%AD%E5%8E%9F%E5%88%99%E4%B9%9D%E4%BA%8C%E5%85%B1%E8%AF%86","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781369463000.webp","sourceId":"rfi"},{"id":1781365785000,"createdDate":"2026-06-13 15:49","name":"法国国际广播电台","title":"黎巴嫩总统吁国人不要再给真主党“民兵逻辑”当人质","content":"黎巴嫩总统在X平台呼吁国人团结在“主权国家”周围，勿继续当“民兵逻辑的人质”。真主党议员反驳称“必须摒弃在以色列人面前被压垮、屈从美国的政策”。以军周六在警告后对黎南真主党目标展开了空袭。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260613-%E9%BB%8E%E5%B7%B4%E5%AB%A9%E6%80%BB%E7%BB%9F%E5%90%81%E5%9B%BD%E4%BA%BA%E4%B8%8D%E8%A6%81%E5%86%8D%E7%BB%99%E7%9C%9F%E4%B8%BB%E5%85%9A-%E6%B0%91%E5%85%B5%E9%80%BB%E8%BE%91-%E5%BD%93%E4%BA%BA%E8%B4%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781365785000.webp","sourceId":"rfi"},{"id":1781356982000,"createdDate":"2026-06-13 13:23","name":"法国国际广播电台","title":"美国顶级人工智能公司Anthropic应政府要求暂停最强大AI系统访问","content":"美国人工智能领军企业Anthropic周五应其政府要求，切断了对其最强大模型的访问权限。此时距离这些模型发布仅过去三天。华盛顿方面以国家安全风险为由，做出了这一史无前例的决定。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260613-%E7%BE%8E%E5%9B%BD%E9%A1%B6%E7%BA%A7%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E5%85%AC%E5%8F%B8anthropic%E5%BA%94%E6%94%BF%E5%BA%9C%E8%A6%81%E6%B1%82%E6%9A%82%E5%81%9C%E6%9C%80%E5%BC%BA%E5%A4%A7ai%E7%B3%BB%E7%BB%9F%E8%AE%BF%E9%97%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781356982000.webp","sourceId":"rfi"},{"id":1781354690000,"createdDate":"2026-06-13 12:44","name":"法国国际广播电台","title":"美军击落伊朗多架无人机尽管接近达成协议","content":"美国称在周六上午击落了数架在霍尔木兹海峡针对商船的伊朗无人机，尽管双方均表示即将达成一项旨在结束中东战争的协议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260613-%E7%BE%8E%E5%86%9B%E5%87%BB%E8%90%BD%E4%BC%8A%E6%9C%97%E5%A4%9A%E6%9E%B6%E6%97%A0%E4%BA%BA%E6%9C%BA-%E5%B0%BD%E7%AE%A1%E6%8E%A5%E8%BF%91%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781354690000.webp","sourceId":"rfi"},{"id":1781352842000,"createdDate":"2026-06-13 12:14","name":"法国国际广播电台","title":"泰国民众悼念长公主 全国举哀15天","content":"法新社曼谷消息，周六，泰国民众身着黑衣、神情肃穆，向国王的长女帕差拉吉帝雅帕公主（BajrakitiyabhaMahidol）致哀。此前一天，官方宣布这位泰国长公主在昏迷三年后去世，享年47岁。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260613-%E6%B3%B0%E5%9B%BD%E6%B0%91%E4%BC%97%E6%82%BC%E5%BF%B5%E9%95%BF%E5%85%AC%E4%B8%BB-%E5%85%A8%E5%9B%BD%E4%B8%BE%E5%93%8015%E5%A4%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781352842000.webp","sourceId":"rfi"},{"id":1781352469000,"createdDate":"2026-06-13 12:07","name":"法国国际广播电台","title":"乌克兰战争：欧盟称数百名俄罗斯士兵曾在中国接受军训","content":"周六出版的法国各大全国性报纸头版关注的重点各不相同。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260613-%E4%B9%8C%E5%85%8B%E5%85%B0%E6%88%98%E4%BA%89-%E6%AC%A7%E7%9B%9F%E7%A7%B0%E6%95%B0%E7%99%BE%E5%90%8D%E4%BF%84%E7%BD%97%E6%96%AF%E5%A3%AB%E5%85%B5%E6%9B%BE%E5%9C%A8%E4%B8%AD%E5%9B%BD%E6%8E%A5%E5%8F%97%E5%86%9B%E8%AE%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781352469000.webp","sourceId":"rfi"},{"id":1781349061000,"createdDate":"2026-06-13 11:11","name":"法国国际广播电台","title":"珍贵馆藏遭“调包” 法国判决跨国古籍盗窃网络成员","content":"据法新社报道，法国法院日前就一起横跨欧洲的珍贵古籍盗窃案作出判决，六名格鲁吉亚人被告因涉嫌盗窃俄罗斯文学经典珍本，被判处最高七年监禁。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260613-%E7%8F%8D%E8%B4%B5%E9%A6%86%E8%97%8F%E9%81%AD-%E8%B0%83%E5%8C%85-%E6%B3%95%E5%9B%BD%E5%88%A4%E5%86%B3%E8%B7%A8%E5%9B%BD%E5%8F%A4%E7%B1%8D%E7%9B%97%E7%AA%83%E7%BD%91%E7%BB%9C%E6%88%90%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781349061000.webp","sourceId":"rfi"},{"id":1781346677000,"createdDate":"2026-06-13 10:31","name":"法国国际广播电台","title":"高市首相向《金融时报》投稿 自比“铁娘子”撒切尔","content":"日本首相高市早苗于日本时间13日下午从羽田机场启程，访问英国和意大利，并分别与两国领导人举行会谈。此外，她还将赴法国出席七国集团（G7）峰会。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260613-%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E5%90%91-%E9%87%91%E8%9E%8D%E6%97%B6%E6%8A%A5-%E6%8A%95%E7%A8%BF-%E8%87%AA%E6%AF%94-%E9%93%81%E5%A8%98%E5%AD%90-%E6%92%92%E5%88%87%E5%B0%94","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781346677000.webp","sourceId":"rfi"},{"id":1781346419000,"createdDate":"2026-06-13 10:26","name":"法国国际广播电台","title":"2026世界杯美加东道主首秀： 美大胜开门红、加终结六连败","content":"2026年美加墨世界杯继续展开小组赛争夺，两支东道主球队加拿大和美国先后亮相。美国队在与南美巴拉圭的比赛中火力全开，最终以4比1大胜；和美国队相比加拿大队的表现则平平，在自己的主场上，只以1比1战平波黑队，不过这是加拿大队在世界杯比赛中最好的成绩，首次拿到了积分。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260613-2026%E4%B8%96%E7%95%8C%E6%9D%AF%E7%BE%8E%E5%8A%A0%E4%B8%9C%E9%81%93%E4%B8%BB%E9%A6%96%E7%A7%80-%E7%BE%8E%E5%A4%A7%E8%83%9C%E5%BC%80%E9%97%A8%E7%BA%A2-%E5%8A%A0%E7%BB%88%E7%BB%93%E5%85%AD%E8%BF%9E%E8%B4%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781346419000.webp","sourceId":"rfi"},{"id":1781390073000,"createdDate":"2026-06-13 22:34","name":"法国国际广播电台","title":"美伊停战协议签还是不签 ？","content":"美伊和谈像一个谜团，如果相信特朗普所言，那么，美伊停战协议将在周日签署。伊朗则表示周日没有派遣外交使团前往日内瓦的计划，而调解方巴基斯坦则表示：“周日举行的是电子签字仪式”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260613-%E7%BE%8E%E4%BC%8A%E5%81%9C%E6%88%98%E5%8D%8F%E8%AE%AE%E7%AD%BE%E8%BF%98%E6%98%AF%E4%B8%8D%E7%AD%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781390073000.webp","sourceId":"rfi"},{"id":1781389400000,"createdDate":"2026-06-13 22:23","name":"法国国际广播电台","title":"G7如何开 全看特朗普心情好坏？","content":"七国集团峰会于15日在法国阿尔卑斯山麓的埃维昂开幕，美国总统特朗普对此峰会有何意图，人们几乎一无所知，除了最关键的一点：特朗普将按照自己的日程和情绪安排行事。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260613-g7%E5%A6%82%E4%BD%95%E5%BC%80-%E5%85%A8%E7%9C%8B%E7%89%B9%E6%9C%97%E6%99%AE%E5%BF%83%E6%83%85%E5%A5%BD%E5%9D%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781389400000.webp","sourceId":"rfi"},{"id":1781387901000,"createdDate":"2026-06-13 21:58","name":"法国国际广播电台","title":"G7：特朗普将与泽连斯基举行会晤 并与马克龙在凡尔赛宫共进晚餐","content":"一位美国高级官员周六表示，特朗普和泽连斯基将于周二在法国举行的七国集团峰会上参加同一场工作会议，美国总统将于次日在凡尔赛宫与法国总统马克龙共进晚餐。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260613-g7-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B0%86%E4%B8%8E%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E4%B8%BE%E8%A1%8C%E4%BC%9A%E6%99%A4-%E5%B9%B6%E4%B8%8E%E9%A9%AC%E5%85%8B%E9%BE%99%E5%9C%A8%E5%87%A1%E5%B0%94%E8%B5%9B%E5%AE%AB%E5%85%B1%E8%BF%9B%E6%99%9A%E9%A4%90","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781387901000.webp","sourceId":"rfi"},{"id":1781387423000,"createdDate":"2026-06-13 21:50","name":"法国国际广播电台","title":"美国下架22项涉冒充“美国制造”餐具产品 扩大打击中国供应链渗透","content":"美国小企业管理局（SBA）与总务管理局（GSA）12日宣布，已从联邦政府采购平台GSAAdvantage!下架22项外国制造产品，原因是部分以中国为基地的企业，涉嫌将产品错误标示为“美国制造”（MadeinAmerica），借此进入联邦采购体系。此举被视为特朗普政府进一步推动本土制造业回流、降低对中国供应链依赖的重要行动之一。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260613-%E7%BE%8E%E5%9B%BD%E4%B8%8B%E6%9E%B622%E9%A1%B9%E6%B6%89%E5%86%92%E5%85%85-%E7%BE%8E%E5%9B%BD%E5%88%B6%E9%80%A0-%E9%A4%90%E5%85%B7%E4%BA%A7%E5%93%81-%E6%89%A9%E5%A4%A7%E6%89%93%E5%87%BB%E4%B8%AD%E5%9B%BD%E4%BE%9B%E5%BA%94%E9%93%BE%E6%B8%97%E9%80%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781387423000.webp","sourceId":"rfi"},{"id":1781385974000,"createdDate":"2026-06-13 21:26","name":"法国国际广播电台","title":"中国警告西北地区今夏或现“极端洪水” 沙漠地带提前进入汛期","content":"中国官方12日警告称，在异常高温、强降雨以及冰川加速融化的共同作用下，新疆及周边西北地区今年夏季可能面临“极端洪水”风险，并呼吁当地社区提前做好防灾准备。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260613-%E4%B8%AD%E5%9B%BD%E8%AD%A6%E5%91%8A%E8%A5%BF%E5%8C%97%E5%9C%B0%E5%8C%BA%E4%BB%8A%E5%A4%8F%E6%88%96%E7%8E%B0-%E6%9E%81%E7%AB%AF%E6%B4%AA%E6%B0%B4-%E6%B2%99%E6%BC%A0%E5%9C%B0%E5%B8%A6%E6%8F%90%E5%89%8D%E8%BF%9B%E5%85%A5%E6%B1%9B%E6%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781385974000.webp","sourceId":"rfi"},{"id":1781385724000,"createdDate":"2026-06-13 21:22","name":"法国国际广播电台","title":"国际原子能机构：扎波罗热核电站恢复接入外部电网","content":"国际原子能机构（IAEA）13日表示，位于乌克兰南部、目前由俄罗斯控制的扎波罗热核电站已于当天重新接入外部电网。此前，该核电站因一处变电站遭袭而失去全部外部供电近三天。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260613-%E5%9B%BD%E9%99%85%E5%8E%9F%E5%AD%90%E8%83%BD%E6%9C%BA%E6%9E%84-%E6%89%8E%E6%B3%A2%E7%BD%97%E7%83%AD%E6%A0%B8%E7%94%B5%E7%AB%99%E6%81%A2%E5%A4%8D%E6%8E%A5%E5%85%A5%E5%A4%96%E9%83%A8%E7%94%B5%E7%BD%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781385724000.webp","sourceId":"rfi"},{"id":1781385498000,"createdDate":"2026-06-13 21:18","name":"法国国际广播电台","title":"美国将多家中国科技企业列入涉军名单 中方强烈不满","content":"中国商务部周六（6月13日）对美国国防部将多家中国大型企业列入“涉军企业名单”表示“强烈不满和坚决反对”，并敦促美方立即停止相关做法，否则中方将采取坚决有力的反制措施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260613-%E7%BE%8E%E5%9B%BD%E5%B0%86%E5%A4%9A%E5%AE%B6%E4%B8%AD%E5%9B%BD%E7%A7%91%E6%8A%80%E4%BC%81%E4%B8%9A%E5%88%97%E5%85%A5%E6%B6%89%E5%86%9B%E5%90%8D%E5%8D%95-%E4%B8%AD%E6%96%B9%E5%BC%BA%E7%83%88%E4%B8%8D%E6%BB%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781385498000.webp","sourceId":"rfi"},{"id":1781385356000,"createdDate":"2026-06-13 21:15","name":"法国国际广播电台","title":"塞内加尔在美国侨民喜迎其国足","content":"第23届世界杯球赛已于2026年06月11日星期四开幕。本届赛事由北美三国：美国、加拿大和墨西哥联合举办，计划为期39天到07月19日星期天落幕。在距离法国和塞内加尔两国足球队06月16日星期二晚首战还有四天之际，本台法广（RFI）法语特派记者于周五发自纽约（NewYork）的特稿说，在美国的塞内加尔侨民热烈欢迎本国的国脚们进驻美国营地。塞内加尔狮子们的部分球迷接受了现场采访。在国际足坛，塞内加尔国家足球队也被称之为特兰加雄狮(LeslionsofTeranga)。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260613-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-2026%E4%B8%96%E7%95%8C%E6%9D%AF-%E5%A1%9E%E5%86%85%E5%8A%A0%E5%B0%94%E5%9C%A8%E7%BE%8E%E5%9B%BD%E4%BE%A8%E6%B0%91%E5%96%9C%E8%BF%8E%E5%85%B6%E5%9B%BD%E8%B6%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781385356000.webp","sourceId":"rfi"},{"id":1781385326000,"createdDate":"2026-06-13 21:15","name":"法国国际广播电台","title":"法国15岁以下社交媒体禁令有望9月实施 欧盟下月表态","content":"法国负责数字事务的部长级代表安娜·勒埃南夫周六（6月13日）表示，希望禁止15岁以下未成年人使用社交媒体的法案能够在今年9月新学期开学前正式生效。目前，法国政府正等待欧盟委员会最迟于7月10日前作出审批决定。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260613-%E6%B3%95%E5%9B%BD15%E5%B2%81%E4%BB%A5%E4%B8%8B%E7%A4%BE%E4%BA%A4%E5%AA%92%E4%BD%93%E7%A6%81%E4%BB%A4%E6%9C%89%E6%9C%9B9%E6%9C%88%E5%AE%9E%E6%96%BD-%E6%AC%A7%E7%9B%9F%E4%B8%8B%E6%9C%88%E8%A1%A8%E6%80%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781385326000.webp","sourceId":"rfi"},{"id":1781384793000,"createdDate":"2026-06-13 21:06","name":"法国国际广播电台","title":"Anthropic停服事件震动法国政坛: “AI之战”与“数字主权”成总统大选焦点","content":"美国政府下令暂停“所有外国公民”使用部分先进人工智能模型的决定，周六（6月13日）在法国总统选举阵营中引发强烈反响。多位重量级政治人物警告称，一场“人工智能之战”已经打响，并强调法国及欧洲必须摆脱对美国技术的依赖。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260613-anthropic%E5%81%9C%E6%9C%8D%E4%BA%8B%E4%BB%B6%E9%9C%87%E5%8A%A8%E6%B3%95%E5%9B%BD%E6%94%BF%E5%9D%9B-ai%E6%88%98%E4%BA%89-%E4%B8%8E-%E6%95%B0%E5%AD%97%E4%B8%BB%E6%9D%83-%E6%88%90%E6%80%BB%E7%BB%9F%E5%A4%A7%E9%80%89%E7%84%A6%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781384793000.webp","sourceId":"rfi"},{"id":1781384429000,"createdDate":"2026-06-13 21:00","name":"法国国际广播电台","title":"特朗普称美伊和平协议将于14日签署 伊朗尚未确认","content":"美国总统特朗普和参与斡旋的巴基斯坦方面周六（6月13日）表示，一项旨在结束中东战争的和平协议预计将于周日（6月14日）签署。协议签署后“霍尔木兹海峡将向所有国家开放”。不过，截至目前，伊朗官方尚未确认这一具体时间表。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260613-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E7%BE%8E%E4%BC%8A%E5%92%8C%E5%B9%B3%E5%8D%8F%E8%AE%AE%E5%B0%86%E4%BA%8E14%E6%97%A5%E7%AD%BE%E7%BD%B2-%E4%BC%8A%E6%9C%97%E5%B0%9A%E6%9C%AA%E7%A1%AE%E8%AE%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781384429000.webp","sourceId":"rfi"},{"id":1781374513000,"createdDate":"2026-06-13 18:15","name":"法国国际广播电台","title":"日本防卫相访问印尼 同意共享敏感情报 确认朝雾护卫舰出口","content":"共同社6月13日消息，日本防卫相小泉进次郎6月12日在印尼与该国总统普拉博沃和防长沙弗里举行了会谈。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260613-%E6%97%A5%E6%9C%AC%E9%98%B2%E5%8D%AB%E7%9B%B8%E8%AE%BF%E9%97%AE%E5%8D%B0%E5%B0%BC-%E5%90%8C%E6%84%8F%E5%85%B1%E4%BA%AB%E6%95%8F%E6%84%9F%E6%83%85%E6%8A%A5-%E7%A1%AE%E8%AE%A4%E6%9C%9D%E9%9B%BE%E6%8A%A4%E5%8D%AB%E8%88%B0%E5%87%BA%E5%8F%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/13/1781374513000.webp","sourceId":"rfi"}]