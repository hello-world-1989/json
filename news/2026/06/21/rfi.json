[{"id":1782033992000,"createdDate":"2026-06-21 09:26","name":"法国国际广播电台","title":"伊朗媒体称霍尔木兹海峡仍关闭 万斯提瑞士会谈应关注两件大事","content":"伊朗外交部发言人巴加埃告诉其官媒称，伊朗、美国、卡塔尔和巴基斯坦将于周日下午在瑞士布尔根施托克山顶度假胜地举行四方会谈。巴加埃表示，伊朗将首先与中间人卡塔尔和巴基斯坦举行会谈，并指此次在瑞士举行的会谈是对上周与美国签署的谅解备忘录的后续落实工作。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260621-%E4%BC%8A%E6%9C%97%E5%AA%92%E4%BD%93%E7%A7%B0%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E4%BB%8D%E5%85%B3%E9%97%AD-%E4%B8%87%E6%96%AF%E6%8F%90%E7%91%9E%E5%A3%AB%E4%BC%9A%E8%B0%88%E5%BA%94%E5%85%B3%E6%B3%A8%E7%9A%84%E4%B8%A4%E4%BB%B6%E5%A4%A7%E4%BA%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782033992000.webp","sourceId":"rfi"},{"id":1782032156000,"createdDate":"2026-06-21 08:55","name":"法国国际广播电台","title":"泽连斯基：克里米亚大桥两侧设施均遭袭，对俄后勤、石油工业等远程制裁","content":"据俄罗斯任命的克里米亚官员称，乌克兰无人机袭击了俄控克里米亚半岛，造成4人死亡，28人受伤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260621-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E5%85%8B%E9%87%8C%E7%B1%B3%E4%BA%9A%E5%A4%A7%E6%A1%A5%E4%B8%A4%E4%BE%A7%E8%AE%BE%E6%96%BD%E5%9D%87%E9%81%AD%E8%A2%AD%EF%BC%8C%E5%AF%B9%E4%BF%84%E5%90%8E%E5%8B%A4-%E7%9F%B3%E6%B2%B9%E5%B7%A5%E4%B8%9A%E7%AD%89%E8%BF%9C%E7%A8%8B%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782032156000.webp","sourceId":"rfi"},{"id":1782031004000,"createdDate":"2026-06-21 08:36","name":"法国国际广播电台","title":"首届日法高级别人工智能对话在巴黎举行","content":"日本外务省于6月20日报道称，6月19日，在法国巴黎，由日本外务审议官赤堀毅和法国欧洲及外交部副秘书长达维德·贝尔托洛蒂共同主持，在两国相关政府部门参加下，召开了首届日法高级别人工智能（AI）对话。此次对话分为政府间对话和官民对话两个部分，两国人工智能相关企业也参加了官民对话。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260621-%E9%A6%96%E5%B1%8A%E6%97%A5%E6%B3%95%E9%AB%98%E7%BA%A7%E5%88%AB%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E5%AF%B9%E8%AF%9D%E5%9C%A8%E5%B7%B4%E9%BB%8E%E4%B8%BE%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782031004000.webp","sourceId":"rfi"},{"id":1782058726000,"createdDate":"2026-06-21 16:18","name":"法国国际广播电台","title":"贝宁和尼日尔迈向重新开放边境","content":"贝宁与尼日尔之间的关系正在加速正常化。贝宁新总统于本月初（2026年06月02日）访问尼日尔首都，为重新缓和紧张局势注入了新的动力。据本台法广非洲组（RFIAfrique）的法文报导，在本月新成立的一个联合专家委员会于本周末（06月20日星期六和06月21日星期天）在科托努（Cotonou）会晤，磋商重启两国边境的相关事宜。贝宁的中文也有译作贝南共和国（leBénin）。尼日尔的中文也有译作尼日共和国(leNiger)。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260621-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E8%B4%9D%E5%AE%81%E5%92%8C%E5%B0%BC%E6%97%A5%E5%B0%94%E8%BF%88%E5%90%91%E9%87%8D%E6%96%B0%E5%BC%80%E6%94%BE%E8%BE%B9%E5%A2%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782058726000.webp","sourceId":"rfi"},{"id":1782048933000,"createdDate":"2026-06-21 13:35","name":"法国国际广播电台","title":"中国掀肥肝养殖潮产量激增 法国生产商深感不安","content":"近年来，中国肥肝产业发展迅速，让法国生产商感到不小的压力。过去十年里，肥肝在中国已经从一种高端食材逐渐走向大众市场，价格也变得更加亲民。与法国产肥肝相比，中国产品不仅价格更低、产量更大，而且近两年还开始积极开拓海外市场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260621-%E4%B8%AD%E5%9B%BD%E6%8E%80%E8%82%A5%E8%82%9D%E5%85%BB%E6%AE%96%E6%BD%AE%E4%BA%A7%E9%87%8F%E6%BF%80%E5%A2%9E-%E6%B3%95%E5%9B%BD%E7%94%9F%E4%BA%A7%E5%95%86%E6%B7%B1%E6%84%9F%E4%B8%8D%E5%AE%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782048933000.webp","sourceId":"rfi"},{"id":1782046625000,"createdDate":"2026-06-21 12:57","name":"法国国际广播电台","title":"5月份中国对日关键矿产出口量仍处低位","content":"5月份，中国对日部分关键矿产的出口量持续低迷，两国政治争端加剧了这一颓势。据中国海关数据显示，5月份部分关键钨矿以及稀土元素镝和铽的出口量为零。其他一些稀土类别的出口量也处于异常低位。自去11月，日本首相高市早苗作出“台湾有事”国会答辩激怒北京以来，工业矿物的流动一直备受关注。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-5%E6%9C%88%E4%BB%BD%E4%B8%AD%E5%9B%BD%E5%AF%B9%E6%97%A5%E5%85%B3%E9%94%AE%E7%9F%BF%E4%BA%A7%E5%87%BA%E5%8F%A3%E9%87%8F%E4%BB%8D%E5%A4%84%E4%BD%8E%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782046625000.webp","sourceId":"rfi"},{"id":1782043229000,"createdDate":"2026-06-21 12:00","name":"法国国际广播电台","title":"英外相加入“逼宫”队伍 预计斯塔默将于周一宣布辞职","content":"天空新闻台周日报导称，英国外交大臣库珀（YvetteCooper）已告知首相斯塔默（KeirStarmer），他必须辞职。据悉，库珀——斯塔默最资深的内阁部长之一——已于周末私下向首相传达了这一信息。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-%E8%8B%B1%E5%A4%96%E7%9B%B8%E5%8A%A0%E5%85%A5-%E9%80%BC%E5%AE%AB-%E9%98%9F%E4%BC%8D-%E9%A2%84%E8%AE%A1%E6%96%AF%E5%A1%94%E9%BB%98%E5%B0%86%E4%BA%8E%E5%91%A8%E4%B8%80%E5%AE%A3%E5%B8%83%E8%BE%9E%E8%81%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782043229000.webp","sourceId":"rfi"},{"id":1782042575000,"createdDate":"2026-06-21 11:49","name":"法国国际广播电台","title":"驻韩美军六辆萨德发射车全部返回驻地星州基地","content":"据韩联社周日援引多方消息报导指，在美伊战争期间从庆尚北道星州基地撤出的6辆驻韩美军“萨德”反导系统发射车已全部返回星州基地。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260621-%E9%A9%BB%E9%9F%A9%E7%BE%8E%E5%86%9B%E5%85%AD%E8%BE%86%E8%90%A8%E5%BE%B7%E5%8F%91%E5%B0%84%E8%BD%A6%E5%85%A8%E9%83%A8%E8%BF%94%E5%9B%9E%E9%A9%BB%E5%9C%B0%E6%98%9F%E5%B7%9E%E5%9F%BA%E5%9C%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782042575000.webp","sourceId":"rfi"},{"id":1782041179000,"createdDate":"2026-06-21 11:26","name":"法国国际广播电台","title":"日本五大芯片制造设备商在华销售额合计下降10% 有史以来首次下滑","content":"截至3月31日的财年中，日本五大芯片制造设备商对华销售额合计下降了10%，这是有史以来的首次下滑，主要是由于中国政府正致力于推动本国相关产业的发展。中国企业不仅从日企手中夺取市场份额，也从欧美竞争对手手中蚕食市场份额。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260621-%E6%97%A5%E6%9C%AC%E4%BA%94%E5%A4%A7%E8%8A%AF%E7%89%87%E5%88%B6%E9%80%A0%E8%AE%BE%E5%A4%87%E5%95%86%E5%9C%A8%E5%8D%8E%E9%94%80%E5%94%AE%E9%A2%9D%E5%90%88%E8%AE%A1%E4%B8%8B%E9%99%8D10-%E6%9C%89%E5%8F%B2%E4%BB%A5%E6%9D%A5%E9%A6%96%E6%AC%A1%E4%B8%8B%E6%BB%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782041179000.webp","sourceId":"rfi"},{"id":1782038303000,"createdDate":"2026-06-21 10:38","name":"法国国际广播电台","title":"2026年世界杯：因凡蒂诺乘坐私人飞机穿梭各个赛场 被指象征着国际足联的奢靡之风","content":"2026世界杯是历史上首次由三国共同主办。国际足联主席詹尼·因凡蒂诺乘私人飞机频繁穿梭于美加墨三国的各个赛场，碳排放量惊人引发环保组织批评，认为这凸显了该足球管理机构对任何气候相关倡议的漠视。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260621-2026%E5%B9%B4%E4%B8%96%E7%95%8C%E6%9D%AF-%E5%9B%A0%E5%87%A1%E8%92%82%E8%AF%BA%E4%B9%98%E5%9D%90%E7%A7%81%E4%BA%BA%E9%A3%9E%E6%9C%BA%E7%A9%BF%E6%A2%AD%E5%90%84%E4%B8%AA%E8%B5%9B%E5%9C%BA-%E8%A2%AB%E6%8C%87%E8%B1%A1%E5%BE%81%E7%9D%80%E5%9B%BD%E9%99%85%E8%B6%B3%E8%81%94%E7%9A%84%E5%A5%A2%E9%9D%A1%E4%B9%8B%E9%A3%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782038303000.webp","sourceId":"rfi"},{"id":1782037274000,"createdDate":"2026-06-21 10:21","name":"法国国际广播电台","title":"2026巴黎香港电影节第二日：不同世代的离散之苦与自我重塑","content":"2026巴黎香港电影节周日进入第二天。围绕本届电影节主题“离散之声”，周日下午将放映一部纪录片和四部短片。其中两部影片导演也会在放映之后与观众互动。晚间则将放映香港著名导演王家卫的作品《一代宗师》。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260621-2026%E5%B7%B4%E9%BB%8E%E9%A6%99%E6%B8%AF%E7%94%B5%E5%BD%B1%E8%8A%82%E7%AC%AC%E4%BA%8C%E6%97%A5-%E4%B8%8D%E5%90%8C%E4%B8%96%E4%BB%A3%E7%9A%84%E7%A6%BB%E6%95%A3%E4%B9%8B%E8%8B%A6%E4%B8%8E%E8%87%AA%E6%88%91%E9%87%8D%E5%A1%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782037274000.webp","sourceId":"rfi"},{"id":1782036922000,"createdDate":"2026-06-21 10:15","name":"法国国际广播电台","title":"民调：高市内阁支持率跌至55%，不支持率上升1.1%","content":"据共同社20日和21日实施的全国电话舆论调查结果显示，高市内阁的支持率为55.8%，创上台以来新低，比5月份的民调结果下降了5.5个百分点。30岁以下年轻人的支持率下降13.5个百分点，女性支持率下降9.2个百分点。不支持率上升1.1个百分点，达到27.9%。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-%E6%B0%91%E8%B0%83-%E9%AB%98%E5%B8%82%E5%86%85%E9%98%81%E6%94%AF%E6%8C%81%E7%8E%87%E8%B7%8C%E8%87%B355-%EF%BC%8C%E4%B8%8D%E6%94%AF%E6%8C%81%E7%8E%87%E4%B8%8A%E5%8D%871-1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782036922000.webp","sourceId":"rfi"},{"id":1782035781000,"createdDate":"2026-06-21 09:56","name":"法国国际广播电台","title":"台国防部：周一起实施“立即备战操演” 强化高战备立即应变能力","content":"台湾国防部周日通过新闻稿表示，为强化国军高战备立即应变能力，验证部队联合作战效能，将自明日起至26日止实施为期5天4夜的“立即备战操演”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-%E5%8F%B0%E5%9B%BD%E9%98%B2%E9%83%A8-%E5%91%A8%E4%B8%80%E8%B5%B7%E5%AE%9E%E6%96%BD-%E7%AB%8B%E5%8D%B3%E5%A4%87%E6%88%98%E6%93%8D%E6%BC%94-%E5%BC%BA%E5%8C%96%E9%AB%98%E6%88%98%E5%A4%87%E7%AB%8B%E5%8D%B3%E5%BA%94%E5%8F%98%E8%83%BD%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782035781000.webp","sourceId":"rfi"}]