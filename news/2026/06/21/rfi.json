[{"id":1782033992000,"createdDate":"2026-06-21 09:26","name":"法国国际广播电台","title":"伊朗媒体称霍尔木兹海峡仍关闭 万斯提瑞士会谈应关注两件大事","content":"伊朗外交部发言人巴加埃告诉其官媒称，伊朗、美国、卡塔尔和巴基斯坦将于周日下午在瑞士布尔根施托克山顶度假胜地举行四方会谈。巴加埃表示，伊朗将首先与中间人卡塔尔和巴基斯坦举行会谈，并指此次在瑞士举行的会谈是对上周与美国签署的谅解备忘录的后续落实工作。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260621-%E4%BC%8A%E6%9C%97%E5%AA%92%E4%BD%93%E7%A7%B0%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E4%BB%8D%E5%85%B3%E9%97%AD-%E4%B8%87%E6%96%AF%E6%8F%90%E7%91%9E%E5%A3%AB%E4%BC%9A%E8%B0%88%E5%BA%94%E5%85%B3%E6%B3%A8%E7%9A%84%E4%B8%A4%E4%BB%B6%E5%A4%A7%E4%BA%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782033992000.webp","sourceId":"rfi"},{"id":1782032156000,"createdDate":"2026-06-21 08:55","name":"法国国际广播电台","title":"泽连斯基：克里米亚大桥两侧设施均遭袭，对俄后勤、石油工业等远程制裁","content":"据俄罗斯任命的克里米亚官员称，乌克兰无人机袭击了俄控克里米亚半岛，造成4人死亡，28人受伤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260621-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E5%85%8B%E9%87%8C%E7%B1%B3%E4%BA%9A%E5%A4%A7%E6%A1%A5%E4%B8%A4%E4%BE%A7%E8%AE%BE%E6%96%BD%E5%9D%87%E9%81%AD%E8%A2%AD%EF%BC%8C%E5%AF%B9%E4%BF%84%E5%90%8E%E5%8B%A4-%E7%9F%B3%E6%B2%B9%E5%B7%A5%E4%B8%9A%E7%AD%89%E8%BF%9C%E7%A8%8B%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782032156000.webp","sourceId":"rfi"},{"id":1782031004000,"createdDate":"2026-06-21 08:36","name":"法国国际广播电台","title":"首届日法高级别人工智能对话在巴黎举行","content":"日本外务省于6月20日报道称，6月19日，在法国巴黎，由日本外务审议官赤堀毅和法国欧洲及外交部副秘书长达维德·贝尔托洛蒂共同主持，在两国相关政府部门参加下，召开了首届日法高级别人工智能（AI）对话。此次对话分为政府间对话和官民对话两个部分，两国人工智能相关企业也参加了官民对话。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260621-%E9%A6%96%E5%B1%8A%E6%97%A5%E6%B3%95%E9%AB%98%E7%BA%A7%E5%88%AB%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E5%AF%B9%E8%AF%9D%E5%9C%A8%E5%B7%B4%E9%BB%8E%E4%B8%BE%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782031004000.webp","sourceId":"rfi"},{"id":1782058726000,"createdDate":"2026-06-21 16:18","name":"法国国际广播电台","title":"贝宁和尼日尔迈向重新开放边境","content":"贝宁与尼日尔之间的关系正在加速正常化。贝宁新总统于本月初（2026年06月02日）访问尼日尔首都，为重新缓和紧张局势注入了新的动力。据本台法广非洲组（RFIAfrique）的法文报导，在本月新成立的一个联合专家委员会于本周末（06月20日星期六和06月21日星期天）在科托努（Cotonou）会晤，磋商重启两国边境的相关事宜。贝宁的中文也有译作贝南共和国（leBénin）。尼日尔的中文也有译作尼日共和国(leNiger)。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260621-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E8%B4%9D%E5%AE%81%E5%92%8C%E5%B0%BC%E6%97%A5%E5%B0%94%E8%BF%88%E5%90%91%E9%87%8D%E6%96%B0%E5%BC%80%E6%94%BE%E8%BE%B9%E5%A2%83","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782058726000.webp","sourceId":"rfi"},{"id":1782048933000,"createdDate":"2026-06-21 13:35","name":"法国国际广播电台","title":"中国掀肥肝养殖潮产量激增 法国生产商深感不安","content":"近年来，中国肥肝产业发展迅速，让法国生产商感到不小的压力。过去十年里，肥肝在中国已经从一种高端食材逐渐走向大众市场，价格也变得更加亲民。与法国产肥肝相比，中国产品不仅价格更低、产量更大，而且近两年还开始积极开拓海外市场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260621-%E4%B8%AD%E5%9B%BD%E6%8E%80%E8%82%A5%E8%82%9D%E5%85%BB%E6%AE%96%E6%BD%AE%E4%BA%A7%E9%87%8F%E6%BF%80%E5%A2%9E-%E6%B3%95%E5%9B%BD%E7%94%9F%E4%BA%A7%E5%95%86%E6%B7%B1%E6%84%9F%E4%B8%8D%E5%AE%89","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782048933000.webp","sourceId":"rfi"},{"id":1782046625000,"createdDate":"2026-06-21 12:57","name":"法国国际广播电台","title":"5月份中国对日关键矿产出口量仍处低位","content":"5月份，中国对日部分关键矿产的出口量持续低迷，两国政治争端加剧了这一颓势。据中国海关数据显示，5月份部分关键钨矿以及稀土元素镝和铽的出口量为零。其他一些稀土类别的出口量也处于异常低位。自去11月，日本首相高市早苗作出“台湾有事”国会答辩激怒北京以来，工业矿物的流动一直备受关注。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-5%E6%9C%88%E4%BB%BD%E4%B8%AD%E5%9B%BD%E5%AF%B9%E6%97%A5%E5%85%B3%E9%94%AE%E7%9F%BF%E4%BA%A7%E5%87%BA%E5%8F%A3%E9%87%8F%E4%BB%8D%E5%A4%84%E4%BD%8E%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782046625000.webp","sourceId":"rfi"},{"id":1782043229000,"createdDate":"2026-06-21 12:00","name":"法国国际广播电台","title":"英外相加入“逼宫”队伍 预计斯塔默将于周一宣布辞职","content":"天空新闻台周日报导称，英国外交大臣库珀（YvetteCooper）已告知首相斯塔默（KeirStarmer），他必须辞职。据悉，库珀——斯塔默最资深的内阁部长之一——已于周末私下向首相传达了这一信息。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-%E8%8B%B1%E5%A4%96%E7%9B%B8%E5%8A%A0%E5%85%A5-%E9%80%BC%E5%AE%AB-%E9%98%9F%E4%BC%8D-%E9%A2%84%E8%AE%A1%E6%96%AF%E5%A1%94%E9%BB%98%E5%B0%86%E4%BA%8E%E5%91%A8%E4%B8%80%E5%AE%A3%E5%B8%83%E8%BE%9E%E8%81%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782043229000.webp","sourceId":"rfi"},{"id":1782042575000,"createdDate":"2026-06-21 11:49","name":"法国国际广播电台","title":"驻韩美军六辆萨德发射车全部返回驻地星州基地","content":"据韩联社周日援引多方消息报导指，在美伊战争期间从庆尚北道星州基地撤出的6辆驻韩美军“萨德”反导系统发射车已全部返回星州基地。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260621-%E9%A9%BB%E9%9F%A9%E7%BE%8E%E5%86%9B%E5%85%AD%E8%BE%86%E8%90%A8%E5%BE%B7%E5%8F%91%E5%B0%84%E8%BD%A6%E5%85%A8%E9%83%A8%E8%BF%94%E5%9B%9E%E9%A9%BB%E5%9C%B0%E6%98%9F%E5%B7%9E%E5%9F%BA%E5%9C%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782042575000.webp","sourceId":"rfi"},{"id":1782041179000,"createdDate":"2026-06-21 11:26","name":"法国国际广播电台","title":"日本五大芯片制造设备商在华销售额合计下降10% 有史以来首次下滑","content":"截至3月31日的财年中，日本五大芯片制造设备商对华销售额合计下降了10%，这是有史以来的首次下滑，主要是由于中国政府正致力于推动本国相关产业的发展。中国企业不仅从日企手中夺取市场份额，也从欧美竞争对手手中蚕食市场份额。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260621-%E6%97%A5%E6%9C%AC%E4%BA%94%E5%A4%A7%E8%8A%AF%E7%89%87%E5%88%B6%E9%80%A0%E8%AE%BE%E5%A4%87%E5%95%86%E5%9C%A8%E5%8D%8E%E9%94%80%E5%94%AE%E9%A2%9D%E5%90%88%E8%AE%A1%E4%B8%8B%E9%99%8D10-%E6%9C%89%E5%8F%B2%E4%BB%A5%E6%9D%A5%E9%A6%96%E6%AC%A1%E4%B8%8B%E6%BB%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782041179000.webp","sourceId":"rfi"},{"id":1782038303000,"createdDate":"2026-06-21 10:38","name":"法国国际广播电台","title":"2026年世界杯：因凡蒂诺乘坐私人飞机穿梭各个赛场 被指象征着国际足联的奢靡之风","content":"2026世界杯是历史上首次由三国共同主办。国际足联主席詹尼·因凡蒂诺乘私人飞机频繁穿梭于美加墨三国的各个赛场，碳排放量惊人引发环保组织批评，认为这凸显了该足球管理机构对任何气候相关倡议的漠视。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260621-2026%E5%B9%B4%E4%B8%96%E7%95%8C%E6%9D%AF-%E5%9B%A0%E5%87%A1%E8%92%82%E8%AF%BA%E4%B9%98%E5%9D%90%E7%A7%81%E4%BA%BA%E9%A3%9E%E6%9C%BA%E7%A9%BF%E6%A2%AD%E5%90%84%E4%B8%AA%E8%B5%9B%E5%9C%BA-%E8%A2%AB%E6%8C%87%E8%B1%A1%E5%BE%81%E7%9D%80%E5%9B%BD%E9%99%85%E8%B6%B3%E8%81%94%E7%9A%84%E5%A5%A2%E9%9D%A1%E4%B9%8B%E9%A3%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782038303000.webp","sourceId":"rfi"},{"id":1782037274000,"createdDate":"2026-06-21 10:21","name":"法国国际广播电台","title":"2026巴黎香港电影节第二日：不同世代的离散之苦与自我重塑","content":"2026巴黎香港电影节周日进入第二天。围绕本届电影节主题“离散之声”，周日下午将放映一部纪录片和四部短片。其中两部影片导演也会在放映之后与观众互动。晚间则将放映香港著名导演王家卫的作品《一代宗师》。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260621-2026%E5%B7%B4%E9%BB%8E%E9%A6%99%E6%B8%AF%E7%94%B5%E5%BD%B1%E8%8A%82%E7%AC%AC%E4%BA%8C%E6%97%A5-%E4%B8%8D%E5%90%8C%E4%B8%96%E4%BB%A3%E7%9A%84%E7%A6%BB%E6%95%A3%E4%B9%8B%E8%8B%A6%E4%B8%8E%E8%87%AA%E6%88%91%E9%87%8D%E5%A1%91","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782037274000.webp","sourceId":"rfi"},{"id":1782036922000,"createdDate":"2026-06-21 10:15","name":"法国国际广播电台","title":"民调：高市内阁支持率跌至55%，不支持率上升1.1%","content":"据共同社20日和21日实施的全国电话舆论调查结果显示，高市内阁的支持率为55.8%，创上台以来新低，比5月份的民调结果下降了5.5个百分点。30岁以下年轻人的支持率下降13.5个百分点，女性支持率下降9.2个百分点。不支持率上升1.1个百分点，达到27.9%。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-%E6%B0%91%E8%B0%83-%E9%AB%98%E5%B8%82%E5%86%85%E9%98%81%E6%94%AF%E6%8C%81%E7%8E%87%E8%B7%8C%E8%87%B355-%EF%BC%8C%E4%B8%8D%E6%94%AF%E6%8C%81%E7%8E%87%E4%B8%8A%E5%8D%871-1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782036922000.webp","sourceId":"rfi"},{"id":1782035781000,"createdDate":"2026-06-21 09:56","name":"法国国际广播电台","title":"台国防部：周一起实施“立即备战操演” 强化高战备立即应变能力","content":"台湾国防部周日通过新闻稿表示，为强化国军高战备立即应变能力，验证部队联合作战效能，将自明日起至26日止实施为期5天4夜的“立即备战操演”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-%E5%8F%B0%E5%9B%BD%E9%98%B2%E9%83%A8-%E5%91%A8%E4%B8%80%E8%B5%B7%E5%AE%9E%E6%96%BD-%E7%AB%8B%E5%8D%B3%E5%A4%87%E6%88%98%E6%93%8D%E6%BC%94-%E5%BC%BA%E5%8C%96%E9%AB%98%E6%88%98%E5%A4%87%E7%AB%8B%E5%8D%B3%E5%BA%94%E5%8F%98%E8%83%BD%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782035781000.webp","sourceId":"rfi"},{"id":1782075258000,"createdDate":"2026-06-21 20:54","name":"法国国际广播电台","title":"美国伊朗在瑞士谈判之日特朗普划红线发飙威胁“再打伊朗”","content":"周日，美国副总统万斯和伊朗官员在瑞士举行谈判之日，特朗普发飙威胁“再打伊朗”，他画出的红线：一是针对伊朗扬言关闭霍尔木兹海峡的威胁，二是针对黎巴嫩真主党武装如果继续开火。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260621-%E7%BE%8E%E5%9B%BD%E4%BC%8A%E6%9C%97%E5%9C%A8%E7%91%9E%E5%A3%AB%E8%B0%88%E5%88%A4%E4%B9%8B%E6%97%A5%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%91%E9%A3%99%E5%A8%81%E8%83%81-%E5%86%8D%E6%89%93%E4%BC%8A%E6%9C%97","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782075258000.webp","sourceId":"rfi"},{"id":1782073966000,"createdDate":"2026-06-21 20:32","name":"法国国际广播电台","title":"法国吉伦特省极端高温致3名老人死亡","content":"法国吉伦特省(Gironde)省长索菲·布罗卡斯(SophieBrocas)周日(6月21日)晚宣布，该省周日有3人死亡，年龄在80至95岁之间，疑似与极端高温有关。吉伦特省自周日中午起已进入红色高温预警。根据法国气象局最新预报，该地区从周一到周三气温可能接近43°C。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-%E6%B3%95%E5%9B%BD%E5%90%89%E4%BC%A6%E7%89%B9%E7%9C%81%E6%9E%81%E7%AB%AF%E9%AB%98%E6%B8%A9%E8%87%B43%E5%90%8D%E8%80%81%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782073966000.webp","sourceId":"rfi"},{"id":1782071043000,"createdDate":"2026-06-21 19:44","name":"法国国际广播电台","title":"拉米罗·巴尔德斯逝世：曾任切·格瓦拉的副手、古巴革命的重要人物","content":"古巴国家主席米格尔·迪亚斯-卡内尔周日(6月21日)在社交媒体上宣布，古巴革命英雄拉米罗·巴尔德斯(RamiroValdés)逝世，享年94岁。他曾担任切·格瓦拉副手并创建古巴强大的情报机构，同时他也是1959年由菲德尔·卡斯特罗领导的古巴革命最后几位历史人物之一。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-%E6%8B%89%E7%B1%B3%E7%BD%97%C2%B7%E5%B7%B4%E5%B0%94%E5%BE%B7%E6%96%AF%E9%80%9D%E4%B8%96-%E6%9B%BE%E4%BB%BB%E5%88%87%C2%B7%E6%A0%BC%E7%93%A6%E6%8B%89%E7%9A%84%E5%89%AF%E6%89%8B-%E5%8F%A4%E5%B7%B4%E9%9D%A9%E5%91%BD%E7%9A%84%E9%87%8D%E8%A6%81%E4%BA%BA%E7%89%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782071043000.webp","sourceId":"rfi"},{"id":1782069102000,"createdDate":"2026-06-21 19:11","name":"法国国际广播电台","title":"偶像的偶像：梅西罕见袒露心声表达对纳达尔的欣赏，纳达尔：“也祝贺你世界杯开局顺利”","content":"即便是传奇人物，也有自己的偶像。一向低调内敛的足坛巨星梅西罕见地袒露心声，表达了他对另一位传奇——纳达尔（RafaelNadal）的敬佩和欣赏。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-%E5%81%B6%E5%83%8F%E7%9A%84%E5%81%B6%E5%83%8F-%E6%A2%85%E8%A5%BF%E7%BD%95%E8%A7%81%E8%A2%92%E9%9C%B2%E5%BF%83%E5%A3%B0%E8%A1%A8%E8%BE%BE%E5%AF%B9%E7%BA%B3%E8%BE%BE%E5%B0%94%E7%9A%84%E6%AC%A3%E8%B5%8F%EF%BC%8C%E7%BA%B3%E8%BE%BE%E5%B0%94-%E4%B9%9F%E7%A5%9D%E8%B4%BA%E4%BD%A0%E4%B8%96%E7%95%8C%E6%9D%AF%E5%BC%80%E5%B1%80%E9%A1%BA%E5%88%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782069102000.webp","sourceId":"rfi"},{"id":1782068835000,"createdDate":"2026-06-21 19:07","name":"法国国际广播电台","title":"美最新民调显示战争疲劳升高 经济压力拖累特朗普支持度","content":"美国最新多项民调显示，多数民众支持结束对伊朗战争，但同时对战争成果，与美国是否真正达成战略目标，抱持高度怀疑。随着2026年期中选举逼近，经济压力、油价波动与国际冲突交织，使美国总统特朗普（DonaldTrump）支持度持续承压，共和党选情也面临更复杂局面。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-%E7%BE%8E%E6%9C%80%E6%96%B0%E6%B0%91%E8%B0%83%E6%98%BE%E7%A4%BA%E6%88%98%E4%BA%89%E7%96%B2%E5%8A%B3%E5%8D%87%E9%AB%98-%E7%BB%8F%E6%B5%8E%E5%8E%8B%E5%8A%9B%E6%8B%96%E7%B4%AF%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%AF%E6%8C%81%E5%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782068835000.webp","sourceId":"rfi"},{"id":1782068187000,"createdDate":"2026-06-21 18:56","name":"法国国际广播电台","title":"德防长公开指责特朗普应对霍尔木兹海峡关闭负责","content":"德国国防部长鲍里斯·皮斯托里乌斯（BorisPistorius）周日(6月21日)表示，美国总统特朗普应对伊朗宣布关闭霍尔木兹海峡负主要责任，并呼吁尽快恢复这一关键航道的通行。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-%E5%BE%B7%E9%98%B2%E9%95%BF%E5%85%AC%E5%BC%80%E6%8C%87%E8%B4%A3%E7%89%B9%E6%9C%97%E6%99%AE%E5%BA%94%E5%AF%B9%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%85%B3%E9%97%AD%E8%B4%9F%E8%B4%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782068187000.webp","sourceId":"rfi"},{"id":1782067724000,"createdDate":"2026-06-21 18:48","name":"法国国际广播电台","title":"乌克兰远程无人机越飞越远 攻击俄罗斯炼油厂","content":"俄罗斯扶植的克里米亚半岛行政首长阿克瑟诺夫（SergeiAksyonov）21日表示，乌克兰无人机攻击克里米亚，导致4人死亡、28人受伤。此外，俄罗斯的克拉斯诺达边疆区也传出1人死亡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260621-%E4%B9%8C%E5%85%8B%E5%85%B0%E8%BF%9C%E7%A8%8B%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%B6%8A%E9%A3%9E%E8%B6%8A%E8%BF%9C-%E6%94%BB%E5%87%BB%E4%BF%84%E7%BD%97%E6%96%AF%E7%82%BC%E6%B2%B9%E5%8E%82","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782067724000.webp","sourceId":"rfi"},{"id":1782066931000,"createdDate":"2026-06-21 18:35","name":"法国国际广播电台","title":"美伊瑞士谈判开局艰难：伊朗警告美方“最好谨慎措辞”","content":"美国和伊朗谈判代表周日（6月21日）在瑞士会面，就双方此前达成的临时协议展开讨论。这次谈判目标是在可延长的60天期限内达成最终协议，以结束中东冲突。美方代表团由美国副总统万斯率领，成员包括库什纳和威特科夫。伊朗方面则由议会议长卡利巴夫和外长阿拉格奇率领。巴基斯坦和卡塔尔担任调解方。然而，特朗普周日曾多次对伊朗发出强硬警告，包括称将“再次对伊朗实施强力打击”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-%E7%BE%8E%E4%BC%8A%E7%91%9E%E5%A3%AB%E8%B0%88%E5%88%A4-%E4%BC%8A%E6%9C%97%E8%AD%A6%E5%91%8A%E7%BE%8E%E6%96%B9-%E6%9C%80%E5%A5%BD%E8%B0%A8%E6%85%8E%E6%8E%AA%E8%BE%9E-%EF%BC%8C%E4%BC%8A%E6%9C%97%E4%BB%A3%E8%A1%A8%E5%9B%A2%E6%8B%92%E7%BB%9D%E4%B8%8E%E7%BE%8E%E5%9B%BD%E4%BB%A3%E8%A1%A8%E5%90%88%E5%BD%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782066931000.webp","sourceId":"rfi"},{"id":1782066472000,"createdDate":"2026-06-21 18:27","name":"法国国际广播电台","title":"几内亚东南重镇大市场遭遇祝融","content":"西非国家几内亚（laGuinée）森林地区的最大城市恩泽雷科雷（Nzérékoré）大市场于2026年06月19日星期五几乎被祝融夷为平地。当局宣称，没有人在火灾中死亡，仅有少数人受轻伤。不过，物资损失相当惨重。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260621-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%87%A0%E5%86%85%E4%BA%9A%E4%B8%9C%E5%8D%97%E9%87%8D%E9%95%87%E5%A4%A7%E5%B8%82%E5%9C%BA%E9%81%AD%E9%81%87%E7%A5%9D%E8%9E%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782066472000.webp","sourceId":"rfi"},{"id":1782064221000,"createdDate":"2026-06-21 17:50","name":"法国国际广播电台","title":"特朗普默认\"斯塔默辞职\"成事实，在社交平台公开送去祝福：“我祝他一切顺利！”","content":"特朗普周日（6月21日）表示，他祝愿英国首相斯塔默“一切顺利”，并已将斯塔默辞职视为既成事实，同时还不忘批评他的移民和能源政策。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260621-%E7%89%B9%E6%9C%97%E6%99%AE%E9%BB%98%E8%AE%A4-%E6%96%AF%E5%A1%94%E9%BB%98%E8%BE%9E%E8%81%8C-%E6%88%90%E4%BA%8B%E5%AE%9E%EF%BC%8C%E5%9C%A8%E7%A4%BE%E4%BA%A4%E5%B9%B3%E5%8F%B0%E5%85%AC%E5%BC%80%E9%80%81%E5%8E%BB%E7%A5%9D%E7%A6%8F-%E6%88%91%E7%A5%9D%E4%BB%96%E4%B8%80%E5%88%87%E9%A1%BA%E5%88%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782064221000.webp","sourceId":"rfi"},{"id":1782063151000,"createdDate":"2026-06-21 17:32","name":"法国国际广播电台","title":"法国35省进入高温红色预警：周日音乐节多地罕见实行禁酒令，周一845所学校停课","content":"周日(6月21日)，法国迎来一场异常强烈的热浪，气温接近40°C，全国有35个省进入最高级别的红色高温预警。这一数字意味着法国约三分之一的地区都发布了高温“红色预警”，而在这个空调普及率并不高的国家，高温天气显得越来越致命。此外，极端高温已扰乱多项公共服务和活动安排，例如每年一年一度备受欢迎的“音乐节”，本来原定周日举行，但多座城市取消了街头和酒吧的演出，不过，巴黎、里昂和斯特拉斯堡仍决定维持庆祝活动。","newsLink":"https://www.rfi.fr/cn/%E7%94%9F%E6%80%81/20260621-%E6%B3%95%E5%9B%BD35%E7%9C%81%E8%BF%9B%E5%85%A5%E9%AB%98%E6%B8%A9%E7%BA%A2%E8%89%B2%E9%A2%84%E8%AD%A6-%E5%91%A8%E6%97%A5%E9%9F%B3%E4%B9%90%E8%8A%82%E5%A4%9A%E5%9C%B0%E5%AE%9E%E8%A1%8C%E7%A6%81%E9%85%92%E4%BB%A4%EF%BC%8C%E5%91%A8%E4%B8%80845%E6%89%80%E5%AD%A6%E6%A0%A1%E5%81%9C%E8%AF%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782063151000.webp","sourceId":"rfi"}]