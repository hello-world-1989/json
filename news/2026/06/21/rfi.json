[{"id":1782033992000,"createdDate":"2026-06-21 09:26","name":"法国国际广播电台","title":"伊朗媒体称霍尔木兹海峡仍关闭 万斯提瑞士会谈应关注两件大事","content":"伊朗外交部发言人巴加埃告诉其官媒称，伊朗、美国、卡塔尔和巴基斯坦将于周日下午在瑞士布尔根施托克山顶度假胜地举行四方会谈。巴加埃表示，伊朗将首先与中间人卡塔尔和巴基斯坦举行会谈，并指此次在瑞士举行的会谈是对上周与美国签署的谅解备忘录的后续落实工作。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260621-%E4%BC%8A%E6%9C%97%E5%AA%92%E4%BD%93%E7%A7%B0%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E4%BB%8D%E5%85%B3%E9%97%AD-%E4%B8%87%E6%96%AF%E6%8F%90%E7%91%9E%E5%A3%AB%E4%BC%9A%E8%B0%88%E5%BA%94%E5%85%B3%E6%B3%A8%E7%9A%84%E4%B8%A4%E4%BB%B6%E5%A4%A7%E4%BA%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782033992000.webp","sourceId":"rfi"},{"id":1782032156000,"createdDate":"2026-06-21 08:55","name":"法国国际广播电台","title":"泽连斯基：克里米亚大桥两侧设施均遭袭，对俄后勤、石油工业等远程制裁","content":"据俄罗斯任命的克里米亚官员称，乌克兰无人机袭击了俄控克里米亚半岛，造成4人死亡，28人受伤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260621-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E5%85%8B%E9%87%8C%E7%B1%B3%E4%BA%9A%E5%A4%A7%E6%A1%A5%E4%B8%A4%E4%BE%A7%E8%AE%BE%E6%96%BD%E5%9D%87%E9%81%AD%E8%A2%AD%EF%BC%8C%E5%AF%B9%E4%BF%84%E5%90%8E%E5%8B%A4-%E7%9F%B3%E6%B2%B9%E5%B7%A5%E4%B8%9A%E7%AD%89%E8%BF%9C%E7%A8%8B%E5%88%B6%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782032156000.webp","sourceId":"rfi"},{"id":1782031004000,"createdDate":"2026-06-21 08:36","name":"法国国际广播电台","title":"首届日法高级别人工智能对话在巴黎举行","content":"日本外务省于6月20日报道称，6月19日，在法国巴黎，由日本外务审议官赤堀毅和法国欧洲及外交部副秘书长达维德·贝尔托洛蒂共同主持，在两国相关政府部门参加下，召开了首届日法高级别人工智能（AI）对话。此次对话分为政府间对话和官民对话两个部分，两国人工智能相关企业也参加了官民对话。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260621-%E9%A6%96%E5%B1%8A%E6%97%A5%E6%B3%95%E9%AB%98%E7%BA%A7%E5%88%AB%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD%E5%AF%B9%E8%AF%9D%E5%9C%A8%E5%B7%B4%E9%BB%8E%E4%B8%BE%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/06/21/1782031004000.webp","sourceId":"rfi"}]