[{"id":1781518461000,"createdDate":"2026-06-15 10:14","name":"法国国际广播电台","title":"瑞典大胜领军小组赛、突尼斯处劣势翻身难","content":"2026年世界杯小组赛继续进行，在F组的小组赛中，欧洲瑞典队大胜连续失误的非洲突尼斯队。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260615-%E7%91%9E%E5%85%B8%E5%A4%A7%E8%83%9C%E9%A2%86%E5%86%9B%E5%B0%8F%E7%BB%84%E8%B5%9B-%E5%A4%84%E5%8A%A3%E5%8A%BF%E7%AA%81%E5%B0%BC%E6%96%AF%E7%BF%BB%E8%BA%AB%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781518461000.webp","sourceId":"rfi"},{"id":1781513549000,"createdDate":"2026-06-15 08:52","name":"法国国际广播电台","title":"脱下军装的敏昂来以缅甸总统身份开启对中国的访问","content":"缅甸前军政府首脑敏昂莱周一（6月15日）抵达北京，开始为期五天的国事访问。这是他今年4月出任缅甸总统后首次访问中国，也是继5月底访问印度后的第二次出访。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260615-%E8%84%B1%E4%B8%8B%E5%86%9B%E8%A3%85%E7%9A%84%E6%95%8F%E6%98%82%E6%9D%A5%E4%BB%A5%E7%BC%85%E7%94%B8%E6%80%BB%E7%BB%9F%E8%BA%AB%E4%BB%BD%E5%BC%80%E5%90%AF%E5%AF%B9%E4%B8%AD%E5%9B%BD%E7%9A%84%E8%AE%BF%E9%97%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781513549000.webp","sourceId":"rfi"},{"id":1781512774000,"createdDate":"2026-06-15 08:39","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第25： 浪漫主义群星之一：浪漫派中萌生的现代之花 - 疯狂的克莱斯特","content":"在海德堡浪漫派吹响男童的神奇魔号的同时，占据德国文坛主位几十载的浪漫主义开始分孽出风格特异的花枝。它所展示出的样态，所使用的手法，所追求的效果，所表现的感受都有着强烈的现代气息。它丰富了浪漫主义文学，深化了浪漫主义的理念和思考，同时也把浪漫主义带入一个更复杂的评价体系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260615-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC25-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%80-%E6%B5%AA%E6%BC%AB%E6%B4%BE%E4%B8%AD%E8%90%8C%E7%94%9F%E7%9A%84%E7%8E%B0%E4%BB%A3%E4%B9%8B%E8%8A%B1-%E7%96%AF%E7%8B%82%E7%9A%84%E5%85%8B%E8%8E%B1%E6%96%AF%E7%89%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781512774000.webp","sourceId":"rfi"},{"id":1781511061000,"createdDate":"2026-06-15 08:11","name":"法国国际广播电台","title":"台湾水果外交进军欧盟市场 首批四吨台湾芒果已抵达法国","content":"台湾驻法代表郝培芝表示，台湾水果要进到欧盟市场，真的要历经很多努力。这项外交与农业的重大突破背后有两大关键。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260615-%E5%8F%B0%E6%B9%BE%E6%B0%B4%E6%9E%9C%E5%A4%96%E4%BA%A4%E8%BF%9B%E5%86%9B%E6%AC%A7%E7%9B%9F%E5%B8%82%E5%9C%BA-%E9%A6%96%E6%89%B9%E5%9B%9B%E5%90%A8%E5%8F%B0%E6%B9%BE%E8%8A%92%E6%9E%9C%E5%B7%B2%E6%8A%B5%E8%BE%BE%E6%B3%95%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781511061000.webp","sourceId":"rfi"},{"id":1781510473000,"createdDate":"2026-06-15 08:01","name":"法国国际广播电台","title":"日本外务大臣发表谈话 欢迎美伊同意签署停战备忘录","content":"6月15日，美国和伊朗双方宣布，已就有关结束战斗等事项的谅解备忘录达成一致，为此，日本外务大臣茂木敏充15日当天发表关于伊朗局势的外务大臣谈话，代表日本政府对此表示欢迎。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260615-%E6%97%A5%E6%9C%AC%E5%A4%96%E5%8A%A1%E5%A4%A7%E8%87%A3%E5%8F%91%E8%A1%A8%E8%B0%88%E8%AF%9D-%E6%AC%A2%E8%BF%8E%E7%BE%8E%E4%BC%8A%E5%90%8C%E6%84%8F%E7%AD%BE%E7%BD%B2%E5%81%9C%E6%88%98%E5%A4%87%E5%BF%98%E5%BD%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781510473000.webp","sourceId":"rfi"},{"id":1781509889000,"createdDate":"2026-06-15 07:51","name":"法国国际广播电台","title":"京官夏宝龙访港前夕 香港特首李家超回应连任时称「时机到便会知道」","content":"香港特首李家超任期尚有一年便结束，他近日接受多家亲北京媒体专访时多被问及连任与否等问题，他的最新答案是「时机到便会知道」。有关专访适逢主管港澳事务的港澳办主任夏宝龙将於本周访港，以视察北部都会区(北都)发展和香港对接国家「十五五」规划的工作，引发外界联想，更关注李家超会否趁机大力推销其政绩和表明有意连任的心迹，为自己争取「再坐一会」的机会。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260615-%E4%BA%AC%E5%AE%98%E5%A4%8F%E5%AE%9D%E9%BE%99%E8%AE%BF%E6%B8%AF%E5%89%8D%E5%A4%95-%E9%A6%99%E6%B8%AF%E7%89%B9%E9%A6%96%E6%9D%8E%E5%AE%B6%E8%B6%85%E5%9B%9E%E5%BA%94%E8%BF%9E%E4%BB%BB%E6%97%B6%E7%A7%B0-%E6%97%B6%E6%9C%BA%E5%88%B0%E4%BE%BF%E4%BC%9A%E7%9F%A5%E9%81%93","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781509889000.webp","sourceId":"rfi"},{"id":1781544590000,"createdDate":"2026-06-15 17:29","name":"法国国际广播电台","title":"尼日利亚西北部再爆圣战分子袭击事件20人死亡","content":"尼日利亚西北部发生一起由圣战分子发动的袭击事件，造成20人死亡。这些圣战分子涉嫌属于去年12月遭美军空袭的目标组织。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260615-%E5%B0%BC%E6%97%A5%E5%88%A9%E4%BA%9A%E8%A5%BF%E5%8C%97%E9%83%A8%E5%86%8D%E7%88%86%E5%9C%A3%E6%88%98%E5%88%86%E5%AD%90%E8%A2%AD%E5%87%BB%E4%BA%8B%E4%BB%B620%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781544590000.webp","sourceId":"rfi"},{"id":1781539547000,"createdDate":"2026-06-15 16:05","name":"法国国际广播电台","title":"乌克兰：俄军空袭致11人死亡 一座标志性大教堂受损","content":"周一，俄罗斯对乌克兰多座城市发动的一系列空袭造成至少11人死亡，一场大火还烧毁了基辅圣母安息大教堂的屋顶——这座东正教标志性建筑被列入联合国教科文组织世界遗产名录。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260615-%E4%B9%8C%E5%85%8B%E5%85%B0-%E4%BF%84%E5%86%9B%E7%A9%BA%E8%A2%AD%E8%87%B411%E4%BA%BA%E6%AD%BB%E4%BA%A1-%E4%B8%80%E5%BA%A7%E6%A0%87%E5%BF%97%E6%80%A7%E5%A4%A7%E6%95%99%E5%A0%82%E5%8F%97%E6%8D%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781539547000.webp","sourceId":"rfi"},{"id":1781537581000,"createdDate":"2026-06-15 15:33","name":"法国国际广播电台","title":"2026巴黎欧洲防务展开幕 无人机受瞩目 坦克顶部加装护罩","content":"欧洲备战之际，欧洲防务展（Eurosatory）周一在巴黎近郊维勒班特拉开帷幕。法新社说，展厅内无人机随处可见，地面机器人赫然矗立在装甲车和火炮之间。乌克兰战争凸显武器已进入另一个时代...","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260615-2026%E5%B7%B4%E9%BB%8E%E6%AC%A7%E6%B4%B2%E9%98%B2%E5%8A%A1%E5%B1%95%E5%BC%80%E5%B9%95-%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%8F%97%E7%9E%A9%E7%9B%AE-%E5%9D%A6%E5%85%8B%E9%A1%B6%E9%83%A8%E5%8A%A0%E8%A3%85%E6%8A%A4%E7%BD%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781537581000.webp","sourceId":"rfi"},{"id":1781535383000,"createdDate":"2026-06-15 14:56","name":"法国国际广播电台","title":"Meta旗下社群今大停摆 遭问与习生日有关？","content":"Meta旗下社群平台今天6月15日大停摆，不少台湾民众、网红、政治人物帐号被无预警停权，台湾中央社也同命运。有网民怀疑是扎克伯格打包送习近平的生日礼物...","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260615-meta%E6%97%97%E4%B8%8B%E7%A4%BE%E7%BE%A4%E4%BB%8A%E5%A4%A7%E5%81%9C%E6%91%86-%E9%81%AD%E9%97%AE%E4%B8%8E%E4%B9%A0%E7%94%9F%E6%97%A5%E6%9C%89%E5%85%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781535383000.webp","sourceId":"rfi"},{"id":1781532504000,"createdDate":"2026-06-15 14:08","name":"法国国际广播电台","title":"G7埃维昂峰会开幕：特朗普备受期待 马克龙力推霍尔木兹海峡重启通航","content":"七国集团（G7）领袖峰会周一（6月15日）在法国东部、阿尔卑斯山脚下的湖畔小城埃维昂开幕，会期三天。峰会召开正值美国与伊朗刚刚宣布达成结束战争的初步协议，获得这一重大外交成果的美国总统特朗普成为峰会焦点，而东道主法国总统马克龙则希望借此契机，启动英法牵头的国际行动，协助霍尔木兹海峡恢复通航，推动中东局势尽快降温，并在全球经济失衡、乌克兰战争以及人工智能监管等议题上取得共识。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260615-g7%E5%B3%B0%E4%BC%9A%E5%9F%83%E7%BB%B4%E6%98%82%E5%BC%80%E5%B9%95-%E7%89%B9%E6%9C%97%E6%99%AE%E5%A4%87%E5%8F%97%E6%9C%9F%E5%BE%85-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%8A%9B%E6%8E%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%87%8D%E5%90%AF%E9%80%9A%E8%88%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781532504000.webp","sourceId":"rfi"},{"id":1781532456000,"createdDate":"2026-06-15 14:07","name":"法国国际广播电台","title":"美伊协议令七国集团法国峰会充满变数","content":"15日出版的法国全国性大报重点关注的国际话题有：在法国埃维昂举行的七大工业国集团领导人峰会、美伊可能达成协议给中东危机带来的希望、在巴黎近郊开幕的2026欧洲防务展（Eurosatory2026）、美国政府禁止外国使用美国科技巨头Anthropic开发的人工智能模型对欧洲的影响，等等。各报今天没有关于中国的特别报道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260615-%E7%BE%8E%E4%BC%8A%E5%8D%8F%E8%AE%AE%E4%BB%A4%E4%B8%83%E5%9B%BD%E9%9B%86%E5%9B%A2%E6%B3%95%E5%9B%BD%E5%B3%B0%E4%BC%9A%E5%85%85%E6%BB%A1%E5%8F%98%E6%95%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781532456000.webp","sourceId":"rfi"},{"id":1781530454000,"createdDate":"2026-06-15 13:34","name":"法国国际广播电台","title":"英国计划禁止16岁下儿童青少年使用社交媒体：  “让孩子们更健康、更快乐”","content":"英国首相基尔·斯塔默周一（6月15号）表示，他计划推出迄今为止全球影响最广泛的网络限制措施。将禁止社交媒体平台向16岁以下未成年人提供服务，让孩子们不再花大量时间刷屏，多进行现实世界的活动和游戏。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260615-%E8%8B%B1%E5%9B%BD%E8%AE%A1%E5%88%92%E7%A6%81%E6%AD%A216%E5%B2%81%E4%B8%8B%E5%84%BF%E7%AB%A5%E9%9D%92%E5%B0%91%E5%B9%B4%E4%BD%BF%E7%94%A8%E7%A4%BE%E4%BA%A4%E5%AA%92%E4%BD%93-%E8%AE%A9%E5%AD%A9%E5%AD%90%E4%BB%AC%E6%9B%B4%E5%81%A5%E5%BA%B7-%E6%9B%B4%E5%BF%AB%E4%B9%90","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781530454000.webp","sourceId":"rfi"},{"id":1781530298000,"createdDate":"2026-06-15 13:31","name":"法国国际广播电台","title":"分析：G7法国峰会  中国问题将成为一个不容忽视的焦点","content":"美国总统唐纳德·特朗普和其他一些世界最富裕国家的领导人将于6月15日至17日在日内瓦湖畔的法国小镇埃维昂莱班举行七国集团峰会。从表面上看，全球安全问题，包括中东和乌克兰局势以及关键资源的获取将是今年峰会的首要议题。但专家预计，特朗普将在峰会期间试探伙伴国在与中国的长期竞争中支持美国的意愿。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260615-%E5%88%86%E6%9E%90-g7%E6%B3%95%E5%9B%BD%E5%B3%B0%E4%BC%9A-%E4%B8%AD%E5%9B%BD%E9%97%AE%E9%A2%98%E5%B0%86%E6%88%90%E4%B8%BA%E4%B8%80%E4%B8%AA%E4%B8%8D%E5%AE%B9%E5%BF%BD%E8%A7%86%E7%9A%84%E7%84%A6%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781530298000.webp","sourceId":"rfi"},{"id":1781530212000,"createdDate":"2026-06-15 13:30","name":"法国国际广播电台","title":"美国国防部长皮特·赫格塞斯否认美军面临弹药短缺","content":"美国国防部长皮特·赫格塞斯周日否认美军面临弹药短缺，称这是媒体“捏造的故事”。赫格塞斯在接受哥伦比亚广播公司（CBS）“面对国家”（FacetheNation）节目采访时被问到是否存在弹药危机，他驳斥了这一说法。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260615-%E7%BE%8E%E5%9B%BD%E5%9B%BD%E9%98%B2%E9%83%A8%E9%95%BF%E7%9A%AE%E7%89%B9%C2%B7%E8%B5%AB%E6%A0%BC%E5%A1%9E%E6%96%AF%E5%90%A6%E8%AE%A4%E7%BE%8E%E5%86%9B%E9%9D%A2%E4%B8%B4%E5%BC%B9%E8%8D%AF%E7%9F%AD%E7%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781530212000.webp","sourceId":"rfi"},{"id":1781529036000,"createdDate":"2026-06-15 13:10","name":"法国国际广播电台","title":"中国对美国伊朗协议表示“欢迎” 对巴基斯坦调解工作表示“赞赏”","content":"中国周一对美国和伊朗宣布达成旨在结束中东战争的谅解备忘录表示欢迎，同时对巴基斯坦的调解努力表示赞赏。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260615-%E4%B8%AD%E5%9B%BD%E5%AF%B9%E7%BE%8E%E5%9B%BD%E4%BC%8A%E6%9C%97%E5%8D%8F%E8%AE%AE%E8%A1%A8%E7%A4%BA-%E6%AC%A2%E8%BF%8E-%E5%AF%B9%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E8%B0%83%E8%A7%A3%E5%B7%A5%E4%BD%9C%E8%A1%A8%E7%A4%BA-%E8%B5%9E%E8%B5%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781529036000.webp","sourceId":"rfi"},{"id":1781525635000,"createdDate":"2026-06-15 12:13","name":"法国国际广播电台","title":"G7艾维昂峰会周一开幕 特朗普赴会士气高涨 威胁对法国酒征100%关税","content":"七国集团领导人峰会周一在法国埃维昂开幕。在与德黑兰达成协议，并举办了一场盛大生日庆典后，士气高涨的唐纳德·特朗普飞往法国参加G7峰会备受期待。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260615-g7%E8%89%BE%E7%BB%B4%E6%98%82%E5%B3%B0%E4%BC%9A%E5%91%A8%E4%B8%80%E5%BC%80%E5%B9%95-%E7%89%B9%E6%9C%97%E6%99%AE%E8%B5%B4%E4%BC%9A%E5%A3%AB%E6%B0%94%E9%AB%98%E6%B6%A8-%E5%A8%81%E8%83%81%E5%AF%B9%E6%B3%95%E5%9B%BD%E9%85%92%E5%BE%81100-%E5%85%B3%E7%A8%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781525635000.webp","sourceId":"rfi"},{"id":1781524287000,"createdDate":"2026-06-15 11:51","name":"法国国际广播电台","title":"美国伊朗达成谅解备忘录 签署前将在多哈举行筹备会谈","content":"美国和伊朗官员表示，双方已就一项旨在结束两国冲突、解除美国对伊朗封锁以及重新开放霍尔木兹海峡的框架达成一致。据接近谈判的人士透露，19日在瑞士签署谅解备忘录之前，将在多哈举行筹备会议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260615-%E7%BE%8E%E5%9B%BD%E4%BC%8A%E6%9C%97%E8%BE%BE%E6%88%90%E8%B0%85%E8%A7%A3%E5%A4%87%E5%BF%98%E5%BD%95-%E7%AD%BE%E7%BD%B2%E5%89%8D%E5%B0%86%E5%9C%A8%E5%A4%9A%E5%93%88%E4%B8%BE%E8%A1%8C%E7%AD%B9%E5%A4%87%E4%BC%9A%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781524287000.webp","sourceId":"rfi"},{"id":1781520850000,"createdDate":"2026-06-15 10:54","name":"法国国际广播电台","title":"日本菲律宾启动海域划界的目的究竟是什么？","content":"日本首相高市早苗与菲律宾总统马科斯于日本时间5月28日发表关于全面战略伙伴关系的日菲联合声明，联合声明表明，双方已就启动划定两国专属经济区（EEZ）及大陆架海洋边界的谈判达成一致。为此，日本时间5月29日，中国外交部发言人毛宁在其主持的例行记者会上表示：中方对此强烈不满，坚决反对，已分别向日、菲提出严正交涉。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260615-%E6%97%A5%E6%9C%AC%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%90%AF%E5%8A%A8%E6%B5%B7%E5%9F%9F%E5%88%92%E7%95%8C%E7%9A%84%E7%9B%AE%E7%9A%84%E7%A9%B6%E7%AB%9F%E6%98%AF%E4%BB%80%E4%B9%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781520850000.webp","sourceId":"rfi"},{"id":1781566896000,"createdDate":"2026-06-15 23:41","name":"法国国际广播电台","title":"订单实在太多！空客在图卢兹新增一条A320总装线","content":"欧洲航空航天巨头空中客车（Airbus）周一在法国图卢兹附近正式启动了第二条A320总装生产线。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260615-%E8%AE%A2%E5%8D%95%E5%AE%9E%E5%9C%A8%E5%A4%AA%E5%A4%9A-%E7%A9%BA%E5%AE%A2%E5%9C%A8%E5%9B%BE%E5%8D%A2%E5%85%B9%E6%96%B0%E5%A2%9E%E4%B8%80%E6%9D%A1a320%E6%80%BB%E8%A3%85%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781566896000.webp","sourceId":"rfi"},{"id":1781566514000,"createdDate":"2026-06-15 23:35","name":"法国国际广播电台","title":"盲目决策代价大：特朗普，听听七国集团盟友的意见吧！","content":"美国与伊朗6月14日星期日宣布达成停战框架协议。与此同时，美国总统特朗普周一前来法国上萨瓦省埃维昂，参加在这里举行的七国集团峰会。在这一背景之下，法国世界报周一发表社论对特朗普盲目决策进行了严厉的批评。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260615-%E7%9B%B2%E7%9B%AE%E5%86%B3%E7%AD%96%E4%BB%A3%E4%BB%B7%E5%A4%A7-%E7%89%B9%E6%9C%97%E6%99%AE%EF%BC%8C%E5%90%AC%E5%90%AC%E4%B8%83%E5%9B%BD%E9%9B%86%E5%9B%A2%E7%9B%9F%E5%8F%8B%E7%9A%84%E6%84%8F%E8%A7%81%E5%90%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781566514000.webp","sourceId":"rfi"},{"id":1781563068000,"createdDate":"2026-06-15 22:37","name":"法国国际广播电台","title":"陷入战争泥潭的特朗普对伊朗作出重大让步","content":"从表面上看，与德黑兰达成框架性协议后，特朗普似乎找到从中东战场抽身的办法，同时也使得国际市场能源逐渐降价。然而，在诸多分析人士眼中，协议的内容与特朗普战争之初宣布的目标相去甚远。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260615-%E9%99%B7%E5%85%A5%E6%88%98%E4%BA%89%E6%B3%A5%E6%BD%AD%E7%9A%84%E7%89%B9%E6%9C%97%E6%99%AE%E5%AF%B9%E4%BC%8A%E6%9C%97%E4%BD%9C%E5%87%BA%E9%87%8D%E5%A4%A7%E8%AE%A9%E6%AD%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781563068000.webp","sourceId":"rfi"},{"id":1781560256000,"createdDate":"2026-06-15 21:50","name":"法国国际广播电台","title":"2026世界杯:爱尔兰球迷挺科特迪瓦","content":"2026年第23届世界杯足球赛（CoupeduMonde2026）正在北美紧张而激烈的进行之中。在E组首轮比赛中，科特迪瓦(laCôted'Ivoire)凭借球星阿马德·迪亚洛（AmadDiallo）在第90分钟时的决定性一击，最终以1比0绝杀对手厄瓜多尔（l'Equateur）。本台法广（RFI）法语特派记者（EnvoyéSpécial）发自美国费城（Philadelphie）林肯金融球场（LincolnFinancialField）的现场报导说，在一个以厄瓜多尔球迷占绝对多数的球场内，科特迪瓦的国脚们在拥有科特迪瓦和法国双重国籍教练埃梅尔斯·法埃（ÉmerseFaé）的率领下，赢得了这场出乎意外的胜利（unevictoireinespérée）。在英国苏格兰的一名爱尔兰酒吧店主接受采访，解释了欧洲的爱尔兰球迷为何支持绰号[大象]（lesÉléphants）的非洲科特迪瓦国家足球队。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260615-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-2026%E4%B8%96%E7%95%8C%E6%9D%AF-%E7%88%B1%E5%B0%94%E5%85%B0%E7%90%83%E8%BF%B7%E6%8C%BA%E7%A7%91%E7%89%B9%E8%BF%AA%E7%93%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781560256000.webp","sourceId":"rfi"},{"id":1781559048000,"createdDate":"2026-06-15 21:30","name":"法国国际广播电台","title":"谷歌称与中国有关联黑客组织长期渗透美加科研机构","content":"谷歌周一（6月15日）表示，一个被认为与中国有关联的黑客组织在长达一年多时间里秘密窃取美国和加拿大多家学术、医疗及军事研究机构的数据，直至其活动被发现。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260615-%E8%B0%B7%E6%AD%8C%E7%A7%B0%E4%B8%8E%E4%B8%AD%E5%9B%BD%E6%9C%89%E5%85%B3%E8%81%94%E9%BB%91%E5%AE%A2%E7%BB%84%E7%BB%87%E9%95%BF%E6%9C%9F%E6%B8%97%E9%80%8F%E7%BE%8E%E5%8A%A0%E7%A7%91%E7%A0%94%E6%9C%BA%E6%9E%84","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781559048000.webp","sourceId":"rfi"},{"id":1781558688000,"createdDate":"2026-06-15 21:24","name":"法国国际广播电台","title":"乌克兰迈出加入欧盟重要一步 但入盟之路仍漫长艰难","content":"在多年僵局之后，乌克兰周一（6月15日）在加入欧盟进程中迈出重要一步。在匈牙利撤回持续两年多的反对立场后，欧盟正式启动与乌克兰的首批入盟谈判，基辅的入欧进程取得重要进展。不过，对于这个仍处于战争中的国家而言，距离成为欧盟正式成员国仍有漫长而艰难的道路要走。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260615-%E4%B9%8C%E5%85%8B%E5%85%B0%E8%BF%88%E5%87%BA%E5%8A%A0%E5%85%A5%E6%AC%A7%E7%9B%9F%E9%87%8D%E8%A6%81%E4%B8%80%E6%AD%A5-%E4%BD%86%E5%85%A5%E7%9B%9F%E4%B9%8B%E8%B7%AF%E4%BB%8D%E6%BC%AB%E9%95%BF%E8%89%B0%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781558688000.webp","sourceId":"rfi"},{"id":1781558453000,"createdDate":"2026-06-15 21:20","name":"法国国际广播电台","title":"特朗普称将推动结束俄乌战争 泽连斯基提议在美国会晤普京","content":"美国总统特朗普周一（6月15日）在七国集团（G7）峰会期间表示，在推动美伊达成结束战争的框架协议后，他将把外交重点转向结束俄乌战争。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260615-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E5%B0%86%E6%8E%A8%E5%8A%A8%E7%BB%93%E6%9D%9F%E4%BF%84%E4%B9%8C%E6%88%98%E4%BA%89-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E6%8F%90%E8%AE%AE%E5%9C%A8%E7%BE%8E%E5%9B%BD%E4%BC%9A%E6%99%A4%E6%99%AE%E4%BA%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781558453000.webp","sourceId":"rfi"},{"id":1781558270000,"createdDate":"2026-06-15 21:17","name":"法国国际广播电台","title":"特朗普称霍尔木兹海峡19日将全面开放 美伊即将启动技术谈判","content":"美国总统特朗普周一（6月15日）在埃维昂表示，作为全球原油运输关键通道的霍尔木兹海峡将于本周五（6月19日）“全面开放”。美伊框架协议预计将于本周在瑞士正式签署，美方称协议文本将很快公布，双方技术性谈判也将于本周晚些时候启动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260615-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%9C%AC%E5%91%A8%E4%BA%94%E5%B0%86%E5%85%A8%E9%9D%A2%E5%BC%80%E6%94%BE-%E7%BE%8E%E4%BC%8A%E5%8D%B3%E5%B0%86%E5%90%AF%E5%8A%A8%E6%8A%80%E6%9C%AF%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781558270000.webp","sourceId":"rfi"},{"id":1781556958000,"createdDate":"2026-06-15 20:55","name":"法国国际广播电台","title":"中国培训俄罗斯军队 欧盟考虑对北京采取更强硬立场","content":"欧盟外交与安全政策高级代表卡拉斯表示，欧盟已核实有关中国军方“训练俄罗斯军事人员在乌克兰作战”的报道，这一事件可能会加剧欧中双方的紧张关系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260615-%E4%B8%AD%E5%9B%BD%E5%9F%B9%E8%AE%AD%E4%BF%84%E7%BD%97%E6%96%AF%E5%86%9B%E9%98%9F-%E6%AC%A7%E7%9B%9F%E8%80%83%E8%99%91%E5%AF%B9%E5%8C%97%E4%BA%AC%E9%87%87%E5%8F%96%E6%9B%B4%E5%BC%BA%E7%A1%AC%E7%AB%8B%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781556958000.webp","sourceId":"rfi"},{"id":1781556684000,"createdDate":"2026-06-15 20:51","name":"法国国际广播电台","title":"万斯：协议确保长期免通行费 阻止伊朗拥核","content":"美国与伊朗即将于本周在瑞士签署结束冲突的重要协议，内容涵盖重新开放全球能源运输命脉霍尔木兹海峡、限制伊朗核计划，以及逐步解除部分经济制裁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260615-%E4%B8%87%E6%96%AF-%E5%8D%8F%E8%AE%AE%E7%A1%AE%E4%BF%9D%E9%95%BF%E6%9C%9F%E5%85%8D%E9%80%9A%E8%A1%8C%E8%B4%B9-%E9%98%BB%E6%AD%A2%E4%BC%8A%E6%9C%97%E6%8B%A5%E6%A0%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781556684000.webp","sourceId":"rfi"}]