[{"id":1781518461000,"createdDate":"2026-06-15 10:14","name":"法国国际广播电台","title":"瑞典大胜领军小组赛、突尼斯处劣势翻身难","content":"2026年世界杯小组赛继续进行，在F组的小组赛中，欧洲瑞典队大胜连续失误的非洲突尼斯队。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260615-%E7%91%9E%E5%85%B8%E5%A4%A7%E8%83%9C%E9%A2%86%E5%86%9B%E5%B0%8F%E7%BB%84%E8%B5%9B-%E5%A4%84%E5%8A%A3%E5%8A%BF%E7%AA%81%E5%B0%BC%E6%96%AF%E7%BF%BB%E8%BA%AB%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781518461000.webp","sourceId":"rfi"},{"id":1781513549000,"createdDate":"2026-06-15 08:52","name":"法国国际广播电台","title":"脱下军装的敏昂来以缅甸总统身份开启对中国的访问","content":"缅甸前军政府首脑敏昂莱周一（6月15日）抵达北京，开始为期五天的国事访问。这是他今年4月出任缅甸总统后首次访问中国，也是继5月底访问印度后的第二次出访。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260615-%E8%84%B1%E4%B8%8B%E5%86%9B%E8%A3%85%E7%9A%84%E6%95%8F%E6%98%82%E6%9D%A5%E4%BB%A5%E7%BC%85%E7%94%B8%E6%80%BB%E7%BB%9F%E8%BA%AB%E4%BB%BD%E5%BC%80%E5%90%AF%E5%AF%B9%E4%B8%AD%E5%9B%BD%E7%9A%84%E8%AE%BF%E9%97%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781513549000.webp","sourceId":"rfi"},{"id":1781512774000,"createdDate":"2026-06-15 08:39","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第25： 浪漫主义群星之一：浪漫派中萌生的现代之花 - 疯狂的克莱斯特","content":"在海德堡浪漫派吹响男童的神奇魔号的同时，占据德国文坛主位几十载的浪漫主义开始分孽出风格特异的花枝。它所展示出的样态，所使用的手法，所追求的效果，所表现的感受都有着强烈的现代气息。它丰富了浪漫主义文学，深化了浪漫主义的理念和思考，同时也把浪漫主义带入一个更复杂的评价体系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260615-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC25-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%80-%E6%B5%AA%E6%BC%AB%E6%B4%BE%E4%B8%AD%E8%90%8C%E7%94%9F%E7%9A%84%E7%8E%B0%E4%BB%A3%E4%B9%8B%E8%8A%B1-%E7%96%AF%E7%8B%82%E7%9A%84%E5%85%8B%E8%8E%B1%E6%96%AF%E7%89%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781512774000.webp","sourceId":"rfi"},{"id":1781511061000,"createdDate":"2026-06-15 08:11","name":"法国国际广播电台","title":"台湾水果外交进军欧盟市场 首批四吨台湾芒果已抵达法国","content":"台湾驻法代表郝培芝表示，台湾水果要进到欧盟市场，真的要历经很多努力。这项外交与农业的重大突破背后有两大关键。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260615-%E5%8F%B0%E6%B9%BE%E6%B0%B4%E6%9E%9C%E5%A4%96%E4%BA%A4%E8%BF%9B%E5%86%9B%E6%AC%A7%E7%9B%9F%E5%B8%82%E5%9C%BA-%E9%A6%96%E6%89%B9%E5%9B%9B%E5%90%A8%E5%8F%B0%E6%B9%BE%E8%8A%92%E6%9E%9C%E5%B7%B2%E6%8A%B5%E8%BE%BE%E6%B3%95%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781511061000.webp","sourceId":"rfi"},{"id":1781510473000,"createdDate":"2026-06-15 08:01","name":"法国国际广播电台","title":"日本外务大臣发表谈话 欢迎美伊同意签署停战备忘录","content":"6月15日，美国和伊朗双方宣布，已就有关结束战斗等事项的谅解备忘录达成一致，为此，日本外务大臣茂木敏充15日当天发表关于伊朗局势的外务大臣谈话，代表日本政府对此表示欢迎。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260615-%E6%97%A5%E6%9C%AC%E5%A4%96%E5%8A%A1%E5%A4%A7%E8%87%A3%E5%8F%91%E8%A1%A8%E8%B0%88%E8%AF%9D-%E6%AC%A2%E8%BF%8E%E7%BE%8E%E4%BC%8A%E5%90%8C%E6%84%8F%E7%AD%BE%E7%BD%B2%E5%81%9C%E6%88%98%E5%A4%87%E5%BF%98%E5%BD%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781510473000.webp","sourceId":"rfi"},{"id":1781509889000,"createdDate":"2026-06-15 07:51","name":"法国国际广播电台","title":"京官夏宝龙访港前夕 香港特首李家超回应连任时称「时机到便会知道」","content":"香港特首李家超任期尚有一年便结束，他近日接受多家亲北京媒体专访时多被问及连任与否等问题，他的最新答案是「时机到便会知道」。有关专访适逢主管港澳事务的港澳办主任夏宝龙将於本周访港，以视察北部都会区(北都)发展和香港对接国家「十五五」规划的工作，引发外界联想，更关注李家超会否趁机大力推销其政绩和表明有意连任的心迹，为自己争取「再坐一会」的机会。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260615-%E4%BA%AC%E5%AE%98%E5%A4%8F%E5%AE%9D%E9%BE%99%E8%AE%BF%E6%B8%AF%E5%89%8D%E5%A4%95-%E9%A6%99%E6%B8%AF%E7%89%B9%E9%A6%96%E6%9D%8E%E5%AE%B6%E8%B6%85%E5%9B%9E%E5%BA%94%E8%BF%9E%E4%BB%BB%E6%97%B6%E7%A7%B0-%E6%97%B6%E6%9C%BA%E5%88%B0%E4%BE%BF%E4%BC%9A%E7%9F%A5%E9%81%93","thumbnail":"","detailImage":"news/detail/rfi/2026/06/15/1781509889000.webp","sourceId":"rfi"}]