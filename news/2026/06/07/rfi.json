[{"id":1780795619000,"createdDate":"2026-06-07 01:26","name":"法国国际广播电台","title":"中国未发出任何警告悄然发射长征十二号乙火箭：蓄意违反国际安全标准 令航天界担忧","content":"各位听众，中国在未发布通常的监管警告的情况下，悄然发射了长征十二号乙运载火箭。此乃蓄意违反国际安全标准，中国再次挑战了国际航天安全标准。这一技术壮举背后隐藏着一项深思熟虑的战略：一个航天强国意图按照自己的方式征服太空。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E4%B8%AD%E5%9B%BD%E6%9C%AA%E5%8F%91%E5%87%BA%E4%BB%BB%E4%BD%95%E8%AD%A6%E5%91%8A%E6%82%84%E7%84%B6%E5%8F%91%E5%B0%84%E9%95%BF%E5%BE%81%E5%8D%81%E4%BA%8C%E5%8F%B7%E4%B9%99%E7%81%AB%E7%AE%AD-%E8%93%84%E6%84%8F%E8%BF%9D%E5%8F%8D%E5%9B%BD%E9%99%85%E5%AE%89%E5%85%A8%E6%A0%87%E5%87%86-%E4%BB%A4%E8%88%AA%E5%A4%A9%E7%95%8C%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780795619000.webp","sourceId":"rfi"},{"id":1780821149000,"createdDate":"2026-06-07 08:32","name":"法国国际广播电台","title":"习近平到访前夕，金正恩胞妹强调朝鲜核计划“绝不容谈判”","content":"法新社首尔消息，在中国国家主席习近平即将访问平壤前夕，朝鲜领导人金正恩的胞妹、具权势的金与正通过朝鲜官媒周日发表谈话称，朝鲜的核武计划“绝对不容许谈判”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%88%B0%E8%AE%BF%E5%89%8D%E5%A4%95%EF%BC%8C%E9%87%91%E6%AD%A3%E6%81%A9%E8%83%9E%E5%A6%B9%E5%BC%BA%E8%B0%83%E6%9C%9D%E9%B2%9C%E6%A0%B8%E8%AE%A1%E5%88%92-%E7%BB%9D%E4%B8%8D%E5%AE%B9%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780821149000.webp","sourceId":"rfi"},{"id":1780820262000,"createdDate":"2026-06-07 08:17","name":"法国国际广播电台","title":"中国高考登场 考生1290万","content":"据中国教育部称，约1290万中国青年于周日开始参加“高考”，即那场令人望而生畏的全国大学入学考试。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E4%B8%AD%E5%9B%BD%E9%AB%98%E8%80%83%E7%99%BB%E5%9C%BA-%E8%80%83%E7%94%9F1290%E4%B8%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780820262000.webp","sourceId":"rfi"},{"id":1780819823000,"createdDate":"2026-06-07 08:10","name":"法国国际广播电台","title":"对抗日本与菲律宾拟划定海洋边界 中国在台湾以东海域实施特别执法","content":"日本与菲律宾5月28日决定启动正式谈判，以划定海洋边界。对此，中国方面加大了反对力度，在中国海警局开展巡航之后，中国交通运输部也于6日宣布对台湾以东海域实施特别执法行动。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260607-%E5%AF%B9%E6%8A%97%E6%97%A5%E6%9C%AC%E4%B8%8E%E8%8F%B2%E5%BE%8B%E5%AE%BE%E6%8B%9F%E5%88%92%E5%AE%9A%E6%B5%B7%E6%B4%8B%E8%BE%B9%E7%95%8C-%E4%B8%AD%E5%9B%BD%E5%9C%A8%E5%8F%B0%E6%B9%BE%E4%BB%A5%E4%B8%9C%E6%B5%B7%E5%9F%9F%E5%AE%9E%E6%96%BD%E7%89%B9%E5%88%AB%E6%89%A7%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780819823000.webp","sourceId":"rfi"},{"id":1780851351000,"createdDate":"2026-06-07 16:55","name":"法国国际广播电台","title":"秘鲁总统大选第二轮 前总统之女藤森对阵左翼候选人桑切斯","content":"周日，秘鲁总统选举第二轮投票，右翼保守派候选人藤森惠子和左翼候选人罗伯托·桑切斯竞争异常激烈。此次选举的背景是民众对政治的失望以及对犯罪问题的愤慨。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260607-%E7%A7%98%E9%B2%81%E6%80%BB%E7%BB%9F%E5%A4%A7%E9%80%89%E7%AC%AC%E4%BA%8C%E8%BD%AE-%E5%89%8D%E6%80%BB%E7%BB%9F%E4%B9%8B%E5%A5%B3%E8%97%A4%E6%A3%AE%E5%AF%B9%E9%98%B5%E5%B7%A6%E7%BF%BC%E5%80%99%E9%80%89%E4%BA%BA%E6%A1%91%E5%88%87%E6%96%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780851351000.webp","sourceId":"rfi"},{"id":1780845489000,"createdDate":"2026-06-07 15:18","name":"法国国际广播电台","title":"马德里化身大教堂 教皇良十四主持巨型弥撒 超百万信徒参加","content":"法新社6月7日马德里消息，据主办方宣布，周日上午，超过120万人聚集在马德里市中心，参加了教皇良十四世在西班牙访问第二天主持的弥撒。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260607-%E9%A9%AC%E5%BE%B7%E9%87%8C%E5%8C%96%E8%BA%AB%E5%A4%A7%E6%95%99%E5%A0%82-%E6%95%99%E7%9A%87%E8%89%AF%E5%8D%81%E5%9B%9B%E4%B8%BB%E6%8C%81%E5%B7%A8%E5%9E%8B%E5%BC%A5%E6%92%92-%E8%B6%85%E7%99%BE%E4%B8%87%E4%BF%A1%E5%BE%92%E5%8F%82%E5%8A%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780845489000.webp","sourceId":"rfi"},{"id":1780843320000,"createdDate":"2026-06-07 14:42","name":"法国国际广播电台","title":"中国在美元投资基础上打造了自己的科技黄金时代","content":"周末版法国《世界报》在头版凸出的不同主题凸显出当前动荡不安的国际关系。头版头条内容是联手发动对伊朗的军事行动三个多月后，美国总统特朗普与以色列总理内塔尼亚胡关系中的裂痕越来越大。该报周末版的地缘政治专栏主题是印度与巴基斯坦在边境划界纠纷之外围绕水资源的争夺。在特别分析乌克兰总统泽连斯基近日写给俄罗斯总统普京的信函的战略意义的同时，该报以新闻图片形式，凸出法国制造业开始将中心向军工业务转移。关于中国，该报在观点争鸣版有两篇关于中美在科技领域的竞争的分析文章。一篇文章强调中国高科技黄金时代的基础是美国投资，另一篇文章则侧重分析中美两国在研发领域投资多寡与政策支持，认为中国研发资金超过美国既不意味着美国科学产出的衰落，也不意味着中国技术力压美国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260607-%E4%B8%AD%E5%9B%BD%E5%9C%A8%E7%BE%8E%E5%85%83%E6%8A%95%E8%B5%84%E5%9F%BA%E7%A1%80%E4%B8%8A%E6%89%93%E9%80%A0%E4%BA%86%E8%87%AA%E5%B7%B1%E7%9A%84%E7%A7%91%E6%8A%80%E9%BB%84%E9%87%91%E6%97%B6%E4%BB%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780843320000.webp","sourceId":"rfi"},{"id":1780839038000,"createdDate":"2026-06-07 13:30","name":"法国国际广播电台","title":"2026世界杯:伊朗国家足球队抵达墨西哥 伊足协主席等15人被美国拒签","content":"伊朗国家队周日抵达墨西哥，在该国北部城市蒂华纳建立大本营，备战这届因与美国交战而变得复杂的世界杯。伊朗队首战所在的美国仍拒绝向部分教练和官员发放签证。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260607-2026%E4%B8%96%E7%95%8C%E6%9D%AF-%E4%BC%8A%E6%9C%97%E5%9B%BD%E5%AE%B6%E8%B6%B3%E7%90%83%E9%98%9F%E6%8A%B5%E8%BE%BE%E5%A2%A8%E8%A5%BF%E5%93%A5-%E4%BC%8A%E8%B6%B3%E5%8D%8F%E4%B8%BB%E5%B8%AD%E7%AD%8915%E4%BA%BA%E8%A2%AB%E7%BE%8E%E5%9B%BD%E6%8B%92%E7%AD%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780839038000.webp","sourceId":"rfi"},{"id":1780835412000,"createdDate":"2026-06-07 12:30","name":"法国国际广播电台","title":"中东战争进入第100天 美军再击落伊朗无人机 称其威胁海峡交通","content":"美国军方宣布击落两架伊朗攻击型无人机，称这些无人机威胁霍尔木兹海峡的海上交通。与此同时，中东战争周日进入第100天，似乎未见结束迹象。美国财政部考虑用伊朗要求解冻的资产，反过来补偿海湾国家因伊朗空袭造成的损失。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260607-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E8%BF%9B%E5%85%A5%E7%AC%AC100%E5%A4%A9-%E7%BE%8E%E5%86%9B%E5%86%8D%E5%87%BB%E8%90%BD%E4%BC%8A%E6%9C%97%E6%97%A0%E4%BA%BA%E6%9C%BA-%E7%A7%B0%E5%85%B6%E5%A8%81%E8%83%81%E6%B5%B7%E5%B3%A1%E4%BA%A4%E9%80%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780835412000.webp","sourceId":"rfi"},{"id":1780830880000,"createdDate":"2026-06-07 11:14","name":"法国国际广播电台","title":"中国在东沙群岛争议海域的特别“执法行动”意欲一箭三雕？","content":"据法新社今天周日（6月7日）援引中国官媒新华社报道，中国昨天周六在台湾以东海域组织了一次“执法行动”，以回应日本与菲律宾近期就其海上边界进行的讨论。台北方面随即宣布向该地区派遣了海巡船。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260607-%E4%B8%AD%E5%9B%BD%E5%9C%A8%E4%B8%9C%E6%B2%99%E7%BE%A4%E5%B2%9B%E4%BA%89%E8%AE%AE%E6%B5%B7%E5%9F%9F%E7%9A%84%E7%89%B9%E5%88%AB-%E6%89%A7%E6%B3%95%E8%A1%8C%E5%8A%A8-%E6%84%8F%E6%AC%B2%E4%B8%80%E7%AE%AD%E4%B8%89%E9%9B%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780830880000.webp","sourceId":"rfi"},{"id":1780872207000,"createdDate":"2026-06-07 22:43","name":"法国国际广播电台","title":"停火以来伊朗首次袭击以色列","content":"伊朗周日向以色列发射了多枚导弹，撕碎了在中东战争爆发第100天时本已岌岌可危的停火协议。美国总统特朗普表示，准备致电以色列总理内塔尼亚胡，要求他不要对伊朗导弹袭击实施报复。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E5%81%9C%E7%81%AB%E4%BB%A5%E6%9D%A5%E4%BC%8A%E6%9C%97%E9%A6%96%E6%AC%A1%E8%A2%AD%E5%87%BB%E4%BB%A5%E8%89%B2%E5%88%97","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780872207000.webp","sourceId":"rfi"},{"id":1780870087000,"createdDate":"2026-06-07 22:08","name":"法国国际广播电台","title":"下马威？习近平到访平壤 核计划免谈","content":"朝鲜一方面准备周一以极其盛大的仪式欢迎习近平，习近平罕见到访，在金正恩眼中，本身就是一个象征意义非常重大的胜利；可是另一方面，在习近平抵达前几个小时，他的胞妹，极有权势的金与正则宣布：朝鲜核计划，绝对不允许谈判。像似一箭双雕，一支明的，射向美国总统特朗普，一支暗的，指向朝鲜人民的老朋友习近平。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E4%B8%8B%E9%A9%AC%E5%A8%81-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%88%B0%E8%AE%BF%E5%B9%B3%E5%A3%A4-%E6%A0%B8%E8%AE%A1%E5%88%92%E5%85%8D%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780870087000.webp","sourceId":"rfi"},{"id":1780868448000,"createdDate":"2026-06-07 21:40","name":"法国国际广播电台","title":"伊朗战争推高燃油成本 全球航空业大幅下调2026年盈利预期","content":"国际航空运输协会（IATA）周日（6月7日）大幅下调全球航空业2026年盈利预期，原因是伊朗战争导致燃油价格飙升、中东重要航线受阻以及运营成本显著增加，对本已利润微薄的航空业造成沉重压力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%8E%A8%E9%AB%98%E7%87%83%E6%B2%B9%E6%88%90%E6%9C%AC-%E5%85%A8%E7%90%83%E8%88%AA%E7%A9%BA%E4%B8%9A%E5%A4%A7%E5%B9%85%E4%B8%8B%E8%B0%832026%E5%B9%B4%E7%9B%88%E5%88%A9%E9%A2%84%E6%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780868448000.webp","sourceId":"rfi"},{"id":1780868155000,"createdDate":"2026-06-07 21:35","name":"法国国际广播电台","title":"欧盟最大党团领导人呼吁对华采取更强硬贸易立场","content":"欧洲议会最大党团欧洲人民党（EPP）主席曼弗雷德·韦伯呼吁欧盟对中国采取更强硬的贸易政策，他并警告称，中国强大的工业生产能力正对欧洲部分产业构成挑战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E6%AC%A7%E7%9B%9F%E6%9C%80%E5%A4%A7%E5%85%9A%E5%9B%A2%E9%A2%86%E5%AF%BC%E4%BA%BA%E5%91%BC%E5%90%81%E5%AF%B9%E5%8D%8E%E9%87%87%E5%8F%96%E6%9B%B4%E5%BC%BA%E7%A1%AC%E8%B4%B8%E6%98%93%E7%AB%8B%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780868155000.webp","sourceId":"rfi"},{"id":1780867885000,"createdDate":"2026-06-07 21:31","name":"法国国际广播电台","title":"科索沃提前议会选举：总理库尔蒂阵营保持领先 或失绝对多数优势","content":"科索沃周日（6月7日）举行提前议会选举。据官方初步计票结果和出口民调，现任总理阿尔宾·库尔蒂领导的自决运动继续保持第一大党地位，但支持率较去年12月选举明显下滑，可能失去单独组阁所需的绝对多数席位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E7%A7%91%E7%B4%A2%E6%B2%83%E6%8F%90%E5%89%8D%E8%AE%AE%E4%BC%9A%E9%80%89%E4%B8%BE-%E6%80%BB%E7%90%86%E5%BA%93%E5%B0%94%E8%92%82%E9%98%B5%E8%90%A5%E4%BF%9D%E6%8C%81%E9%A2%86%E5%85%88-%E6%88%96%E5%A4%B1%E7%BB%9D%E5%AF%B9%E5%A4%9A%E6%95%B0%E4%BC%98%E5%8A%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780867885000.webp","sourceId":"rfi"},{"id":1780867561000,"createdDate":"2026-06-07 21:26","name":"法国国际广播电台","title":"特朗普拒绝提前解冻伊朗资产 呼吁以色列对真主党实施“精准打击”","content":"美国总统特朗普周日（6月7日）表示，在与伊朗达成最终协议之前，美国不会解冻被冻结的伊朗海外资产，他并同时警告，如果外交谈判失败，美国将对伊朗采取“非常严厉”的军事行动。特朗普并呼吁以色列对黎巴嫩真主党采取更加“精准”和“外科手术式”的军事行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8B%92%E7%BB%9D%E6%8F%90%E5%89%8D%E8%A7%A3%E5%86%BB%E4%BC%8A%E6%9C%97%E8%B5%84%E4%BA%A7-%E5%91%BC%E5%90%81%E4%BB%A5%E8%89%B2%E5%88%97%E5%AF%B9%E7%9C%9F%E4%B8%BB%E5%85%9A%E5%AE%9E%E6%96%BD-%E7%B2%BE%E5%87%86%E6%89%93%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780867561000.webp","sourceId":"rfi"},{"id":1780867256000,"createdDate":"2026-06-07 21:20","name":"法国国际广播电台","title":"法英德支持泽连斯基提出的乌俄“直接对话”倡议","content":"法国、德国和英国领导人周日（6月7日）晚在伦敦与乌克兰总统泽连斯基举行会晤后表示，支持泽连斯基提出的乌克兰与俄罗斯开展“直接对话”的建议，并强调应有“美国和欧洲的积极参与”。与此同时，俄罗斯对乌克兰的新一轮袭击造成至少5人死亡，并波及切尔诺贝利核电站禁区内一处核设施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E6%B3%95%E8%8B%B1%E5%BE%B7%E6%94%AF%E6%8C%81%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E6%8F%90%E5%87%BA%E7%9A%84%E4%B9%8C%E4%BF%84-%E7%9B%B4%E6%8E%A5%E5%AF%B9%E8%AF%9D-%E5%80%A1%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780867256000.webp","sourceId":"rfi"},{"id":1780865708000,"createdDate":"2026-06-07 20:55","name":"法国国际广播电台","title":"美国将以色列间谍威胁提升至最高级","content":"美国多家媒体报道，在美国总统特朗普与以色列总理内塔尼亚胡关系紧张的大背景下，美国国防部决定把针对以色列的反间谍威胁提升至最高级别。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E7%BE%8E%E5%9B%BD%E5%B0%86%E4%BB%A5%E8%89%B2%E5%88%97%E9%97%B4%E8%B0%8D%E5%A8%81%E8%83%81%E6%8F%90%E5%8D%87%E8%87%B3%E6%9C%80%E9%AB%98%E7%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780865708000.webp","sourceId":"rfi"},{"id":1780865410000,"createdDate":"2026-06-07 20:50","name":"法国国际广播电台","title":"彭博：GE执行长看好中国航空市场 特朗普访华后将带来新商机","content":"美国GEAerospace（通用电气航空航太）执行长卡尔普（LarryCulp）表示，随着中国计划采购200架波音（客机，公司有信心进一步取得更多来自中国市场的航空发动机订单。他指出，中方提出购买波音飞机，是重新开启中国市场销售的重要第一步，也将为GEAerospace带来庞大的发动机供应与后续维修服务商机。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E5%BD%AD%E5%8D%9A-ge%E6%89%A7%E8%A1%8C%E9%95%BF%E7%9C%8B%E5%A5%BD%E4%B8%AD%E5%9B%BD%E8%88%AA%E7%A9%BA%E5%B8%82%E5%9C%BA-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BF%E5%8D%8E%E5%90%8E%E5%B0%86%E5%B8%A6%E6%9D%A5%E6%96%B0%E5%95%86%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780865410000.webp","sourceId":"rfi"},{"id":1780855981000,"createdDate":"2026-06-07 18:13","name":"法国国际广播电台","title":"亚美尼亚议会选举：对转向西方的一次民意测试","content":"亚美尼亚选民周日开始投票，此次议会选举被视为对总理尼科尔·帕希尼扬所倡导的地缘政治转向的民意测试。帕希尼扬转向西方令俄罗斯非常不满。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260607-%E4%BA%9A%E7%BE%8E%E5%B0%BC%E4%BA%9A%E8%AE%AE%E4%BC%9A%E9%80%89%E4%B8%BE-%E5%AF%B9%E8%BD%AC%E5%90%91%E8%A5%BF%E6%96%B9%E7%9A%84%E4%B8%80%E6%AC%A1%E6%B0%91%E6%84%8F%E6%B5%8B%E8%AF%95","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780855981000.webp","sourceId":"rfi"}]