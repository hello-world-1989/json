[{"id":1780795619000,"createdDate":"2026-06-07 01:26","name":"法国国际广播电台","title":"中国未发出任何警告悄然发射长征十二号乙火箭：蓄意违反国际安全标准 令航天界担忧","content":"各位听众，中国在未发布通常的监管警告的情况下，悄然发射了长征十二号乙运载火箭。此乃蓄意违反国际安全标准，中国再次挑战了国际航天安全标准。这一技术壮举背后隐藏着一项深思熟虑的战略：一个航天强国意图按照自己的方式征服太空。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E4%B8%AD%E5%9B%BD%E6%9C%AA%E5%8F%91%E5%87%BA%E4%BB%BB%E4%BD%95%E8%AD%A6%E5%91%8A%E6%82%84%E7%84%B6%E5%8F%91%E5%B0%84%E9%95%BF%E5%BE%81%E5%8D%81%E4%BA%8C%E5%8F%B7%E4%B9%99%E7%81%AB%E7%AE%AD-%E8%93%84%E6%84%8F%E8%BF%9D%E5%8F%8D%E5%9B%BD%E9%99%85%E5%AE%89%E5%85%A8%E6%A0%87%E5%87%86-%E4%BB%A4%E8%88%AA%E5%A4%A9%E7%95%8C%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780795619000.webp","sourceId":"rfi"},{"id":1780821149000,"createdDate":"2026-06-07 08:32","name":"法国国际广播电台","title":"习近平到访前夕，金正恩胞妹强调朝鲜核计划“绝不容谈判”","content":"法新社首尔消息，在中国国家主席习近平即将访问平壤前夕，朝鲜领导人金正恩的胞妹、具权势的金与正通过朝鲜官媒周日发表谈话称，朝鲜的核武计划“绝对不容许谈判”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%88%B0%E8%AE%BF%E5%89%8D%E5%A4%95%EF%BC%8C%E9%87%91%E6%AD%A3%E6%81%A9%E8%83%9E%E5%A6%B9%E5%BC%BA%E8%B0%83%E6%9C%9D%E9%B2%9C%E6%A0%B8%E8%AE%A1%E5%88%92-%E7%BB%9D%E4%B8%8D%E5%AE%B9%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780821149000.webp","sourceId":"rfi"},{"id":1780820262000,"createdDate":"2026-06-07 08:17","name":"法国国际广播电台","title":"中国高考登场 考生1290万","content":"据中国教育部称，约1290万中国青年于周日开始参加“高考”，即那场令人望而生畏的全国大学入学考试。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260607-%E4%B8%AD%E5%9B%BD%E9%AB%98%E8%80%83%E7%99%BB%E5%9C%BA-%E8%80%83%E7%94%9F1290%E4%B8%87","thumbnail":"","detailImage":"news/detail/rfi/2026/06/07/1780820262000.webp","sourceId":"rfi"},{"id":1780819823000,"createdDate":"2026-06-07 08:10","name":"法国国际广播电台","title":"对抗日本与菲律宾拟划定海洋边界 中国在台湾以东海域实施特别执法","content":"日本与菲律宾5月28日决定启动正式谈判，以划定海洋边界。对此，中国方面加大了反对力度，在中国海警局开展巡航之后，中国交通运输部也于6日宣布对台湾以东海域实施特别执法行动。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260607-%E