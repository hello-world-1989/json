[{"id":1775549958000,"createdDate":"2026-04-07 08:19","name":"法国国际广播电台","title":"拉夫罗夫将于14日访华？俄外交部发言人：会与中方同时宣布","content":"俄罗斯外交部发言人扎哈罗娃向塔斯社证实，俄外长拉夫罗夫访华的筹备工作正在进行中。俄中双方将同时宣布此次访问。此前，中国外长王毅周日应约同拉夫罗夫通电话，就当前中东形势交换了意见。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260407-%E6%8B%89%E5%A4%AB%E7%BD%97%E5%A4%AB%E5%B0%86%E4%BA%8E14%E6%97%A5%E8%AE%BF%E5%8D%8E-%E4%BF%84%E5%A4%96%E4%BA%A4%E9%83%A8%E5%8F%91%E8%A8%80%E4%BA%BA-%E4%BC%9A%E4%B8%8E%E4%B8%AD%E6%96%B9%E5%90%8C%E6%97%B6%E5%AE%A3%E5%B8%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775549958000.webp","sourceId":"rfi"},{"id":1775549922000,"createdDate":"2026-04-07 08:18","name":"法国国际广播电台","title":"越共总书记苏林当选国家主席：打破集体领导传统 效法习近平“定权力为一尊”","content":"路透社河内消息，越南新一届国会周二（4月7日）一致选出越共中央总书记苏林为该国未来五年的国家主席，这使他成为几十年来越南最有权势的领导人，也打破了一党制越南长久以来「四架马车」的传统，即越共总书记、国家主席、总理、国会主席的分权共治的传统。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260407-%E8%B6%8A%E5%85%B1%E6%80%BB%E4%B9%A6%E8%AE%B0%E8%8B%8F%E6%9E%97%E5%BD%93%E9%80%89%E5%9B%BD%E5%AE%B6%E4%B8%BB%E5%B8%AD-%E6%89%93%E7%A0%B4%E9%9B%86%E4%BD%93%E9%A2%86%E5%AF%BC%E4%BC%A0%E7%BB%9F-%E6%95%88%E6%B3%95%E4%B9%A0%E8%BF%91%E5%B9%B3-%E5%AE%9A%E6%9D%83%E5%8A%9B%E4%B8%BA%E4%B8%80%E5%B0%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775549922000.webp","sourceId":"rfi"},{"id":1775548476000,"createdDate":"2026-04-07 07:54","name":"法国国际广播电台","title":"港年底办首办国际刑警大会 人权律师忧中港借机洗白 又订利跨境镇压异见行动","content":"国际刑警组织（Interpol）将在11月首度於香港举行周年大会，香港警方表明，欲借机说好中国故事和香港警队故事。但自2019年反修例运动以来，港警以过度武力对付示威者和利用《港区国安法》等打压异见，屡遭包括联合国人权高专办和国际特赦组织等的批评。有人权律师组织担忧，让严重侵犯人权的中国承办并在香港举办大会，等于是用国际刑警组织的名义，为镇压异见的政权背书。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260407-%E6%B8%AF%E5%B9%B4%E5%BA%95%E5%8A%9E%E9%A6%96%E5%8A%9E%E5%9B%BD%E9%99%85%E5%88%91%E8%AD%A6%E5%A4%A7%E4%BC%9A-%E4%BA%BA%E6%9D%83%E5%BE%8B%E5%B8%88%E5%BF%A7%E4%B8%AD%E6%B8%AF%E5%80%9F%E6%9C%BA%E6%B4%97%E7%99%BD-%E5%8F%88%E8%AE%A2%E5%88%A9%E8%B7%A8%E5%A2%83%E9%95%87%E5%8E%8B%E5%BC%82%E8%A7%81%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775548476000.webp","sourceId":"rfi"},{"id":1775547979000,"createdDate":"2026-04-07 07:46","name":"法国国际广播电台","title":"国民党主席郑丽文访中  行政院长：政党代表人与中共接触须受强度监督","content":"国民党主席郑丽文于7日启程访中，抵达上海后由国台办主任宋涛亲自接机，预计与习近平会面将落在10日。台湾行政院长表示，身为政党代表人或具实质政治影响力人士，用公开方式与中共接触，必须受到高强度监督，尤其是民众与媒体的监督。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260407-%E5%9B%BD%E6%B0%91%E5%85%9A%E4%B8%BB%E5%B8%AD%E9%83%91%E4%B8%BD%E6%96%87%E8%AE%BF%E4%B8%AD-%E8%A1%8C%E6%94%BF%E9%99%A2%E9%95%BF-%E6%94%BF%E5%85%9A%E4%BB%A3%E8%A1%A8%E4%BA%BA%E4%B8%8E%E4%B8%AD%E5%85%B1%E6%8E%A5%E8%A7%A6%E9%A1%BB%E5%8F%97%E5%BC%BA%E5%BA%A6%E7%9B%91%E7%9D%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775547979000.webp","sourceId":"rfi"},{"id":1775532265000,"createdDate":"2026-04-07 03:24","name":"法国国际广播电台","title":"巧克力配奶酪还是牡蛎：复活节的主角美食正经历一场变革？","content":"各位听众：复活节的主角美食现今正在经历一场变革？拿巧克力配奶酪呢，还是配牡蛎？在某些饮食文化中，巧克力很容易融入咸味菜肴中。而在法国，复活节前夕，虽然一些巧克力制造商或高级餐厅正在推陈出新，但甜咸搭配仍然比较谨慎。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260407-%E5%B7%A7%E5%85%8B%E5%8A%9B%E9%85%8D%E5%A5%B6%E9%85%AA%E8%BF%98%E6%98%AF%E7%89%A1%E8%9B%8E-%E5%A4%8D%E6%B4%BB%E8%8A%82%E7%9A%84%E4%B8%BB%E8%A7%92%E7%BE%8E%E9%A3%9F%E6%AD%A3%E7%BB%8F%E5%8E%86%E4%B8%80%E5%9C%BA%E5%8F%98%E9%9D%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775532265000.webp","sourceId":"rfi"}]