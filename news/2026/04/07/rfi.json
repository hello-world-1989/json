[{"id":1775549958000,"createdDate":"2026-04-07 08:19","name":"法国国际广播电台","title":"拉夫罗夫将于14日访华？俄外交部发言人：会与中方同时宣布","content":"俄罗斯外交部发言人扎哈罗娃向塔斯社证实，俄外长拉夫罗夫访华的筹备工作正在进行中。俄中双方将同时宣布此次访问。此前，中国外长王毅周日应约同拉夫罗夫通电话，就当前中东形势交换了意见。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260407-%E6%8B%89%E5%A4%AB%E7%BD%97%E5%A4%AB%E5%B0%86%E4%BA%8E14%E6%97%A5%E8%AE%BF%E5%8D%8E-%E4%BF%84%E5%A4%96%E4%BA%A4%E9%83%A8%E5%8F%91%E8%A8%80%E4%BA%BA-%E4%BC%9A%E4%B8%8E%E4%B8%AD%E6%96%B9%E5%90%8C%E6%97%B6%E5%AE%A3%E5%B8%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775549958000.webp","sourceId":"rfi"},{"id":1775549922000,"createdDate":"2026-04-07 08:18","name":"法国国际广播电台","title":"越共总书记苏林当选国家主席：打破集体领导传统 效法习近平“定权力为一尊”","content":"路透社河内消息，越南新一届国会周二（4月7日）一致选出越共中央总书记苏林为该国未来五年的国家主席，这使他成为几十年来越南最有权势的领导人，也打破了一党制越南长久以来「四架马车」的传统，即越共总书记、国家主席、总理、国会主席的分权共治的传统。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260407-%E8%B6%8A%E5%85%B1%E6%80%BB%E4%B9%A6%E8%AE%B0%E8%8B%8F%E6%9E%97%E5%BD%93%E9%80%89%E5%9B%BD%E5%AE%B6%E4%B8%BB%E5%B8%AD-%E6%89%93%E7%A0%B4%E9%9B%86%E4%BD%93%E9%A2%86%E5%AF%BC%E4%BC%A0%E7%BB%9F-%E6%95%88%E6%B3%95%E4%B9%A0%E8%BF%91%E5%B9%B3-%E5%AE%9A%E6%9D%83%E5%8A%9B%E4%B8%BA%E4%B8%80%E5%B0%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775549922000.webp","sourceId":"rfi"},{"id":1775548476000,"createdDate":"2026-04-07 07:54","name":"法国国际广播电台","title":"港年底办首办国际刑警大会 人权律师忧中港借机洗白 又订利跨境镇压异见行动","content":"国际刑警组织（Interpol）将在11月首度於香港举行周年大会，香港警方表明，欲借机说好中国故事和香港警队故事。但自2019年反修例运动以来，港警以过度武力对付示威者和利用《港区国安法》等打压异见，屡遭包括联合国人权高专办和国际特赦组织等的批评。有人权律师组织担忧，让严重侵犯人权的中国承办并在香港举办大会，等于是用国际刑警组织的名义，为镇压异见的政权背书。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260407-%E6%B8%AF%E5%B9%B4%E5%BA%95%E5%8A%9E%E9%A6%96%E5%8A%9E%E5%9B%BD%E9%99%85%E5%88%91%E8%AD%A6%E5%A4%A7%E4%BC%9A-%E4%BA%BA%E6%9D%83%E5%BE%8B%E5%B8%88%E5%BF%A7%E4%B8%AD%E6%B8%AF%E5%80%9F%E6%9C%BA%E6%B4%97%E7%99%BD-%E5%8F%88%E8%AE%A2%E5%88%A9%E8%B7%A8%E5%A2%83%E9%95%87%E5%8E%8B%E5%BC%82%E8%A7%81%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775548476000.webp","sourceId":"rfi"},{"id":1775547979000,"createdDate":"2026-04-07 07:46","name":"法国国际广播电台","title":"国民党主席郑丽文访中  行政院长：政党代表人与中共接触须受强度监督","content":"国民党主席郑丽文于7日启程访中，抵达上海后由国台办主任宋涛亲自接机，预计与习近平会面将落在10日。台湾行政院长表示，身为政党代表人或具实质政治影响力人士，用公开方式与中共接触，必须受到高强度监督，尤其是民众与媒体的监督。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260407-%E5%9B%BD%E6%B0%91%E5%85%9A%E4%B8%BB%E5%B8%AD%E9%83%91%E4%B8%BD%E6%96%87%E8%AE%BF%E4%B8%AD-%E8%A1%8C%E6%94%BF%E9%99%A2%E9%95%BF-%E6%94%BF%E5%85%9A%E4%BB%A3%E8%A1%A8%E4%BA%BA%E4%B8%8E%E4%B8%AD%E5%85%B1%E6%8E%A5%E8%A7%A6%E9%A1%BB%E5%8F%97%E5%BC%BA%E5%BA%A6%E7%9B%91%E7%9D%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775547979000.webp","sourceId":"rfi"},{"id":1775532265000,"createdDate":"2026-04-07 03:24","name":"法国国际广播电台","title":"巧克力配奶酪还是牡蛎：复活节的主角美食正经历一场变革？","content":"各位听众：复活节的主角美食现今正在经历一场变革？拿巧克力配奶酪呢，还是配牡蛎？在某些饮食文化中，巧克力很容易融入咸味菜肴中。而在法国，复活节前夕，虽然一些巧克力制造商或高级餐厅正在推陈出新，但甜咸搭配仍然比较谨慎。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260407-%E5%B7%A7%E5%85%8B%E5%8A%9B%E9%85%8D%E5%A5%B6%E9%85%AA%E8%BF%98%E6%98%AF%E7%89%A1%E8%9B%8E-%E5%A4%8D%E6%B4%BB%E8%8A%82%E7%9A%84%E4%B8%BB%E8%A7%92%E7%BE%8E%E9%A3%9F%E6%AD%A3%E7%BB%8F%E5%8E%86%E4%B8%80%E5%9C%BA%E5%8F%98%E9%9D%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775532265000.webp","sourceId":"rfi"},{"id":1775575566000,"createdDate":"2026-04-07 15:26","name":"法国国际广播电台","title":"伊朗据报切断与美直接沟通 消息人士：通过巴基斯坦促成对话的努力仍继续","content":"据《华尔街日报》周二报导，中东官员们称，伊朗周一上午切断了与美国的直接沟通，以回应特朗普总统威胁要摧毁伊朗的“整个文明”。不过，与停火调解人的谈判仍在继续。官员们表示，此举暂时使在特朗普设定的美东时间周二晚8点最后期限前达成协议的努力变得复杂，但并未导致谈判破裂。其中一位官员称，伊朗切断直接沟通意在发出不满和挑衅的信号。目前尚不清楚直接谈判是否会在最后期限前恢复。白宫尚未对此置评。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260407-%E4%BC%8A%E6%9C%97%E6%8D%AE%E6%8A%A5%E5%88%87%E6%96%AD%E4%B8%8E%E7%BE%8E%E7%9B%B4%E6%8E%A5%E6%B2%9F%E9%80%9A-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB-%E9%80%9A%E8%BF%87%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E4%BF%83%E6%88%90%E5%AF%B9%E8%AF%9D%E7%9A%84%E5%8A%AA%E5%8A%9B%E4%BB%8D%E7%BB%A7%E7%BB%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775575566000.webp","sourceId":"rfi"},{"id":1775574345000,"createdDate":"2026-04-07 15:05","name":"法国国际广播电台","title":"欧尔班与普京去年10月通话内容被曝光 甘扮“老鼠”帮助俄罗斯“狮子”","content":"匈牙利总理欧尔班在去年10月一次与俄罗斯总统普京的通话中表示，他愿意竭尽全力协助普京，包括在布达佩斯举办峰会，以帮助解决乌克兰战争。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260407-%E6%AC%A7%E5%B0%94%E7%8F%AD%E4%B8%8E%E6%99%AE%E4%BA%AC%E5%8E%BB%E5%B9%B410%E6%9C%88%E9%80%9A%E8%AF%9D%E5%86%85%E5%AE%B9%E8%A2%AB%E6%9B%9D%E5%85%89-%E7%94%98%E6%89%AE-%E8%80%81%E9%BC%A0-%E5%B8%AE%E5%8A%A9%E4%BF%84%E7%BD%97%E6%96%AF-%E7%8B%AE%E5%AD%90","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775574345000.webp","sourceId":"rfi"},{"id":1775573699000,"createdDate":"2026-04-07 14:54","name":"法国国际广播电台","title":"乌克兰 : 俄罗斯向伊朗提供网络和间谍卫星图像支持","content":"乌克兰情报部门的评估报告指出俄罗斯向伊朗提供了网络和间谍卫星拍摄的图像支持，以加强其攻击能力。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260407-%E4%B9%8C%E5%85%8B%E5%85%B0-%E4%BF%84%E7%BD%97%E6%96%AF%E5%90%91%E4%BC%8A%E6%9C%97%E6%8F%90%E4%BE%9B%E7%BD%91%E7%BB%9C%E5%92%8C%E9%97%B4%E8%B0%8D%E5%8D%AB%E6%98%9F%E5%9B%BE%E5%83%8F%E6%94%AF%E6%8C%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775573699000.webp","sourceId":"rfi"},{"id":1775570468000,"createdDate":"2026-04-07 14:01","name":"法国国际广播电台","title":"中国再度调控国内汽柴油价格 美制裁下伊朗如何加大对华出口引关注","content":"随着中东紧张局势持续推高国际油价，中国在两周前对成品油价格采取临时调控措施后，周二再次调控油价。中国国家发展改革委当天发布消息指，“3月23日国内成品油价格调整以来，国际市场原油价格大幅震荡。为减缓国际油价上涨对国内的冲击，国家继续对成品油价格采取调控措施。按照成品油价格机制计算，自4月7日24时起，国内汽、柴油（标准品）价格每吨应分别上调800元、770元，调控后实际上调420元、400元”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260407-%E4%B8%AD%E5%9B%BD%E5%86%8D%E5%BA%A6%E8%B0%83%E6%8E%A7%E5%9B%BD%E5%86%85%E6%B1%BD%E6%9F%B4%E6%B2%B9%E4%BB%B7%E6%A0%BC-%E7%BE%8E%E5%88%B6%E8%A3%81%E4%B8%8B%E4%BC%8A%E6%9C%97%E5%A6%82%E4%BD%95%E5%8A%A0%E5%A4%A7%E5%AF%B9%E5%8D%8E%E5%87%BA%E5%8F%A3%E5%BC%95%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775570468000.webp","sourceId":"rfi"},{"id":1775569357000,"createdDate":"2026-04-07 13:42","name":"法国国际广播电台","title":"台湾学者寇健文：郑丽文北京行像是一次政治豪赌","content":"台湾中国国民党主席郑丽文4月7日启程赴大陆访问。首站上海。国台办主任宋涛7日亲自前往接机。从目前的消息来看，她应该有可能在本周五也就是4月10日，在北京与中国国家主席习近平会谈。这是国民党在职党主席时隔十年再次访问大陆。而此时，台海两岸紧张关系自2016年蔡英文领导民进党上台执政以后，就一直不断升级。此次郑丽文出访行程又恰好赶在美国总统特朗普预计今年5月中旬将访问北京之前。而几个月来，台湾行政院提出的包括大笔对美军购预算在内的国防特别预算案，一直因为在野党国民党和民众党的掣肘，而无法获得通过。在这种多重紧张关系交织背景下，如何看国民党在职主席的大陆之行？郑丽文此行的意义是否真能与二十年前时任国民党主席连战在北京与时任中共总书记兼国家主席胡锦涛的会面相比较？台湾国立政治大学国际关系研究所的寇健文教授接受本台电话采访时认为，鉴于郑丽文当前在国民党内部权力架构中的弱势地位，她的此次北京行程对于她本人来说，不亚于一次政治豪赌，对两岸关系产生实质影响的可能性不大。而对于北京来说，这次会晤更可能是一个平台，不仅向台湾朝野传递和统信息，而且也面向国际社会，展示中国更爱和平的形象。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260407-%E5%8F%B0%E6%B9%BE%E5%AD%A6%E8%80%85%E5%AF%87%E5%81%A5%E6%96%87-%E9%83%91%E4%B8%BD%E6%96%87%E5%8C%97%E4%BA%AC%E8%A1%8C%E5%83%8F%E6%98%AF%E4%B8%80%E6%AC%A1%E6%94%BF%E6%B2%BB%E8%B1%AA%E8%B5%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775569357000.webp","sourceId":"rfi"},{"id":1775568440000,"createdDate":"2026-04-07 13:27","name":"法国国际广播电台","title":"赖清德：在对等、尊严原则下，台湾愿与大陆进行交流合作","content":"周二，台湾总统赖清德强调说：只要对等、尊严，台湾愿意和中国进行交流合作，促进两岸和平繁荣的发展。赖清德的这一表态，是在出席“郑南榕殉道37周年追思纪念会”致词时表达的。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260407-%E8%B5%96%E6%B8%85%E5%BE%B7-%E5%9C%A8%E5%AF%B9%E7%AD%89-%E5%B0%8A%E4%B8%A5%E5%8E%9F%E5%88%99%E4%B8%8B%EF%BC%8C%E5%8F%B0%E6%B9%BE%E6%84%BF%E4%B8%8E%E5%A4%A7%E9%99%86%E8%BF%9B%E8%A1%8C%E4%BA%A4%E6%B5%81%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775568440000.webp","sourceId":"rfi"},{"id":1775565943000,"createdDate":"2026-04-07 12:45","name":"法国国际广播电台","title":"特朗普：一整个文明或在今夜消亡 美军袭击哈尔克岛军事目标","content":"美国总统特朗普（DonaldTrump）周二在其社媒平台“真相社交”上发文称，“一个整个文明将在今夜消亡，永不复生。我不希望这种事发生，但恐怕终将成真。不过，既然我们已经完成了彻底的政权更迭，让那些不同、更睿智且不那么极端的人占据上风，说不定会发生某种革命性的美妙之事，谁知道呢？今晚，我们便会知晓答案——这将是世界漫长而复杂的历史中最重要的时刻之一。长达47年的敲诈、腐败与死亡，终将结束。愿上帝保佑伟大的伊朗人民！”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260407-%E7%89%B9%E6%9C%97%E6%99%AE-%E4%B8%80%E6%95%B4%E4%B8%AA%E6%96%87%E6%98%8E%E6%88%96%E5%9C%A8%E4%BB%8A%E5%A4%9C%E6%B6%88%E4%BA%A1-%E7%BE%8E%E5%86%9B%E8%A2%AD%E5%87%BB%E5%93%88%E5%B0%94%E5%85%8B%E5%B2%9B%E5%86%9B%E4%BA%8B%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775565943000.webp","sourceId":"rfi"},{"id":1775561936000,"createdDate":"2026-04-07 11:38","name":"法国国际广播电台","title":"加拿大与伊斯玛仪伊玛目的特殊伙伴关系","content":"三月底，什叶派伊斯玛仪派穆斯林领袖阿迦汗五世（HisHighnesstheAgaKhanV）首次正式访问加拿大，为表明对这一重新建立的伙伴关系的重视，卡尼宣布任命原加拿大司法部长、现任加拿大常驻联合国代表戴维·拉梅蒂（DavidLametti）为加拿大驻伊斯玛仪派伊玛目的新代表，以推进双方的伙伴关系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%8C%97%E7%BE%8E%E6%9D%A5%E9%B8%BF/20260407-%E5%8A%A0%E6%8B%BF%E5%A4%A7%E4%B8%8E%E4%BC%8A%E6%96%AF%E7%8E%9B%E4%BB%AA%E4%BC%8A%E7%8E%9B%E7%9B%AE%E7%9A%84%E7%89%B9%E6%AE%8A%E4%BC%99%E4%BC%B4%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775561936000.webp","sourceId":"rfi"},{"id":1775561547000,"createdDate":"2026-04-07 11:32","name":"法国国际广播电台","title":"伊朗最高领袖死活或有下落 总统称愿为伊朗而牺牲","content":"伊朗总统佩泽希齐扬（MasoudPezeshkian）周二在社媒平台X上贴文称，“迄今为止，已有超过1400万勇敢的伊朗人宣布他们准备为保卫伊朗而牺牲生命。我过去、现在和将来也都甘愿为伊朗而牺牲”。此前，美国总统特朗普周一在白宫举行的新闻发布会上表示，对伊朗的战事是否即将升级或接近结束，取决于伊朗当局对他设定的“最后期限”，即美东时间7日20时的回应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260407-%E4%BC%8A%E6%9C%97%E6%9C%80%E9%AB%98%E9%A2%86%E8%A2%96%E6%AD%BB%E6%B4%BB%E6%88%96%E6%9C%89%E4%B8%8B%E8%90%BD-%E6%80%BB%E7%BB%9F%E7%A7%B0%E6%84%BF%E4%B8%BA%E4%BC%8A%E6%9C%97%E8%80%8C%E7%89%BA%E7%89%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775561547000.webp","sourceId":"rfi"},{"id":1775560163000,"createdDate":"2026-04-07 11:09","name":"法国国际广播电台","title":"郑丽文需习近平之力巩固领导地位 习近平借郑丽文之口为特朗普设局","content":"台湾主要反对党国民党党魁郑丽文周二抵达中国上海，展开为期六天的罕见访问，据法新社报道，出发前，郑丽文表示，台湾“必须竭尽全力防止战争爆发”。“维护和平就是维护台湾。”郑丽文在台北的国民党总部举行的新闻发布会上说，“双方必须逐步增进善意，扩大互信。”与此同时，台湾政府警告称，北京将寻求阻止美国向台湾出售武器。据台湾《自由时报》报道，台湾3月最新民调显示，有56%的受访者认为郑丽文会晤习近平弊大于利，且多数选民倾向支持增加国防开支。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260407-%E9%83%91%E4%B8%BD%E6%96%87%E9%9C%80%E4%B9%A0%E8%BF%91%E5%B9%B3%E4%B9%8B%E5%8A%9B%E5%B7%A9%E5%9B%BA%E9%A2%86%E5%AF%BC%E5%9C%B0%E4%BD%8D-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%80%9F%E9%83%91%E4%B8%BD%E6%96%87%E4%B9%8B%E5%8F%A3%E4%B8%BA%E7%89%B9%E6%9C%97%E6%99%AE%E8%AE%BE%E5%B1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775560163000.webp","sourceId":"rfi"},{"id":1775559892000,"createdDate":"2026-04-07 11:04","name":"法国国际广播电台","title":"法国媒体如何看待“郑丽文访中”？","content":"各位听众，今日出刊的多家法国报纸头条继续聚焦伊朗战争。《费加罗报》头条指出，中东的冲突正在加深美国与欧洲的隔阂，让彼此之间的关系越发疏远。《解放报》头版发表社论批评特朗普“鲁莽”的行事态度，并称这位美国总统正在加剧紧张局势，然而，最糟糕的时刻尚未到来。中国方面的消息：《费加罗报》发表两篇文章，一篇聚焦国民党主席郑丽文率团访中，一篇聚焦美国和法国在东亚地缘政治上的博弈。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260407-%E6%B3%95%E5%9B%BD%E5%AA%92%E4%BD%93%E5%A6%82%E4%BD%95%E7%9C%8B%E5%BE%85-%E9%83%91%E4%B8%BD%E6%96%87%E8%AE%BF%E4%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775559892000.webp","sourceId":"rfi"},{"id":1775557219000,"createdDate":"2026-04-07 10:20","name":"法国国际广播电台","title":"特朗普谈夺取伊朗石油背后有增加对华贸易筹码考量？","content":"据彭博社援引知情人士报导称，随着美国总统特朗普沉思控制伊朗石油行业，他的想法中也隐隐透露出一个潜在的好处：扩大美方在全球能源领域的主导地位，从而获得对华贸易谈判的筹码。特朗普周一多次谈及这一前景，将其描述为对美国来说非常有用的东西，尽管他也承认进一步卷入中东局势会带来政治风险。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260407-%E7%89%B9%E6%9C%97%E6%99%AE%E8%B0%88%E5%A4%BA%E5%8F%96%E4%BC%8A%E6%9C%97%E7%9F%B3%E6%B2%B9%E8%83%8C%E5%90%8E%E6%9C%89%E5%A2%9E%E5%8A%A0%E5%AF%B9%E5%8D%8E%E8%B4%B8%E6%98%93%E7%AD%B9%E7%A0%81%E8%80%83%E9%87%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775557219000.webp","sourceId":"rfi"},{"id":1775554246000,"createdDate":"2026-04-07 09:30","name":"法国国际广播电台","title":"美AI三巨头罕见合作联手 打击中国竞争对手对抗性蒸馏行为","content":"美国人工智能巨头OpenAI、Anthropic和字母表公司旗下的谷歌这三家竞争对手已开始联手，试图打击中国竞争对手从美国尖端人工智能模型中提取结果，以在全球人工智能竞赛中占据优势的行为。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260407-%E7%BE%8Eai%E4%B8%89%E5%B7%A8%E5%A4%B4%E7%BD%95%E8%A7%81%E5%90%88%E4%BD%9C%E8%81%94%E6%89%8B%E6%89%93%E5%87%BB%E4%B8%AD%E5%9B%BD%E7%AB%9E%E4%BA%89%E5%AF%B9%E6%8A%97%E6%80%A7%E8%92%B8%E9%A6%8F%E8%A1%8C%E4%B8%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775554246000.webp","sourceId":"rfi"},{"id":1775552473000,"createdDate":"2026-04-07 09:01","name":"法国国际广播电台","title":"日本伊朗外长举行会谈 伊朗关押的日本人获保释","content":"日本外务大臣茂木敏充在日本时间6日晚与伊朗外长阿拉格齐进行了电话会谈。据称，在会谈中，阿拉格齐外长就当前局势及伊朗立场作出了说明。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260407-%E6%97%A5%E6%9C%AC%E4%BC%8A%E6%9C%97%E5%A4%96%E9%95%BF%E4%B8%BE%E8%A1%8C%E4%BC%9A%E8%B0%88-%E4%BC%8A%E6%9C%97%E5%85%B3%E6%8A%BC%E7%9A%84%E6%97%A5%E6%9C%AC%E4%BA%BA%E8%8E%B7%E4%BF%9D%E9%87%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775552473000.webp","sourceId":"rfi"},{"id":1775604282000,"createdDate":"2026-04-07 23:24","name":"法国国际广播电台","title":"伊朗战争和霍尔木兹海峡：最后通牒到期前特朗普声明有条件接受停战两周","content":"美国总统特朗普7日晚在原定20点最后通牒到期以前在自家社交媒体上表示：如果伊朗同意就开放霍尔木兹问题展开谈判的话，他接受停止空袭伊朗两周。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260407-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E5%92%8C%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E6%9C%80%E5%90%8E%E9%80%9A%E7%89%92%E5%88%B0%E6%9C%9F%E5%89%8D%E7%89%B9%E6%9C%97%E6%99%AE%E5%A3%B0%E6%98%8E%E6%9C%89%E6%9D%A1%E4%BB%B6%E6%8E%A5%E5%8F%97%E5%81%9C%E6%88%98%E4%B8%A4%E5%91%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775604282000.webp","sourceId":"rfi"},{"id":1775600198000,"createdDate":"2026-04-07 22:16","name":"法国国际广播电台","title":"中俄投否决票，重启霍尔木兹海峡决议案在安理会未获通过","content":"联合国安理会就重启霍尔木兹海峡决议投票，中国和俄罗斯纷纷投了否决票，决议未通过。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260407-%E4%B8%AD%E4%BF%84%E6%8A%95%E5%90%A6%E5%86%B3%E7%A5%A8%EF%BC%8C%E9%87%8D%E5%90%AF%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%86%B3%E8%AE%AE%E6%A1%88%E5%9C%A8%E5%AE%89%E7%90%86%E4%BC%9A%E6%9C%AA%E8%8E%B7%E9%80%9A%E8%BF%87","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775600198000.webp","sourceId":"rfi"},{"id":1775599838000,"createdDate":"2026-04-07 22:10","name":"法国国际广播电台","title":"中国接待郑丽文来访，以强化台湾问题可以政治解决的说法","content":"法国世界报周二刊发文章，关注台湾在野党国民党领袖郑丽文前往中国大陆访问。该报强调，中国十年来首次接待国民党主席郑丽文来访，为的是强化台湾问题可以政治解决的说法，为的是说服特朗普：台海战争是可以避免的，从而遏制美国的对台军售。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260407-%E4%B8%AD%E5%9B%BD%E6%8E%A5%E5%BE%85%E9%83%91%E4%B8%BD%E6%96%87%E6%9D%A5%E8%AE%BF%EF%BC%8C%E4%B8%BA%E7%9A%84%E6%98%AF%E5%BC%BA%E5%8C%96%E5%8F%B0%E6%B9%BE%E9%97%AE%E9%A2%98%E5%8F%AF%E4%BB%A5%E6%94%BF%E6%B2%BB%E8%A7%A3%E5%86%B3%E7%9A%84%E8%AF%B4%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775599838000.webp","sourceId":"rfi"},{"id":1775594951000,"createdDate":"2026-04-07 20:49","name":"法国国际广播电台","title":"美以7日空袭哈格岛 伊朗媒体说重要基础设施未受损","content":"美国媒体稍早披露美国和以色列对伊朗石油枢纽哈格岛（KhargIsland）展开新一轮攻击后，伊朗“梅尔通讯社”（Mehr）报导，岛上“重要基础设施未受损”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260407-%E7%BE%8E%E4%BB%A57%E6%97%A5%E7%A9%BA%E8%A2%AD%E5%93%88%E6%A0%BC%E5%B2%9B-%E4%BC%8A%E6%9C%97%E5%AA%92%E4%BD%93%E8%AF%B4%E9%87%8D%E8%A6%81%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD%E6%9C%AA%E5%8F%97%E6%8D%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775594951000.webp","sourceId":"rfi"},{"id":1775594778000,"createdDate":"2026-04-07 20:46","name":"法国国际广播电台","title":"伊朗常驻联合国代表批特朗普言论“令人震惊”","content":"伊朗常驻联合国代表周二谴责特朗普威胁要摧毁伊朗“整个文明”的言论“极其不负责任”，并指责这位美国总统意图犯下“战争罪行”。教皇认为对全体伊朗人民的威胁是“不可接受的”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260407-%E4%BC%8A%E6%9C%97%E5%B8%B8%E9%A9%BB%E8%81%94%E5%90%88%E5%9B%BD%E4%BB%A3%E8%A1%A8%E6%89%B9%E7%89%B9%E6%9C%97%E6%99%AE%E8%A8%80%E8%AE%BA-%E4%BB%A4%E4%BA%BA%E9%9C%87%E6%83%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775594778000.webp","sourceId":"rfi"},{"id":1775594572000,"createdDate":"2026-04-07 20:42","name":"法国国际广播电台","title":"伊朗：马克龙将于周三召开新的国防委员会","content":"法国总统马克龙将于周三召开国防和安全委员会会议，讨论“伊朗和中东局势”。爱丽舍宫周二晚间宣布了这一消息。此次新的国防委员会会议将于上午8:30举行，届时将有部长和负责安全事务的官员参加。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260407-%E4%BC%8A%E6%9C%97-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%B0%86%E4%BA%8E%E5%91%A8%E4%B8%89%E5%8F%AC%E5%BC%80%E6%96%B0%E7%9A%84%E5%9B%BD%E9%98%B2%E5%A7%94%E5%91%98%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775594572000.webp","sourceId":"rfi"},{"id":1775594420000,"createdDate":"2026-04-07 20:40","name":"法国国际广播电台","title":"伊朗人链保护发电厂","content":"据伊朗国家媒体发布的图片显示，在美国总统特朗普威胁要打击能源基础设施后，伊朗民众周二组成人链保护发电厂。在由以色列和美国联合袭击伊朗引发的中东战争的第39天，伊朗高级官员也表示，他们已做好牺牲的准备。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260407-%E4%BC%8A%E6%9C%97%E4%BA%BA%E9%93%BE%E4%BF%9D%E6%8A%A4%E5%8F%91%E7%94%B5%E5%8E%82","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775594420000.webp","sourceId":"rfi"},{"id":1775594147000,"createdDate":"2026-04-07 20:35","name":"法国国际广播电台","title":"伊朗两座桥梁和一处火车站遭到袭击","content":"伊朗的两座桥梁和一处火车站也在周二遭到袭击。一名美国官员周二表示，美军在夜间对伊朗哈尔克岛（KhargIsland）的数十个军事目标实施了打击。白宫发言人卡罗琳·莱维特周二表示：“只有总统才知道他的立场以及他将要采取的行动。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260407-%E4%BC%8A%E6%9C%97%E4%B8%A4%E5%BA%A7%E6%A1%A5%E6%A2%81%E5%92%8C%E4%B8%80%E5%A4%84%E7%81%AB%E8%BD%A6%E7%AB%99%E9%81%AD%E5%88%B0%E8%A2%AD%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775594147000.webp","sourceId":"rfi"},{"id":1775593975000,"createdDate":"2026-04-07 20:32","name":"法国国际广播电台","title":"以军误炸德黑兰一座犹太教堂","content":"以色列军方对袭击“高级军事指挥官”后损毁德黑兰一座犹太教堂表示“遗憾”。以军称此次空袭的目标是“一名伊朗高级军事指挥官”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260407-%E4%BB%A5%E5%86%9B%E8%AF%AF%E7%82%B8%E5%BE%B7%E9%BB%91%E5%85%B0%E4%B8%80%E5%BA%A7%E7%8A%B9%E5%A4%AA%E6%95%99%E5%A0%82","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775593975000.webp","sourceId":"rfi"},{"id":1775593793000,"createdDate":"2026-04-07 20:29","name":"法国国际广播电台","title":"爱泼斯坦案：比尔·盖茨将接受质询","content":"据法新社周二从一位知情人士处获悉，比尔·盖茨（BillGates）将于6月10日出席美国国会一个调查爱泼斯坦案的委员会的听证会。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260407-%E7%88%B1%E6%B3%BC%E6%96%AF%E5%9D%A6%E6%A1%88-%E6%AF%94%E5%B0%94%C2%B7%E7%9B%96%E8%8C%A8%E5%B0%86%E6%8E%A5%E5%8F%97%E8%B4%A8%E8%AF%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775593793000.webp","sourceId":"rfi"},{"id":1775593558000,"createdDate":"2026-04-07 20:25","name":"法国国际广播电台","title":"政治献金案：萨科齐辩解说“未经他许可...”","content":"法国前总统萨科齐4月7日在非法竞选融资案庭审上没有那么张狂。他在庭上说，“事实是，他从未承诺或采取任何行动来帮助希望赦免的塞努西先生。”1989年，阿卜杜拉·塞努西（AbdallahSenoussi）因共谋策划袭击一架DC-10客机在法被判处终身监禁。这起空难造成170人死亡，其中包括54名法国公民。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260407-%E6%94%BF%E6%B2%BB%E7%8C%AE%E9%87%91%E6%A1%88-%E8%90%A8%E7%A7%91%E9%BD%90%E8%BE%A9%E8%A7%A3%E8%AF%B4-%E6%9C%AA%E7%BB%8F%E4%BB%96%E8%AE%B8%E5%8F%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775593558000.webp","sourceId":"rfi"},{"id":1775593406000,"createdDate":"2026-04-07 20:23","name":"法国国际广播电台","title":"特朗普将最后通牒推迟两周","content":"美国总统特朗普表示，他已同意暂停对伊朗的轰炸与攻击，为期两周。特朗普在其“真理社交网络”上宣布，他“已收到伊朗提出的十点方案”，并认为该方案“可用于启动谈判”。此前巴基斯坦提议延长最后期限。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260407-%E5%B7%B4%E6%80%BB%E7%90%86%E8%AE%A9%E7%89%B9%E6%9C%97%E6%99%AE%E7%BB%99%E4%BC%8A%E6%9C%97%E7%9A%84%E6%9C%80%E5%90%8E%E6%9C%9F%E9%99%90%E5%BB%B6%E9%95%BF%E4%B8%A4%E5%91%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775593406000.webp","sourceId":"rfi"},{"id":1775592155000,"createdDate":"2026-04-07 20:02","name":"法国国际广播电台","title":"万斯暗示对伊朗用核武？白宫急澄清","content":"在美国总统特朗普（DonaldTrump）对伊朗设定最后期限、威胁发动重大军事打击之际，白宫7日紧急出面澄清，否认美方考虑动用核武器，试图平息外界因副总统万斯（JDVance）言论与特朗普强硬警告，所引发的广泛揣测与不安。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260407-%E4%B8%87%E6%96%AF%E6%9A%97%E7%A4%BA%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%94%A8%E6%A0%B8%E6%AD%A6-%E7%99%BD%E5%AE%AB%E6%80%A5%E6%BE%84%E6%B8%85","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775592155000.webp","sourceId":"rfi"},{"id":1775589251000,"createdDate":"2026-04-07 19:14","name":"法国国际广播电台","title":"匈牙利国会大选前美国副总统万斯到场为欧尔班拉抬选情","content":"在12日匈牙利国会大选前夕，美国副总统万斯（J.D.Vance）4月7日抵达匈牙利，展开为期两天访问，为面临艰困选情的民粹保守派总理欧尔班拉抬选情。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260407-%E5%8C%88%E7%89%99%E5%88%A9%E5%9B%BD%E4%BC%9A%E5%A4%A7%E9%80%89%E5%89%8D%E7%BE%8E%E5%9B%BD%E5%89%AF%E6%80%BB%E7%BB%9F%E4%B8%87%E6%96%AF%E5%88%B0%E5%9C%BA%E4%B8%BA%E6%AC%A7%E5%B0%94%E7%8F%AD%E6%8B%89%E6%8A%AC%E9%80%89%E6%83%85","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775589251000.webp","sourceId":"rfi"},{"id":1775583573000,"createdDate":"2026-04-07 17:39","name":"法国国际广播电台","title":"法国外长：“他们终于自由了！”","content":"被伊朗当局以间谍罪拘押的两名前人质塞西尔·科勒（CécileKohler）和雅克·帕里斯（JacquesParis）即将返回法国。马克龙4月7日宣布：“塞西尔·科勒和雅克·帕里斯在伊朗被拘留三年半后，已获得自由，正在返回法国的途中。”","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260407-%E6%B3%95%E5%9B%BD%E5%A4%96%E9%95%BF-%E4%BB%96%E4%BB%AC%E7%BB%88%E4%BA%8E%E8%87%AA%E7%94%B1%E4%BA%86","thumbnail":"","detailImage":"news/detail/rfi/2026/04/07/1775583573000.webp","sourceId":"rfi"}]