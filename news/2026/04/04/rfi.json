[{"id":1775289517000,"createdDate":"2026-04-04 07:58","name":"法国国际广播电台","title":"日本积极斡旋建立中东“安全海上通道”","content":"为推动开放霍尔木兹海峡，40多个国家的外长通过线上方式召开了会议。日本外务大臣茂木敏充呼吁各国协助建立“安全海上通道”，而建立“安全海上通道”离不开伊朗、美国及以色列的合作，日本为此正在展开积极的外交努力。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260404-%E6%97%A5%E6%9C%AC%E7%A7%AF%E6%9E%81%E6%96%A1%E6%97%8B%E5%BB%BA%E7%AB%8B%E4%B8%AD%E4%B8%9C-%E5%AE%89%E5%85%A8%E6%B5%B7%E4%B8%8A%E9%80%9A%E9%81%93","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775289517000.webp","sourceId":"rfi"},{"id":1775319181000,"createdDate":"2026-04-04 16:13","name":"法国国际广播电台","title":"能源冲击：中国早有准备，欧盟却没有","content":"据《柏林日报》报道：面对即将出现的全球石油和天然气短缺，中国与欧盟的反应可谓截然不同。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260404-%E8%83%BD%E6%BA%90%E5%86%B2%E5%87%BB-%E4%B8%AD%E5%9B%BD%E6%97%A9%E6%9C%89%E5%87%86%E5%A4%87%EF%BC%8C%E6%AC%A7%E7%9B%9F%E5%8D%B4%E6%B2%A1%E6%9C%89","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775319181000.webp","sourceId":"rfi"},{"id":1775316597000,"createdDate":"2026-04-04 15:29","name":"法国国际广播电台","title":"留美是生活？绿卡被撤销苏莱曼尼外甥女在美被捕 拉里贾尼之女身份被终止","content":"美国国务院周六宣布，在鲁比奥（MarcoRubio）国务卿撤销了已故伊朗伊斯兰革命卫队下属“圣城旅”指挥官苏莱曼尼（QasemSoleimani）的外甥女和外甥孙女的合法永久居民身份后，美国联邦特工已将她们逮捕。2020年1月3日，美军无人机在伊拉克巴格达国际机场附近发动袭击并将苏莱曼尼击杀。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260404-%E8%B5%B4%E7%BE%8E%E6%98%AF%E7%94%9F%E6%B4%BB-%E7%BB%BF%E5%8D%A1%E8%A2%AB%E6%92%A4%E9%94%80%E8%8B%8F%E8%8E%B1%E6%9B%BC%E5%B0%BC%E5%A4%96%E7%94%A5%E5%A5%B3%E5%9C%A8%E7%BE%8E%E8%A2%AB%E6%8D%95-%E6%8B%89%E9%87%8C%E8%B4%BE%E5%B0%BC%E4%B9%8B%E5%A5%B3%E8%BA%AB%E4%BB%BD%E8%A2%AB%E7%BB%88%E6%AD%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775316597000.webp","sourceId":"rfi"},{"id":1775313876000,"createdDate":"2026-04-04 14:44","name":"法国国际广播电台","title":"特朗普：留给伊朗的时间不多了，48小时后，地狱将降临到他们头上","content":"美国总统特朗普（DonaldTrump）周六在其社媒平台“真相社交”发文称，“还记得我曾给伊朗十天时间，要么达成协议，要么开放霍尔木兹海峡吗？时间不多了——48小时后，地狱将降临到他们头上。荣耀归于上帝！” 此前，特朗普26日发文称，“应伊朗政府请求”，他将对伊朗能源设施的“摧毁”行动推迟10天，期限延至美东时间4月6日20时。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260404-%E7%89%B9%E6%9C%97%E6%99%AE-%E7%95%99%E7%BB%99%E4%BC%8A%E6%9C%97%E7%9A%84%E6%97%B6%E9%97%B4%E4%B8%8D%E5%A4%9A%E4%BA%86%EF%BC%8C48%E5%B0%8F%E6%97%B6%E5%90%8E%EF%BC%8C%E5%9C%B0%E7%8B%B1%E4%B9%8B%E9%97%A8%E5%B0%86%E9%99%8D%E4%B8%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775313876000.webp","sourceId":"rfi"},{"id":1775310058000,"createdDate":"2026-04-04 13:40","name":"法国国际广播电台","title":"日本政府拟突破性放宽防卫装备品出口规则","content":"据共同社周五援引多名消息人士报导，日本政府正在研究的放宽防卫装备品出口规则方案的概要已浮出水面。该方案将废除仅限非战斗目的的“5类”装备品出口规定，原则上允许出口包括具有杀伤能力的武器在内的成品。针对向处于冲突中的国家出口，也将设置例外规定，留有余地。报导指，作为制约措施受到关注的日本国会参与，将仅需事后“通知”。高市政府计划下周在自民党安全保障调查会干部会议上提出该方案，并拟在本月内修改“防卫装备转移三原则”及其运用指南。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260404-%E6%97%A5%E6%9C%AC%E6%94%BF%E5%BA%9C%E6%8B%9F%E7%AA%81%E7%A0%B4%E6%80%A7%E6%94%BE%E5%AE%BD%E9%98%B2%E5%8D%AB%E8%A3%85%E5%A4%87%E5%93%81%E5%87%BA%E5%8F%A3%E8%A7%84%E5%88%99","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775310058000.webp","sourceId":"rfi"},{"id":1775307570000,"createdDate":"2026-04-04 12:59","name":"法国国际广播电台","title":"击落中制“翼龙”无人机 伊朗要求阿联酋和沙特作出解释","content":"伊朗外交部发言人巴加埃（EsmailBaghaei）周五要求两个拥有中国制造的“翼龙II”无人机的海湾国家就一架据称在与美国和以色列的战争中被击落无人机一事作出解释。众所周知，阿联酋和沙特都拥有这种侦察和精确打击无人机。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260404-%E5%87%BB%E8%90%BD%E4%B8%AD%E5%88%B6-%E7%BF%BC%E9%BE%99-%E6%97%A0%E4%BA%BA%E6%9C%BA-%E4%BC%8A%E6%9C%97%E8%A6%81%E6%B1%82%E9%98%BF%E8%81%94%E9%85%8B%E5%92%8C%E6%B2%99%E7%89%B9%E4%BD%9C%E5%87%BA%E8%A7%A3%E9%87%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775307570000.webp","sourceId":"rfi"},{"id":1775307170000,"createdDate":"2026-04-04 12:52","name":"法国国际广播电台","title":"法国一些靠微薄收入维生退休人士叹：“我们不追求奢华，只想过正常的生活！”","content":"各位听众，一些法国人退休后，只能靠微薄的收入维持生计，例如：罗伯特、杰拉德和让-皮埃尔等的三人，他们从青少年时期就开始工作，退休后每人每月收入减少了约500欧元。如今为了维持生计，他们不得不精打细算，每天都在为生存而挣扎。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260404-%E6%B3%95%E5%9B%BD%E4%B8%80%E4%BA%9B%E9%9D%A0%E5%BE%AE%E8%96%84%E6%94%B6%E5%85%A5%E7%BB%B4%E7%94%9F%E9%80%80%E4%BC%91%E4%BA%BA%E5%A3%AB%E5%8F%B9-%E6%88%91%E4%BB%AC%E4%B8%8D%E8%BF%BD%E6%B1%82%E5%A5%A2%E5%8D%8E%EF%BC%8C%E5%8F%AA%E6%83%B3%E8%BF%87%E6%AD%A3%E5%B8%B8%E7%9A%84%E7%94%9F%E6%B4%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775307170000.webp","sourceId":"rfi"},{"id":1775301353000,"createdDate":"2026-04-04 11:15","name":"法国国际广播电台","title":"两年半以来的首次 俄3月份几未取得任何领土进展","content":"根据法新社对战争研究所（ISW）数据的分析，俄罗斯军队3月份在乌克兰几乎没有取得任何领土进展，这是自2023年9月以来的首次，甚至在一些地区还退守到基辅军队手中。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260404-%E4%B8%A4%E5%B9%B4%E5%8D%8A%E4%BB%A5%E6%9D%A5%E7%9A%84%E9%A6%96%E6%AC%A1-%E4%BF%843%E6%9C%88%E4%BB%BD%E5%87%A0%E6%9C%AA%E5%8F%96%E5%BE%97%E4%BB%BB%E4%BD%95%E9%A2%86%E5%9C%9F%E8%BF%9B%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775301353000.webp","sourceId":"rfi"},{"id":1775298658000,"createdDate":"2026-04-04 10:30","name":"法国国际广播电台","title":"阿尔忒弥斯二号任务进行时，NASA开支面临大幅削减","content":"美国总统提出的2027财年预算草案显示，美国国家航空航天局的开支将面临大幅削减。白宫要求对美国国家航空航天局整体预算削减23%，其中科学部门的资金将减少约36亿美元，这意味着约40个项目可能被取消。这一决定正值“阿尔忒米斯二号”任务进行之际，引发关注，因为该任务是五十多年来首次有宇航员绕月飞行，此次任务的宇航员分别为三名美国人和一名加拿大人，他们是自1972年阿波罗17号以来首批飞向月球的宇航员。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260404-%E9%98%BF%E8%80%B3%E5%BF%92%E5%BC%A5%E6%96%AF%E4%BA%8C%E5%8F%B7%E4%BB%BB%E5%8A%A1%E8%BF%9B%E8%A1%8C%E6%97%B6%EF%BC%8Cnasa%E5%BC%80%E6%94%AF%E9%9D%A2%E4%B8%B4%E5%A4%A7%E5%B9%85%E5%89%8A%E5%87%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775298658000.webp","sourceId":"rfi"},{"id":1775298542000,"createdDate":"2026-04-04 10:29","name":"法国国际广播电台","title":"美海军造船经费申请在2027财年提案中增长近50%，为1962年来最高","content":"美国白宫周五公布了2027财年预算提案，寻求将国防开支飙升44%，至1.5万亿美元。根据预算文件，五角大楼提出的新造船资金申请金额位列朝鲜战争以来最高之列，堪比里根时代的600艘舰艇建造计划，以及上世纪60年代的核潜艇扩建计划。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260404-%E7%BE%8E%E6%B5%B7%E5%86%9B%E9%80%A0%E8%88%B9%E7%BB%8F%E8%B4%B9%E7%94%B3%E8%AF%B7%E5%9C%A82027%E8%B4%A2%E5%B9%B4%E6%8F%90%E6%A1%88%E4%B8%AD%E5%A2%9E%E9%95%BF%E8%BF%9150-%EF%BC%8C%E4%B8%BA1962%E5%B9%B4%E6%9D%A5%E6%9C%80%E9%AB%98","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775298542000.webp","sourceId":"rfi"},{"id":1775294400000,"createdDate":"2026-04-04 09:20","name":"法国国际广播电台","title":"高市拟月底访问澳大利亚 探讨稀土合作、“自由开放的印太”倡议","content":"据《日经亚洲》报导，日本首相高市早苗计划在本月晚些时候开始的，即将到来的假期期间访问澳大利亚，寻求讨论加强稀土元素供应链，以及在霍尔木兹海峡安全航行等方面的合作。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260404-%E9%AB%98%E5%B8%82%E6%8B%9F%E6%9C%88%E5%BA%95%E8%AE%BF%E9%97%AE%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A-%E6%8E%A2%E8%AE%A8%E7%A8%80%E5%9C%9F%E5%90%88%E4%BD%9C-%E8%87%AA%E7%94%B1%E5%BC%80%E6%94%BE%E7%9A%84%E5%8D%B0%E5%A4%AA-%E5%80%A1%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775294400000.webp","sourceId":"rfi"},{"id":1775294297000,"createdDate":"2026-04-04 09:18","name":"法国国际广播电台","title":"西方竞逐乌克兰无人机合作，乌拟在欧洲设立约十个军工出口中心","content":"俄乌战争正在深刻改变着当代军事技术的发展节奏。如今，美国、英国、瑞典、西班牙、法国等西方多国代表频繁前往基辅，推动合作协议签署和技术转移。尽管未来乌克兰可能成为这些国家在无人机领域的竞争对手，但在当前，各方更关注如何利用前线验证过的技术成果。此前在爱沙尼亚的一次演习中，仅十余名乌克兰无人机操作员在24小时内摧毁了两个北约营，这一事件已引发广泛关注。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260404-%E8%A5%BF%E6%96%B9%E7%AB%9E%E9%80%90%E4%B9%8C%E5%85%8B%E5%85%B0%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%90%88%E4%BD%9C%EF%BC%8C%E4%B9%8C%E6%8B%9F%E5%9C%A8%E6%AC%A7%E6%B4%B2%E8%AE%BE%E7%AB%8B%E7%BA%A6%E5%8D%81%E4%B8%AA%E5%86%9B%E5%B7%A5%E5%87%BA%E5%8F%A3%E4%B8%AD%E5%BF%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775294297000.webp","sourceId":"rfi"},{"id":1775338735000,"createdDate":"2026-04-04 21:38","name":"法国国际广播电台","title":"马达加斯加破阴谋刺杀过渡总统","content":"印度洋中的非洲岛国马达加斯加于2026年04月02日星期四对外宣布，对涉嫌参与刺杀过渡总统和发动政变阴谋的13人予以司法追究。这是该国当局自去年（2025年）11月以来，在过去半年里第二次破获企图暗杀过渡总统米夏埃尔·兰德里亚尼里纳（PrésidentMichaëlRandrianirina)的案件。","newsLink":"https://www.rfi.fr/cn/rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E9%A9%AC%E8%BE%BE%E5%8A%A0%E6%96%AF%E5%8A%A0%E7%A0%B4%E9%98%B4%E8%B0%8B%E5%88%BA%E6%9D%80%E8%BF%87%E6%B8%A1%E6%80%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775338735000.webp","sourceId":"rfi"},{"id":1775337387000,"createdDate":"2026-04-04 21:16","name":"法国国际广播电台","title":"美以4日空袭击中伊朗南部和西南部多处设施","content":"美国与以色列4月4日发动空袭攻势，击中伊朗南部和西南部多处设施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260404-%E7%BE%8E%E4%BB%A54%E6%97%A5%E7%A9%BA%E8%A2%AD%E5%87%BB%E4%B8%AD%E4%BC%8A%E6%9C%97%E5%8D%97%E9%83%A8%E5%92%8C%E8%A5%BF%E5%8D%97%E9%83%A8%E5%A4%9A%E5%A4%84%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775337387000.webp","sourceId":"rfi"},{"id":1775336312000,"createdDate":"2026-04-04 20:58","name":"法国国际广播电台","title":"美以空袭伊朗一处石化设施   5人死亡   170人受伤","content":"伊朗一名高级官员周六宣布，以色列和美国对伊朗西南部一处石化设施发动空袭，造成5人死亡，170人受伤。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260404-%E7%BE%8E%E4%BB%A5%E7%A9%BA%E8%A2%AD%E4%BC%8A%E6%9C%97%E4%B8%80%E5%A4%84%E7%9F%B3%E5%8C%96%E8%AE%BE%E6%96%BD-5%E4%BA%BA%E6%AD%BB%E4%BA%A1-170%E4%BA%BA%E5%8F%97%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775336312000.webp","sourceId":"rfi"},{"id":1775336158000,"createdDate":"2026-04-04 20:55","name":"法国国际广播电台","title":"约二十艘法国船只将起航前往加沙","content":"4月4日，约二十艘法国船只离开马赛港，加入一支新的国际船队，前往加沙地带“打破”以色列的封锁，前往加沙。船员们表示，马赛和你们同在！不要忘记加沙。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260404-%E7%BA%A6%E4%BA%8C%E5%8D%81%E8%89%98%E6%B3%95%E5%9B%BD%E8%88%B9%E5%8F%AA%E5%B0%86%E8%B5%B7%E8%88%AA%E5%89%8D%E5%BE%80%E5%8A%A0%E6%B2%99","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775336158000.webp","sourceId":"rfi"},{"id":1775335975000,"createdDate":"2026-04-04 20:52","name":"法国国际广播电台","title":"欧尔班将面临16年来最大执政挑战","content":"匈牙利4月12日举行议会选举，竞选活动已进入关键阶段。主要反对党尊重与自由党（Tisza，以下简称“蒂萨党”）挑战现任总理欧尔班。据25日公布的最新民调显示，反对派领袖马加尔（PeterMagyar）领导的反对党进一步扩大优势，支持度领先执政党超过20％。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260404-%E6%AC%A7%E5%B0%94%E7%8F%AD%E5%B0%86%E9%9D%A2%E4%B8%B416%E5%B9%B4%E6%9D%A5%E6%9C%80%E5%A4%A7%E6%89%A7%E6%94%BF%E6%8C%91%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775335975000.webp","sourceId":"rfi"},{"id":1775335692000,"createdDate":"2026-04-04 20:48","name":"法国国际广播电台","title":"泽连斯基到访土耳其","content":"乌克兰总统泽连斯基与土耳其总统埃尔多安的正式会晤在伊斯坦布尔多尔玛巴赫切宫举行。会晤以闭门形式展开，未向媒体开放。双方就能源和海上安全以及结束俄乌冲突的努力进行了讨论。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260404-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%88%B0%E8%AE%BF%E5%9C%9F%E8%80%B3%E5%85%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775335692000.webp","sourceId":"rfi"},{"id":1775335408000,"createdDate":"2026-04-04 20:43","name":"法国国际广播电台","title":"塞内加尔：政府暂停部长“非必要”出国旅行","content":"塞内加尔总理奥斯曼·松科决定暂停政府成员“非必要”的出国旅行，原因是该国债务高企以及中东战争的影响。松科先生周六在社交媒体上发布的一段视频中表示：“我已经采取了一系列严厉措施来限制所有政府开支”，其中包括“取消所有政府成员的非必要出国访问”。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260404-%E5%A1%9E%E5%86%85%E5%8A%A0%E5%B0%94-%E6%94%BF%E5%BA%9C%E6%9A%82%E5%81%9C%E9%83%A8%E9%95%BF-%E9%9D%9E%E5%BF%85%E8%A6%81-%E5%87%BA%E5%9B%BD%E6%97%85%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775335408000.webp","sourceId":"rfi"},{"id":1775335192000,"createdDate":"2026-04-04 20:39","name":"法国国际广播电台","title":"特拉维夫爆发反战游行    被警方驱散","content":"周六晚间，超过一千人在特拉维夫举行示威游行，抗议以色列对伊朗和黎巴嫩真主党发动的战争，呼吁当局结束战争，随后被警方驱散。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260404-%E7%89%B9%E6%8B%89%E7%BB%B4%E5%A4%AB%E7%88%86%E5%8F%91%E5%8F%8D%E6%88%98%E6%B8%B8%E8%A1%8C-%E8%A2%AB%E8%AD%A6%E6%96%B9%E9%A9%B1%E6%95%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775335192000.webp","sourceId":"rfi"},{"id":1775334689000,"createdDate":"2026-04-04 20:31","name":"法国国际广播电台","title":"盖洛普：20年来中国全球认可度首次超过美国","content":"近20年来，中国领导人在全球范围内的支持率首次超过美国领导人。这是盖洛普（Gallup）2025年对130多个国家进行的年度全球民意调查的结果。调查结果显示，中国共产党领导人的全球支持率达到36%；而美国政府的支持率为31%消息称。中国对美国的五个百分点的优势是盖洛普近二十年来记录到的中国支持率的最大优势。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260404-%E7%9B%96%E6%B4%9B%E6%99%AE-20%E5%B9%B4%E6%9D%A5%E4%B8%AD%E5%9B%BD%E5%85%A8%E7%90%83%E8%AE%A4%E5%8F%AF%E5%BA%A6%E9%A6%96%E6%AC%A1%E8%B6%85%E8%BF%87%E7%BE%8E%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775334689000.webp","sourceId":"rfi"},{"id":1775334478000,"createdDate":"2026-04-04 20:27","name":"法国国际广播电台","title":"特朗普：都是“欧洲人、法英的错儿”","content":"特朗普一再要求美国的欧洲盟友提供军事支持，但法英等欧洲国家都拒绝卷入这场战争。法国全天候电视台BFMTV4日刊文指出，特朗普承诺迅速结束与伊朗的冲突，如今却将部分责任推卸给欧洲盟友。这位美国总统指责法国和英国在霍尔木兹海峡没有支持华盛顿。法国媒体表示，特朗普是否试图将战争的失败归咎于欧洲？","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260404-%E7%89%B9%E6%9C%97%E6%99%AE-%E9%83%BD%E6%98%AF-%E6%AC%A7%E6%B4%B2%E4%BA%BA-%E6%B3%95%E8%8B%B1%E7%9A%84%E9%94%99%E5%84%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775334478000.webp","sourceId":"rfi"},{"id":1775334244000,"createdDate":"2026-04-04 20:24","name":"法国国际广播电台","title":"法外交部：惊悉陈森在广州被执行死刑","content":"法国外交部4月4日宣布，2010年因贩毒在中国被判处死刑的法籍大毒枭陈森（法文名ChanThaoPhoumy）已在广州被执行死刑，法方对此表示“震惊”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260404-%E6%B3%95%E5%A4%96%E4%BA%A4%E9%83%A8-%E6%83%8A%E6%82%89%E9%99%88%E6%A3%AE%E5%9C%A8%E5%B9%BF%E5%B7%9E%E8%A2%AB%E6%89%A7%E8%A1%8C%E6%AD%BB%E5%88%91","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775334244000.webp","sourceId":"rfi"},{"id":1775331895000,"createdDate":"2026-04-04 19:44","name":"法国国际广播电台","title":"开打五周后美方领教到伊朗战术难缠","content":"美国联手以色列向伊朗发起的军事行动席卷中东地区也影响到全世界，已持续5个星期。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260404-%E5%BC%80%E6%89%93%E4%BA%94%E5%91%A8%E5%90%8E%E7%BE%8E%E6%96%B9%E9%A2%86%E6%95%99%E5%88%B0%E4%BC%8A%E6%9C%97%E6%88%98%E6%9C%AF%E9%9A%BE%E7%BC%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775331895000.webp","sourceId":"rfi"},{"id":1775325842000,"createdDate":"2026-04-04 18:04","name":"法国国际广播电台","title":"特朗普2027预算案出炉：国防支出创新高、内政大砍","content":"美国总统特朗普（DonaldTrump）近日公布2027财政年度预算提案，内容大幅调整联邦政府支出结构，在国防、移民与科技领域投入创纪录资金，同时对多项社会、教育与科研计划进行大规模削减，显示本次预算核心方向在于，缩减联邦规模并重塑政策优先顺序。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260404-%E7%89%B9%E6%9C%97%E6%99%AE2027%E9%A2%84%E7%AE%97%E6%A1%88%E5%87%BA%E7%82%89-%E5%9B%BD%E9%98%B2%E6%94%AF%E5%87%BA%E5%88%9B%E6%96%B0%E9%AB%98-%E5%86%85%E6%94%BF%E5%A4%A7%E7%A0%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775325842000.webp","sourceId":"rfi"},{"id":1775321450000,"createdDate":"2026-04-04 16:50","name":"法国国际广播电台","title":"中企结合AI“实时”追踪披露伊朗战争中美军部署及动向受关注","content":"五周前，美国和以色列与伊朗的战争爆发之际，西方和中国的社交媒体平台上涌现出大量病毒式传播的帖子，详细披露了美军基地的装备、美军航母战斗群的动向，以及军机集结准备空袭德黑兰的详细情况。《华盛顿邮报》报导称，这些情报来自一个快速增长的新兴市场：中国公司，其中一些与解放军有关联，将人工智能与开源数据相结合，兜售它们声称可以“揭露”美军动向的信息。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260404-%E4%B8%AD%E4%BC%81%E7%BB%93%E5%90%88ai-%E5%AE%9E%E6%97%B6-%E8%BF%BD%E8%B8%AA%E6%8A%AB%E9%9C%B2%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E4%B8%AD%E7%BE%8E%E5%86%9B%E9%83%A8%E7%BD%B2%E5%8F%8A%E5%8A%A8%E5%90%91%E5%8F%97%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/04/1775321450000.webp","sourceId":"rfi"}]