[{"id":1776903733000,"createdDate":"2026-04-23 00:22","name":"法国国际广播电台","title":"中国创世界纪录：为高速列车挖掘了史来最深海底隧道","content":"中国南方海底高速铁路隧道创下了隧道深度的世界纪录。中国为修建高速列车挖掘了有史以来最深的海底隧道，深江一号隧道掘进机历时四年不间断掘进，总掘进距离超过4公里。这项宏伟工程将深圳和江门两座城市连接起来，全程不到一小时。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260423-%E4%B8%AD%E5%9B%BD%E5%88%9B%E4%B8%96%E7%95%8C%E7%BA%AA%E5%BD%95-%E4%B8%BA%E9%AB%98%E9%80%9F%E5%88%97%E8%BD%A6%E6%8C%96%E6%8E%98%E4%BA%86%E5%8F%B2%E6%9D%A5%E6%9C%80%E6%B7%B1%E6%B5%B7%E5%BA%95%E9%9A%A7%E9%81%93","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776903733000.webp","sourceId":"rfi"},{"id":1776933551000,"createdDate":"2026-04-23 08:39","name":"法国国际广播电台","title":"中国美国商会：中国供应链相关新规令美国企业“担忧”","content":"中国美国商会周四（4月23日）表示，中国最新出台的供应链相关法规或令美国企业“担忧”。该新规4月7日发布，允许当局可对“损害中国工业和供应链安全”的外国公司或个人采取措施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260423-%E7%BE%8E%E5%9B%BD%E4%B8%AD%E5%9B%BD%E5%95%86%E4%BC%9A-%E4%B8%AD%E5%9B%BD%E4%BE%9B%E5%BA%94%E9%93%BE%E7%9B%B8%E5%85%B3%E6%96%B0%E8%A7%84%E4%BB%A4%E7%BE%8E%E5%9B%BD%E4%BC%81%E4%B8%9A-%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776933551000.webp","sourceId":"rfi"},{"id":1776933049000,"createdDate":"2026-04-23 08:30","name":"法国国际广播电台","title":"泽连斯基：特朗普、习近平、莫迪等须告诉普京，他必须停止战争","content":"乌克兰总统泽连斯基（VolodymyrZelenskyy）近日在接受美国有线电视新闻网（CNN）采访时表示，“我认为特朗普总统、习主席、莫迪总理以及其他世界主要参与者必须告诉普京，他必须停止这场战争。他们不能对乌克兰说：‘你们必须停止战争’。我们是在自卫，我们不是侵略者”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260423-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E7%89%B9%E6%9C%97%E6%99%AE-%E4%B9%A0%E8%BF%91%E5%B9%B3-%E8%8E%AB%E8%BF%AA%E7%AD%89%E9%A1%BB%E5%91%8A%E8%AF%89%E6%99%AE%E4%BA%AC%EF%BC%8C%E4%BB%96%E5%BF%85%E9%A1%BB%E5%81%9C%E6%AD%A2%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776933049000.webp","sourceId":"rfi"},{"id":1776932879000,"createdDate":"2026-04-23 08:27","name":"法国国际广播电台","title":"日本众议院通过《国家情报会议设立法案》 共产党担心与CIA合作","content":"为提升政府的信息收集能力和分析能力的《国家情报会议设立法案》日本时间23日下午在众议院获得通过，日本共产党表示反对，并担心与美国CIA合作。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260423-%E6%97%A5%E6%9C%AC%E4%BC%97%E8%AE%AE%E9%99%A2%E9%80%9A%E8%BF%87-%E5%9B%BD%E5%AE%B6%E6%83%85%E6%8A%A5%E4%BC%9A%E8%AE%AE%E8%AE%BE%E7%AB%8B%E6%B3%95%E6%A1%88-%E5%85%B1%E4%BA%A7%E5%85%9A%E6%8B%85%E5%BF%83%E4%B8%8Ecia%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776932879000.webp","sourceId":"rfi"},{"id":1776927230000,"createdDate":"2026-04-23 06:53","name":"法国国际广播电台","title":"168人身死大火：港府各部门听证会上互相卸责 消防称部分火警风险与职权无关捱轰","content":"港府就宏福苑大火成立的独立委员会，连日来传召消防丶劳工和房屋等多个政府部门代表作供，揭示各部门未有认真转介和处理居民的投诉丶未发现承建商用旧有合格检测证书偷龙转凤等情况。其中，消防代表作供称，工人在工地吸烟丶承建商使用易燃棚网及以发泡胶板(又称「泡沫塑胶」)封窗等火警风险，一概与消防无关，被各界狠批为卸责。委员会主席陆启康指出，事件反映各部门分工存在灰色地带，监管权责不清问题完全浮现；评论则认为，事件凸显官僚之恶。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260423-168%E4%BA%BA%E8%BA%AB%E6%AD%BB%E5%A4%A7%E7%81%AB-%E6%B8%AF%E5%BA%9C%E5%90%84%E9%83%A8%E9%97%A8%E5%90%AC%E8%AF%81%E4%BC%9A%E4%B8%8A%E4%BA%92%E7%9B%B8%E5%8D%B8%E8%B4%A3-%E6%B6%88%E9%98%B2%E7%A7%B0%E9%83%A8%E5%88%86%E7%81%AB%E8%AD%A6%E9%A3%8E%E9%99%A9%E4%B8%8E%E8%81%8C%E6%9D%83%E6%97%A0%E5%85%B3%E6%8D%B1%E8%BD%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776927230000.webp","sourceId":"rfi"},{"id":1776906470000,"createdDate":"2026-04-23 01:07","name":"法国国际广播电台","title":"台湾指责中国向马达加斯加、毛里求斯和塞舌尔施压，阻止其总统的一次出访","content":"中华民国台湾的总统赖清德被迫推迟对位于莫桑比克和南非之间的斯威士兰(Eswatini)非洲国家的的正式访问。与此同时，在飞行航空领域方面，非洲国家塞舌尔、毛里求斯和马达加斯加针对相关包机，撤销了台湾包机的飞越许可。台北方面指责中国对这三个国家实施经济威胁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E9%9D%9E%E6%B4%B2/20260423-%E5%8F%B0%E6%B9%BE%E6%8C%87%E8%B4%A3%E4%B8%AD%E5%9B%BD%E5%90%91%E9%A9%AC%E8%BE%BE%E5%8A%A0%E6%96%AF%E5%8A%A0-%E6%AF%9B%E9%87%8C%E6%B1%82%E6%96%AF%E5%92%8C%E5%A1%9E%E8%88%8C%E5%B0%94%E6%96%BD%E5%8E%8B%EF%BC%8C%E9%98%BB%E6%AD%A2%E5%85%B6%E6%80%BB%E7%BB%9F%E7%9A%84%E4%B8%80%E6%AC%A1%E5%87%BA%E8%AE%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776906470000.webp","sourceId":"rfi"}]