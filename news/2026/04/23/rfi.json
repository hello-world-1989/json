[{"id":1776903733000,"createdDate":"2026-04-23 00:22","name":"法国国际广播电台","title":"中国创世界纪录：为高速列车挖掘了史来最深海底隧道","content":"中国南方海底高速铁路隧道创下了隧道深度的世界纪录。中国为修建高速列车挖掘了有史以来最深的海底隧道，深江一号隧道掘进机历时四年不间断掘进，总掘进距离超过4公里。这项宏伟工程将深圳和江门两座城市连接起来，全程不到一小时。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260423-%E4%B8%AD%E5%9B%BD%E5%88%9B%E4%B8%96%E7%95%8C%E7%BA%AA%E5%BD%95-%E4%B8%BA%E9%AB%98%E9%80%9F%E5%88%97%E8%BD%A6%E6%8C%96%E6%8E%98%E4%BA%86%E5%8F%B2%E6%9D%A5%E6%9C%80%E6%B7%B1%E6%B5%B7%E5%BA%95%E9%9A%A7%E9%81%93","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776903733000.webp","sourceId":"rfi"},{"id":1776933551000,"createdDate":"2026-04-23 08:39","name":"法国国际广播电台","title":"中国美国商会：中国供应链相关新规令美国企业“担忧”","content":"中国美国商会周四（4月23日）表示，中国最新出台的供应链相关法规或令美国企业“担忧”。该新规4月7日发布，允许当局可对“损害中国工业和供应链安全”的外国公司或个人采取措施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260423-%E7%BE%8E%E5%9B%BD%E4%B8%AD%E5%9B%BD%E5%95%86%E4%BC%9A-%E4%B8%AD%E5%9B%BD%E4%BE%9B%E5%BA%94%E9%93%BE%E7%9B%B8%E5%85%B3%E6%96%B0%E8%A7%84%E4%BB%A4%E7%BE%8E%E5%9B%BD%E4%BC%81%E4%B8%9A-%E6%8B%85%E5%BF%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776933551000.webp","sourceId":"rfi"},{"id":1776933049000,"createdDate":"2026-04-23 08:30","name":"法国国际广播电台","title":"泽连斯基：特朗普、习近平、莫迪等须告诉普京，他必须停止战争","content":"乌克兰总统泽连斯基（VolodymyrZelenskyy）近日在接受美国有线电视新闻网（CNN）采访时表示，“我认为特朗普总统、习主席、莫迪总理以及其他世界主要参与者必须告诉普京，他必须停止这场战争。他们不能对乌克兰说：‘你们必须停止战争’。我们是在自卫，我们不是侵略者”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260423-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA-%E7%89%B9%E6%9C%97%E6%99%AE-%E4%B9%A0%E8%BF%91%E5%B9%B3-%E8%8E%AB%E8%BF%AA%E7%AD%89%E9%A1%BB%E5%91%8A%E8%AF%89%E6%99%AE%E4%BA%AC%EF%BC%8C%E4%BB%96%E5%BF%85%E9%A1%BB%E5%81%9C%E6%AD%A2%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776933049000.webp","sourceId":"rfi"},{"id":1776932879000,"createdDate":"2026-04-23 08:27","name":"法国国际广播电台","title":"日本众议院通过《国家情报会议设立法案》 共产党担心与CIA合作","content":"为提升政府的信息收集能力和分析能力的《国家情报会议设立法案》日本时间23日下午在众议院获得通过，日本共产党表示反对，并担心与美国CIA合作。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260423-%E6%97%A5%E6%9C%AC%E4%BC%97%E8%AE%AE%E9%99%A2%E9%80%9A%E8%BF%87-%E5%9B%BD%E5%AE%B6%E6%83%85%E6%8A%A5%E4%BC%9A%E8%AE%AE%E8%AE%BE%E7%AB%8B%E6%B3%95%E6%A1%88-%E5%85%B1%E4%BA%A7%E5%85%9A%E6%8B%85%E5%BF%83%E4%B8%8Ecia%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776932879000.webp","sourceId":"rfi"},{"id":1776927230000,"createdDate":"2026-04-23 06:53","name":"法国国际广播电台","title":"168人身死大火：港府各部门听证会上互相卸责 消防称部分火警风险与职权无关捱轰","content":"港府就宏福苑大火成立的独立委员会，连日来传召消防丶劳工和房屋等多个政府部门代表作供，揭示各部门未有认真转介和处理居民的投诉丶未发现承建商用旧有合格检测证书偷龙转凤等情况。其中，消防代表作供称，工人在工地吸烟丶承建商使用易燃棚网及以发泡胶板(又称「泡沫塑胶」)封窗等火警风险，一概与消防无关，被各界狠批为卸责。委员会主席陆启康指出，事件反映各部门分工存在灰色地带，监管权责不清问题完全浮现；评论则认为，事件凸显官僚之恶。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260423-168%E4%BA%BA%E8%BA%AB%E6%AD%BB%E5%A4%A7%E7%81%AB-%E6%B8%AF%E5%BA%9C%E5%90%84%E9%83%A8%E9%97%A8%E5%90%AC%E8%AF%81%E4%BC%9A%E4%B8%8A%E4%BA%92%E7%9B%B8%E5%8D%B8%E8%B4%A3-%E6%B6%88%E9%98%B2%E7%A7%B0%E9%83%A8%E5%88%86%E7%81%AB%E8%AD%A6%E9%A3%8E%E9%99%A9%E4%B8%8E%E8%81%8C%E6%9D%83%E6%97%A0%E5%85%B3%E6%8D%B1%E8%BD%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776927230000.webp","sourceId":"rfi"},{"id":1776906470000,"createdDate":"2026-04-23 01:07","name":"法国国际广播电台","title":"台湾指责中国向马达加斯加、毛里求斯和塞舌尔施压，阻止其总统的一次出访","content":"中华民国台湾的总统赖清德被迫推迟对位于莫桑比克和南非之间的斯威士兰(Eswatini)非洲国家的的正式访问。与此同时，在飞行航空领域方面，非洲国家塞舌尔、毛里求斯和马达加斯加针对相关包机，撤销了台湾包机的飞越许可。台北方面指责中国对这三个国家实施经济威胁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E9%9D%9E%E6%B4%B2/20260423-%E5%8F%B0%E6%B9%BE%E6%8C%87%E8%B4%A3%E4%B8%AD%E5%9B%BD%E5%90%91%E9%A9%AC%E8%BE%BE%E5%8A%A0%E6%96%AF%E5%8A%A0-%E6%AF%9B%E9%87%8C%E6%B1%82%E6%96%AF%E5%92%8C%E5%A1%9E%E8%88%8C%E5%B0%94%E6%96%BD%E5%8E%8B%EF%BC%8C%E9%98%BB%E6%AD%A2%E5%85%B6%E6%80%BB%E7%BB%9F%E7%9A%84%E4%B8%80%E6%AC%A1%E5%87%BA%E8%AE%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776906470000.webp","sourceId":"rfi"},{"id":1776961036000,"createdDate":"2026-04-23 16:17","name":"法国国际广播电台","title":"联合国：伊朗战争将令全球至少三千万人重陷贫困","content":"联合国开发计划署署长23日向媒体表示，由于霍尔木兹海峡通航受阻，农药运输不畅，对农业生产产生的影响将导致全球超过三千万人因此而重返贫困。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260423-%E8%81%94%E5%90%88%E5%9B%BD-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E5%B0%86%E4%BB%A4%E5%85%A8%E7%90%83%E8%87%B3%E5%B0%91%E4%B8%89%E5%8D%83%E4%B8%87%E4%BA%BA%E9%87%8D%E9%99%B7%E8%B4%AB%E5%9B%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776961036000.webp","sourceId":"rfi"},{"id":1776959331000,"createdDate":"2026-04-23 15:48","name":"法国国际广播电台","title":"民间怨声载道 普京首次就俄互联网限制问题发表讲话","content":"俄总统普京首次就俄罗斯的互联网限制问题发表讲话。周四，普京与负责北极地区发展和跨北极运输走廊建设的政府成员举行了会议。会议期间，普京提到了俄罗斯一些城市出现网络中断的情况。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260423-%E6%B0%91%E9%97%B4%E6%80%A8%E5%A3%B0%E8%BD%BD%E9%81%93-%E6%99%AE%E4%BA%AC%E9%A6%96%E6%AC%A1%E5%B0%B1%E4%BF%84%E4%BA%92%E8%81%94%E7%BD%91%E9%99%90%E5%88%B6%E9%97%AE%E9%A2%98%E5%8F%91%E8%A1%A8%E8%AE%B2%E8%AF%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776959331000.webp","sourceId":"rfi"},{"id":1776958109000,"createdDate":"2026-04-23 15:28","name":"法国国际广播电台","title":"美战争部印太事务高官：美军不能也不应独自维持有利的力量平衡","content":"一位五角大楼高级官员周三表示，加强美国在日本的军事存在和态势是美国战争部的一项“首要任务”，随着中国不断扩展军力，美国正寻求重建在印太地区的威慑力。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260423-%E7%BE%8E%E6%88%98%E4%BA%89%E9%83%A8%E5%8D%B0%E5%A4%AA%E4%BA%8B%E5%8A%A1%E9%AB%98%E5%AE%98-%E7%BE%8E%E5%86%9B%E4%B8%8D%E8%83%BD%E4%B9%9F%E4%B8%8D%E5%BA%94%E7%8B%AC%E8%87%AA%E7%BB%B4%E6%8C%81%E6%9C%89%E5%88%A9%E7%9A%84%E5%8A%9B%E9%87%8F%E5%B9%B3%E8%A1%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776958109000.webp","sourceId":"rfi"},{"id":1776956130000,"createdDate":"2026-04-23 14:55","name":"法国国际广播电台","title":"欧盟批准向乌克兰提供900亿欧元贷款和一项新的对俄制裁方案","content":"欧盟周四最终批准向乌克兰提供900亿欧元贷款，并对俄罗斯实施新一轮制裁，法新社说，这在乌克兰与俄罗斯长期争端后，无疑给基辅带来了一线生机。乌克兰修复受损的“友谊”输油管道后恢复石油输送，在匈牙利和斯洛伐克撤回反对意见后，这些措施得以签署生效。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260423-%E6%AC%A7%E7%9B%9F%E6%89%B9%E5%87%86%E5%90%91%E4%B9%8C%E5%85%8B%E5%85%B0%E6%8F%90%E4%BE%9B900%E4%BA%BF%E6%AC%A7%E5%85%83%E8%B4%B7%E6%AC%BE%E5%92%8C%E4%B8%80%E9%A1%B9%E6%96%B0%E7%9A%84%E5%AF%B9%E4%BF%84%E5%88%B6%E8%A3%81%E6%96%B9%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776956130000.webp","sourceId":"rfi"},{"id":1776955429000,"createdDate":"2026-04-23 14:43","name":"法国国际广播电台","title":"白宫：中国实体正蓄意开展工业规模运动，蒸馏美国前沿AI系统","content":"白宫指责中国大规模窃取美国人工智能实验室的知识产权，并警告称将严厉打击这种利用美国创新成果的行为。白宫科技政策办公室主任克拉齐奥斯（MichaelKratsios）在一份备忘录中写道：“美国政府掌握的信息表明，主要位于中国的外国实体正在蓄意开展工业规模的运动，蒸馏美国前沿人工智能系统”。这份备忘录被英国《金融时报》看到。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260423-%E7%99%BD%E5%AE%AB-%E4%B8%AD%E5%9B%BD%E5%AE%9E%E4%BD%93%E6%AD%A3%E8%93%84%E6%84%8F%E5%BC%80%E5%B1%95%E5%B7%A5%E4%B8%9A%E8%A7%84%E6%A8%A1%E8%BF%90%E5%8A%A8%EF%BC%8C%E8%92%B8%E9%A6%8F%E7%BE%8E%E5%9B%BD%E5%89%8D%E6%B2%BFai%E7%B3%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776955429000.webp","sourceId":"rfi"},{"id":1776953754000,"createdDate":"2026-04-23 14:15","name":"法国国际广播电台","title":"工业七强环保部长巴黎会议： 为内部团结避谈能源转型","content":"七大工业国集团23日和24日在巴黎举行部长级会议，讨论环境议题。如果说当前的中东动荡引发的能源危机正推动不少国家加速能源转型的话，能源转型并没有被这次会议的东道主国列入重点讨论议题。目前担任七国集团轮值主席国的法国似乎想借此避开与美国特别是特朗普政府在此议题上的分歧。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260423-%E5%B7%A5%E4%B8%9A%E4%B8%83%E5%BC%BA%E7%8E%AF%E4%BF%9D%E9%83%A8%E9%95%BF%E5%B7%B4%E9%BB%8E%E4%BC%9A%E8%AE%AE-%E4%B8%BA%E5%86%85%E9%83%A8%E5%9B%A2%E7%BB%93%E9%81%BF%E8%B0%88%E8%83%BD%E6%BA%90%E8%BD%AC%E5%9E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776953754000.webp","sourceId":"rfi"},{"id":1776953537000,"createdDate":"2026-04-23 14:12","name":"法国国际广播电台","title":"特朗普：已命令击沉任何在霍尔木兹海峡布雷船只，伊朗不知自己领导人是谁","content":"美国总统特朗普（DonaldTrump）周四通过其社媒平台“真相社交”发文称，“我已经命令美国海军击沉任何在霍尔木兹海峡布雷的船只，无论大小（他们的海军舰艇全部159艘都已沉入海底！）。务必毫不犹豫。此外，我们的扫雷舰目前正在清理该海峡。我在此命令继续进行这项行动，但力度要加强三倍！”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260423-%E7%89%B9%E6%9C%97%E6%99%AE-%E5%B7%B2%E5%91%BD%E4%BB%A4%E5%87%BB%E6%B2%89%E4%BB%BB%E4%BD%95%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%B8%83%E9%9B%B7%E8%88%B9%E5%8F%AA%EF%BC%8C%E4%BC%8A%E6%9C%97%E4%B8%8D%E7%9F%A5%E8%87%AA%E5%B7%B1%E9%A2%86%E5%AF%BC%E4%BA%BA%E6%98%AF%E8%B0%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776953537000.webp","sourceId":"rfi"},{"id":1776951091000,"createdDate":"2026-04-23 13:31","name":"法国国际广播电台","title":"英国生物样本库50万人数据疑在阿里平台上被挂售 英政府展开调查","content":"英国科学、创新和技术部负责数字政府与数据事物的国务大臣默里（IanMurray）周四表示，英国政府正在调查一家健康慈善机构的数据为何会在中国阿里巴巴平台上被挂出出售，其中包括一个似乎包含50万人信息的数据集。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260423-%E8%8B%B1%E5%9B%BD%E7%94%9F%E7%89%A9%E6%A0%B7%E6%9C%AC%E5%BA%9350%E4%B8%87%E4%BA%BA%E6%95%B0%E6%8D%AE%E7%96%91%E5%9C%A8%E9%98%BF%E9%87%8C%E5%B9%B3%E5%8F%B0%E4%B8%8A%E8%A2%AB%E6%8C%82%E5%94%AE-%E8%8B%B1%E6%94%BF%E5%BA%9C%E5%B1%95%E5%BC%80%E8%B0%83%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776951091000.webp","sourceId":"rfi"},{"id":1776949805000,"createdDate":"2026-04-23 13:10","name":"法国国际广播电台","title":"芬兰外长：北京与莫斯科的密切关系将阻碍欧中达成任何贸易协议","content":"芬兰外交部长瓦尔托宁（ElinaValtonen）表示，中国与俄罗斯的密切关系应该成为北京试图与欧盟启动自由贸易协定谈判的“取消资格因素”。在与欧洲领导人的会晤中，中方一直在暗示可能达成贸易或投资协议，而德国总理默茨上月也曾提出，未来可预见欧中达成贸易协议。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260423-%E8%8A%AC%E5%85%B0%E5%A4%96%E9%95%BF-%E5%8C%97%E4%BA%AC%E4%B8%8E%E8%8E%AB%E6%96%AF%E7%A7%91%E7%9A%84%E5%AF%86%E5%88%87%E5%85%B3%E7%B3%BB%E5%B0%86%E9%98%BB%E7%A2%8D%E6%AC%A7%E4%B8%AD%E8%BE%BE%E6%88%90%E4%BB%BB%E4%BD%95%E8%B4%B8%E6%98%93%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776949805000.webp","sourceId":"rfi"},{"id":1776939927000,"createdDate":"2026-04-23 10:25","name":"法国国际广播电台","title":"阻不了国际政要访台，中国转而堵台湾总统出访，美国谴责此为“恐吓行动”","content":"大家好，欢迎收听法国报纸摘要，4月23日星期四上市的法国全国性日报头版大多关注国内事务。据《费加罗报》表示，为准备2027年总统大选，社会党周三公布了旨在界定“21世纪社会主义”的纲领。与此同时，碧姬·芭铎基金会：一笔失控的巨额财富成为《解放报》的封面故事，该报对这家由女演员去世后留下的、作为动物保护事业先锋的机构的阴暗面进行了调查。《回声报》社评则以伊朗战争有如慢性毒药为主题。《十字架报》探讨法国企业急需接手者的难关，指出未来十年内将有50万名企业高管退休；该报国际版还关注了，中国通过向其非洲盟友施压，阻止台湾总统赖清德赴史瓦帝尼访问。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260423-%E9%98%BB%E4%B8%8D%E4%BA%86%E5%9B%BD%E9%99%85%E6%94%BF%E8%A6%81%E8%AE%BF%E5%8F%B0%EF%BC%8C%E4%B8%AD%E5%9B%BD%E8%BD%AC%E8%80%8C%E5%A0%B5%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E5%87%BA%E8%AE%BF%EF%BC%8C%E7%BE%8E%E5%9B%BD%E8%B0%B4%E8%B4%A3%E6%AD%A4%E4%B8%BA-%E6%81%90%E5%90%93%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776939927000.webp","sourceId":"rfi"},{"id":1776939099000,"createdDate":"2026-04-23 10:11","name":"法国国际广播电台","title":"三星电子前高管向中企泄露半导体技术重审判囚6年零4个月","content":"周四，首尔高等法院在针对因涉嫌违反韩国《工业技术泄露预防和保护法》（《工业技术保护法》）等罪名被起诉的三星电子前经理金某的撤销发回重审中，判处其有期徒刑6年零4个月，并处罚金2亿韩元（约合13.53万美元）。首尔高等法院周四作出的判决比下级法院此前的量刑更为严厉，并在判决书中指出，“侵犯专有和核心国家技术是严重的犯罪行为”。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260423-%E4%B8%89%E6%98%9F%E7%94%B5%E5%AD%90%E5%89%8D%E9%AB%98%E7%AE%A1%E5%90%91%E4%B8%AD%E4%BC%81%E6%B3%84%E9%9C%B2%E5%8D%8A%E5%AF%BC%E4%BD%93%E6%8A%80%E6%9C%AF%E9%87%8D%E5%AE%A1%E5%88%A4%E5%9B%9A6%E5%B9%B4%E9%9B%B64%E4%B8%AA%E6%9C%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776939099000.webp","sourceId":"rfi"},{"id":1776938297000,"createdDate":"2026-04-23 09:58","name":"法国国际广播电台","title":"华盛顿谴责北京对台湾总统的“恐吓”","content":"美国谴责中国发起“恐吓行动”，此前多个非洲国家撤销了台湾总统赖清德的飞越许可，迫使他推迟访问斯威士兰。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260423-%E5%8D%8E%E7%9B%9B%E9%A1%BF%E8%B0%B4%E8%B4%A3%E5%8C%97%E4%BA%AC%E5%AF%B9%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E7%9A%84-%E6%81%90%E5%90%93","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776938297000.webp","sourceId":"rfi"},{"id":1776936973000,"createdDate":"2026-04-23 09:36","name":"法国国际广播电台","title":"台政府机关禁用高德地图 顾立雄：通令全军禁止下载使用","content":"中国行动通讯应用程序高德地图在台引发资安疑虑。台湾数发部周四表示，政府机关禁用高德地图。台国防部长顾立雄受访时亦指，国防部会依循数发部立场，禁止下载使用，也会通令全体国军遵循。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260423-%E5%8F%B0%E6%94%BF%E5%BA%9C%E6%9C%BA%E5%85%B3%E7%A6%81%E7%94%A8%E9%AB%98%E5%BE%B7%E5%9C%B0%E5%9B%BE-%E9%A1%BE%E7%AB%8B%E9%9B%84-%E9%80%9A%E4%BB%A4%E5%85%A8%E5%86%9B%E7%A6%81%E6%AD%A2%E4%B8%8B%E8%BD%BD%E4%BD%BF%E7%94%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776936973000.webp","sourceId":"rfi"},{"id":1776935685000,"createdDate":"2026-04-23 09:14","name":"法国国际广播电台","title":"忧特朗普政府不作为 美众院两党推进多项对华AI出口管制法案","content":"美国众议院外交委员会周三推进了一系列两党共同支持的出口管制法案，这些法案表明，美国国会越来越希望限制人工智能技术流向中国，而特朗普政府迄今为止一直没有出台任何重大的新限制措施。该委员会正试图堵住两党议员眼中的漏洞，这些漏洞使得中方能够获取包括英伟达芯片在内的美国强大技术。这些措施势预计会遭到白宫和行业利益相关者的反对，他们此前已对可能出台的芯片工具出口新限制表示担忧。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260423-%E5%BF%A7%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E4%B8%8D%E4%BD%9C%E4%B8%BA-%E7%BE%8E%E4%BC%97%E9%99%A2%E4%B8%A4%E5%85%9A%E6%8E%A8%E8%BF%9B%E5%A4%9A%E9%A1%B9%E5%AF%B9%E5%8D%8Eai%E5%87%BA%E5%8F%A3%E7%AE%A1%E5%88%B6%E6%B3%95%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776935685000.webp","sourceId":"rfi"}]