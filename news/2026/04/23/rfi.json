[{"id":1776903733000,"createdDate":"2026-04-23 00:22","name":"法国国际广播电台","title":"中国创世界纪录：为高速列车挖掘了史来最深海底隧道","content":"中国南方海底高速铁路隧道创下了隧道深度的世界纪录。中国为修建高速列车挖掘了有史以来最深的海底隧道，深江一号隧道掘进机历时四年不间断掘进，总掘进距离超过4公里。这项宏伟工程将深圳和江门两座城市连接起来，全程不到一小时。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260423-%E4%B8%AD%E5%9B%BD%E5%88%9B%E4%B8%96%E7%95%8C%E7%BA%AA%E5%BD%95-%E4%B8%BA%E9%AB%98%E9%80%9F%E5%88%97%E8%BD%A6%E6%8C%96%E6%8E%98%E4%BA%86%E5%8F%B2%E6%9D%A5%E6%9C%80%E6%B7%B1%E6%B5%B7%E5%BA%95%E9%9A%A7%E9%81%93","thumbnail":"","detailImage":"news/detail/rfi/2026/04/23/1776903733000.webp","sourceId":"rfi"}]