[{"id":1775982267000,"createdDate":"2026-04-12 08:24","name":"法国国际广播电台","title":"国台办选郑丽文返台前一刻抛10项惠台措施，陆委会：包装成“大礼包”的糖衣毒药","content":"法新社北京消息，就在台湾最大反对党国民党主席台湾郑丽文星期天12日返回台北的前几小时，北京发布了10项旨在“推动两岸关系和平发展，增进同胞福祉”的措施，包括努力“推动恢复上海市及福建省居民赴台个人游试点项目”。随后，台湾陆委会指出，这些“片面让利”的惠台措施只是包装为“大礼包”的糖衣毒药。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260412-%E5%9B%BD%E5%8F%B0%E5%8A%9E%E9%80%89%E9%83%91%E4%B8%BD%E6%96%87%E8%BF%94%E5%8F%B0%E5%89%8D%E4%B8%80%E5%88%BB%E6%8A%9B10%E9%A1%B9%E6%83%A0%E5%8F%B0%E6%8E%AA%E6%96%BD%EF%BC%8C%E9%99%86%E5%A7%94%E4%BC%9A-%E5%8C%85%E8%A3%85%E6%88%90-%E5%A4%A7%E7%A4%BC%E5%8C%85-%E7%9A%84%E7%B3%96%E8%A1%A3%E6%AF%92%E8%8D%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/12/1775982267000.webp","sourceId":"rfi"},{"id":1775958469000,"createdDate":"2026-04-12 01:47","name":"法国国际广播电台","title":"非洲吉布提总统高票赢得六连任","content":"在东非国家吉布提,该国官方在周六（2026年04月11日）对外公布了2026年总统大选结果。现年78岁的吉布提国家元首伊斯梅尔·奥马尔·盖莱(IsmaïlOmarGuelleh)以97.81%的得票率赢得第六个总统任期。经修宪取消了总统候选人年龄75岁上限的吉布提，将由在27年前1999年04月09日首次胜选的现总统继续执政。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260412-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2%E5%90%89%E5%B8%83%E6%8F%90%E6%80%BB%E7%BB%9F%E9%AB%98%E7%A5%A8%E8%B5%A2%E5%BE%97%E5%85%AD%E8%BF%9E%E4%BB%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/12/1775958469000.webp","sourceId":"rfi"},{"id":1776008361000,"createdDate":"2026-04-12 15:39","name":"法国国际广播电台","title":"复活节停火：乌克兰与俄罗斯互相指责对方违反上千次","content":"乌克兰和俄罗斯周日互相指责对方上千次违反了为庆祝东正教复活节而在乌克兰前线建立的停火协议。莫斯科方面表示，如果基辅不屈从其要求，将拒绝延长这一停火期。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260412-%E5%A4%8D%E6%B4%BB%E8%8A%82%E5%81%9C%E7%81%AB-%E4%B9%8C%E5%85%8B%E5%85%B0%E4%B8%8E%E4%BF%84%E7%BD%97%E6%96%AF%E4%BA%92%E7%9B%B8%E6%8C%87%E8%B4%A3%E5%AF%B9%E6%96%B9%E8%BF%9D%E5%8F%8D%E5%8D%8F%E8%AE%AE%E4%B8%8A%E5%8D%83%E6%AC%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/12/1776008361000.webp","sourceId":"rfi"},{"id":1776002663000,"createdDate":"2026-04-12 14:04","name":"法国国际广播电台","title":"特朗普宣布封锁霍尔木兹海峡以阻止伊朗收取过路费","content":"唐纳德·特朗普周日宣布，美国海军将立即封锁霍尔木兹海峡，并阻止任何向伊朗支付过过路费的船只在国际水域航行。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260412-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AE%A3%E5%B8%83%E5%B0%81%E9%94%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E4%BB%A5%E9%98%BB%E6%AD%A2%E4%BC%8A%E6%9C%97%E6%94%B6%E5%8F%96%E8%BF%87%E8%B7%AF%E8%B4%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/12/1776002663000.webp","sourceId":"rfi"},{"id":1776001887000,"createdDate":"2026-04-12 13:51","name":"法国国际广播电台","title":"匈牙利选举：奥尔班结束16年执政或开启第5个任期？","content":"法新社周日发自布达佩斯的报道称，此次议会选举可能终结维克托·奥尔班长达16年的执政生涯。选举结果受到众多国家，尤其是受到欧洲和美国政府的密切关注。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260412-%E5%8C%88%E7%89%99%E5%88%A9%E9%80%89%E4%B8%BE-%E5%A5%A5%E5%B0%94%E7%8F%AD%E7%BB%93%E6%9D%9F16%E5%B9%B4%E6%89%A7%E6%94%BF%E6%88%96%E5%BC%80%E5%90%AF%E7%AC%AC5%E4%B8%AA%E4%BB%BB%E6%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/12/1776001887000.webp","sourceId":"rfi"},{"id":1775999599000,"createdDate":"2026-04-12 13:13","name":"法国国际广播电台","title":"葛莱仪投书美媒《外交政策》警示：台湾的政治危机已经变成国安恶梦","content":"4月10日“习郑会”举行当天，美国期刊《外交政策》ForeignPolicy网站登出华盛顿智库库德国马歇尔基金会印太计划主任葛来仪的投书指出，台湾正面临数十年来最严峻的政治危机，这场危机现已成国安噩梦（Taiwan’sPoliticalCrisisIsaSecurityNightmare）。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260412-%E8%91%9B%E8%8E%B1%E4%BB%AA%E6%8A%95%E4%B9%A6%E7%BE%8E%E5%AA%92-%E5%A4%96%E4%BA%A4%E6%94%BF%E7%AD%96-%E8%AD%A6%E7%A4%BA-%E5%8F%B0%E6%B9%BE%E7%9A%84%E6%94%BF%E6%B2%BB%E5%8D%B1%E6%9C%BA%E5%B7%B2%E7%BB%8F%E5%8F%98%E6%88%90%E5%9B%BD%E5%AE%89%E6%81%B6%E6%A2%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/12/1775999599000.webp","sourceId":"rfi"},{"id":1775997283000,"createdDate":"2026-04-12 12:34","name":"法国国际广播电台","title":"彭博: 战争冲击硫酸供应 中国将禁止硫酸出口","content":"中国表示将从5月起停止硫酸出口，将对金属和化肥行业造成打击。这些行业正因伊朗战争造成的原材料短缺而捉襟见肘。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260412-%E5%BD%AD%E5%8D%9A-%E6%88%98%E4%BA%89%E5%86%B2%E5%87%BB%E7%A1%AB%E9%85%B8%E4%BE%9B%E5%BA%94-%E4%B8%AD%E5%9B%BD%E5%B0%86%E7%A6%81%E6%AD%A2%E7%A1%AB%E9%85%B8%E5%87%BA%E5%8F%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/12/1775997283000.webp","sourceId":"rfi"},{"id":1775995243000,"createdDate":"2026-04-12 12:00","name":"法国国际广播电台","title":"伊朗否认美国军舰穿越霍尔木兹海峡展开扫雷行动的说法","content":"美国军方周六表示其两艘驱逐舰已于周六穿越霍尔木兹海峡，以对这条由伊朗控制的战略水道展开扫雷行动。据法新社报道，在美伊两国于巴基斯坦举行会谈之际，德黑兰方面否认了这一说法。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260412-%E4%BC%8A%E6%9C%97%E5%90%A6%E8%AE%A4%E7%BE%8E%E5%9B%BD%E5%86%9B%E8%88%B0%E7%A9%BF%E8%B6%8A%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%B1%95%E5%BC%80%E6%89%AB%E9%9B%B7%E8%A1%8C%E5%8A%A8%E7%9A%84%E8%AF%B4%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/04/12/1775995243000.webp","sourceId":"rfi"},{"id":1775992525000,"createdDate":"2026-04-12 11:15","name":"法国国际广播电台","title":"谈判破局：万斯称提出了“最终最佳”方案，伊媒曝“关键问题”谈不拢","content":"在与伊朗进行了一场马拉松式的谈判后，美国副总统万斯（JDVance）离开巴基斯坦。当地时间星期天凌晨，万斯宣布，伊朗代表团没有接受美国提出的旨在巩固美以针对伊朗政权联合军事行动中临时停火的协议条件。伊朗外交部发言人随后告诉伊朗伊斯兰共和国广播电视台，双方确实在部分问题达成共识，但在“2、3个关键问题”存在观点分歧。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260412-%E8%B0%88%E5%88%A4%E7%A0%B4%E5%B1%80-%E4%B8%87%E6%96%AF%E7%A7%B0%E6%8F%90%E5%87%BA%E4%BA%86-%E6%9C%80%E7%BB%88%E6%9C%80%E4%BD%B3-%E6%96%B9%E6%A1%88%EF%BC%8C%E4%BC%8A%E5%AA%92%E6%9B%9D-%E5%85%B3%E9%94%AE%E9%97%AE%E9%A2%98-%E8%B0%88%E4%B8%8D%E6%8B%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/04/12/1775992525000.webp","sourceId":"rfi"},{"id":1775990234000,"createdDate":"2026-04-12 10:37","name":"法国国际广播电台","title":"伊朗权力结构重组中，“系统管理者”加利巴夫走向前台","content":"本期世界报头版关注了4月11日美国和伊朗在巴基斯坦的谈判。在国际版内页，世界报写道，万斯站在与伊朗谈判的第一线。这位美国副总统是自1979年以来参与与伊斯兰共和国会谈的美国最高级别的官员。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260412-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E8%B0%88%E5%88%A4-%E8%BF%91%E8%A7%82%E7%BE%8E%E4%BC%8A%E4%BB%A3%E8%A1%A8%E5%9B%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/04/12/1775990234000.webp","sourceId":"rfi"},{"id":1775989611000,"createdDate":"2026-04-12 10:26","name":"法国国际广播电台","title":"东南亚：苦盼中东冲突尽早落幕","content":"在中东冲突背景下，事关伊朗战局是否和平落幕的美国、伊朗和平谈判在巴基斯坦宣布“尚无定论”。尽管如此，北京发挥中东影响力扮演促谈的斡旋角色引发关注，外界将即将登场的中美元首会晤纳入观察视野。泰国学者评估以色列地缘角色成为中东和平谈判的重大障碍，而在中美冲突的背景下，东南亚国家正在重新调整战略视角、外交政策以及评估全球大国的角色。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260412-%E4%B8%9C%E5%8D%97%E4%BA%9A-%E8%8B%A6%E7%9B%BC%E4%B8%AD%E4%B8%9C%E5%86%B2%E7%AA%81%E5%B0%BD%E6%97%A9%E8%90%BD%E5%B9%95","thumbnail":"","detailImage":"news/detail/rfi/2026/04/12/1775989611000.webp","sourceId":"rfi"},{"id":1775985726000,"createdDate":"2026-04-12 09:22","name":"法国国际广播电台","title":"美国与伊朗未能达成协议 双方代表团离开巴基斯坦","content":"美国副总统J.D.万斯周日宣布，美国与伊朗在伊斯兰堡进行的马拉松式谈判结束，双方未能就结束中东战争达成协议。JD·万斯将核问题视为谈判破裂的核心原因，并表示，他已向伊朗提出了“最终且最优的提议”，目前他正返回美国。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260412-%E7%BE%8E%E5%9B%BD%E4%B8%8E%E4%BC%8A%E6%9C%97%E6%9C%AA%E8%83%BD%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE-%E5%8F%8C%E6%96%B9%E4%BB%A3%E8%A1%A8%E5%9B%A2%E7%A6%BB%E5%BC%80%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/12/1775985726000.webp","sourceId":"rfi"},{"id":1775983559000,"createdDate":"2026-04-12 08:45","name":"法国国际广播电台","title":"郑丽文与北京市委书记会谈言及两岸展开抗日史料交流  引日方关注","content":"台湾最大在野党中国国民党主席郑丽文11日在北京与北京市委书记尹力举行会谈，在会谈中郑丽文提出，通过保存与“抗日战争”以及象征日本统治结束的“台湾光复”相关史料并开展交流，推动国共两党的合作，引起日方广泛关注，日本《读卖新闻》等11日报道了这一消息，日本《产经新闻》10日发文称郑丽文“持有较强反日色彩的历史观”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260412-%E9%83%91%E4%B8%BD%E6%96%87%E4%B8%8E%E5%8C%97%E4%BA%AC%E5%B8%82%E5%A7%94%E4%B9%A6%E8%AE%B0%E4%BC%9A%E8%B0%88%E8%A8%80%E5%8F%8A%E4%B8%A4%E5%B2%B8%E5%B1%95%E5%BC%80%E6%8A%97%E6%97%A5%E5%8F%B2%E6%96%99%E4%BA%A4%E6%B5%81-%E5%BC%95%E6%97%A5%E6%96%B9%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/12/1775983559000.webp","sourceId":"rfi"}]