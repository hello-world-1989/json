[{"id":1777020085000,"createdDate":"2026-04-24 08:41","name":"法国国际广播电台","title":"销量暴跌、战争阴影下 北京举办规模空前新款齐聚的车展","content":"据《回声报报》两名特派记者从北京车展现场发回报道称，这场盛大的车展将于周五开幕，但背景却充满动荡，包括伊朗战争和中国汽车销量暴跌。中国和外国汽车制造商都面临着巨大的压力，他们都将推出大量新车型。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260424-%E9%94%80%E9%87%8F%E4%B8%8D%E6%9A%B4%E8%B7%8C-%E6%88%98%E4%BA%89%E9%98%B4%E5%BD%B1%E4%B8%8B-%E5%8C%97%E4%BA%AC%E4%B8%BE%E5%8A%9E%E8%A7%84%E6%A8%A1%E7%A9%BA%E5%89%8D%E7%9A%84%E8%BD%A6%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777020085000.webp","sourceId":"rfi"},{"id":1777017598000,"createdDate":"2026-04-24 07:59","name":"法国国际广播电台","title":"中共将海外领空武器化进一步孤立台湾 美议员、学者和33个海外台湾人团齐声谴责中国","content":"台湾总统赖清德原订22日启程前往斯威士兰，因中共以经济胁迫手段施压，非洲三国撤回台湾专机飞航许可。此举显示北京将航空通行权纳入对台打压战略工具。对此，国际声援台湾声音不断。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260424-%E4%B8%AD%E5%85%B1%E5%B0%86%E6%B5%B7%E5%A4%96%E9%A2%86%E7%A9%BA%E6%AD%A6%E5%99%A8%E5%8C%96%E8%BF%9B%E4%B8%80%E6%AD%A5%E5%AD%A4%E7%AB%8B%E5%8F%B0%E6%B9%BE-%E7%BE%8E%E8%AE%AE%E5%91%98-%E5%AD%A6%E8%80%85%E5%92%8C33%E4%B8%AA%E6%B5%B7%E5%A4%96%E5%8F%B0%E6%B9%BE%E4%BA%BA%E5%9B%A2%E9%BD%90%E5%A3%B0%E8%B0%B4%E8%B4%A3%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777017598000.webp","sourceId":"rfi"},{"id":1777014421000,"createdDate":"2026-04-24 07:07","name":"法国国际广播电台","title":"菲律宾总统将作为国宾访问日本","content":"日本政府4月24日宣布，5月26日至29日，菲律宾总统马科斯二世及其夫人将作为国宾访问日本。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260424-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E6%80%BB%E7%BB%9F%E5%B0%86%E4%BD%9C%E4%B8%BA%E5%9B%BD%E5%AE%BE%E8%AE%BF%E9%97%AE%E6%97%A5%E6%9C%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777014421000.webp","sourceId":"rfi"},{"id":1777013849000,"createdDate":"2026-04-24 06:57","name":"法国国际广播电台","title":"港府「两手抓」反修例人士：重审脱暴动罪女学生 被捕者参与「特别更生」换不起诉及就业机会","content":"2019年的反修例运动至今已近七年，但有约七千名被捕但未被起诉者一直生活在头顶悬剑的生活中，保安局早前透露有向该等人士提供「特别更生」，参加者可能会确认获得撤销起诉，近日首次有曾参加者披露，曾参与艺人在中国内地工作经验分享后获撤控，之後继续获推介不同的内地交流及工作实习计划。而对於已审讯者，律政司继续锲而不舍地「追究」脱罪者，一名早前获判暴动罪脱的法律系女学生，在港府提出上诉後得直，案件需重审，暂定6月判决。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260424-%E6%B8%AF%E5%BA%9C-%E4%B8%A4%E6%89%8B%E6%8A%93-%E5%8F%8D%E4%BF%AE%E4%BE%8B%E4%BA%BA%E5%A3%AB-%E9%87%8D%E5%AE%A1%E8%84%B1%E6%9A%B4%E5%8A%A8%E7%BD%AA%E5%A5%B3%E5%AD%A6%E7%94%9F-%E8%A2%AB%E6%8D%95%E8%80%85%E5%8F%82%E4%B8%8E-%E7%89%B9%E5%88%AB%E6%9B%B4%E7%94%9F-%E6%8D%A2%E4%B8%8D%E8%B5%B7%E8%AF%89%E5%8F%8A%E5%B0%B1%E4%B8%9A%E6%9C%BA%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777013849000.webp","sourceId":"rfi"},{"id":1777013474000,"createdDate":"2026-04-24 06:51","name":"法国国际广播电台","title":"BBC报英女在港称被强奸「原告变被告」案 遭港府去信谴责不符事实","content":"一名25岁英国女子报称，两年前在香港遭同属英籍的银行家强奸，她在接受对方以金钱补偿後报案，却被香港警方反控勒索及妨碍司法公正。英国广播公司（BBC）就案件作详细报道后一天，遭港府去信谴责和反驳，指报道失实，企图削弱香港法律制度的公信力。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260424-bbc%E6%8A%A5%E8%8B%B1%E5%A5%B3%E5%9C%A8%E6%B8%AF%E7%A7%B0%E8%A2%AB%E5%BC%BA%E5%A5%B8-%E5%8E%9F%E5%91%8A%E5%8F%98%E8%A2%AB%E5%91%8A-%E6%A1%88-%E9%81%AD%E6%B8%AF%E5%BA%9C%E5%8E%BB%E4%BF%A1%E8%B0%B4%E8%B4%A3%E4%B8%8D%E7%AC%A6%E4%BA%8B%E5%AE%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777013474000.webp","sourceId":"rfi"},{"id":1777044814000,"createdDate":"2026-04-24 15:33","name":"法国国际广播电台","title":"中国否认特朗普所说被扣伊朗货船上有“来自中国的礼物”","content":"中国外交部周五（4月24日）就美国总统特朗普有关一艘挂伊朗旗帜的货船被美军拦截时装有“来自中国的礼物”作出回应。外交部发言人郭嘉昆在记者会上说，“中方反对任何缺乏事实依据的指责和关联。国家之间正常的国际贸易不应受到干扰和破坏。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260424-%E4%B8%AD%E5%9B%BD%E5%90%A6%E8%AE%A4%E7%89%B9%E6%9C%97%E6%99%AE%E6%89%80%E6%8C%87%E8%A2%AB%E6%89%A3%E4%BC%8A%E6%9C%97%E8%B4%A7%E8%88%B9%E4%B8%8A%E6%9C%89-%E6%9D%A5%E8%87%AA%E4%B8%AD%E5%9B%BD%E7%9A%84%E7%A4%BC%E7%89%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777044814000.webp","sourceId":"rfi"},{"id":1777043762000,"createdDate":"2026-04-24 15:16","name":"法国国际广播电台","title":"俄防长会见董军：当今，俄中军事合作变得尤为重要","content":"周五，俄罗斯国防部长别洛乌索夫会见了到访的中国国防部长董军。别洛乌索夫表示，在不断变化的军事和政治背景下，俄中军事合作变得尤为重要。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260424-%E4%BF%84%E9%98%B2%E9%95%BF%E4%BC%9A%E8%A7%81%E8%91%A3%E5%86%9B-%E5%BD%93%E4%BB%8A%EF%BC%8C%E4%BF%84%E4%B8%AD%E5%86%9B%E4%BA%8B%E5%90%88%E4%BD%9C%E5%B0%A4%E4%B8%BA%E9%87%8D%E8%A6%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777043762000.webp","sourceId":"rfi"},{"id":1777041541000,"createdDate":"2026-04-24 14:39","name":"法国国际广播电台","title":"美战争部长：我们对伊朗的封锁正在扩大，并走向全球","content":"美国战争部长赫格塞思（PeteHegseth）周五在新闻发布会上表示，美国对伊朗的封锁正在扩大至全球范围。他还称，德黑兰有机会与华盛顿达成一项“好协议”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260424-%E7%BE%8E%E6%88%98%E4%BA%89%E9%83%A8%E9%95%BF-%E6%88%91%E4%BB%AC%E5%AF%B9%E4%BC%8A%E6%9C%97%E7%9A%84%E5%B0%81%E9%94%81%E6%AD%A3%E5%9C%A8%E6%89%A9%E5%A4%A7%EF%BC%8C%E5%B9%B6%E8%B5%B0%E5%90%91%E5%85%A8%E7%90%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777041541000.webp","sourceId":"rfi"},{"id":1777037739000,"createdDate":"2026-04-24 13:35","name":"法国国际广播电台","title":"特朗普称普京出席G20峰会“可能很有帮助” 克宫：普京可能去，也可能不去","content":"美国总统特朗普表示，预计俄总统普京不会出席今年晚些时候在他位于佛罗里达州多勒尔的度假村举行的二十国集团（G20）峰会，但他同时声称，普京的出席可能会是有用的。周四早些时候，《华盛顿邮报》报导称，俄罗斯将受邀参加部长级会议和领导人峰会。自2019年以来，由于新冠疫情以及随后的乌克兰战争，俄方一直缺席G20年度峰会。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260424-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E6%99%AE%E4%BA%AC%E5%87%BA%E5%B8%ADg20%E5%B3%B0%E4%BC%9A-%E5%8F%AF%E8%83%BD%E5%BE%88%E6%9C%89%E5%B8%AE%E5%8A%A9-%E5%85%8B%E5%AE%AB-%E6%99%AE%E4%BA%AC%E5%8F%AF%E8%83%BD%E5%8E%BB%EF%BC%8C%E4%B9%9F%E5%8F%AF%E8%83%BD%E4%B8%8D%E5%8E%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777037739000.webp","sourceId":"rfi"},{"id":1777037626000,"createdDate":"2026-04-24 13:33","name":"法国国际广播电台","title":"美国威胁暂停西班牙北约成员资格后 意大利总理呼吁北约“保持团结”","content":"意大利总理梅洛尼今天在塞浦路斯举行的欧盟领导人峰会上重申，北约必须“保持团结”。此前有媒体报道称，美国威胁可能暂停西班牙北约成员国资格。梅洛尼表示：“我认为北约必须保持团结，这是我们拥有的优势。”","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260424-%E7%BE%8E%E5%9B%BD%E5%A8%81%E8%83%81%E6%9A%82%E5%81%9C%E8%A5%BF%E7%8F%AD%E7%89%99%E5%8C%97%E7%BA%A6%E6%88%90%E5%91%98%E8%B5%84%E6%A0%BC%E5%90%8E-%E6%84%8F%E5%A4%A7%E5%88%A9%E6%80%BB%E7%90%86%E5%91%BC%E5%90%81%E5%8C%97%E7%BA%A6-%E4%BF%9D%E6%8C%81%E5%9B%A2%E7%BB%93","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777037626000.webp","sourceId":"rfi"},{"id":1777036306000,"createdDate":"2026-04-24 13:11","name":"法国国际广播电台","title":"伊朗外长出访伊斯兰堡、马斯喀特和莫斯科 美海军三航母20逾年来首次齐聚中东","content":"据伊通社报导，伊朗外交部长阿拉格齐周五将出访，行程包括巴基斯坦首都伊斯兰堡、阿曼首都马斯喀特和俄罗斯首都莫斯科。伊通社称，“此次访问的目的是举行双边磋商，讨论地区当前局势，以及美国和以色列政权对伊朗发动的战争的最新进展”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260424-%E4%BC%8A%E6%9C%97%E5%A4%96%E9%95%BF%E5%87%BA%E8%AE%BF%E4%BC%8A%E6%96%AF%E5%85%B0%E5%A0%A1-%E9%A9%AC%E6%96%AF%E5%96%80%E7%89%B9%E5%92%8C%E8%8E%AB%E6%96%AF%E7%A7%91-%E7%BE%8E%E5%86%9B%E6%96%B9%E5%88%B6%E5%AE%9A%E9%92%88%E5%AF%B9%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777036306000.webp","sourceId":"rfi"},{"id":1777034459000,"createdDate":"2026-04-24 12:40","name":"法国国际广播电台","title":"【视频】切尔诺贝利40年后 清理人员讲述亲历见证","content":"1986年4月26日凌晨1点23分，位于乌克兰北部前苏联切尔诺贝利核电站4号反应堆发生爆炸。首批抵达事故现场的人员中，有该机组的操作员叶夫根尼·亚努什凯维奇和亚历山大·泽连佐夫，他们不顾危险，参加了最早灾难控制的工作。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260424-%E8%A7%86%E9%A2%91-%E5%88%87%E5%B0%94%E8%AF%BA%E8%B4%9D%E5%88%A940%E5%B9%B4%E5%90%8E-%E6%B8%85%E7%90%86%E4%BA%BA%E5%91%98%E8%AE%B2%E8%BF%B0%E4%BA%B2%E5%8E%86%E8%A7%81%E8%AF%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777034459000.webp","sourceId":"rfi"},{"id":1777033797000,"createdDate":"2026-04-24 12:29","name":"法国国际广播电台","title":"菲防长：始终愿重置对华关系但取决诚意 解放军编队吕宋岛海域实弹射击演练","content":"解放军“南部战区”微信公众号周五发文称，“近期，中国人民解放军南部战区组织107编队位菲律宾吕宋岛以东海域开展演训活动，重点进行实弹射击、海空协同、快速机动、航行补给等演练，检验一体化联合作战能力”。本周，美国、菲律宾及盟国的17000多名军人开始举行年度“肩并肩”联合军演。在中日关系持续紧张背景下，日本作战部队也首次参加“肩并肩”联合军演。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260424-%E8%8F%B2%E9%98%B2%E9%95%BF-%E5%A7%8B%E7%BB%88%E6%84%BF%E9%87%8D%E7%BD%AE%E5%AF%B9%E5%8D%8E%E5%85%B3%E7%B3%BB%E4%BD%86%E5%8F%96%E5%86%B3%E8%AF%9A%E6%84%8F-%E8%A7%A3%E6%94%BE%E5%86%9B%E7%BC%96%E9%98%9F%E5%90%95%E5%AE%8B%E5%B2%9B%E6%B5%B7%E5%9F%9F%E5%AE%9E%E5%BC%B9%E5%B0%84%E5%87%BB%E6%BC%94%E7%BB%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777033797000.webp","sourceId":"rfi"},{"id":1777030103000,"createdDate":"2026-04-24 11:28","name":"法国国际广播电台","title":"费加罗报：白宫公开指责中国秘密且大规模地抄袭美国人工智能","content":"大家好，欢迎收听法国报纸摘要，4月24日星期五上市的法国全国性日报头版各有侧重。《费加罗报》关注伊朗战争动摇了特朗普的总统地位，因为“史诗怒火”行动已演变为“经济怒火”。对特朗普而言，伊朗战争如今纯粹成了一个令人愤怒的根源。《解放报》指出，长期以来，法国一些大企业的高管对国民联盟的经济主张不以为然，但如今他们却越来越表现出对这个极右翼政党的关注……与中国相关的报道见于《费加罗报》科技版，报道白宫指责中国秘密且大规模地抄袭美国人工智能模型。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260424-%E7%99%BD%E5%AE%AB%E5%85%AC%E5%BC%80%E6%8C%87%E8%B4%A3%E4%B8%AD%E5%9B%BD%E7%A7%98%E5%AF%86%E4%B8%94%E5%A4%A7%E8%A7%84%E6%A8%A1%E5%9C%B0%E6%8A%84%E8%A2%AD%E7%BE%8E%E5%9B%BD%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777030103000.webp","sourceId":"rfi"},{"id":1777029645000,"createdDate":"2026-04-24 11:20","name":"法国国际广播电台","title":"「漏洞末日」风险：若中国已有强大如Mythos的大语言模型，它会告诉你吗？","content":"Anthropic最新大语言模型Mythos能够识别并利用未知漏洞。因此面对相互毁灭的风险，美国与中国应当携手合作，防止该工具落入不法之手。前Orange硅谷总经理GeorgesNahon4月23日投书《回声报》论坛栏目作出如此分析。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260424-%E6%BC%8F%E6%B4%9E%E6%9C%AB%E6%97%A5-%E9%A3%8E%E9%99%A9-%E8%8B%A5%E4%B8%AD%E5%9B%BD%E5%B7%B2%E6%9C%89%E5%BC%BA%E5%A4%A7%E5%A6%82mythos%E7%9A%84%E5%A4%A7%E8%AF%AD%E8%A8%80%E6%A8%A1%E5%9E%8B%EF%BC%8C%E5%AE%83%E4%BC%9A%E5%91%8A%E8%AF%89%E4%BD%A0%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777029645000.webp","sourceId":"rfi"},{"id":1777027108000,"createdDate":"2026-04-24 10:38","name":"法国国际广播电台","title":"印尼财长：不计划对途经马六甲海峡的船只征收通行费","content":"印度尼西亚财政部长普尔巴亚（PurbayaYudhiSadewa）周五表示，印尼没有计划对途经马六甲海峡的船只征收通行费。此前，他曾就将这条战略航道转换为收入来源发表言论，引发本周早些时候的争议。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260424-%E5%8D%B0%E5%B0%BC%E8%B4%A2%E9%95%BF-%E4%B8%8D%E8%AE%A1%E5%88%92%E5%AF%B9%E9%80%94%E7%BB%8F%E9%A9%AC%E5%85%AD%E7%94%B2%E6%B5%B7%E5%B3%A1%E7%9A%84%E8%88%B9%E5%8F%AA%E5%BE%81%E6%94%B6%E9%80%9A%E8%A1%8C%E8%B4%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777027108000.webp","sourceId":"rfi"},{"id":1777026571000,"createdDate":"2026-04-24 10:29","name":"法国国际广播电台","title":"中国是否踩过伊朗战争“红线” 美国施压下的深度角力","content":"在美国与伊朗冲突持续升温之际，美国总统特朗普公开指控中国可能向伊朗提供军事相关支援，并威胁若相关行为属实，将对中国商品课征高达50%的关税。这一强硬表态不仅加剧美中紧张，也使中国在中东冲突中的角色受到全球高度关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260424-%E4%B8%AD%E5%9B%BD%E6%98%AF%E5%90%A6%E8%B8%A9%E8%BF%87%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89-%E7%BA%A2%E7%BA%BF-%E7%BE%8E%E5%9B%BD%E6%96%BD%E5%8E%8B%E4%B8%8B%E7%9A%84%E6%B7%B1%E5%BA%A6%E8%A7%92%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777026571000.webp","sourceId":"rfi"},{"id":1777025798000,"createdDate":"2026-04-24 10:16","name":"法国国际广播电台","title":"Manus收购案余波继续 中国加强监管美国资本对科技公司投资","content":"中国监管机构计划限制包括一些国内最知名的人工智能先驱企业在内的科技公司，在未经政府批准的情况下接受美国资本，这是北京方面对脸书母公司Meta收购人工智能初创公司Manus一事作出的更广泛回应的一部分。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260424-manus%E6%94%B6%E8%B4%AD%E6%A1%88%E4%BD%99%E6%B3%A2%E7%BB%A7%E7%BB%AD-%E4%B8%AD%E5%9B%BD%E5%8A%A0%E5%BC%BA%E7%9B%91%E7%AE%A1%E7%BE%8E%E5%9B%BD%E8%B5%84%E6%9C%AC%E5%AF%B9ai%E5%85%AC%E5%8F%B8%E6%8A%95%E8%B5%84","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777025798000.webp","sourceId":"rfi"},{"id":1777022225000,"createdDate":"2026-04-24 09:17","name":"法国国际广播电台","title":"韩前总统尹锡悦或因用军用无人机向朝鲜散发传单而再获刑30年","content":"已经因为未遂戒严令而被以“叛乱罪”判处终身监禁的韩国前总统尹锡悦可能面对新的刑罚。24日，韩国检察院以“对敌人有利的行为”的罪名，要求判处他30年徒刑，理由是他任下曾下令军用无人机向朝鲜散发传单，制造敌意。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260424-%E9%9F%A9%E5%89%8D%E6%80%BB%E7%BB%9F%E5%B0%B9%E9%94%A1%E6%82%A6%E6%88%96%E5%9B%A0%E7%94%A8%E5%86%9B%E7%94%A8%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%90%91%E6%9C%9D%E9%B2%9C%E6%95%A3%E5%8F%91%E4%BC%A0%E5%8D%95%E8%80%8C%E5%86%8D%E8%8E%B7%E5%88%9130%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777022225000.webp","sourceId":"rfi"},{"id":1777020852000,"createdDate":"2026-04-24 08:54","name":"法国国际广播电台","title":"欧盟对俄制裁多家中企被列入名单 中方将7欧盟实体列入出口管制名单","content":"欧洲理事会主席科斯塔周四表示，欧盟已批准向乌克兰提供900亿欧元贷款，并通过第20轮对俄罗斯制裁方案。第20轮制裁方案是两年来规模最大的方案，包括制裁名单新增120个个人和实体，新增36项涉及俄石油勘探、开采、炼制和运输等环节的限制措施等。《欧盟官方公报》发布的文件显示，欧盟已将六家中国公司和一名自然人列入第20轮对俄制裁方案。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260424-%E6%AC%A7%E7%9B%9F%E5%AF%B9%E4%BF%84%E5%88%B6%E8%A3%816%E5%AE%B6%E4%B8%AD%E4%BC%81%E8%A2%AB%E5%88%97%E5%85%A5%E5%90%8D%E5%8D%95-%E4%B8%AD%E6%96%B9%E5%B0%867%E6%AC%A7%E7%9B%9F%E5%AE%9E%E4%BD%93%E5%88%97%E5%85%A5%E5%87%BA%E5%8F%A3%E7%AE%A1%E5%88%B6%E5%90%8D%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777020852000.webp","sourceId":"rfi"}]