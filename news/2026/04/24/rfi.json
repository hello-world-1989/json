[{"id":1777020085000,"createdDate":"2026-04-24 08:41","name":"法国国际广播电台","title":"销量暴跌、战争阴影下 北京举办规模空前新款齐聚的车展","content":"据《回声报报》两名特派记者从北京车展现场发回报道称，这场盛大的车展将于周五开幕，但背景却充满动荡，包括伊朗战争和中国汽车销量暴跌。中国和外国汽车制造商都面临着巨大的压力，他们都将推出大量新车型。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260424-%E9%94%80%E9%87%8F%E4%B8%8D%E6%9A%B4%E8%B7%8C-%E6%88%98%E4%BA%89%E9%98%B4%E5%BD%B1%E4%B8%8B-%E5%8C%97%E4%BA%AC%E4%B8%BE%E5%8A%9E%E8%A7%84%E6%A8%A1%E7%A9%BA%E5%89%8D%E7%9A%84%E8%BD%A6%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777020085000.webp","sourceId":"rfi"},{"id":1777017598000,"createdDate":"2026-04-24 07:59","name":"法国国际广播电台","title":"中共将海外领空武器化进一步孤立台湾 美议员、学者和33个海外台湾人团齐声谴责中国","content":"台湾总统赖清德原订22日启程前往斯威士兰，因中共以经济胁迫手段施压，非洲三国撤回台湾专机飞航许可。此举显示北京将航空通行权纳入对台打压战略工具。对此，国际声援台湾声音不断。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260424-%E4%B8%AD%E5%85%B1%E5%B0%86%E6%B5%B7%E5%A4%96%E9%A2%86%E7%A9%BA%E6%AD%A6%E5%99%A8%E5%8C%96%E8%BF%9B%E4%B8%80%E6%AD%A5%E5%AD%A4%E7%AB%8B%E5%8F%B0%E6%B9%BE-%E7%BE%8E%E8%AE%AE%E5%91%98-%E5%AD%A6%E8%80%85%E5%92%8C33%E4%B8%AA%E6%B5%B7%E5%A4%96%E5%8F%B0%E6%B9%BE%E4%BA%BA%E5%9B%A2%E9%BD%90%E5%A3%B0%E8%B0%B4%E8%B4%A3%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777017598000.webp","sourceId":"rfi"},{"id":1777014421000,"createdDate":"2026-04-24 07:07","name":"法国国际广播电台","title":"菲律宾总统将作为国宾访问日本","content":"日本政府4月24日宣布，5月26日至29日，菲律宾总统马科斯二世及其夫人将作为国宾访问日本。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260424-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E6%80%BB%E7%BB%9F%E5%B0%86%E4%BD%9C%E4%B8%BA%E5%9B%BD%E5%AE%BE%E8%AE%BF%E9%97%AE%E6%97%A5%E6%9C%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777014421000.webp","sourceId":"rfi"},{"id":1777013849000,"createdDate":"2026-04-24 06:57","name":"法国国际广播电台","title":"港府「两手抓」反修例人士：重审脱暴动罪女学生 被捕者参与「特别更生」换不起诉及就业机会","content":"2019年的反修例运动至今已近七年，但有约七千名被捕但未被起诉者一直生活在头顶悬剑的生活中，保安局早前透露有向该等人士提供「特别更生」，参加者可能会确认获得撤销起诉，近日首次有曾参加者披露，曾参与艺人在中国内地工作经验分享后获撤控，之後继续获推介不同的内地交流及工作实习计划。而对於已审讯者，律政司继续锲而不舍地「追究」脱罪者，一名早前获判暴动罪脱的法律系女学生，在港府提出上诉後得直，案件需重审，暂定6月判决。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260424-%E6%B8%AF%E5%BA%9C-%E4%B8%A4%E6%89%8B%E6%8A%93-%E5%8F%8D%E4%BF%AE%E4%BE%8B%E4%BA%BA%E5%A3%AB-%E9%87%8D%E5%AE%A1%E8%84%B1%E6%9A%B4%E5%8A%A8%E7%BD%AA%E5%A5%B3%E5%AD%A6%E7%94%9F-%E8%A2%AB%E6%8D%95%E8%80%85%E5%8F%82%E4%B8%8E-%E7%89%B9%E5%88%AB%E6%9B%B4%E7%94%9F-%E6%8D%A2%E4%B8%8D%E8%B5%B7%E8%AF%89%E5%8F%8A%E5%B0%B1%E4%B8%9A%E6%9C%BA%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777013849000.webp","sourceId":"rfi"},{"id":1777013474000,"createdDate":"2026-04-24 06:51","name":"法国国际广播电台","title":"BBC报英女在港称被强奸「原告变被告」案 遭港府去信谴责不符事实","content":"一名25岁英国女子报称，两年前在香港遭同属英籍的银行家强奸，她在接受对方以金钱补偿後报案，却被香港警方反控勒索及妨碍司法公正。英国广播公司（BBC）就案件作详细报道后一天，遭港府去信谴责和反驳，指报道失实，企图削弱香港法律制度的公信力。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260424-bbc%E6%8A%A5%E8%8B%B1%E5%A5%B3%E5%9C%A8%E6%B8%AF%E7%A7%B0%E8%A2%AB%E5%BC%BA%E5%A5%B8-%E5%8E%9F%E5%91%8A%E5%8F%98%E8%A2%AB%E5%91%8A-%E6%A1%88-%E9%81%AD%E6%B8%AF%E5%BA%9C%E5%8E%BB%E4%BF%A1%E8%B0%B4%E8%B4%A3%E4%B8%8D%E7%AC%A6%E4%BA%8B%E5%AE%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/24/1777013474000.webp","sourceId":"rfi"}]