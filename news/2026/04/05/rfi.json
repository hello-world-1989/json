[{"id":1775377926000,"createdDate":"2026-04-05 08:32","name":"法国国际广播电台","title":"俄罗斯多地重要能源设施遭无人机袭击，炼油厂起火，出口港受损","content":"4月5日路透社消息，俄罗斯多地重要能源设施遭无人机袭击，出现火情与泄漏情况。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260405-%E4%BF%84%E7%BD%97%E6%96%AF%E5%A4%9A%E5%9C%B0%E9%87%8D%E8%A6%81%E8%83%BD%E6%BA%90%E8%AE%BE%E6%96%BD%E9%81%AD%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB%EF%BC%8C%E7%82%BC%E6%B2%B9%E5%8E%82%E8%B5%B7%E7%81%AB%EF%BC%8C%E5%87%BA%E5%8F%A3%E6%B8%AF%E5%8F%97%E6%8D%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775377926000.webp","sourceId":"rfi"},{"id":1775376480000,"createdDate":"2026-04-05 08:08","name":"法国国际广播电台","title":"失踪的美国战机机组人员在伊朗获救 特朗普：我们找到他了，现在平安无事","content":"多名美国官员向哥伦比亚广播公司（CBS）透露，一架F-15E战斗机在伊朗偏远地区被击落时失踪的一名美国机组人员，已于当地时间周日清晨被美军救出。该战机的飞行员早前于周五获救。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260405-%E5%A4%B1%E8%B8%AA%E7%9A%84%E7%BE%8E%E5%9B%BD%E6%88%98%E6%9C%BA%E6%9C%BA%E7%BB%84%E4%BA%BA%E5%91%98%E5%9C%A8%E4%BC%8A%E6%9C%97%E8%8E%B7%E6%95%91-%E7%89%B9%E6%9C%97%E6%99%AE-%E6%88%91%E4%BB%AC%E6%89%BE%E5%88%B0%E4%BB%96%E4%BA%86%EF%BC%8C%E7%8E%B0%E5%9C%A8%E5%B9%B3%E5%AE%89%E6%97%A0%E4%BA%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775376480000.webp","sourceId":"rfi"},{"id":1775401849000,"createdDate":"2026-04-05 15:10","name":"法国国际广播电台","title":"王毅与拉夫罗夫通电话：中东局势仍在恶化、战事还在升级","content":"自北京方面消息，中国外交部长王毅周日应约同俄罗斯外交部长拉夫罗夫通电话，就当前中东形势交换了意见。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260405-%E7%8E%8B%E6%AF%85%E4%B8%8E%E6%8B%89%E5%A4%AB%E7%BD%97%E5%A4%AB%E9%80%9A%E7%94%B5%E8%AF%9D-%E4%B8%AD%E4%B8%9C%E5%B1%80%E5%8A%BF%E4%BB%8D%E5%9C%A8%E6%81%B6%E5%8C%96-%E6%88%98%E4%BA%8B%E8%BF%98%E5%9C%A8%E5%8D%87%E7%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775401849000.webp","sourceId":"rfi"},{"id":1775400397000,"createdDate":"2026-04-05 14:46","name":"法国国际广播电台","title":"特朗普：伊朗政权年初镇压杀了4.5万平民，美国之后曾向抗议者送大量枪支","content":"美国总统特朗普（DonaldTrump）当地时间周日早上接受福克斯新闻频道记者采访时表示，如果伊朗当局不尽快达成协议，“我考虑把一切都炸掉，然后接管石油”，并警告称“你会看到他们全国各地的桥梁和发电厂倒塌”。特朗普称，“目前，代表伊朗进行谈判的人员已获得有限特赦，以便他们能够继续谈判”，并指其认为周一有希望能达成协议。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260405-%E7%89%B9%E6%9C%97%E6%99%AE-%E4%BC%8A%E6%9C%97%E6%94%BF%E6%9D%83%E5%B9%B4%E5%88%9D%E9%95%87%E5%8E%8B%E6%9D%80%E4%BA%864-5%E4%B8%87%E5%B9%B3%E6%B0%91%EF%BC%8C%E7%BE%8E%E5%9B%BD%E4%B9%8B%E5%90%8E%E6%9B%BE%E5%90%91%E6%8A%97%E8%AE%AE%E8%80%85%E9%80%81%E5%A4%A7%E9%87%8F%E6%9E%AA%E6%94%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775400397000.webp","sourceId":"rfi"},{"id":1775394329000,"createdDate":"2026-04-05 13:05","name":"法国国际广播电台","title":"特朗普：“赶紧打开他妈的海峡，周二将是电厂日和大桥日合二为一”","content":"美国总统特朗普（DonaldTrump）周日在其社媒平台“真相社交”上发文称，“周二在伊朗将是‘电厂日’和‘大桥日’，两者合二为一！绝对将是前所未有的！！！赶紧打开他妈的海峡，你们这些疯杂种们，否则就等着下地狱吧——等着瞧！赞美真主。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260405-%E7%89%B9%E6%9C%97%E6%99%AE-%E8%B5%B6%E7%B4%A7%E6%89%93%E5%BC%80%E4%BB%96%E5%A6%88%E7%9A%84%E6%B5%B7%E5%B3%A1%EF%BC%8C%E5%91%A8%E4%BA%8C%E5%B0%86%E6%98%AF%E7%94%B5%E5%8E%82%E6%97%A5%E5%92%8C%E5%A4%A7%E6%A1%A5%E6%97%A5%E5%90%88%E4%BA%8C%E4%B8%BA%E4%B8%80","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775394329000.webp","sourceId":"rfi"},{"id":1775392463000,"createdDate":"2026-04-05 12:34","name":"法国国际广播电台","title":"房山推土机撞人事件后 北京多区大集停摆","content":"据《明报》报导，北京房山3月29日发生推土机冲击露天市集事件后，各区多个“大集”停摆，不少摊主在社交平台发帖提醒民众“别跑空”。多名博主周六发片称，朝阳金盏大集暂停一个月升级改造；平谷靠山集大集昨天是最后一天，今天开始暂停；原定周日举行的通州张家湾大集将临时停业；平谷南独乐河大集2日起停业。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260405-%E6%88%BF%E5%B1%B1%E6%8E%A8%E5%9C%9F%E6%9C%BA%E6%92%9E%E4%BA%BA%E4%BA%8B%E4%BB%B6%E5%90%8E-%E5%8C%97%E4%BA%AC%E5%A4%9A%E5%8C%BA%E5%A4%A7%E9%9B%86%E5%81%9C%E6%91%86","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775392463000.webp","sourceId":"rfi"},{"id":1775389507000,"createdDate":"2026-04-05 11:45","name":"法国国际广播电台","title":"美商业供应商暂缓发布中东冲突地区卫星图像 美从太平洋地区调拨隐形巡航导弹打伊朗","content":"由于中东冲突持续，特朗普政府要求卫星图像供应商自愿停止提供指定区域的图像，这促使美国卫星影像供应商行星实验室（PlanetLabsPBC）限制了对该地区数据的访问。这家总部位于旧金山的商业卫星供应商周日表示，这些措施将追溯至3月9日，预计将持续到冲突结束。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260405-%E7%BE%8E%E5%95%86%E4%B8%9A%E4%BE%9B%E5%BA%94%E5%95%86%E6%9A%82%E7%BC%93%E5%8F%91%E5%B8%83%E4%B8%AD%E4%B8%9C%E5%86%B2%E7%AA%81%E5%9C%B0%E5%8C%BA%E5%8D%AB%E6%98%9F%E5%9B%BE%E5%83%8F-%E7%BE%8E%E4%BB%8E%E5%A4%AA%E5%B9%B3%E6%B4%8B%E5%9C%B0%E5%8C%BA%E8%B0%83%E6%8B%A8%E9%9A%90%E5%BD%A2%E5%B7%A1%E8%88%AA%E5%AF%BC%E5%BC%B9%E6%89%93%E4%BC%8A%E6%9C%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775389507000.webp","sourceId":"rfi"},{"id":1775386505000,"createdDate":"2026-04-05 10:55","name":"法国国际广播电台","title":"死不起的时代：当“骨灰房”成为一种现实选择","content":"一年一度的清明节前，中国在三月三十日起，开始正式实施在一月份公布的新《殡葬管理条例》。这是对1997年7月下旬开始实施的条例的全面修订。这次修订中引人注目的是针对一些城市的“骨灰房”进行了明文禁止。近年来各地大城市中骨灰房的出现，不再只是个别现象，而是逐渐成为舆论场中的高频词。在今天的微言微语种，就看看网友们的怎么说。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%BE%AE%E8%A8%80%E5%BE%AE%E8%AF%AD/20260405-%E6%AD%BB%E4%B8%8D%E8%B5%B7%E7%9A%84%E6%97%B6%E4%BB%A3-%E5%BD%93-%E9%AA%A8%E7%81%B0%E6%88%BF-%E6%88%90%E4%B8%BA%E4%B8%80%E7%A7%8D%E7%8E%B0%E5%AE%9E%E9%80%89%E6%8B%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775386505000.webp","sourceId":"rfi"},{"id":1775384548000,"createdDate":"2026-04-05 10:22","name":"法国国际广播电台","title":"东盟峰会看点 能源战略与缅甸关系","content":"当前中东危机给世界带来的能源紧张压力持续影响东南亚，所有国家民生状况与产业经济均受到不同程度影响。与此同时，菲律宾更改南海岛屿名称，外界恐加剧与中国的领土争议；缅甸军头化身民选总统后将如何重塑国际关系；柬埔寨当局承诺4月底实现电诈清零后转向强化柬美军事合作，这些都是东南亚媒体密切跟踪的热点话题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260405-%E4%B8%9C%E7%9B%9F%E5%B3%B0%E4%BC%9A%E7%9C%8B%E7%82%B9-%E8%83%BD%E6%BA%90%E6%88%98%E7%95%A5%E4%B8%8E%E7%BC%85%E7%94%B8%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775384548000.webp","sourceId":"rfi"},{"id":1775383981000,"createdDate":"2026-04-05 10:13","name":"法国国际广播电台","title":"蒋中正逝世51周年 台湾公民团体推动中正纪念堂转型彻底去蒋化","content":"台湾民团5日在中正纪念堂举办「台湾不需要独裁者纪念堂」活动，推动中正纪念堂转型。民团表示，蒋中正是全球公认的独裁者之一，如今仍在台北市中心接受众人膜拜，这是台湾民主最大的荒谬。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260405-%E8%92%8B%E4%B8%AD%E6%AD%A3%E9%80%9D%E4%B8%9651%E5%91%A8%E5%B9%B4-%E5%8F%B0%E6%B9%BE%E5%85%AC%E6%B0%91%E5%9B%A2%E4%BD%93%E6%8E%A8%E5%8A%A8%E4%B8%AD%E6%AD%A3%E7%BA%AA%E5%BF%B5%E5%A0%82%E8%BD%AC%E5%9E%8B%E5%BD%BB%E5%BA%95%E5%8E%BB%E8%92%8B%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775383981000.webp","sourceId":"rfi"},{"id":1775383825000,"createdDate":"2026-04-05 10:10","name":"法国国际广播电台","title":"高市拟出访越南澳洲 小泉5月初拟访菲律宾协调护卫舰、防空导弹出口事宜","content":"综合消息显示，日本首相高市早苗正考虑在4月下旬至5月初的黄金周假期期间访问越南，与越南总理及其他官员举行会谈。她还在协调访问澳大利亚的事宜，并计划通过这一系列外交活动，加强合作，共同构建“自由开放的印度-太平洋”倡议。日本放送协会（NHK）报导称，高市希望在安全保障、经济等广泛领域加强合作，预计将根据中东局势的最新发展来决定是否成行。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260405-%E9%AB%98%E5%B8%82%E6%8B%9F%E5%87%BA%E8%AE%BF%E8%B6%8A%E5%8D%97%E6%BE%B3%E6%B4%B2-%E5%B0%8F%E6%B3%895%E6%9C%88%E5%88%9D%E6%8B%9F%E8%AE%BF%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%8D%8F%E8%B0%83%E6%8A%A4%E5%8D%AB%E8%88%B0-%E9%98%B2%E7%A9%BA%E5%AF%BC%E5%BC%B9%E5%87%BA%E5%8F%A3%E4%BA%8B%E5%AE%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775383825000.webp","sourceId":"rfi"},{"id":1775382687000,"createdDate":"2026-04-05 09:51","name":"法国国际广播电台","title":"日本第二艘油轮通过霍尔木兹海峡 伊朗革命卫队前司令称日本可能实现通航","content":"受中东局势恶化的影响，在霍尔木兹海峡以西的波斯湾内，曾有45艘与日本相关的船舶受阻。而继商船三井的液化天然气（LNG）船4月3日首次通过霍尔木兹海峡后，又有第二艘与日本相关的船舶驶出湾外，而伊朗伊斯兰革命卫队前司令侯赛因·卡纳尼·马加迪姆在接受采访时表示，日本通过谈判有可能实现通航。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260405-%E6%97%A5%E6%9C%AC%E7%AC%AC%E4%BA%8C%E8%89%98%E6%B2%B9%E8%BD%AE%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E4%BC%8A%E6%9C%97%E9%9D%A9%E5%91%BD%E5%8D%AB%E9%98%9F%E5%89%8D%E5%8F%B8%E4%BB%A4%E7%A7%B0%E6%97%A5%E6%9C%AC%E5%8F%AF%E8%83%BD%E5%AE%9E%E7%8E%B0%E9%80%9A%E8%88%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775382687000.webp","sourceId":"rfi"},{"id":1775381531000,"createdDate":"2026-04-05 09:32","name":"法国国际广播电台","title":"泽连斯基警告：爱国者系统迫切不足，防空或因伊朗战争受影响","content":"本周末，围绕俄乌战争的外交、军事和安全领域动态持续推进。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260405-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E8%AD%A6%E5%91%8A-%E7%88%B1%E5%9B%BD%E8%80%85%E7%B3%BB%E7%BB%9F%E8%BF%AB%E5%88%87%E4%B8%8D%E8%B6%B3%EF%BC%8C%E9%98%B2%E7%A9%BA%E6%88%96%E5%9B%A0%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E5%8F%97%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775381531000.webp","sourceId":"rfi"},{"id":1775431998000,"createdDate":"2026-04-05 23:33","name":"法国国际广播电台","title":"北约再次面临美国退群威胁，特朗普能否单方面退出北约？","content":"欢迎收听国际纵横节目，我是阿曼亭，今天的主题是，特朗普领导的美国威胁要退出北约，北约再次面临美国退群的威胁。那么，这一威胁是否会变成现实：美国总统是否真的可以单方面退出北约？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%9B%BD%E9%99%85%E7%BA%B5%E6%A8%AA/20260405-%E5%8C%97%E7%BA%A6%E5%86%8D%E6%AC%A1%E9%9D%A2%E4%B8%B4%E7%BE%8E%E5%9B%BD%E9%80%80%E7%BE%A4%E5%A8%81%E8%83%81%EF%BC%8C%E7%89%B9%E6%9C%97%E6%99%AE%E8%83%BD%E5%90%A6%E5%8D%95%E6%96%B9%E9%9D%A2%E9%80%80%E5%87%BA%E5%8C%97%E7%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775431998000.webp","sourceId":"rfi"},{"id":1775424618000,"createdDate":"2026-04-05 21:30","name":"法国国际广播电台","title":"伊朗战争迈入第6周 油价飙涨对全球经济产生负面影响","content":"伊朗战争迈入第6周，中央社分析了油价飙涨对全球经济产生的具体负面影响：","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260405-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E8%BF%88%E5%85%A5%E7%AC%AC6%E5%91%A8-%E6%B2%B9%E4%BB%B7%E9%A3%99%E6%B6%A8%E5%AF%B9%E5%85%A8%E7%90%83%E7%BB%8F%E6%B5%8E%E4%BA%A7%E7%94%9F%E8%B4%9F%E9%9D%A2%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775424618000.webp","sourceId":"rfi"},{"id":1775423171000,"createdDate":"2026-04-05 21:06","name":"法国国际广播电台","title":"“最后通牒”又被延后","content":"周日，美国总统特朗普在其“真相社交”（TruthSocial）平台上发布简短消息，宣布将对伊朗的最后通牒再次推迟24小时，现定于华盛顿时间“周二晚上8点”（格林尼治标准时间周三午夜）。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260405-%E6%9C%80%E5%90%8E%E9%80%9A%E7%89%92-%E5%8F%88%E8%A2%AB%E5%BB%B6%E5%90%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775423171000.webp","sourceId":"rfi"},{"id":1775422968000,"createdDate":"2026-04-05 21:02","name":"法国国际广播电台","title":"拉夫罗夫：不要把“最后通牒”挂在嘴边","content":"俄罗斯外长谢尔盖·拉夫罗夫周日与伊朗外长阿巴斯·阿拉格奇通电话时表示，他希望美国“放弃最后通牒的言辞”，以促成“重返谈判桌”。“俄方表示希望一些国家为缓和伊朗局势紧张所做的努力能够取得成功。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260405-%E6%8B%89%E5%A4%AB%E7%BD%97%E5%A4%AB-%E4%B8%8D%E8%A6%81%E6%8A%8A-%E6%9C%80%E5%90%8E%E9%80%9A%E7%89%92-%E6%8C%82%E5%9C%A8%E5%98%B4%E8%BE%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775422968000.webp","sourceId":"rfi"},{"id":1775422377000,"createdDate":"2026-04-05 20:52","name":"法国国际广播电台","title":"教宗主持复活弥撒  呼吁选择和平","content":"在梵蒂冈，阳光灿烂的圣伯多禄广场上，鲜花簇拥，良十四世自2025年5月当选教宗以来首次主持复活节弥撒。弥撒气氛喜庆，号角齐鸣，圣歌吟唱。在传统的“致罗马城及全世界”（UrbietOrbi）祝福中，教宗呼吁“那些有权发动战争的人选择和平”。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260405-%E6%95%99%E5%AE%97%E4%B8%BB%E6%8C%81%E5%A4%8D%E6%B4%BB%E5%BC%A5%E6%92%92-%E5%91%BC%E5%90%81%E9%80%89%E6%8B%A9%E5%92%8C%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775422377000.webp","sourceId":"rfi"},{"id":1775422232000,"createdDate":"2026-04-05 20:50","name":"法国国际广播电台","title":"伊一枚导弹击中以色列北部一层住宅楼","content":"以色列军方和救援部门宣布，周日，一枚伊朗导弹直接击中了位于以色列北部海法（Haïfa）的一栋七层住宅楼，造成至少四人受伤，其中一人伤势严重。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260405-%E4%BC%8A%E4%B8%80%E6%9E%9A%E5%AF%BC%E5%BC%B9%E5%87%BB%E4%B8%AD%E4%BB%A5%E8%89%B2%E5%88%97%E5%8C%97%E9%83%A8%E4%B8%80%E5%B1%82%E4%BD%8F%E5%AE%85%E6%A5%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775422232000.webp","sourceId":"rfi"},{"id":1775421921000,"createdDate":"2026-04-05 20:45","name":"法国国际广播电台","title":"美反对派对特朗普爆粗口极大不满","content":"特朗普在复活节期间发布侮辱伊朗的信息。他周日在真相社交上发文称：“赶紧打开XXX海峡”...，特朗普公开爆粗口的做法引发反对党派人士的强烈不满。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260405-%E7%BE%8E%E5%8F%8D%E5%AF%B9%E6%B4%BE%E5%AF%B9%E7%89%B9%E6%9C%97%E6%99%AE%E7%88%86%E7%B2%97%E5%8F%A3%E6%9E%81%E5%A4%A7%E4%B8%8D%E6%BB%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775421921000.webp","sourceId":"rfi"},{"id":1775421647000,"createdDate":"2026-04-05 20:40","name":"法国国际广播电台","title":"欧佩克：修复能源设施“成本高昂”且“耗时漫长”","content":"沙特阿拉伯、俄罗斯和其它六个欧佩克+成员国周日决定再次提高石油产量配额，并警告称，修复中东战争造成的能源基础设施“成本高昂”，而且“耗时漫长”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260405-%E6%AC%A7%E4%BD%A9%E5%85%8B-%E4%BF%AE%E5%A4%8D%E8%83%BD%E6%BA%90%E8%AE%BE%E6%96%BD-%E6%88%90%E6%9C%AC%E9%AB%98%E6%98%82-%E4%B8%94-%E8%80%97%E6%97%B6%E6%BC%AB%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775421647000.webp","sourceId":"rfi"},{"id":1775421434000,"createdDate":"2026-04-05 20:37","name":"法国国际广播电台","title":"比警方寻查在云南失踪的雨果 （Hugo Huyghebaert）","content":"4月3日，比利时联邦警察发布寻人启事，寻找一名在中国失踪的比利时公民。他已经失踪10天了。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260405-%E6%AF%94%E8%AD%A6%E6%96%B9%E5%AF%BB%E6%9F%A5%E5%9C%A8%E4%BA%91%E5%8D%97%E5%A4%B1%E8%B8%AA%E7%9A%84%E9%9B%A8%E6%9E%9C-hugo-huyghebaert","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775421434000.webp","sourceId":"rfi"},{"id":1775421345000,"createdDate":"2026-04-05 20:35","name":"法国国际广播电台","title":"专家描绘最坏情景:“台湾海峡也可能决定德国的未来”","content":"如果中国对台湾动武，会发生什么？据慕尼黑《墨丘利报》报道：政治学家安德烈亚斯·富尔达（AndreasFulda）表示：台湾会迅速失守。但“如果台湾真的沦陷，这不仅对台湾人民来说是一场灾难，也将改变整个世界。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260405-%E4%B8%93%E5%AE%B6%E6%8F%8F%E7%BB%98%E6%9C%80%E5%9D%8F%E6%83%85%E6%99%AF-%E5%8F%B0%E6%B9%BE%E6%B5%B7%E5%B3%A1%E4%B9%9F%E5%8F%AF%E8%83%BD%E5%86%B3%E5%AE%9A%E5%BE%B7%E5%9B%BD%E7%9A%84%E6%9C%AA%E6%9D%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775421345000.webp","sourceId":"rfi"},{"id":1775421215000,"createdDate":"2026-04-05 20:33","name":"法国国际广播电台","title":"红十字会：蓄意攻击民用基础设施可构成战争罪","content":"法国《世界报》一名读者（Dolfina）提问：“蓄意破坏民用基础设施（例如发电厂）是否构成战争罪？如果构成战争罪，执行此类命令的高级军官是否会像特朗普本人一样，被国际刑事法院起诉？”红十字国际委员会主席对此给予了肯定的回答。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260405-%E7%BA%A2%E5%8D%81%E5%AD%97%E4%BC%9A-%E8%93%84%E6%84%8F%E6%94%BB%E5%87%BB%E6%B0%91%E7%94%A8%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD%E5%8F%AF%E6%9E%84%E6%88%90%E6%88%98%E4%BA%89%E7%BD%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775421215000.webp","sourceId":"rfi"},{"id":1775420754000,"createdDate":"2026-04-05 20:25","name":"法国国际广播电台","title":"开放霍尔木兹海峡：特朗普以粗话施压 底气何来？","content":"在美军救出第二位身陷危境的机组人员奇迹后，美国总统特朗普5日以罕见以粗话再次施压伊朗：必须立即开放霍尔木兹海峡，否则美军本月7日将大举打击伊朗发电厂及桥梁等关键基础设施。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260405-%E5%BC%80%E6%94%BE%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E7%89%B9%E6%9C%97%E6%99%AE%E6%9C%89%E4%BF%A1%E5%BF%83%E4%BD%86%E4%BB%8D%E4%BB%A5%E7%B2%97%E8%AF%9D%E6%96%BD%E5%8E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775420754000.webp","sourceId":"rfi"},{"id":1775413989000,"createdDate":"2026-04-05 18:33","name":"法国国际广播电台","title":"佩洛西：特朗普无权单方面退北约","content":"美国前众议院议长佩洛西（NancyPelosi）近日强烈批评美国总统特朗普（DonaldTrump）多次威胁退出北大西洋公约组织（NATO），直言相关言论“目光短浅”，并警告这样的说法形同“送给俄罗斯总统普京（VladimirPutin）的一份礼物”。她同时强调，美国法律已明确规定，总统无权在未经国会批准下单方面退出北约，使得特朗普的相关表态在制度上难以实现。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260405-%E4%BD%A9%E6%B4%9B%E8%A5%BF-%E7%89%B9%E6%9C%97%E6%99%AE%E6%97%A0%E6%9D%83%E5%8D%95%E6%96%B9%E9%9D%A2%E9%80%80%E5%8C%97%E7%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/05/1775413989000.webp","sourceId":"rfi"}]