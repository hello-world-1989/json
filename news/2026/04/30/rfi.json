[{"id":1777540582000,"createdDate":"2026-04-30 09:16","name":"法国国际广播电台","title":"日本首相与外务省就前往日本的油轮通过霍尔木兹海峡发表谈话","content":"29日，在伊朗与美国围绕结束战斗进行的谈判陷入停滞之际，日本相关船舶通过了事实上已被封锁的霍尔木兹海峡，成为霍尔木兹海峡被封锁以来，有日本船员搭乘、由日本企业管理的船舶首次通过该海峡直接前往日本。为此，日本首相高市早苗与日本外务省发表谈话，表示日本将为确保包括其余日本相关船舶在内的所有国家船舶，都能够自由且安全地通过霍尔木兹海峡继续向伊朗方面做工作。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260430-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E4%B8%8E%E5%A4%96%E5%8A%A1%E7%9C%81%E5%B0%B1%E5%89%8D%E5%BE%80%E6%97%A5%E6%9C%AC%E7%9A%84%E6%B2%B9%E8%BD%AE%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%8F%91%E8%A1%A8%E8%B0%88%E8%AF%9D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777540582000.webp","sourceId":"rfi"},{"id":1777536220000,"createdDate":"2026-04-30 08:03","name":"法国国际广播电台","title":"全球新闻自由25年来最差 中港排「黑榜」名次不变 但得分均下降","content":"在全球新闻自由恶化以至无国界记者组织的自由指数首次出现过半国家的新闻自由程度落入「状况艰难」或「状况恶劣」类别之际，香港和中国的最新排名均分别维持在140位和178位，但得分均告轻微下跌；而两岸三地中的台湾，虽下跌四位至全球排第28名，仍能蝉联亚洲第一。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260430-%E5%85%A8%E7%90%83%E6%96%B0%E9%97%BB%E8%87%AA%E7%94%B125%E5%B9%B4%E6%9D%A5%E6%9C%80%E5%B7%AE-%E4%B8%AD%E6%B8%AF%E6%8E%92-%E9%BB%91%E6%A6%9C-%E5%90%8D%E6%AC%A1%E4%B8%8D%E5%8F%98-%E4%BD%86%E5%BE%97%E5%88%86%E5%9D%87%E4%B8%8B%E9%99%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777536220000.webp","sourceId":"rfi"},{"id":1777535764000,"createdDate":"2026-04-30 07:56","name":"法国国际广播电台","title":"港国安法致工会碎片化 近三成工会人数仅「个位」 工人受压诉无门","content":"一份报告显示，香港实施国安法五年来，香港工会数目虽有增加，但实情是工会被迫解散後大幅缩少会员人数「个位化」所致，以致工会总人数已大幅减少一成七。在工会碎片化的情况下，劳工权利大受压榨，以致工资增长放缓丶高失业率行业仍获批输入外劳等问题持续。团体认为，在法律压力下，政权对工会的控制已达窒息程度，劳工权利面对「结构性崩坏」，预计维权人士须继续在恐惧和受滋扰的情况下争取劳工权利。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260430-%E6%B8%AF%E5%9B%BD%E5%AE%89%E6%B3%95%E8%87%B4%E5%B7%A5%E4%BC%9A%E7%A2%8E%E7%89%87%E5%8C%96-%E8%BF%91%E4%B8%89%E6%88%90%E5%B7%A5%E4%BC%9A%E4%BA%BA%E6%95%B0%E4%BB%85-%E4%B8%AA%E4%BD%8D-%E5%B7%A5%E4%BA%BA%E5%8F%97%E5%8E%8B%E8%AF%89%E6%97%A0%E9%97%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777535764000.webp","sourceId":"rfi"},{"id":1777564866000,"createdDate":"2026-04-30 16:01","name":"法国国际广播电台","title":"伦敦两名犹太人遭持刀袭击 英国首相斯塔默谴责伊朗","content":"两名犹太男子周三在伦敦北部遭遇持刀袭击受伤。英国首相斯塔默周四指责伊朗“意图伤害英国犹太人”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260430-%E4%BC%A6%E6%95%A6%E4%B8%A4%E5%90%8D%E7%8A%B9%E5%A4%AA%E4%BA%BA%E9%81%AD%E6%8C%81%E5%88%80%E8%A2%AD%E5%87%BB-%E8%8B%B1%E5%9B%BD%E9%A6%96%E7%9B%B8%E6%96%AF%E5%A1%94%E9%BB%98%E8%B0%B4%E8%B4%A3%E4%BC%8A%E6%9C%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777564866000.webp","sourceId":"rfi"},{"id":1777563383000,"createdDate":"2026-04-30 15:36","name":"法国国际广播电台","title":"特朗普准备长期封锁 伊朗最高层都表态了","content":"伊朗国家电视台周四转播了最高领袖小哈梅内伊回击特朗普威胁要长期封锁称，美国遭受了“可耻的失败”；伊朗总统则说美国的封锁“注定失败”；革命卫队前司令则威胁予以反击；议会主席针对美国加剧分裂毛拉政权的意图呼吁“团结”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260430-%E7%89%B9%E6%9C%97%E6%99%AE%E5%87%86%E5%A4%87%E9%95%BF%E6%9C%9F%E5%B0%81%E9%94%81-%E4%BC%8A%E6%9C%97%E6%9C%80%E9%AB%98%E5%B1%82%E9%83%BD%E8%A1%A8%E6%80%81%E4%BA%86","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777563383000.webp","sourceId":"rfi"},{"id":1777560635000,"createdDate":"2026-04-30 14:50","name":"法国国际广播电台","title":"迪拜警方与中美合作逮捕国际金融诈骗团伙276人","content":"法新社4月29日迪拜消息，迪拜警方宣布，在与美国联邦调查局（FBI）和中国警方合作开展的一项行动中，逮捕了276名涉嫌参与国际金融诈骗犯罪网络成员，其中大多数来自东南亚国家。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260430-%E8%BF%AA%E6%8B%9C%E8%AD%A6%E6%96%B9%E4%B8%8E%E4%B8%AD%E7%BE%8E%E5%90%88%E4%BD%9C%E9%80%AE%E6%8D%95%E5%9B%BD%E9%99%85%E9%87%91%E8%9E%8D%E8%AF%88%E9%AA%97%E5%9B%A2%E4%BC%99276%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777560635000.webp","sourceId":"rfi"},{"id":1777554731000,"createdDate":"2026-04-30 13:12","name":"法国国际广播电台","title":"朝鲜面临严重旱灾","content":"朝中社周四的报道证实，朝鲜今年正面临异常严重干旱，并希望保护农作物。法新社指出，鉴于朝鲜基础设施和经济较为脆弱，自然灾害会对这个外交孤立的国家造成的影响更为严重。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260430-%E6%9C%9D%E9%B2%9C%E9%9D%A2%E4%B8%B4%E4%B8%A5%E9%87%8D%E6%97%B1%E7%81%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777554731000.webp","sourceId":"rfi"},{"id":1777554677000,"createdDate":"2026-04-30 13:11","name":"法国国际广播电台","title":"霍尔木兹海峡：华盛顿组建国际保安联盟 共享情报协调行动","content":"美国政府要求其驻外使馆游说盟友加入负责保障霍尔木兹海峡安全的国际联盟。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260430-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E5%8D%8E%E7%9B%9B%E9%A1%BF%E7%BB%84%E5%BB%BA%E5%9B%BD%E9%99%85%E4%BF%9D%E5%AE%89%E8%81%94%E7%9B%9F-%E5%85%B1%E4%BA%AB%E6%83%85%E6%8A%A5%E5%8D%8F%E8%B0%83%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777554677000.webp","sourceId":"rfi"},{"id":1777554047000,"createdDate":"2026-04-30 13:00","name":"法国国际广播电台","title":"中东海湾战争: 欧洲开始通胀付出经济代价","content":"2026年第一季度欧元区经济增长率降至0.1%，德国的表现优于法国，法国经济增长率为零，通胀率突破3%。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260430-%E4%B8%AD%E4%B8%9C%E6%B5%B7%E6%B9%BE%E6%88%98%E4%BA%89-%E6%AC%A7%E6%B4%B2%E5%BC%80%E5%A7%8B%E9%80%9A%E8%83%80%E4%BB%98%E5%87%BA%E7%BB%8F%E6%B5%8E%E4%BB%A3%E4%BB%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777554047000.webp","sourceId":"rfi"},{"id":1777553152000,"createdDate":"2026-04-30 12:45","name":"法国国际广播电台","title":"特朗普周四或听取对伊朗新军事选项包括“短而猛”打击计划","content":"据两位知情人士向Axios透露，特朗普总统将于周四听取中央司令部司令库珀海军上将关于对伊朗采取潜在军事行动的新计划简报。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260430-%E7%89%B9%E6%9C%97%E6%99%AE%E5%91%A8%E5%9B%9B%E6%88%96%E5%90%AC%E5%8F%96%E5%AF%B9%E4%BC%8A%E6%9C%97%E6%96%B0%E5%86%9B%E4%BA%8B%E9%80%89%E9%A1%B9%E5%8C%85%E6%8B%AC-%E7%9F%AD%E8%80%8C%E7%8C%9B-%E6%89%93%E5%87%BB%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777553152000.webp","sourceId":"rfi"},{"id":1777550086000,"createdDate":"2026-04-30 11:54","name":"法国国际广播电台","title":"美国总统提及长期封锁伊朗港口 国际油价飙升 股市下挫 美元走强","content":"美国周三提及可能对伊朗港口实施“数月”的长期封锁，法新社30日发自东京说，这将使全球经济承受更长时间的压力，并对油价产生立竿见影的影响，油价已飙升至四年来的最高水平。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260430-%E7%BE%8E%E5%9B%BD%E6%80%BB%E7%BB%9F%E6%8F%90%E5%8F%8A%E9%95%BF%E6%9C%9F%E5%B0%81%E9%94%81%E4%BC%8A%E6%9C%97%E6%B8%AF%E5%8F%A3-%E5%9B%BD%E9%99%85%E6%B2%B9%E4%BB%B7%E9%A3%99%E5%8D%87-%E8%82%A1%E5%B8%82%E4%B8%8B%E6%8C%AB-%E7%BE%8E%E5%85%83%E8%B5%B0%E5%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777550086000.webp","sourceId":"rfi"},{"id":1777548526000,"createdDate":"2026-04-30 11:28","name":"法国国际广播电台","title":"马里：法国政府建议其在该国侨民“尽快”暂时撤离","content":"各位听众，根据法国外交部4月29日发布的最新指示，法国建议在马里的法国公民“尽快搭乘剩余的商业航班暂时离开马里”。主因是该国上周末发生圣战分子与图阿雷格（Tuareg）分离主义分子的袭击事件；马里国防部长卡马拉（SadioCamara）已经于26日遇害。与此同时，阿扎瓦德解放阵线（FLA）已呼吁俄罗斯非洲军团撤离该国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E9%9D%9E%E6%B4%B2/20260430-%E9%A9%AC%E9%87%8C-%E6%B3%95%E5%9B%BD%E6%94%BF%E5%BA%9C%E5%BB%BA%E8%AE%AE%E5%85%B6%E5%9C%A8%E8%AF%A5%E5%9B%BD%E4%BE%A8%E6%B0%91-%E5%B0%BD%E5%BF%AB-%E6%9A%82%E6%97%B6%E6%92%A4%E7%A6%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777548526000.webp","sourceId":"rfi"},{"id":1777545847000,"createdDate":"2026-04-30 10:44","name":"法国国际广播电台","title":"台湾民调显示两成二民众接受台湾成为下一个香港的一国两制和平统一方案","content":"-台湾《美丽岛电子报》民调日前发布，有22.4%民众能接受中共的一国两制和平统一方案。台湾政评家表示，两岸统独议题在今年县市长选举可能更具影响力。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260430-%E5%8F%B0%E6%B9%BE%E6%B0%91%E8%B0%83%E6%98%BE%E7%A4%BA%E4%B8%A4%E6%88%90%E4%BA%8C%E6%B0%91%E4%BC%97%E6%8E%A5%E5%8F%97%E5%8F%B0%E6%B9%BE%E6%88%90%E4%B8%BA%E4%B8%8B%E4%B8%80%E4%B8%AA%E9%A6%99%E6%B8%AF%E7%9A%84%E4%B8%80%E5%9B%BD%E4%B8%A4%E5%88%B6%E5%92%8C%E5%B9%B3%E7%BB%9F%E4%B8%80%E6%96%B9%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777545847000.webp","sourceId":"rfi"},{"id":1777541520000,"createdDate":"2026-04-30 09:32","name":"法国国际广播电台","title":"高油价与我们、法国五一劳动节今年变成“绕法节”了！","content":"普京与特朗普周三通电话讨论停火，美国提及了长期封锁伊朗港口的可能性，导致油价飙升至历史新高。布伦特原油价格现升破每桶125美元，创下自乌战爆发四年来的最高水平。高油价问题再度成为周四4月30日出版的法国主要全国性日报头版关注焦点。此外在五一劳动节前夕，各报也纷纷推出相关报道，例如《解放报》对此指出，对法国政府而言，五一节现在成了“绕法节”了！","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260430-%E9%AB%98%E6%B2%B9%E4%BB%B7%E4%B8%8E%E6%88%91%E4%BB%AC-%E6%B3%95%E5%9B%BD%E4%BA%94%E4%B8%80%E5%8A%B3%E5%8A%A8%E8%8A%82%E4%BB%8A%E5%B9%B4%E5%8F%98%E6%88%90-%E7%BB%95%E6%B3%95%E8%8A%82-%E4%BA%86","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777541520000.webp","sourceId":"rfi"},{"id":1777539377000,"createdDate":"2026-04-30 08:56","name":"法国国际广播电台","title":"记者无疆界：全球新闻自由状况降至25年来最低","content":"“记者无疆界”组织（RSF）周四（4月30日）公布2026年世界新闻自由排名，警告全球新闻自由已降至25年来的最低点，首次出现超过半数国家落入“状况艰难”或“状况恶劣”类别。中国连续第二年排名倒数第三。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260430-%E8%AE%B0%E8%80%85%E6%97%A0%E7%96%86%E7%95%8C-%E5%85%A8%E7%90%83%E6%96%B0%E9%97%BB%E8%87%AA%E7%94%B1%E7%8A%B6%E5%86%B5%E9%99%8D%E8%87%B325%E5%B9%B4%E6%9D%A5%E6%9C%80%E4%BD%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/30/1777539377000.webp","sourceId":"rfi"}]