[{"id":1777451421000,"createdDate":"2026-04-29 08:30","name":"法国国际广播电台","title":"新西兰在日本压力下放弃建日本“慰安妇”雕像计划","content":"新西兰官方周三（4月29日）正式否决了一项纪念二战前及战争期间日本“慰安妇”雕像的建设计划，此前东京方面曾表示，该项目可能损害两国外交关系。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260429-%E6%96%B0%E8%A5%BF%E5%85%B0%E5%9C%A8%E6%97%A5%E6%9C%AC%E5%8E%8B%E5%8A%9B%E4%B8%8B%E6%94%BE%E5%BC%83%E5%BB%BA%E6%97%A5%E6%9C%AC-%E6%85%B0%E5%AE%89%E5%A6%87-%E9%9B%95%E5%83%8F%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777451421000.webp","sourceId":"rfi"},{"id":1777450701000,"createdDate":"2026-04-29 08:18","name":"法国国际广播电台","title":"日本相关油轮首次通过霍尔木兹海峡前往日本","content":"在伊朗与美国围绕结束战斗进行的谈判陷入停滞之际，伊朗媒体报道称，日本相关船舶通过了事实上已被封锁的霍尔木兹海峡。这将成为霍尔木兹海峡事实上被封锁以来，日本企业管理的船舶首次通过该海峡直接前往日本。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260429-%E6%97%A5%E6%9C%AC%E7%9B%B8%E5%85%B3%E6%B2%B9%E8%BD%AE%E9%A6%96%E6%AC%A1%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%89%8D%E5%BE%80%E6%97%A5%E6%9C%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777450701000.webp","sourceId":"rfi"},{"id":1777445795000,"createdDate":"2026-04-29 06:56","name":"法国国际广播电台","title":"粤「十五五」首提对接香港北都 评论指將以粤为主 难重视保港国际化","content":"实施社会主义的中国广东省，昨(28日)午正式发布《广东省国民经济和社会发展第十五个五年规划纲要》(下称「十五五」规划纲要)，重点之一是建设粤港澳大湾区，内容除大量增加涉港合作之外，还首次提出积极对接实施资本主义的香港北部都会区(北都)发展策略。中国时事评论员刘锐绍向本台表示，广东省只是明确指出香港北都的发展须「以今我为主」的政策思维，即香港须为中国服务，至於香港国际化地位会否被削以至如何利用香港推动中国现代化，明显不被重视。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260429-%E7%B2%A4-%E5%8D%81%E4%BA%94%E4%BA%94-%E9%A6%96%E6%8F%90%E5%AF%B9%E6%8E%A5%E9%A6%99%E6%B8%AF%E5%8C%97%E9%83%BD-%E8%AF%84%E8%AE%BA%E6%8C%87%E5%B0%87%E4%BB%A5%E7%B2%A4%E4%B8%BA%E4%B8%BB-%E9%9A%BE%E9%87%8D%E8%A7%86%E4%BF%9D%E6%B8%AF%E5%9B%BD%E9%99%85%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777445795000.webp","sourceId":"rfi"},{"id":1777479523000,"createdDate":"2026-04-29 16:18","name":"法国国际广播电台","title":"韩国前总统尹锡悦妨碍司法案上诉加刑至七年","content":"韩国前总统尹锡悦周三因妨碍司法拘留被上诉法院判处七年监禁，而一审判决为五年。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260429-%E9%9F%A9%E5%9B%BD%E5%89%8D%E6%80%BB%E7%BB%9F%E5%B0%B9%E9%94%A1%E6%82%A6%E5%A6%A8%E7%A2%8D%E5%8F%B8%E6%B3%95%E6%A1%88%E4%B8%8A%E8%AF%89%E5%8A%A0%E5%88%91%E8%87%B3%E4%B8%83%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777479523000.webp","sourceId":"rfi"},{"id":1777476396000,"createdDate":"2026-04-29 15:26","name":"法国国际广播电台","title":"中国暂停油品出口 澳大利亚外长访华谈能源供应","content":"法新社北京29日电：澳大利亚外长黄英贤周三在访问北京期间与中方官员会面，谈及能源供应问题和霍尔木兹海峡封锁带来的影响。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260429-%E4%B8%AD%E5%9B%BD%E6%9A%82%E5%81%9C%E6%B2%B9%E5%93%81%E5%87%BA%E5%8F%A3-%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E5%A4%96%E9%95%BF%E8%AE%BF%E5%8D%8E%E8%B0%88%E8%83%BD%E6%BA%90%E4%BE%9B%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777476396000.webp","sourceId":"rfi"},{"id":1777474355000,"createdDate":"2026-04-29 14:52","name":"法国国际广播电台","title":"阿联酋为何突然退出石油输出国组织？影响几何？","content":"重要的石油输出航道霍尔木兹海峡通航依然受阻以及美伊两国的停战谈判也还在原地踏步，导致国际能源市场价格面对新一波反弹上升压力之际，海湾地区重要产油国阿拉伯联合酋长国28日突然宣布将自5月1日起退出石油输出国组织及其扩大版。这项退出决定几乎是立即生效。阿联酋为何要退出这个它加入近六十年的组织？有分析认为阿联酋的退出将是石油输出国组织组织的一次重要转折。那么阿联酋退出又会对当前市场产生怎样的影响？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260429-%E9%98%BF%E8%81%94%E9%85%8B%E4%B8%BA%E4%BD%95%E7%AA%81%E7%84%B6%E9%80%80%E5%87%BA%E7%9F%B3%E6%B2%B9%E8%BE%93%E5%87%BA%E5%9B%BD%E7%BB%84%E7%BB%87-%E5%BD%B1%E5%93%8D%E5%87%A0%E4%BD%95","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777474355000.webp","sourceId":"rfi"},{"id":1777472886000,"createdDate":"2026-04-29 14:28","name":"法国国际广播电台","title":"联合国称中东战争爆发以来伊朗已处决21人逮捕4000人","content":"联合国人权事务高专办周三宣布，自中东冲突爆发以来，伊朗已有21人因政治或国家安全相关原因被处决，另有4000多人被捕。","newsLink":"https://www.rfi.fr/cn/%E4%BA%BA%E6%9D%83/20260429-%E8%81%94%E5%90%88%E5%9B%BD%E7%A7%B0%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E7%88%86%E5%8F%91%E4%BB%A5%E6%9D%A5%E4%BC%8A%E6%9C%97%E5%B7%B2%E5%A4%84%E5%86%B321%E4%BA%BA%E9%80%AE%E6%8D%954000%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777472886000.webp","sourceId":"rfi"},{"id":1777471195000,"createdDate":"2026-04-29 13:59","name":"法国国际广播电台","title":"特朗普抨击德国总理在伊朗问题上贬损美国的言论","content":"美国总统特朗普周二在其社交媒体平台“真相社交”（TruthSocial）上猛烈抨击德国总理弗里德里希·默茨，指责默茨在伊朗问题上“全不知自己在说什么”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260429-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8A%A8%E5%87%BB%E5%BE%B7%E5%9B%BD%E6%80%BB%E7%90%86%E5%9C%A8%E4%BC%8A%E6%9C%97%E9%97%AE%E9%A2%98%E4%B8%8A%E8%B4%AC%E6%8D%9F%E7%BE%8E%E5%9B%BD%E7%9A%84%E8%A8%80%E8%AE%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777471195000.webp","sourceId":"rfi"},{"id":1777469886000,"createdDate":"2026-04-29 13:38","name":"法国国际广播电台","title":"伦敦发生持刀袭击事件 两人受伤 嫌犯被捕","content":"伦敦戈尔德斯格林区今天周三发生一起持刀袭击事件，造成两人受伤。戈尔德斯格林区是犹太人聚居地区，两家英国犹太组织表示，一名嫌犯已被逮捕。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260429-%E4%BC%A6%E6%95%A6%E5%8F%91%E7%94%9F%E6%8C%81%E5%88%80%E8%A2%AD%E5%87%BB%E4%BA%8B%E4%BB%B6-%E4%B8%A4%E4%BA%BA%E5%8F%97%E4%BC%A4-%E5%AB%8C%E7%8A%AF%E8%A2%AB%E6%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777469886000.webp","sourceId":"rfi"},{"id":1777467219000,"createdDate":"2026-04-29 12:53","name":"法国国际广播电台","title":"在尘土之下：墨西哥13万失踪者与无尽的寻亲之路","content":"在墨西哥，失踪人口持续攀升。过去十年间，这一数字增长超过200%，目前已有超过13万人被登记为失踪或“被消失”。在有组织犯罪不断扩张、执法体系乏力的背景下，越来越多家属被迫亲自行动，在缺乏安全保障的情况下寻找失踪亲人。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260429-%E5%9C%A8%E5%B0%98%E5%9C%9F%E4%B9%8B%E4%B8%8B-%E5%A2%A8%E8%A5%BF%E5%93%A513%E4%B8%87%E5%A4%B1%E8%B8%AA%E8%80%85%E4%B8%8E%E6%97%A0%E5%B0%BD%E7%9A%84%E5%AF%BB%E4%BA%B2%E4%B9%8B%E8%B7%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777467219000.webp","sourceId":"rfi"},{"id":1777464669000,"createdDate":"2026-04-29 12:11","name":"法国国际广播电台","title":"美国联手五个拉美盟友支持巴拿马，反对中国在巴拿马运河的作为","content":"美国牵头与五个拉美地区盟友于29日发表联合声明，针对巴拿马与中国围绕巴拿马运河港口运营权的争议，向巴拿马政府表达支持，认为中国的所作所为对所有联署国家都构成威胁。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260429-%E7%BE%8E%E5%9B%BD%E8%81%94%E6%89%8B%E4%BA%94%E4%B8%AA%E6%8B%89%E7%BE%8E%E7%9B%9F%E5%8F%8B%E6%94%AF%E6%8C%81%E5%B7%B4%E6%8B%BF%E9%A9%AC%EF%BC%8C%E5%8F%8D%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%9C%A8%E5%B7%B4%E6%8B%BF%E9%A9%AC%E8%BF%90%E6%B2%B3%E7%9A%84%E4%BD%9C%E4%B8%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777464669000.webp","sourceId":"rfi"},{"id":1777464548000,"createdDate":"2026-04-29 12:09","name":"法国国际广播电台","title":"美国战争部长海格塞斯遭六项弹劾无果后 将首次向国会解释伊朗战争","content":"周三，皮特-海格塞斯在伊朗战争爆发（含停火时间）60天后，将首次在国会就伊朗战争的指挥问题作出说明。法新社预计关于战争平民伤亡、美国对德黑兰报复行动的准备，及五角大楼战略逻辑等问题将成为质询的主要焦点。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260429-%E7%BE%8E%E5%9B%BD%E6%88%98%E4%BA%89%E9%83%A8%E9%95%BF%E6%B5%B7%E6%A0%BC%E5%A1%9E%E6%96%AF%E9%81%AD%E5%85%AD%E6%AC%A1%E5%BC%B9%E5%8A%BE%E6%97%A0%E6%9E%9C%E5%90%8E-%E5%B0%86%E9%A6%96%E6%AC%A1%E5%90%91%E5%9B%BD%E4%BC%9A%E8%A7%A3%E9%87%8A%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777464548000.webp","sourceId":"rfi"},{"id":1777462895000,"createdDate":"2026-04-29 11:41","name":"法国国际广播电台","title":"特朗普警告伊朗人“最好赶紧放聪明点！”","content":"周三，美国总统唐纳德·特朗普在其社交媒体平台“真相社交”（Truth）上发出警告称，伊朗人“最好赶紧放聪明点！”此刻华盛顿与德黑兰之间的谈判陷入完全僵局已经数日。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260429-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AD%A6%E5%91%8A%E4%BC%8A%E6%9C%97%E4%BA%BA-%E6%9C%80%E5%A5%BD%E8%B5%B6%E7%B4%A7%E6%94%BE%E8%81%AA%E6%98%8E%E7%82%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777462895000.webp","sourceId":"rfi"},{"id":1777459966000,"createdDate":"2026-04-29 10:52","name":"法国国际广播电台","title":"能源转型：当特朗普的美国回顾过去时，中国收获了丰厚回报","content":"据《回声报》周二（4月28日）报道分析，如果听信特朗普政府的说法，似乎只有化石燃料和核能才重要。与此同时，北京正持续加速发展绿色能源，并日益主导这些未来技术。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260429-%E8%83%BD%E6%BA%90%E8%BD%AC%E5%9E%8B-%E5%BD%93%E7%89%B9%E6%9C%97%E6%99%AE%E7%9A%84%E7%BE%8E%E5%9B%BD%E5%9B%9E%E9%A1%BE%E8%BF%87%E5%8E%BB%E6%97%B6%EF%BC%8C%E4%B8%AD%E5%9B%BD%E6%94%B6%E8%8E%B7%E4%BA%86%E4%B8%B0%E5%8E%9A%E5%9B%9E%E6%8A%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777459966000.webp","sourceId":"rfi"},{"id":1777456435000,"createdDate":"2026-04-29 09:53","name":"法国国际广播电台","title":"《观点》专栏：日本“前车之鉴”显示中国制造攻势难以叫停","content":"周三4月29日出版的法国三大主要全国性日报头版主题各有侧重：《解放报》关注前总统萨科齐将在今天接受巴黎上诉法院的诘问；《费加罗报》聚焦反梅朗雄的左翼阵营正在物色2027总统候选人；《十字架报》推出陷于威胁与停火的伊朗专题。有关中国的报道为您详介《观点》周刊专栏作者、法国经济学家查尔斯·塞尔法蒂（CharlesSerfaty）撰写的文章，他以全球经济史的重要事件为视角来分析，凭借高达1.2万亿美元的贸易顺差，中国正在挤压全球工业的发展。从20世纪末日本的经验来看，我们并无理由认为北京会采取温和策略。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260429-%E8%A7%82%E7%82%B9-%E4%B8%93%E6%A0%8F-%E6%97%A5%E6%9C%AC-%E5%89%8D%E8%BD%A6%E4%B9%8B%E9%89%B4-%E6%98%BE%E7%A4%BA%E4%B8%AD%E5%9B%BD%E5%88%B6%E9%80%A0%E6%94%BB%E5%8A%BF%E9%9A%BE%E4%BB%A5%E5%8F%AB%E5%81%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777456435000.webp","sourceId":"rfi"},{"id":1777454759000,"createdDate":"2026-04-29 09:25","name":"法国国际广播电台","title":"中共将飞安武器化打压台湾 可看出中共将长期经济合作关系转化为即时政治杠杆工具","content":"台湾总统赖清德原定22日出访非洲邦交国斯威士兰，但因非洲三国突然以「一个中国原则」等理由，撤销台湾总统专机的飞越许可而暂缓。台学者表示，台湾元首出访受阻的警讯不只是北京开始病态的打压台湾，还同时透露出习近平主政下的中共已将长期经济合作关系转化为即时政治杠杆工具，特别是利用「带路倡议」及相关金融安排，对发展中国家施行「胁迫外交」。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260429-%E4%B8%AD%E5%85%B1%E5%B0%86%E9%A3%9E%E5%AE%89%E6%AD%A6%E5%99%A8%E5%8C%96%E6%89%93%E5%8E%8B%E5%8F%B0%E6%B9%BE-%E5%8F%AF%E7%9C%8B%E5%87%BA%E4%B8%AD%E5%85%B1%E5%B0%86%E9%95%BF%E6%9C%9F%E7%BB%8F%E6%B5%8E%E5%90%88%E4%BD%9C%E5%85%B3%E7%B3%BB%E8%BD%AC%E5%8C%96%E4%B8%BA%E5%8D%B3%E6%97%B6%E6%94%BF%E6%B2%BB%E6%9D%A0%E6%9D%86%E5%B7%A5%E5%85%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/29/1777454759000.webp","sourceId":"rfi"}]