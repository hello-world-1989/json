[{"id":1776614594000,"createdDate":"2026-04-19 16:03","name":"法国国际广播电台","title":"日美韩要求朝鲜停止挑衅 李在明缓和平壤关系未果","content":"日美韩三国在朝鲜4月19日试射多枚短程弹道导弹后联合要求平壤停止挑衅。李在明政府致力于缓和双边关系未果，敦促朝鲜停止接连不断的挑衅。日本政府则通过其在北京的大使馆渠道向朝鲜提出了严正抗议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260419-%E6%97%A5%E7%BE%8E%E9%9F%A9%E8%A6%81%E6%B1%82%E6%9C%9D%E9%B2%9C%E5%81%9C%E6%AD%A2%E6%8C%91%E8%A1%85-%E6%9D%8E%E5%9C%A8%E6%98%8E%E7%BC%93%E5%92%8C%E5%B9%B3%E5%A3%A4%E5%85%B3%E7%B3%BB%E6%9C%AA%E6%9E%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/19/1776614594000.webp","sourceId":"rfi"},{"id":1776611539000,"createdDate":"2026-04-19 15:12","name":"法国国际广播电台","title":"特朗普宣布美国代表团将于周一抵达巴基斯坦与伊朗谈判","content":"美国总统唐纳德·特朗普周日宣布，美国代表团将于周一抵达巴基斯坦，以重启与伊朗的谈判，此次副总统J.D.万斯将不去。同时，他威胁称，若谈判失败，将摧毁该国的基础设施。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260419-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AE%A3%E5%B8%83%E7%BE%8E%E5%9B%BD%E4%BB%A3%E8%A1%A8%E5%9B%A2%E5%B0%86%E4%BA%8E%E5%91%A8%E4%B8%80%E6%8A%B5%E8%BE%BE%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E4%B8%8E%E4%BC%8A%E6%9C%97%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/19/1776611539000.webp","sourceId":"rfi"},{"id":1776608630000,"createdDate":"2026-04-19 14:23","name":"法国国际广播电台","title":"教皇良十四世在安哥拉呼吁克服分裂 谴责掠夺式开采资源带来“灾难”","content":"法新社说，周日上午，约10万信徒在安哥拉首都罗安达附近参加了一场由教皇良十四世主持的露天大型弥撒。在对这个深受严重经济和社会不平等困扰的葡语国家进行访问的第二天，教皇呼吁人们怀抱“希望”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260419-%E6%95%99%E7%9A%87%E8%89%AF%E5%8D%81%E5%9B%9B%E4%B8%96%E5%9C%A8%E5%AE%89%E5%93%A5%E6%8B%89%E5%91%BC%E5%90%81%E5%85%8B%E6%9C%8D%E5%88%86%E8%A3%82-%E8%B0%B4%E8%B4%A3%E6%8E%A0%E5%A4%BA%E5%BC%8F%E5%BC%80%E9%87%87%E8%B5%84%E6%BA%90%E5%B8%A6%E6%9D%A5-%E7%81%BE%E9%9A%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/19/1776608630000.webp","sourceId":"rfi"},{"id":1776604566000,"createdDate":"2026-04-19 13:16","name":"法国国际广播电台","title":"暂停对俄罗斯石油制裁：泽连斯基谴责此举是为侵略乌克兰“战争提供资金”","content":"乌克兰总统泽连斯基：“支付给俄罗斯石油的每一美元，都是莫斯科在乌克兰发动战争的资金”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260419-%E6%9A%82%E5%81%9C%E5%AF%B9%E4%BF%84%E7%BD%97%E6%96%AF%E7%9F%B3%E6%B2%B9%E5%88%B6%E8%A3%81-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E8%B0%B4%E8%B4%A3%E6%AD%A4%E4%B8%BE%E6%98%AF%E4%B8%BA%E4%BE%B5%E7%95%A5%E4%B9%8C%E5%85%8B%E5%85%B0-%E6%88%98%E4%BA%89%E6%8F%90%E4%BE%9B%E8%B5%84%E9%87%91","thumbnail":"","detailImage":"news/detail/rfi/2026/04/19/1776604566000.webp","sourceId":"rfi"},{"id":1776604407000,"createdDate":"2026-04-19 13:13","name":"法国国际广播电台","title":"能源危机加剧 东盟各国经受考验","content":"随着全球秩序的变化进入关键节点，中美权力博弈和随之而来的世界能源危机加剧，东盟各国正面临一场决定其未来的重大考验。为了确保燃油供应充足，马来西亚、印度尼西亚等国采购俄罗斯石油；越南领导人走访北京寻求建立更紧密的互利共赢关系；缅甸特赦囚犯试图创造更有利于外界接受的政治氛围；泰国则积极推动自由贸易谈判以拓展未来市场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260419-%E8%83%BD%E6%BA%90%E5%8D%B1%E6%9C%BA%E5%8A%A0%E5%89%A7-%E4%B8%9C%E7%9B%9F%E5%90%84%E5%9B%BD%E7%BB%8F%E5%8F%97%E8%80%83%E9%AA%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/19/1776604407000.webp","sourceId":"rfi"},{"id":1776604089000,"createdDate":"2026-04-19 13:08","name":"法国国际广播电台","title":"中东战争：霍尔木兹海峡关闭 和平协议“遥遥无期”","content":"周日法国报纸国际版继续关注中东海湾战争局势，由于美国封锁伊朗港口，伊朗周日再次关闭了具有战略意义的霍尔木兹海峡，美国和伊朗两国之间的停火协议将于三天后到期，现在的情况是伊朗和美国之间的和平谈判“取得了进展”，但距离达成和平协议仍有很长的路要走。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260419-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%85%B3%E9%97%AD-%E5%92%8C%E5%B9%B3%E5%8D%8F%E8%AE%AE-%E9%81%A5%E9%81%A5%E6%97%A0%E6%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/19/1776604089000.webp","sourceId":"rfi"},{"id":1776603123000,"createdDate":"2026-04-19 12:52","name":"法国国际广播电台","title":"北京半马赛 多台中国造人形机器人战胜人类选手 青年人担心未来就业","content":"路透社发自北京的消息说：在周日于北京举行的一场半程马拉松比赛中，多台中国制造的人形机器人击败了人类选手，展示了它们的运动能力及自主导航技能。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260419-%E5%8C%97%E4%BA%AC%E5%8D%8A%E9%A9%AC%E8%B5%9B-%E5%A4%9A%E5%8F%B0%E4%B8%AD%E5%9B%BD%E9%80%A0%E4%BA%BA%E5%BD%A2%E6%9C%BA%E5%99%A8%E4%BA%BA%E6%88%98%E8%83%9C%E4%BA%BA%E7%B1%BB%E9%80%89%E6%89%8B-%E9%9D%92%E5%B9%B4%E4%BA%BA%E6%8B%85%E5%BF%83%E6%9C%AA%E6%9D%A5%E5%B0%B1%E4%B8%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/19/1776603123000.webp","sourceId":"rfi"},{"id":1776599495000,"createdDate":"2026-04-19 11:51","name":"法国国际广播电台","title":"拖字诀？停火协议到期还有三天 伊朗警告达成和平协议遥遥无期","content":"距离美伊临时停火协议到期仅剩三天之际，战略要地霍尔木兹海峡仍处于封锁状态，伊朗方面警告称，与美国达成和平协议仍遥遥无期。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260419-%E6%8B%96%E5%AD%97%E8%AF%80-%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E5%88%B0%E6%9C%9F%E8%BF%98%E6%9C%89%E4%B8%89%E5%A4%A9-%E4%BC%8A%E6%9C%97%E8%AD%A6%E5%91%8A%E8%BE%BE%E6%88%90%E5%92%8C%E5%B9%B3%E5%8D%8F%E8%AE%AE%E9%81%A5%E9%81%A5%E6%97%A0%E6%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/19/1776599495000.webp","sourceId":"rfi"},{"id":1776591273000,"createdDate":"2026-04-19 09:34","name":"法国国际广播电台","title":"伊朗再封锁霍尔木兹海峡后 特朗普召开战情室会议","content":"美国总统特朗普周六召开了战情室会议。距离停火到期还有三天。伊朗周六宣布再次封锁霍尔木兹海峡以报复美国继续封锁其港口。关于谈判，伊朗议长加利巴夫表示：“我们距离达成共识还很遥远”。伊朗总统佩泽什基安说：唐纳德·特朗普没有理由剥夺伊朗的核权利。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260419-%E4%BC%8A%E6%9C%97%E5%86%8D%E5%B0%81%E9%94%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%90%8E-%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%AC%E5%BC%80%E6%88%98%E6%83%85%E5%AE%A4%E4%BC%9A%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/19/1776591273000.webp","sourceId":"rfi"},{"id":1776590859000,"createdDate":"2026-04-19 09:27","name":"法国国际广播电台","title":"首尔称 : 朝鲜周日再次试射了数枚短程弹道导弹","content":"韩国军方称平壤周日再次试射数枚短程弹道导弹，这些导弹飞行约140公里后落入海中。这也是朝鲜不顾联合国的制裁今年进行的第六次此类导弹试射。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260419-%E9%A6%96%E5%B0%94%E7%A7%B0-%E6%9C%9D%E9%B2%9C%E5%91%A8%E6%97%A5%E5%86%8D%E6%AC%A1%E8%AF%95%E5%B0%84%E4%BA%86%E6%95%B0%E6%9E%9A%E7%9F%AD%E7%A8%8B%E5%BC%B9%E9%81%93%E5%AF%BC%E5%BC%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/19/1776590859000.webp","sourceId":"rfi"},{"id":1776590478000,"createdDate":"2026-04-19 09:21","name":"法国国际广播电台","title":"日本谨慎对待派兵参加霍尔木兹海峡多国籍部队","content":"4月17日，围绕霍尔木兹海峡问题，志同道合国家举行了“关于霍尔木兹海峡航行自由的首脑线上会议”，有50多个国家和机构参加，并就清除霍尔木兹海峡的水雷等问题进行了讨论,目前没有迹象表明日本首相高市早苗参加了这次线上会议。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260419-%E6%97%A5%E6%9C%AC%E8%B0%A8%E6%85%8E%E5%AF%B9%E5%BE%85%E6%B4%BE%E5%85%B5%E5%8F%82%E5%8A%A0%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%A4%9A%E5%9B%BD%E7%B1%8D%E9%83%A8%E9%98%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/19/1776590478000.webp","sourceId":"rfi"},{"id":1776588965000,"createdDate":"2026-04-19 08:56","name":"法国国际广播电台","title":"保加利亚举行5年内第八次议会选举 亲俄的前总统拉德夫民调领先","content":"保加利亚周日（4月19日）举行议会选举，这是这个巴尔干国家五年来的第八次议会选举，在民众普遍的疲惫情绪和对变革的希望背景下，亲俄的前总统鲁门·拉德夫（RoumenRadev）领导的政党在民调中明显领先，他承诺结束长期的政治僵局、打击腐败以及恢复政府稳定。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260419-%E4%BF%9D%E5%8A%A0%E5%88%A9%E4%BA%9A%E4%B8%BE%E8%A1%8C5%E5%B9%B4%E5%86%85%E7%AC%AC%E5%85%AB%E6%AC%A1%E8%AE%AE%E4%BC%9A%E9%80%89%E4%B8%BE-%E4%BA%B2%E4%BF%84%E7%9A%84%E5%89%8D%E6%80%BB%E7%BB%9F%E6%8B%89%E5%BE%B7%E5%A4%AB%E6%B0%91%E8%B0%83%E9%A2%86%E5%85%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/19/1776588965000.webp","sourceId":"rfi"}]