[{"id":1776762460000,"createdDate":"2026-04-21 09:07","name":"法国国际广播电台","title":"特朗普：停火将在华盛顿时间周三晚到期，极不可能延长","content":"美国和伊朗为期两周的停火期限即将到期，两国在巴基斯坦重启谈判的前景仍不明朗。特朗普称，“在协议签署之前，我不会开放海峡。”","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260421-%E7%89%B9%E6%9C%97%E6%99%AE-%E5%81%9C%E7%81%AB%E5%B0%86%E5%9C%A8%E5%8D%8E%E7%9B%9B%E9%A1%BF%E6%97%B6%E9%97%B4%E5%91%A8%E4%B8%89%E6%99%9A%E5%88%B0%E6%9C%9F%EF%BC%8C%E6%9E%81%E4%B8%8D%E5%8F%AF%E8%83%BD%E5%BB%B6%E9%95%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776762460000.webp","sourceId":"rfi"},{"id":1776758905000,"createdDate":"2026-04-21 08:08","name":"法国国际广播电台","title":"苹果换主帅：库克退居二线，特努斯接棒，AI将成新战场","content":"苹果公司首席执行官蒂姆·库克（TimCook）将于今年9月卸任，由集团高管约翰·特努斯（JohnTernus）接任，后者此前负责从iPhone到Mac等实体产品的开发。根据周一（4月20日）发布的公告，尽管特努斯一直被视为库克的接班热门人选，但这一交接来得比预期更快。蒂姆·库克将出任苹果公司董事会执行主席。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260421-%E8%8B%B9%E6%9E%9Cceo%E6%8D%A2%E5%B8%85-%E5%BA%93%E5%85%8B%E9%80%80%E5%B1%85%E4%BA%8C%E7%BA%BF%EF%BC%8C%E7%89%B9%E5%8A%AA%E6%96%AF%E6%8E%A5%E6%A3%92%EF%BC%8Cai%E5%B0%86%E6%88%90%E6%96%B0%E6%88%98%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776758905000.webp","sourceId":"rfi"},{"id":1776758298000,"createdDate":"2026-04-21 07:58","name":"法国国际广播电台","title":"维稳先行：港府安排宏福苑灾民返家执拾设诸多限制  并禁媒体随行","content":"大埔宏福苑夺命火灾发生近五个月，港府终于安排灾民由本周起，分批回家执拾，但设诸多限制，包括设时限3小时丶最多每户4人同行，又临时煞停社福团体义助居民搬运「灾后遗物」的服务，禁止记者随居民返家和采访。港府中人指，设多重限制是要严防「搞事者」。但有资深传媒人指，港府以维稳思维安排灾民返家，未有顾及灾民感受之余，更突显港府敌视媒体的态度。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260421-%E7%BB%B4%E7%A8%B3%E5%85%88%E8%A1%8C-%E6%B8%AF%E5%BA%9C%E5%AE%89%E6%8E%92%E5%AE%8F%E7%A6%8F%E8%8B%91%E7%81%BE%E6%B0%91%E8%BF%94%E5%AE%B6%E6%89%A7%E6%8B%BE%E8%AE%BE%E8%AF%B8%E5%A4%9A%E9%99%90%E5%88%B6-%E5%B9%B6%E7%A6%81%E5%AA%92%E4%BD%93%E9%9A%8F%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776758298000.webp","sourceId":"rfi"},{"id":1776757807000,"createdDate":"2026-04-21 07:50","name":"法国国际广播电台","title":"港府急煞篮球博彩合法化  原因仍然扑朔迷离 李家超只称做法恰当","content":"香港原订最快于今年9月容许篮球博彩合法化，但港府突然煞停已获立法会通过的相关安排，除了使已投放10亿港元（下同，折算约1.08亿欧元）作准备的马会大失预算外，也引起外界诸多揣测，包括此举是否要配合北京打击赌博政策。特首李家超则表示，港府一贯不鼓励赌博，此举是按形势评估潜在风险後的恰当做法。但有评论指，港府急煞车，有违「以赌制赌」原意之余，也涉及明年特首选举的潜在人选争夺战。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260421-%E6%B8%AF%E5%BA%9C%E6%80%A5%E7%85%9E%E7%AF%AE%E7%90%83%E5%8D%9A%E5%BD%A9%E5%90%88%E6%B3%95%E5%8C%96-%E5%8E%9F%E5%9B%A0%E4%BB%8D%E7%84%B6%E6%89%91%E6%9C%94%E8%BF%B7%E7%A6%BB-%E6%9D%8E%E5%AE%B6%E8%B6%85%E5%8F%AA%E7%A7%B0%E5%81%9A%E6%B3%95%E6%81%B0%E5%BD%93","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776757807000.webp","sourceId":"rfi"},{"id":1776790029000,"createdDate":"2026-04-21 16:47","name":"法国国际广播电台","title":"英伟达一家中国供应商在香港上市时筹集了18.7亿欧元","content":"中国企业胜宏科技（VictoryGiantTechnology）周二在香港上市，其股价飙升近60%，该公司主要为英伟达（Nvidia）供应印刷电路板，此次上市为其筹集了超过18.7亿欧元。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260421-%E8%8B%B1%E4%BC%9F%E8%BE%BE%E4%B8%80%E5%AE%B6%E4%B8%AD%E5%9B%BD%E4%BE%9B%E5%BA%94%E5%95%86%E5%9C%A8%E9%A6%99%E6%B8%AF%E4%B8%8A%E5%B8%82%E6%97%B6%E7%AD%B9%E9%9B%86%E4%BA%8618-7%E4%BA%BF%E6%AC%A7%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776790029000.webp","sourceId":"rfi"},{"id":1776789675000,"createdDate":"2026-04-21 16:41","name":"法国国际广播电台","title":"霍尔木兹海峡的“有限陆路替代”？伊叙边境口岸重启","content":"伊拉克与叙利亚之间一处重要边境口岸在本周一恢复开放，这是十多年来的首次通行。相关官员表示，这一举措有望推动双边贸易，并为石油出口提供新的通道。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260421-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%9A%84-%E6%9C%89%E9%99%90%E9%99%86%E8%B7%AF%E6%9B%BF%E4%BB%A3-%E4%BC%8A%E5%8F%99%E8%BE%B9%E5%A2%83%E5%8F%A3%E5%B2%B8%E9%87%8D%E5%90%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776789675000.webp","sourceId":"rfi"},{"id":1776786829000,"createdDate":"2026-04-21 15:53","name":"法国国际广播电台","title":"“我们将重返竞争”——尽管面临价格战 奥迪仍看好中国市场","content":"据德国N-TV电视台报道：德国汽车制造商奥迪认为，尽管中国市场竞争激烈、价格战持续，但这一全球最大汽车市场仍然存在增长空间，公司希望借此实现“重返竞争”。为此，来自英戈尔施塔特的奥迪将依靠与中国国有汽车集团上汽（SAIC）共同开发的E7X车型重新开拓中国市场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260421-%E6%88%91%E4%BB%AC%E5%B0%86%E9%87%8D%E8%BF%94%E7%AB%9E%E4%BA%89-%E5%B0%BD%E7%AE%A1%E9%9D%A2%E4%B8%B4%E4%BB%B7%E6%A0%BC%E6%88%98-%E5%A5%A5%E8%BF%AA%E4%BB%8D%E7%9C%8B%E5%A5%BD%E4%B8%AD%E5%9B%BD%E5%B8%82%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776786829000.webp","sourceId":"rfi"},{"id":1776786549000,"createdDate":"2026-04-21 15:49","name":"法国国际广播电台","title":"停火协议即将到期之际，特朗普指责伊朗违反协议","content":"在停火协议即将到期之际，且伊斯兰堡方面未见重启谈判的迹象，唐纳德·特朗普周二指责伊朗多次违反停火协议，同时表示确信华盛顿将达成“一项超级协议”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260421-%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E5%8D%B3%E5%B0%86%E5%88%B0%E6%9C%9F%E4%B9%8B%E9%99%85%EF%BC%8C%E7%89%B9%E6%9C%97%E6%99%AE%E6%8C%87%E8%B4%A3%E4%BC%8A%E6%9C%97%E8%BF%9D%E5%8F%8D%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776786549000.webp","sourceId":"rfi"},{"id":1776785884000,"createdDate":"2026-04-21 15:38","name":"法国国际广播电台","title":"蒂姆-库克将退居二线：人事变动能否让苹果集团再创辉煌？","content":"如果说中东冲突尚未影响全球科技市场对前景的乐观期待的话，美国科技巨头之一苹果集团日前宣布任命原本是苹果产品硬件工程高级副总裁的约翰-特努斯为新任首席执行官，自9月1日起取代现任首席执行官蒂姆-库克的消息则在市场引发些许波澜。蒂姆-库克将不再担任首席执行官原本已为业界所知，但这则人事任命的宣布似乎还是快得有些突然。这是否意味着苹果集团已经做好迎接新挑战的准备？亦或在集团内部选择接任者意味着苹果品牌将继续库克此前开辟的道路？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%A7%91%E6%8A%80%E6%97%B6%E7%A9%BA/20260421-%E8%92%82%E5%A7%86-%E5%BA%93%E5%85%8B%E5%B0%86%E8%AE%A9%E4%BD%8D%E6%96%B0%E4%BA%BA-%E4%BA%BA%E4%BA%8B%E5%8F%98%E5%8A%A8%E8%83%BD%E5%90%A6%E8%AE%A9%E8%8B%B9%E6%9E%9C%E9%9B%86%E5%9B%A2%E5%86%8D%E5%88%9B%E8%BE%89%E7%85%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776785884000.webp","sourceId":"rfi"},{"id":1776785696000,"createdDate":"2026-04-21 15:34","name":"法国国际广播电台","title":"卡拉斯：欧盟预计将很快就900亿欧元援乌贷款作出“积极决定”","content":"欧盟外交与安全政策高级代表卡拉斯周二（4月21日）表示，预计将很快就欧盟承诺向乌克兰提供的900亿欧元贷款作出“积极决定”，该贷款的最终落实此前一直因匈牙利的反对而受阻。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260421-%E5%8D%A1%E6%8B%89%E6%96%AF-%E6%AC%A7%E7%9B%9F%E9%A2%84%E8%AE%A1%E5%B0%86%E5%BE%88%E5%BF%AB%E5%B0%B1900%E4%BA%BF%E6%AC%A7%E5%85%83%E6%8F%B4%E4%B9%8C%E8%B4%B7%E6%AC%BE%E4%BD%9C%E5%87%BA-%E7%A7%AF%E6%9E%81%E5%86%B3%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776785696000.webp","sourceId":"rfi"},{"id":1776780952000,"createdDate":"2026-04-21 14:15","name":"法国国际广播电台","title":"国际特赦点名美俄以，呼吁各国阻止掠夺性反人权秩序成型","content":"持续的中东冲突也成为国际人权组织国际特赦年度人权报告关注的一大重点。该组织20日在伦敦发布年度报告时，特别点名美国总统特朗普、俄罗斯总统普京和以色列总理内塔尼亚胡，呼吁各国领导人抵制以战争取代外交的掠夺性破坏国际法的作为。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260421-%E5%9B%BD%E9%99%85%E7%89%B9%E8%B5%A6%E7%82%B9%E5%90%8D%E7%BE%8E%E4%BF%84%E4%BB%A5%EF%BC%8C%E5%91%BC%E5%90%81%E5%90%84%E5%9B%BD%E9%98%BB%E6%AD%A2%E6%8E%A0%E5%A4%BA%E6%80%A7%E5%8F%8D%E4%BA%BA%E6%9D%83%E7%A7%A9%E5%BA%8F%E6%88%90%E5%9E%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776780952000.webp","sourceId":"rfi"},{"id":1776779857000,"createdDate":"2026-04-21 13:57","name":"法国国际广播电台","title":"中国长剑-10巡航导弹射程升至2000公里 三重惯性制导   旨在突破敌方防御系统并打击印太地区","content":"北京正不声不响地升级其最常用的导弹之一。升级后的导弹射程更远、以求突破敌方防御系统并打击印太地区。旨在让打击能力更灵活、更难被反制……","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260421-%E4%B8%AD%E5%9B%BD%E9%95%BF%E5%89%91-10%E5%B7%A1%E8%88%AA%E5%AF%BC%E5%BC%B9%E5%B0%84%E7%A8%8B%E5%8D%87%E8%87%B32000%E5%85%AC%E9%87%8C-%E4%B8%89%E9%87%8D%E6%83%AF%E6%80%A7%E5%88%B6%E5%AF%BC-%E6%97%A8%E5%9C%A8%E7%AA%81%E7%A0%B4%E6%95%8C%E6%96%B9%E9%98%B2%E5%BE%A1%E7%B3%BB%E7%BB%9F%E5%B9%B6%E6%89%93%E5%87%BB%E5%8D%B0%E5%A4%AA%E5%9C%B0%E5%8C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776779857000.webp","sourceId":"rfi"},{"id":1776778573000,"createdDate":"2026-04-21 13:36","name":"法国国际广播电台","title":"X平台涉违规司法问询：马斯克未现身 巴黎法庭称调查继续","content":"法国司法部门原定于周一传唤埃隆·马斯克，就其社交媒体平台X可能存在的违规行为进行问询，但他并未应传唤前往巴黎接受非正式问询。巴黎检察院强调，调查工作仍在继续。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260421-x%E5%B9%B3%E5%8F%B0%E6%B6%89%E8%BF%9D%E8%A7%84%E5%8F%B8%E6%B3%95%E9%97%AE%E8%AF%A2-%E9%A9%AC%E6%96%AF%E5%85%8B%E6%9C%AA%E7%8E%B0%E8%BA%AB-%E5%B7%B4%E9%BB%8E%E6%B3%95%E5%BA%AD%E7%A7%B0%E8%B0%83%E6%9F%A5%E7%BB%A7%E7%BB%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776778573000.webp","sourceId":"rfi"},{"id":1776777595000,"createdDate":"2026-04-21 13:19","name":"法国国际广播电台","title":"韩媒：韩国情报院长的“台湾杠杆论” 北京怒斥不符“一个中国原则”","content":"据韩国多家媒体周二4月21日报道，中韩高层交流近期陷入僵局，中国外长王毅原定访韩行程多次推迟，韩国国家情报院长李钟奭访华计划也遭暂缓。据韩媒AsiaToday驻北京特派员透露，中方认为韩国政府在“一个中国原则”问题上“口惠而实不至”，暗中采取亲台立场，并对李钟奭提出的“台湾牌”论调表示强烈不满。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260421-%E9%9F%A9%E5%AA%92-%E9%9F%A9%E5%9B%BD%E6%83%85%E6%8A%A5%E9%99%A2%E9%95%BF%E7%9A%84-%E5%8F%B0%E6%B9%BE%E6%9D%A0%E6%9D%86%E8%AE%BA-%E5%8C%97%E4%BA%AC%E6%80%92%E6%96%A5%E4%B8%8D%E7%AC%A6-%E4%B8%80%E4%B8%AA%E4%B8%AD%E5%9B%BD%E5%8E%9F%E5%88%99","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776777595000.webp","sourceId":"rfi"},{"id":1776774327000,"createdDate":"2026-04-21 12:25","name":"法国国际广播电台","title":"赖清德暂缓出访史瓦帝尼 台北强力谴责北京粗暴干预","content":"台湾总统赖清德出访台湾非洲邦交国史瓦帝尼的行程受阻：三个途径国家突然取消了飞航许可。台北谴责北京粗暴干涉。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260421-%E8%B5%96%E6%B8%85%E5%BE%B7%E6%9A%82%E7%BC%93%E5%87%BA%E8%AE%BF%E5%8F%B2%E7%93%A6%E5%B8%9D%E5%B0%BC-%E5%8F%B0%E5%8C%97%E5%BC%BA%E5%8A%9B%E8%B0%B4%E8%B4%A3%E5%8C%97%E4%BA%AC%E7%B2%97%E6%9A%B4%E5%B9%B2%E9%A2%84","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776774327000.webp","sourceId":"rfi"},{"id":1776771479000,"createdDate":"2026-04-21 11:37","name":"法国国际广播电台","title":"中日紧张局势加剧，中国向太平洋派遣军舰","content":"就在东京加入美菲年度联合军演的同一天，北京部署了海军驱逐舰编队。今年美菲肩并肩演习至少动用1.7万名士兵，除了日本之外，还包括来自法国、澳大利亚、加拿大和新西兰的部队。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260421-%E4%B8%AD%E6%97%A5%E7%B4%A7%E5%BC%A0%E5%B1%80%E5%8A%BF%E5%8A%A0%E5%89%A7%EF%BC%8C%E4%B8%AD%E5%9B%BD%E5%90%91%E5%A4%AA%E5%B9%B3%E6%B4%8B%E6%B4%BE%E9%81%A3%E5%86%9B%E8%88%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776771479000.webp","sourceId":"rfi"},{"id":1776769264000,"createdDate":"2026-04-21 11:01","name":"法国国际广播电台","title":"日本历史性转向解除杀伤性武器出口限制，中国严重“关切”称将抵制日本“军事化”","content":"日本周二（4月21日）解除了实行数十年的最后几项武器出口障碍。法新社对此指出，这一历史性变革为这个自二战以来奉行和平宪法的国家销售杀伤性武器扫清了道路。同一天，中国对日本解除最后几项武器出口障碍表示严重“关切”，并誓言将抵制日本“盲目的军事化”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260421-%E6%97%A5%E6%9C%AC%E5%8E%86%E5%8F%B2%E6%80%A7%E8%BD%AC%E5%90%91%E8%A7%A3%E9%99%A4%E6%9D%80%E4%BC%A4%E6%80%A7%E6%AD%A6%E5%99%A8%E5%87%BA%E5%8F%A3%E9%99%90%E5%88%B6%EF%BC%8C%E4%B8%AD%E5%9B%BD%E4%B8%A5%E9%87%8D-%E5%85%B3%E5%88%87-%E7%A7%B0%E5%B0%86%E6%8A%B5%E5%88%B6%E6%97%A5%E6%9C%AC-%E5%86%9B%E4%BA%8B%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776769264000.webp","sourceId":"rfi"},{"id":1776764400000,"createdDate":"2026-04-21 09:40","name":"法国国际广播电台","title":"日本自卫队演习场坦克炸膛 自卫队员3死1伤","content":"4月21日上午8点39分左右，在陆上自卫队日出生台演习场（位于大分县由布市、九重町、玖珠町），有人拨打119报警称“在射击训练中坦克内发生了爆炸事故”。据陆上自卫队称，有3名队员在事故中死亡、1人受伤，原因是炮弹在炮筒中炸膛。大分县当地消防与急救部门表示，受伤的1人面部被烧伤，但推测仍有意识。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260421-%E6%97%A5%E6%9C%AC%E8%87%AA%E5%8D%AB%E9%98%9F%E6%BC%94%E4%B9%A0%E5%9C%BA%E5%9D%A6%E5%85%8B%E7%82%B8%E8%86%9B-%E8%87%AA%E5%8D%AB%E9%98%9F%E5%91%983%E6%AD%BB1%E4%BC%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776764400000.webp","sourceId":"rfi"},{"id":1776763327000,"createdDate":"2026-04-21 09:22","name":"法国国际广播电台","title":"周二 亚洲油价回落 股市走高 市场关注伊朗与美国重启谈判","content":"法新社东京消息，周二油价回落，市场正密切关注德黑兰与华盛顿可能在伊斯兰堡重启谈判的消息，这一前景在霍尔木兹海峡局势紧张的背景下，推动亚洲股市走高。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260421-%E5%91%A8%E4%BA%8C-%E4%BA%9A%E6%B4%B2%E6%B2%B9%E4%BB%B7%E5%9B%9E%E8%90%BD-%E8%82%A1%E5%B8%82%E8%B5%B0%E9%AB%98-%E5%B8%82%E5%9C%BA%E5%85%B3%E6%B3%A8%E4%BC%8A%E6%9C%97%E4%B8%8E%E7%BE%8E%E5%9B%BD%E9%87%8D%E5%90%AF%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/21/1776763327000.webp","sourceId":"rfi"}]