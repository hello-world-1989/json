[{"id":1777366525000,"createdDate":"2026-04-28 08:55","name":"法国国际广播电台","title":"英国放行中国龙佰收购Venator二氧化钛工厂，欧盟表示极度失望","content":"据《金融时报》报道，英国竞争与市场管理局（CMA）近日批准了中国化工业者龙佰集团收购进入破产程序的VenatorMaterials英国工厂，遭到欧洲和美国制造商联盟批评，龙佰获得中国政府补贴，通过大量生产和压低价格，恐危及他们的生存。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260428-%E8%8B%B1%E5%9B%BD%E6%94%BE%E8%A1%8C%E4%B8%AD%E5%9B%BD%E9%BE%99%E4%BD%B0%E6%94%B6%E8%B4%ADvenator%E4%BA%8C%E6%B0%A7%E5%8C%96%E9%92%9B%E5%B7%A5%E5%8E%82%EF%BC%8C%E6%AC%A7%E7%9B%9F%E8%A1%A8%E7%A4%BA%E6%9E%81%E5%BA%A6%E5%A4%B1%E6%9C%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777366525000.webp","sourceId":"rfi"},{"id":1777363476000,"createdDate":"2026-04-28 08:04","name":"法国国际广播电台","title":"美国认为伊朗的新停火协议比美国预期的还要好， 并称伊朗的石油产量很快会崩溃","content":"此前有媒体报道称，德黑兰通过巴基斯坦提交了新的停火方案。周一，美国总统特朗普在华盛顿与他的高级安全顾问举行了会议，美国政府没有就该提议的细节发表评论。白宫发言人卡罗琳·莱维特表示，伊朗的这个新提议“正在审查中”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260428-%E7%BE%8E%E5%9B%BD%E8%AE%A4%E4%B8%BA%E4%BC%8A%E6%9C%97%E7%9A%84%E6%96%B0%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E6%AF%94%E7%BE%8E%E5%9B%BD%E9%A2%84%E6%9C%9F%E7%9A%84%E8%BF%98%E8%A6%81%E5%A5%BD%EF%BC%8C-%E5%B9%B6%E7%A7%B0%E4%BC%8A%E6%9C%97%E7%9A%84%E7%9F%B3%E6%B2%B9%E4%BA%A7%E9%87%8F%E5%BE%88%E5%BF%AB%E4%BC%9A%E5%B4%A9%E6%BA%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777363476000.webp","sourceId":"rfi"},{"id":1777363236000,"createdDate":"2026-04-28 08:00","name":"法国国际广播电台","title":"台湾罕见公布：发现两艘中国军舰靠近有军事基地的​​澎湖群岛","content":"路透社台北消息——台湾国防部周一27日晚表示，台湾发现两艘中国军舰在台湾海峡澎湖群岛附近海域活动，已派出海军和空军部队进行监视。报道指出，台湾国防部每天都会提供中国军用飞机的位置信息，但很少透露中国军舰的活动地点，通常只有在探测到航空母舰时才会透露。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260428-%E5%8F%B0%E6%B9%BE%E7%BD%95%E8%A7%81%E5%85%AC%E5%B8%83-%E5%8F%91%E7%8E%B0%E4%B8%A4%E8%89%98%E4%B8%AD%E5%9B%BD%E5%86%9B%E8%88%B0%E9%9D%A0%E8%BF%91%E6%9C%89%E5%86%9B%E4%BA%8B%E5%9F%BA%E5%9C%B0%E7%9A%84-%E6%BE%8E%E6%B9%96%E7%BE%A4%E5%B2%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777363236000.webp","sourceId":"rfi"},{"id":1777361639000,"createdDate":"2026-04-28 07:33","name":"法国国际广播电台","title":"港府改口 指政策局最高公务员的「常秘」亦受新责任制规管","content":"经过舆论质疑後，香港政府改口称，拟於今年10月推出的「部门首长责任制」，其规管对象涵盖各政策局内最高级公务员的常任秘书长(简称「常秘」)，而不是如早前政府发言人所说的不包括常秘。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260428-%E6%B8%AF%E5%BA%9C%E6%94%B9%E5%8F%A3-%E6%8C%87%E6%94%BF%E7%AD%96%E5%B1%80%E6%9C%80%E9%AB%98%E5%85%AC%E5%8A%A1%E5%91%98%E7%9A%84-%E5%B8%B8%E7%A7%98-%E4%BA%A6%E5%8F%97%E6%96%B0%E8%B4%A3%E4%BB%BB%E5%88%B6%E8%A7%84%E7%AE%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777361639000.webp","sourceId":"rfi"},{"id":1777361213000,"createdDate":"2026-04-28 07:26","name":"法国国际广播电台","title":"香港大火听证会：不同部门就规管说法出现矛盾","content":"造成168人死亡的宏福苑火灾，调查事件的听证会继揭发香港政府不同部门出现不作为及推诿责任後，更出现屋宇署官员与房屋局和劳工处人员就同一规定有前後矛盾的说法，前者昨(27日)天作供时推翻之前作证人士的说法，指以发泡胶(又称「泡沫板」)封窗属违法，并非没有法例规管；屋宇署巡查前不会预先通知地盘相关人员，以免出现规避情况；而改动建筑做出来的「生口」(活动通道)亦属违法。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260428-%E9%A6%99%E6%B8%AF%E5%A4%A7%E7%81%AB%E5%90%AC%E8%AF%81%E4%BC%9A-%E4%B8%8D%E5%90%8C%E9%83%A8%E9%97%A8%E5%B0%B1%E8%A7%84%E7%AE%A1%E8%AF%B4%E6%B3%95%E5%87%BA%E7%8E%B0%E7%9F%9B%E7%9B%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777361213000.webp","sourceId":"rfi"}]