[{"id":1777366525000,"createdDate":"2026-04-28 08:55","name":"法国国际广播电台","title":"英国放行中国龙佰收购Venator二氧化钛工厂，欧盟表示极度失望","content":"据《金融时报》报道，英国竞争与市场管理局（CMA）近日批准了中国化工业者龙佰集团收购进入破产程序的VenatorMaterials英国工厂，遭到欧洲和美国制造商联盟批评，龙佰获得中国政府补贴，通过大量生产和压低价格，恐危及他们的生存。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260428-%E8%8B%B1%E5%9B%BD%E6%94%BE%E8%A1%8C%E4%B8%AD%E5%9B%BD%E9%BE%99%E4%BD%B0%E6%94%B6%E8%B4%ADvenator%E4%BA%8C%E6%B0%A7%E5%8C%96%E9%92%9B%E5%B7%A5%E5%8E%82%EF%BC%8C%E6%AC%A7%E7%9B%9F%E8%A1%A8%E7%A4%BA%E6%9E%81%E5%BA%A6%E5%A4%B1%E6%9C%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777366525000.webp","sourceId":"rfi"},{"id":1777363476000,"createdDate":"2026-04-28 08:04","name":"法国国际广播电台","title":"美国认为伊朗的新停火协议比美国预期的还要好， 并称伊朗的石油产量很快会崩溃","content":"此前有媒体报道称，德黑兰通过巴基斯坦提交了新的停火方案。周一，美国总统特朗普在华盛顿与他的高级安全顾问举行了会议，美国政府没有就该提议的细节发表评论。白宫发言人卡罗琳·莱维特表示，伊朗的这个新提议“正在审查中”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260428-%E7%BE%8E%E5%9B%BD%E8%AE%A4%E4%B8%BA%E4%BC%8A%E6%9C%97%E7%9A%84%E6%96%B0%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E6%AF%94%E7%BE%8E%E5%9B%BD%E9%A2%84%E6%9C%9F%E7%9A%84%E8%BF%98%E8%A6%81%E5%A5%BD%EF%BC%8C-%E5%B9%B6%E7%A7%B0%E4%BC%8A%E6%9C%97%E7%9A%84%E7%9F%B3%E6%B2%B9%E4%BA%A7%E9%87%8F%E5%BE%88%E5%BF%AB%E4%BC%9A%E5%B4%A9%E6%BA%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777363476000.webp","sourceId":"rfi"},{"id":1777363236000,"createdDate":"2026-04-28 08:00","name":"法国国际广播电台","title":"台湾罕见公布：发现两艘中国军舰靠近有军事基地的​​澎湖群岛","content":"路透社台北消息——台湾国防部周一27日晚表示，台湾发现两艘中国军舰在台湾海峡澎湖群岛附近海域活动，已派出海军和空军部队进行监视。报道指出，台湾国防部每天都会提供中国军用飞机的位置信息，但很少透露中国军舰的活动地点，通常只有在探测到航空母舰时才会透露。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260428-%E5%8F%B0%E6%B9%BE%E7%BD%95%E8%A7%81%E5%85%AC%E5%B8%83-%E5%8F%91%E7%8E%B0%E4%B8%A4%E8%89%98%E4%B8%AD%E5%9B%BD%E5%86%9B%E8%88%B0%E9%9D%A0%E8%BF%91%E6%9C%89%E5%86%9B%E4%BA%8B%E5%9F%BA%E5%9C%B0%E7%9A%84-%E6%BE%8E%E6%B9%96%E7%BE%A4%E5%B2%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777363236000.webp","sourceId":"rfi"},{"id":1777361639000,"createdDate":"2026-04-28 07:33","name":"法国国际广播电台","title":"港府改口 指政策局最高公务员的「常秘」亦受新责任制规管","content":"经过舆论质疑後，香港政府改口称，拟於今年10月推出的「部门首长责任制」，其规管对象涵盖各政策局内最高级公务员的常任秘书长(简称「常秘」)，而不是如早前政府发言人所说的不包括常秘。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260428-%E6%B8%AF%E5%BA%9C%E6%94%B9%E5%8F%A3-%E6%8C%87%E6%94%BF%E7%AD%96%E5%B1%80%E6%9C%80%E9%AB%98%E5%85%AC%E5%8A%A1%E5%91%98%E7%9A%84-%E5%B8%B8%E7%A7%98-%E4%BA%A6%E5%8F%97%E6%96%B0%E8%B4%A3%E4%BB%BB%E5%88%B6%E8%A7%84%E7%AE%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777361639000.webp","sourceId":"rfi"},{"id":1777361213000,"createdDate":"2026-04-28 07:26","name":"法国国际广播电台","title":"香港大火听证会：不同部门就规管说法出现矛盾","content":"造成168人死亡的宏福苑火灾，调查事件的听证会继揭发香港政府不同部门出现不作为及推诿责任後，更出现屋宇署官员与房屋局和劳工处人员就同一规定有前後矛盾的说法，前者昨(27日)天作供时推翻之前作证人士的说法，指以发泡胶(又称「泡沫板」)封窗属违法，并非没有法例规管；屋宇署巡查前不会预先通知地盘相关人员，以免出现规避情况；而改动建筑做出来的「生口」(活动通道)亦属违法。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260428-%E9%A6%99%E6%B8%AF%E5%A4%A7%E7%81%AB%E5%90%AC%E8%AF%81%E4%BC%9A-%E4%B8%8D%E5%90%8C%E9%83%A8%E9%97%A8%E5%B0%B1%E8%A7%84%E7%AE%A1%E8%AF%B4%E6%B3%95%E5%87%BA%E7%8E%B0%E7%9F%9B%E7%9B%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777361213000.webp","sourceId":"rfi"},{"id":1777394571000,"createdDate":"2026-04-28 16:42","name":"法国国际广播电台","title":"毛泽东青睐的红旗车也要进军欧洲了：拟先收购斯特兰蒂斯西班牙工厂","content":"据路透周二说，毛泽东青睐的中国红旗轿车集团正考虑收购斯特兰蒂斯（Stellantis）在西班牙的工厂，以拓展欧洲市场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260428-%E6%AF%9B%E6%B3%BD%E4%B8%9C%E9%9D%92%E7%9D%90%E7%9A%84%E7%BA%A2%E6%97%97%E8%BD%A6%E4%B9%9F%E8%A6%81%E8%BF%9B%E5%86%9B%E6%AC%A7%E6%B4%B2%E4%BA%86-%E6%8B%9F%E5%85%88%E6%94%B6%E8%B4%AD%E6%96%AF%E7%89%B9%E5%85%B0%E8%92%82%E6%96%AF%E8%A5%BF%E7%8F%AD%E7%89%99%E5%B7%A5%E5%8E%82","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777394571000.webp","sourceId":"rfi"},{"id":1777393909000,"createdDate":"2026-04-28 16:31","name":"法国国际广播电台","title":"霍尔木兹海峡受阻推高航运压力，巴拿马运河单船通行竞价飙至400万美元","content":"随着伊朗与美国围绕霍尔木兹海峡通行问题的对峙持续，全球航运出现瓶颈，可用通行时段需求急剧上升，拍卖价格也随之大幅攀升。越来越多商业船只改道巴拿马运河，运输的货物则来自改道或从其他国家采购，以避开伊朗附近水域。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260428-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%8F%97%E9%98%BB%E6%8E%A8%E9%AB%98%E8%88%AA%E8%BF%90%E5%8E%8B%E5%8A%9B%EF%BC%8C%E5%B7%B4%E6%8B%BF%E9%A9%AC%E8%BF%90%E6%B2%B3%E5%8D%95%E8%88%B9%E9%80%9A%E8%A1%8C%E7%AB%9E%E4%BB%B7%E9%A3%99%E8%87%B3400%E4%B8%87%E7%BE%8E%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777393909000.webp","sourceId":"rfi"},{"id":1777393111000,"createdDate":"2026-04-28 16:18","name":"法国国际广播电台","title":"中国商务部长称与欧盟就电动汽车关税达成“软着陆”协议","content":"路透社28日北京消息，中国商务部长王文涛在与德国汽车制造商行业协会负责人会晤时表示，中国和欧盟在欧盟对电动汽车征收进口关税的问题上已经“软着陆”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260428-%E4%B8%AD%E5%9B%BD%E5%95%86%E5%8A%A1%E9%83%A8%E9%95%BF%E7%A7%B0%E4%B8%8E%E6%AC%A7%E7%9B%9F%E5%B0%B1%E7%94%B5%E5%8A%A8%E6%B1%BD%E8%BD%A6%E5%85%B3%E7%A8%8E%E8%BE%BE%E6%88%90-%E8%BD%AF%E7%9D%80%E9%99%86-%E5%8D%8F%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777393111000.webp","sourceId":"rfi"},{"id":1777385859000,"createdDate":"2026-04-28 14:17","name":"法国国际广播电台","title":"特朗普为何不太可能接受伊朗的新提议？","content":"白宫正在考虑伊朗提出的重新开放霍尔木兹海峡的新方案。自中东战争爆发以来，霍尔木兹海峡几乎一直处于瘫痪状态。美国封锁伊朗的港口将致伊朗原油库存爆满，被迫关闭油井。X上可见有地方被迫燃烧石油冒出浓烟。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260428-%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%8D%E5%A4%AA%E5%8F%AF%E8%83%BD%E6%8E%A5%E5%8F%97%E4%BC%8A%E6%9C%97%E6%96%B0%E6%8F%90%E8%AE%AE%E4%B8%BA%E4%BB%80%E4%B9%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777385859000.webp","sourceId":"rfi"},{"id":1777382184000,"createdDate":"2026-04-28 13:16","name":"法国国际广播电台","title":"应对经济困境 中国要在技术和产业链供应链方面拥有更大战略自主权","content":"中国官方今天周二呼吁在技术和产业链供应链方面拥有更大的战略自主权，并提重振国内内需，以应对中国当前面临的经济挑战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260428-%E5%BA%94%E5%AF%B9%E7%BB%8F%E6%B5%8E%E5%9B%B0%E5%A2%83-%E4%B8%AD%E5%9B%BD%E8%A6%81%E5%9C%A8%E6%8A%80%E6%9C%AF%E5%92%8C%E4%BA%A7%E4%B8%9A%E9%93%BE%E4%BE%9B%E5%BA%94%E9%93%BE%E6%96%B9%E9%9D%A2%E6%8B%A5%E6%9C%89%E6%9B%B4%E5%A4%A7%E6%88%98%E7%95%A5%E8%87%AA%E4%B8%BB%E6%9D%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777382184000.webp","sourceId":"rfi"},{"id":1777382029000,"createdDate":"2026-04-28 13:13","name":"法国国际广播电台","title":"法国外长在联合国表示伊朗必须做出“重大让步”才能结束战争","content":"法国外交部长让-诺埃尔-巴罗4月27日在联合国海上安全辩论会上指出，伊朗必须在和平谈判中做出“重大让步”，以结束中东战争。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260428-%E6%B3%95%E5%9B%BD%E5%A4%96%E9%95%BF%E5%9C%A8%E8%81%94%E5%90%88%E5%9B%BD%E8%A1%A8%E7%A4%BA%E4%BC%8A%E6%9C%97%E5%BF%85%E9%A1%BB%E5%81%9A%E5%87%BA-%E9%87%8D%E5%A4%A7%E8%AE%A9%E6%AD%A5-%E6%89%8D%E8%83%BD%E7%BB%93%E6%9D%9F%E6%88%98%E4%BA%89","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777382029000.webp","sourceId":"rfi"},{"id":1777377856000,"createdDate":"2026-04-28 12:04","name":"法国国际广播电台","title":"以色列摩萨德庆祝在伊朗和黎巴嫩取得革命性突破","content":"法新社28日耶路撒冷消息，以色列对外情报机构摩萨德（Mossad）负责人在授勋仪式上赞扬其特工取得的成就，称他们在伊朗和黎巴嫩开展的行动具有“革命性”，包括在德黑兰的斩首行动。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260428-%E4%BB%A5%E8%89%B2%E5%88%97%E6%91%A9%E8%90%A8%E5%BE%B7%E5%BA%86%E7%A5%9D%E5%9C%A8%E4%BC%8A%E6%9C%97%E5%92%8C%E9%BB%8E%E5%B7%B4%E5%AB%A9%E5%8F%96%E5%BE%97%E9%9D%A9%E5%91%BD%E6%80%A7%E7%AA%81%E7%A0%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777377856000.webp","sourceId":"rfi"},{"id":1777374370000,"createdDate":"2026-04-28 11:06","name":"法国国际广播电台","title":"中国出手后 Meta 拟弃 Manus：“新加坡洗白”模式将终结？","content":"据法新社援引《华尔街日报》报道，Meta正准备放弃对人工智能初创公司Manus的收购。Facebook的母公司Meta在去年12月宣布收购Manus，这是一款由一家中国创立但现总部位于新加坡的公司开发的人工智能助理。但中国发改委27日在一份声明中表示，将“禁止外国投资收购Manus项目”，并“要求相关各方撤回收购”。此一事件不仅揭示了中美科技竞争的新动向，更标志着中国对AI技术出海和“新加坡洗白”模式的态度发生根本性转变。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260428-%E4%B8%AD%E5%9B%BD%E5%87%BA%E6%89%8B%E5%90%8E-meta-%E6%8B%9F%E5%BC%83-manus-%E6%96%B0%E5%8A%A0%E5%9D%A1%E6%B4%97%E7%99%BD-%E6%A8%A1%E5%BC%8F%E5%B0%86%E7%BB%88%E7%BB%93","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777374370000.webp","sourceId":"rfi"},{"id":1777371715000,"createdDate":"2026-04-28 10:21","name":"法国国际广播电台","title":"日本首相高市早苗将出访越南与澳大利亚","content":"日本首相高市早苗计划于5月1日至5日访问越南和澳大利亚。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260428-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E5%B0%86%E5%87%BA%E8%AE%BF%E8%B6%8A%E5%8D%97%E4%B8%8E%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777371715000.webp","sourceId":"rfi"},{"id":1777368842000,"createdDate":"2026-04-28 09:34","name":"法国国际广播电台","title":"全球能源危机 哥伦比亚国际峰会旨在逐步淘汰化石燃料","content":"鉴于联合国气候峰会未能帮助各国摆脱对化石能源的依赖，哥伦比亚于4月24日至29日在圣玛尔塔举办此次峰会，汇聚五十多个致力于加速经济脱碳的国家。目前中东战争加剧了石油供应危机，并引发了各国的能源安全担忧并加速了一些国家的绿色能源经济转型。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260428-%E5%85%A8%E7%90%83%E8%83%BD%E6%BA%90%E5%8D%B1%E6%9C%BA-%E5%93%A5%E4%BC%A6%E6%AF%94%E4%BA%9A%E5%9B%BD%E9%99%85%E5%B3%B0%E4%BC%9A%E6%97%A8%E5%9C%A8%E9%80%90%E6%AD%A5%E6%B7%98%E6%B1%B0%E5%8C%96%E7%9F%B3%E7%87%83%E6%96%99","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777368842000.webp","sourceId":"rfi"},{"id":1777368362000,"createdDate":"2026-04-28 09:26","name":"法国国际广播电台","title":"韩国前第一夫人金建熙上诉被加刑 加到4年","content":"韩国前第一夫人金建熙周二上诉法院加重了刑期：她被以操纵股票和腐败罪判处四年有期徒刑。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260428-%E9%9F%A9%E5%9B%BD%E5%89%8D%E7%AC%AC%E4%B8%80%E5%A4%AB%E4%BA%BA%E9%87%91%E5%BB%BA%E7%86%99%E4%B8%8A%E8%AF%89%E8%A2%AB%E5%8A%A0%E5%88%91-20%E4%B8%AA%E6%9C%88%E5%8A%A0%E5%88%B04%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/28/1777368362000.webp","sourceId":"rfi"}]