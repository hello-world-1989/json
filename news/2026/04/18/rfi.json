[{"id":1776500020000,"createdDate":"2026-04-18 08:13","name":"法国国际广播电台","title":"否认滋扰指控 新西兰为其巡逻机靠近中国海空域行动辩护","content":"新西兰周六（4月18日）为其一架空军巡逻机在靠近中国海域执行任务辩护，此前北京方面称该行动损害了中方的安全利益。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260418-%E5%90%A6%E8%AE%A4%E6%BB%8B%E6%89%B0%E6%8C%87%E6%8E%A7-%E6%96%B0%E8%A5%BF%E5%85%B0%E4%B8%BA%E5%85%B6%E5%B7%A1%E9%80%BB%E6%9C%BA%E9%9D%A0%E8%BF%91%E4%B8%AD%E5%9B%BD%E6%B5%B7%E7%A9%BA%E5%9F%9F%E8%A1%8C%E5%8A%A8%E8%BE%A9%E6%8A%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/18/1776500020000.webp","sourceId":"rfi"},{"id":1776522346000,"createdDate":"2026-04-18 14:25","name":"法国国际广播电台","title":"日本自卫队舰艇通过台海后 中国宣布在东海军演","content":"日本自卫队「雷」号护卫舰17日通过台湾海峡引发中国强烈抗议后，中国东部战区宣布18日在东海相关海空域进行海空兵力联合巡航。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260418-%E6%97%A5%E6%9C%AC%E8%87%AA%E5%8D%AB%E9%98%9F%E8%88%B0%E8%89%87%E9%80%9A%E8%BF%87%E5%8F%B0%E6%B5%B7%E5%90%8E-%E4%B8%AD%E5%9B%BD%E5%AE%A3%E5%B8%83%E5%9C%A8%E4%B8%9C%E6%B5%B7%E5%86%9B%E6%BC%94","thumbnail":"","detailImage":"news/detail/rfi/2026/04/18/1776522346000.webp","sourceId":"rfi"},{"id":1776517433000,"createdDate":"2026-04-18 13:03","name":"法国国际广播电台","title":"日本向澳大利亚出口隐形护卫舰 双方签署首批合同","content":"日本和澳大利亚于周六签署了一份合同，约定日本向澳大利亚海军首批交付三艘隐形护卫舰。这是日本自二战以来最大国防出口合同的一部分。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260418-%E6%97%A5%E6%9C%AC%E5%90%91%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E5%87%BA%E5%8F%A3%E9%9A%90%E5%BD%A2%E6%8A%A4%E5%8D%AB%E8%88%B0-%E5%8F%8C%E6%96%B9%E7%AD%BE%E7%BD%B2%E9%A6%96%E6%89%B9%E5%90%88%E5%90%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/18/1776517433000.webp","sourceId":"rfi"},{"id":1776515341000,"createdDate":"2026-04-18 12:29","name":"法国国际广播电台","title":"至少八艘油轮周六已过霍尔木兹海峡","content":"法新社18日伦敦消息，据克莱珀（Kpler）海事追踪数据显示，周六早些时候，至少有八艘油轮和液化气船穿越了霍尔木兹海峡。此前，伊朗于周五下午宣布在停火期间开放该海峡，但周六又改变了立场。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260418-%E4%BC%8A%E6%9C%97%E5%AE%A3%E5%B8%83%E5%86%8D%E5%B0%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%90%8E-%E5%85%AB%E8%89%98%E6%B2%B9%E8%BD%AE%E5%B7%B2%E8%BF%87%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/18/1776515341000.webp","sourceId":"rfi"},{"id":1776513251000,"createdDate":"2026-04-18 11:54","name":"法国国际广播电台","title":"特朗普称若未达成协议美国将维持对伊朗港口的封锁","content":"美国总统唐纳德·特朗普周五晚间在空军一号专机上表示，若未能与德黑兰达成和平协议，他将维持美国对伊朗港口的封锁，并表示，停火协议下周三（22日）到期后，他可能不再延长该协议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260418-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E8%8B%A5%E6%9C%AA%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE%E7%BE%8E%E5%9B%BD%E5%B0%86%E7%BB%B4%E6%8C%81%E5%AF%B9%E4%BC%8A%E6%9C%97%E6%B8%AF%E5%8F%A3%E7%9A%84%E5%B0%81%E9%94%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/18/1776513251000.webp","sourceId":"rfi"},{"id":1776512528000,"createdDate":"2026-04-18 11:42","name":"法国国际广播电台","title":"伊朗周六宣布重新关闭霍尔木兹海峡","content":"伊朗周六18日宣布，鉴于美国继续封锁伊朗港口，伊朗已重新对霍尔木兹海峡实施“严格管控”，并撤销前一天重新开放霍尔木兹海峡的决定。此举被认为给德黑兰与华盛顿之间的和平谈判蒙上阴影。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260418-%E4%BC%8A%E6%9C%97%E5%91%A8%E5%85%AD%E5%AE%A3%E5%B8%83%E9%87%8D%E6%96%B0%E5%85%B3%E9%97%AD%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/18/1776512528000.webp","sourceId":"rfi"},{"id":1776510310000,"createdDate":"2026-04-18 11:05","name":"法国国际广播电台","title":"特朗普急于结束中东危机 伊朗则在拖延","content":"美国总统特朗普声称德黑兰已同意“永不再封锁霍尔木兹海峡”，并将浓缩铀库存移交给美国，伊朗方面则称这些说法“不属实”。华盛顿希望从对手那里获得明确的让步，不过实力被削弱的德黑兰政权正伺机而动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260418-%E7%89%B9%E6%9C%97%E6%99%AE%E6%80%A5%E4%BA%8E%E7%BB%93%E6%9D%9F%E4%B8%AD%E4%B8%9C%E5%8D%B1%E6%9C%BA-%E4%BC%8A%E6%9C%97%E5%88%99%E5%9C%A8%E6%8B%96%E5%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/18/1776510310000.webp","sourceId":"rfi"},{"id":1776509587000,"createdDate":"2026-04-18 10:53","name":"法国国际广播电台","title":"巴基斯坦官员称结束了旨在促进中东和平斡旋","content":"巴基斯坦陆军参谋长和总理周六宣布，已经分别结束了旨在结束中东海湾战争的外交斡旋。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260418-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%AE%98%E5%91%98%E7%A7%B0%E7%BB%93%E6%9D%9F%E4%BA%86%E6%97%A8%E5%9C%A8%E4%BF%83%E8%BF%9B%E4%B8%AD%E4%B8%9C%E5%92%8C%E5%B9%B3%E6%96%A1%E6%97%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/18/1776509587000.webp","sourceId":"rfi"},{"id":1776507243000,"createdDate":"2026-04-18 10:14","name":"法国国际广播电台","title":"中共对台资讯战：利用台湾舆论营造「抵抗徒劳」意象削弱台湾人防卫意志","content":"《路透社》日前报导，中共利用国民党、其他反对派人物及与国民党亲近的网红批评台湾政府的公开发言，透过中国官媒及社群大量输出反民进党资讯。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260418-%E4%B8%AD%E5%85%B1%E5%AF%B9%E5%8F%B0%E8%B5%84%E8%AE%AF%E6%88%98-%E5%88%A9%E7%94%A8%E5%8F%B0%E6%B9%BE%E8%88%86%E8%AE%BA%E8%90%A5%E9%80%A0-%E6%8A%B5%E6%8A%97%E5%BE%92%E5%8A%B3-%E6%84%8F%E8%B1%A1%E5%89%8A%E5%BC%B1%E5%8F%B0%E6%B9%BE%E4%BA%BA%E9%98%B2%E5%8D%AB%E6%84%8F%E5%BF%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/18/1776507243000.webp","sourceId":"rfi"},{"id":1776506111000,"createdDate":"2026-04-18 09:55","name":"法国国际广播电台","title":"霍尔木兹：特朗普强硬外交重新打开海峡","content":"周末出版的左右两份大报《解放报》和《费加罗报》头版主题各有侧重，《解放报》刊出其调查报道，揭示法国用于协助一般利益协会的捐赠免税立法如何被一些种族主义、宣扬暴力的极右翼团体利用用以筹集资金，数额可达到每年数百万欧元。《费加罗报》头版重点关注中东局势，围绕美国总统特朗普在中东的强势外交行动，分析其通过军事打击和经济施压，试图推动伊朗问题和以黎冲突同步降温的策略及初步成效。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260418-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9-%E7%89%B9%E6%9C%97%E6%99%AE%E5%BC%BA%E7%A1%AC%E5%A4%96%E4%BA%A4%E9%87%8D%E6%96%B0%E6%89%93%E5%BC%80%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/18/1776506111000.webp","sourceId":"rfi"},{"id":1776505069000,"createdDate":"2026-04-18 09:37","name":"法国国际广播电台","title":"七国集团财长汇聚华盛顿商讨对抗中国稀土垄断","content":"七国集团（G7）以及资源国等的财长们于日本时间18日上午在美国华盛顿召开了有关重要矿产的G7扩大会议。会议围绕稀土等关键矿产的稳定供应展开了讨论。日本财务大臣片山皋月出席并共同主持了会议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260418-%E4%B8%83%E5%9B%BD%E9%9B%86%E5%9B%A2%E8%B4%A2%E9%95%BF%E6%B1%87%E8%81%9A%E5%8D%8E%E7%9B%9B%E9%A1%BF%E5%95%86%E8%AE%A8%E5%AF%B9%E6%8A%97%E4%B8%AD%E5%9B%BD%E7%A8%80%E5%9C%9F%E5%9E%84%E6%96%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/18/1776505069000.webp","sourceId":"rfi"}]