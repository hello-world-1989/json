[{"id":1776157107000,"createdDate":"2026-04-14 08:58","name":"法国国际广播电台","title":"欧盟驻华商会：中国稀土审批程序仍然缓慢且不透明，促使欧洲企业调整在华业务战略，努力寻求“替代方案”","content":"中国在全球稀土产业中占据主导地位。欧盟商会周二（4月14日）警告称，中国对稀土出口实施的严格管控正在打乱欧洲企业在华业务战略。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260414-%E6%AC%A7%E7%9B%9F%E9%A9%BB%E5%8D%8E%E5%95%86%E4%BC%9A-%E4%B8%AD%E5%9B%BD%E7%A8%80%E5%9C%9F%E5%AE%A1%E6%89%B9%E7%A8%8B%E5%BA%8F%E4%BB%8D%E7%84%B6%E7%BC%93%E6%85%A2%E4%B8%94%E4%B8%8D%E9%80%8F%E6%98%8E%EF%BC%8C%E4%BF%83%E4%BD%BF%E6%AC%A7%E6%B4%B2%E4%BC%81%E4%B8%9A%E8%B0%83%E6%95%B4%E5%9C%A8%E5%8D%8E%E4%B8%9A%E5%8A%A1%E6%88%98%E7%95%A5%EF%BC%8C%E5%8A%AA%E5%8A%9B%E5%AF%BB%E6%B1%82-%E6%9B%BF%E4%BB%A3%E6%96%B9%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776157107000.webp","sourceId":"rfi"},{"id":1776156872000,"createdDate":"2026-04-14 08:54","name":"法国国际广播电台","title":"恒大欺诈案开审 许家印认罪","content":"中国官媒报道，恒大欺诈案昨(13日)天起一连两天在深圳市中级人民法院开审，被告人许家印当庭表示认罪悔罪，法庭将择日判刑。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E6%81%92%E5%A4%A7%E6%AC%BA%E8%AF%88%E6%A1%88%E5%BC%80%E5%AE%A1-%E8%AE%B8%E5%AE%B6%E5%8D%B0%E8%AE%A4%E7%BD%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776156872000.webp","sourceId":"rfi"},{"id":1776156823000,"createdDate":"2026-04-14 08:53","name":"法国国际广播电台","title":"再有香港记者受跟踪骚扰 记协查询保安局求保证 反被指责","content":"在香港新闻自由排名每况愈下之际，近月再发生媒体记者收滋扰信息和被不明身份人士跟踪事件，媒体向警方报案後，至今未有回覆；业界工会除强烈谴责事件会对记者造成心理压力之外，更向保安局查询及要求澄清执法机关有否监视或跟踪记者，却反遭对方指工会捕风捉影。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E5%86%8D%E6%9C%89%E9%A6%99%E6%B8%AF%E8%AE%B0%E8%80%85%E5%8F%97%E8%B7%9F%E8%B8%AA%E9%AA%9A%E6%89%B0-%E8%AE%B0%E5%8D%8F%E6%9F%A5%E8%AF%A2%E4%BF%9D%E5%AE%89%E5%B1%80%E6%B1%82%E4%BF%9D%E8%AF%81-%E5%8F%8D%E8%A2%AB%E6%8C%87%E8%B4%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776156823000.webp","sourceId":"rfi"},{"id":1776156736000,"createdDate":"2026-04-14 08:52","name":"法国国际广播电台","title":"中国立法反制「不当域外管辖」阻外国长臂管辖 在华跨国企业营运风险增","content":"继反对外国制裁之後，中国再立法将反对范围扩大至所有「不当域外管辖」，在华组织或个人均须拒绝执行相关不当域外管辖，而中国政府更有权对相关国家采取包括贸易在内的反制措施。新例料将令在华跨国企业堕入两难局面。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E4%B8%AD%E5%9B%BD%E7%AB%8B%E6%B3%95%E5%8F%8D%E5%88%B6-%E4%B8%8D%E5%BD%93%E5%9F%9F%E5%A4%96%E7%AE%A1%E8%BE%96-%E9%98%BB%E5%A4%96%E5%9B%BD%E9%95%BF%E8%87%82%E7%AE%A1%E8%BE%96-%E5%9C%A8%E5%8D%8E%E8%B7%A8%E5%9B%BD%E4%BC%81%E4%B8%9A%E8%90%A5%E8%BF%90%E9%A3%8E%E9%99%A9%E5%A2%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776156736000.webp","sourceId":"rfi"},{"id":1776156463000,"createdDate":"2026-04-14 08:47","name":"法国国际广播电台","title":"法新社：中国经济短期能够抵御中东战争带来的冲击，但若战争引发全球经济普遍放缓，中国出口也将受到影响","content":"法新社周二（4月14日）消息称，分析人士认为，年初中国经济增长有所加快，尽管中东战争和内需疲软带来压力，但出口增长为经济提供了支撑。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260414-%E6%B3%95%E6%96%B0%E7%A4%BE-%E4%B8%AD%E5%9B%BD%E7%BB%8F%E6%B5%8E%E7%9F%AD%E6%9C%9F%E8%83%BD%E5%A4%9F%E6%8A%B5%E5%BE%A1%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E5%B8%A6%E6%9D%A5%E7%9A%84%E5%86%B2%E5%87%BB%EF%BC%8C%E4%BD%86%E8%8B%A5%E6%88%98%E4%BA%89%E5%BC%95%E5%8F%91%E5%85%A8%E7%90%83%E7%BB%8F%E6%B5%8E%E6%99%AE%E9%81%8D%E6%94%BE%E7%BC%93%EF%BC%8C%E4%B8%AD%E5%9B%BD%E5%87%BA%E5%8F%A3%E4%B9%9F%E5%B0%86%E5%8F%97%E5%88%B0%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776156463000.webp","sourceId":"rfi"},{"id":1776155927000,"createdDate":"2026-04-14 08:38","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第24：浪漫主义群星之三：荷尔德林 ：第七节：诗与思的二重奏","content":"归根到底荷尔德林是诗人，不过他是一位意义独特的诗人。用海德格尔的话说，他是“诗人的诗人”因为他的诗体现了“诗之本质”。什么是诗？诗人何为？诗思与哲学在何处同一？诗人荷尔德林和哲人海德格尔共同操演了一首精美绝伦的诗与思的二重奏。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260414-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%89-%E8%8D%B7%E5%B0%94%E5%BE%B7%E6%9E%97-%E7%AC%AC%E4%B8%83%E8%8A%82-%E8%AF%97%E4%B8%8E%E6%80%9D%E7%9A%84%E4%BA%8C%E9%87%8D%E5%A5%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776155927000.webp","sourceId":"rfi"},{"id":1776155475000,"createdDate":"2026-04-14 08:31","name":"法国国际广播电台","title":"中国经济：3月出口增速明显低于预期，进口却大幅增长，3月对美出口同比下滑26.5%","content":"中国官方周二（4月14日）公布的数据显示，在中东战争冲击全球经济的背景下，中国3月份出口增速明显低于预期，而进口则出现增长。此外，中国海关数据显示，3月份对美出口额为294亿美元，较2025年3月大幅下滑26.5%。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E4%B8%AD%E5%9B%BD%E7%BB%8F%E6%B5%8E-3%E6%9C%88%E5%87%BA%E5%8F%A3%E5%A2%9E%E9%80%9F%E6%98%8E%E6%98%BE%E4%BD%8E%E4%BA%8E%E9%A2%84%E6%9C%9F%EF%BC%8C%E8%BF%9B%E5%8F%A3%E5%8D%B4%E5%A4%A7%E5%B9%85%E5%A2%9E%E9%95%BF%EF%BC%8C3%E6%9C%88%E5%AF%B9%E7%BE%8E%E5%87%BA%E5%8F%A3%E5%90%8C%E6%AF%94%E4%B8%8B%E6%BB%9126-5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776155475000.webp","sourceId":"rfi"},{"id":1776155395000,"createdDate":"2026-04-14 08:29","name":"法国国际广播电台","title":"习近平：面对全球“混乱”加强中西经贸关系，桑切斯：“中国可发挥重要作用”解决中东冲突","content":"法新社北京消息，中国国家主席习近平周二14日会见西班牙首相桑切斯时警告称，国际关系不应回归“丛林法则”，并呼吁加强中西两国的经济联系。桑切斯此次访华为期三天，访问的第二天他与习近平举行会谈。桑切斯试图将西班牙定位为北京与欧盟之间的桥梁，而欧盟与美国的关系正面临紧张。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E4%B9%A0%E8%BF%91%E5%B9%B3-%E9%9D%A2%E5%AF%B9%E5%85%A8%E7%90%83-%E6%B7%B7%E4%B9%B1-%E5%8A%A0%E5%BC%BA%E4%B8%AD%E8%A5%BF%E7%BB%8F%E8%B4%B8%E5%85%B3%E7%B3%BB%EF%BC%8C%E6%A1%91%E5%88%87%E6%96%AF-%E4%B8%AD%E5%9B%BD%E5%8F%AF%E5%8F%91%E6%8C%A5%E9%87%8D%E8%A6%81%E4%BD%9C%E7%94%A8-%E8%A7%A3%E5%86%B3%E4%B8%AD%E4%B8%9C%E5%86%B2%E7%AA%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776155395000.webp","sourceId":"rfi"},{"id":1776155376000,"createdDate":"2026-04-14 08:29","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第24：浪漫主义群星之三：荷尔德林：第六节：狄奥提玛的嘱托","content":"通信体小说《许佩里翁》的写作修改过程，特别是第二卷的写作过程，与荷尔德林同苏赛特，他心目中的狄奥提玛，的相爱紧密相关。小说中许佩里翁与狄奥提玛的大量通信阐述了荷尔德林最重要的哲学、诗学思考。狄奥提玛给了许佩里翁一个重要嘱托。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260414-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%89-%E8%8D%B7%E5%B0%94%E5%BE%B7%E6%9E%97-%E7%AC%AC%E5%85%AD%E8%8A%82-%E7%8B%84%E5%A5%A5%E6%8F%90%E7%8E%9B%E7%9A%84%E5%98%B1%E6%89%98","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776155376000.webp","sourceId":"rfi"},{"id":1776154586000,"createdDate":"2026-04-14 08:16","name":"法国国际广播电台","title":"习近平呼吁在中东地区尊重国际法，承诺中国将发挥“建设性”作用","content":"中国国家主席习近平周二（4月14日）呼吁在中东地区尊重各国主权和国际法，并表示中国将继续在推动和平方面发挥“建设性”作用。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260414-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%91%BC%E5%90%81%E5%9C%A8%E4%B8%AD%E4%B8%9C%E5%9C%B0%E5%8C%BA%E5%B0%8A%E9%87%8D%E5%9B%BD%E9%99%85%E6%B3%95%EF%BC%8C%E6%89%BF%E8%AF%BA%E4%B8%AD%E5%9B%BD%E5%B0%86%E5%8F%91%E6%8C%A5-%E5%BB%BA%E8%AE%BE%E6%80%A7-%E4%BD%9C%E7%94%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776154586000.webp","sourceId":"rfi"},{"id":1776154505000,"createdDate":"2026-04-14 08:15","name":"法国国际广播电台","title":"日本与巴基斯坦举行首脑会谈  支持巴基斯坦促进美伊和谈","content":"日本时间4月13日下午，日本首相高市早苗与巴基斯坦总理夏巴兹·谢里夫举行了电话会谈。日方表示，重要的是切实实现包括确保霍尔木兹海峡航行安全在内的局势降温，并通过协商尽早达成最终协议，这是日本的一贯立场。而在日本时间14日上午的日本内阁官房长官木原稔主持的记者会上，木原围绕美国开始实施封锁霍尔木兹海峡的措施重申了“尽早确保自由、安全航行至关重要”的立场。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260414-%E6%97%A5%E6%9C%AC%E4%B8%8E%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E4%B8%BE%E8%A1%8C%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88-%E6%94%AF%E6%8C%81%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E4%BF%83%E8%BF%9B%E7%BE%8E%E4%BC%8A%E5%92%8C%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776154505000.webp","sourceId":"rfi"},{"id":1776154293000,"createdDate":"2026-04-14 08:11","name":"法国国际广播电台","title":"朝鲜再进行海上导弹试射","content":"朝鲜再次进行海上导弹试射。据朝鲜官媒朝中社周二（4月14日）报道，朝鲜领导人金正恩观摩了此次从海军驱逐舰上发射的巡航导弹和反舰导弹试射。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260414-%E6%9C%9D%E9%B2%9C%E5%86%8D%E6%AC%A1%E8%BF%9B%E8%A1%8C%E6%B5%B7%E4%B8%8A%E5%AF%BC%E5%BC%B9%E8%AF%95%E5%B0%84","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776154293000.webp","sourceId":"rfi"},{"id":1776154175000,"createdDate":"2026-04-14 08:09","name":"法国国际广播电台","title":"台湾首位中配立委上任70天后画下国会生涯句点 民众党决议开除李贞秀党籍","content":"民众党中评会在13日一致决议开除李贞秀党籍，台湾首位中配立委的国会生涯也就此止步。虽然李贞秀任期仅短短70天，但期间她接连陷入双重国籍争议与发言风波。李贞秀发声明，从政是为向社会证明，中配立委具备充分问政能力与正当性。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E5%8F%B0%E6%B9%BE%E9%A6%96%E4%BD%8D%E4%B8%AD%E9%85%8D%E7%AB%8B%E5%A7%94%E4%B8%8A%E4%BB%BB70%E5%A4%A9%E5%90%8E%E7%94%BB%E4%B8%8B%E5%9B%BD%E4%BC%9A%E7%94%9F%E6%B6%AF%E5%8F%A5%E7%82%B9-%E6%B0%91%E4%BC%97%E5%85%9A%E5%86%B3%E8%AE%AE%E5%BC%80%E9%99%A4%E6%9D%8E%E8%B4%9E%E7%A7%80%E5%85%9A%E7%B1%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776154175000.webp","sourceId":"rfi"},{"id":1776183577000,"createdDate":"2026-04-14 16:19","name":"法国国际广播电台","title":"中国逾70支队伍推出100台人形机器人参加第二届机器人半程马拉松比赛","content":"各位听众，超过100台机器人由70支队伍促成参加半程马拉松比赛，旨在测试人形机器人在真实环境下的极限性能。中国：人形机器人参加第二届机器人半程马拉松比赛。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E4%B8%AD%E5%9B%BD-%E9%80%BE70%E5%85%B7%E4%BA%BA%E5%BD%A2%E6%9C%BA%E5%99%A8%E4%BA%BA%E5%8F%82%E5%8A%A0%E7%AC%AC%E4%BA%8C%E5%B1%8A%E6%9C%BA%E5%99%A8%E4%BA%BA%E5%8D%8A%E7%A8%8B%E9%A9%AC%E6%8B%89%E6%9D%BE%E6%AF%94%E8%B5%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776183577000.webp","sourceId":"rfi"},{"id":1776178107000,"createdDate":"2026-04-14 14:48","name":"法国国际广播电台","title":"以色列黎巴嫩和平谈判在即，法英等17个国家呼吁“抓住机会”","content":"包括法国和英国在内的17个国家周二（4月14日）呼吁黎巴嫩与以色列“抓住机会”，推进即将在华盛顿举行的和平谈判（这是自1993年以来两国首次举行直接会谈）。据悉，以色列与黎巴嫩之间的会谈将于周二上午晚些时候由美国国务卿卢比奥斡旋，真主党将缺席。会谈参与者包括以色列驻美大使耶希埃尔·莱特、黎巴嫩驻美大使纳达·哈马德·莫阿瓦德以及美国驻黎巴嫩大使米歇尔·伊萨。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260414-%E4%BB%A5%E8%89%B2%E5%88%97%E9%BB%8E%E5%B7%B4%E5%AB%A9%E5%92%8C%E5%B9%B3%E8%B0%88%E5%88%A4%E5%9C%A8%E5%8D%B3%EF%BC%8C%E6%B3%95%E8%8B%B1%E7%AD%8917%E4%B8%AA%E5%9B%BD%E5%AE%B6%E5%91%BC%E5%90%81-%E6%8A%93%E4%BD%8F%E6%9C%BA%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776178107000.webp","sourceId":"rfi"},{"id":1776175705000,"createdDate":"2026-04-14 14:08","name":"法国国际广播电台","title":"美国宣布实施封锁后，仍有两艘伊朗船只穿越了霍尔木兹海峡，另有一艘中国船只也成功通行","content":"海事数据公司Kpler周二（4月14日）表示，自美国于周一14时（格林尼治时间）开始实施军事封锁后，至少有两艘来自伊朗港口的船只成功穿越了霍尔木兹海峡。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260414-%E7%BE%8E%E5%9B%BD%E5%AE%A3%E5%B8%83%E5%AE%9E%E6%96%BD%E5%B0%81%E9%94%81%E5%90%8E%EF%BC%8C%E4%BB%8D%E6%9C%89%E4%B8%A4%E8%89%98%E4%BC%8A%E6%9C%97%E8%88%B9%E5%8F%AA%E7%A9%BF%E8%B6%8A%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%EF%BC%8C%E5%8F%A6%E6%9C%89%E4%B8%80%E8%89%98%E4%B8%AD%E5%9B%BD%E8%88%B9%E5%8F%AA%E4%B9%9F%E6%88%90%E5%8A%9F%E9%80%9A%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776175705000.webp","sourceId":"rfi"},{"id":1776172360000,"createdDate":"2026-04-14 13:12","name":"法国国际广播电台","title":"欧盟出台重磅计划 扶持钢铁行业","content":"欧盟批准了一项重要欧洲钢铁行业扶持计划，以援助陷入危机的该行业，来应对由于中国销售产能过剩钢铁以及特朗普政府加征的关税，让欧洲钢铁行业遭受的双重打击。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E6%AC%A7%E7%9B%9F%E5%87%BA%E5%8F%B0%E9%87%8D%E7%A3%85%E8%AE%A1%E5%88%92-%E6%89%B6%E6%8C%81%E9%92%A2%E9%93%81%E8%A1%8C%E4%B8%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776172360000.webp","sourceId":"rfi"},{"id":1776169032000,"createdDate":"2026-04-14 12:17","name":"法国国际广播电台","title":"中国外交人事又传异动！副外长孙卫东突“被免职”","content":"中国外交系统再出现人事震荡！根据中国人社部14日发布的国务院任免名单，外交部副部长孙卫东被免去职务，但未公布他的去向，加上他尚未届满退休年龄，引发外界揣测","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E4%B8%AD%E5%9B%BD%E5%A4%96%E4%BA%A4%E4%BA%BA%E4%BA%8B%E5%8F%88%E5%8A%A8-%E5%89%AF%E5%A4%96%E9%95%BF%E5%AD%99%E5%8D%AB%E4%B8%9C%E7%AA%81-%E8%A2%AB%E5%85%8D%E8%81%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776169032000.webp","sourceId":"rfi"},{"id":1776168409000,"createdDate":"2026-04-14 12:06","name":"法国国际广播电台","title":"霍尔木兹海峡封锁启示 台湾有何准备？彭博：应对解放军 台拟布局日、菲、美三条航运通道","content":"美国总统特朗普周一13日明确警告，任何伊朗快艇若接近美国海军在伊朗港口周围设置的封锁线，都将遭到摧毁，尽管国际社会持续呼吁各方必须遵守停火协议并尽快恢复谈判。周二，中国表示，美国对伊朗港口的封锁是“危险且不负责任的”。面对霍尔木兹海峡被封锁导致的能源危机，台湾将在近期进行新的演习，以确保在遭到中国封锁的情况下，台湾仍能获得关键物资供应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260414-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%8D%B1%E6%9C%BA-%E5%8F%B0%E6%B9%BE%E6%9C%89%E4%BD%95%E5%87%86%E5%A4%87-%E5%BD%AD%E5%8D%9A-%E5%8F%B0%E6%8B%9F%E5%B8%83%E5%B1%80%E6%97%A5-%E8%8F%B2-%E7%BE%8E%E4%B8%89%E6%9D%A1%E8%88%AA%E8%BF%90%E9%80%9A%E9%81%93","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776168409000.webp","sourceId":"rfi"},{"id":1776164421000,"createdDate":"2026-04-14 11:00","name":"法国国际广播电台","title":"当政治人物受审：从柯文哲案看台湾民主与司法","content":"近期，台湾政坛最受瞩目的事件之一，莫过于前台北市长与2024总统选举候选人柯文哲所涉及的贪污与政治献金争议。这起案件不仅是一宗单纯的司法事件，更引发了一连串更深层的问题：台湾的民主制度，尤其是选举制度，是否在某种程度上助长了此类争议？而司法体系，又能否在高度政治化的环境中维持其应有的公正与独立？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%85%AC%E6%B0%91%E8%AE%BA%E5%9D%9B/20260414-%E5%BD%93%E6%94%BF%E6%B2%BB%E4%BA%BA%E7%89%A9%E5%8F%97%E5%AE%A1-%E4%BB%8E%E6%9F%AF%E6%96%87%E5%93%B2%E6%A1%88%E7%9C%8B%E5%8F%B0%E6%B9%BE%E6%B0%91%E4%B8%BB%E4%B8%8E%E5%8F%B8%E6%B3%95","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776164421000.webp","sourceId":"rfi"},{"id":1776160447000,"createdDate":"2026-04-14 09:54","name":"法国国际广播电台","title":"消息人士透露：美国与伊朗的谈判或将在伊斯兰堡重启，可能在本周末或下周初会面","content":"路透社周二（4月14日）消息显示，据五名了解谈判情况的消息人士称，在上周末第一轮谈判失败后，伊朗与美国之间的谈判可能很快在伊斯兰堡重启。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260414-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB%E9%80%8F%E9%9C%B2-%E7%BE%8E%E5%9B%BD%E4%B8%8E%E4%BC%8A%E6%9C%97%E7%9A%84%E8%B0%88%E5%88%A4%E6%88%96%E5%B0%86%E5%9C%A8%E4%BC%8A%E6%96%AF%E5%85%B0%E5%A0%A1%E9%87%8D%E5%90%AF%EF%BC%8C%E5%8F%AF%E8%83%BD%E5%9C%A8%E6%9C%AC%E5%91%A8%E6%9C%AB%E6%88%96%E4%B8%8B%E5%91%A8%E5%88%9D%E4%BC%9A%E9%9D%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776160447000.webp","sourceId":"rfi"},{"id":1776159893000,"createdDate":"2026-04-14 09:44","name":"法国国际广播电台","title":"默茨与泽连斯基在柏林会晤 将加强德乌无人机合作","content":"作为乌克兰战争中对基辅提供最多援助的国家领导人之一，德国总理默茨周二（4月14日）在柏林接待乌克兰总统泽连斯基，希望借此加强欧洲防务合作。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260414-%E9%BB%98%E8%8C%A8%E4%B8%8E%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E5%9C%A8%E6%9F%8F%E6%9E%97%E4%BC%9A%E6%99%A4-%E5%B0%86%E5%8A%A0%E5%BC%BA%E5%BE%B7%E4%B9%8C%E6%97%A0%E4%BA%BA%E6%9C%BA%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776159893000.webp","sourceId":"rfi"},{"id":1776159356000,"createdDate":"2026-04-14 09:35","name":"法国国际广播电台","title":"台湾检方：10名台湾人被控为北京从事间谍活动，其中9人为现役或退役军人","content":"台湾检方周二（4月14日）表示，包括仍在服役军人在内的10名台湾人因涉嫌间谍活动被起诉，罪名包括拍摄向北京效忠的视频以及泄露机密信息。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E5%8F%B0%E6%B9%BE%E6%A3%80%E6%96%B9-10%E5%90%8D%E5%8F%B0%E6%B9%BE%E4%BA%BA%E8%A2%AB%E6%8E%A7%E4%B8%BA%E5%8C%97%E4%BA%AC%E4%BB%8E%E4%BA%8B%E9%97%B4%E8%B0%8D%E6%B4%BB%E5%8A%A8%EF%BC%8C%E5%85%B6%E4%B8%AD9%E4%BA%BA%E4%B8%BA%E7%8E%B0%E5%BD%B9%E6%88%96%E9%80%80%E5%BD%B9%E5%86%9B%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776159356000.webp","sourceId":"rfi"},{"id":1776158788000,"createdDate":"2026-04-14 09:26","name":"法国国际广播电台","title":"特朗普威胁：将摧毁任何突破港口封锁的伊朗军舰  伊朗回应：或对海湾邻国港口采取报复行动","content":"美国总统特朗普周一（4月14日）威胁称，将“摧毁”任何试图突破伊朗港口封锁的“伊朗快速攻击艇”。该封锁已在美伊谈判破裂次日正式生效。伊朗谴责这一举动为“非法”的“海盗行为”，并警告称，如果“伊朗伊斯兰共和国港口的安全受到威胁”，将对海湾邻国港口采取报复行动。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260414-%E7%89%B9%E6%9C%97%E6%99%AE%E5%A8%81%E8%83%81-%E5%B0%86%E6%91%A7%E6%AF%81%E4%BB%BB%E4%BD%95%E7%AA%81%E7%A0%B4%E6%B8%AF%E5%8F%A3%E5%B0%81%E9%94%81%E7%9A%84%E4%BC%8A%E6%9C%97%E5%86%9B%E8%88%B0-%E4%BC%8A%E6%9C%97%E5%9B%9E%E5%BA%94-%E6%88%96%E5%AF%B9%E6%B5%B7%E6%B9%BE%E9%82%BB%E5%9B%BD%E6%B8%AF%E5%8F%A3%E9%87%87%E5%8F%96%E6%8A%A5%E5%A4%8D%E8%A1%8C%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776158788000.webp","sourceId":"rfi"}]