[{"id":1776157107000,"createdDate":"2026-04-14 08:58","name":"法国国际广播电台","title":"欧盟驻华商会：中国稀土审批程序仍然缓慢且不透明，促使欧洲企业调整在华业务战略，努力寻求“替代方案”","content":"中国在全球稀土产业中占据主导地位。欧盟商会周二（4月14日）警告称，中国对稀土出口实施的严格管控正在打乱欧洲企业在华业务战略。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260414-%E6%AC%A7%E7%9B%9F%E9%A9%BB%E5%8D%8E%E5%95%86%E4%BC%9A-%E4%B8%AD%E5%9B%BD%E7%A8%80%E5%9C%9F%E5%AE%A1%E6%89%B9%E7%A8%8B%E5%BA%8F%E4%BB%8D%E7%84%B6%E7%BC%93%E6%85%A2%E4%B8%94%E4%B8%8D%E9%80%8F%E6%98%8E%EF%BC%8C%E4%BF%83%E4%BD%BF%E6%AC%A7%E6%B4%B2%E4%BC%81%E4%B8%9A%E8%B0%83%E6%95%B4%E5%9C%A8%E5%8D%8E%E4%B8%9A%E5%8A%A1%E6%88%98%E7%95%A5%EF%BC%8C%E5%8A%AA%E5%8A%9B%E5%AF%BB%E6%B1%82-%E6%9B%BF%E4%BB%A3%E6%96%B9%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776157107000.webp","sourceId":"rfi"},{"id":1776156872000,"createdDate":"2026-04-14 08:54","name":"法国国际广播电台","title":"恒大欺诈案开审 许家印认罪","content":"中国官媒报道，恒大欺诈案昨(13日)天起一连两天在深圳市中级人民法院开审，被告人许家印当庭表示认罪悔罪，法庭将择日判刑。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E6%81%92%E5%A4%A7%E6%AC%BA%E8%AF%88%E6%A1%88%E5%BC%80%E5%AE%A1-%E8%AE%B8%E5%AE%B6%E5%8D%B0%E8%AE%A4%E7%BD%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776156872000.webp","sourceId":"rfi"},{"id":1776156823000,"createdDate":"2026-04-14 08:53","name":"法国国际广播电台","title":"再有香港记者受跟踪骚扰 记协查询保安局求保证 反被指责","content":"在香港新闻自由排名每况愈下之际，近月再发生媒体记者收滋扰信息和被不明身份人士跟踪事件，媒体向警方报案後，至今未有回覆；业界工会除强烈谴责事件会对记者造成心理压力之外，更向保安局查询及要求澄清执法机关有否监视或跟踪记者，却反遭对方指工会捕风捉影。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E5%86%8D%E6%9C%89%E9%A6%99%E6%B8%AF%E8%AE%B0%E8%80%85%E5%8F%97%E8%B7%9F%E8%B8%AA%E9%AA%9A%E6%89%B0-%E8%AE%B0%E5%8D%8F%E6%9F%A5%E8%AF%A2%E4%BF%9D%E5%AE%89%E5%B1%80%E6%B1%82%E4%BF%9D%E8%AF%81-%E5%8F%8D%E8%A2%AB%E6%8C%87%E8%B4%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776156823000.webp","sourceId":"rfi"},{"id":1776156736000,"createdDate":"2026-04-14 08:52","name":"法国国际广播电台","title":"中国立法反制「不当域外管辖」阻外国长臂管辖 在华跨国企业营运风险增","content":"继反对外国制裁之後，中国再立法将反对范围扩大至所有「不当域外管辖」，在华组织或个人均须拒绝执行相关不当域外管辖，而中国政府更有权对相关国家采取包括贸易在内的反制措施。新例料将令在华跨国企业堕入两难局面。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E4%B8%AD%E5%9B%BD%E7%AB%8B%E6%B3%95%E5%8F%8D%E5%88%B6-%E4%B8%8D%E5%BD%93%E5%9F%9F%E5%A4%96%E7%AE%A1%E8%BE%96-%E9%98%BB%E5%A4%96%E5%9B%BD%E9%95%BF%E8%87%82%E7%AE%A1%E8%BE%96-%E5%9C%A8%E5%8D%8E%E8%B7%A8%E5%9B%BD%E4%BC%81%E4%B8%9A%E8%90%A5%E8%BF%90%E9%A3%8E%E9%99%A9%E5%A2%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776156736000.webp","sourceId":"rfi"},{"id":1776156463000,"createdDate":"2026-04-14 08:47","name":"法国国际广播电台","title":"法新社：中国经济短期能够抵御中东战争带来的冲击，但若战争引发全球经济普遍放缓，中国出口也将受到影响","content":"法新社周二（4月14日）消息称，分析人士认为，年初中国经济增长有所加快，尽管中东战争和内需疲软带来压力，但出口增长为经济提供了支撑。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260414-%E6%B3%95%E6%96%B0%E7%A4%BE-%E4%B8%AD%E5%9B%BD%E7%BB%8F%E6%B5%8E%E7%9F%AD%E6%9C%9F%E8%83%BD%E5%A4%9F%E6%8A%B5%E5%BE%A1%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E5%B8%A6%E6%9D%A5%E7%9A%84%E5%86%B2%E5%87%BB%EF%BC%8C%E4%BD%86%E8%8B%A5%E6%88%98%E4%BA%89%E5%BC%95%E5%8F%91%E5%85%A8%E7%90%83%E7%BB%8F%E6%B5%8E%E6%99%AE%E9%81%8D%E6%94%BE%E7%BC%93%EF%BC%8C%E4%B8%AD%E5%9B%BD%E5%87%BA%E5%8F%A3%E4%B9%9F%E5%B0%86%E5%8F%97%E5%88%B0%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776156463000.webp","sourceId":"rfi"},{"id":1776155927000,"createdDate":"2026-04-14 08:38","name":"法国国际广播电台","title":"欧洲思想文化长廊:德国浪漫主义第24：浪漫主义群星之三：荷尔德林 ：第七节：诗与思的二重奏","content":"归根到底荷尔德林是诗人，不过他是一位意义独特的诗人。用海德格尔的话说，他是“诗人的诗人”因为他的诗体现了“诗之本质”。什么是诗？诗人何为？诗思与哲学在何处同一？诗人荷尔德林和哲人海德格尔共同操演了一首精美绝伦的诗与思的二重奏。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260414-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%89-%E8%8D%B7%E5%B0%94%E5%BE%B7%E6%9E%97-%E7%AC%AC%E4%B8%83%E8%8A%82-%E8%AF%97%E4%B8%8E%E6%80%9D%E7%9A%84%E4%BA%8C%E9%87%8D%E5%A5%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776155927000.webp","sourceId":"rfi"},{"id":1776155475000,"createdDate":"2026-04-14 08:31","name":"法国国际广播电台","title":"中国经济：3月出口增速明显低于预期，进口却大幅增长，3月对美出口同比下滑26.5%","content":"中国官方周二（4月14日）公布的数据显示，在中东战争冲击全球经济的背景下，中国3月份出口增速明显低于预期，而进口则出现增长。此外，中国海关数据显示，3月份对美出口额为294亿美元，较2025年3月大幅下滑26.5%。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E4%B8%AD%E5%9B%BD%E7%BB%8F%E6%B5%8E-3%E6%9C%88%E5%87%BA%E5%8F%A3%E5%A2%9E%E9%80%9F%E6%98%8E%E6%98%BE%E4%BD%8E%E4%BA%8E%E9%A2%84%E6%9C%9F%EF%BC%8C%E8%BF%9B%E5%8F%A3%E5%8D%B4%E5%A4%A7%E5%B9%85%E5%A2%9E%E9%95%BF%EF%BC%8C3%E6%9C%88%E5%AF%B9%E7%BE%8E%E5%87%BA%E5%8F%A3%E5%90%8C%E6%AF%94%E4%B8%8B%E6%BB%9126-5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776155475000.webp","sourceId":"rfi"},{"id":1776155395000,"createdDate":"2026-04-14 08:29","name":"法国国际广播电台","title":"习近平：面对全球“混乱”加强中西经贸关系，桑切斯：“中国可发挥重要作用”解决中东冲突","content":"法新社北京消息，中国国家主席习近平周二14日会见西班牙首相桑切斯时警告称，国际关系不应回归“丛林法则”，并呼吁加强中西两国的经济联系。桑切斯此次访华为期三天，访问的第二天他与习近平举行会谈。桑切斯试图将西班牙定位为北京与欧盟之间的桥梁，而欧盟与美国的关系正面临紧张。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E4%B9%A0%E8%BF%91%E5%B9%B3-%E9%9D%A2%E5%AF%B9%E5%85%A8%E7%90%83-%E6%B7%B7%E4%B9%B1-%E5%8A%A0%E5%BC%BA%E4%B8%AD%E8%A5%BF%E7%BB%8F%E8%B4%B8%E5%85%B3%E7%B3%BB%EF%BC%8C%E6%A1%91%E5%88%87%E6%96%AF-%E4%B8%AD%E5%9B%BD%E5%8F%AF%E5%8F%91%E6%8C%A5%E9%87%8D%E8%A6%81%E4%BD%9C%E7%94%A8-%E8%A7%A3%E5%86%B3%E4%B8%AD%E4%B8%9C%E5%86%B2%E7%AA%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776155395000.webp","sourceId":"rfi"},{"id":1776155376000,"createdDate":"2026-04-14 08:29","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第24：浪漫主义群星之三：荷尔德林：第六节：狄奥提玛的嘱托","content":"通信体小说《许佩里翁》的写作修改过程，特别是第二卷的写作过程，与荷尔德林同苏赛特，他心目中的狄奥提玛，的相爱紧密相关。小说中许佩里翁与狄奥提玛的大量通信阐述了荷尔德林最重要的哲学、诗学思考。狄奥提玛给了许佩里翁一个重要嘱托。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260414-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%89-%E8%8D%B7%E5%B0%94%E5%BE%B7%E6%9E%97-%E7%AC%AC%E5%85%AD%E8%8A%82-%E7%8B%84%E5%A5%A5%E6%8F%90%E7%8E%9B%E7%9A%84%E5%98%B1%E6%89%98","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776155376000.webp","sourceId":"rfi"},{"id":1776154586000,"createdDate":"2026-04-14 08:16","name":"法国国际广播电台","title":"习近平呼吁在中东地区尊重国际法，承诺中国将发挥“建设性”作用","content":"中国国家主席习近平周二（4月14日）呼吁在中东地区尊重各国主权和国际法，并表示中国将继续在推动和平方面发挥“建设性”作用。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260414-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%91%BC%E5%90%81%E5%9C%A8%E4%B8%AD%E4%B8%9C%E5%9C%B0%E5%8C%BA%E5%B0%8A%E9%87%8D%E5%9B%BD%E9%99%85%E6%B3%95%EF%BC%8C%E6%89%BF%E8%AF%BA%E4%B8%AD%E5%9B%BD%E5%B0%86%E5%8F%91%E6%8C%A5-%E5%BB%BA%E8%AE%BE%E6%80%A7-%E4%BD%9C%E7%94%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776154586000.webp","sourceId":"rfi"},{"id":1776154505000,"createdDate":"2026-04-14 08:15","name":"法国国际广播电台","title":"日本与巴基斯坦举行首脑会谈  支持巴基斯坦促进美伊和谈","content":"日本时间4月13日下午，日本首相高市早苗与巴基斯坦总理夏巴兹·谢里夫举行了电话会谈。日方表示，重要的是切实实现包括确保霍尔木兹海峡航行安全在内的局势降温，并通过协商尽早达成最终协议，这是日本的一贯立场。而在日本时间14日上午的日本内阁官房长官木原稔主持的记者会上，木原围绕美国开始实施封锁霍尔木兹海峡的措施重申了“尽早确保自由、安全航行至关重要”的立场。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260414-%E6%97%A5%E6%9C%AC%E4%B8%8E%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E4%B8%BE%E8%A1%8C%E9%A6%96%E8%84%91%E4%BC%9A%E8%B0%88-%E6%94%AF%E6%8C%81%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E4%BF%83%E8%BF%9B%E7%BE%8E%E4%BC%8A%E5%92%8C%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776154505000.webp","sourceId":"rfi"},{"id":1776154293000,"createdDate":"2026-04-14 08:11","name":"法国国际广播电台","title":"朝鲜再进行海上导弹试射","content":"朝鲜再次进行海上导弹试射。据朝鲜官媒朝中社周二（4月14日）报道，朝鲜领导人金正恩观摩了此次从海军驱逐舰上发射的巡航导弹和反舰导弹试射。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260414-%E6%9C%9D%E9%B2%9C%E5%86%8D%E6%AC%A1%E8%BF%9B%E8%A1%8C%E6%B5%B7%E4%B8%8A%E5%AF%BC%E5%BC%B9%E8%AF%95%E5%B0%84","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776154293000.webp","sourceId":"rfi"},{"id":1776154175000,"createdDate":"2026-04-14 08:09","name":"法国国际广播电台","title":"台湾首位中配立委上任70天后画下国会生涯句点 民众党决议开除李贞秀党籍","content":"民众党中评会在13日一致决议开除李贞秀党籍，台湾首位中配立委的国会生涯也就此止步。虽然李贞秀任期仅短短70天，但期间她接连陷入双重国籍争议与发言风波。李贞秀发声明，从政是为向社会证明，中配立委具备充分问政能力与正当性。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260414-%E5%8F%B0%E6%B9%BE%E9%A6%96%E4%BD%8D%E4%B8%AD%E9%85%8D%E7%AB%8B%E5%A7%94%E4%B8%8A%E4%BB%BB70%E5%A4%A9%E5%90%8E%E7%94%BB%E4%B8%8B%E5%9B%BD%E4%BC%9A%E7%94%9F%E6%B6%AF%E5%8F%A5%E7%82%B9-%E6%B0%91%E4%BC%97%E5%85%9A%E5%86%B3%E8%AE%AE%E5%BC%80%E9%99%A4%E6%9D%8E%E8%B4%9E%E7%A7%80%E5%85%9A%E7%B1%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/14/1776154175000.webp","sourceId":"rfi"}]