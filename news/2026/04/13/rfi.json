[{"id":1776070023000,"createdDate":"2026-04-13 08:47","name":"法国国际广播电台","title":"受战争影响 沙特5月对华原油销量据报将减半","content":"据彭博社援引知情交易员报导称，由于中东战乱扰乱了原油流动并推高了油价，沙特下月对最大进口国中国的原油销量预计将减半。上述交易员表示，作为全球最大的石油出口国，沙特计划在5月份向中国客户出口约2000万桶原油。这一数字低于4月份约4000万桶的装货量。由于未获授权公开谈论此事，这些交易员要求匿名。沙特阿美公司拒绝置评。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260413-%E5%8F%97%E6%88%98%E4%BA%89%E5%BD%B1%E5%93%8D-%E6%B2%99%E7%89%B95%E6%9C%88%E5%AF%B9%E5%8D%8E%E5%8E%9F%E6%B2%B9%E5%87%BA%E5%8F%A3%E9%87%8F%E6%8D%AE%E6%8A%A5%E5%B0%86%E5%87%8F%E5%8D%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776070023000.webp","sourceId":"rfi"},{"id":1776069660000,"createdDate":"2026-04-13 08:41","name":"法国国际广播电台","title":"中共宣布对台十项政策 台湾学者称：经贸交流政策武器化","content":"中共12日宣布对台10项政策，台学者分析这些措施有一半以上是过去曾经执行过的。另外，民进党也质疑，其中一些措施涉及国家安全与主权，国民党与中共之间的交流无法代表台湾政府。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260413-%E4%B8%AD%E5%85%B1%E5%AE%A3%E5%B8%83%E5%AF%B9%E5%8F%B0%E5%8D%81%E9%A1%B9%E6%94%BF%E7%AD%96-%E5%8F%B0%E6%B9%BE%E5%AD%A6%E8%80%85%E7%A7%B0-%E7%BB%8F%E8%B4%B8%E4%BA%A4%E6%B5%81%E6%94%BF%E7%AD%96%E6%AD%A6%E5%99%A8%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776069660000.webp","sourceId":"rfi"},{"id":1776069085000,"createdDate":"2026-04-13 08:31","name":"法国国际广播电台","title":"菲律宾指责中国在争议海域投放氰化物","content":"菲律宾周一（4月13号）指责中国渔民向南海南沙群岛海域倾倒氰化物。不仅威胁到菲律宾在南中国海争议海域的军事基地稳定，也危及菲律宾士兵的安全。中国称菲方“自导自演”，不具有可信度。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260413-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E6%8C%87%E8%B4%A3%E4%B8%AD%E5%9B%BD%E5%9C%A8%E4%BA%89%E8%AE%AE%E6%B5%B7%E5%9F%9F%E6%8A%95%E6%94%BE%E6%B0%B0%E5%8C%96%E7%89%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776069085000.webp","sourceId":"rfi"},{"id":1776068138000,"createdDate":"2026-04-13 08:15","name":"法国国际广播电台","title":"俄外长拉夫罗夫14日至15日访华 拟探讨乌克兰、中东局势","content":"中国外交部发言人郭嘉昆在周一的例行记者会上宣布，应中共中央政治局委员、外交部长王毅邀请，俄罗斯外长拉夫罗夫将于4月14日至15日对中国进行正式访问。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260413-%E4%BF%84%E5%A4%96%E9%95%BF%E6%8B%89%E5%A4%AB%E7%BD%97%E5%A4%AB14%E6%97%A5%E8%87%B315%E6%97%A5%E8%AE%BF%E5%8D%8E-%E6%8B%9F%E6%8E%A2%E8%AE%A8%E4%B9%8C%E5%85%8B%E5%85%B0-%E4%B8%AD%E4%B8%9C%E5%B1%80%E5%8A%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776068138000.webp","sourceId":"rfi"},{"id":1776062415000,"createdDate":"2026-04-13 06:40","name":"法国国际广播电台","title":"日本针对美国封锁霍尔木兹海峡强调通过外交解决问题的重要性","content":"在日本内阁官房长官木原稔于日本时间13日上午主持的记者会上，围绕美国与伊朗的谈判未能达成协议、美国反而决定封锁霍尔木兹海峡，以及美国总统特朗普就霍尔木兹海峡局势表示对日本未支持美国“感到惊讶”等言论，回答了记者的提问。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260413-%E6%97%A5%E6%9C%AC%E9%92%88%E5%AF%B9%E7%BE%8E%E5%9B%BD%E5%B0%81%E9%94%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%BC%BA%E8%B0%83%E9%80%9A%E8%BF%87%E5%A4%96%E4%BA%A4%E8%A7%A3%E5%86%B3%E9%97%AE%E9%A2%98%E7%9A%84%E9%87%8D%E8%A6%81%E6%80%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776062415000.webp","sourceId":"rfi"},{"id":1776062080000,"createdDate":"2026-04-13 06:34","name":"法国国际广播电台","title":"美伊谈判破裂 港日台韩股市半日普遍向下 惟中国股市上升","content":"美国和朗的谈判未能达成协议，美国总统特朗普更指示海军封锁霍尔木兹海峡来施压，导致原油价格重上逾100美元，金价则回落至4710美元水平，亚太区股市亦普遍向下，但范围及跌幅均略小於早前开战时。当中，印度和香港半日跌幅最大，达1.1%以上；其次是南韩和日本；不过，中国内地的上海和深圳两地股市则逆市0.3%至2.43%。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260413-%E7%BE%8E%E4%BC%8A%E8%B0%88%E5%88%A4%E7%A0%B4%E8%A3%82-%E6%B8%AF%E6%97%A5%E5%8F%B0%E9%9F%A9%E8%82%A1%E5%B8%82%E5%8D%8A%E6%97%A5%E6%99%AE%E9%81%8D%E5%90%91%E4%B8%8B-%E6%83%9F%E4%B8%AD%E5%9B%BD%E8%82%A1%E5%B8%82%E4%B8%8A%E5%8D%87","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776062080000.webp","sourceId":"rfi"},{"id":1776061763000,"createdDate":"2026-04-13 06:29","name":"法国国际广播电台","title":"学者：「习郑会」逼国民党重新定位 效果是成功分化 年底选情未定","content":"台湾的中国国民党主席郑丽文已完成六天的「两岸和平之旅」，反映执政和在野两党的三份主流报章的社评，评论未见调和，大陆学者沈逸亦继续呼吁台湾人民现在接受统一可获最大利益；在台的两岸关系研究员林泉忠则认为，「习郑会」突显的「国共合作」在党内外均面对困难，若该党无法形成清晰而具说服力的「国家」论述，「国共合作」可能会加剧内部分裂与社会疑虑。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260413-%E5%AD%A6%E8%80%85-%E4%B9%A0%E9%83%91%E4%BC%9A-%E9%80%BC%E5%9B%BD%E6%B0%91%E5%85%9A%E9%87%8D%E6%96%B0%E5%AE%9A%E4%BD%8D-%E6%95%88%E6%9E%9C%E6%98%AF%E6%88%90%E5%8A%9F%E5%88%86%E5%8C%96-%E5%B9%B4%E5%BA%95%E9%80%89%E6%83%85%E6%9C%AA%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776061763000.webp","sourceId":"rfi"},{"id":1776046559000,"createdDate":"2026-04-13 02:15","name":"法国国际广播电台","title":"中国真是中东战争的最大赢家吗？","content":"各位听众，能源价格上涨、地缘政治紧张局势、全球增长面临威胁……中东战争令世界忧心忡忡。然而，在这场危机的核心，有一个国家很可能最终胜出：中国。北京在战略、能源、产业方面，正以惊人的效率推进自身利益。面对能源冲击，中国经济似乎比许多其他经济体更具韧性。更重要的是，油价上涨反而对中国有利。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260413-%E4%B8%AD%E5%9B%BD%E7%9C%9F%E6%98%AF%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E7%9A%84%E6%9C%80%E5%A4%A7%E8%B5%A2%E5%AE%B6%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776046559000.webp","sourceId":"rfi"},{"id":1776092377000,"createdDate":"2026-04-13 14:59","name":"法国国际广播电台","title":"帕劳总统：中国施压要求放弃承认台湾","content":"帕劳总统惠普斯周一在到访新西兰期间接受法新社独家专访时表示，中国“非常坚持”要求帕劳放弃与台湾的外交关系，他並提到，全球石油危机对帕劳经济和百姓生活造成巨大冲击。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260413-%E5%B8%95%E5%8A%B3%E6%80%BB%E7%BB%9F-%E4%B8%AD%E5%9B%BD%E6%96%BD%E5%8E%8B%E8%A6%81%E6%B1%82%E6%94%BE%E5%BC%83%E6%89%BF%E8%AE%A4%E5%8F%B0%E6%B9%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776092377000.webp","sourceId":"rfi"},{"id":1776091933000,"createdDate":"2026-04-13 14:52","name":"法国国际广播电台","title":"毛焦尔：莫斯科和北京对务实合作持开放态度，匈牙利也是如此","content":"匈牙利周日大选的获胜者、蒂萨党主席毛焦尔（PeterMagyar）周一在记者会上说道，“我也看到莫斯科和克里姆林宫以及北京都已表态。我感谢它们对匈牙利选民和匈牙利人民的决定表示尊重，它们对务实合作持开放态度，匈牙利也是如此”。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260413-%E6%AF%9B%E7%84%A6%E5%B0%94-%E8%8E%AB%E6%96%AF%E7%A7%91%E5%92%8C%E5%8C%97%E4%BA%AC%E5%AF%B9%E5%8A%A1%E5%AE%9E%E5%90%88%E4%BD%9C%E6%8C%81%E5%BC%80%E6%94%BE%E6%80%81%E5%BA%A6%EF%BC%8C%E5%8C%88%E7%89%99%E5%88%A9%E4%B9%9F%E6%98%AF%E5%A6%82%E6%AD%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776091933000.webp","sourceId":"rfi"},{"id":1776090453000,"createdDate":"2026-04-13 14:27","name":"法国国际广播电台","title":"日本舆论：压倒多数反对美国和以色列攻击伊朗","content":"美国和以色列攻击伊朗的作战已持续一个多月，从日本整体的舆论看，反对美国和以色列攻击伊朗的声音占压倒多数。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260413-%E6%97%A5%E6%9C%AC%E8%88%86%E8%AE%BA-%E5%8E%8B%E5%80%92%E5%A4%9A%E6%95%B0%E5%8F%8D%E5%AF%B9%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%BB%A5%E8%89%B2%E5%88%97%E6%94%BB%E5%87%BB%E4%BC%8A%E6%9C%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776090453000.webp","sourceId":"rfi"},{"id":1776089311000,"createdDate":"2026-04-13 14:08","name":"法国国际广播电台","title":"法国2026年报税开季，在确认送出您纳税申报表前，必须检查的内容","content":"各位听众，2026年的纳税申报季到了，从4月9日开始，您可以提交税表并检查预填信息是否正确。在此提醒您，在确认您的纳税申报表之前，必须检查哪些内容。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260413-%E6%B3%95%E5%9B%BD2026%E5%B9%B4%E6%8A%A5%E7%A8%8E%E5%BC%80%E5%AD%A3%EF%BC%8C%E5%9C%A8%E7%A1%AE%E8%AE%A4%E9%80%81%E5%87%BA%E6%82%A8%E7%BA%B3%E7%A8%8E%E7%94%B3%E6%8A%A5%E8%A1%A8%E5%89%8D%EF%BC%8C%E5%BF%85%E9%A1%BB%E6%A3%80%E6%9F%A5%E7%9A%84%E5%86%85%E5%AE%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776089311000.webp","sourceId":"rfi"},{"id":1776088810000,"createdDate":"2026-04-13 14:00","name":"法国国际广播电台","title":"美澳菲今年二度南中国海联演：支持自由开放的印度-太平洋","content":"在菲中两国围绕南中国海主权争端持续紧张之际，美国和澳大利亚与菲律宾共同举行了今年在南中国海的第二次联合海上演习。菲律宾军方周一表示，此次为期四天的演习于4月9日至12日举行，汇集了军舰、战斗机和侦察机，开展了一系列协调行动，旨在加强海上防御能力。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260413-%E7%BE%8E%E6%BE%B3%E8%8F%B2%E4%BB%8A%E5%B9%B4%E4%BA%8C%E5%BA%A6%E5%8D%97%E4%B8%AD%E5%9B%BD%E6%B5%B7%E8%81%94%E6%BC%94-%E6%94%AF%E6%8C%81%E8%87%AA%E7%94%B1%E5%BC%80%E6%94%BE%E7%9A%84%E5%8D%B0%E5%BA%A6-%E5%A4%AA%E5%B9%B3%E6%B4%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776088810000.webp","sourceId":"rfi"},{"id":1776086757000,"createdDate":"2026-04-13 13:25","name":"法国国际广播电台","title":"南非:第二大政党有了一位新党魁","content":"南非第二大政党[民主联盟]（DA-AllianceDémocratique）于2026年04月12日星期天在豪登省（Gauteng）省城约翰内斯堡（Johannesburg）附近的米德兰（Midrand）召开会议，选举产生了一位新党魁。这是本台法广非洲组（RFIAfrique）今天（2026年04月13日星期一）的最新法文消息之一。在原党魁、现任农业部长约翰·斯汀霍森（JohnSteenhuisen）决定不参选的情况下，开普敦（leCap）市长乔丹·希尔-刘易斯（GeordinHill-Lewis）在选举中战胜一位尚不知名的对手SibusisoDyonase，成为了南非第二大政党的新党魁。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260413-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%8D%97%E9%9D%9E-%E7%AC%AC%E4%BA%8C%E5%A4%A7%E6%94%BF%E5%85%9A%E6%9C%89%E4%BA%86%E4%B8%80%E4%BD%8D%E6%96%B0%E5%85%9A%E9%AD%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776086757000.webp","sourceId":"rfi"},{"id":1776086346000,"createdDate":"2026-04-13 13:19","name":"法国国际广播电台","title":"遭民众党开除党籍确定失立委席位 陆配李贞秀：不会提出任何法律诉讼或仲裁","content":"台湾民众党立法委员李贞秀近期争议不断，民众党中评会于当地时间周一下午开会，决定将李贞秀开除党籍，即日起生效，李贞秀也将因此失去不分区立委资格。台湾中选会表示，民众党已发函给中选会，开除李贞秀党籍，因此中选会13日依《公职人员选举罢免法》第73条第2项规定，函请立法院註销李贞秀的立委名籍。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260413-%E9%81%AD%E6%B0%91%E4%BC%97%E5%85%9A%E5%BC%80%E9%99%A4%E5%85%9A%E7%B1%8D%E7%A1%AE%E5%AE%9A%E5%A4%B1%E7%AB%8B%E5%A7%94%E5%B8%AD%E4%BD%8D-%E9%99%86%E9%85%8D%E6%9D%8E%E8%B4%9E%E7%A7%80-%E4%B8%8D%E4%BC%9A%E6%8F%90%E5%87%BA%E4%BB%BB%E4%BD%95%E6%B3%95%E5%BE%8B%E8%AF%89%E8%AE%BC%E6%88%96%E4%BB%B2%E8%A3%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776086346000.webp","sourceId":"rfi"},{"id":1776077899000,"createdDate":"2026-04-13 10:58","name":"法国国际广播电台","title":"台湾总统下周出访斯威士兰　期盼达成3项共荣目标","content":"周一，台湾总统府宣布，总统赖清德将在4月22日至27日访问非洲邦交国斯威士兰，以及这次出访的行程安排，这是赖清德上任来首次访问非洲，也是他在任期内的第二次出国访问。据总统府发言人称，此行是以“台斯同庆、携手共荣”为主题，旨在深化双方关系，并推动多项合作。尤其是在安全、经济、数位这三方面达成共荣。台湾外交部还特别指出，此行是直飞，不会过境他国。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260413-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E4%B8%8B%E5%91%A8%E5%87%BA%E8%AE%BF%E6%96%AF%E5%A8%81%E5%A3%AB%E5%85%B0-%E6%9C%9F%E7%9B%BC%E8%BE%BE%E6%88%903%E9%A1%B9%E5%85%B1%E8%8D%A3%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776077899000.webp","sourceId":"rfi"},{"id":1776076652000,"createdDate":"2026-04-13 10:37","name":"法国国际广播电台","title":"约30国驻北约大使将于周三起一同访日 被指具里程碑意义","content":"一支由约30个国家的驻北约大使组成的史无前例的代表团将于周三起访问日本，这标志着北约成员国对日本进行的最大规模高级别访问，也是深化双边关系的重要里程碑。在为期三天的访问中，这些外交官将与日本内阁大臣和高官会面，讨论共同关心的安全问题，并探讨加强合作和战略协同的途径。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260413-%E7%BA%A630%E5%9B%BD%E9%A9%BB%E5%8C%97%E7%BA%A6%E5%A4%A7%E4%BD%BF%E5%B0%86%E4%BA%8E%E5%91%A8%E4%B8%89%E8%B5%B7%E8%AE%BF%E6%97%A5-%E8%A2%AB%E6%8C%87%E5%85%B7%E9%87%8C%E7%A8%8B%E7%A2%91%E6%84%8F%E4%B9%89","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776076652000.webp","sourceId":"rfi"},{"id":1776074570000,"createdDate":"2026-04-13 10:02","name":"法国国际广播电台","title":"特朗普指若发现中国军援伊朗加征50%关税 北京：关税战没有赢家、反对抹黑","content":"美国总统特朗普（DonaldTrump）周日在受访时表示，若中方向伊朗提供军事装备，美方将对华加征50%的额外关税，此前有报道称，中国正准备向伊朗交付一批新的防空系统。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260413-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8C%87%E8%8B%A5%E5%8F%91%E7%8E%B0%E4%B8%AD%E5%9B%BD%E5%86%9B%E6%8F%B4%E4%BC%8A%E6%9C%97%E5%8A%A0%E5%BE%8150-%E5%85%B3%E7%A8%8E-%E5%8C%97%E4%BA%AC-%E5%85%B3%E7%A8%8E%E6%88%98%E6%B2%A1%E6%9C%89%E8%B5%A2%E5%AE%B6-%E5%8F%8D%E5%AF%B9%E6%8A%B9%E9%BB%91","thumbnail":"","detailImage":"news/detail/rfi/2026/04/13/1776074570000.webp","sourceId":"rfi"}]