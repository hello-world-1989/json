[{"id":1776848534000,"createdDate":"2026-04-22 09:02","name":"法国国际广播电台","title":"对华贸易逆差不断扩大 德国经济部长赖歇拟下月访华","content":"随着德方官员对不断扩大的对华贸易逆差、原材料获取以及人工智能监管等问题的担忧日益加剧，德国总理默茨将于下月派遣联邦经济与能源部长赖歇（KatherinaReiche）出访中国。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260422-%E5%AF%B9%E5%8D%8E%E8%B4%B8%E6%98%93%E9%80%86%E5%B7%AE%E4%B8%8D%E6%96%AD%E6%89%A9%E5%A4%A7-%E5%BE%B7%E5%9B%BD%E7%BB%8F%E6%B5%8E%E9%83%A8%E9%95%BF%E8%B5%96%E6%AD%87%E6%8B%9F%E4%B8%8B%E6%9C%88%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776848534000.webp","sourceId":"rfi"},{"id":1776847601000,"createdDate":"2026-04-22 08:46","name":"法国国际广播电台","title":"美国弗吉尼亚州选民通过重新划分选区方案，或将增加民主党在国会的席位，进而改变中期选举走向","content":"美国弗吉尼亚州选民周二（4月22日）批准了一项“期中改划选区”的方案，这一举措可能在11月的中期选举中帮助民主党额外赢得四个联邦众议院席位。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260422-%E7%BE%8E%E5%9B%BD%E5%BC%97%E5%90%89%E5%B0%BC%E4%BA%9A%E5%B7%9E%E9%80%89%E6%B0%91%E9%80%9A%E8%BF%87%E9%87%8D%E6%96%B0%E5%88%92%E5%88%86%E9%80%89%E5%8C%BA%E6%96%B9%E6%A1%88%EF%BC%8C%E6%88%96%E5%B0%86%E5%A2%9E%E5%8A%A0%E6%B0%91%E4%B8%BB%E5%85%9A%E5%9C%A8%E5%9B%BD%E4%BC%9A%E7%9A%84%E5%B8%AD%E4%BD%8D%EF%BC%8C%E8%BF%9B%E8%80%8C%E6%94%B9%E5%8F%98%E4%B8%AD%E6%9C%9F%E9%80%89%E4%B8%BE%E8%B5%B0%E5%90%91","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776847601000.webp","sourceId":"rfi"},{"id":1776847002000,"createdDate":"2026-04-22 08:36","name":"法国国际广播电台","title":"乌外长：已请求土耳其主办泽普会，愿考虑在除俄白俄外举行峰会","content":"乌克兰外交部长瑟比加（AndriiSybiha）表示，乌方已请求土耳其主办泽连斯基总统与俄罗斯总统普京的会晤，基辅方面希望借此重启陷入僵局的和平谈判。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260422-%E4%B9%8C%E5%A4%96%E9%95%BF-%E5%B7%B2%E8%AF%B7%E6%B1%82%E5%9C%9F%E8%80%B3%E5%85%B6%E4%B8%BB%E5%8A%9E%E6%B3%BD%E6%99%AE%E4%BC%9A%EF%BC%8C%E6%84%BF%E8%80%83%E8%99%91%E5%9C%A8%E9%99%A4%E8%8E%AB%E6%96%AF%E7%A7%91%E4%B8%8E%E6%98%8E%E6%96%AF%E5%85%8B%E5%A4%96%E4%B8%BE%E8%A1%8C%E4%B9%8C%E4%BF%84%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776847002000.webp","sourceId":"rfi"},{"id":1776845027000,"createdDate":"2026-04-22 08:03","name":"法国国际广播电台","title":"台湾总统赖清德访非洲友邦行程受阻取消 国台办称一中原则才是国际共识","content":"台湾总统赖清德原定22日出访非洲友邦斯威士兰王国的行程暂缓，总统府表示，中国以经济胁迫施压。中国国台办赞赏非洲国家「一中原则」的坚持并称此为国际共识。国民党主席郑丽文则借此谴责民进党的两岸论述。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260422-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E8%B5%96%E6%B8%85%E5%BE%B7%E8%AE%BF%E9%9D%9E%E6%B4%B2%E5%8F%8B%E9%82%A6%E8%A1%8C%E7%A8%8B%E5%8F%97%E9%98%BB%E5%8F%96%E6%B6%88-%E5%9B%BD%E5%8F%B0%E5%8A%9E%E7%A7%B0%E4%B8%80%E4%B8%AD%E5%8E%9F%E5%88%99%E6%89%8D%E6%98%AF%E5%9B%BD%E9%99%85%E5%85%B1%E8%AF%86","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776845027000.webp","sourceId":"rfi"},{"id":1776844026000,"createdDate":"2026-04-22 07:47","name":"法国国际广播电台","title":"高市内阁阁僚首次参拜靖国神社 日本126名议员参拜","content":"日本经济财政担当大臣城内实于22日上午参拜了位于东京九段下的靖国神社。这是自去年10月高市早苗政权成立以来，首次有内阁成员参拜靖国神社。靖国神社自21日起正在举行春季例大祭。22日跨党派国会议员组织“大家一起参拜靖国神社的国会议员之会”集体参拜，共有126人参加。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260422-%E9%AB%98%E5%B8%82%E5%86%85%E9%98%81%E9%98%81%E5%83%9A%E9%A6%96%E6%AC%A1%E5%8F%82%E6%8B%9C%E9%9D%96%E5%9B%BD%E7%A5%9E%E7%A4%BE-%E6%97%A5%E6%9C%AC126%E5%90%8D%E8%AE%AE%E5%91%98%E5%8F%82%E6%8B%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776844026000.webp","sourceId":"rfi"},{"id":1776841236000,"createdDate":"2026-04-22 07:00","name":"法国国际广播电台","title":"疑受中日关系紧张影响 日本人气男歌手藤井风突宣布取消香港站演唱会","content":"继日本摇滚乐队ONEOKROCK取消香港演出两场演唱会后，日本人气创作男歌手藤井风（FujiiKaze）在未有解释原因下，突然宣布取消原订于今年在香港举办演唱会的安排，是一个月之内第二次有日本人气艺人取消在港演唱的安排，同时宣布追加首尔站。日媒估计，事件与中日关系紧张有关。香港网民则忧虑，另一日本人气组合Yoasobi预告下半年来港演出的安排会否有变数，更谑称香港是「取消盛事之都」。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260422-%E7%96%91%E5%8F%97%E4%B8%AD%E6%97%A5%E5%85%B3%E7%B3%BB%E7%B4%A7%E5%BC%A0%E5%BD%B1%E5%93%8D-%E6%97%A5%E6%9C%AC%E4%BA%BA%E6%B0%94%E7%94%B7%E6%AD%8C%E6%89%8B%E8%97%A4%E4%BA%95%E9%A3%8E%E7%AA%81%E5%AE%A3%E5%B8%83%E5%8F%96%E6%B6%88%E9%A6%99%E6%B8%AF%E7%AB%99%E6%BC%94%E5%94%B1%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776841236000.webp","sourceId":"rfi"},{"id":1776840954000,"createdDate":"2026-04-22 06:55","name":"法国国际广播电台","title":"黎智英逾亿港元财产遭港府申请充公 其子女再呼吁美国总统助其父重获自由","content":"香港传媒大亨黎智英被判串谋勾结外国势力等罪成后，港府引用新修订的国安法实施细则赋权，充公他的在港资产。根据新曝光的入禀状显示，黎智英被充公的资产包括在港数十个银行户口内的存款及其公司股份，遭充公资产总值估计逾1.27亿港元（约1381万欧元）。与此同时，黎智英子女再次呼吁美国总统特朗普，下月出访中国时争取让黎智英重获自由。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260422-%E9%BB%8E%E6%99%BA%E8%8B%B1%E9%80%BE%E4%BA%BF%E6%B8%AF%E5%85%83%E8%B4%A2%E4%BA%A7%E9%81%AD%E6%B8%AF%E5%BA%9C%E7%94%B3%E8%AF%B7%E5%85%85%E5%85%AC-%E5%85%B6%E5%AD%90%E5%A5%B3%E5%86%8D%E5%91%BC%E5%90%81%E7%BE%8E%E5%9B%BD%E6%80%BB%E7%BB%9F%E5%8A%A9%E5%85%B6%E7%88%B6%E9%87%8D%E8%8E%B7%E8%87%AA%E7%94%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776840954000.webp","sourceId":"rfi"},{"id":1776875467000,"createdDate":"2026-04-22 16:31","name":"法国国际广播电台","title":"伊朗政权内部分歧凸显 消息人士：特朗普延长停火不会是无限期的","content":"据三位美国官员向Axios新闻网透露称，特朗普总统给了存在内部纠纷的伊朗政权各方一个短暂的窗口期，让他们团结起来，提出一个连贯的还盘——否则他周二延长的停火协议将失效。一位了解此事的美方消息人士声称，“特朗普愿意再延长三到五天的停火，让伊朗方面把事情理顺。（停火）它不会是无限期的”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260422-%E4%BC%8A%E6%9C%97%E6%94%BF%E6%9D%83%E5%86%85%E9%83%A8%E5%88%86%E6%AD%A7%E5%87%B8%E6%98%BE-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB-%E7%89%B9%E6%9C%97%E6%99%AE%E5%BB%B6%E9%95%BF%E5%81%9C%E7%81%AB%E4%B8%8D%E4%BC%9A%E6%98%AF%E6%97%A0%E9%99%90%E6%9C%9F%E7%9A%84","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776875467000.webp","sourceId":"rfi"},{"id":1776872750000,"createdDate":"2026-04-22 15:45","name":"法国国际广播电台","title":"美光正推动美国会通过限制向中国竞争对手出售芯片工具法案","content":"据路透社援引知情人士报导，美国最大的存储芯片制造商美光科技（MicronTechnology）正积极推动美国国会通过一项法案，该法案将对其中国竞争对手用于芯片制造的设备实施新的出口限制。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260422-%E7%BE%8E%E5%85%89%E6%AD%A3%E6%8E%A8%E5%8A%A8%E7%BE%8E%E5%9B%BD%E4%BC%9A%E9%80%9A%E8%BF%87%E9%99%90%E5%88%B6%E5%90%91%E4%B8%AD%E5%9B%BD%E7%AB%9E%E4%BA%89%E5%AF%B9%E6%89%8B%E5%87%BA%E5%94%AE%E8%8A%AF%E7%89%87%E5%B7%A5%E5%85%B7%E6%B3%95%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776872750000.webp","sourceId":"rfi"},{"id":1776870881000,"createdDate":"2026-04-22 15:14","name":"法国国际广播电台","title":"伊朗对华秘密运输石油正面临美拦截威胁 本周，至少有两艘伊朗油轮突破封锁","content":"多年来，伊朗、中国和众多中间商通过使用记录不透明的老旧油轮运输石油，并在海上船舶之间转移货物，来规避美国的制裁，所有这些都是为了避免审查和法律责任。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260422-%E4%BC%8A%E6%9C%97%E5%AF%B9%E5%8D%8E%E7%A7%98%E5%AF%86%E8%BF%90%E8%BE%93%E7%9F%B3%E6%B2%B9%E6%AD%A3%E9%9D%A2%E4%B8%B4%E7%BE%8E%E6%8B%A6%E6%88%AA%E5%A8%81%E8%83%81-%E6%9C%AC%E5%91%A8%EF%BC%8C%E8%87%B3%E5%B0%91%E6%9C%89%E4%B8%A4%E8%89%98%E4%BC%8A%E6%9C%97%E6%B2%B9%E8%BD%AE%E7%AA%81%E7%A0%B4%E5%B0%81%E9%94%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776870881000.webp","sourceId":"rfi"},{"id":1776866021000,"createdDate":"2026-04-22 13:53","name":"法国国际广播电台","title":"不止Manus 中国据报要求MiroMind勿将AI人才研究成果送出国","content":"据《华盛顿邮报》援引十几位在中国内外从事人工智能领域的人士报导称，面对与美国在人工智能领域的激烈竞争，中国当局正在采取更有力的措施，试图阻止新兴人工智能初创企业离开中国，前往西方寻求资金和市场。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260422-%E4%B8%8D%E6%AD%A2manus-%E4%B8%AD%E5%9B%BD%E6%8D%AE%E6%8A%A5%E8%A6%81%E6%B1%82miromind%E5%8B%BF%E5%B0%86ai%E4%BA%BA%E6%89%8D%E5%92%8C%E7%A0%94%E7%A9%B6%E6%88%90%E6%9E%9C%E9%80%81%E5%87%BA%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776866021000.webp","sourceId":"rfi"},{"id":1776865652000,"createdDate":"2026-04-22 13:47","name":"法国国际广播电台","title":"霍尔木兹海峡多国护航方案讨论移师伦敦，美伊双向封锁持续","content":"继上周英法两国在巴黎召集峰会讨论霍尔木兹海峡安全通航行动之后，相关讨论今明两天在伦敦继续。从法新社22日发自伦敦的消息来看，参与讨论活动的主要是军方领导人。这可能意味着上周巴黎峰会上围绕组建多国部队、在霍尔木兹海峡开展护航议题的讨论已经取得进展，现在需要将共识变成具体方案。不过，此时美国和伊朗在霍尔木兹海峡的对峙何时停止还是一个巨大的未知数。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260422-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%A4%9A%E5%9B%BD%E6%8A%A4%E8%88%AA%E6%96%B9%E6%A1%88%E8%AE%A8%E8%AE%BA%E7%A7%BB%E5%B8%88%E4%BC%A6%E6%95%A6%EF%BC%8C%E7%BE%8E%E4%BC%8A%E5%8F%8C%E5%90%91%E5%B0%81%E9%94%81%E6%8C%81%E7%BB%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776865652000.webp","sourceId":"rfi"},{"id":1776861126000,"createdDate":"2026-04-22 12:32","name":"法国国际广播电台","title":"苹果新掌门严峻挑战的重中之重：供应链上怎么平衡中国与美国","content":"在苹果集团宣布蒂姆·库克（TimCook）将于九月交棒给约翰·特纳斯（JohnTernus）后，《费加罗报》科技版周二21日发表LucasMediavilla撰写的分析文章说，苹果的产品工程主管接管了一个财务状况良好但已不再处于创新前沿的团队，这位五十多岁相对年轻的新任CEO接下来将面临诸多重要挑战。其中一项是：既要加快将部分生产从中国工厂转移出去的战略，又要能在北京和华盛顿两头都不得罪。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260422-%E8%8B%B9%E6%9E%9C%E6%96%B0%E6%8E%8C%E9%97%A8%E4%B8%A5%E5%B3%BB%E6%8C%91%E6%88%98%E7%9A%84%E9%87%8D%E4%B8%AD%E4%B9%8B%E9%87%8D-%E4%BE%9B%E5%BA%94%E9%93%BE%E4%B8%8A%E6%80%8E%E4%B9%88%E5%B9%B3%E8%A1%A1%E4%B8%AD%E5%9B%BD%E4%B8%8E%E7%BE%8E%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776861126000.webp","sourceId":"rfi"},{"id":1776857739000,"createdDate":"2026-04-22 11:35","name":"法国国际广播电台","title":"三星电子前职员向中企泄露核心半导体技术一审判囚七年","content":"涉嫌向中国企业泄露核心半导体技术的一名前三星电子研究人员周三被判有期徒刑7年。韩联社报导指，首尔中央地方法院刑事审判第28合议庭当天对三星电子半导体技术遭泄案作出一审判决，判处因违反韩国《工业技术保护法》等罪名被捕并被起诉的全某（56岁）有期徒刑7年。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260422-%E4%B8%89%E6%98%9F%E7%94%B5%E5%AD%90%E5%89%8D%E8%81%8C%E5%91%98%E5%90%91%E4%B8%AD%E4%BC%81%E6%B3%84%E9%9C%B2%E6%A0%B8%E5%BF%83%E5%8D%8A%E5%AF%BC%E4%BD%93%E6%8A%80%E6%9C%AF-%E4%B8%80%E5%AE%A1%E5%88%A4%E5%9B%9A%E4%B8%83%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776857739000.webp","sourceId":"rfi"},{"id":1776855370000,"createdDate":"2026-04-22 10:56","name":"法国国际广播电台","title":"回声报解析：日本为何罔顾中美的嘘声 坚持出口致命性武器","content":"大家好，欢迎收听法国报纸摘要，4月22日星期三上市的法国各全国性日报头版关注重点，多以国内议题为主。如《解放报》报道缺工的法国企业主希望将外籍雇员身份合法化。而《费加罗报》与《回声报》则关注法国2027年财政预算需要进一步紧缩。与此同时，继特朗普宣布延长与伊朗的停火以待德黑兰提交新的谈判方案后，据《费加罗报》表示，这一决定与特朗普21日早前的立场形成反差；此外，特朗普周二在CNBC电视台直播的电话采访中暗示，中国曾协助伊朗补充武器储备。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260422-%E5%9B%9E%E5%A3%B0%E6%8A%A5%E8%A7%A3%E6%9E%90-%E6%97%A5%E6%9C%AC%E4%B8%BA%E4%BD%95%E7%BD%94%E9%A1%BE%E4%B8%AD%E7%BE%8E%E7%9A%84%E5%98%98%E5%A3%B0-%E5%9D%9A%E6%8C%81%E5%87%BA%E5%8F%A3%E8%87%B4%E5%91%BD%E6%80%A7%E6%AD%A6%E5%99%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776855370000.webp","sourceId":"rfi"},{"id":1776854317000,"createdDate":"2026-04-22 10:38","name":"法国国际广播电台","title":"美贸易代表告知盟友须为中国以外地区关键矿产支付国安溢价","content":"美国贸易代表格里尔（JamiesonGreer）已经告知盟友们，他们必须为从中国以外地区采购的关键矿产支付更高费用，此举正值华盛顿正试图打破北京对关键矿产供应的垄断。格里尔表示，美国盟友必须准备好为这些矿产支付“国家安全溢价”，这些矿产将来自包括欧洲在内的一系列拟议贸易伙伴。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260422-%E7%BE%8E%E8%B4%B8%E6%98%93%E4%BB%A3%E8%A1%A8%E5%91%8A%E7%9F%A5%E7%9B%9F%E5%8F%8B%E9%A1%BB%E4%B8%BA%E4%B8%AD%E5%9B%BD%E4%BB%A5%E5%A4%96%E5%9C%B0%E5%8C%BA%E5%85%B3%E9%94%AE%E7%9F%BF%E4%BA%A7%E6%94%AF%E4%BB%98%E5%9B%BD%E5%AE%89%E6%BA%A2%E4%BB%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776854317000.webp","sourceId":"rfi"},{"id":1776853701000,"createdDate":"2026-04-22 10:28","name":"法国国际广播电台","title":"中共利用台人反制台湾：以台湾人熟悉的言语与人物形象进行「在地化」的统战","content":"《路透社》发布一篇报导，讲述中共如何利用台湾舆论在台打资讯战，运用台湾反对党政治人物、相关网红等对政府的批评声浪，扩大对民进党的打击。此外，台湾网红更成为了中国统战的宣传链，全面渗透台湾身份认同。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260422-%E4%B8%AD%E5%85%B1%E5%88%A9%E7%94%A8%E5%8F%B0%E4%BA%BA%E5%8F%8D%E5%88%B6%E5%8F%B0%E6%B9%BE-%E4%BB%A5%E5%8F%B0%E6%B9%BE%E4%BA%BA%E7%86%9F%E6%82%89%E7%9A%84%E8%A8%80%E8%AF%AD%E4%B8%8E%E4%BA%BA%E7%89%A9%E5%BD%A2%E8%B1%A1%E8%BF%9B%E8%A1%8C-%E5%9C%A8%E5%9C%B0%E5%8C%96-%E7%9A%84%E7%BB%9F%E6%88%98","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776853701000.webp","sourceId":"rfi"},{"id":1776852236000,"createdDate":"2026-04-22 10:03","name":"法国国际广播电台","title":"特朗普：我们截获了一艘船，上面有不太好的东西，也许是来自中国的礼物","content":"美国总统特朗普（DonaldTrump）周二在受访时就中国可能向伊朗提供武器或其他致命性战争物资发表了隐晦的言论。此举将试探华盛顿在援助德黑兰方面所划定的红线。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260422-%E7%89%B9%E6%9C%97%E6%99%AE-%E6%88%91%E4%BB%AC%E6%88%AA%E8%8E%B7%E4%BA%86%E4%B8%80%E8%89%98%E8%88%B9%EF%BC%8C%E4%B8%8A%E9%9D%A2%E6%9C%89%E4%B8%8D%E5%A4%AA%E5%A5%BD%E7%9A%84%E4%B8%9C%E8%A5%BF%EF%BC%8C%E4%B9%9F%E8%AE%B8%E6%98%AF%E6%9D%A5%E8%87%AA%E4%B8%AD%E5%9B%BD%E7%9A%84%E7%A4%BC%E7%89%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776852236000.webp","sourceId":"rfi"},{"id":1776848861000,"createdDate":"2026-04-22 09:07","name":"法国国际广播电台","title":"驻韩美军司令首次否认从韩国撤走萨德防空系统","content":"有关美国可能正将部署在韩国的反导防空系统调往中东的消息传出一个多月后，驻韩美军司令泽维尔-布伦森21日出席美国参议院听证会时表示，美国并未将部署在韩国的萨德反导防空系统调离。但他也并未提供更多具体信息。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260422-%E9%A9%BB%E9%9F%A9%E7%BE%8E%E5%86%9B%E5%8F%B8%E4%BB%A4%E9%A6%96%E6%AC%A1%E5%90%A6%E8%AE%A4%E4%BB%8E%E9%9F%A9%E5%9B%BD%E6%92%A4%E8%B5%B0%E8%90%A8%E5%BE%B7%E9%98%B2%E7%A9%BA%E7%B3%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776848861000.webp","sourceId":"rfi"}]