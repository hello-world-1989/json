[{"id":1776848534000,"createdDate":"2026-04-22 09:02","name":"法国国际广播电台","title":"对华贸易逆差不断扩大 德国经济部长赖歇拟下月访华","content":"随着德方官员对不断扩大的对华贸易逆差、原材料获取以及人工智能监管等问题的担忧日益加剧，德国总理默茨将于下月派遣联邦经济与能源部长赖歇（KatherinaReiche）出访中国。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260422-%E5%AF%B9%E5%8D%8E%E8%B4%B8%E6%98%93%E9%80%86%E5%B7%AE%E4%B8%8D%E6%96%AD%E6%89%A9%E5%A4%A7-%E5%BE%B7%E5%9B%BD%E7%BB%8F%E6%B5%8E%E9%83%A8%E9%95%BF%E8%B5%96%E6%AD%87%E6%8B%9F%E4%B8%8B%E6%9C%88%E8%AE%BF%E5%8D%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776848534000.webp","sourceId":"rfi"},{"id":1776847601000,"createdDate":"2026-04-22 08:46","name":"法国国际广播电台","title":"美国弗吉尼亚州选民通过重新划分选区方案，或将增加民主党在国会的席位，进而改变中期选举走向","content":"美国弗吉尼亚州选民周二（4月22日）批准了一项“期中改划选区”的方案，这一举措可能在11月的中期选举中帮助民主党额外赢得四个联邦众议院席位。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260422-%E7%BE%8E%E5%9B%BD%E5%BC%97%E5%90%89%E5%B0%BC%E4%BA%9A%E5%B7%9E%E9%80%89%E6%B0%91%E9%80%9A%E8%BF%87%E9%87%8D%E6%96%B0%E5%88%92%E5%88%86%E9%80%89%E5%8C%BA%E6%96%B9%E6%A1%88%EF%BC%8C%E6%88%96%E5%B0%86%E5%A2%9E%E5%8A%A0%E6%B0%91%E4%B8%BB%E5%85%9A%E5%9C%A8%E5%9B%BD%E4%BC%9A%E7%9A%84%E5%B8%AD%E4%BD%8D%EF%BC%8C%E8%BF%9B%E8%80%8C%E6%94%B9%E5%8F%98%E4%B8%AD%E6%9C%9F%E9%80%89%E4%B8%BE%E8%B5%B0%E5%90%91","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776847601000.webp","sourceId":"rfi"},{"id":1776847002000,"createdDate":"2026-04-22 08:36","name":"法国国际广播电台","title":"乌外长：已请求土耳其主办泽普会，愿考虑在除俄白俄外举行峰会","content":"乌克兰外交部长瑟比加（AndriiSybiha）表示，乌方已请求土耳其主办泽连斯基总统与俄罗斯总统普京的会晤，基辅方面希望借此重启陷入僵局的和平谈判。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260422-%E4%B9%8C%E5%A4%96%E9%95%BF-%E5%B7%B2%E8%AF%B7%E6%B1%82%E5%9C%9F%E8%80%B3%E5%85%B6%E4%B8%BB%E5%8A%9E%E6%B3%BD%E6%99%AE%E4%BC%9A%EF%BC%8C%E6%84%BF%E8%80%83%E8%99%91%E5%9C%A8%E9%99%A4%E8%8E%AB%E6%96%AF%E7%A7%91%E4%B8%8E%E6%98%8E%E6%96%AF%E5%85%8B%E5%A4%96%E4%B8%BE%E8%A1%8C%E4%B9%8C%E4%BF%84%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776847002000.webp","sourceId":"rfi"},{"id":1776845027000,"createdDate":"2026-04-22 08:03","name":"法国国际广播电台","title":"台湾总统赖清德访非洲友邦行程受阻取消 国台办称一中原则才是国际共识","content":"台湾总统赖清德原定22日出访非洲友邦斯威士兰王国的行程暂缓，总统府表示，中国以经济胁迫施压。中国国台办赞赏非洲国家「一中原则」的坚持并称此为国际共识。国民党主席郑丽文则借此谴责民进党的两岸论述。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260422-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E8%B5%96%E6%B8%85%E5%BE%B7%E8%AE%BF%E9%9D%9E%E6%B4%B2%E5%8F%8B%E9%82%A6%E8%A1%8C%E7%A8%8B%E5%8F%97%E9%98%BB%E5%8F%96%E6%B6%88-%E5%9B%BD%E5%8F%B0%E5%8A%9E%E7%A7%B0%E4%B8%80%E4%B8%AD%E5%8E%9F%E5%88%99%E6%89%8D%E6%98%AF%E5%9B%BD%E9%99%85%E5%85%B1%E8%AF%86","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776845027000.webp","sourceId":"rfi"},{"id":1776844026000,"createdDate":"2026-04-22 07:47","name":"法国国际广播电台","title":"高市内阁阁僚首次参拜靖国神社 日本126名议员参拜","content":"日本经济财政担当大臣城内实于22日上午参拜了位于东京九段下的靖国神社。这是自去年10月高市早苗政权成立以来，首次有内阁成员参拜靖国神社。靖国神社自21日起正在举行春季例大祭。22日跨党派国会议员组织“大家一起参拜靖国神社的国会议员之会”集体参拜，共有126人参加。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260422-%E9%AB%98%E5%B8%82%E5%86%85%E9%98%81%E9%98%81%E5%83%9A%E9%A6%96%E6%AC%A1%E5%8F%82%E6%8B%9C%E9%9D%96%E5%9B%BD%E7%A5%9E%E7%A4%BE-%E6%97%A5%E6%9C%AC126%E5%90%8D%E8%AE%AE%E5%91%98%E5%8F%82%E6%8B%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776844026000.webp","sourceId":"rfi"},{"id":1776841236000,"createdDate":"2026-04-22 07:00","name":"法国国际广播电台","title":"疑受中日关系紧张影响 日本人气男歌手藤井风突宣布取消香港站演唱会","content":"继日本摇滚乐队ONEOKROCK取消香港演出两场演唱会后，日本人气创作男歌手藤井风（FujiiKaze）在未有解释原因下，突然宣布取消原订于今年在香港举办演唱会的安排，是一个月之内第二次有日本人气艺人取消在港演唱的安排，同时宣布追加首尔站。日媒估计，事件与中日关系紧张有关。香港网民则忧虑，另一日本人气组合Yoasobi预告下半年来港演出的安排会否有变数，更谑称香港是「取消盛事之都」。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260422-%E7%96%91%E5%8F%97%E4%B8%AD%E6%97%A5%E5%85%B3%E7%B3%BB%E7%B4%A7%E5%BC%A0%E5%BD%B1%E5%93%8D-%E6%97%A5%E6%9C%AC%E4%BA%BA%E6%B0%94%E7%94%B7%E6%AD%8C%E6%89%8B%E8%97%A4%E4%BA%95%E9%A3%8E%E7%AA%81%E5%AE%A3%E5%B8%83%E5%8F%96%E6%B6%88%E9%A6%99%E6%B8%AF%E7%AB%99%E6%BC%94%E5%94%B1%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776841236000.webp","sourceId":"rfi"},{"id":1776840954000,"createdDate":"2026-04-22 06:55","name":"法国国际广播电台","title":"黎智英逾亿港元财产遭港府申请充公 其子女再呼吁美国总统助其父重获自由","content":"香港传媒大亨黎智英被判串谋勾结外国势力等罪成后，港府引用新修订的国安法实施细则赋权，充公他的在港资产。根据新曝光的入禀状显示，黎智英被充公的资产包括在港数十个银行户口内的存款及其公司股份，遭充公资产总值估计逾1.27亿港元（约1381万欧元）。与此同时，黎智英子女再次呼吁美国总统特朗普，下月出访中国时争取让黎智英重获自由。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260422-%E9%BB%8E%E6%99%BA%E8%8B%B1%E9%80%BE%E4%BA%BF%E6%B8%AF%E5%85%83%E8%B4%A2%E4%BA%A7%E9%81%AD%E6%B8%AF%E5%BA%9C%E7%94%B3%E8%AF%B7%E5%85%85%E5%85%AC-%E5%85%B6%E5%AD%90%E5%A5%B3%E5%86%8D%E5%91%BC%E5%90%81%E7%BE%8E%E5%9B%BD%E6%80%BB%E7%BB%9F%E5%8A%A9%E5%85%B6%E7%88%B6%E9%87%8D%E8%8E%B7%E8%87%AA%E7%94%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/22/1776840954000.webp","sourceId":"rfi"}]