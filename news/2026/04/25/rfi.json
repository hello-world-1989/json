[{"id":1777104326000,"createdDate":"2026-04-25 08:05","name":"法国国际广播电台","title":"欧盟考虑协助建设中东能源基础设施以绕开冲突地区，冯德莱恩提及“印度—中东—欧洲经济走廊”这一可能","content":"由于伊朗战争引发的严重燃料短缺以及油气价格飙升，当前，欧盟正认真考虑为中东替代能源运输路线提供资金支持，以避开霍尔木兹海峡等冲突地区。欧盟委员会主席冯德莱恩周五表示，欧盟准备与波斯湾国家合作开展新项目，将能源输送到全球市场，而不再受制于战争或地缘政治冲突。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260425-%E6%AC%A7%E7%9B%9F%E8%80%83%E8%99%91%E5%8D%8F%E5%8A%A9%E5%BB%BA%E8%AE%BE%E4%B8%AD%E4%B8%9C%E8%83%BD%E6%BA%90%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD%E4%BB%A5%E7%BB%95%E5%BC%80%E5%86%B2%E7%AA%81%E5%9C%B0%E5%8C%BA%EF%BC%8C%E5%86%AF%E5%BE%B7%E8%8E%B1%E6%81%A9%E6%8F%90%E5%8F%8A-%E5%8D%B0%E5%BA%A6-%E4%B8%AD%E4%B8%9C-%E6%AC%A7%E6%B4%B2%E7%BB%8F%E6%B5%8E%E8%B5%B0%E5%BB%8A-%E8%BF%99%E4%B8%80%E5%8F%AF%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777104326000.webp","sourceId":"rfi"},{"id":1777103910000,"createdDate":"2026-04-25 07:58","name":"法国国际广播电台","title":"美国或重新评估英国对马岛主权，阿根廷表示欢迎","content":"美国政府对部分欧洲盟友的不满情绪正在加剧。由路透社披露的五角大楼内部备忘录显示，美国正考虑对部分在与伊朗冲突中表现出与美国“合作不足”的北约盟友施加多种压力手段，其中甚至包括重新评估美国对英国在马尔维纳斯群岛主权问题上的支持立场。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260425-%E7%BE%8E%E5%9B%BD%E6%88%96%E9%87%8D%E6%96%B0%E8%AF%84%E4%BC%B0%E8%8B%B1%E5%9B%BD%E5%AF%B9%E9%A9%AC%E5%B2%9B%E4%B8%BB%E6%9D%83%EF%BC%8C%E9%98%BF%E6%A0%B9%E5%BB%B7%E8%A1%A8%E7%A4%BA%E6%AC%A2%E8%BF%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777103910000.webp","sourceId":"rfi"},{"id":1777128693000,"createdDate":"2026-04-25 14:51","name":"法国国际广播电台","title":"日本政府考虑出资加强对驻日美军设施保护","content":"据共同社获悉，日本政府已开始考虑在日美就驻日美军费用分担问题的谈判中，提议加强对美军设施的保护。预计谈判将于今年夏季正式启动，费用将由日本承担。此举旨在通过增强驻日美军基地的“韧性”，提升日美同盟的威慑和应对能力，使其在紧急情况下能够维持正常运转并最大限度减少损失。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260425-%E6%97%A5%E6%9C%AC%E6%94%BF%E5%BA%9C%E8%80%83%E8%99%91%E5%87%BA%E8%B5%84%E5%8A%A0%E5%BC%BA%E5%AF%B9%E9%A9%BB%E6%97%A5%E7%BE%8E%E5%86%9B%E8%AE%BE%E6%96%BD%E4%BF%9D%E6%8A%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777128693000.webp","sourceId":"rfi"},{"id":1777127395000,"createdDate":"2026-04-25 14:29","name":"法国国际广播电台","title":"印陆军前参谋长：短期内不能忽视巴基斯坦，长远应聚焦中国","content":"曾在2020年中印边境冲突期间担任印度陆军参谋长的退役将军纳拉瓦内（MMNaravane）在受访时表示，中国和印度之间总会存在竞争，这可能会导致对抗，因此印度必须做好准备，应对更强大的对手。在他看来，对印度来说，巴基斯坦是短期挑战，而中国仍然是长期挑战。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260425-%E5%8D%B0%E9%99%86%E5%86%9B%E5%89%8D%E5%8F%82%E8%B0%8B%E9%95%BF-%E7%9F%AD%E6%9C%9F%E5%86%85%E4%B8%8D%E8%83%BD%E5%BF%BD%E8%A7%86%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%EF%BC%8C%E9%95%BF%E8%BF%9C%E5%BA%94%E8%81%9A%E7%84%A6%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777127395000.webp","sourceId":"rfi"},{"id":1777123902000,"createdDate":"2026-04-25 13:31","name":"法国国际广播电台","title":"贝森特：我们在稀土矿产领域取得了相当大进展，或4年内就能彻底解决","content":"美国财政部长贝森特（ScottBessent）在接受《华尔街日报》采访时表示，即将在中国举行的美中峰会旨在维护“稳定”，避免局势升级，保持两国关系的可预测性。在稀土矿产领域，贝森特说道，“我们取得了相当大的进展”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260425-%E8%B4%9D%E6%A3%AE%E7%89%B9-%E6%88%91%E4%BB%AC%E5%9C%A8%E7%A8%80%E5%9C%9F%E7%9F%BF%E4%BA%A7%E9%A2%86%E5%9F%9F%E5%8F%96%E5%BE%97%E4%BA%86%E7%9B%B8%E5%BD%93%E5%A4%A7%E8%BF%9B%E5%B1%95%EF%BC%8C%E6%88%964%E5%B9%B4%E5%86%85%E5%B0%B1%E8%83%BD%E5%BD%BB%E5%BA%95%E8%A7%A3%E5%86%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777123902000.webp","sourceId":"rfi"},{"id":1777122475000,"createdDate":"2026-04-25 13:07","name":"法国国际广播电台","title":"加沙时隔21年重新举行市政选举：战火余烬后，迎来的新生还是走不出的困局？","content":"各位听众，周六（4月25日），约旦河西岸以及加沙部分地区的巴勒斯坦人开始投票，选举市长和市政委员会成员。投票的具体地理范围是在约旦河西岸182个城镇，同时也包括加沙地带唯一一个城市——代尔巴拉赫（Deirel-Balah），这是受破坏程度较轻的地区之一，但即便受破坏程度较轻，在在长达两年半的战争之后，当地12个投票站中有9个位于帐篷内。值得注意的是，这是加沙自2005年以来（即哈马斯接管该地区以来）的首次选举。代尔巴拉赫约7万名巴勒斯坦人将投票选出负责城市和村庄事务的地方官员，这些官员将管理供水、电力等基本公共服务。约旦河西岸的投票站将于19点（格林尼治时间16点）关闭，而因为当地缺乏电力，代尔巴拉赫的投票站将在17点关闭，以便在白天完成计票。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260425-%E5%8A%A0%E6%B2%99%E6%97%B6%E9%9A%9421%E5%B9%B4%E9%87%8D%E6%96%B0%E4%B8%BE%E8%A1%8C%E5%B8%82%E6%94%BF%E9%80%89%E4%B8%BE-%E6%88%98%E7%81%AB%E4%BD%99%E7%83%AC%E5%90%8E%EF%BC%8C%E8%BF%8E%E6%9D%A5%E7%9A%84%E6%96%B0%E7%94%9F%E8%BF%98%E6%98%AF%E8%B5%B0%E4%B8%8D%E5%87%BA%E7%9A%84%E5%9B%B0%E5%B1%80","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777122475000.webp","sourceId":"rfi"},{"id":1777122141000,"createdDate":"2026-04-25 13:02","name":"法国国际广播电台","title":"专访台湾学者张昱谦（Kenny Chang）：中国5月1日起对非洲实施零关税政策，谁是最终受益者？","content":"据中国商务部消息，5月1日起，53个与中国建交的非洲国家100%税目的商品进入中国市场将不用缴纳关税，此前中国已对33个非洲国家实施了零关税政策。这一举措若全面落实，相当于对几乎整个非洲大陆免除关税，唯一被排除在外的是仍与台湾保持外交关系的斯威士兰。中国的这一政策究竟想释放出什么信号呢？本台的印太纵览节目将围绕该主题制作两期节目，本期节目我们邀请到了台湾淡江大学外交与国际关系学系的学者张昱谦KennyChang，他同时也是《用地图看懂中国经济》等多本畅销财经图书的作者。张昱谦将为我们深入解读中国对非洲近20年来外交策略的转变，零关税政策背后的真实意图，以及未来中国对非洲的具体定位和战略方向。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%8D%B0%E5%A4%AA%E7%BA%B5%E8%A7%88/20260425-%E4%B8%93%E8%AE%BF%E5%8F%B0%E6%B9%BE%E5%AD%A6%E8%80%85%E5%BC%A0%E6%98%B1%E8%B0%A6-kenny-chang-%E4%B8%AD%E5%9B%BD%E5%AF%B9%E9%9D%9E%E6%B4%B2%E5%AE%9E%E6%96%BD%E9%9B%B6%E5%85%B3%E7%A8%8E%E6%94%BF%E7%AD%96%EF%BC%8C%E8%83%8C%E5%90%8E%E7%9A%84%E6%84%8F%E5%9B%BE%E7%A9%B6%E7%AB%9F%E6%98%AF%E4%BB%80%E4%B9%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777122141000.webp","sourceId":"rfi"},{"id":1777117609000,"createdDate":"2026-04-25 11:46","name":"法国国际广播电台","title":"赖清德出访受阻 林佳龙任特使抵达斯威士兰出席庆典活动","content":"台湾外交部长林佳龙已抵达非洲国家斯威士兰，他将以总统特使身份，出席斯威士兰重要庆典活动。斯威士兰是台湾在非洲唯一的邦交国。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260425-%E8%B5%96%E6%B8%85%E5%BE%B7%E5%87%BA%E8%AE%BF%E5%8F%97%E9%98%BB-%E6%9E%97%E4%BD%B3%E9%BE%99%E4%BB%BB%E7%89%B9%E4%BD%BF%E6%8A%B5%E8%BE%BE%E6%96%AF%E5%A8%81%E5%A3%AB%E5%85%B0%E5%87%BA%E5%B8%AD%E5%BA%86%E5%85%B8%E6%B4%BB%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777117609000.webp","sourceId":"rfi"},{"id":1777113820000,"createdDate":"2026-04-25 10:43","name":"法国国际广播电台","title":"委美两国官员据报正商讨将反对派纳入委央行董事会","content":"委内瑞拉和美国官员正在商讨将该国政治反对派和独立人士纳入委内瑞拉中央银行董事会，这是朝着权力分享迈出的关键一步，有助于根除腐败。与委内瑞拉几乎所有机构一样，委内瑞拉央行在长达四分之一世纪的社会主义统治下被政府指派。恢复这些机构的公信力，尤其是委内瑞拉央行的公信力，对于这个石油资源丰富的国家重返国际社会至关重要。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260425-%E5%A7%94%E7%BE%8E%E4%B8%A4%E5%9B%BD%E5%AE%98%E5%91%98%E6%8D%AE%E6%8A%A5%E6%AD%A3%E5%95%86%E8%AE%A8%E5%B0%86%E5%8F%8D%E5%AF%B9%E6%B4%BE%E7%BA%B3%E5%85%A5%E5%A7%94%E5%A4%AE%E8%A1%8C%E8%91%A3%E4%BA%8B%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777113820000.webp","sourceId":"rfi"},{"id":1777113583000,"createdDate":"2026-04-25 10:39","name":"法国国际广播电台","title":"切尔诺贝利40年：政府公信力与人类集体核安全","content":"2026年4月26日是切尔诺贝利核电站事故40周年。4月25日，本台订阅的法国主流日刊多集中聚焦40年后的人类集体核安全。","newsLink":"https://www.rfi.fr/cn/%E5%88%87%E5%B0%94%E8%AF%BA%E8%B4%9D%E5%88%A940%E5%B9%B4-%E6%94%BF%E5%BA%9C%E5%85%AC%E4%BF%A1%E5%8A%9B%E4%B8%8E%E4%BA%BA%E7%B1%BB%E9%9B%86%E4%BD%93%E6%A0%B8%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777113583000.webp","sourceId":"rfi"},{"id":1777112289000,"createdDate":"2026-04-25 10:18","name":"法国国际广播电台","title":"已与吉利洽谈引进中国技术入美国市场？ 福特加以否认","content":"福特汽车公司否认了有关其与吉利汽车控股有限公司就将中国汽车技术引入美国市场举行会谈的报道。福特发言人告诉彭博社称，福特从未与任何中国汽车制造商就技术共享或平台共享事宜进行过此类会谈。吉利方面尚未对此置评。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260425-%E5%B7%B2%E4%B8%8E%E5%90%89%E5%88%A9%E6%B4%BD%E8%B0%88%E5%BC%95%E8%BF%9B%E4%B8%AD%E5%9B%BD%E6%8A%80%E6%9C%AF%E5%85%A5%E7%BE%8E%E5%9B%BD%E5%B8%82%E5%9C%BA-%E7%A6%8F%E7%89%B9%E5%8A%A0%E4%BB%A5%E5%90%A6%E8%AE%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777112289000.webp","sourceId":"rfi"},{"id":1777109992000,"createdDate":"2026-04-25 09:39","name":"法国国际广播电台","title":"美国务院下令就DeepSeek等中企涉嫌窃取AI知识产权一事通告全球","content":"据路透社看到的一份外交电报显示，美国国务院已下令在全球范围内开展行动，旨在引起外界对中国公司——包括人工智能初创公司DeepSeek——被指大规模窃取美国人工智能实验室知识产权行为的关注。这份日期为周五、已发送至世界各地外交和领事机构的电报指示美国外交人员与外国对应方沟通，表达对“敌手们提取和蒸馏美国人工智能模型”的担忧。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260425-%E7%BE%8E%E5%9B%BD%E5%8A%A1%E9%99%A2%E4%B8%8B%E4%BB%A4%E5%B0%B1deepseek%E7%AD%89%E4%B8%AD%E4%BC%81%E6%B6%89%E5%AB%8C%E7%AA%83%E5%8F%96ai%E6%8A%80%E6%9C%AF%E4%B8%80%E4%BA%8B%E9%80%9A%E5%91%8A%E5%85%A8%E7%90%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777109992000.webp","sourceId":"rfi"},{"id":1777108898000,"createdDate":"2026-04-25 09:21","name":"法国国际广播电台","title":"日本等10国签署应对中国相关黑客组织的国际文件","content":"日本网络安全保障担当相松本尚24日在记者会上透露，已签署由英国起草的国际文件，表明将联合对应包括“伏特台风”（VoltTyphoon）在内的疑似中国相关网络攻击黑客。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260425-%E6%97%A5%E6%9C%AC%E7%AD%8910%E5%9B%BD%E7%AD%BE%E7%BD%B2%E5%BA%94%E5%AF%B9%E4%B8%AD%E5%9B%BD%E7%9B%B8%E5%85%B3%E9%BB%91%E5%AE%A2%E7%BB%84%E7%BB%87%E7%9A%84%E5%9B%BD%E9%99%85%E6%96%87%E4%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777108898000.webp","sourceId":"rfi"},{"id":1777107820000,"createdDate":"2026-04-25 09:03","name":"法国国际广播电台","title":"美国制裁中国第二大茶壶炼油厂和40家航运公司及油轮","content":"美国政府对一家位于中国的大型炼油厂以及约40家参与运输伊朗石油的航运公司和油轮实施经济制裁。这项于周五宣布的举措，兑现了特朗普此前对与伊朗有业务往来的公司和国家实施二级制裁的威胁。这也是华盛顿加大力度切断伊朗政权主要收入来源——石油出口——的整体行动的一部分。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260425-%E7%BE%8E%E5%9B%BD%E5%88%B6%E8%A3%81%E4%B8%AD%E5%9B%BD%E7%AC%AC%E4%BA%8C%E5%A4%A7%E8%8C%B6%E5%A3%B6%E7%82%BC%E6%B2%B9%E5%8E%82%E5%92%8C40%E5%AE%B6%E8%88%AA%E8%BF%90%E5%85%AC%E5%8F%B8%E5%8F%8A%E6%B2%B9%E8%BD%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777107820000.webp","sourceId":"rfi"},{"id":1777151194000,"createdDate":"2026-04-25 21:06","name":"法国国际广播电台","title":"马克龙：中东战争“并不意味着法会出现任何燃料短缺”","content":"道达尔能源董事长兼首席执行官潘彦磊（PatrickPouyanné）24日表示：如果霍尔木兹海峡的封锁再持续“两到三个月”，法国将进入“能源短缺时代”。法国总统马克龙于4月25日出面安抚民众说，目前中东战争“并不意味着法国会出现任何燃料短缺”，同时警告不要出现可能引发“恐慌反应”的情况。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260425-%E9%A9%AC%E5%85%8B%E9%BE%99-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89-%E5%B9%B6%E4%B8%8D%E6%84%8F%E5%91%B3%E7%9D%80%E6%B3%95%E4%BC%9A%E5%87%BA%E7%8E%B0%E4%BB%BB%E4%BD%95%E7%87%83%E6%96%99%E7%9F%AD%E7%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777151194000.webp","sourceId":"rfi"},{"id":1777151027000,"createdDate":"2026-04-25 21:03","name":"法国国际广播电台","title":"国产自行车、纪念册、花瓶    马克龙送礼结束希腊之行","content":"法国总统马克龙于4月24日至25日访问希腊。为了纪念此次访问，马克龙总统特意为希腊总理准备了几份厚礼。一辆国产自行车、一本纪念册和一个奥运主题的花瓶。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260425-%E5%9B%BD%E4%BA%A7%E8%87%AA%E8%A1%8C%E8%BD%A6-%E7%BA%AA%E5%BF%B5%E5%86%8C-%E8%8A%B1%E7%93%B6-%E9%A9%AC%E5%85%8B%E9%BE%99%E9%80%81%E7%A4%BC%E7%BB%93%E6%9D%9F%E5%B8%8C%E8%85%8A%E4%B9%8B%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777151027000.webp","sourceId":"rfi"},{"id":1777150719000,"createdDate":"2026-04-25 20:58","name":"法国国际广播电台","title":"中光伏组件出口三月份飙升至历史最高水平","content":"中国海关及行业数据显示，由于东南亚和非洲在预期价格上涨前进行囤货，加之伊朗战争的后续影响刺激了需求，中国光伏组件出口在三月份飙升至历史最高水平。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260425-%E4%B8%AD%E5%85%89%E4%BC%8F%E7%BB%84%E4%BB%B6%E5%87%BA%E5%8F%A3%E4%B8%89%E6%9C%88%E4%BB%BD%E9%A3%99%E5%8D%87%E8%87%B3%E5%8E%86%E5%8F%B2%E6%9C%80%E9%AB%98%E6%B0%B4%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777150719000.webp","sourceId":"rfi"},{"id":1777150407000,"createdDate":"2026-04-25 20:53","name":"法国国际广播电台","title":"大熊猫“平平”与“福双”将赴美","content":"中国野生动物保护协会此前发文表示，与美国亚特兰大动物园开启新一轮大熊猫保护合作研究。大熊猫“平平”和“福双”将赴美开启为期10年的大熊猫保护合作。延续两国人民20多年“熊猫情”。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260425-%E5%A4%A7%E7%86%8A%E7%8C%AB-%E5%B9%B3%E5%B9%B3-%E4%B8%8E-%E7%A6%8F%E5%8F%8C-%E5%B0%86%E8%B5%B4%E7%BE%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777150407000.webp","sourceId":"rfi"},{"id":1777150163000,"createdDate":"2026-04-25 20:49","name":"法国国际广播电台","title":"美国猎人在加蓬被五头大象踩死","content":"一名热衷“战利品狩猎”（TrophyHunting）的美国加州百万富翁厄尼·多西奥（ErnieDosio），于2026年4月17日在非洲加蓬共和国中部的罗佩（Lopé）地区雨林遭惊吓的森林象群猛烈反击，当场被踩踏致死，享年75岁。他的向导身受重伤。这场意外，让他长年累积的“狩猎战绩”最终付出了自己的命。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260425-%E7%BE%8E%E5%9B%BD%E7%8C%8E%E4%BA%BA%E5%9C%A8%E5%8A%A0%E8%93%AC%E8%A2%AB%E4%BA%94%E5%A4%B4%E5%A4%A7%E8%B1%A1%E8%B8%A9%E6%AD%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777150163000.webp","sourceId":"rfi"},{"id":1777150131000,"createdDate":"2026-04-25 20:48","name":"法国国际广播电台","title":"德国警方抓获来自中国的诈骗团伙","content":"据慕尼黑《墨丘利报》报道，德国警方逮捕了一个来自中国的诈骗团伙。他们冒充驱逐诅咒和鬼魂的“神医”，曾在德国和欧洲多地行骗。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260425-%E5%BE%B7%E5%9B%BD%E8%AD%A6%E6%96%B9%E6%8A%93%E8%8E%B7%E6%9D%A5%E8%87%AA%E4%B8%AD%E5%9B%BD%E7%9A%84%E8%AF%88%E9%AA%97%E5%9B%A2%E4%BC%99","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777150131000.webp","sourceId":"rfi"},{"id":1777149886000,"createdDate":"2026-04-25 20:44","name":"法国国际广播电台","title":"中超级乐透    法一人赢1300万欧元","content":"在法国诺曼底奥恩省举行的50周年特别超级乐透抽奖中，一位幸运儿中了头奖。4月24日，一位彩民赢得了1300万欧元。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260425-%E4%B8%AD%E8%B6%85%E7%BA%A7%E4%B9%90%E9%80%8F-%E6%B3%95%E4%B8%80%E4%BA%BA%E8%B5%A21300%E4%B8%87%E6%AC%A7%E5%85%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777149886000.webp","sourceId":"rfi"},{"id":1777149611000,"createdDate":"2026-04-25 20:40","name":"法国国际广播电台","title":"特朗普说：他收到伊朗官员提出达成持久和平协议的提议“不够好”","content":"周六（4月25日），美国总统特朗普表示，他收到的伊朗官员提出达成持久和平协议的提议“不够好”；因此他取消了美方代表团前往伊斯兰堡的行程。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260425-%E7%89%B9%E6%9C%97%E6%99%AE%E8%AF%B4-%E4%BB%96%E6%94%B6%E5%88%B0%E4%BC%8A%E6%9C%97%E5%AE%98%E5%91%98%E6%8F%90%E5%87%BA%E8%BE%BE%E6%88%90%E6%8C%81%E4%B9%85%E5%92%8C%E5%B9%B3%E5%8D%8F%E8%AE%AE%E7%9A%84%E6%8F%90%E8%AE%AE-%E4%B8%8D%E5%A4%9F%E5%A5%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777149611000.webp","sourceId":"rfi"},{"id":1777146773000,"createdDate":"2026-04-25 19:52","name":"法国国际广播电台","title":"特朗普忽悠外交 伊朗强硬不吃","content":"美国总统特朗普周六（4月25日）表示，他已经取消美国团队前往巴基斯坦参加美伊谈判的行程。而在这之前，伊朗外长离开了伊斯兰堡。特朗普的忽悠外交，伊朗强硬不吃，美伊第二轮谈判的叙事终于流产。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260425-%E7%89%B9%E6%9C%97%E6%99%AE%E5%BF%BD%E6%82%A0%E5%A4%96%E4%BA%A4-%E4%BC%8A%E6%9C%97%E5%BC%BA%E7%A1%AC%E4%B8%8D%E5%90%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777146773000.webp","sourceId":"rfi"},{"id":1777139160000,"createdDate":"2026-04-25 17:46","name":"法国国际广播电台","title":"特朗普：刚取消美方代表前往伊斯兰堡与伊朗人会面的行程","content":"美国总统特朗普4月25日称，他已取消总统特使威特科夫和库什纳前往巴基斯坦与伊朗谈判的行程。福克斯（FoxNews）一名女记者表示，她和特朗普通过电话。特朗普对新闻记者表示，取消行程不意味着要重启战争。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260425-%E7%89%B9%E6%9C%97%E6%99%AE-%E5%88%9A%E5%8F%96%E6%B6%88%E7%BE%8E%E6%96%B9%E4%BB%A3%E8%A1%A8%E5%89%8D%E5%BE%80%E4%BC%8A%E6%96%AF%E5%85%B0%E5%A0%A1%E4%B8%8E%E4%BC%8A%E6%9C%97%E4%BA%BA%E4%BC%9A%E9%9D%A2%E7%9A%84%E8%A1%8C%E7%A8%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777139160000.webp","sourceId":"rfi"}]