[{"id":1777104326000,"createdDate":"2026-04-25 08:05","name":"法国国际广播电台","title":"欧盟考虑协助建设中东能源基础设施以绕开冲突地区，冯德莱恩提及“印度—中东—欧洲经济走廊”这一可能","content":"由于伊朗战争引发的严重燃料短缺以及油气价格飙升，当前，欧盟正认真考虑为中东替代能源运输路线提供资金支持，以避开霍尔木兹海峡等冲突地区。欧盟委员会主席冯德莱恩周五表示，欧盟准备与波斯湾国家合作开展新项目，将能源输送到全球市场，而不再受制于战争或地缘政治冲突。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260425-%E6%AC%A7%E7%9B%9F%E8%80%83%E8%99%91%E5%8D%8F%E5%8A%A9%E5%BB%BA%E8%AE%BE%E4%B8%AD%E4%B8%9C%E8%83%BD%E6%BA%90%E5%9F%BA%E7%A1%80%E8%AE%BE%E6%96%BD%E4%BB%A5%E7%BB%95%E5%BC%80%E5%86%B2%E7%AA%81%E5%9C%B0%E5%8C%BA%EF%BC%8C%E5%86%AF%E5%BE%B7%E8%8E%B1%E6%81%A9%E6%8F%90%E5%8F%8A-%E5%8D%B0%E5%BA%A6-%E4%B8%AD%E4%B8%9C-%E6%AC%A7%E6%B4%B2%E7%BB%8F%E6%B5%8E%E8%B5%B0%E5%BB%8A-%E8%BF%99%E4%B8%80%E5%8F%AF%E8%83%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777104326000.webp","sourceId":"rfi"},{"id":1777103910000,"createdDate":"2026-04-25 07:58","name":"法国国际广播电台","title":"美国或重新评估英国对马岛主权，阿根廷表示欢迎","content":"美国政府对部分欧洲盟友的不满情绪正在加剧。由路透社披露的五角大楼内部备忘录显示，美国正考虑对部分在与伊朗冲突中表现出与美国“合作不足”的北约盟友施加多种压力手段，其中甚至包括重新评估美国对英国在马尔维纳斯群岛主权问题上的支持立场。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260425-%E7%BE%8E%E5%9B%BD%E6%88%96%E9%87%8D%E6%96%B0%E8%AF%84%E4%BC%B0%E8%8B%B1%E5%9B%BD%E5%AF%B9%E9%A9%AC%E5%B2%9B%E4%B8%BB%E6%9D%83%EF%BC%8C%E9%98%BF%E6%A0%B9%E5%BB%B7%E8%A1%A8%E7%A4%BA%E6%AC%A2%E8%BF%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/25/1777103910000.webp","sourceId":"rfi"}]