[{"id":1775033505000,"createdDate":"2026-04-01 08:51","name":"法国国际广播电台","title":"支联会煽颠案举证完毕 法官禁用「六四屠城」 又禁问2018年前事实","content":"被迫解散的香港市民支援爱国民主运动联合会(支联会)被控煽动颠覆国家政权罪(煽颠案)一案完成举证，在最後一天的盘问中，法官多次打断自辩的邹幸彤的提问，更一度考虑不让前常委关振邦作供，遭邹指法庭不想听证据。法庭最後决定，只可提问2018年之後的事宜，而法庭亦在没有事实否定的情况下，指示邹幸彤以「六四事件」代替「六四屠城」来作出提问。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260401-%E6%94%AF%E8%81%94%E4%BC%9A%E7%85%BD%E9%A2%A0%E6%A1%88%E4%B8%BE%E8%AF%81%E5%AE%8C%E6%AF%95-%E6%B3%95%E5%AE%98%E7%A6%81%E7%94%A8-%E5%85%AD%E5%9B%9B%E5%B1%A0%E5%9F%8E-%E5%8F%88%E7%A6%81%E9%97%AE2018%E5%B9%B4%E5%89%8D%E4%BA%8B%E5%AE%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/01/1775033505000.webp","sourceId":"rfi"},{"id":1775033037000,"createdDate":"2026-04-01 08:43","name":"法国国际广播电台","title":"港美领就香港将拒解密手机等刑事化发安全警告 中方不满召见伊珠丽","content":"美国驻港澳总领事馆就港府修订国安法律丶令拒绝向执法人员交出个人电子装置及密码者须面对刑事检控一事发出警告，并呼吁美国公民一旦被扣押或被捕，应接触领事馆；此项「安全警告」发出两日後，中国驻港特派员崔建春「约见」美国驻港总领事伊珠丽(JulieEadeh)，表示强烈不满和坚决反对。有关态度和回应速度均较上次强硬和快速。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260401-%E6%B8%AF%E7%BE%8E%E9%A2%86%E5%B0%B1%E9%A6%99%E6%B8%AF%E5%B0%86%E6%8B%92%E8%A7%A3%E5%AF%86%E6%89%8B%E6%9C%BA%E7%AD%89%E5%88%91%E4%BA%8B%E5%8C%96%E5%8F%91%E5%AE%89%E5%85%A8%E8%AD%A6%E5%91%8A-%E4%B8%AD%E6%96%B9%E4%B8%8D%E6%BB%A1%E5%8F%AC%E8%A7%81%E4%BC%8A%E7%8F%A0%E4%B8%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/01/1775033037000.webp","sourceId":"rfi"},{"id":1775032707000,"createdDate":"2026-04-01 08:38","name":"法国国际广播电台","title":"中东：中国巴基斯坦联合提五点倡议促立即停火 尽速和谈","content":"中国和巴基斯坦周二（3月31号）呼吁立即结束中东战争，并提出一项五点计划，其中包括停火和尽快开启和谈。法新社报道称，中巴两国已将自身定位为调解人，以防止当前冲突升级。美国总统唐纳德·特朗普称对伊朗的战争可能即将结束。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260401-%E4%B8%AD%E4%B8%9C-%E4%B8%AD%E5%9B%BD%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E8%81%94%E5%90%88%E6%8F%90%E4%BA%94%E7%82%B9%E5%80%A1%E8%AE%AE%E4%BF%83%E7%AB%8B%E5%8D%B3%E5%81%9C%E7%81%AB-%E5%B0%BD%E9%80%9F%E5%92%8C%E8%B0%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/01/1775032707000.webp","sourceId":"rfi"},{"id":1775028947000,"createdDate":"2026-04-01 07:35","name":"法国国际广播电台","title":"中国、伊朗、俄、日《游戏视频工业》地缘政治要素 敌人英雄定位争夺战 腾讯大肆收购欧美市场","content":"各位听众，中国腾讯在国内和国际市场上大幅增加了对电子游戏行业的收购和投资。受到玩家追捧的电子游戏从《使命召唤（CallofDuty）》到《战地风云系列（Battlefield）》，一般他们都会根据地缘政治和市场情况调整其“反派”和英雄角色；通常是俄罗斯或中国或伊朗或日本，甚至是一些虚拟国家，因为如今市场利益为导向的视频游戏开发商，试图在不断变化的地缘政治格局中避免冒犯某些市场。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260401-%E4%B8%AD%E5%9B%BD-%E4%BF%84%E7%BD%97%E6%96%AF-%E4%BC%8A%E6%9C%97-%E6%97%A5%E6%9C%AC-%E6%B8%B8%E6%88%8F%E8%A7%86%E9%A2%91%E5%B7%A5%E4%B8%9A-%E5%9C%B0%E7%BC%98%E6%94%BF%E6%B2%BB%E8%A6%81%E7%B4%A0-%E6%95%8C%E4%BA%BA%E8%8B%B1%E9%9B%84%E5%AE%9A%E4%BD%8D%E4%BA%89%E5%A4%BA%E6%88%98-%E8%85%BE%E8%AE%AF%E5%87%BA%E6%89%8B%E6%AC%A7%E7%BE%8E%E5%B8%82%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/01/1775028947000.webp","sourceId":"rfi"},{"id":1775059565000,"createdDate":"2026-04-01 16:06","name":"法国国际广播电台","title":"伊朗导弹袭以色列14人伤 阿联酋1孟加拉公民被弹片击中身亡","content":"以色列军方4月1日早晨报告伊朗向以色列发射了导弹。以色列紧急救援部门宣布有14人受伤，其中一名11岁女童伤势严重。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260401-%E4%BC%8A%E6%9C%97%E5%AF%BC%E5%BC%B9%E8%A2%AD%E4%BB%A5%E8%89%B2%E5%88%9714%E4%BA%BA%E4%BC%A4-%E9%98%BF%E8%81%94%E9%85%8B1%E5%AD%9F%E5%8A%A0%E6%8B%89%E5%85%AC%E6%B0%91%E8%A2%AB%E5%BC%B9%E7%89%87%E5%87%BB%E4%B8%AD%E8%BA%AB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/01/1775059565000.webp","sourceId":"rfi"},{"id":1775059475000,"createdDate":"2026-04-01 16:04","name":"法国国际广播电台","title":"特朗普不满盟国在伊朗战争的态度，威胁要美国退出北约","content":"美国总统特朗普4月1日称，美国将很快结束对伊朗的战争，且他正在考虑将美国撤出北约。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260401-%E7%89%B9%E6%9C%97%E6%99%AE%E4%B8%8D%E6%BB%A1%E7%9B%9F%E5%9B%BD%E5%9C%A8%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E7%9A%84%E6%80%81%E5%BA%A6%EF%BC%8C%E5%A8%81%E8%83%81%E8%A6%81%E7%BE%8E%E5%9B%BD%E9%80%80%E5%87%BA%E5%8C%97%E7%BA%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/01/1775059475000.webp","sourceId":"rfi"},{"id":1775057776000,"createdDate":"2026-04-01 15:36","name":"法国国际广播电台","title":"专家解读：美国取消出生公民权将意味着什么？","content":"美国最高法院2026年4月1日开始审理总统特朗普签发的取消出生公民权行政命令的合法性。特朗普当日亲自到场，出席大法官的辩论。美国宾夕法尼亚州立大学社会学和人口统计学的特聘教授JenniferVanHook3月31日接受采访时表示，若最高法院维持这项行政命令，未来25年内，预计美国将有340万没有公民身分的儿童生活在美国。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260401-%E4%B8%93%E5%AE%B6%E8%A7%A3%E8%AF%BB-%E7%BE%8E%E5%9B%BD%E5%8F%96%E6%B6%88%E5%87%BA%E7%94%9F%E5%85%AC%E6%B0%91%E6%9D%83%E5%B0%86%E6%84%8F%E5%91%B3%E7%9D%80%E4%BB%80%E4%B9%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/01/1775057776000.webp","sourceId":"rfi"},{"id":1775054005000,"createdDate":"2026-04-01 14:33","name":"法国国际广播电台","title":"伊朗外长称未回应美国15点计划 否认德黑兰提5项条件","content":"伊朗表示未对美国提出的15点计划作出回应，该计划由特朗普于上周提出，旨在结束战争；伊朗外交部长拒绝提谈判事宜。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260401-%E4%BC%8A%E6%9C%97%E5%A4%96%E9%95%BF%E7%A7%B0%E6%9C%AA%E5%9B%9E%E5%BA%94%E7%BE%8E%E5%9B%BD15%E7%82%B9%E8%AE%A1%E5%88%92-%E5%90%A6%E8%AE%A4%E5%BE%B7%E9%BB%91%E5%85%B0%E6%8F%905%E9%A1%B9%E6%9D%A1%E4%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/01/1775054005000.webp","sourceId":"rfi"},{"id":1775053719000,"createdDate":"2026-04-01 14:28","name":"法国国际广播电台","title":"美国太空新篇章：阿尔忒弥斯2号绕月任务即将登场","content":"若最后一刻不出现技术故障或天气状况，美国宇航局（NASA）的阿尔忒弥斯2号（ArtemisII）任务预计将于周三（4月1号）美国东部时间下午6点24分（格林尼治标准时间晚上10点24分）从佛罗里达州肯尼迪航天中心发射升空，在阿波罗计划结束、人类最后一次登月50多年后，这次更广泛的美国登月目标关键测试飞行的背景是，面对来自中国的竞争日益激烈，美国正努力在太空领域重新确立领导地位。阿尔忒弥斯2号任务标志着美国太空探索新篇章的开启。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260401-%E9%98%BF%E5%B0%94%E5%BF%92%E5%BC%A5%E6%96%AF2%E5%8F%B7%E7%BB%95%E6%9C%88%E4%BB%BB%E5%8A%A1%E5%8D%B3%E5%B0%86%E7%99%BB%E5%9C%BA-%E7%BE%8E%E5%9B%BD%E8%A6%81%E5%A4%AA%E7%A9%BA%E6%8E%A2%E7%B4%A2%E6%96%B0%E7%AF%87%E7%AB%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/04/01/1775053719000.webp","sourceId":"rfi"},{"id":1775052367000,"createdDate":"2026-04-01 14:06","name":"法国国际广播电台","title":"柬埔寨大型网络诈骗团伙核心成员被引渡至中国","content":"被指为华裔大亨陈志犯罪团伙的一名核心成员和电诈嫌疑人李雄，已从柬埔寨被引渡回中国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260401-%E6%9F%AC%E5%9F%94%E5%AF%A8%E5%A4%A7%E5%9E%8B%E7%BD%91%E7%BB%9C%E8%AF%88%E9%AA%97%E5%9B%A2%E4%BC%99%E6%A0%B8%E5%BF%83%E6%88%90%E5%91%98%E8%A2%AB%E5%BC%95%E6%B8%A1%E8%87%B3%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/01/1775052367000.webp","sourceId":"rfi"},{"id":1775051131000,"createdDate":"2026-04-01 13:45","name":"法国国际广播电台","title":"中国夫妇因窃医疗商业机密定罪被撤销美国公民身份","content":"美国司法部（DOJ）周二表示，因试图从俄亥俄州一家儿童医院窃取尖端研究成果并将其提供给中国的一对中国夫妇被定罪后，其美国公民身份将被撤销。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260401-%E4%B8%AD%E5%9B%BD%E5%A4%AB%E5%A6%87%E5%9B%A0%E7%AA%83%E5%8C%BB%E7%96%97%E5%95%86%E4%B8%9A%E6%9C%BA%E5%AF%86%E5%AE%9A%E7%BD%AA%E8%A2%AB%E6%92%A4%E9%94%80%E7%BE%8E%E5%9B%BD%E5%85%AC%E6%B0%91%E8%BA%AB%E4%BB%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/01/1775051131000.webp","sourceId":"rfi"},{"id":1775048437000,"createdDate":"2026-04-01 13:00","name":"法国国际广播电台","title":"毛泽东秘书私人档案司法争讼判留在美国","content":"美国一名法官周二裁定中国前领导人毛泽东的秘书李锐的日记可继续保存在斯坦福大学。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260401-%E6%AF%9B%E6%B3%BD%E4%B8%9C%E7%A7%98%E4%B9%A6%E7%A7%81%E4%BA%BA%E6%A1%A3%E6%A1%88%E5%8F%B8%E6%B3%95%E4%BA%89%E8%AE%BC%E5%88%A4%E7%95%99%E5%9C%A8%E7%BE%8E%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/01/1775048437000.webp","sourceId":"rfi"},{"id":1775045212000,"createdDate":"2026-04-01 12:06","name":"法国国际广播电台","title":"法国专家谈穿山甲走私为何禁不住？","content":"今年一月底，刚果民主共和国警方查获了超过一吨重的穿山甲鳞片，这项历时六个多月的行动，再次将人们的目光聚焦于那一同当年的象牙走私一样，屡禁不止的走私濒危物种行为。究竟是什么原因使穿山甲走私活动继续如此猖獗呢？解决问题的钥匙是否捏在中国政府的手中？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E4%BF%9D%E5%A4%A9%E5%9C%B0/20260401-%E6%B3%95%E5%9B%BD%E4%B8%93%E5%AE%B6%E8%B0%88%E7%A9%BF%E5%B1%B1%E7%94%B2%E8%B5%B0%E7%A7%81%E4%B8%BA%E4%BD%95%E7%A6%81%E4%B8%8D%E4%BD%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/01/1775045212000.webp","sourceId":"rfi"},{"i