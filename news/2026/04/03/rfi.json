[{"id":1775206135000,"createdDate":"2026-04-03 08:48","name":"法国国际广播电台","title":"法韩建立“全面战略伙伴关系” 马克龙邀李在明出席G7峰会","content":"法国总统马克龙周五（4月3号）表示，法国和韩国已建立“全面战略伙伴关系”，此举将加强两国关系。法韩也签署了3份协定修正案、11份谅解备忘录和合作意向书，商定在关键矿产、核电、人工智能（AI）等多方面深化合作。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260403-%E6%B3%95%E9%9F%A9%E5%BB%BA%E7%AB%8B-%E5%85%A8%E9%9D%A2%E6%88%98%E7%95%A5%E4%BC%99%E4%BC%B4%E5%85%B3%E7%B3%BB-%E9%A9%AC%E5%85%8B%E9%BE%99%E9%82%80%E6%9D%8E%E5%9C%A8%E6%98%8E%E5%87%BA%E5%B8%ADg7%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775206135000.webp","sourceId":"rfi"},{"id":1775202849000,"createdDate":"2026-04-03 07:54","name":"法国国际广播电台","title":"特朗普「解放日」满一年 台湾对美出口大幅成长八成超越日韩","content":"根据《日经亚洲》报导，自特朗普宣布对等关税以来，台湾对美国出口大幅成长81.8%，达到1890亿美元，超越日本和韩国。大多受惠于人工智慧时代关键的高科技产业优势。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260403-%E7%89%B9%E6%9C%97%E6%99%AE-%E8%A7%A3%E6%94%BE%E6%97%A5-%E6%BB%A1%E4%B8%80%E5%B9%B4-%E5%8F%B0%E6%B9%BE%E5%AF%B9%E7%BE%8E%E5%87%BA%E5%8F%A3%E5%A4%A7%E5%B9%85%E6%88%90%E9%95%BF%E5%85%AB%E6%88%90%E8%B6%85%E8%B6%8A%E6%97%A5%E9%9F%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775202849000.webp","sourceId":"rfi"},{"id":1775200021000,"createdDate":"2026-04-03 07:07","name":"法国国际广播电台","title":"香港跃为全球第五大商贸经济体 中国续居首位","content":"面对去年的关税贸易战和国际贸易碎片，香港反而跃升为全球第五大商品贸易经济体，较2024年跃升两位；商品贸易总额按年上升17.5%至15850亿美元(下同)，占全球总额3%。港府官员表示，面对挑战，香港对外贸易展现强劲韧力。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260403-%E9%A6%99%E6%B8%AF%E8%B7%83%E4%B8%BA%E5%85%A8%E7%90%83%E7%AC%AC%E4%BA%94%E5%A4%A7%E5%95%86%E8%B4%B8%E7%BB%8F%E6%B5%8E%E4%BD%93-%E4%B8%AD%E5%9B%BD%E7%BB%AD%E5%B1%85%E9%A6%96%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775200021000.webp","sourceId":"rfi"},{"id":1775199567000,"createdDate":"2026-04-03 06:59","name":"法国国际广播电台","title":"港府申请充公黎智英财产 称要切断危害国安资金链","content":"继将与《苹果日报》相关的三间公司除牌后，香港政府采取进一步行动，申请把被裁定串谋勾结外国势力罪名成立的该报创办人黎智英的资产充公。政府的新闻公报未有透露充公的数额或详情，未知是否包括五年前藉国安法律冻结的三间《苹果》公司涉及的1800万港元(折算约199万欧元)资产。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260403-%E6%B8%AF%E5%BA%9C%E7%94%B3%E8%AF%B7%E5%85%85%E5%85%AC%E9%BB%8E%E6%99%BA%E8%8B%B1%E8%B4%A2%E4%BA%A7-%E7%A7%B0%E8%A6%81%E5%88%87%E6%96%AD%E5%8D%B1%E5%AE%B3%E5%9B%BD%E5%AE%89%E8%B5%84%E9%87%91%E7%82%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775199567000.webp","sourceId":"rfi"}]