[{"id":1775206135000,"createdDate":"2026-04-03 08:48","name":"法国国际广播电台","title":"法韩建立“全面战略伙伴关系” 马克龙邀李在明出席G7峰会","content":"法国总统马克龙周五（4月3号）表示，法国和韩国已建立“全面战略伙伴关系”，此举将加强两国关系。法韩也签署了3份协定修正案、11份谅解备忘录和合作意向书，商定在关键矿产、核电、人工智能（AI）等多方面深化合作。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260403-%E6%B3%95%E9%9F%A9%E5%BB%BA%E7%AB%8B-%E5%85%A8%E9%9D%A2%E6%88%98%E7%95%A5%E4%BC%99%E4%BC%B4%E5%85%B3%E7%B3%BB-%E9%A9%AC%E5%85%8B%E9%BE%99%E9%82%80%E6%9D%8E%E5%9C%A8%E6%98%8E%E5%87%BA%E5%B8%ADg7%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775206135000.webp","sourceId":"rfi"},{"id":1775202849000,"createdDate":"2026-04-03 07:54","name":"法国国际广播电台","title":"特朗普「解放日」满一年 台湾对美出口大幅成长八成超越日韩","content":"根据《日经亚洲》报导，自特朗普宣布对等关税以来，台湾对美国出口大幅成长81.8%，达到1890亿美元，超越日本和韩国。大多受惠于人工智慧时代关键的高科技产业优势。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260403-%E7%89%B9%E6%9C%97%E6%99%AE-%E8%A7%A3%E6%94%BE%E6%97%A5-%E6%BB%A1%E4%B8%80%E5%B9%B4-%E5%8F%B0%E6%B9%BE%E5%AF%B9%E7%BE%8E%E5%87%BA%E5%8F%A3%E5%A4%A7%E5%B9%85%E6%88%90%E9%95%BF%E5%85%AB%E6%88%90%E8%B6%85%E8%B6%8A%E6%97%A5%E9%9F%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775202849000.webp","sourceId":"rfi"},{"id":1775200021000,"createdDate":"2026-04-03 07:07","name":"法国国际广播电台","title":"香港跃为全球第五大商贸经济体 中国续居首位","content":"面对去年的关税贸易战和国际贸易碎片，香港反而跃升为全球第五大商品贸易经济体，较2024年跃升两位；商品贸易总额按年上升17.5%至15850亿美元(下同)，占全球总额3%。港府官员表示，面对挑战，香港对外贸易展现强劲韧力。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260403-%E9%A6%99%E6%B8%AF%E8%B7%83%E4%B8%BA%E5%85%A8%E7%90%83%E7%AC%AC%E4%BA%94%E5%A4%A7%E5%95%86%E8%B4%B8%E7%BB%8F%E6%B5%8E%E4%BD%93-%E4%B8%AD%E5%9B%BD%E7%BB%AD%E5%B1%85%E9%A6%96%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775200021000.webp","sourceId":"rfi"},{"id":1775199567000,"createdDate":"2026-04-03 06:59","name":"法国国际广播电台","title":"港府申请充公黎智英财产 称要切断危害国安资金链","content":"继将与《苹果日报》相关的三间公司除牌后，香港政府采取进一步行动，申请把被裁定串谋勾结外国势力罪名成立的该报创办人黎智英的资产充公。政府的新闻公报未有透露充公的数额或详情，未知是否包括五年前藉国安法律冻结的三间《苹果》公司涉及的1800万港元(折算约199万欧元)资产。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260403-%E6%B8%AF%E5%BA%9C%E7%94%B3%E8%AF%B7%E5%85%85%E5%85%AC%E9%BB%8E%E6%99%BA%E8%8B%B1%E8%B4%A2%E4%BA%A7-%E7%A7%B0%E8%A6%81%E5%88%87%E6%96%AD%E5%8D%B1%E5%AE%B3%E5%9B%BD%E5%AE%89%E8%B5%84%E9%87%91%E7%82%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775199567000.webp","sourceId":"rfi"},{"id":1775229118000,"createdDate":"2026-04-03 15:11","name":"法国国际广播电台","title":"美国施压加剧 古巴宣布出于“人道主义和主权姿态”将释放2010名囚犯","content":"古巴政府周四晚间宣布，将从监狱中释放2000多名囚犯。这是今年古巴共产党领导的政府第二次在与美国特朗普政府进行谈判期间宣布囚犯特赦。古共中央机关报《格拉玛报》称此举是“人道主义和主权姿态”。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260403-%E7%BE%8E%E5%9B%BD%E6%96%BD%E5%8E%8B%E5%8A%A0%E5%89%A7-%E5%8F%A4%E5%B7%B4%E5%AE%A3%E5%B8%83%E5%87%BA%E4%BA%8E-%E4%BA%BA%E9%81%93%E4%B8%BB%E4%B9%89%E5%92%8C%E4%B8%BB%E6%9D%83%E5%A7%BF%E6%80%81-%E5%B0%86%E9%87%8A%E6%94%BE2010%E5%90%8D%E5%9B%9A%E7%8A%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775229118000.webp","sourceId":"rfi"},{"id":1775227840000,"createdDate":"2026-04-03 14:50","name":"法国国际广播电台","title":"美联邦通信委员会提议扩大禁止进口中国电子设备范围","content":"美国联邦通信委员会（FCC）周五提议禁止进口一批中国制造商的设备。此前，FCC已于2022年禁止批准这些制造商生产的新型设备。这是华盛顿打击中国制造电子设备的最新举措。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260403-%E7%BE%8E%E8%81%94%E9%82%A6%E9%80%9A%E4%BF%A1%E5%A7%94%E5%91%98%E4%BC%9A%E6%8F%90%E8%AE%AE%E6%89%A9%E5%A4%A7%E7%A6%81%E6%AD%A2%E8%BF%9B%E5%8F%A3%E4%B8%AD%E5%9B%BD%E7%A7%91%E6%8A%80%E8%AE%BE%E5%A4%87%E8%8C%83%E5%9B%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775227840000.webp","sourceId":"rfi"},{"id":1775226235000,"createdDate":"2026-04-03 14:23","name":"法国国际广播电台","title":"泽连斯基谴责俄罗斯空袭“升级”并表示愿意帮助疏通霍尔木兹海峡","content":"乌克兰总统泽连斯基今天与教宗良十四世通话，谴责俄罗斯轰炸“升级”而非复活节休战，此前莫斯科对乌克兰再次发动了大规模空袭。另外乌克兰总统泽连斯基表示愿意帮助疏通霍尔木兹海峡。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260403-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E8%B0%B4%E8%B4%A3%E4%BF%84%E7%BD%97%E6%96%AF%E7%A9%BA%E8%A2%AD-%E5%8D%87%E7%BA%A7-%E5%B9%B6%E8%A1%A8%E7%A4%BA%E6%84%BF%E6%84%8F%E5%B8%AE%E5%8A%A9%E7%96%8F%E9%80%9A%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775226235000.webp","sourceId":"rfi"},{"id":1775225748000,"createdDate":"2026-04-03 14:15","name":"法国国际广播电台","title":"特朗普称很快就能轻易打通霍尔木兹海峡 一美战机被击落，正搜寻两名机组人员","content":"美国总统特朗普（DonaldTrump）周五表示，可以再给一些时间以疏通霍尔木兹海峡，与此同时，各方压力不断增加，要求其政府尽快解决与伊朗的战争。特朗普在其社媒平台“真相社交”上贴文称，“只要再多一点时间，我们就能轻易打通霍尔木兹海峡，夺取石油，大赚一笔。那对世界来说岂不是‘井喷’？？？”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260403-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E5%BE%88%E5%BF%AB%E5%B0%B1%E8%83%BD%E8%BD%BB%E6%98%93%E6%89%93%E9%80%9A%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E4%B8%80%E7%BE%8E%E6%88%98%E6%9C%BA%E8%A2%AB%E5%87%BB%E8%90%BD%EF%BC%8C%E6%AD%A3%E6%90%9C%E5%AF%BB%E4%B8%A4%E5%90%8D%E6%9C%BA%E7%BB%84%E4%BA%BA%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775225748000.webp","sourceId":"rfi"},{"id":1775223830000,"createdDate":"2026-04-03 13:43","name":"法国国际广播电台","title":"霍尔木兹海峡：安理会决议草案据报含“防御性” 手段护航  伊朗警告勿“挑衅”","content":"自2月28日以色列和美国对伊朗发动空袭引发冲突以来，德黑兰几乎瘫痪了霍尔木兹海峡。联合国安理会预计周六（4月4号）就巴林提出的旨在恢复和保护商船通过海峡的决议草案进行投票表决。最新草案强调，安理会将授权任何国家或国家联盟使用“防御性”手段确保船舶安全。这项授权条款并未包含在最初的草案中。伊朗方面已经警告安理会不要采取任何“挑衅行动”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260403-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E5%AE%89%E7%90%86%E4%BC%9A%E5%86%B3%E8%AE%AE%E8%8D%89%E6%A1%88%E6%8D%AE%E6%8A%A5%E5%90%AB-%E9%98%B2%E5%BE%A1%E6%80%A7-%E6%89%8B%E6%AE%B5%E6%8A%A4%E8%88%AA-%E4%BC%8A%E6%9C%97%E8%AD%A6%E5%91%8A%E5%8B%BF-%E6%8C%91%E8%A1%85","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775223830000.webp","sourceId":"rfi"},{"id":1775223675000,"createdDate":"2026-04-03 13:41","name":"法国国际广播电台","title":"继军媒批评后 广电总局开会要求电视剧业杜绝“颜值崇拜”","content":"自北京方面消息，中国国家广播电视总局电视剧司周四（2日）召开电视剧健康审美座谈会。会议指出，要坚决摒弃畸形审美，实现从“明星中心制”转向“剧本中心制”。要杜绝“颜值崇拜”，坚持“内容为王、人物为本”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260403-%E7%BB%A7%E5%86%9B%E5%AA%92%E6%89%B9%E8%AF%84%E5%90%8E-%E5%B9%BF%E7%94%B5%E6%80%BB%E5%B1%80%E5%BC%80%E4%BC%9A%E8%A6%81%E6%B1%82%E7%94%B5%E8%A7%86%E5%89%A7%E4%B8%9A%E6%9D%9C%E7%BB%9D%E9%A2%9C%E5%80%BC%E5%B4%87%E6%8B%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775223675000.webp","sourceId":"rfi"},{"id":1775219799000,"createdDate":"2026-04-03 12:36","name":"法国国际广播电台","title":"FBI向美国会通报一起涉华重大黑客攻击事件 涉维尔京群岛的FBI系统","content":"据美国全国广播公司（NBC）援引一位高级执法官员和一位知情人士透露，美国联邦调查局（FBI）已将一起疑似中国黑客入侵政府监控系统的事件定性为“重大事件”，认为其对美国国家安全构成威胁。消息人士称，此次黑客攻击泄露了与美国国内执法相关的敏感信息，FBI近期已将此事通报给国会议员。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260403-fbi%E5%90%91%E7%BE%8E%E5%9B%BD%E4%BC%9A%E9%80%9A%E6%8A%A5%E4%B8%80%E8%B5%B7%E6%B6%89%E5%8D%8E%E9%87%8D%E5%A4%A7%E9%BB%91%E5%AE%A2%E6%94%BB%E5%87%BB%E4%BA%8B%E4%BB%B6-%E6%B6%89%E7%BB%B4%E5%B0%94%E4%BA%AC%E7%BE%A4%E5%B2%9B%E7%9A%84fbi%E7%B3%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775219799000.webp","sourceId":"rfi"},{"id":1775216329000,"createdDate":"2026-04-03 11:38","name":"法国国际广播电台","title":"首位执行月球轨道任务的女性宇航员：克里斯蒂娜·科赫的登月使命","content":"克里斯蒂娜·科赫（ChristinaKoch）正在创造历史。这位美国宇航员刚刚从肯尼迪航天中心搭乘“阿尔忒弥斯二号”成功发射升空，而距离人类上一次登月飞行已经过去了54年。克里斯蒂娜是首位飞出地球轨道的女性宇航员，在为期10天的任务中，她将绕月飞行而不着陆，为人类太空探索史翻开新的篇章。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260403-%E9%A6%96%E4%BD%8D%E6%89%A7%E8%A1%8C%E6%9C%88%E7%90%83%E8%BD%A8%E9%81%93%E4%BB%BB%E5%8A%A1%E7%9A%84%E5%A5%B3%E6%80%A7%E5%AE%87%E8%88%AA%E5%91%98-%E5%85%8B%E9%87%8C%E6%96%AF%E8%92%82%E5%A8%9C%C2%B7%E7%A7%91%E8%B5%AB%E7%9A%84%E7%99%BB%E6%9C%88%E4%BD%BF%E5%91%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775216329000.webp","sourceId":"rfi"},{"id":1775215442000,"createdDate":"2026-04-03 11:24","name":"法国国际广播电台","title":"伊朗战争冲击美国中期选举 民意反弹、共和党内部分裂加剧","content":"美国总统特朗普（DonaldTrump）在2026年2月28日宣布对伊朗开战后，原本被视为稳操胜券的共和党中期选举，选情迅速逆转。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260403-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E5%86%B2%E5%87%BB%E7%BE%8E%E5%9B%BD%E4%B8%AD%E6%9C%9F%E9%80%89%E4%B8%BE-%E6%B0%91%E6%84%8F%E5%8F%8D%E5%BC%B9-%E5%85%B1%E5%92%8C%E5%85%9A%E5%86%85%E9%83%A8%E5%88%86%E8%A3%82%E5%8A%A0%E5%89%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775215442000.webp","sourceId":"rfi"},{"id":1775213358000,"createdDate":"2026-04-03 10:49","name":"法国国际广播电台","title":"伊朗战争一月后：中国渐失耐心，以最低限度参与支持一项和平计划","content":"随着中东战争进入第二个月，中国开始感到不耐烦了，周四2日要求立即停止中东局势“升级”之际，《解放报》国际版当晚刊登资深记者ArnaudVaulerin的文章指出，通过与巴基斯坦联署一份呼吁遏制局势升级的五点倡议，习近平政权在政治层面审慎推进，寻求危机解决方案——既着眼于确保航运安全，也着力维护与美国的关系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260403-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E4%B8%80%E6%9C%88%E5%90%8E-%E4%B8%AD%E5%9B%BD%E6%B8%90%E5%A4%B1%E8%80%90%E5%BF%83%EF%BC%8C%E4%BB%A5%E6%9C%80%E4%BD%8E%E9%99%90%E5%BA%A6%E5%8F%82%E4%B8%8E%E6%94%AF%E6%8C%81%E4%B8%80%E9%A1%B9%E5%92%8C%E5%B9%B3%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775213358000.webp","sourceId":"rfi"},{"id":1775213075000,"createdDate":"2026-04-03 10:44","name":"法国国际广播电台","title":"涉嫌严重违纪违法 中共中央政治局委员马兴瑞被查","content":"4月3日，官方消息显示，中央政治局委员、中央农村工作领导小组副组长马兴瑞涉嫌严重违纪违法，目前正接受中央纪委国家监委纪律审查和监察调查。自此去年11月起连续缺席重要高层会议的马兴瑞官宣落马。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260403-%E6%B6%89%E5%AB%8C%E4%B8%A5%E9%87%8D%E8%BF%9D%E7%BA%AA%E8%BF%9D%E6%B3%95-%E4%B8%AD%E5%85%B1%E4%B8%AD%E5%A4%AE%E6%94%BF%E6%B2%BB%E5%B1%80%E5%A7%94%E5%91%98%E9%A9%AC%E5%85%B4%E7%91%9E%E8%A2%AB%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775213075000.webp","sourceId":"rfi"},{"id":1775212668000,"createdDate":"2026-04-03 10:37","name":"法国国际广播电台","title":"鲁比奥指中方扣押巴拿马籍船舶“霸凌、破坏供应链稳定” 北京：坚定维护自身正当权益","content":"美国国务卿鲁比奥（MarcoRubio）周四公开指责中方“霸凌”巴拿马，扣押或阻拦数十艘悬挂巴拿马国旗的船只——尽管时间很短。今年1月下旬，巴拿马最高法院宣布1997年授予香港长和旗下——巴拿马港口公司（PPC）运营巴拿马运河太平洋和大西洋两侧巴尔博亚和克里斯托瓦尔码头的法律框架无效。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260403-%E9%B2%81%E6%AF%94%E5%A5%A5%E6%8C%87%E4%B8%AD%E6%96%B9%E6%89%A3%E6%8A%BC%E5%B7%B4%E6%8B%BF%E9%A9%AC%E7%B1%8D%E8%88%B9%E8%88%B6-%E9%9C%B8%E5%87%8C-%E7%A0%B4%E5%9D%8F%E4%BE%9B%E5%BA%94%E9%93%BE%E7%A8%B3%E5%AE%9A-%E5%8C%97%E4%BA%AC-%E5%9D%9A%E5%AE%9A%E7%BB%B4%E6%8A%A4%E8%87%AA%E8%BA%AB%E6%AD%A3%E5%BD%93%E6%9D%83%E7%9B%8A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775212668000.webp","sourceId":"rfi"},{"id":1775210933000,"createdDate":"2026-04-03 10:08","name":"法国国际广播电台","title":"中国，有望成美国冒险攻打伊朗致其印太地位衰退的最大赢家","content":"法广听友大家好，欢迎收听法国报纸摘要，今天是4月3日星期五，我们为您选播《回声报》上对于中国在伊朗战争爆发月余后利弊得失的分析。这篇由亚洲政治专家Pierre-AntoineDonnet撰写的文章说，北京置身冲突之外，如今似乎即将坐收美国深陷伊朗泥潭的渔翁之利。第三次海湾战争或将标志着美国在印太地区战略地位的持久衰退，从而为中国巩固其在该地区的影响力创造条件。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260403-%E4%B8%AD%E5%9B%BD%EF%BC%8C%E6%9C%89%E6%9C%9B%E6%88%90%E7%BE%8E%E5%9B%BD%E5%86%92%E9%99%A9%E6%94%BB%E6%89%93%E4%BC%8A%E6%9C%97%E8%87%B4%E5%85%B6%E5%8D%B0%E5%A4%AA%E5%9C%B0%E4%BD%8D%E8%A1%B0%E9%80%80%E7%9A%84%E6%9C%80%E5%A4%A7%E8%B5%A2%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775210933000.webp","sourceId":"rfi"},{"id":1775209283000,"createdDate":"2026-04-03 09:41","name":"法国国际广播电台","title":"美议员提新法案收紧荷日对华芯片设备出口管制 浸没式DUV也全禁","content":"美国国会两党议员公布了一项旨在打击芯片制造设备出口到中国的法案，尤其针对包括荷兰和日本在内的盟友。此举旨在帮助华盛顿进一步遏制北京的技术野心。该法案草案于周四提交美国众议院，将加强对阿斯麦（ASML）和东京威力科创（TEL）等公司半导体制造设备销售的现有限制。据知情人士透露，美国参议院预计将于本月晚些时候公布相应的法案版本。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260403-%E7%BE%8E%E8%AE%AE%E5%91%98%E6%8F%90%E6%96%B0%E6%B3%95%E6%A1%88%E6%94%B6%E7%B4%A7%E8%8D%B7%E6%97%A5%E5%AF%B9%E5%8D%8E%E8%8A%AF%E7%89%87%E8%AE%BE%E5%A4%87%E5%87%BA%E5%8F%A3%E7%AE%A1%E5%88%B6-%E6%B5%B8%E6%B6%A6%E5%BC%8Fduv%E4%B9%9F%E5%85%A8%E7%A6%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775209283000.webp","sourceId":"rfi"},{"id":1775207460000,"createdDate":"2026-04-03 09:11","name":"法国国际广播电台","title":"日英意下一代战斗机项目进入统一研制阶段","content":"日本防卫大臣小泉进次郎在4月3日的记者会上，在谈及全球空中作战计划（GCAP）项目时表示，关于与英国、意大利共同推进研发的下一代战斗机项目，三国政府设立的国际机构“全球空中作战计划国际政府组织（GIGO）”与负责设计等工作的合资公司“边缘之翼（Edgewing）”已达成合同签署，并对此表示欢迎。他强调，为实现2035年部署首架机的目标，“将由三国政府与企业协同合作，推进高效开发”。这标志日英意下一代战斗机项目进入实质研制阶段。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260403-%E6%97%A5%E8%8B%B1%E6%84%8F%E4%B8%8B%E4%B8%80%E4%BB%A3%E6%88%98%E6%96%97%E6%9C%BA%E9%A1%B9%E7%9B%AE%E8%BF%9B%E5%85%A5%E7%BB%9F%E4%B8%80%E7%A0%94%E5%88%B6%E9%98%B6%E6%AE%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/03/1775207460000.webp","sourceId":"rfi"}]