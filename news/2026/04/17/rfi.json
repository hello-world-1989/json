[{"id":1776408939000,"createdDate":"2026-04-17 06:55","name":"法国国际广播电台","title":"国安法刑满出狱 前议员郭家麒医生资格终身被剥：见怪不怪","content":"已就民主派「35+」初选案被裁定串谋颠覆国家政权罪服刑完毕的前立法会医学界议员郭家麒，在出狱後一年，被香港医务委员会以维持公众信心为由而终身除牌，不能在港执业，成为首名因医生涉及国家安全法律案件而举行研讯的个案，裁决有先例作用。郭家麒表示，对裁决「毫不诧异」，也明白当下香港「什麽荒谬的事情也可以发生」；有评论员形容，这是要对「35+」初选案这世纪寃案的人赶尽杀绝。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260417-%E5%9B%BD%E5%AE%89%E6%B3%95%E5%88%91%E6%BB%A1%E5%87%BA%E7%8B%B1-%E5%89%8D%E8%AE%AE%E5%91%98%E9%83%AD%E5%AE%B6%E9%BA%92%E5%8C%BB%E7%94%9F%E8%B5%84%E6%A0%BC%E7%BB%88%E8%BA%AB%E8%A2%AB%E5%89%A5-%E8%A7%81%E6%80%AA%E4%B8%8D%E6%80%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776408939000.webp","sourceId":"rfi"},{"id":1776408666000,"createdDate":"2026-04-17 06:51","name":"法国国际广播电台","title":"高兟审而未判逾两周 联合国人权高专办呼吁立即释放","content":"联合国人权事务高级专员办事处对被中国闭门审讯的艺术家高兟表示关注，发言人指出，该处关注当局以新的「侵害英雄烈士名誉丶荣誉罪」来追溯控告高兟多年前有关讽刺毛泽东的作品，是以刑事罪行惩罚艺术表达，违背法律原则，吁吁立即无条件释放高兟，并取消对其妻子和儿子的出境限制。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260417-%E9%AB%98%E5%85%9F%E5%AE%A1%E8%80%8C%E6%9C%AA%E5%88%A4%E9%80%BE%E4%B8%A4%E5%91%A8-%E8%81%94%E5%90%88%E5%9B%BD%E4%BA%BA%E6%9D%83%E9%AB%98%E4%B8%93%E5%8A%9E%E5%91%BC%E5%90%81%E7%AB%8B%E5%8D%B3%E9%87%8A%E6%94%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776408666000.webp","sourceId":"rfi"},{"id":1776440443000,"createdDate":"2026-04-17 15:40","name":"法国国际广播电台","title":"媒体：中国乐用台湾人打台湾自己","content":"路透：“信息战是北京在不诉诸武力的情况下消耗台湾战略的一部分。在这方面，台湾在野的国民党为中国提供了一个宝贵的契机”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260417-%E5%AA%92%E4%BD%93-%E4%B8%AD%E5%9B%BD%E4%B9%90%E7%94%A8%E5%8F%B0%E6%B9%BE%E4%BA%BA%E6%89%93%E5%8F%B0%E6%B9%BE%E8%87%AA%E5%B7%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776440443000.webp","sourceId":"rfi"},{"id":1776437376000,"createdDate":"2026-04-17 14:49","name":"法国国际广播电台","title":"从纽约走向世界的国际法语作家节","content":"提到法语世界，大家首先想到的可能是法国，是比利时、瑞士或加拿大的魁北克等法语为通用语言之一的地区，或者伴随了法国海外殖民步伐的非洲国家。在英语几乎成为全球通用语言的当今世界，“国际法语作家节”竟然是于20220年在美国纽约诞生的，如今它已经是覆盖全球五十多个国家的400多名作家的法语文学网络。2026年3月26日至28日，这个国际法语文学节活动重返纽约，并在2026年4月10日至12日首次在美国新泽西州城市普林斯顿以及宾夕法尼亚州城市费城举办活动。如果说“国际法语作家节”得以在国际立足，并持续在美国发展反映着法语正重新巩固其国际地位的话，法语世界仍未完全走出以法国，以前法属殖民地为中心的刻板印象。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C/20260417-%E4%BB%8E%E7%BA%BD%E7%BA%A6%E8%B5%B0%E5%90%91%E4%B8%96%E7%95%8C%E7%9A%84%E5%9B%BD%E9%99%85%E6%B3%95%E8%AF%AD%E4%BD%9C%E5%AE%B6%E8%8A%82","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776437376000.webp","sourceId":"rfi"},{"id":1776435023000,"createdDate":"2026-04-17 14:10","name":"法国国际广播电台","title":"菲律宾加入美国“硅和平”倡议  将共建工业中心加强供应链安全","content":"美国国务院在4月16日一份声明中表示，马尼拉加入华盛顿牵头的旨在保障人工智能和半导体供应链的“硅和平倡议”（PaxSilica）后，两国将共同建设一个占地4000英亩（1620公顷）的工业中心。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260417-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%8A%A0%E5%85%A5%E7%BE%8E%E5%9B%BD-%E7%A1%85%E5%92%8C%E5%B9%B3-%E5%80%A1%E8%AE%AE-%E5%B0%86%E5%85%B1%E5%BB%BA%E5%B7%A5%E4%B8%9A%E4%B8%AD%E5%BF%83%E5%8A%A0%E5%BC%BA%E4%BE%9B%E5%BA%94%E9%93%BE%E5%AE%89%E5%85%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776435023000.webp","sourceId":"rfi"},{"id":1776432934000,"createdDate":"2026-04-17 13:35","name":"法国国际广播电台","title":"英法等三十多国巴黎共商霍尔木兹海峡护航使命，美国缺席","content":"法国总统马克龙和英国首相斯塔默17日在巴黎召开峰会，与全球不同地区三十多个国家一起讨论如何启动一项保证霍尔木兹海峡安全通航的行动，希望在伊朗的封锁与美国的反向封锁之间找到第三条道路。美国缺席相关讨论。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260417-%E8%8B%B1%E6%B3%95%E7%AD%89%E4%B8%89%E5%8D%81%E5%A4%9A%E5%9B%BD%E5%B7%B4%E9%BB%8E%E5%85%B1%E5%95%86%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%8A%A4%E8%88%AA%E4%BD%BF%E5%91%BD%EF%BC%8C%E7%BE%8E%E5%9B%BD%E7%BC%BA%E5%B8%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776432934000.webp","sourceId":"rfi"},{"id":1776432233000,"createdDate":"2026-04-17 13:23","name":"法国国际广播电台","title":"后欧尔班时代匈牙利对华经济关系：务实非敌对 重新平衡 强化监管？","content":"在匈牙利上周日的立法选举中，连续四届赢得绝对多数席位的总理欧尔班及其领导的青民盟遭遇惨败,领导蒂萨党获胜的毛焦尔将组建下一届政府。匈牙利的内政外交都将迎来重大变革，对华政策也不例外。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E7%BB%8F%E6%B5%8E/20260417-%E5%90%8E%E6%AC%A7%E5%B0%94%E7%8F%AD%E6%97%B6%E4%BB%A3%E5%8C%88%E7%89%99%E5%88%A9%E5%AF%B9%E5%8D%8E%E7%BB%8F%E6%B5%8E%E5%85%B3%E7%B3%BB-%E5%8A%A1%E5%AE%9E%E9%9D%9E%E6%95%8C%E5%AF%B9-%E9%87%8D%E6%96%B0%E5%B9%B3%E8%A1%A1-%E5%BC%BA%E5%8C%96%E7%9B%91%E7%AE%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776432233000.webp","sourceId":"rfi"},{"id":1776430707000,"createdDate":"2026-04-17 12:58","name":"法国国际广播电台","title":"土库曼斯坦与中国启动大型天然气田工程 丁薛祥称它已进入每个中国家庭","content":"土库曼斯坦和中国周五启动了扩大加尔金内什（Galkynysh）巨大天然气田产量的工程。法新社说，此举进一步加强了中国在这个中亚封闭国家能源领域的不可或缺的地位。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260417-%E5%9C%9F%E5%BA%93%E6%9B%BC%E6%96%AF%E5%9D%A6%E4%B8%8E%E4%B8%AD%E5%9B%BD%E5%90%AF%E5%8A%A8%E5%A4%A7%E5%9E%8B%E5%A4%A9%E7%84%B6%E6%B0%94%E7%94%B0%E5%B7%A5%E7%A8%8B-%E4%B8%81%E8%96%9B%E7%A5%A5%E7%A7%B0%E5%AE%83%E5%B7%B2%E8%BF%9B%E5%85%A5%E6%AF%8F%E4%B8%AA%E4%B8%AD%E5%9B%BD%E5%AE%B6%E5%BA%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776430707000.webp","sourceId":"rfi"},{"id":1776429938000,"createdDate":"2026-04-17 12:45","name":"法国国际广播电台","title":"中东战争：中国能否将危机转化为机遇？专家怎么答...","content":"大家好，欢迎收听法国报纸摘要，今天是4月17日星期五，法国各全国性日报头版重点多以国内议题为主。《十字架报》除推出探讨法国短期合同的封面专题外，也采访了多位专家针对中国面对中东战争能否将危机化为机遇？提出他们的看法。据《十字架报》分析说，美国封锁伊朗港口直接触及北京的核心利益，中国从伊朗进口的石油占其总进口量的近13%。具有讽刺意味的是，美国的不可预测行动可能反而会增强其中国对手的实力——前提是危机不会持续太久。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260417-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89-%E4%B8%AD%E5%9B%BD%E8%83%BD%E5%90%A6%E5%B0%86%E5%8D%B1%E6%9C%BA%E8%BD%AC%E5%8C%96%E4%B8%BA%E6%9C%BA%E9%81%87-%E4%B8%93%E5%AE%B6%E6%80%8E%E4%B9%88%E7%AD%94","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776429938000.webp","sourceId":"rfi"},{"id":1776429559000,"createdDate":"2026-04-17 12:39","name":"法国国际广播电台","title":"特朗普称伊朗同意交出“核尘埃” 美伊停火谈判关键时刻要来了？","content":"美国总统唐纳德·特朗普周四16日表示，伊朗已同意交出在去年美军空袭后埋于地下的高浓缩铀，即他所称的“核尘埃”，若此说法属实，将是华盛顿削弱德黑兰核武能力的重要进展。不过，伊朗方面截至目前并未证实相关让步，外界对此仍保持高度怀疑。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%BE%8E%E5%9B%BD%E4%B8%93%E6%A0%8F/20260417-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E4%BC%8A%E6%9C%97%E5%90%8C%E6%84%8F%E4%BA%A4%E5%87%BA-%E6%A0%B8%E5%B0%98%E5%9F%83-%E7%BE%8E%E4%BC%8A%E5%81%9C%E7%81%AB%E8%B0%88%E5%88%A4%E5%85%B3%E9%94%AE%E6%97%B6%E5%88%BB%E8%A6%81%E6%9D%A5%E4%BA%86","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776429559000.webp","sourceId":"rfi"},{"id":1776426916000,"createdDate":"2026-04-17 11:55","name":"法国国际广播电台","title":"以色列与黎巴嫩停火协议正式生效 特朗普称美国与伊朗或于本周末再会晤","content":"法新社17日贝鲁特报道说，在美国总统唐纳德·特朗普宣布的为期十天的停火协议生效后，黎巴嫩南部和贝鲁特南郊的居民于周五纷纷返回因以色列与亲伊朗的真主党之间的战争而遭破坏的家园。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260417-%E4%BB%A5%E8%89%B2%E5%88%97%E4%B8%8E%E9%BB%8E%E5%B7%B4%E5%AB%A9%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E6%AD%A3%E5%BC%8F%E7%94%9F%E6%95%88-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E7%BE%8E%E5%9B%BD%E4%B8%8E%E4%BC%8A%E6%9C%97%E6%88%96%E4%BA%8E%E6%9C%AC%E5%91%A8%E6%9C%AB%E5%86%8D%E4%BC%9A%E6%99%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776426916000.webp","sourceId":"rfi"},{"id":1776423768000,"createdDate":"2026-04-17 11:02","name":"法国国际广播电台","title":"以黎刚达成停火就遭违反，细看停火协议具体内容","content":"4月17日上午，黎巴嫩军方表示，以色列在午夜刚刚生效的为期10天停火协议后不久即出现违反行为，对黎巴嫩南部多个村庄实施间歇性轰炸。停火协议于前一日午夜正式启动，而以色列方面在此前已表示其部队仍部署在相关区域，对上述指控暂未立即回应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260417-%E4%BB%A5%E9%BB%8E%E5%88%9A%E8%BE%BE%E6%88%90%E5%81%9C%E7%81%AB%E5%B0%B1%E9%81%AD%E8%BF%9D%E5%8F%8D%EF%BC%8C%E7%BB%86%E7%9C%8B%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E5%85%B7%E4%BD%93%E5%86%85%E5%AE%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776423768000.webp","sourceId":"rfi"},{"id":1776418762000,"createdDate":"2026-04-17 09:39","name":"法国国际广播电台","title":"广交会展商疾呼“战争得要尽快结束”：中东冲突重压中国中小工厂的最后利润","content":"据《回声报》广交会特派记者RaphaëlBalenieri报道指出，广东中小工业企业深受伊朗战争引发的原材料价格上涨之苦，塑料价格尤为突出，原因在于作为原料的石油和天然气价格攀升，加之运输成本上涨，都令本已利润微薄的中国中小工业企业雪上加霜，利润被进一步压缩。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260417-%E5%B9%BF%E4%BA%A4%E4%BC%9A%E5%B1%95%E5%95%86%E7%96%BE%E5%91%BC-%E6%88%98%E4%BA%89%E5%B0%BD%E5%BF%AB%E7%BB%93%E6%9D%9F-%E4%B8%AD%E4%B8%9C%E5%86%B2%E7%AA%81%E9%87%8D%E5%8E%8B%E4%B8%AD%E5%9B%BD%E4%B8%AD%E5%B0%8F%E5%B7%A5%E5%8E%82%E7%9A%84%E6%9C%80%E5%90%8E%E5%88%A9%E6%B6%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776418762000.webp","sourceId":"rfi"},{"id":1776417000000,"createdDate":"2026-04-17 09:10","name":"法国国际广播电台","title":"欧盟拟重启与叙利亚正式政治接触，叙在霍尔木兹海峡危机中地位凸显","content":"4月17日路透社布鲁塞尔和大马士革消息，一份由欧盟外交机构起草、并于本周分发给成员国的背景文件指出，欧盟将全面恢复与叙利亚在1978年签署的合作协议。双方关系已经冻结了多年。同时，欧盟还计划于5月11日与叙利亚过渡当局启动“高级别政治对话”，这是一种正式且具有结构性的会谈机制。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260417-%E6%AC%A7%E7%9B%9F%E6%8B%9F%E9%87%8D%E5%90%AF%E4%B8%8E%E5%8F%99%E5%88%A9%E4%BA%9A%E6%AD%A3%E5%BC%8F%E6%94%BF%E6%B2%BB%E6%8E%A5%E8%A7%A6%EF%BC%8C%E5%8F%99%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%8D%B1%E6%9C%BA%E4%B8%AD%E5%9C%B0%E4%BD%8D%E5%87%B8%E6%98%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776417000000.webp","sourceId":"rfi"},{"id":1776467207000,"createdDate":"2026-04-17 23:06","name":"法国国际广播电台","title":"法国出版业危机，马克龙：“维护”出版多元化“至关重要”","content":"在法国出版业正陷入一场罕见危机的背景下，马克龙总统称，“维护”出版多元化“至关重要”。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260417-%E6%B3%95%E5%9B%BD%E5%87%BA%E7%89%88%E4%B8%9A%E5%8D%B1%E6%9C%BA%EF%BC%8C%E9%A9%AC%E5%85%8B%E9%BE%99-%E7%BB%B4%E6%8A%A4-%E5%87%BA%E7%89%88%E5%A4%9A%E5%85%83%E5%8C%96-%E8%87%B3%E5%85%B3%E9%87%8D%E8%A6%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776467207000.webp","sourceId":"rfi"},{"id":1776467032000,"createdDate":"2026-04-17 23:03","name":"法国国际广播电台","title":"稀土：欧洲企业落入中国管控措施的陷阱","content":"法国世界报报道，中国欧盟商会对中国当局在稀土出口领域实施的管控工具表示担忧。它呼吁欧盟不要再被动地去面对中美博弈了。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260417-%E7%A8%80%E5%9C%9F-%E6%AC%A7%E6%B4%B2%E4%BC%81%E4%B8%9A%E8%90%BD%E5%85%A5%E4%B8%AD%E5%9B%BD%E7%AE%A1%E6%8E%A7%E6%8E%AA%E6%96%BD%E7%9A%84%E9%99%B7%E9%98%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776467032000.webp","sourceId":"rfi"},{"id":1776465337000,"createdDate":"2026-04-17 22:35","name":"法国国际广播电台","title":"“越南习近平”苏林中国行：  “同志加兄弟”来了？","content":"越共总书记兼国家主席苏林，4月17日在十余小时的高铁之旅结束后告别中国，这位罕见地打破越南二十多年来集体领导体制的强人，在把党权和国家权力一把抓之后首访中国，与同样集党权与国家权力一身的中国领导人习近平会面，随后乘高铁横跨中国南北数千公里，颇受瞩目。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260417-%E8%B6%8A%E5%8D%97%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%8B%8F%E6%9E%97%E4%B8%AD%E5%9B%BD%E8%A1%8C-%E5%90%8C%E5%BF%97%E5%8A%A0%E5%85%84%E5%BC%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776465337000.webp","sourceId":"rfi"},{"id":1776461601000,"createdDate":"2026-04-17 21:33","name":"法国国际广播电台","title":"美国将在菲律宾建高科技制造区 削弱中国供应链影响力","content":"美国与菲律宾近日签署协议，计划在吕宋岛建设一座高科技产业中心，以推动美国制造业发展，并减少对中国关键矿产及原材料供应的依赖。这一举措被视为美国总统唐纳德·特朗普政府削弱中国在全球供应链主导地位的最新行动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260417-%E7%BE%8E%E5%9B%BD%E5%B0%86%E5%9C%A8%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%BB%BA%E9%AB%98%E7%A7%91%E6%8A%80%E5%88%B6%E9%80%A0%E5%8C%BA-%E5%89%8A%E5%BC%B1%E4%B8%AD%E5%9B%BD%E4%BE%9B%E5%BA%94%E9%93%BE%E5%BD%B1%E5%93%8D%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776461601000.webp","sourceId":"rfi"},{"id":1776461191000,"createdDate":"2026-04-17 21:26","name":"法国国际广播电台","title":"中国指日舰过航台海属“蓄意挑衅” 台方称\"有效掌控\"","content":"中国外交部周五(4月17日）指责日本一艘军舰当天通过台湾海峡属“蓄意挑衅”，已向日方提出强烈抗议，并称中方已全程跟监相关行动；台湾方面则表示，对周边海空动态均“有效掌握”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260417-%E4%B8%AD%E5%9B%BD%E6%8C%87%E6%97%A5%E8%88%B0%E8%BF%87%E8%88%AA%E5%8F%B0%E6%B5%B7%E5%B1%9E-%E8%93%84%E6%84%8F%E6%8C%91%E8%A1%85-%E5%8F%B0%E6%96%B9%E7%A7%B0-%E6%9C%89%E6%95%88%E6%8E%8C%E6%8E%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776461191000.webp","sourceId":"rfi"},{"id":1776460925000,"createdDate":"2026-04-17 21:22","name":"法国国际广播电台","title":"缅甸新总统宣布大赦 昂山素季获得减刑","content":"缅甸当局4月17日在传统新年大赦中宣布为昂山素季减刑。此举由新任总统敏昂莱主导，他曾于2021年发动政变推翻昂山素季领导的政府。分析认为，这一决定是其上任后释放政治信号的重要举措之一。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260417-%E7%BC%85%E7%94%B8%E6%96%B0%E6%80%BB%E7%BB%9F%E5%AE%A3%E5%B8%83%E5%A4%A7%E8%B5%A6-%E6%98%82%E5%B1%B1%E7%B4%A0%E5%AD%A3%E8%8E%B7%E5%BE%97%E5%87%8F%E5%88%91","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776460925000.webp","sourceId":"rfi"},{"id":1776460729000,"createdDate":"2026-04-17 21:18","name":"法国国际广播电台","title":"德国查处跨国性交易网络 涉数十名中国女性非法入境","content":"德国检方周五（4月17日）表示，一个跨国犯罪网络在过去数年间，将数十名未持有效居留许可的中国女性带入德国，并安排其从事卖淫活动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260417-%E5%BE%B7%E5%9B%BD%E6%9F%A5%E5%A4%84%E8%B7%A8%E5%9B%BD%E6%80%A7%E4%BA%A4%E6%98%93%E7%BD%91%E7%BB%9C-%E6%B6%89%E6%95%B0%E5%8D%81%E5%90%8D%E4%B8%AD%E5%9B%BD%E5%A5%B3%E6%80%A7%E9%9D%9E%E6%B3%95%E5%85%A5%E5%A2%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776460729000.webp","sourceId":"rfi"},{"id":1776460382000,"createdDate":"2026-04-17 21:13","name":"法国国际广播电台","title":"特朗普：美伊协议接近达成 已无重大分歧","content":"美国总统特朗普周五（4月17日）在接受法新社采访时表示，美国与伊朗“已非常接近”达成协议，并称华盛顿与德黑兰之间“已不存在实质性分歧”。特朗普并表示，伊朗已承诺“永远不会再关闭霍尔木兹海峡”，在美国协助下，伊朗“已经或正在清除”该海域的所有水雷。而伊朗方面周五否认已同意转移其浓缩铀库存。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260417-%E7%89%B9%E6%9C%97%E6%99%AE-%E7%BE%8E%E4%BC%8A%E5%8D%8F%E8%AE%AE-%E6%8E%A5%E8%BF%91%E8%BE%BE%E6%88%90-%E5%B7%B2%E6%97%A0%E9%87%8D%E5%A4%A7%E5%88%86%E6%AD%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776460382000.webp","sourceId":"rfi"},{"id":1776460257000,"createdDate":"2026-04-17 21:10","name":"法国国际广播电台","title":"美国国会聚焦中国非法捕鱼　跨党派警告威胁国安与全球供应链","content":"美国国会本周四针对中国非法、未报告及不受规范（IUU）捕鱼问题举行听证会，跨党派议员与官员一致警告，相关行为已从单纯渔业争议升高为影响国家安全、全球供应链与人权的复合性威胁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260417-%E7%BE%8E%E5%9B%BD%E5%9B%BD%E4%BC%9A%E8%81%9A%E7%84%A6%E4%B8%AD%E5%9B%BD%E9%9D%9E%E6%B3%95%E6%8D%95%E9%B1%BC-%E8%B7%A8%E5%85%9A%E6%B4%BE%E8%AD%A6%E5%91%8A%E5%A8%81%E8%83%81%E5%9B%BD%E5%AE%89%E4%B8%8E%E5%85%A8%E7%90%83%E4%BE%9B%E5%BA%94%E9%93%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776460257000.webp","sourceId":"rfi"},{"id":1776459827000,"createdDate":"2026-04-17 21:03","name":"法国国际广播电台","title":"黎巴嫩停战后伊朗全面开放霍尔木兹海峡","content":"伊朗周五宣布在停战期间“全面”开放霍尔木兹海峡，稍早，以色列与黎巴嫩真主党民兵正式停战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260417-%E9%BB%8E%E5%B7%B4%E5%AB%A9%E5%81%9C%E6%88%98%E5%90%8E%E4%BC%8A%E6%9C%97%E5%85%A8%E9%9D%A2%E5%BC%80%E6%94%BE%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776459827000.webp","sourceId":"rfi"},{"id":1776448123000,"createdDate":"2026-04-17 17:48","name":"法国国际广播电台","title":"首尔: 在北京和莫斯科支持下，朝鲜经济出现复苏迹象","content":"韩国统一部周五向法新社提交的一份报告指出，在平壤加强与俄罗斯和中国关系的背景下，朝鲜经济正显出复苏的迹象。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260417-%E9%A6%96%E5%B0%94-%E5%9C%A8%E5%8C%97%E4%BA%AC%E5%92%8C%E8%8E%AB%E6%96%AF%E7%A7%91%E6%94%AF%E6%8C%81%E4%B8%8B%EF%BC%8C%E6%9C%9D%E9%B2%9C%E7%BB%8F%E6%B5%8E%E5%87%BA%E7%8E%B0%E5%A4%8D%E8%8B%8F%E8%BF%B9%E8%B1%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776448123000.webp","sourceId":"rfi"},{"id":1776447467000,"createdDate":"2026-04-17 17:37","name":"法国国际广播电台","title":"苏林结束访华 北京承诺融资修建越南高铁","content":"越南最高领导人苏林周五结束对中国为期四天的国是访问。北京承诺援建越南高铁，特别是提供财政援助。越南新高铁包括中国“一带一路”项目的一部分，将连接越南东北部的重要港口海防、河内以及中国南部。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260417-%E8%8B%8F%E6%9E%97%E7%BB%93%E6%9D%9F%E8%AE%BF%E5%8D%8E-%E5%8C%97%E4%BA%AC%E6%89%BF%E8%AF%BA%E8%9E%8D%E8%B5%84%E4%BF%AE%E5%BB%BA%E8%B6%8A%E5%8D%97%E9%93%81%E8%B7%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776447467000.webp","sourceId":"rfi"},{"id":1776446122000,"createdDate":"2026-04-17 17:15","name":"法国国际广播电台","title":"日本自卫队舰艇进入台湾海峡 中国强烈抗议","content":"共同社引述多名日中关系消息人士透露称，日本海上自卫队护卫舰“雷”号17日航行通过台湾海峡。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260417-%E6%97%A5%E6%9C%AC%E8%87%AA%E5%8D%AB%E9%98%9F%E8%88%B0%E8%89%87%E8%BF%9B%E5%85%A5%E5%8F%B0%E6%B9%BE%E6%B5%B7%E5%B3%A1-%E4%B8%AD%E5%9B%BD%E5%BC%BA%E7%83%88%E6%8A%97%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/17/1776446122000.webp","sourceId":"rfi"}]