[{"id":1777191041000,"createdDate":"2026-04-26 08:10","name":"法国国际广播电台","title":"王毅：中国承诺帮助缅甸维护安全与主权","content":"法新社消息称，当地时间4月25日，中国外交部长王毅在与缅甸新任总统敏昂莱会晤时表示，将“坚定支持缅方维护好国家主权、安全和领土完整”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260426-%E7%8E%8B%E6%AF%85-%E4%B8%AD%E5%9B%BD%E6%89%BF%E8%AF%BA%E5%B8%AE%E5%8A%A9%E7%BC%85%E7%94%B8%E7%BB%B4%E6%8A%A4%E5%AE%89%E5%85%A8%E4%B8%8E%E4%B8%BB%E6%9D%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777191041000.webp","sourceId":"rfi"},{"id":1777216284000,"createdDate":"2026-04-26 15:11","name":"法国国际广播电台","title":"俄防长会见金正恩出席援俄朝军纪念馆开幕式：两国关系正处于前所未有的高水平","content":"俄罗斯国防部周日宣布，俄国防部长别洛乌索夫抵达朝鲜进行工作访问。他将与朝鲜最高领导层和军方官员举行会谈。在平壤机场，别洛乌索夫受到了朝鲜国防相努光铁大将的迎接。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260426-%E4%BF%84%E9%98%B2%E9%95%BF%E4%BC%9A%E8%A7%81%E9%87%91%E6%AD%A3%E6%81%A9%E5%87%BA%E5%B8%AD%E6%8F%B4%E4%BF%84%E6%9C%9D%E5%86%9B%E7%BA%AA%E5%BF%B5%E9%A6%86%E5%BC%80%E5%B9%95%E5%BC%8F-%E4%B8%A4%E5%9B%BD%E5%85%B3%E7%B3%BB%E6%AD%A3%E5%A4%84%E4%BA%8E%E5%89%8D%E6%89%80%E6%9C%AA%E6%9C%89%E7%9A%84%E9%AB%98%E6%B0%B4%E5%B9%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777216284000.webp","sourceId":"rfi"},{"id":1777214080000,"createdDate":"2026-04-26 14:34","name":"法国国际广播电台","title":"台湾部会首长时隔7年登太平岛主持演练 越南抗议","content":"针对台湾在太平岛（越南称岛波平）举行“南援九号”演练的报道，越南政府重申反对任何未经其许可在斯普拉特利群岛（中方称南沙群岛）和帕拉塞尔群岛（中方称西沙群岛）进行的外国活动。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260426-%E5%8F%B0%E6%B9%BE%E9%83%A8%E4%BC%9A%E9%A6%96%E9%95%BF%E6%97%B6%E9%9A%947%E5%B9%B4%E7%99%BB%E5%A4%AA%E5%B9%B3%E5%B2%9B%E4%B8%BB%E6%8C%81%E6%BC%94%E7%BB%83-%E8%B6%8A%E5%8D%97%E6%8A%97%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777214080000.webp","sourceId":"rfi"},{"id":1777211087000,"createdDate":"2026-04-26 13:44","name":"法国国际广播电台","title":"日美将在军民两用技术领域开展合作 首阶段关注无人机","content":"据共同社周日获悉，日本和美国政府计划在年底前建立一个官民合作框架，旨在利用军民两用技术开发防卫装备，该框架将促成负责构思和设计的企业与负责制造的企业展开合作。第一阶段预计将在日本生产由美国初创公司研发的无人机。此举旨在对抗占据无人机市场大部分份额的中国，同时强化防务相关供应链。围绕防卫装备研发的日美一体化进程可能会加速。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260426-%E6%97%A5%E7%BE%8E%E5%B0%86%E5%9C%A8%E5%86%9B%E6%B0%91%E4%B8%A4%E7%94%A8%E6%8A%80%E6%9C%AF%E9%A2%86%E5%9F%9F%E5%BC%80%E5%B1%95%E5%90%88%E4%BD%9C-%E9%A6%96%E9%98%B6%E6%AE%B5%E5%85%B3%E6%B3%A8%E6%97%A0%E4%BA%BA%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777211087000.webp","sourceId":"rfi"},{"id":1777209012000,"createdDate":"2026-04-26 13:10","name":"法国国际广播电台","title":"流亡藏人社区选举终选 9万多藏人27个国家投票","content":"周日，流亡海外的藏人将投票选举流亡政府。此次选举意义非凡，因为他们正为不可避免的未来做准备，那就是失去他们敬仰的西藏精神领袖达赖喇嘛。总部位于印度的藏人行政中央——被北京谴责为“分裂主义政治团体”——是流亡藏人的重要机构，尤其是在达赖喇嘛于2011年卸下政治领袖身分之后。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260426-%E6%B5%81%E4%BA%A1%E8%97%8F%E4%BA%BA%E7%A4%BE%E5%8C%BA%E9%80%89%E4%B8%BE%E7%BB%88%E9%80%89-9%E4%B8%87%E5%A4%9A%E8%97%8F%E4%BA%BA27%E4%B8%AA%E5%9B%BD%E5%AE%B6%E6%8A%95%E7%A5%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777209012000.webp","sourceId":"rfi"},{"id":1777207253000,"createdDate":"2026-04-26 12:40","name":"法国国际广播电台","title":"[视频] - [法语世界]第153集:法国神学家谈教宗Léon XIV非洲行","content":"梵蒂冈教廷第267任天主教教宗PapeLéonXIV于2026年04月23日星期四全满结束对非洲四国11天的使徒之行(unevisiteapostolique)。法国天主教神学家、宗教史和宗教人类学专家皮埃尔·迪亚拉博士（Dr.PierreDiarra）在接受本台法广(RFI)法语[非洲大咖嘉宾](GrandInvitéAfrique)节目女主持人CharlotteIdrac采访时，谈到跨宗教对话在耶稣信仰传播中的重要意义。现任罗马教宗首次牧灵之旅走访的四个国家：阿尔及利亚、喀麦隆、安哥拉和赤道几内亚，要不是说法语，要不就是和[法语国家及地区国际组织]（OIF）有直接衔接。（编译：法广尼古拉）注：梵蒂冈把PapeLéonXIV的中文翻译为：教宗良十四世；中国官方的翻译是：教皇利奧十四世。[Mondefrancophone-153]avecDr.PierreDiarra,Théologien,GrandInvitéAfriquedeRFIaumicrode CharlotteIdrac(le13avril2026)","newsLink":"https://www.rfi.fr/cn/rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C-%E7%AC%AC153%E9%9B%86-%E6%B3%95%E5%9B%BD%E7%A5%9E%E5%AD%A6%E5%AE%B6%E8%B0%88%E5%A4%A9%E4%B8%BB%E6%95%99%E6%95%99%E5%AE%97%E9%9D%9E%E6%B4%B2%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777207253000.webp","sourceId":"rfi"},{"id":1777203039000,"createdDate":"2026-04-26 11:30","name":"法国国际广播电台","title":"白宫记者晚宴枪击案嫌疑人承认目标是特朗普政府官员 先前无犯罪记录","content":"据哥伦比亚广播公司（CBS）新闻网报导，两名消息人士透露，周六晚在白宫记者协会晚宴外枪击案中被捕的嫌疑人艾伦（ColeTomasAllen）在被捕后告诉执法部门，他想枪击特朗普政府官员。一名执法部门消息人士称，该嫌疑人没有明确表示他的目标是特朗普总统，只是说是“政府官员”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260426-%E7%99%BD%E5%AE%AB%E8%AE%B0%E8%80%85%E6%99%9A%E5%AE%B4%E6%9E%AA%E5%87%BB%E6%A1%88%E5%AB%8C%E7%96%91%E4%BA%BA%E6%89%BF%E8%AE%A4%E7%9B%AE%E6%A0%87%E6%98%AF%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E5%AE%98%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777203039000.webp","sourceId":"rfi"},{"id":1777199867000,"createdDate":"2026-04-26 10:37","name":"法国国际广播电台","title":"日韩拟下月首次举行次官级外交防务2+2磋商 加强安保合作","content":"自东京方面消息，日韩政府正在筹备两国外交部和国防部次官级（副部长级）官员之间的新磋商机制，并协调于下月初在首尔举行首次会议。此举旨在加强安保合作，尤其关注中国和朝鲜的动向。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260426-%E6%97%A5%E9%9F%A9%E6%8B%9F%E4%B8%8B%E6%9C%88%E9%A6%96%E6%AC%A1%E4%B8%BE%E8%A1%8C%E6%AC%A1%E5%AE%98%E7%BA%A7%E5%A4%96%E4%BA%A4%E9%98%B2%E5%8A%A12-2%E7%A3%8B%E5%95%86-%E5%8A%A0%E5%BC%BA%E5%AE%89%E4%BF%9D%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777199867000.webp","sourceId":"rfi"},{"id":1777199442000,"createdDate":"2026-04-26 10:30","name":"法国国际广播电台","title":"泰评：王毅访东盟 寻求地区稳定","content":"在过去一周里，中国外交部长王毅先后走访柬埔寨、泰国、缅甸三个东南亚国家。该地区媒体报道此行旨在稳定亚太地区局势、推进一带一路合作、加强该地区安全协同。评论认为北京有意在中美元首下月举行“习特会”前夕加强地区联盟，凸显中国影响力以抗衡美国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%9B%BC%E8%B0%B7%E4%B8%93%E6%A0%8F/20260426-%E6%B3%B0%E8%AF%84-%E7%8E%8B%E6%AF%85%E8%AE%BF%E4%B8%9C%E7%9B%9F-%E5%AF%BB%E6%B1%82%E5%9C%B0%E5%8C%BA%E7%A8%B3%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777199442000.webp","sourceId":"rfi"},{"id":1777198543000,"createdDate":"2026-04-26 10:15","name":"法国国际广播电台","title":"欧盟第20轮对俄制裁列单中企 北京：促立即移出制裁清单，一切后果由欧方承担","content":"中国商务部新闻发言人周六以答记者问方式，就欧盟第20轮对俄制裁列单中企一事表示，“中方将采取必要措施，坚决维护中国企业的正当合法权益，一切后果将由欧方承担”。欧盟数日前公布了针对俄罗斯的第20轮制裁措施细节，其中包括对多家中国公司实施新的限制。这些制裁针对的是向俄罗斯提供敏感高科技设备的第三国供应商，欧方指控多家中国公司向俄罗斯军工企业提供军民两用物项。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260426-%E6%AC%A7%E7%9B%9F%E7%AC%AC20%E8%BD%AE%E5%AF%B9%E4%BF%84%E5%88%B6%E8%A3%81%E5%88%97%E5%8D%95%E4%B8%AD%E4%BC%81-%E5%8C%97%E4%BA%AC-%E4%BF%83%E7%AB%8B%E5%8D%B3%E7%A7%BB%E5%87%BA%E5%88%B6%E8%A3%81%E6%B8%85%E5%8D%95%EF%BC%8C%E4%B8%80%E5%88%87%E5%90%8E%E6%9E%9C%E7%94%B1%E6%AC%A7%E6%96%B9%E6%89%BF%E6%8B%85","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777198543000.webp","sourceId":"rfi"},{"id":1777194842000,"createdDate":"2026-04-26 09:14","name":"法国国际广播电台","title":"白宫记者晚宴枪击案嫌疑人毕业于加州理工 是兼职教师和电游开发者","content":"据公开记录显示，涉嫌在周六晚白宫记者协会晚宴期间开枪的男子来自南加州，是一名教师兼电子游戏开发者。据两名知情人士向美国有限电视新闻网（CNN）透露，执法部门已确认，居住在洛杉矶郊区托伦斯的31岁男子​艾伦（ColeTomasAllen）就是在晚宴附近被制服的持枪男子。当时，特朗普总统和其他官员正在晚宴现场。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260426-%E7%99%BD%E5%AE%AB%E8%AE%B0%E8%80%85%E6%99%9A%E5%AE%B4%E6%9E%AA%E5%87%BB%E6%A1%88%E5%AB%8C%E7%96%91%E4%BA%BA%E6%AF%95%E4%B8%9A%E4%BA%8E%E5%8A%A0%E5%B7%9E%E7%90%86%E5%B7%A5-%E6%98%AF%E5%85%BC%E8%81%8C%E6%95%99%E5%B8%88%E5%92%8C%E7%94%B5%E6%B8%B8%E5%BC%80%E5%8F%91%E8%80%85","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777194842000.webp","sourceId":"rfi"},{"id":1777194763000,"createdDate":"2026-04-26 09:12","name":"法国国际广播电台","title":"特朗普再遭刺杀未遂，45年前里根也在同一间酒店中弹","content":"今天要闻解说的主题是特朗普再次遭遇刺杀未遂。45年前这间酒店也曾发生刺杀总统的枪击事件，这样的“巧合”让人不禁对酒店以及围绕总统的安保措施产生质疑。让我们先来还原一下事情的经过。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260426-%E7%89%B9%E6%9C%97%E6%99%AE%E5%86%8D%E9%81%AD%E5%88%BA%E6%9D%80%E6%9C%AA%E9%81%82-45%E5%B9%B4%E5%89%8D%E9%87%8C%E6%A0%B9%E4%B9%9F%E5%9C%A8%E5%90%8C%E4%B8%80%E9%97%B4%E9%85%92%E5%BA%97%E4%B8%AD%E5%BC%B9%EF%BC%8C%E6%80%BB%E7%BB%9F%E7%9A%84%E5%AE%89%E4%BF%9D%E6%8E%AA%E6%96%BD%E5%87%BA%E7%8E%B0-%E9%87%8D%E5%A4%A7%E7%BA%B0%E6%BC%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777194763000.webp","sourceId":"rfi"},{"id":1777193909000,"createdDate":"2026-04-26 08:58","name":"法国国际广播电台","title":"日本将修改自卫队法以出口二手武器","content":"据悉，日本防卫相小泉进次郎拟于5月大型连休期间访问东南亚的菲律宾和印度尼西亚。预计双方将就扩大安全保障合作以及防卫装备出口等问题展开磋商。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260426-%E6%97%A5%E6%9C%AC%E5%B0%86%E4%BF%AE%E6%94%B9%E8%87%AA%E5%8D%AB%E9%98%9F%E6%B3%95%E4%BB%A5%E5%87%BA%E5%8F%A3%E4%BA%8C%E6%89%8B%E6%AD%A6%E5%99%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777193909000.webp","sourceId":"rfi"},{"id":1777193419000,"createdDate":"2026-04-26 08:50","name":"法国国际广播电台","title":"特朗普：独狼枪手已被抓获，呼吁所有美国人以和平方式解决分歧","content":"美国总统特朗普（DonaldTrump）表示，他的印象是，周六在华盛顿特区扰乱白宫记者协会晚宴的嫌疑人是“独狼”作案，目前已被拘留，执法部门正在调查这起事件。当地时间周六晚，特朗普参加白宫记者协会晚宴时，建筑内传出枪声，总统一行人随后在安保人员护送下离场。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260426-%E7%89%B9%E6%9C%97%E6%99%AE-%E7%8B%AC%E7%8B%BC%E6%9E%AA%E6%89%8B%E5%B7%B2%E8%A2%AB%E6%8A%93%E8%8E%B7%EF%BC%8C%E5%91%BC%E5%90%81%E6%89%80%E6%9C%89%E7%BE%8E%E5%9B%BD%E4%BA%BA%E4%BB%A5%E5%92%8C%E5%B9%B3%E6%96%B9%E5%BC%8F%E8%A7%A3%E5%86%B3%E5%88%86%E6%AD%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777193419000.webp","sourceId":"rfi"},{"id":1777242063000,"createdDate":"2026-04-26 22:21","name":"法国国际广播电台","title":"电动汽车数量创纪录增长：中国遥遥领先 德国排名第三","content":"据德国N-TV电视台报道：搭载电动驱动系统的汽车保有量增长速度达到了前所未有的水平。其中中国遥遥领先，几乎难以被追赶。这一点也反映在最成功电动车制造商的统计数据中。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260426-%E7%94%B5%E5%8A%A8%E6%B1%BD%E8%BD%A6%E6%95%B0%E9%87%8F%E5%88%9B%E7%BA%AA%E5%BD%95%E5%A2%9E%E9%95%BF-%E4%B8%AD%E5%9B%BD%E9%81%A5%E9%81%A5%E9%A2%86%E5%85%88-%E5%BE%B7%E5%9B%BD%E6%8E%92%E5%90%8D%E7%AC%AC%E4%B8%89","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777242063000.webp","sourceId":"rfi"},{"id":1777238934000,"createdDate":"2026-04-26 21:28","name":"法国国际广播电台","title":"一法国记者谈被香港遣返的经历","content":"“无国界记者组织”（RSF）的数据显示：自2020年以来，至少已有13名记者被拒发签证或禁止入境香港，当中包括新闻自由倡议者。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260426-%E4%B8%80%E6%B3%95%E5%9B%BD%E8%AE%B0%E8%80%85%E8%B0%88%E8%A2%AB%E9%A6%99%E6%B8%AF%E9%81%A3%E8%BF%94%E7%9A%84%E7%BB%8F%E5%8E%86","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777238934000.webp","sourceId":"rfi"},{"id":1777238515000,"createdDate":"2026-04-26 21:21","name":"法国国际广播电台","title":"目击者：记者晚宴上枪手如何就地组装武器？","content":"美国总统特朗普周六（4月25日）出席每年一度的白宫记协晚宴时，周围传出枪响，特朗普等人被保护和紧急撤离华盛顿希尔顿饭店。特朗普成为任期内受到暗杀威胁次数最多的美国总统。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260426-%E7%9B%AE%E5%87%BB%E8%80%85-%E8%AE%B0%E8%80%85%E6%99%9A%E5%AE%B4%E4%B8%8A%E6%9E%AA%E6%89%8B%E5%A6%82%E4%BD%95%E5%B0%B1%E5%9C%B0%E7%BB%84%E8%A3%85%E6%AD%A6%E5%99%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777238515000.webp","sourceId":"rfi"},{"id":1777238502000,"createdDate":"2026-04-26 21:21","name":"法国国际广播电台","title":"马里国防部长在自杀式汽车炸弹袭击中丧生","content":"马里政府周日晚间宣布国防部长萨迪奥·卡马拉将军在周六的“恐怖袭击”中丧生。他是在首都巴马科附近卡蒂的住所遭到自杀式汽车炸弹袭击。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260426-%E9%A9%AC%E9%87%8C%E5%9B%BD%E9%98%B2%E9%83%A8%E9%95%BF%E5%9C%A8%E8%87%AA%E6%9D%80%E5%BC%8F%E6%B1%BD%E8%BD%A6%E7%82%B8%E5%BC%B9%E8%A2%AD%E5%87%BB%E4%B8%AD%E4%B8%A7%E7%94%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777238502000.webp","sourceId":"rfi"},{"id":1777238269000,"createdDate":"2026-04-26 21:17","name":"法国国际广播电台","title":"白金汉宫：枪击事件后   查理三世对美国事访问不变","content":"英国国王查尔斯三世定于4月27日开始对美国进行访问，行程包括在国会发表演讲以及出席白宫的国宴。白金汉宫26日特别强调说，记者协会晚宴发生的枪击案不会影响查尔斯三世访美的行程安排。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260426-%E7%99%BD%E9%87%91%E6%B1%89%E5%AE%AB-%E6%9E%AA%E5%87%BB%E4%BA%8B%E4%BB%B6%E5%90%8E-%E6%9F%A5%E7%90%86%E4%B8%89%E4%B8%96%E5%AF%B9%E7%BE%8E%E5%9B%BD%E4%BA%8B%E8%AE%BF%E9%97%AE%E4%B8%8D%E5%8F%98","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777238269000.webp","sourceId":"rfi"},{"id":1777235730000,"createdDate":"2026-04-26 20:35","name":"法国国际广播电台","title":"白宫记者晚宴爆枪击惊魂 国会批安全失灵","content":"美国华盛顿白宫记者协会晚宴周六晚上发生枪击事件后，国会迅速成为舆论与政策焦点，多名两党议员直指安全漏洞严重，要求彻查责任并强化维安机制；白宫记者协会则在稍晚发声，强调新闻自由核心价值不变，并将评估未来活动安排。总统特朗普（DonaldTrump）表示，计划在30天内重新举办晚宴。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260426-%E7%99%BD%E5%AE%AB%E8%AE%B0%E8%80%85%E6%99%9A%E5%AE%B4%E7%88%86%E6%9E%AA%E5%87%BB%E6%83%8A%E9%AD%82-%E5%9B%BD%E4%BC%9A%E6%89%B9%E5%AE%89%E5%85%A8%E5%A4%B1%E7%81%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777235730000.webp","sourceId":"rfi"},{"id":1777235065000,"createdDate":"2026-04-26 20:24","name":"法国国际广播电台","title":"伊朗仍没与美直接会谈的打算","content":"伊朗外长阿巴斯·阿拉格奇周日离开伊斯兰堡前往莫斯科。尽管美国总统特朗普取消了美国代表团的访问，中东冲突的调解人仍在努力维持和平谈判的势头。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260426-%E4%BC%8A%E6%9C%97%E4%BB%8D%E6%B2%A1%E4%B8%8E%E7%BE%8E%E7%9B%B4%E6%8E%A5%E4%BC%9A%E8%B0%88%E7%9A%84%E6%89%93%E7%AE%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777235065000.webp","sourceId":"rfi"},{"id":1777234938000,"createdDate":"2026-04-26 20:22","name":"法国国际广播电台","title":"2026北京国际车展：现代汽车推出中国专属电动车IONIQ V","content":"现代汽车在中国推出专属电动车品牌“IONIQ”，并计划在未来五年内推出20款新车型。为适应市场需求，现代汽车加强与中国电池企业CATL和自动驾驶公司Momenta的合作。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260426-2026%E5%8C%97%E4%BA%AC%E5%9B%BD%E9%99%85%E8%BD%A6%E5%B1%95-%E7%8E%B0%E4%BB%A3%E6%B1%BD%E8%BD%A6%E6%8E%A8%E5%87%BA%E4%B8%AD%E5%9B%BD%E4%B8%93%E5%B1%9E%E7%94%B5%E5%8A%A8%E8%BD%A6ioniq-v","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777234938000.webp","sourceId":"rfi"},{"id":1777233658000,"createdDate":"2026-04-26 20:00","name":"法国国际广播电台","title":"燃油价高     泛航航空（Transavia）取消五、六月部分航班","content":"一位公司发言人表示，此次航班取消“仅影响五月至六月期间不到2%的航班”，航空公司将通知乘客。此前已有乘客反映航班取消。法航-荷航集团旗下的低成本航空公司泛航航空(Transavia)发言人周日证实，由于中东战乱导致煤油价格飙升，该公司将调整5月和6月的航班时刻表。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260426-%E7%87%83%E6%B2%B9%E4%BB%B7%E9%AB%98-%E6%B3%9B%E8%88%AA%E8%88%AA%E7%A9%BA-transavia-%E5%8F%96%E6%B6%88%E4%BA%94-%E5%85%AD%E6%9C%88%E9%83%A8%E5%88%86%E8%88%AA%E7%8F%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777233658000.webp","sourceId":"rfi"},{"id":1777229581000,"createdDate":"2026-04-26 18:53","name":"法国国际广播电台","title":"非洲:喀麦隆启动第四次人口普查","content":"位于非洲中西部的喀麦隆，当局在2026年04月24日周五启动新一轮全国人口普查。整个进程预计将持续五个星期，到05月29日星期五截止。这是喀麦隆第四次全国人口普查。本台法广（RFI）非洲通讯员发自雅温得（Yaoundé）的法文消息指出，喀麦隆上一次人口普查活动要追溯到21年前的2005年。当年的居民人口总数是超过1700万。","newsLink":"https://www.rfi.fr/cn/%E7%BB%8F%E8%B4%B8/20260426-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E5%96%80%E9%BA%A6%E9%9A%86%E5%90%AF%E5%8A%A8%E7%AC%AC%E5%9B%9B%E6%AC%A1%E4%BA%BA%E5%8F%A3%E6%99%AE%E6%9F%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777229581000.webp","sourceId":"rfi"},{"id":1777225822000,"createdDate":"2026-04-26 17:50","name":"法国国际广播电台","title":"美国白宫记协晚宴枪手其人其事","content":"4月26日，美国媒体确认枪手身份，他是一名来自加利福尼亚州的31岁机械工程师和游戏开发者，名为科尔·托马斯·艾伦（ColeTomasAllen），此人曾导致美国总统特朗普出席的白宫记协晚宴陷入混乱。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260426-%E7%BE%8E%E5%9B%BD%E7%99%BD%E5%AE%AB%E8%AE%B0%E5%8D%8F%E6%99%9A%E5%AE%B4%E6%9E%AA%E6%89%8B%E5%85%B6%E4%BA%BA%E5%85%B6%E4%BA%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777225822000.webp","sourceId":"rfi"},{"id":1777224607000,"createdDate":"2026-04-26 17:30","name":"法国国际广播电台","title":"全球多国领导人谴责白宫记协晚宴枪击案","content":"涉及白宫记者晚宴枪击事件的枪手是一名31岁加利福尼亚州男子。美国总统特朗普表示，枪手携带多种武器，并冲向会场设立的安检站，还近距离朝一名特勤局人员开枪。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260426-%E5%85%A8%E7%90%83%E5%A4%9A%E5%9B%BD%E9%A2%86%E5%AF%BC%E4%BA%BA%E8%B0%B4%E8%B4%A3%E7%99%BD%E5%AE%AB%E8%AE%B0%E5%8D%8F%E6%99%9A%E5%AE%B4%E6%9E%AA%E5%87%BB%E6%A1%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777224607000.webp","sourceId":"rfi"},{"id":1777224333000,"createdDate":"2026-04-26 17:25","name":"法国国际广播电台","title":"马克龙谴责袭击事件","content":"美国总统特朗普出席的白宫记者晚宴突发枪击事件后，法国总统马克龙4月26日谴责了“不可接受的”袭击，并表达了对已撤离会场的美国总统特朗普的“全力支持”。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260426-%E9%A9%AC%E5%85%8B%E9%BE%99%E8%B0%B4%E8%B4%A3%E8%A2%AD%E5%87%BB%E4%BA%8B%E4%BB%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/26/1777224333000.webp","sourceId":"rfi"}]