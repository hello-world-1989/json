[{"id":1775463819000,"createdDate":"2026-04-06 08:23","name":"法国国际广播电台","title":"美以大规模轰炸行动计划已就绪 调解人做最后努力，争取先促成45天停火","content":"据Axios新闻网援引四位了解谈判情况的美国、以色列和地区消息人士报导称，美国、伊朗和一组地区调解人正在商讨一项可能为期45天的停火协议的条款，该协议有望永久结束这场战争。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260406-%E7%BE%8E%E4%BB%A5%E5%A4%A7%E8%A7%84%E6%A8%A1%E8%BD%B0%E7%82%B8%E8%A1%8C%E5%8A%A8%E8%AE%A1%E5%88%92%E5%B7%B2%E5%B0%B1%E7%BB%AA-%E8%B0%83%E8%A7%A3%E4%BA%BA%E5%81%9A%E6%9C%80%E5%90%8E%E5%8A%AA%E5%8A%9B%EF%BC%8C%E4%BA%89%E5%8F%96%E5%85%88%E4%BF%83%E6%88%9045%E5%A4%A9%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775463819000.webp","sourceId":"rfi"},{"id":1775462535000,"createdDate":"2026-04-06 08:02","name":"法国国际广播电台","title":"日本能与伊朗单独磋商并通过霍尔木兹海峡吗？","content":"由于美国和以色列对伊朗发动攻击，霍尔木兹海峡事实上被封锁，该海峡承担着日本94%的原油和6%的液化天然气（LNG）运输。在全球范围内，如此依赖中东石油的国家只有日本，日本面临着空前的能源危机和石油制品衍生危机，那么，从历史到如今一直和伊朗保持着友好关系的日本，是否能够和伊朗单独磋商，保证日本的船只通过霍尔木兹海峡呢？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260406-%E6%97%A5%E6%9C%AC%E8%83%BD%E4%B8%8E%E4%BC%8A%E6%9C%97%E5%8D%95%E7%8B%AC%E7%A3%8B%E5%95%86%E5%B9%B6%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775462535000.webp","sourceId":"rfi"},{"id":1775460352000,"createdDate":"2026-04-06 07:25","name":"法国国际广播电台","title":"港博物馆改港史：「六七暴动」变「反英抗暴」 以中共史观谈「香港故事」惹争议","content":"在《港区国安法》实施后，香港历史博物馆重整「香港故事」常设展览逾五年，于本月重开后，被指改以中共史观讲述殖民地年代史事及「六四事件」内容，包括将香港被「割让」的历史改为被英国「割占」；把1967年由中国在港左派发动的「六七暴动」说成「反英抗暴」；将「六四事件」改为「春夏之交的政治风」等等，而对这种有去殖地民化丶甚至篡改历史之嫌的争议，港府没有正面回应，只说这是与时并进，不拟与二十年前的旧展作对比。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260406-%E6%B8%AF%E5%8D%9A%E7%89%A9%E9%A6%86%E6%94%B9%E6%B8%AF%E5%8F%B2-%E5%85%AD%E4%B8%83%E6%9A%B4%E5%8A%A8-%E5%8F%98-%E5%8F%8D%E8%8B%B1%E6%8A%97%E6%9A%B4-%E4%BB%A5%E4%B8%AD%E5%85%B1%E5%8F%B2%E8%A7%82%E8%B0%88-%E9%A6%99%E6%B8%AF%E6%95%85%E4%BA%8B-%E6%83%B9%E4%BA%89%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775460352000.webp","sourceId":"rfi"},{"id":1775448856000,"createdDate":"2026-04-06 04:14","name":"法国国际广播电台","title":"中国大幅减少了污染，虽成功限制风暴数量，却加速北极气暖","content":"中国大幅减少了污染，甚至改变了风暴的路径。气溶胶的减少扰乱了北太平洋的旋风形成。反过来，这项气溶胶的变化又削弱了北极海冰层，加速了北极地区的气暖。这进一步证明了气候对人类活动的复杂响应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260406-%E4%B8%AD%E5%9B%BD%E5%A4%A7%E5%B9%85%E5%87%8F%E5%B0%91%E4%BA%86%E6%B1%A1%E6%9F%93%EF%BC%8C%E8%99%BD%E6%88%90%E5%8A%9F%E9%99%90%E5%88%B6%E9%A3%8E%E6%9A%B4%E6%95%B0%E9%87%8F%EF%BC%8C%E5%8D%B4%E5%8A%A0%E9%80%9F%E5%8C%97%E6%9E%81%E6%B0%94%E6%9A%96","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775448856000.webp","sourceId":"rfi"}]