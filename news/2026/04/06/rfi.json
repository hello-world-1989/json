[{"id":1775463819000,"createdDate":"2026-04-06 08:23","name":"法国国际广播电台","title":"美以大规模轰炸行动计划已就绪 调解人做最后努力，争取先促成45天停火","content":"据Axios新闻网援引四位了解谈判情况的美国、以色列和地区消息人士报导称，美国、伊朗和一组地区调解人正在商讨一项可能为期45天的停火协议的条款，该协议有望永久结束这场战争。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260406-%E7%BE%8E%E4%BB%A5%E5%A4%A7%E8%A7%84%E6%A8%A1%E8%BD%B0%E7%82%B8%E8%A1%8C%E5%8A%A8%E8%AE%A1%E5%88%92%E5%B7%B2%E5%B0%B1%E7%BB%AA-%E8%B0%83%E8%A7%A3%E4%BA%BA%E5%81%9A%E6%9C%80%E5%90%8E%E5%8A%AA%E5%8A%9B%EF%BC%8C%E4%BA%89%E5%8F%96%E5%85%88%E4%BF%83%E6%88%9045%E5%A4%A9%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775463819000.webp","sourceId":"rfi"},{"id":1775462535000,"createdDate":"2026-04-06 08:02","name":"法国国际广播电台","title":"日本能与伊朗单独磋商并通过霍尔木兹海峡吗？","content":"由于美国和以色列对伊朗发动攻击，霍尔木兹海峡事实上被封锁，该海峡承担着日本94%的原油和6%的液化天然气（LNG）运输。在全球范围内，如此依赖中东石油的国家只有日本，日本面临着空前的能源危机和石油制品衍生危机，那么，从历史到如今一直和伊朗保持着友好关系的日本，是否能够和伊朗单独磋商，保证日本的船只通过霍尔木兹海峡呢？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260406-%E6%97%A5%E6%9C%AC%E8%83%BD%E4%B8%8E%E4%BC%8A%E6%9C%97%E5%8D%95%E7%8B%AC%E7%A3%8B%E5%95%86%E5%B9%B6%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775462535000.webp","sourceId":"rfi"},{"id":1775460352000,"createdDate":"2026-04-06 07:25","name":"法国国际广播电台","title":"港博物馆改港史：「六七暴动」变「反英抗暴」 以中共史观谈「香港故事」惹争议","content":"在《港区国安法》实施后，香港历史博物馆重整「香港故事」常设展览逾五年，于本月重开后，被指改以中共史观讲述殖民地年代史事及「六四事件」内容，包括将香港被「割让」的历史改为被英国「割占」；把1967年由中国在港左派发动的「六七暴动」说成「反英抗暴」；将「六四事件」改为「春夏之交的政治风」等等，而对这种有去殖地民化丶甚至篡改历史之嫌的争议，港府没有正面回应，只说这是与时并进，不拟与二十年前的旧展作对比。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260406-%E6%B8%AF%E5%8D%9A%E7%89%A9%E9%A6%86%E6%94%B9%E6%B8%AF%E5%8F%B2-%E5%85%AD%E4%B8%83%E6%9A%B4%E5%8A%A8-%E5%8F%98-%E5%8F%8D%E8%8B%B1%E6%8A%97%E6%9A%B4-%E4%BB%A5%E4%B8%AD%E5%85%B1%E5%8F%B2%E8%A7%82%E8%B0%88-%E9%A6%99%E6%B8%AF%E6%95%85%E4%BA%8B-%E6%83%B9%E4%BA%89%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775460352000.webp","sourceId":"rfi"},{"id":1775448856000,"createdDate":"2026-04-06 04:14","name":"法国国际广播电台","title":"中国大幅减少了污染，虽成功限制风暴数量，却加速北极气暖","content":"中国大幅减少了污染，甚至改变了风暴的路径。气溶胶的减少扰乱了北太平洋的旋风形成。反过来，这项气溶胶的变化又削弱了北极海冰层，加速了北极地区的气暖。这进一步证明了气候对人类活动的复杂响应。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260406-%E4%B8%AD%E5%9B%BD%E5%A4%A7%E5%B9%85%E5%87%8F%E5%B0%91%E4%BA%86%E6%B1%A1%E6%9F%93%EF%BC%8C%E8%99%BD%E6%88%90%E5%8A%9F%E9%99%90%E5%88%B6%E9%A3%8E%E6%9A%B4%E6%95%B0%E9%87%8F%EF%BC%8C%E5%8D%B4%E5%8A%A0%E9%80%9F%E5%8C%97%E6%9E%81%E6%B0%94%E6%9A%96","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775448856000.webp","sourceId":"rfi"},{"id":1775488997000,"createdDate":"2026-04-06 15:23","name":"法国国际广播电台","title":"据信被击落随后被救的美国军官从藏身处指挥了对伊朗阵地空袭","content":"美国武器军官驾驶的战斗机在伊朗上空被击落后，他躲藏在山脊上等待美军救援之际，据信他利用紧急通讯设备协助指挥了对伊朗伊斯兰共和国军队的空袭。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260406-%E6%8D%AE%E4%BF%A1%E8%A2%AB%E5%87%BB%E8%90%BD%E9%9A%8F%E5%90%8E%E8%A2%AB%E6%95%91%E7%9A%84%E7%BE%8E%E5%9B%BD%E5%86%9B%E5%AE%98%E4%BB%8E%E8%97%8F%E8%BA%AB%E5%A4%84%E6%8C%87%E6%8C%A5%E4%BA%86%E5%AF%B9%E4%BC%8A%E6%9C%97%E9%98%B5%E5%9C%B0%E7%A9%BA%E8%A2%AD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775488997000.webp","sourceId":"rfi"},{"id":1775488816000,"createdDate":"2026-04-06 15:20","name":"法国国际广播电台","title":"台学者王宏仁看郑丽文北京行：北京欲向美展示两岸有和解迹象","content":"2025年年底当选台湾最大在野党国民党党主席的郑丽文4月7日将启程前往北京访问。预计她此行可能也将与中国国家主席习近平会晤。这是国民党在职党主席时隔十年首次访问北京，意义因此也不同寻常。而郑丽文自去年11月底当选党主席以来，早已流露出想要访问北京的意愿，但只是在近日此行才被正式安排上日程。而此次访问的时机，也正赶在美国总统特朗普延后至5月中旬访问北京之前。这种时间上的安排也令人多有揣测。台湾成功大学政治系教授、国策研究院执行长王宏仁先生接受本台电话采访时认为，郑丽文此次北京行程的时间安排颇有些刻意设计。北京方面可能想在特朗普访华之前营造某种两岸出现和解对话趋势的假象。同时，特兰普第二个总统任期下政策的不确定性可能也令北京感觉有必要进一步支持台湾的统派力量。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260406-%E5%8F%B0%E5%AD%A6%E8%80%85%E7%8E%8B%E5%AE%8F%E4%BB%81%E7%9C%8B%E9%83%91%E4%B8%BD%E6%96%87%E5%8C%97%E4%BA%AC%E8%A1%8C-%E5%8C%97%E4%BA%AC%E6%AC%B2%E5%90%91%E7%BE%8E%E5%B1%95%E7%A4%BA%E4%B8%A4%E5%B2%B8%E6%9C%89%E5%92%8C%E8%A7%A3%E8%BF%B9%E8%B1%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775488816000.webp","sourceId":"rfi"},{"id":1775488053000,"createdDate":"2026-04-06 15:07","name":"法国国际广播电台","title":"伊朗拒绝停火提议 回复包含十点内容 美官员指“最大限度”不利外交解决","content":"伊朗官媒伊通社周一报道称，伊朗已就美国提出的结束战争的提议通过巴基斯坦作出回应，拒绝停火，并强调必须永久结束战争。该报道补充说，伊朗当局的回应包含十项条款，其中包括结束该地区的冲突、制定霍尔木兹海峡安全通航规约、解除制裁以及重建。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260406-%E4%BC%8A%E6%9C%97%E6%8B%92%E7%BB%9D%E5%81%9C%E7%81%AB%E6%8F%90%E8%AE%AE-%E5%9B%9E%E5%A4%8D%E5%8C%85%E5%90%AB%E5%8D%81%E7%82%B9%E5%86%85%E5%AE%B9-%E7%BE%8E%E5%AE%98%E5%91%98%E6%8C%87-%E6%9C%80%E5%A4%A7%E9%99%90%E5%BA%A6-%E4%B8%8D%E5%88%A9%E5%A4%96%E4%BA%A4%E8%A7%A3%E5%86%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775488053000.webp","sourceId":"rfi"},{"id":1775486623000,"createdDate":"2026-04-06 14:43","name":"法国国际广播电台","title":"菲律宾参议院考虑在小马科斯任期内推动菲中联合石油勘探","content":"随着菲政府寻求确保替代能源供应的途径，菲律宾参议院正考虑在小马科斯总统执政期间，重启菲律宾与中国在西菲律宾海（菲方对其专属经济区内南中国海海域的称呼）的联合石油勘探。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260406-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%8F%82%E8%AE%AE%E9%99%A2%E8%80%83%E8%99%91%E5%9C%A8%E5%B0%8F%E9%A9%AC%E7%A7%91%E6%96%AF%E4%BB%BB%E6%9C%9F%E5%86%85%E6%8E%A8%E5%8A%A8%E8%8F%B2%E4%B8%AD%E8%81%94%E5%90%88%E7%9F%B3%E6%B2%B9%E5%8B%98%E6%8E%A2","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775486623000.webp","sourceId":"rfi"},{"id":1775484497000,"createdDate":"2026-04-06 14:08","name":"法国国际广播电台","title":"遭石油封锁电力匮乏 古巴加快对中国太阳能技术依赖","content":"据英国《金融时报》报导，古巴正借助从中国大量进口太阳能技术来缓解因美国特朗普政府施加的近乎全面的石油封锁，而加剧的电力短缺和停电问题。去年，中方向这个共产主义岛国提供了1吉瓦（GW）的光伏电池板，并承诺提供更多支持，以帮助古巴根据其新的经济和社会计划，在2026年实现15%的电力来自可再生能源。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260406-%E9%81%AD%E7%9F%B3%E6%B2%B9%E5%B0%81%E9%94%81%E7%94%B5%E5%8A%9B%E5%8C%AE%E4%B9%8F-%E5%8F%A4%E5%B7%B4%E5%8A%A0%E5%BF%AB%E5%AF%B9%E4%B8%AD%E5%9B%BD%E5%A4%AA%E9%98%B3%E8%83%BD%E6%8A%80%E6%9C%AF%E4%BE%9D%E8%B5%96","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775484497000.webp","sourceId":"rfi"},{"id":1775481416000,"createdDate":"2026-04-06 13:16","name":"法国国际广播电台","title":"“阿尔忒弥斯二号”探月 ：NASA将直播飞船绕月飞行","content":"美国“阿尔忒弥斯二号”（ArtemisII）飞船4月1日自佛罗里达州发射升空近五天后，6日国际标准时间凌晨4点42分已经进入月球引力圈。这是开始绕月飞行前的最后一个阶段。这次载人绕月飞行不仅因为开创了有女性飞行员和黑人飞行员参与的先例，而且也是人类太空探索史上，飞船距离地球最远的一次旅行。从多个角度说都可以说是一次历史性的飞行。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260406-%E9%98%BF%E5%B0%94%E5%BF%92%E5%BC%A5%E6%96%AF%E4%BA%8C%E5%8F%B7-%E6%8E%A2%E6%9C%88-nasa%E5%B0%86%E7%9B%B4%E6%92%AD%E9%A3%9E%E8%88%B9%E7%BB%95%E6%9C%88%E9%A3%9E%E8%A1%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775481416000.webp","sourceId":"rfi"},{"id":1775476798000,"createdDate":"2026-04-06 11:59","name":"法国国际广播电台","title":"郑丽文周二启程出访大陆 郑习会据报预定周五登场","content":"综合消息显示，国民党主席郑丽文周二将启程访问中国大陆，展开为期5天的参访行程，各界关注的“郑习会”预定周五登场；这将是10年后，国共领导人再次会晤。国民党副主席张荣恭称，郑丽文受邀规格跟2005年“连胡会”一样，合乎对等尊严。郑丽文表示，此行将以巩固两岸和平为目的，有把握北京会释出重大的善意与诚意，成果一定超乎大家期待。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260406-%E9%83%91%E4%B8%BD%E6%96%87%E5%91%A8%E4%BA%8C%E5%90%AF%E7%A8%8B%E5%87%BA%E8%AE%BF%E5%A4%A7%E9%99%86-%E9%83%91%E4%B9%A0%E4%BC%9A%E6%8D%AE%E6%8A%A5%E9%A2%84%E5%AE%9A%E5%91%A8%E4%BA%94%E7%99%BB%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775476798000.webp","sourceId":"rfi"},{"id":1775471516000,"createdDate":"2026-04-06 10:31","name":"法国国际广播电台","title":"郑习会、特习会在即 中国不寻常划设航空保留区40天受关注","content":"据《华尔街日报》报导称，中国采取了一项不寻常的举措，在未作解释的情况下划设了大片近海空域保留区，为期长达40天，并发布了类似于此前用于警告航空当局有关中国军事演习的警报，而这些演习通常不会持续超过数日。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260406-%E9%83%91%E4%B9%A0%E4%BC%9A-%E7%89%B9%E4%B9%A0%E4%BC%9A%E5%9C%A8%E5%8D%B3-%E4%B8%AD%E5%9B%BD%E4%B8%8D%E5%AF%BB%E5%B8%B8%E5%88%92%E8%AE%BE%E8%88%AA%E7%A9%BA%E4%BF%9D%E7%95%99%E5%8C%BA40%E5%A4%A9%E5%8F%97%E5%85%B3%E6%B3%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775471516000.webp","sourceId":"rfi"},{"id":1775470448000,"createdDate":"2026-04-06 10:14","name":"法国国际广播电台","title":"欧盟议员访华后 中国发布电子商务发展指导意见","content":"为协调国内发展与国际市场，中国在周一发布了电子商务发展指导意见。此前一周，一个欧洲议员代表团访问中国，讨论了相关挑战和竞争问题。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260406-%E6%AC%A7%E7%9B%9F%E8%AE%AE%E5%91%98%E8%AE%BF%E5%8D%8E%E5%90%8E-%E4%B8%AD%E5%9B%BD%E5%8F%91%E5%B8%83%E7%94%B5%E5%AD%90%E5%95%86%E5%8A%A1%E5%8F%91%E5%B1%95%E6%8C%87%E5%AF%BC%E6%84%8F%E8%A7%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775470448000.webp","sourceId":"rfi"},{"id":1775469231000,"createdDate":"2026-04-06 09:53","name":"法国国际广播电台","title":"日本首相透露正在推进与伊朗领导人会谈 日本第三艘油轮通过霍尔木兹","content":"日本首相高市早苗在日本时间4月6日午前的参议院预算委员会上表示，关于与伊朗领导人的会谈“正在进行安排”，透露围绕首脑会谈的协调工作正在推进中,而商船三井6日表示，新增一艘由其关联公司持有的液化石油气（LPG）船已通过被伊朗事实上封锁的霍尔木兹海峡，驶出波斯湾。这是第3艘商船三井相关船舶通过该海峡。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260406-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E9%80%8F%E9%9C%B2%E6%AD%A3%E5%9C%A8%E6%8E%A8%E8%BF%9B%E4%B8%8E%E4%BC%8A%E6%9C%97%E9%A2%86%E5%AF%BC%E4%BA%BA%E4%BC%9A%E8%B0%88-%E6%97%A5%E6%9C%AC%E7%AC%AC%E4%B8%89%E8%89%98%E6%B2%B9%E8%BD%AE%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775469231000.webp","sourceId":"rfi"},{"id":1775468187000,"createdDate":"2026-04-06 09:36","name":"法国国际广播电台","title":"中国将对俄公民的免签制度延长一年 中国大使：望中俄永久互免签证","content":"俄罗斯外交部向《消息报》透露，中方已通知俄方，愿意将对俄罗斯公民的免签旅行政策延长一年。在这种情况下，该政策将持续到2027年9月中旬。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260406-%E4%B8%AD%E5%9B%BD%E5%B0%86%E5%AF%B9%E4%BF%84%E5%85%AC%E6%B0%91%E7%9A%84%E5%85%8D%E7%AD%BE%E5%88%B6%E5%BA%A6%E5%BB%B6%E9%95%BF%E4%B8%80%E5%B9%B4-%E4%B8%AD%E5%9B%BD%E5%A4%A7%E4%BD%BF-%E6%9C%9B%E4%B8%AD%E4%BF%84%E6%B0%B8%E4%B9%85%E4%BA%92%E5%85%8D%E7%AD%BE%E8%AF%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775468187000.webp","sourceId":"rfi"},{"id":1775466092000,"createdDate":"2026-04-06 09:01","name":"法国国际广播电台","title":"伊朗伊斯兰革命卫队情报机构领导人、“圣城旅”840部队指挥官被击杀","content":"伊朗方面宣布，美以联军周一凌晨发动的空袭导致伊朗伊斯兰革命卫队情报机构的领导人哈德米（MajidKhademi）身亡。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260406-%E4%BC%8A%E6%9C%97%E4%BC%8A%E6%96%AF%E5%85%B0%E9%9D%A9%E5%91%BD%E5%8D%AB%E9%98%9F%E6%83%85%E6%8A%A5%E6%9C%BA%E6%9E%84%E9%A2%86%E5%AF%BC%E4%BA%BA-%E5%9C%A3%E5%9F%8E%E6%97%85-840%E9%83%A8%E9%98%9F%E6%8C%87%E6%8C%A5%E5%AE%98%E8%A2%AB%E5%87%BB%E6%9D%80","thumbnail":"","detailImage":"news/detail/rfi/2026/04/06/1775466092000.webp","sourceId":"rfi"}]