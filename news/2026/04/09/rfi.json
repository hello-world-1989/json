[{"id":1775723988000,"createdDate":"2026-04-09 08:39","name":"法国国际广播电台","title":"伊朗：所有通过霍尔木兹海峡的船只必须改走两条替代航线","content":"周四（4月9日），伊朗与美国之间停火协议进入第二天。法新社消息称，伊朗伊斯兰革命卫队海军周四宣布，所有通过霍尔木兹海峡的船只必须改走两条靠近伊朗海岸的替代航线，理由是传统的外海航道可能存在“水雷”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260409-%E4%BC%8A%E6%9C%97-%E6%89%80%E6%9C%89%E9%80%9A%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%9A%84%E8%88%B9%E5%8F%AA%E5%BF%85%E9%A1%BB%E6%94%B9%E8%B5%B0%E4%B8%A4%E6%9D%A1%E6%9B%BF%E4%BB%A3%E8%88%AA%E7%BA%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775723988000.webp","sourceId":"rfi"},{"id":1775719825000,"createdDate":"2026-04-09 07:30","name":"法国国际广播电台","title":"新加坡应对美伊战争支援措施「落地」 港府始构思 评论批又慢半拍","content":"美伊战事变数不断，至今未知何时才会真正停战，但战事影响则不断扩大，特别是国际油价，而政府的应对之策亦惹人关注。以同处亚洲的金融中心新加坡为例，其政府早于本周已迅速推出大规模纾援措施，缓解社会各界受能源成本上升的影响；反观港府，至今仍未见具体行动。评论指出，港府应对民生问题的反应不如新加坡政府及时，也缺乏居安思危的准备，令港人饱受油价高企之苦，连中产亦陷入水深火热之中。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260409-%E6%96%B0%E5%8A%A0%E5%9D%A1%E5%BA%94%E5%AF%B9%E7%BE%8E%E4%BC%8A%E6%88%98%E4%BA%89%E6%94%AF%E6%8F%B4%E6%8E%AA%E6%96%BD-%E8%90%BD%E5%9C%B0-%E6%B8%AF%E5%BA%9C%E5%A7%8B%E6%9E%84%E6%80%9D-%E8%AF%84%E8%AE%BA%E6%89%B9%E5%8F%88%E6%85%A2%E5%8D%8A%E6%8B%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775719825000.webp","sourceId":"rfi"},{"id":1775751420000,"createdDate":"2026-04-09 16:17","name":"法国国际广播电台","title":"越共总书记兼国家主席苏林下周将访问中国","content":"据法新社引述越南高官透露，“越共总书记兼国家主席苏林定于4月15日至17日访问中国”，届时他将与习近平会面。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260409-%E8%B6%8A%E5%85%B1%E6%80%BB%E4%B9%A6%E8%AE%B0%E5%85%BC%E5%9B%BD%E5%AE%B6%E4%B8%BB%E5%B8%AD%E8%8B%8F%E6%9E%97%E4%B8%8B%E5%91%A8%E5%B0%86%E8%AE%BF%E9%97%AE%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775751420000.webp","sourceId":"rfi"},{"id":1775750813000,"createdDate":"2026-04-09 16:06","name":"法国国际广播电台","title":"CAN2025:非洲足联寻求化解争端","content":"围绕2025年非洲国家杯（CAN2025）足球赛桂冠得主的争议是本台法广非洲组（RFIAfrique）近期更进的焦点话题之一。来自西非和北非的最新消息显示，中文简称非洲足联（CAF）的非洲足球联合会（Confédérationafricainedefootball）正在为此努力周旋，以期化解达喀尔（Dakar）和拉巴特（Rabat）之间的这一严重分歧。据介绍，律师出身的非洲足联（CAF）现任主席帕特里斯·莫特塞佩（PatriceMotsepe）是一名南非人。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260409-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-can-2025-%E9%9D%9E%E6%B4%B2%E8%B6%B3%E8%81%94%E5%AF%BB%E6%B1%82%E5%8C%96%E8%A7%A3%E4%BA%89%E7%AB%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775750813000.webp","sourceId":"rfi"},{"id":1775750694000,"createdDate":"2026-04-09 16:04","name":"法国国际广播电台","title":"民进党发言人：郑丽文“和平种子”被中共无预警实弹演习打脸","content":"正在中国访问的国民党主席郑丽文预计周五与中国国家主席习近平相见在北京。昨天周三，她在南京参拜了中山陵，并表示她此行播下和平的种子。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260409-%E6%B0%91%E8%BF%9B%E5%85%9A%E5%8F%91%E8%A8%80%E4%BA%BA-%E9%83%91%E4%B8%BD%E6%96%87-%E5%92%8C%E5%B9%B3%E7%A7%8D%E5%AD%90-%E8%A2%AB%E4%B8%AD%E5%85%B1%E6%97%A0%E9%A2%84%E8%AD%A6%E5%AE%9E%E5%BC%B9%E6%BC%94%E4%B9%A0%E6%89%93%E8%84%B8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775750694000.webp","sourceId":"rfi"},{"id":1775745177000,"createdDate":"2026-04-09 14:32","name":"法国国际广播电台","title":"法英要求美伊停火协议扩展至黎巴嫩","content":"以色列以4月7日美伊停火协议不涵盖黎巴嫩为由，对黎巴嫩真主党控制区展开致命轰炸，后者为支持伊朗于3月2日对以色列发动袭击。法英呼吁美伊将黎巴嫩纳入停火协议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260409-%E6%B3%95%E8%8B%B1%E8%A6%81%E6%B1%82%E7%BE%8E%E4%BC%8A%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E6%89%A9%E5%B1%95%E8%87%B3%E9%BB%8E%E5%B7%B4%E5%AB%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775745177000.webp","sourceId":"rfi"},{"id":1775745059000,"createdDate":"2026-04-09 14:30","name":"法国国际广播电台","title":"巴基斯坦推动美伊间接对话，以提升自身地缘政治地位","content":"法国极右翼政党在刚刚落下帷幕的市政选举中进一步加强了影响力，其正常化和巩固进程仍在继续；海湾冲突加剧了法国的财政压力，至2030年，法国的债务负担可能翻番；中东冲突背景下，乌克兰担忧以色列和美国对伊朗的战争正在垄断西方的注意力和资源，使其在与俄罗斯的对抗中孤立和削弱；罗马教皇利奥十四世将于周六前往摩纳哥进行为期一天的闪电式访问；这是27日出版的法国各大日报头版关注的国内和国际新闻焦点。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260409-%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E6%8E%A8%E5%8A%A8%E7%BE%8E%E4%BC%8A%E9%97%B4%E6%8E%A5%E5%AF%B9%E8%AF%9D%EF%BC%8C%E4%BB%A5%E6%8F%90%E5%8D%87%E8%87%AA%E8%BA%AB%E5%9C%B0%E7%BC%98%E6%94%BF%E6%B2%BB%E5%9C%B0%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775745059000.webp","sourceId":"rfi"},{"id":1775743888000,"createdDate":"2026-04-09 14:11","name":"法国国际广播电台","title":"中国油轮加入队列测试霍尔木兹海峡通道和伊朗停火协议（彭博）","content":"彭博社4月9日消息，两艘满载的中国油轮停泊在霍尔木兹海峡附近，它们有望成为在美伊停火协议生效仅一天后首批离开波斯湾的油轮，与此同时，船东们正在密切关注这条狭窄水道的状况。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260409-%E4%B8%AD%E5%9B%BD%E6%B2%B9%E8%BD%AE%E5%8A%A0%E5%85%A5%E9%98%9F%E5%88%97%E6%B5%8B%E8%AF%95%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%80%9A%E9%81%93%E5%92%8C%E4%BC%8A%E6%9C%97%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE-%E5%BD%AD%E5%8D%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775743888000.webp","sourceId":"rfi"},{"id":1775741609000,"createdDate":"2026-04-09 13:33","name":"法国国际广播电台","title":"一美国集团和法国基金计划投资里昂初创公司开发稀土","content":"美国稀土公司计划与法国基础建设基金共同投资卡宏寇特(Carester)开发公司，在法国波城附近建设一座稀土金属和合金工厂，应对中国在该领域的主导地位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260409-%E4%B8%80%E7%BE%8E%E5%9B%BD%E9%9B%86%E5%9B%A2%E5%92%8C%E6%B3%95%E5%9B%BD%E5%9F%BA%E9%87%91%E8%AE%A1%E5%88%92%E6%8A%95%E8%B5%84%E9%87%8C%E6%98%82%E5%88%9D%E5%88%9B%E5%85%AC%E5%8F%B8%E5%BC%80%E5%8F%91%E7%A8%80%E5%9C%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775741609000.webp","sourceId":"rfi"},{"id":1775740746000,"createdDate":"2026-04-09 13:19","name":"法国国际广播电台","title":"法国和欧盟不接受在霍尔木兹海峡征收过路费","content":"法国外交部长周四强调，在霍尔木兹海峡设立收费机制是“不可接受的”，他重申此举违反国际法。欧盟一名发言人周四表示，欧盟坚决反对在霍尔木兹海峡征收“过路费”的任何想法。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260409-%E6%B3%95%E5%9B%BD%E5%92%8C%E6%AC%A7%E7%9B%9F%E4%B8%8D%E6%8E%A5%E5%8F%97%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%BE%81%E6%94%B6%E8%BF%87%E8%B7%AF%E8%B4%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775740746000.webp","sourceId":"rfi"},{"id":1775739085000,"createdDate":"2026-04-09 12:51","name":"法国国际广播电台","title":"“同一健康峰会” 不合时宜的峰会？","content":"2026年4月5日至7日，法国政府在里昂举办了“同一健康峰会”，来自世界各地的领导人和科学家齐聚一堂，共同探讨人类、动物和环境健康之间密不可分的联系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%81%A5%E5%BA%B7%E6%97%B6%E9%97%B4/20260409-%E5%90%8C%E4%B8%80%E5%81%A5%E5%BA%B7%E5%B3%B0%E4%BC%9A-%E4%B8%8D%E5%90%88%E6%97%B6%E5%AE%9C%E7%9A%84%E5%B3%B0%E4%BC%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775739085000.webp","sourceId":"rfi"},{"id":1775738667000,"createdDate":"2026-04-09 12:44","name":"法国国际广播电台","title":"美伊停火第二天，特朗普称在“真正的协议”全面执行之前美军原地驻扎","content":"美国总统唐纳德·特朗普周三晚间表示，在“真正的协议”得到全面执行之前，美军将继续在伊朗附近驻扎。此前一天，美国与伊朗宣布达成一项为期两周的脆弱停火协议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260409-%E7%BE%8E%E4%BC%8A%E5%81%9C%E7%81%AB%E7%AC%AC%E4%BA%8C%E5%A4%A9%EF%BC%8C%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E5%9C%A8-%E7%9C%9F%E6%AD%A3%E7%9A%84%E5%8D%8F%E8%AE%AE-%E5%85%A8%E9%9D%A2%E6%89%A7%E8%A1%8C%E4%B9%8B%E5%89%8D%E7%BE%8E%E5%86%9B%E5%8E%9F%E5%9C%B0%E9%A9%BB%E6%89%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775738667000.webp","sourceId":"rfi"},{"id":1775735565000,"createdDate":"2026-04-09 11:52","name":"法国国际广播电台","title":"回声报：匈牙利，中国在欧洲的巨型实验室","content":"周四出刊的法国各大全国性报纸不约而同聚焦关注美伊停火协议。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260409-%E5%9B%9E%E5%A3%B0%E6%8A%A5-%E5%8C%88%E7%89%99%E5%88%A9%EF%BC%8C%E4%B8%AD%E5%9B%BD%E5%9C%A8%E6%AC%A7%E6%B4%B2%E7%9A%84%E5%B7%A8%E5%9E%8B%E5%AE%9E%E9%AA%8C%E5%AE%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775735565000.webp","sourceId":"rfi"},{"id":1775733294000,"createdDate":"2026-04-09 11:14","name":"法国国际广播电台","title":"美伊之间的这份停火协议究竟有多“脆弱”？","content":"周四（4月9日），美伊之间的停火协议进入第二天。这份停火协议本来是为了两国之间就长期和平展开谈判创造条件，但纵观国际媒体的新闻标题，几乎都用了“脆弱”一词来形容此次的停火协议。更有智库警告称，这项停火协议“处于崩溃边缘”，所以为什么会这么说呢？美伊之间的停火协议到底有多脆弱？今天的要闻解说将解答：为什么我们很难对这份停火协议持乐观的态度？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260409-%E7%BE%8E%E4%BC%8A%E4%B9%8B%E9%97%B4%E7%9A%84%E8%BF%99%E4%BB%BD%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E7%A9%B6%E7%AB%9F%E6%9C%89%E5%A4%9A-%E8%84%86%E5%BC%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775733294000.webp","sourceId":"rfi"},{"id":1775732785000,"createdDate":"2026-04-09 11:06","name":"法国国际广播电台","title":"俄罗斯抗议日本企业投资乌克兰制造无人机","content":"俄罗斯外交部4月8日表示，鉴于日本一家初创企业向一家开发乌克兰拦截无人机的公司出资，已召见日本驻俄大使并提出抗议。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260409-%E4%BF%84%E7%BD%97%E6%96%AF%E6%8A%97%E8%AE%AE%E6%97%A5%E6%9C%AC%E4%BC%81%E4%B8%9A%E6%8A%95%E8%B5%84%E4%B9%8C%E5%85%8B%E5%85%B0%E5%88%B6%E9%80%A0%E6%97%A0%E4%BA%BA%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775732785000.webp","sourceId":"rfi"},{"id":1775732435000,"createdDate":"2026-04-09 11:00","name":"法国国际广播电台","title":"香港「反共斗士」古思尧病逝 中港多名维权和社运人士发文悼念","content":"在1989年「六四事件」后，多次抬着自制纸棺材到中国驻港最高机构外抗议的社运人士古思尧，昨(8日)午因病离世，享年80岁。古思尧爱国反共立场鲜明，曾因参与保钓行动登上钓鱼台(日本称尖阁诸岛)而遭日本驱逐出境；亦曾多次在抗议期间焚烧中国国旗和香港区旗而被捕及判刑，是活跃于香港社运最前线丶深受港人认识的社运人士之一。他因患直肠癌病逝的消息传出后，多名香港社运人士和中国维权人士均在社交平台发文悼念。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260409-%E9%A6%99%E6%B8%AF-%E5%8F%8D%E5%85%B1%E6%96%97%E5%A3%AB-%E5%8F%A4%E6%80%9D%E5%B0%A7%E7%97%85%E9%80%9D-%E4%B8%AD%E6%B8%AF%E5%A4%9A%E5%90%8D%E7%BB%B4%E6%9D%83%E5%92%8C%E7%A4%BE%E8%BF%90%E4%BA%BA%E5%A3%AB%E5%8F%91%E6%96%87%E6%82%BC%E5%BF%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775732435000.webp","sourceId":"rfi"},{"id":1775729568000,"createdDate":"2026-04-09 10:12","name":"法国国际广播电台","title":"菲律宾在南海争议海域设立新海岸警卫队指挥中心","content":"菲律宾海岸警卫队周四（4月9号）在南海争议海域，南沙群岛启用了其首个专门指挥中心。该海域曾多次发生与中国船只的冲突。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260409-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%9C%A8%E5%8D%97%E6%B5%B7%E4%BA%89%E8%AE%AE%E6%B5%B7%E5%9F%9F%E8%AE%BE%E7%AB%8B%E6%96%B0%E6%B5%B7%E5%B2%B8%E8%AD%A6%E5%8D%AB%E9%98%9F%E6%8C%87%E6%8C%A5%E4%B8%AD%E5%BF%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775729568000.webp","sourceId":"rfi"},{"id":1775777454000,"createdDate":"2026-04-09 23:30","name":"法国国际广播电台","title":"特朗普宣告的胜利在哪里","content":"美国总统特朗普徒然地狂呼 “我们胜利了 !”事实上，美国被迫接受了单方面停火，霍尔木兹海峡至今还没有真正开放。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260409-%E7%89%B9%E6%9C%97%E6%99%AE%E5%AE%A3%E5%91%8A%E7%9A%84%E8%83%9C%E5%88%A9%E5%9C%A8%E5%93%AA%E9%87%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775777454000.webp","sourceId":"rfi"},{"id":1775777221000,"createdDate":"2026-04-09 23:27","name":"法国国际广播电台","title":"伊朗战争：中国的低调角色与模糊立场","content":"美国和伊朗即将在巴基斯坦举行谈判，中国在促成停火过程中发挥了低调却实际的作用。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260409-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89-%E4%B8%AD%E5%9B%BD%E7%9A%84%E4%BD%8E%E8%B0%83%E8%A7%92%E8%89%B2%E4%B8%8E%E6%A8%A1%E7%B3%8A%E7%AB%8B%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775777221000.webp","sourceId":"rfi"},{"id":1775777078000,"createdDate":"2026-04-09 23:24","name":"法国国际广播电台","title":"伊朗战争：目前的停火形同美国遭遇了战略溃败","content":"法国世界报周四刊发文章，分析了美国与伊朗之间的停火协议，并表示，目前的停火形同美国遭遇了战略性的溃败。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260409-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89-%E7%9B%AE%E5%89%8D%E7%9A%84%E5%81%9C%E7%81%AB%E5%BD%A2%E5%90%8C%E7%BE%8E%E5%9B%BD%E9%81%AD%E9%81%87%E4%BA%86%E6%88%98%E7%95%A5%E6%BA%83%E8%B4%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775777078000.webp","sourceId":"rfi"},{"id":1775775034000,"createdDate":"2026-04-09 22:50","name":"法国国际广播电台","title":"以色列议题在美国民主党内部为筹备中期选举的重要会议上引起激烈辩论","content":"这个星期，在11月中期选举前夕的一次重要战略会议上，美国民主党内部就亲以色列游说团体对美国政治的影响以及美国盟友以色列在中东的军事行动展开激烈辩论。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260409-%E4%BB%A5%E8%89%B2%E5%88%97%E8%AE%AE%E9%A2%98%E5%9C%A8%E7%BE%8E%E5%9B%BD%E6%B0%91%E4%B8%BB%E5%85%9A%E5%86%85%E9%83%A8%E4%B8%BA%E7%AD%B9%E5%A4%87%E4%B8%AD%E6%9C%9F%E9%80%89%E4%B8%BE%E7%9A%84%E9%87%8D%E8%A6%81%E4%BC%9A%E8%AE%AE%E4%B8%8A%E5%BC%95%E8%B5%B7%E6%BF%80%E7%83%88%E8%BE%A9%E8%AE%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775775034000.webp","sourceId":"rfi"},{"id":1775774621000,"createdDate":"2026-04-09 22:43","name":"法国国际广播电台","title":"说到真主党，穆杰塔巴·哈梅内伊：我们将整个抵抗阵线视为一个整体","content":"伊朗新任最高领袖穆杰塔巴·哈梅内伊在最新书面声明中表示，我们绝不会在任何情况下放弃我们的合法权利，我们将整个抵抗阵线视为一个整体。法新社说，穆杰塔巴·哈梅内伊显然是指以色列正在黎巴嫩与德黑兰的盟友真主党交战。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260409-%E8%AF%B4%E5%88%B0%E7%9C%9F%E4%B8%BB%E5%85%9A%EF%BC%8C%E7%A9%86%E6%9D%B0%E5%A1%94%E5%B7%B4%C2%B7%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A-%E6%88%91%E4%BB%AC%E5%B0%86%E6%95%B4%E4%B8%AA%E6%8A%B5%E6%8A%97%E9%98%B5%E7%BA%BF%E8%A7%86%E4%B8%BA%E4%B8%80%E4%B8%AA%E6%95%B4%E4%BD%93","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775774621000.webp","sourceId":"rfi"},{"id":1775774228000,"createdDate":"2026-04-09 22:37","name":"法国国际广播电台","title":"从美国和伊朗停火协议生效到星期四，只有四艘油轮和六艘散货船通过了霍尔木兹海峡","content":"伊朗和美国表示，在周三宣布为期两周的停火协议后，连接波斯湾和印度洋的霍尔木兹海峡将重新开放。可是以色列无视停火协议，对黎巴嫩发动的袭击，法新社说，加上伊朗伊斯兰革命卫队的各种声明，都给霍尔木兹海峡的开放蒙上了阴影。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260409-%E4%BB%8E%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%BC%8A%E6%9C%97%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E7%94%9F%E6%95%88%E5%88%B0%E6%98%9F%E6%9C%9F%E5%9B%9B%EF%BC%8C%E5%8F%AA%E6%9C%89%E5%9B%9B%E8%89%98%E6%B2%B9%E8%BD%AE%E5%92%8C%E5%85%AD%E8%89%98%E6%95%A3%E8%B4%A7%E8%88%B9%E9%80%9A%E8%BF%87%E4%BA%86%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/09/1775774228000.webp","sourceId":"rfi"},{"id":1775771135000,"createdDate":"2026-04-09 21:45","name":"法国国际广播电台","title":"乌克兰在对俄空战中开始占据上风","content":"乌克兰军队三月份使用新一代无人机对俄罗斯进行的空袭创下历史纪录，自从2022年2月侵乌战争爆发以来，乌克兰首次在对俄空战中占据上风。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260409-%E4%B9%8C%E5%85%8B%E5%85%B0%E5%9C%A8%E5%AF%B9%E4%BF%84%E7%A9%BA%E6%88%98%E4%B8%AD%E5%BC%80%E5%A7%8B%E5%8D%A0%E6%8D%AE%E4%B8%8A%E9%A3%8E","thu