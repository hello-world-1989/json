[{"id":1775810605000,"createdDate":"2026-04-10 08:43","name":"法国国际广播电台","title":"日本新版《外交蓝皮书》下调日中关系规格  欲推动中东局势缓和","content":"日本外相茂木敏充在10日的内阁会议上报告了2026年版《外交蓝皮书》，《外交蓝皮书》主要汇总了2025年的外交和国际形势。关于中国，其表述从2025年版中的“最重要的双边关系之一”下调为“重要的邻国”。此外，围绕伊朗局势，《外交蓝皮书》表示将继续开展一切必要的外交努力，以推动局势尽早缓和。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260410-%E6%97%A5%E6%9C%AC%E6%96%B0%E7%89%88-%E5%A4%96%E4%BA%A4%E8%93%9D%E7%9A%AE%E4%B9%A6-%E4%B8%8B%E8%B0%83%E6%97%A5%E4%B8%AD%E5%85%B3%E7%B3%BB%E8%A7%84%E6%A0%BC-%E6%AC%B2%E6%8E%A8%E5%8A%A8%E4%B8%AD%E4%B8%9C%E5%B1%80%E5%8A%BF%E7%BC%93%E5%92%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775810605000.webp","sourceId":"rfi"},{"id":1775807226000,"createdDate":"2026-04-10 07:47","name":"法国国际广播电台","title":"国民党主席郑丽文于人民大会堂会面习近平握手15秒 台湾国防部同时警示中共15架机舰扰台","content":"众所瞩目的郑习会10日登场，国民党主席郑丽文与习近平于人民大会堂东大厅会面，双方都再次强调坚持九二共识与反对台独的政治立场。民进党秘书长表示，请郑丽文告诉习近平，台湾是一个独立的国家，台湾跟中国互不隶属。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260410-%E5%9B%BD%E6%B0%91%E5%85%9A%E4%B8%BB%E5%B8%AD%E9%83%91%E4%B8%BD%E6%96%87%E4%BA%8E%E4%BA%BA%E6%B0%91%E5%A4%A7%E4%BC%9A%E5%A0%82%E4%BC%9A%E9%9D%A2%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%8F%A1%E6%89%8B15%E7%A7%92-%E5%8F%B0%E6%B9%BE%E5%9B%BD%E9%98%B2%E9%83%A8%E5%90%8C%E6%97%B6%E8%AD%A6%E7%A4%BA%E4%B8%AD%E5%85%B115%E6%9E%B6%E6%9C%BA%E8%88%B0%E6%89%B0%E5%8F%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775807226000.webp","sourceId":"rfi"},{"id":1775800429000,"createdDate":"2026-04-10 05:53","name":"法国国际广播电台","title":"日本天团ONE OK ROCK因「不可抗力因素」取消在港演出  四月内第三宗","content":"中日关系变得紧张已持续近半年之际，原拟下月初再度来港演出两场的日本摇滚乐队ONEOKROCK，突然宣布取消行程，原因是「艺人与主办方均无法预见且不可抗力之因素」，是该乐队继上月宣布取消上海演唱会后，再因「不可抗力因素」取消在华演唱会安排；亦是中日关系变差後，第三个日本艺人取消在港的演出活动。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260410-%E6%97%A5%E6%9C%AC%E5%A4%A9%E5%9B%A2one-ok-rock%E5%9B%A0-%E4%B8%8D%E5%8F%AF%E6%8A%97%E5%8A%9B%E5%9B%A0%E7%B4%A0-%E5%8F%96%E6%B6%88%E5%9C%A8%E6%B8%AF%E6%BC%94%E5%87%BA-%E5%9B%9B%E6%9C%88%E5%86%85%E7%AC%AC%E4%B8%89%E5%AE%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775800429000.webp","sourceId":"rfi"},{"id":1775838159000,"createdDate":"2026-04-10 16:22","name":"法国国际广播电台","title":"俄罗斯和乌克兰东正教复活节停火","content":"俄罗斯和乌克兰已就东正教复活节达成停火协议，据克里姆林宫称，此次停火将从周六下午持续至周日晚间。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E4%BF%84%E7%BD%97%E6%96%AF%E5%92%8C%E4%B9%8C%E5%85%8B%E5%85%B0%E4%B8%9C%E6%AD%A3%E6%95%99%E5%A4%8D%E6%B4%BB%E8%8A%82%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775838159000.webp","sourceId":"rfi"},{"id":1775835445000,"createdDate":"2026-04-10 15:37","name":"法国国际广播电台","title":"缅甸：敏昂莱宣誓就任总统 “军转民”继续掌控国家","content":"缅甸军政府首脑敏昂莱于周五宣誓就任总统，在发动政变将该国推入内战五年后，他以文职身份继续掌控国家。中印泰代表出席了就职典礼。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E7%BC%85%E7%94%B8-%E6%95%8F%E6%98%82%E8%8E%B1%E5%AE%A3%E8%AA%93%E5%B0%B1%E4%BB%BB%E6%80%BB%E7%BB%9F-%E5%86%9B%E8%BD%AC%E6%B0%91-%E7%BB%A7%E7%BB%AD%E6%8E%8C%E6%8E%A7%E5%9B%BD%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775835445000.webp","sourceId":"rfi"},{"id":1775833453000,"createdDate":"2026-04-10 15:04","name":"法国国际广播电台","title":"中国外长王毅访朝呼吁就国际问题加强协调 赞平壤在美国遏制下取得“成就”","content":"正在朝鲜访问的中国外长王毅周五与金正恩会面，呼吁两国在国际问题上加强协调，并赞扬平壤在美国和西方大国遏制下取得的“成就”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E4%B8%AD%E5%9B%BD%E5%A4%96%E9%95%BF%E7%8E%8B%E6%AF%85%E8%AE%BF%E6%9C%9D%E5%91%BC%E5%90%81%E5%B0%B1%E5%9B%BD%E9%99%85%E9%97%AE%E9%A2%98%E5%8A%A0%E5%BC%BA%E5%8D%8F%E8%B0%83-%E8%B5%9E%E5%B9%B3%E5%A3%A4%E5%9C%A8%E7%BE%8E%E5%9B%BD%E9%81%8F%E5%88%B6%E4%B8%8B%E5%8F%96%E5%BE%97-%E6%88%90%E5%B0%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775833453000.webp","sourceId":"rfi"},{"id":1775833235000,"createdDate":"2026-04-10 15:00","name":"法国国际广播电台","title":"法新：习近平告诉台湾反对派领导人他坚信中国和台湾终会统一","content":"法新社4月10日北京消息，中国国家主席习近平周五在北京对台湾主要在野党党魁郑丽文表示，尽管两岸关系紧张，但他完全相信未来中国与台湾终将实现统一。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260410-%E6%B3%95%E6%96%B0-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%91%8A%E8%AF%89%E5%8F%B0%E6%B9%BE%E5%8F%8D%E5%AF%B9%E6%B4%BE%E9%A2%86%E5%AF%BC%E4%BA%BA%E4%BB%96%E5%9D%9A%E4%BF%A1%E4%B8%AD%E5%9B%BD%E5%92%8C%E5%8F%B0%E6%B9%BE%E7%BB%88%E4%BC%9A%E7%BB%9F%E4%B8%80","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775833235000.webp","sourceId":"rfi"},{"id":1775833012000,"createdDate":"2026-04-10 14:56","name":"法国国际广播电台","title":"太空，中美的下一个“战场”?","content":"过去50年，美国几乎一直主导全球太空体系。但如今，这一格局正面临挑战。多份美国政府、军方和智库的报告显示，中国正在以前所未有的速度扩展太空能力，中美太空竞争已经成型。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E5%A4%AA%E7%A9%BA%EF%BC%8C%E4%B8%AD%E7%BE%8E%E7%9A%84%E4%B8%8B%E4%B8%80%E4%B8%AA-%E6%88%98%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775833012000.webp","sourceId":"rfi"},{"id":1775831017000,"createdDate":"2026-04-10 14:23","name":"法国国际广播电台","title":"台湾总统赖清德：不允许外来力量改变台海现状","content":"台湾总统赖清德4月10日表示，面对中国威胁，台湾要强化自己，不允许外来力量改变台海现状。他此番讲话之际，国民党主席郑丽文与中共总书记习近平正在北京会面。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260410-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E8%B5%96%E6%B8%85%E5%BE%B7-%E4%B8%8D%E5%85%81%E8%AE%B8%E5%A4%96%E6%9D%A5%E5%8A%9B%E9%87%8F%E6%94%B9%E5%8F%98%E5%8F%B0%E6%B5%B7%E7%8E%B0%E7%8A%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775831017000.webp","sourceId":"rfi"},{"id":1775828825000,"createdDate":"2026-04-10 13:47","name":"法国国际广播电台","title":"美伊巴基斯坦谈判存变数 因黎巴嫩遭空袭伊朗代表是否出席未定","content":"今天周五，美伊临时停火协议进入第三天。据法新社周五伊斯兰堡消息，巴基斯坦准备于周五接待伊朗和美国代表团进行会谈，尽管伊朗代表团能否出席仍不确定。原因是周三以色列空袭黎巴嫩袭造成300多人死亡，使美伊停火协议岌岌可危。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E7%BE%8E%E4%BC%8A%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E8%B0%88%E5%88%A4%E5%AD%98%E5%8F%98%E6%95%B0-%E5%9B%A0%E9%BB%8E%E5%B7%B4%E5%AB%A9%E9%81%AD%E7%A9%BA%E8%A2%AD%E4%BC%8A%E6%9C%97%E4%BB%A3%E8%A1%A8%E6%98%AF%E5%90%A6%E5%87%BA%E5%B8%AD%E6%9C%AA%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775828825000.webp","sourceId":"rfi"},{"id":1775820419000,"createdDate":"2026-04-10 11:26","name":"法国国际广播电台","title":"中国汽车制造商比亚迪在欧洲推出全新高端品牌","content":"法国全国性大报周五仍主要聚焦中东战事。面对黎巴嫩遭受的猛烈轰炸，法共“人道报”称《所有的人都看到了，竟无人采取措施》，报道了以色列军方不停地轰炸贝鲁特和黎巴嫩南部地区。在美伊展开谈判之际，将这一停火协议扩大是刻不容缓的事项。右派费加罗报也报道了《弹火下的黎巴嫩期待停火》，指出重启针对黎巴嫩真主党的战斗后，以色列实施最致命的、将该国化为灰烬的打击，以至于会影响到美伊的停火协议。周四，以色列宣布想和贝鲁特谈判。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260410-%E4%B8%AD%E5%9B%BD%E6%B1%BD%E8%BD%A6%E5%88%B6%E9%80%A0%E5%95%86%E6%AF%94%E4%BA%9A%E8%BF%AA%E5%9C%A8%E6%AC%A7%E6%B4%B2%E6%8E%A8%E5%87%BA%E5%85%A8%E6%96%B0%E9%AB%98%E7%AB%AF%E5%93%81%E7%89%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775820419000.webp","sourceId":"rfi"},{"id":1775817446000,"createdDate":"2026-04-10 10:37","name":"法国国际广播电台","title":"泽连斯基称乌部队在“多国”击落伊朗无人机   法新社： 中东战争为基辅在海湾带来外交优势","content":"乌克兰总统泽连斯基告诉记者，今年3月部署到中东的乌克兰部队已证明其作战效能，并在该地区“多个”国家击落了伊朗无人机。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E7%A7%B0%E4%B9%8C%E9%83%A8%E9%98%9F%E5%9C%A8-%E5%A4%9A%E5%9B%BD-%E5%87%BB%E8%90%BD%E4%BC%8A%E6%9C%97%E6%97%A0%E4%BA%BA%E6%9C%BA-%E6%B3%95%E6%96%B0%E7%A4%BE-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E4%B8%BA%E5%9F%BA%E8%BE%85%E5%9C%A8%E6%B5%B7%E6%B9%BE%E5%B8%A6%E6%9D%A5%E5%A4%96%E4%BA%A4%E4%BC%98%E5%8A%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775817446000.webp","sourceId":"rfi"},{"id":1775865135000,"createdDate":"2026-04-10 23:52","name":"法国国际广播电台","title":"短短数日，美国副总统万斯成了当前局势中的关键人物","content":"美国副总统万斯原本反对对伊朗开战，如今却被赋予重任，受总统特朗普的指派，前往巴基斯坦领导谈判，要将一项极为脆弱的两周停火转化为更长期的和平协议，要结束一场他自己并不支持的战争。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E7%9F%AD%E7%9F%AD%E6%95%B0%E6%97%A5%EF%BC%8C%E7%BE%8E%E5%9B%BD%E5%89%AF%E6%80%BB%E7%BB%9F%E4%B8%87%E6%96%AF%E6%88%90%E4%BA%86%E5%BD%93%E5%89%8D%E5%B1%80%E5%8A%BF%E4%B8%AD%E7%9A%84%E5%85%B3%E9%94%AE%E4%BA%BA%E7%89%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775865135000.webp","sourceId":"rfi"},{"id":1775864890000,"createdDate":"2026-04-10 23:48","name":"法国国际广播电台","title":"中国：卡车司机担忧石油危机将让他们不得不“停工”","content":"法国世界报刊发文章，报道了伊朗战争以及霍尔木兹海峡受阻所引发的石油危机对中国公路运输业的冲击。该报指出，在中国，公路运输业的竞争非常激烈，运输企业担心竞争力下降，所以，就是否将燃料成本的上涨转嫁给客户，它们非常谨慎。中国的卡车司机则担忧石油危机将让他们不得不“停工”。他们甚至说，“在这种情况下，还不如让卡车停在车库里”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260410-%E4%B8%AD%E5%9B%BD-%E5%8D%A1%E8%BD%A6%E5%8F%B8%E6%9C%BA%E6%8B%85%E5%BF%A7%E7%9F%B3%E6%B2%B9%E5%8D%B1%E6%9C%BA%E5%B0%86%E8%AE%A9%E4%BB%96%E4%BB%AC%E4%B8%8D%E5%BE%97%E4%B8%8D-%E5%81%9C%E5%B7%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775864890000.webp","sourceId":"rfi"},{"id":1775861844000,"createdDate":"2026-04-10 22:57","name":"法国国际广播电台","title":"台湾当局为何担心两岸问题“内政化”","content":"台湾最大反对党中国国民党主席郑丽文周五在北京与中共总书记习近平举行会谈，双方高谈“九二共识”、“两岸和平”以及“中华民族伟大复兴”，然而台湾主政的民进党政府对这些说辞保持着高度警惕。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260410-%E5%8F%B0%E6%B9%BE%E5%BD%93%E5%B1%80%E4%B8%BA%E4%BD%95%E6%8B%85%E5%BF%83%E4%B8%A4%E5%B2%B8%E9%97%AE%E9%A2%98-%E5%86%85%E6%94%BF%E5%8C%96","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775861844000.webp","sourceId":"rfi"},{"id":1775860720000,"createdDate":"2026-04-10 22:38","name":"法国国际广播电台","title":"特朗普：伊朗在即将与美国举行的会谈中“没有任何筹码”","content":"美国总统特朗普周五表示，伊朗在即将与美国举行的会谈中“没有任何筹码”。特朗普在其“真相社交网络”（TruthSocial）上写道：“伊朗人似乎没有意识到，除了利用国际水道对世界进行短期勒索之外，他们没有任何筹码。”","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260410-%E7%89%B9%E6%9C%97%E6%99%AE-%E4%BC%8A%E6%9C%97%E5%9C%A8%E5%8D%B3%E5%B0%86%E4%B8%8E%E7%BE%8E%E5%9B%BD%E4%B8%BE%E8%A1%8C%E7%9A%84%E4%BC%9A%E8%B0%88%E4%B8%AD-%E6%B2%A1%E6%9C%89%E4%BB%BB%E4%BD%95%E7%AD%B9%E7%A0%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775860720000.webp","sourceId":"rfi"},{"id":1775860310000,"createdDate":"2026-04-10 22:31","name":"法国国际广播电台","title":"良十四世和马克龙周五会晤后强调缓和中东局势及将黎巴嫩纳入停火协议的必要性","content":"天主教教宗良十四世和法国总统马克龙周五在梵蒂冈举行了首次会晤，双方强调了中东对话的必要性。一位法国总统府消息人士称，美以对伊朗的战争及其对更广泛地区的影响是马克龙与教宗良十四世会谈的主要议题，双方都强调了缓和局势以及将黎巴嫩纳入停火协议的必要性。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260410-%E8%89%AF%E5%8D%81%E5%9B%9B%E4%B8%96%E5%92%8C%E9%A9%AC%E5%85%8B%E9%BE%99%E5%91%A8%E4%BA%94%E4%BC%9A%E6%99%A4%E5%90%8E%E5%BC%BA%E8%B0%83%E7%BC%93%E5%92%8C%E5%B1%80%E5%8A%BF%E5%8F%8A%E5%B0%86%E9%BB%8E%E5%B7%B4%E5%AB%A9%E7%BA%B3%E5%85%A5%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E7%9A%84%E5%BF%85%E8%A6%81%E6%80%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775860310000.webp","sourceId":"rfi"},{"id":1775860283000,"createdDate":"2026-04-10 22:31","name":"法国国际广播电台","title":"美伊停火背后的中国角色 华盛顿关注战略意图与经济动机","content":"在美国与伊朗冲突暂时停火之际，华盛顿正密切关注中国在中东局势中的角色转变。多方观察认为，北京虽试图借机展现调停能力，但其核心动机仍以自身经济利益与对美战略布局为主，这也使美中关系在合作与竞争之间呈现更加复杂的态势。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260410-%E7%BE%8E%E4%BC%8A%E5%81%9C%E7%81%AB%E8%83%8C%E5%90%8E%E7%9A%84%E4%B8%AD%E5%9B%BD%E8%A7%92%E8%89%B2-%E5%8D%8E%E7%9B%9B%E9%A1%BF%E5%85%B3%E6%B3%A8%E6%88%98%E7%95%A5%E6%84%8F%E5%9B%BE%E4%B8%8E%E7%BB%8F%E6%B5%8E%E5%8A%A8%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775860283000.webp","sourceId":"rfi"},{"id":1775859596000,"createdDate":"2026-04-10 22:19","name":"法国国际广播电台","title":"伊朗开出先决条件为美伊谈判蒙上阴影","content":"巴基斯坦即将举行美伊和平谈判，不过，伊朗代表团虽已抵达伊斯兰堡，但是否出席仍不确定，因为德黑兰方面把以色列必须停止对黎巴嫩的空袭作为先决条件。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260410-%E4%BC%8A%E6%9C%97%E5%BC%80%E5%87%BA%E5%85%88%E5%86%B3%E6%9D%A1%E4%BB%B6%E4%B8%BA%E7%BE%8E%E4%BC%8A%E8%B0%88%E5%88%A4%E8%92%99%E4%B8%8A%E9%98%B4%E5%BD%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775859596000.webp","sourceId":"rfi"},{"id":1775859003000,"createdDate":"2026-04-10 22:10","name":"法国国际广播电台","title":"[法语世界]第151集：非洲国家尼日利亚有座[法国城]","content":"法国国际广播电台(RadioFranceInternationale)中文[法语世界](Chroniquefrancophonie)专栏2026年04月10日星期五第151集介绍在以英语为官方语言的西非大国尼日利亚（leNigéria）内陆，远离边境线的奥孙州（EtatOSUN）有一座普遍使用法语的城镇，中文名为埃吉博，也有译作埃吉格博（Ejigbo）。尼日利亚知名学者和社会语言学家、法语教授阿坎比·穆达西鲁·伊卢佩朱(Pr.AkanbiMudasiruIlupeju)就此接受了本台法广非洲组(RFIAfrique)法语记者采访。他也是拉各斯大学艺术学院院长。这集节目由尼古拉编译和播报，感谢收听。Ejigbo,villefrancophoneàl'intérieurduNigeria.Pr.AkanbiMudasiruIlupeju,notreinvitéRFIAfrique，estledoyendelafacultédesarts  del'UniversitédeLagos.","newsLink":"https://www.rfi.fr/cn/%E8%A7%86%E9%A2%91/20260410-%E6%B3%95%E5%B9%BFrfi-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E8%A7%86%E9%A2%91-%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C-%E7%AC%AC151%E9%9B%86-%E9%9D%9E%E6%B4%B2-%E5%B0%BC%E6%97%A5%E5%88%A9%E4%BA%9A%E5%86%85%E5%9C%B0%E6%9C%89%E5%BA%A7-%E6%B3%95%E5%9B%BD%E5%9F%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775859003000.webp","sourceId":"rfi"},{"id":1775857955000,"createdDate":"2026-04-10 21:52","name":"法国国际广播电台","title":"特朗普称赞中国促使伊朗接受了为期两周的停火协议， 中国出奇低调","content":"美国总统特朗普星期五在接受法新社采访时，称赞中国促使伊朗接受了为期两个星期的停火协议。就在他威胁要摧毁伊朗文明的最后期限即将到期前不到一个小时，伊朗同意停火。一位巴基斯坦高级官员说，中国在各方希望几乎破灭之际“介入并说服了伊朗”。但中国自身的表态一直较为谨慎，仅表示支持停火，并未大肆宣扬自身的外交努力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260410-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E8%B5%9E%E4%B8%AD%E5%9B%BD%E4%BF%83%E4%BD%BF%E4%BC%8A%E6%9C%97%E6%8E%A5%E5%8F%97%E4%BA%86%E4%B8%BA%E6%9C%9F%E4%B8%A4%E5%91%A8%E7%9A%84%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%EF%BC%8C-%E4%B8%AD%E5%9B%BD%E5%87%BA%E5%A5%87%E4%BD%8E%E8%B0%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775857955000.webp","sourceId":"rfi"},{"id":1775857244000,"createdDate":"2026-04-10 21:40","name":"法国国际广播电台","title":"当一经济体的精英认为他们不再需用人类时，这体系将变成啥样？","content":"硅谷巨头们通过大量投资人工智能工具，最终削弱了人类本身所能提出的贡献。作家弗朗索瓦-雷吉斯·德·盖尼沃认为，这场技术变革类似于人类学意义上的逆转，最终可能会对资本主义产生反作用。而当一个经济体的精英认为他们不再需要人类时，这个经济体将会变成什么样呢？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E7%BB%8F%E6%B5%8E/20260410-%E5%BD%93%E4%B8%80%E7%BB%8F%E6%B5%8E%E4%BD%93%E7%9A%84%E7%B2%BE%E8%8B%B1%E8%AE%A4%E4%B8%BA%E4%BB%96%E4%BB%AC%E4%B8%8D%E5%86%8D%E9%9C%80%E7%94%A8%E4%BA%BA%E7%B1%BB%E6%97%B6%EF%BC%8C%E8%BF%99%E4%BD%93%E7%B3%BB%E5%B0%86%E5%8F%98%E6%88%90%E5%95%A5%E6%A0%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775857244000.webp","sourceId":"rfi"},{"id":1775846721000,"createdDate":"2026-04-10 18:45","name":"法国国际广播电台","title":"天然气经管人认为 尽快开始向欧洲的储气库注气“至关重要”","content":"欧洲储存和储仓协会(ENTSOG)总干事皮奥特·库斯呼吁其25个欧盟成员国“最早从4月开始填充天然气、装满储仓，并持续填充至11月，以确保即将到来的冬季有足够的储罐容量”。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260410-%E5%A4%A9%E7%84%B6%E6%B0%94%E7%BB%8F%E7%AE%A1%E4%BA%BA%E8%AE%A4%E4%B8%BA-%E5%B0%BD%E5%BF%AB%E5%BC%80%E5%A7%8B%E5%90%91%E6%AC%A7%E6%B4%B2%E7%9A%84%E5%82%A8%E6%B0%94%E5%BA%93%E6%B3%A8%E6%B0%94-%E8%87%B3%E5%85%B3%E9%87%8D%E8%A6%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775846721000.webp","sourceId":"rfi"},{"id":1775844105000,"createdDate":"2026-04-10 18:01","name":"法国国际广播电台","title":"特朗普称伊朗在允许石油过霍尔木兹海峡方面做得“非常糟糕”警告伊朗不得收过路费","content":"周四晚，美国总统唐纳德·特朗普抨击伊朗在允许石油通过波斯湾霍尔木兹海峡方面做得“非常糟糕”.","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E4%BC%8A%E6%9C%97%E5%9C%A8%E5%85%81%E8%AE%B8%E7%9F%B3%E6%B2%B9%E8%BF%87%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%96%B9%E9%9D%A2%E5%81%9A%E5%BE%97-%E9%9D%9E%E5%B8%B8%E7%B3%9F%E7%B3%95-%E8%AD%A6%E5%91%8A%E4%BC%8A%E6%9C%97%E4%B8%8D%E5%BE%97%E6%94%B6%E8%BF%87%E8%B7%AF%E8%B4%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775844105000.webp","sourceId":"rfi"},{"id":1775843633000,"createdDate":"2026-04-10 17:53","name":"法国国际广播电台","title":"非洲:尼日利亚内地有座[法国城]","content":"法国国际广播电台（RadioFranceInternationale）中文节目[法语世界]（Chroniquefrancophonie）专栏2026年04月10日星期五第151集介绍在以英语为官方语言的西非次区大国尼日利亚（leNigéria）内陆，远离边境线的奥孙州（EtatOSUN）有一座普遍使用法语的城镇，中文名为埃吉博，也有译作埃吉格博（Ejigbo）。在三周前的2026年03月20日法语国家的[法语圈国际日]（laJournéeInternationaledelafrancophonie）当天，本台法广非洲组（RFIAfrique）播出了对尼日利亚法语教授阿坎比·穆达西鲁·伊卢佩朱（Pr.AkanbiMudasiruIlupeju）的一段专访。作为尼日利亚的知名学者和社会语言学家（sociolinguiste），这位原籍埃吉博（Ejigbo）的法语教授也是拉各斯大学(l'UniversitédeLagos)艺术学院(lafacultédesarts)院长，这集节目由尼古拉编译和播报，感谢收听。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C/20260410-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E6%B3%95%E8%AF%AD%E4%B8%96%E7%95%8C-%E7%AC%AC151%E9%9B%86-%E9%9D%9E%E6%B4%B2-%E5%B0%BC%E6%97%A5%E5%88%A9%E4%BA%9A%E5%86%85%E5%9C%B0%E6%9C%89%E5%BA%A7-%E6%B3%95%E5%9B%BD%E5%9F%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775843633000.webp","sourceId":"rfi"}]