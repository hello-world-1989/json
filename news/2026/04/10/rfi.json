[{"id":1775810605000,"createdDate":"2026-04-10 08:43","name":"法国国际广播电台","title":"日本新版《外交蓝皮书》下调日中关系规格  欲推动中东局势缓和","content":"日本外相茂木敏充在10日的内阁会议上报告了2026年版《外交蓝皮书》，《外交蓝皮书》主要汇总了2025年的外交和国际形势。关于中国，其表述从2025年版中的“最重要的双边关系之一”下调为“重要的邻国”。此外，围绕伊朗局势，《外交蓝皮书》表示将继续开展一切必要的外交努力，以推动局势尽早缓和。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260410-%E6%97%A5%E6%9C%AC%E6%96%B0%E7%89%88-%E5%A4%96%E4%BA%A4%E8%93%9D%E7%9A%AE%E4%B9%A6-%E4%B8%8B%E8%B0%83%E6%97%A5%E4%B8%AD%E5%85%B3%E7%B3%BB%E8%A7%84%E6%A0%BC-%E6%AC%B2%E6%8E%A8%E5%8A%A8%E4%B8%AD%E4%B8%9C%E5%B1%80%E5%8A%BF%E7%BC%93%E5%92%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775810605000.webp","sourceId":"rfi"},{"id":1775807226000,"createdDate":"2026-04-10 07:47","name":"法国国际广播电台","title":"国民党主席郑丽文于人民大会堂会面习近平握手15秒 台湾国防部同时警示中共15架机舰扰台","content":"众所瞩目的郑习会10日登场，国民党主席郑丽文与习近平于人民大会堂东大厅会面，双方都再次强调坚持九二共识与反对台独的政治立场。民进党秘书长表示，请郑丽文告诉习近平，台湾是一个独立的国家，台湾跟中国互不隶属。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260410-%E5%9B%BD%E6%B0%91%E5%85%9A%E4%B8%BB%E5%B8%AD%E9%83%91%E4%B8%BD%E6%96%87%E4%BA%8E%E4%BA%BA%E6%B0%91%E5%A4%A7%E4%BC%9A%E5%A0%82%E4%BC%9A%E9%9D%A2%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%8F%A1%E6%89%8B15%E7%A7%92-%E5%8F%B0%E6%B9%BE%E5%9B%BD%E9%98%B2%E9%83%A8%E5%90%8C%E6%97%B6%E8%AD%A6%E7%A4%BA%E4%B8%AD%E5%85%B115%E6%9E%B6%E6%9C%BA%E8%88%B0%E6%89%B0%E5%8F%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775807226000.webp","sourceId":"rfi"},{"id":1775800429000,"createdDate":"2026-04-10 05:53","name":"法国国际广播电台","title":"日本天团ONE OK ROCK因「不可抗力因素」取消在港演出  四月内第三宗","content":"中日关系变得紧张已持续近半年之际，原拟下月初再度来港演出两场的日本摇滚乐队ONEOKROCK，突然宣布取消行程，原因是「艺人与主办方均无法预见且不可抗力之因素」，是该乐队继上月宣布取消上海演唱会后，再因「不可抗力因素」取消在华演唱会安排；亦是中日关系变差後，第三个日本艺人取消在港的演出活动。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260410-%E6%97%A5%E6%9C%AC%E5%A4%A9%E5%9B%A2one-ok-rock%E5%9B%A0-%E4%B8%8D%E5%8F%AF%E6%8A%97%E5%8A%9B%E5%9B%A0%E7%B4%A0-%E5%8F%96%E6%B6%88%E5%9C%A8%E6%B8%AF%E6%BC%94%E5%87%BA-%E5%9B%9B%E6%9C%88%E5%86%85%E7%AC%AC%E4%B8%89%E5%AE%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775800429000.webp","sourceId":"rfi"},{"id":1775838159000,"createdDate":"2026-04-10 16:22","name":"法国国际广播电台","title":"俄罗斯和乌克兰东正教复活节停火","content":"俄罗斯和乌克兰已就东正教复活节达成停火协议，据克里姆林宫称，此次停火将从周六下午持续至周日晚间。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E4%BF%84%E7%BD%97%E6%96%AF%E5%92%8C%E4%B9%8C%E5%85%8B%E5%85%B0%E4%B8%9C%E6%AD%A3%E6%95%99%E5%A4%8D%E6%B4%BB%E8%8A%82%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775838159000.webp","sourceId":"rfi"},{"id":1775835445000,"createdDate":"2026-04-10 15:37","name":"法国国际广播电台","title":"缅甸：敏昂莱宣誓就任总统 “军转民”继续掌控国家","content":"缅甸军政府首脑敏昂莱于周五宣誓就任总统，在发动政变将该国推入内战五年后，他以文职身份继续掌控国家。中印泰代表出席了就职典礼。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E7%BC%85%E7%94%B8-%E6%95%8F%E6%98%82%E8%8E%B1%E5%AE%A3%E8%AA%93%E5%B0%B1%E4%BB%BB%E6%80%BB%E7%BB%9F-%E5%86%9B%E8%BD%AC%E6%B0%91-%E7%BB%A7%E7%BB%AD%E6%8E%8C%E6%8E%A7%E5%9B%BD%E5%AE%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775835445000.webp","sourceId":"rfi"},{"id":1775833453000,"createdDate":"2026-04-10 15:04","name":"法国国际广播电台","title":"中国外长王毅访朝呼吁就国际问题加强协调 赞平壤在美国遏制下取得“成就”","content":"正在朝鲜访问的中国外长王毅周五与金正恩会面，呼吁两国在国际问题上加强协调，并赞扬平壤在美国和西方大国遏制下取得的“成就”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E4%B8%AD%E5%9B%BD%E5%A4%96%E9%95%BF%E7%8E%8B%E6%AF%85%E8%AE%BF%E6%9C%9D%E5%91%BC%E5%90%81%E5%B0%B1%E5%9B%BD%E9%99%85%E9%97%AE%E9%A2%98%E5%8A%A0%E5%BC%BA%E5%8D%8F%E8%B0%83-%E8%B5%9E%E5%B9%B3%E5%A3%A4%E5%9C%A8%E7%BE%8E%E5%9B%BD%E9%81%8F%E5%88%B6%E4%B8%8B%E5%8F%96%E5%BE%97-%E6%88%90%E5%B0%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775833453000.webp","sourceId":"rfi"},{"id":1775833235000,"createdDate":"2026-04-10 15:00","name":"法国国际广播电台","title":"法新：习近平告诉台湾反对派领导人他坚信中国和台湾终会统一","content":"法新社4月10日北京消息，中国国家主席习近平周五在北京对台湾主要在野党党魁郑丽文表示，尽管两岸关系紧张，但他完全相信未来中国与台湾终将实现统一。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260410-%E6%B3%95%E6%96%B0-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%91%8A%E8%AF%89%E5%8F%B0%E6%B9%BE%E5%8F%8D%E5%AF%B9%E6%B4%BE%E9%A2%86%E5%AF%BC%E4%BA%BA%E4%BB%96%E5%9D%9A%E4%BF%A1%E4%B8%AD%E5%9B%BD%E5%92%8C%E5%8F%B0%E6%B9%BE%E7%BB%88%E4%BC%9A%E7%BB%9F%E4%B8%80","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775833235000.webp","sourceId":"rfi"},{"id":1775833012000,"createdDate":"2026-04-10 14:56","name":"法国国际广播电台","title":"太空，中美的下一个“战场”?","content":"过去50年，美国几乎一直主导全球太空体系。但如今，这一格局正面临挑战。多份美国政府、军方和智库的报告显示，中国正在以前所未有的速度扩展太空能力，中美太空竞争已经成型。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E5%A4%AA%E7%A9%BA%EF%BC%8C%E4%B8%AD%E7%BE%8E%E7%9A%84%E4%B8%8B%E4%B8%80%E4%B8%AA-%E6%88%98%E5%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775833012000.webp","sourceId":"rfi"},{"id":1775831017000,"createdDate":"2026-04-10 14:23","name":"法国国际广播电台","title":"台湾总统赖清德：不允许外来力量改变台海现状","content":"台湾总统赖清德4月10日表示，面对中国威胁，台湾要强化自己，不允许外来力量改变台海现状。他此番讲话之际，国民党主席郑丽文与中共总书记习近平正在北京会面。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260410-%E5%8F%B0%E6%B9%BE%E6%80%BB%E7%BB%9F%E8%B5%96%E6%B8%85%E5%BE%B7-%E4%B8%8D%E5%85%81%E8%AE%B8%E5%A4%96%E6%9D%A5%E5%8A%9B%E9%87%8F%E6%94%B9%E5%8F%98%E5%8F%B0%E6%B5%B7%E7%8E%B0%E7%8A%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775831017000.webp","sourceId":"rfi"},{"id":1775828825000,"createdDate":"2026-04-10 13:47","name":"法国国际广播电台","title":"美伊巴基斯坦谈判存变数 因黎巴嫩遭空袭伊朗代表是否出席未定","content":"今天周五，美伊临时停火协议进入第三天。据法新社周五伊斯兰堡消息，巴基斯坦准备于周五接待伊朗和美国代表团进行会谈，尽管伊朗代表团能否出席仍不确定。原因是周三以色列空袭黎巴嫩袭造成300多人死亡，使美伊停火协议岌岌可危。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E7%BE%8E%E4%BC%8A%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E8%B0%88%E5%88%A4%E5%AD%98%E5%8F%98%E6%95%B0-%E5%9B%A0%E9%BB%8E%E5%B7%B4%E5%AB%A9%E9%81%AD%E7%A9%BA%E8%A2%AD%E4%BC%8A%E6%9C%97%E4%BB%A3%E8%A1%A8%E6%98%AF%E5%90%A6%E5%87%BA%E5%B8%AD%E6%9C%AA%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775828825000.webp","sourceId":"rfi"},{"id":1775820419000,"createdDate":"2026-04-10 11:26","name":"法国国际广播电台","title":"中国汽车制造商比亚迪在欧洲推出全新高端品牌","content":"法国全国性大报周五仍主要聚焦中东战事。面对黎巴嫩遭受的猛烈轰炸，法共“人道报”称《所有的人都看到了，竟无人采取措施》，报道了以色列军方不停地轰炸贝鲁特和黎巴嫩南部地区。在美伊展开谈判之际，将这一停火协议扩大是刻不容缓的事项。右派费加罗报也报道了《弹火下的黎巴嫩期待停火》，指出重启针对黎巴嫩真主党的战斗后，以色列实施最致命的、将该国化为灰烬的打击，以至于会影响到美伊的停火协议。周四，以色列宣布想和贝鲁特谈判。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260410-%E4%B8%AD%E5%9B%BD%E6%B1%BD%E8%BD%A6%E5%88%B6%E9%80%A0%E5%95%86%E6%AF%94%E4%BA%9A%E8%BF%AA%E5%9C%A8%E6%AC%A7%E6%B4%B2%E6%8E%A8%E5%87%BA%E5%85%A8%E6%96%B0%E9%AB%98%E7%AB%AF%E5%93%81%E7%89%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775820419000.webp","sourceId":"rfi"},{"id":1775817446000,"createdDate":"2026-04-10 10:37","name":"法国国际广播电台","title":"泽连斯基称乌部队在“多国”击落伊朗无人机   法新社： 中东战争为基辅在海湾带来外交优势","content":"乌克兰总统泽连斯基告诉记者，今年3月部署到中东的乌克兰部队已证明其作战效能，并在该地区“多个”国家击落了伊朗无人机。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260410-%E6%B3%BD%E8%BF%9E%E6%96%AF%E5%9F%BA%E7%A7%B0%E4%B9%8C%E9%83%A8%E9%98%9F%E5%9C%A8-%E5%A4%9A%E5%9B%BD-%E5%87%BB%E8%90%BD%E4%BC%8A%E6%9C%97%E6%97%A0%E4%BA%BA%E6%9C%BA-%E6%B3%95%E6%96%B0%E7%A4%BE-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E4%B8%BA%E5%9F%BA%E8%BE%85%E5%9C%A8%E6%B5%B7%E6%B9%BE%E5%B8%A6%E6%9D%A5%E5%A4%96%E4%BA%A4%E4%BC%98%E5%8A%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/10/1775817446000.webp","sourceId":"rfi"}]