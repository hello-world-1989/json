[{"id":1775119705000,"createdDate":"2026-04-02 08:48","name":"法国国际广播电台","title":"特朗普再次抨击法国总统：称马克龙“被妻子欺负”， 并透露曾在霍尔木兹海峡问题上请求法国协助但未收到满意的回复","content":"美国总统特朗普在周三（2月3日）晚的一次新闻发布会上再次讽刺法国总统马克龙，并对双方之间的通话表达不满。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260402-%E7%89%B9%E6%9C%97%E6%99%AE%E5%86%8D%E6%AC%A1%E6%8A%A8%E5%87%BB%E6%B3%95%E5%9B%BD%E6%80%BB%E7%BB%9F-%E7%A7%B0-%E9%A9%AC%E5%85%8B%E9%BE%99%E8%A2%AB%E5%A6%BB%E5%AD%90%E6%AC%BA%E8%B4%9F-%EF%BC%8C-%E5%B9%B6%E9%80%8F%E9%9C%B2%E6%9B%BE%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%97%AE%E9%A2%98%E4%B8%8A%E8%AF%B7%E6%B1%82%E6%B3%95%E5%9B%BD%E5%8D%8F%E5%8A%A9%E4%BD%86%E6%9C%AA%E6%94%B6%E5%88%B0%E6%BB%A1%E6%84%8F%E7%9A%84%E5%9B%9E%E5%A4%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775119705000.webp","sourceId":"rfi"},{"id":1775113822000,"createdDate":"2026-04-02 07:10","name":"法国国际广播电台","title":"特朗普最新讲话未为伊战降温 油价转升 亚太股市普遍下跌 南韩半日最惨","content":"美国总统特朗普(DonaldTrump，又译川普)在香港时间今(2日)早发表的全国讲话，未能为结束伊朗战争订下时间表，令市场失望，以致石油价格由原先的回落转为抽高，亚太区股市亦普遍低开，至中午收市时，32个股市中，七成半指数下跌，跌幅由0.25%至4.41%不等，当中，韩国股市跌幅最大，上海B股跌幅最小。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260402-%E7%89%B9%E6%9C%97%E6%99%AE%E6%9C%80%E6%96%B0%E8%AE%B2%E8%AF%9D%E6%9C%AA%E4%B8%BA%E4%BC%8A%E6%88%98%E9%99%8D%E6%B8%A9-%E6%B2%B9%E4%BB%B7%E8%BD%AC%E5%8D%87-%E4%BA%9A%E5%A4%AA%E8%82%A1%E5%B8%82%E6%99%AE%E9%81%8D%E4%B8%8B%E8%B7%8C-%E5%8D%97%E9%9F%A9%E5%8D%8A%E6%97%A5%E6%9C%80%E6%83%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775113822000.webp","sourceId":"rfi"},{"id":1775113302000,"createdDate":"2026-04-02 07:01","name":"法国国际广播电台","title":"港2月零售飙19% 业界忧伊战碍消费 未敢抬前景预测","content":"香港零售销售额连升十个月，今年2月的零售额和销货量均大幅上升，当中，货额的临时估值达350亿港元(下同，折算约38.7亿欧元)，按年升19.3%，远优於市场预期，且是33个月以来最大升幅，主因受去年基数低及农历新年所在月份不同所影响。零售管理协会认为，香港首两个月的消费气氛确有好转，但忧虑中东局势会影响股市及消费气氛，加上港人4月会着长假期北上消费或外游，会维持上半年零售额按年不变的预测。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260402-%E6%B8%AF2%E6%9C%88%E9%9B%B6%E5%94%AE%E9%A3%9919-%E4%B8%9A%E7%95%8C%E5%BF%A7%E4%BC%8A%E6%88%98%E7%A2%8D%E6%B6%88%E8%B4%B9-%E6%9C%AA%E6%95%A2%E6%8A%AC%E5%89%8D%E6%99%AF%E9%A2%84%E6%B5%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775113302000.webp","sourceId":"rfi"}]