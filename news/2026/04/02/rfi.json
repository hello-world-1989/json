[{"id":1775119705000,"createdDate":"2026-04-02 08:48","name":"法国国际广播电台","title":"特朗普再次抨击法国总统：称马克龙“被妻子欺负”， 并透露曾在霍尔木兹海峡问题上请求法国协助但未收到满意的回复","content":"美国总统特朗普在周三（2月3日）晚的一次新闻发布会上再次讽刺法国总统马克龙，并对双方之间的通话表达不满。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260402-%E7%89%B9%E6%9C%97%E6%99%AE%E5%86%8D%E6%AC%A1%E6%8A%A8%E5%87%BB%E6%B3%95%E5%9B%BD%E6%80%BB%E7%BB%9F-%E7%A7%B0-%E9%A9%AC%E5%85%8B%E9%BE%99%E8%A2%AB%E5%A6%BB%E5%AD%90%E6%AC%BA%E8%B4%9F-%EF%BC%8C-%E5%B9%B6%E9%80%8F%E9%9C%B2%E6%9B%BE%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%97%AE%E9%A2%98%E4%B8%8A%E8%AF%B7%E6%B1%82%E6%B3%95%E5%9B%BD%E5%8D%8F%E5%8A%A9%E4%BD%86%E6%9C%AA%E6%94%B6%E5%88%B0%E6%BB%A1%E6%84%8F%E7%9A%84%E5%9B%9E%E5%A4%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775119705000.webp","sourceId":"rfi"},{"id":1775113822000,"createdDate":"2026-04-02 07:10","name":"法国国际广播电台","title":"特朗普最新讲话未为伊战降温 油价转升 亚太股市普遍下跌 南韩半日最惨","content":"美国总统特朗普(DonaldTrump，又译川普)在香港时间今(2日)早发表的全国讲话，未能为结束伊朗战争订下时间表，令市场失望，以致石油价格由原先的回落转为抽高，亚太区股市亦普遍低开，至中午收市时，32个股市中，七成半指数下跌，跌幅由0.25%至4.41%不等，当中，韩国股市跌幅最大，上海B股跌幅最小。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260402-%E7%89%B9%E6%9C%97%E6%99%AE%E6%9C%80%E6%96%B0%E8%AE%B2%E8%AF%9D%E6%9C%AA%E4%B8%BA%E4%BC%8A%E6%88%98%E9%99%8D%E6%B8%A9-%E6%B2%B9%E4%BB%B7%E8%BD%AC%E5%8D%87-%E4%BA%9A%E5%A4%AA%E8%82%A1%E5%B8%82%E6%99%AE%E9%81%8D%E4%B8%8B%E8%B7%8C-%E5%8D%97%E9%9F%A9%E5%8D%8A%E6%97%A5%E6%9C%80%E6%83%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775113822000.webp","sourceId":"rfi"},{"id":1775113302000,"createdDate":"2026-04-02 07:01","name":"法国国际广播电台","title":"港2月零售飙19% 业界忧伊战碍消费 未敢抬前景预测","content":"香港零售销售额连升十个月，今年2月的零售额和销货量均大幅上升，当中，货额的临时估值达350亿港元(下同，折算约38.7亿欧元)，按年升19.3%，远优於市场预期，且是33个月以来最大升幅，主因受去年基数低及农历新年所在月份不同所影响。零售管理协会认为，香港首两个月的消费气氛确有好转，但忧虑中东局势会影响股市及消费气氛，加上港人4月会着长假期北上消费或外游，会维持上半年零售额按年不变的预测。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260402-%E6%B8%AF2%E6%9C%88%E9%9B%B6%E5%94%AE%E9%A3%9919-%E4%B8%9A%E7%95%8C%E5%BF%A7%E4%BC%8A%E6%88%98%E7%A2%8D%E6%B6%88%E8%B4%B9-%E6%9C%AA%E6%95%A2%E6%8A%AC%E5%89%8D%E6%99%AF%E9%A2%84%E6%B5%8B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775113302000.webp","sourceId":"rfi"},{"id":1775146499000,"createdDate":"2026-04-02 16:14","name":"法国国际广播电台","title":"伊朗回应特朗普威胁 誓言发动“毁灭性”打击","content":"在美国总统周三晚发表有关伊朗战争的讲话后，伊朗发动了新一轮导弹袭击，伊朗军队作战指挥官在国家电视台发布的声明中坚称，这场战争将持续下去，直到伊朗的敌人受到“羞辱”，并威胁将发动“更加毁灭性的”行动。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260402-%E4%BC%8A%E6%9C%97%E5%9B%9E%E5%BA%94%E7%89%B9%E6%9C%97%E6%99%AE%E5%A8%81%E8%83%81-%E8%AA%93%E8%A8%80%E5%8F%91%E5%8A%A8-%E6%AF%81%E7%81%AD%E6%80%A7-%E6%89%93%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775146499000.webp","sourceId":"rfi"},{"id":1775145104000,"createdDate":"2026-04-02 15:51","name":"法国国际广播电台","title":"法国总统马克龙回应特朗普有关其婚姻等言论 “既不优雅也不属实”","content":"法国总统马克龙周四回应了特朗普对其婚姻的嘲讽言论，称其“既不优雅也不属实”，马克龙评论美国总统在中东战争和北约问题上反复无常并“到处在空谈”。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260402-%E6%B3%95%E5%9B%BD%E6%80%BB%E7%BB%9F%E9%A9%AC%E5%85%8B%E9%BE%99%E5%9B%9E%E5%BA%94%E7%89%B9%E6%9C%97%E6%99%AE%E6%9C%89%E5%85%B3%E5%85%B6%E5%A9%9A%E5%A7%BB%E7%AD%89%E8%A8%80%E8%AE%BA-%E6%97%A2%E4%B8%8D%E4%BC%98%E9%9B%85%E4%B9%9F%E4%B8%8D%E5%B1%9E%E5%AE%9E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775145104000.webp","sourceId":"rfi"},{"id":1775143511000,"createdDate":"2026-04-02 15:25","name":"法国国际广播电台","title":"中国航空公司上调燃油附加费","content":"随着中东战事推高航空煤油价格，包括中国国航在内的多家中国航空公司宣布，将从周日起上调国内航班的燃油附加费。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260402-%E4%B8%AD%E5%9B%BD%E8%88%AA%E7%A9%BA%E5%85%AC%E5%8F%B8%E4%B8%8A%E8%B0%83%E7%87%83%E6%B2%B9%E9%99%84%E5%8A%A0%E8%B4%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775143511000.webp","sourceId":"rfi"},{"id":1775141687000,"createdDate":"2026-04-02 14:54","name":"法国国际广播电台","title":"伊朗战争进退两难，特朗普如何自圆其说？","content":"美国与以色列联手对伊朗发动大规模军事行动一个多月之后，特朗普4月1日晚间首次就这场搅动全球的战争发表电视讲话。如果说特朗普在这次近20分钟的讲话中努力称赞军事行动战果的话，人们却很难判断此番讲话更是在安抚市场对战争持续的担心，还是在预告人们还有一场硬仗要打。讲话结束不到24小时，国际市场原油价格已经重新飙升，在欧洲市场上升幅已经超过7%。显然，这次电视讲话不仅没能对市场起到安抚，反而激发了新一波不安。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260402-%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E8%BF%9B%E9%80%80%E4%B8%A4%E9%9A%BE%EF%BC%8C%E7%89%B9%E6%9C%97%E6%99%AE%E5%A6%82%E4%BD%95%E8%87%AA%E5%9C%86%E5%85%B6%E8%AF%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775141687000.webp","sourceId":"rfi"},{"id":1775140185000,"createdDate":"2026-04-02 14:29","name":"法国国际广播电台","title":"【视频】专家解析：特朗普真的能让美国退出北约组织吗？","content":"美国总统唐纳德·特朗普周三（4月1日）威胁称，由于北约欧洲成员国拒绝派遣船只疏通伊朗附近的霍尔木兹海峡，他将带领美国退出北约。与此同时，特朗普加大了对该军事联盟的谴责力度。但特朗普真的会带领美国撤出已有77年历史的跨大西洋联盟吗 ?在法律层面，2023年美国国会通过的一个法案禁止任何美国总统暂停、终止、谴责或退出建立北约的条约，除非退出北约的动议得到参议院100名成员中三分之二多数的支持。专家也分析认为，如果美国退出北约，是送给中俄的一份“大礼“，但特朗普的难以预测性让这个问题的答案也难以预测.....","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20260402-%E4%B8%93%E5%AE%B6%E8%A7%A3%E8%AF%BB-%E7%89%B9%E6%9C%97%E6%99%AE%E7%9C%9F%E7%9A%84%E8%83%BD%E8%AE%A9%E7%BE%8E%E5%9B%BD%E9%80%80%E5%87%BA%E5%8C%97%E7%BA%A6%E5%90%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775140185000.webp","sourceId":"rfi"},{"id":1775137309000,"createdDate":"2026-04-02 13:41","name":"法国国际广播电台","title":"美国阿耳忒弥斯2号绕月任务成功发射","content":"美国宇航局阿耳忒弥斯2号任务的四名宇航员于周三搭乘“猎户座”太空舱成功启程，进入地球轨道，展开为期十天的绕地和绕月飞行，此次测试任务旨在为2028年重返月球表面铺平道路。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260402-%E7%BE%8E%E5%9B%BD%E9%98%BF%E8%80%B3%E5%BF%92%E5%BC%A5%E6%96%AF2%E5%8F%B7%E7%BB%95%E6%9C%88%E4%BB%BB%E5%8A%A1%E6%88%90%E5%8A%9F%E5%8F%91%E5%B0%84","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775137309000.webp","sourceId":"rfi"},{"id":1775135725000,"createdDate":"2026-04-02 13:15","name":"法国国际广播电台","title":"马克龙对韩国进行国是访问 纪念建交140周年 凭吊韩战阵亡法军士兵","content":"法国总统马克龙周四从东京飞抵首尔，对韩国展开为期两天的国是访问，期间他将与韩国总统李在明举行会晤。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260402-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%AF%B9%E9%9F%A9%E5%9B%BD%E8%BF%9B%E8%A1%8C%E5%9B%BD%E6%98%AF%E8%AE%BF%E9%97%AE-%E7%BA%AA%E5%BF%B5%E5%BB%BA%E4%BA%A4140%E5%91%A8%E5%B9%B4-%E5%87%AD%E5%90%8A%E9%9F%A9%E6%88%98%E9%98%B5%E4%BA%A1%E6%B3%95%E5%86%9B%E5%A3%AB%E5%85%B5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775135725000.webp","sourceId":"rfi"},{"id":1775134599000,"createdDate":"2026-04-02 12:56","name":"法国国际广播电台","title":"缅甸联邦议会即将选举总统，军政强人敏昂莱几乎胜券在握","content":"缅甸联邦议会4月2日举行会议，确定三名总统候选人资格，提交议会明日（4月3日）表决。三名总统候选人均为此前联邦议会的民选议员团与军人议员团于3月31日推举出的副总统。2021年2月发动军事政变上台的敏昂莱几乎笃定当选总统。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260402-%E7%BC%85%E7%94%B8%E8%81%94%E9%82%A6%E8%AE%AE%E4%BC%9A%E5%8D%B3%E5%B0%86%E9%80%89%E4%B8%BE%E6%80%BB%E7%BB%9F%EF%BC%8C%E5%86%9B%E6%94%BF%E5%BC%BA%E4%BA%BA%E6%95%8F%E6%98%82%E8%8E%B1%E5%87%A0%E4%B9%8E%E8%83%9C%E5%88%B8%E5%9C%A8%E6%8F%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775134599000.webp","sourceId":"rfi"},{"id":1775130788000,"createdDate":"2026-04-02 11:53","name":"法国国际广播电台","title":"特朗普称在伊朗“目标即将实现” 未来两三周要把伊朗打回“石器时代”","content":"美国总统特朗普周三晚间向全国发表讲话称：伊朗“不再构成真正”的威胁，美军即将实现其战略目标，并承诺，将在未来两到三周内“猛烈”打击伊朗，将其打回“石器时代”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260402-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E5%9C%A8%E4%BC%8A%E6%9C%97-%E7%9B%AE%E6%A0%87%E5%8D%B3%E5%B0%86%E5%AE%9E%E7%8E%B0-%E6%9C%AA%E6%9D%A5%E4%B8%A4%E4%B8%89%E5%91%A8%E8%A6%81%E6%8A%8A%E4%BC%8A%E6%9C%97%E6%89%93%E5%9B%9E-%E7%9F%B3%E5%99%A8%E6%97%B6%E4%BB%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775130788000.webp","sourceId":"rfi"},{"id":1775127440000,"createdDate":"2026-04-02 10:57","name":"法国国际广播电台","title":"切换夏令时到底对健康有什么影响？","content":"法国于2026年3月28日至29日夜间切换至夏令时。凌晨2点，时间变为凌晨3点，这意味着睡眠时间减少了一小时。智能手机电子设备会自动更新时间，但对人的身体而言，情况却截然不同。这一小时的时差到底会对人的健康产生什么影响呢？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%81%A5%E5%BA%B7%E6%97%B6%E9%97%B4/20260402-%E5%88%87%E6%8D%A2%E5%A4%8F%E4%BB%A4%E6%97%B6%E5%88%B0%E5%BA%95%E5%AF%B9%E5%81%A5%E5%BA%B7%E6%9C%89%E4%BB%80%E4%B9%88%E5%BD%B1%E5%93%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775127440000.webp","sourceId":"rfi"},{"id":1775126585000,"createdDate":"2026-04-02 10:43","name":"法国国际广播电台","title":"《观点》专栏：中国正蓄势取代美国的全球科研领导地位","content":"法国《观点》周刊专栏作家Jean-FrançoisBouvet日前发文表示，倘若“中央帝国”北京在军事上尚未能与美国比肩，但其科研产出却正迈向全球主导地位。自第二次世界大战结束以来，美国始终是全球研究与开发（R&D）投资的最大资助方。然而，根据加州大学圣地亚哥分校“科学与创新政策前沿”项目（FSIP）为《自然指数》所做的分析，中国有望在两到三年内取而代之，夺得这一领导地位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260402-%E8%A7%82%E7%82%B9-%E4%B8%93%E6%A0%8F-%E4%B8%AD%E5%9B%BD%E6%AD%A3%E8%93%84%E5%8A%BF%E5%8F%96%E4%BB%A3%E7%BE%8E%E5%9B%BD%EF%BC%8C%E6%8A%A2%E5%8D%A0%E5%85%A8%E7%90%83%E7%A7%91%E7%A0%94%E9%A2%86%E5%AF%BC%E5%9C%B0%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775126585000.webp","sourceId":"rfi"},{"id":1775123843000,"createdDate":"2026-04-02 09:57","name":"法国国际广播电台","title":"马克龙力主“独立者联盟” 应对特朗普的不确定性和习近平的野心","content":"法广听友大家好，就在特朗普抨击马克龙并威胁退出北约之际，4月2日出刊的法国右翼大报《费加罗报》与左翼大报《解放报》同时关注了法国总统马克龙周三访问日本期间，强调欧洲的“可预见性”，并将欧洲的“可预见性”与那些“不动声色地伤害你”的国家进行了对比，《费加罗报》就此指出，马克龙显然是在暗讽美国总统特朗普。《解放报》则侧重法国总统主张与东京建立战略轴心，以应对北京的野心和特朗普的不确定性。然而，这一主张受到了日本首相高市早苗的谨慎对待，后者正极力维护与美国元首的关系。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260402-%E9%A9%AC%E5%85%8B%E9%BE%99%E5%9C%A8%E6%97%A5%E6%9C%AC%E5%80%A1%E8%AE%AE%E4%BB%A5-%E7%8B%AC%E7%AB%8B%E8%80%85%E8%81%94%E7%9B%9F-%E4%B8%BA%E6%88%98%E7%95%A5%E6%94%AF%E7%82%B9-%E5%BA%94%E5%AF%B9%E7%BE%8E%E4%B8%AD%E4%B8%A4%E5%BC%BA%E5%AF%B9%E6%8A%97%E7%9A%84%E5%86%B2%E5%87%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775123843000.webp","sourceId":"rfi"},{"id":1775122950000,"createdDate":"2026-04-02 09:42","name":"法国国际广播电台","title":"日法首脑在联合声明中谴责以色列","content":"日本时间4月1日18时起，约2小时10分钟内，日本首相高市早苗与作为正式工作访问宾客访日的法国总统马克龙举行了日法首脑会谈。随后，双方举行了日法首脑联合声明签署仪式、联合记者会以及工作晚宴。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260402-%E6%97%A5%E6%B3%95%E9%A6%96%E8%84%91%E5%9C%A8%E8%81%94%E5%90%88%E5%A3%B0%E6%98%8E%E4%B8%AD%E8%B0%B4%E8%B4%A3%E4%BB%A5%E8%89%B2%E5%88%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/02/1775122950000.webp","sourceId":"rfi"}]