[{"id":1776240343000,"createdDate":"2026-04-15 08:05","name":"法国国际广播电台","title":"金融时报：伊朗利用中国间谍卫星监视美军基地","content":"法新社消息称，据《金融时报》周三（4月15日）报道，伊朗于2024年底秘密获得了一颗中国间谍卫星，因此自2月28日美国和以色列对伊朗发动战争以来，使得伊朗能够获取中东各地美军基地的图像。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260415-%E9%87%91%E8%9E%8D%E6%97%B6%E6%8A%A5-%E4%BC%8A%E6%9C%97%E5%88%A9%E7%94%A8%E4%B8%AD%E5%9B%BD%E9%97%B4%E8%B0%8D%E5%8D%AB%E6%98%9F%E7%9B%91%E8%A7%86%E7%BE%8E%E5%86%9B%E5%9F%BA%E5%9C%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776240343000.webp","sourceId":"rfi"},{"id":1776237559000,"createdDate":"2026-04-15 07:19","name":"法国国际广播电台","title":"日本阿曼举行首脑电话会谈 日方表示最重要的是维持美伊停火","content":"日本时间4月14日下午4时起约20分钟，日本首相高市早苗与阿曼国家元首苏丹海赛姆举行了电话会谈。鉴于中东局势紧张升级，高市首相与苏丹海赛姆通电话进行了磋商，她传达了日本的立场，即除了推动局势降温之外，尽早确保霍尔木兹海峡的自由且安全的航行是不可或缺的。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260415-%E6%97%A5%E6%9C%AC%E9%98%BF%E6%9B%BC%E4%B8%BE%E8%A1%8C%E9%A6%96%E8%84%91%E7%94%B5%E8%AF%9D%E4%BC%9A%E8%B0%88-%E6%97%A5%E6%96%B9%E8%A1%A8%E7%A4%BA%E6%9C%80%E9%87%8D%E8%A6%81%E7%9A%84%E6%98%AF%E7%BB%B4%E6%8C%81%E7%BE%8E%E4%BC%8A%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776237559000.webp","sourceId":"rfi"},{"id":1776237346000,"createdDate":"2026-04-15 07:15","name":"法国国际广播电台","title":"中国未放松香港国安 夏宝龙再促乃外力干预 又批有人借大火以灾乱港","content":"今天是「全民国家安全教育日」，中国负责港澳事务的最高级官员夏宝龙在开幕礼上致词时强调，香港发展须由「高水平安全」来护航，时常居安思危，并以去年底导致168人死亡的大埔火灾为例说明，指有人把灾情政治化，「妄图『以灾乱港』」；更须警惕外部势力插手干预的风险，在他们唱衰香港时予以回击，世界地缘冲突对香港可能造成的影响做好应对准备。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260415-%E4%B8%AD%E5%9B%BD%E6%9C%AA%E6%94%BE%E6%9D%BE%E9%A6%99%E6%B8%AF%E5%9B%BD%E5%AE%89-%E5%A4%8F%E5%AE%9D%E9%BE%99%E5%86%8D%E4%BF%83%E4%B9%83%E5%A4%96%E5%8A%9B%E5%B9%B2%E9%A2%84-%E5%8F%88%E6%89%B9%E6%9C%89%E4%BA%BA%E5%80%9F%E5%A4%A7%E7%81%AB%E4%BB%A5%E7%81%BE%E4%B9%B1%E6%B8%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776237346000.webp","sourceId":"rfi"},{"id":1776237046000,"createdDate":"2026-04-15 07:10","name":"法国国际广播电台","title":"法轮功学员发布煽动帖文判囚一年 法官指以言论自由包装政治立场属挑战政权","content":"在国际特赦组织香港海外分会发布年报，指香港表达自由持续恶化之际，香港国安法法官将一名在社交平台上发表「天灭中共」等推翻中共和光复香港等帖文的法轮功学员在煽动，判他入狱12个月。法官明言，被告言论是在抹黑中央政府，但仍以言论自由作辩解，属於公然挑战国家政权。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260415-%E6%B3%95%E8%BD%AE%E5%8A%9F%E5%AD%A6%E5%91%98%E5%8F%91%E5%B8%83%E7%85%BD%E5%8A%A8%E5%B8%96%E6%96%87%E5%88%A4%E5%9B%9A%E4%B8%80%E5%B9%B4-%E6%B3%95%E5%AE%98%E6%8C%87%E4%BB%A5%E8%A8%80%E8%AE%BA%E8%87%AA%E7%94%B1%E5%8C%85%E8%A3%85%E6%94%BF%E6%B2%BB%E7%AB%8B%E5%9C%BA%E5%B1%9E%E6%8C%91%E6%88%98%E6%94%BF%E6%9D%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776237046000.webp","sourceId":"rfi"}]