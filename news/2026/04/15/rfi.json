[{"id":1776240343000,"createdDate":"2026-04-15 08:05","name":"法国国际广播电台","title":"金融时报：伊朗利用中国间谍卫星监视美军基地","content":"法新社消息称，据《金融时报》周三（4月15日）报道，伊朗于2024年底秘密获得了一颗中国间谍卫星，因此自2月28日美国和以色列对伊朗发动战争以来，使得伊朗能够获取中东各地美军基地的图像。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260415-%E9%87%91%E8%9E%8D%E6%97%B6%E6%8A%A5-%E4%BC%8A%E6%9C%97%E5%88%A9%E7%94%A8%E4%B8%AD%E5%9B%BD%E9%97%B4%E8%B0%8D%E5%8D%AB%E6%98%9F%E7%9B%91%E8%A7%86%E7%BE%8E%E5%86%9B%E5%9F%BA%E5%9C%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776240343000.webp","sourceId":"rfi"},{"id":1776237559000,"createdDate":"2026-04-15 07:19","name":"法国国际广播电台","title":"日本阿曼举行首脑电话会谈 日方表示最重要的是维持美伊停火","content":"日本时间4月14日下午4时起约20分钟，日本首相高市早苗与阿曼国家元首苏丹海赛姆举行了电话会谈。鉴于中东局势紧张升级，高市首相与苏丹海赛姆通电话进行了磋商，她传达了日本的立场，即除了推动局势降温之外，尽早确保霍尔木兹海峡的自由且安全的航行是不可或缺的。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260415-%E6%97%A5%E6%9C%AC%E9%98%BF%E6%9B%BC%E4%B8%BE%E8%A1%8C%E9%A6%96%E8%84%91%E7%94%B5%E8%AF%9D%E4%BC%9A%E8%B0%88-%E6%97%A5%E6%96%B9%E8%A1%A8%E7%A4%BA%E6%9C%80%E9%87%8D%E8%A6%81%E7%9A%84%E6%98%AF%E7%BB%B4%E6%8C%81%E7%BE%8E%E4%BC%8A%E5%81%9C%E7%81%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776237559000.webp","sourceId":"rfi"},{"id":1776237346000,"createdDate":"2026-04-15 07:15","name":"法国国际广播电台","title":"中国未放松香港国安 夏宝龙再促乃外力干预 又批有人借大火以灾乱港","content":"今天是「全民国家安全教育日」，中国负责港澳事务的最高级官员夏宝龙在开幕礼上致词时强调，香港发展须由「高水平安全」来护航，时常居安思危，并以去年底导致168人死亡的大埔火灾为例说明，指有人把灾情政治化，「妄图『以灾乱港』」；更须警惕外部势力插手干预的风险，在他们唱衰香港时予以回击，世界地缘冲突对香港可能造成的影响做好应对准备。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260415-%E4%B8%AD%E5%9B%BD%E6%9C%AA%E6%94%BE%E6%9D%BE%E9%A6%99%E6%B8%AF%E5%9B%BD%E5%AE%89-%E5%A4%8F%E5%AE%9D%E9%BE%99%E5%86%8D%E4%BF%83%E4%B9%83%E5%A4%96%E5%8A%9B%E5%B9%B2%E9%A2%84-%E5%8F%88%E6%89%B9%E6%9C%89%E4%BA%BA%E5%80%9F%E5%A4%A7%E7%81%AB%E4%BB%A5%E7%81%BE%E4%B9%B1%E6%B8%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776237346000.webp","sourceId":"rfi"},{"id":1776237046000,"createdDate":"2026-04-15 07:10","name":"法国国际广播电台","title":"法轮功学员发布煽动帖文判囚一年 法官指以言论自由包装政治立场属挑战政权","content":"在国际特赦组织香港海外分会发布年报，指香港表达自由持续恶化之际，香港国安法法官将一名在社交平台上发表「天灭中共」等推翻中共和光复香港等帖文的法轮功学员在煽动，判他入狱12个月。法官明言，被告言论是在抹黑中央政府，但仍以言论自由作辩解，属於公然挑战国家政权。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260415-%E6%B3%95%E8%BD%AE%E5%8A%9F%E5%AD%A6%E5%91%98%E5%8F%91%E5%B8%83%E7%85%BD%E5%8A%A8%E5%B8%96%E6%96%87%E5%88%A4%E5%9B%9A%E4%B8%80%E5%B9%B4-%E6%B3%95%E5%AE%98%E6%8C%87%E4%BB%A5%E8%A8%80%E8%AE%BA%E8%87%AA%E7%94%B1%E5%8C%85%E8%A3%85%E6%94%BF%E6%B2%BB%E7%AB%8B%E5%9C%BA%E5%B1%9E%E6%8C%91%E6%88%98%E6%94%BF%E6%9D%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776237046000.webp","sourceId":"rfi"},{"id":1776266942000,"createdDate":"2026-04-15 15:29","name":"法国国际广播电台","title":"2026世界杯伊朗队参赛前景未定：坚持要求更改赛地，FIFA暂未回应","content":"距离2026年6月11日至7月19日举行的男足世界杯越来越近，伊朗国家队的参赛与比赛举办地问题持续引发关注。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E4%BD%93%E8%82%B2/20260415-2026%E4%B8%96%E7%95%8C%E6%9D%AF%E4%BC%8A%E6%9C%97%E9%98%9F%E5%8F%82%E8%B5%9B%E5%89%8D%E6%99%AF%E6%9C%AA%E5%AE%9A-%E5%9D%9A%E6%8C%81%E8%A6%81%E6%B1%82%E6%9B%B4%E6%94%B9%E8%B5%9B%E5%9C%B0%EF%BC%8Cfifa%E6%9A%82%E6%9C%AA%E5%9B%9E%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776266942000.webp","sourceId":"rfi"},{"id":1776264715000,"createdDate":"2026-04-15 14:51","name":"法国国际广播电台","title":"路透社获取的卫星图像显示：中国正通过部署船只和屏障的方式，加强对南海争议岛礁的控制","content":"路透社周三（4月15日）消息称，从获取的卫星图像显示，中国已在南海争议水域的斯卡伯勒浅滩入口部署船只并设置屏障，以加强对该区域的控制。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260415-%E8%B7%AF%E9%80%8F%E7%A4%BE%E8%8E%B7%E5%8F%96%E7%9A%84%E5%8D%AB%E6%98%9F%E5%9B%BE%E5%83%8F%E6%98%BE%E7%A4%BA-%E4%B8%AD%E5%9B%BD%E6%AD%A3%E9%80%9A%E8%BF%87%E9%83%A8%E7%BD%B2%E8%88%B9%E5%8F%AA%E5%92%8C%E5%B1%8F%E9%9A%9C%E7%9A%84%E6%96%B9%E5%BC%8F%EF%BC%8C%E5%8A%A0%E5%BC%BA%E5%AF%B9%E5%8D%97%E6%B5%B7%E4%BA%89%E8%AE%AE%E5%B2%9B%E7%A4%81%E7%9A%84%E6%8E%A7%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776264715000.webp","sourceId":"rfi"},{"id":1776260833000,"createdDate":"2026-04-15 13:47","name":"法国国际广播电台","title":"中东海湾战争引发全球煤炭消费复苏","content":"随着中东海湾战争持续，导致全球原油和天然气等能源价格飙升，让德国、意大利、日本、印度、中国等重启老旧燃煤电厂，同时开始兴建新的煤炭发电厂，转向这种高环境污染能源的国家名单还在不断增加，引发环保人士的担忧。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E7%8E%AF%E5%A2%83%E4%B8%8E%E5%8F%91%E5%B1%95/20260415-%E4%B8%AD%E4%B8%9C%E6%B5%B7%E6%B9%BE%E6%88%98%E4%BA%89%E5%BC%95%E5%8F%91%E5%85%A8%E7%90%83%E7%85%A4%E7%82%AD%E6%B6%88%E8%B4%B9%E5%A4%8D%E8%8B%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776260833000.webp","sourceId":"rfi"},{"id":1776260561000,"createdDate":"2026-04-15 13:42","name":"法国国际广播电台","title":"美国封锁霍尔木兹海峡 伊朗威胁关闭红海","content":"伊朗今天周三威胁称如果美国继续封锁霍尔木兹海峡的伊朗港口，伊朗将封锁红海海上交通，并警告说自4月8日生效的停火协议岌岌可危。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260415-%E7%BE%8E%E5%9B%BD%E5%B0%81%E9%94%81%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E4%BC%8A%E6%9C%97%E5%A8%81%E8%83%81%E5%85%B3%E9%97%AD%E7%BA%A2%E6%B5%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776260561000.webp","sourceId":"rfi"},{"id":1776259489000,"createdDate":"2026-04-15 13:24","name":"法国国际广播电台","title":"特朗普称中国已同意不向伊朗输送武器，还表示到访中国时“习近平主席会给我一个大大的拥抱”","content":"美国总统特朗普周三（4月15日）表示，中国已同意不向伊朗提供武器，并称他已从中国国家主席习近平那里获得了保证。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260415-%E7%89%B9%E6%9C%97%E6%99%AE%E7%A7%B0%E4%B8%AD%E5%9B%BD%E5%B7%B2%E5%90%8C%E6%84%8F%E4%B8%8D%E5%90%91%E4%BC%8A%E6%9C%97%E8%BE%93%E9%80%81%E6%AD%A6%E5%99%A8%EF%BC%8C%E5%B9%B6%E5%86%8D%E6%AC%A1%E9%87%8D%E7%94%B3%E5%92%8C%E4%B9%A0%E8%BF%91%E5%B9%B3-%E5%85%B3%E7%B3%BB%E5%BE%88%E5%A5%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776259489000.webp","sourceId":"rfi"},{"id":1776258624000,"createdDate":"2026-04-15 13:10","name":"法国国际广播电台","title":"日本承诺向东南亚国家提供85亿欧元财政支持，以稳定亚洲能源供应链","content":"由于中东战争威胁到日本关键医疗设备及石油衍生产品的供应，日本周三（4月15日）承诺向东南亚国家提供相当于85亿欧元的财政支持。在这项名为“PowerAsia”的倡议中，日本计划向东南亚国家提供1.6万亿日元，以加强日本的能源供应链，并帮助它们获取原油及石油产品。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260415-%E6%97%A5%E6%9C%AC%E6%89%BF%E8%AF%BA%E5%90%91%E4%B8%9C%E5%8D%97%E4%BA%9A%E6%8F%90%E4%BE%9B85%E4%BA%BF%E6%AC%A7%E5%85%83%E8%B4%A2%E6%94%BF%E6%94%AF%E6%8C%81%EF%BC%8C%E4%BB%A5%E7%A8%B3%E5%AE%9A%E4%BA%9A%E6%B4%B2%E8%83%BD%E6%BA%90%E4%BE%9B%E5%BA%94%E9%93%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776258624000.webp","sourceId":"rfi"},{"id":1776258515000,"createdDate":"2026-04-15 13:08","name":"法国国际广播电台","title":"中东战乱 中国密集外交   俄罗斯能弥补资源缺口？","content":"在中东战争前景不明和全球紧张的地缘战略局势下，目前北京的外交活动显得异常活跃，周二与西班牙首相桑切斯和阿联酋阿布扎比王储哈立德会谈后，中国国家主席习近平周三（4月15号）会见了越南主席苏林和俄罗斯外交部长拉夫罗夫。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260415-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%B9%B1-%E4%B8%AD%E5%9B%BD%E5%AF%86%E9%9B%86%E5%A4%96%E4%BA%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776258515000.webp","sourceId":"rfi"},{"id":1776255956000,"createdDate":"2026-04-15 12:25","name":"法国国际广播电台","title":"台湾首位中配立法委员70天国会生涯 中配在台从政涉及国安与参政权的拉扯","content":"李贞秀作为首位中配立委的国会路却不顺遂，接连陷入双国籍争议与失言风波。这也引起中配参政权与国籍法争议再度浮上台面。然而，中配参政问题复杂，除了涉及国安问题外，法律上也遇到无可解的难题。究竟中配能如何在台湾参政？","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260415-%E5%8F%B0%E6%B9%BE%E9%A6%96%E4%BD%8D%E4%B8%AD%E9%85%8D%E7%AB%8B%E6%B3%95%E5%A7%94%E5%91%9870%E5%A4%A9%E5%9B%BD%E4%BC%9A%E7%94%9F%E6%B6%AF-%E4%B8%AD%E9%85%8D%E5%9C%A8%E5%8F%B0%E4%BB%8E%E6%94%BF%E6%B6%89%E5%8F%8A%E5%9B%BD%E5%AE%89%E4%B8%8E%E5%8F%82%E6%94%BF%E6%9D%83%E7%9A%84%E6%8B%89%E6%89%AF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776255956000.webp","sourceId":"rfi"},{"id":1776252941000,"createdDate":"2026-04-15 11:35","name":"法国国际广播电台","title":"斯大林曾问：教宗，座下有多少个师？费加罗报今问： 特朗普，麾下有多少个师？","content":"大家好，欢迎收听法国报纸摘要，今天是4月15日星期三，法国各主要日报头版重点各有不同。在中东战争未歇之际，《解放报》关注苏丹打了三年的内战，迄今仍在交火，导致上万人死亡以及逾1300万人流离失所，目前这场战争已进入政权割据的阶段。正展开非洲使徒之旅的教宗良十四与美国总统特朗普就伊朗战争的论战升级成为《费加罗报》首页议题，该报编辑部提问「特朗普，麾下有多少个师？」做为标题发表社评文章。《费加罗报》国际版同时报道了，拉夫罗夫在北京表示，俄罗斯准备「弥补」中国及其他国家因中东战争而遭受的能源短缺。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260415-%E6%96%AF%E5%A4%A7%E6%9E%97%E6%9B%BE%E9%97%AE-%E6%95%99%E5%AE%97%EF%BC%8C%E5%BA%A7%E4%B8%8B%E6%9C%89%E5%A4%9A%E5%B0%91%E4%B8%AA%E5%B8%88-%E8%B4%B9%E5%8A%A0%E7%BD%97%E6%8A%A5%E4%BB%8A%E9%97%AE-%E7%89%B9%E6%9C%97%E6%99%AE%EF%BC%8C%E9%BA%BE%E4%B8%8B%E6%9C%89%E5%A4%9A%E5%B0%91%E4%B8%AA%E5%B8%88","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776252941000.webp","sourceId":"rfi"},{"id":1776251017000,"createdDate":"2026-04-15 11:03","name":"法国国际广播电台","title":"电动卡车：一家中国start-up筹划在法国落地","content":"周三15日《回声报》报道指，中国风玫瑰科技（WindroseTechnology）正在推进其在法国瓦朗谢讷（LesValenciennes）附近建设电动卡车工厂的项目。该公司希望撼动行业巨头。这一计划获得了1.75亿欧元的投资支持。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260415-%E7%94%B5%E5%8A%A8%E5%8D%A1%E8%BD%A6-%E4%B8%80%E5%AE%B6%E4%B8%AD%E5%9B%BDstart-up%E7%AD%B9%E5%88%92%E5%9C%A8%E6%B3%95%E5%9B%BD%E8%90%BD%E5%9C%B0","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776251017000.webp","sourceId":"rfi"},{"id":1776248109000,"createdDate":"2026-04-15 10:15","name":"法国国际广播电台","title":"莫斯科之后，印尼总统访法商讨加强防务合作","content":"雅加达周三（4月15号）表示，印度尼西亚总统普拉博沃·苏比安托与法国总统埃马纽埃尔·马克龙周二在巴黎就加强两国在国防领域的合作进行了讨论。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20260415-%E8%8E%AB%E6%96%AF%E7%A7%91%E4%B9%8B%E5%90%8E%EF%BC%8C%E5%8D%B0%E5%B0%BC%E6%80%BB%E7%BB%9F%E8%AE%BF%E6%B3%95%E5%95%86%E8%AE%A8%E5%8A%A0%E5%BC%BA%E9%98%B2%E5%8A%A1%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776248109000.webp","sourceId":"rfi"},{"id":1776247604000,"createdDate":"2026-04-15 10:06","name":"法国国际广播电台","title":"中国重申：“坚定支持”古巴应对来自美国的压力和威胁","content":"中国周三（4月15日）重申，将“坚定支持”古巴应对来自美国持续的压力和威胁。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260415-%E4%B8%AD%E5%9B%BD%E9%87%8D%E7%94%B3-%E5%9D%9A%E5%AE%9A%E6%94%AF%E6%8C%81-%E5%8F%A4%E5%B7%B4%E5%BA%94%E5%AF%B9%E6%9D%A5%E8%87%AA%E7%BE%8E%E5%9B%BD%E7%9A%84%E5%8E%8B%E5%8A%9B%E5%92%8C%E5%A8%81%E8%83%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776247604000.webp","sourceId":"rfi"},{"id":1776247049000,"createdDate":"2026-04-15 09:57","name":"法国国际广播电台","title":"匈牙利候任总理马扎尔：将暂停曾作为政府“传声筒”的公共媒体新闻服务，并出台新的媒体法充分保障新闻自由","content":"近日，彼得·马扎尔在匈牙利选举中大获全胜，即将终结欧尔班长达16年的执政。这位候任总理周三（4月15日）表示，新政府将通过出台新的媒体法等措施，保障新闻自由。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260415-%E5%8C%88%E7%89%99%E5%88%A9%E5%80%99%E4%BB%BB%E6%80%BB%E7%90%86%E9%A9%AC%E6%89%8E%E5%B0%94-%E5%B0%86%E6%9A%82%E5%81%9C%E6%9B%BE%E4%BD%9C%E4%B8%BA%E6%94%BF%E5%BA%9C-%E4%BC%A0%E5%A3%B0%E7%AD%92-%E7%9A%84%E5%85%AC%E5%85%B1%E5%AA%92%E4%BD%93%E6%96%B0%E9%97%BB%E6%9C%8D%E5%8A%A1%EF%BC%8C%E5%B9%B6%E5%87%BA%E5%8F%B0%E6%96%B0%E7%9A%84%E5%AA%92%E4%BD%93%E6%B3%95%E5%85%85%E5%88%86%E4%BF%9D%E9%9A%9C%E6%96%B0%E9%97%BB%E8%87%AA%E7%94%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776247049000.webp","sourceId":"rfi"},{"id":1776245879000,"createdDate":"2026-04-15 09:37","name":"法国国际广播电台","title":"匈牙利政局更迭后，欧盟对俄乌政策僵局有望松动","content":"匈牙利政局的最新变化正引发欧洲的高度关注。彼得·马扎尔在立法选举中大举获胜，可能打破此前长期存在的欧盟对乌援助和对俄政策方面的僵局。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260415-%E5%8C%88%E7%89%99%E5%88%A9%E6%94%BF%E5%B1%80%E6%9B%B4%E8%BF%AD%E5%90%8E%EF%BC%8C%E6%AC%A7%E7%9B%9F%E5%AF%B9%E4%BF%84%E4%B9%8C%E6%94%BF%E7%AD%96%E5%83%B5%E5%B1%80%E6%9C%89%E6%9C%9B%E6%9D%BE%E5%8A%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776245879000.webp","sourceId":"rfi"},{"id":1776245459000,"createdDate":"2026-04-15 09:30","name":"法国国际广播电台","title":"韩国：将从霍尔木兹海峡外的其它渠道获得2.7亿桶原油供应","content":"韩国总统府幕僚长姜勋植周三（4月15日）表示，韩国已通过未受霍尔木兹海峡封锁影响的渠道，确保获得超过2.7亿桶原油供应。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260415-%E9%9F%A9%E5%9B%BD-%E5%B0%86%E4%BB%8E%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E5%A4%96%E7%9A%84%E5%85%B6%E5%AE%83%E6%B8%A0%E9%81%93%E8%8E%B7%E5%BE%972-7%E4%BA%BF%E6%A1%B6%E5%8E%9F%E6%B2%B9%E4%BE%9B%E5%BA%94","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776245459000.webp","sourceId":"rfi"},{"id":1776244812000,"createdDate":"2026-04-15 09:20","name":"法国国际广播电台","title":"尽管中国游客数量大幅下滑，3月赴日本赏樱花的外国游客数量创历年最高纪录","content":"目前日本正值樱花盛开季节，尽管中国游客数量大幅下滑以及中东战争带来影响，日本在3月仍吸引了创纪录数量的外国游客。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260415-%E5%B0%BD%E7%AE%A1%E4%B8%AD%E5%9B%BD%E6%B8%B8%E5%AE%A2%E6%95%B0%E9%87%8F%E5%A4%A7%E5%B9%85%E4%B8%8B%E6%BB%91%EF%BC%8C3%E6%9C%88%E8%B5%B4%E6%97%A5%E6%9C%AC%E8%B5%8F%E6%A8%B1%E8%8A%B1%E7%9A%84%E5%A4%96%E5%9B%BD%E6%B8%B8%E5%AE%A2%E6%95%B0%E9%87%8F%E5%88%9B%E5%8E%86%E5%B9%B4%E6%9C%80%E9%AB%98%E7%BA%AA%E5%BD%95","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776244812000.webp","sourceId":"rfi"},{"id":1776244632000,"createdDate":"2026-04-15 09:17","name":"法国国际广播电台","title":"国际原子能机构警告：朝鲜核能力的增长\"令人担忧\"，并称发现朝鲜正在建设新的铀浓缩设施","content":"国际原子能机构（AIEA）负责人周三警告称，朝鲜在生产核武器方面的能力出现了“非常令人担忧的增长”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260415-%E5%9B%BD%E9%99%85%E5%8E%9F%E5%AD%90%E8%83%BD%E6%9C%BA%E6%9E%84%E8%AD%A6%E5%91%8A-%E6%9C%9D%E9%B2%9C%E6%A0%B8%E8%83%BD%E5%8A%9B%E7%9A%84%E5%A2%9E%E9%95%BF-%E4%BB%A4%E4%BA%BA%E6%8B%85%E5%BF%A7-%EF%BC%8C%E5%B9%B6%E7%A7%B0%E5%8F%91%E7%8E%B0%E6%9C%9D%E9%B2%9C%E6%AD%A3%E5%9C%A8%E5%BB%BA%E8%AE%BE%E6%96%B0%E7%9A%84%E9%93%80%E6%B5%93%E7%BC%A9%E8%AE%BE%E6%96%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776244632000.webp","sourceId":"rfi"},{"id":1776244396000,"createdDate":"2026-04-15 09:13","name":"法国国际广播电台","title":"特朗普：与伊朗的战争“几乎已经结束”，重启谈判在“接下来两三天内可能会有进展”","content":"美国总统特朗普周二（4月15日）表示，与伊朗的战争“几乎已经结束”，他还表示本周可能在巴基斯坦恢复与伊朗的谈判。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260415-%E7%89%B9%E6%9C%97%E6%99%AE-%E4%B8%8E%E4%BC%8A%E6%9C%97%E7%9A%84%E6%88%98%E4%BA%89-%E5%87%A0%E4%B9%8E%E5%B7%B2%E7%BB%8F%E7%BB%93%E6%9D%9F-%EF%BC%8C%E9%87%8D%E5%90%AF%E8%B0%88%E5%88%A4%E5%9C%A8-%E6%8E%A5%E4%B8%8B%E6%9D%A5%E4%B8%A4%E4%B8%89%E5%A4%A9%E5%86%85%E5%8F%AF%E8%83%BD%E4%BC%9A%E6%9C%89%E8%BF%9B%E5%B1%95","thumbnail":"","detailImage":"news/detail/rfi/2026/04/15/1776244396000.webp","sourceId":"rfi"}]