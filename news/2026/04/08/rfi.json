[{"id":1775638268000,"createdDate":"2026-04-08 08:51","name":"法国国际广播电台","title":"法国总统马克龙 :与伊朗停火协议必须“完全”涵盖黎巴嫩","content":"中东战事已持续40天，华盛顿和德黑兰于4月7日达成停火两周协议，以重新开放霍尔木兹海峡为条件。不过以色列方面表示，此次停火“不包括黎巴嫩”。法国总统马克龙对停火协议表示欢迎，称其为“一件好事”，但他强调停火协议必须“完全”涵盖黎巴嫩。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260408-%E6%B3%95%E5%9B%BD%E6%80%BB%E7%BB%9F%E9%A9%AC%E5%85%8B%E9%BE%99-%E4%B8%8E%E4%BC%8A%E6%9C%97%E5%81%9C%E7%81%AB%E5%8D%8F%E8%AE%AE%E5%BF%85%E9%A1%BB-%E5%AE%8C%E5%85%A8-%E6%B6%B5%E7%9B%96%E9%BB%8E%E5%B7%B4%E5%AB%A9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775638268000.webp","sourceId":"rfi"},{"id":1775636805000,"createdDate":"2026-04-08 08:26","name":"法国国际广播电台","title":"日本首相与伊朗总统举行会谈 日本对美伊停火表示欢迎","content":"日本首相高市早苗日本时间8日下午与伊朗总统佩泽希齐扬进行了约25分钟的电话会谈。围绕中东局势，日方在说明日本立场的同时，也就美国与伊朗“为期两周的停火协议”等问题交换了意见，此前她表示希望发挥日本在伊朗与美国之间的桥梁作用，而日本内阁官房长官木原稔在日本时间8日上午的记者会上，就美国与伊朗达成两周停火协议一事表示：“对于此次美伊双方的发表，我们将其视为积极动向并表示欢迎。”他还强调，关键在于“包括确保霍尔木兹海峡航行安全在内，局势能够真正得到缓和”，并对尽早达成最终停火协议表示期待。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260408-%E6%97%A5%E6%9C%AC%E5%AF%B9%E7%BE%8E%E4%BC%8A%E5%81%9C%E7%81%AB%E8%A1%A8%E7%A4%BA%E6%AC%A2%E8%BF%8E-%E9%A6%96%E7%9B%B8%E5%B8%8C%E6%9C%9B%E5%9C%A8%E7%BE%8E%E4%BC%8A%E4%B9%8B%E9%97%B4%E7%89%B5%E7%BA%BF%E6%90%AD%E6%A1%A5","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775636805000.webp","sourceId":"rfi"},{"id":1775631161000,"createdDate":"2026-04-08 06:52","name":"法国国际广播电台","title":"国安新规9月涵盖全港食肆 评论忧食肆为符规成国安「耳目」 异见更受针对","content":"港府高层在「全民国家安全教育日」前，纷纷强调香港国安斗争未停止，强化对港人各层面的国安管理，无处不在的食肆自然成为目标，当局预计，到了今年9月，全港食肆将会全数被纳入国安管理条款内。业内人士担心，日后各部门以国安之名的巡查将愈见频密且合理化，使经营更加困难；评论批评，港府的做法是要全港食肆成为国安「耳目」，协助打压被针对人士。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260408-%E5%9B%BD%E5%AE%89%E6%96%B0%E8%A7%849%E6%9C%88%E6%B6%B5%E7%9B%96%E5%85%A8%E6%B8%AF%E9%A3%9F%E8%82%86-%E8%AF%84%E8%AE%BA%E5%BF%A7%E9%A3%9F%E8%82%86%E4%B8%BA%E7%AC%A6%E8%A7%84%E6%88%90%E5%9B%BD%E5%AE%89-%E8%80%B3%E7%9B%AE-%E5%BC%82%E8%A7%81%E6%9B%B4%E5%8F%97%E9%92%88%E5%AF%B9","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775631161000.webp","sourceId":"rfi"},{"id":1775663095000,"createdDate":"2026-04-08 15:44","name":"法国国际广播电台","title":"郑丽文访中山陵 称播撒和平种子 现场保安严密 外国人禁止入内","content":"据法新社4月8日南京消息，台湾在野党党魁、主张与北京拉近关系的郑丽文周三表示，在此次罕见的访华行程第二天，她希望在双边关系紧张之际“播下和平的种子”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260408-%E9%83%91%E4%B8%BD%E6%96%87%E8%AE%BF%E4%B8%AD%E5%B1%B1%E9%99%B5-%E7%A7%B0%E6%92%AD%E6%92%92%E5%92%8C%E5%B9%B3%E7%A7%8D%E5%AD%90-%E7%8E%B0%E5%9C%BA%E4%BF%9D%E5%AE%89%E4%B8%A5%E5%AF%86-%E5%A4%96%E5%9B%BD%E4%BA%BA%E7%A6%81%E6%AD%A2%E5%85%A5%E5%86%85","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775663095000.webp","sourceId":"rfi"},{"id":1775659999000,"createdDate":"2026-04-08 14:53","name":"法国国际广播电台","title":"伊朗以间谍罪监禁的两名法国公民返巴黎 马克龙感谢安曼 但交换条件秘而不宣","content":"两名被伊朗当局指控间谍而监禁的法国公民获释后周三飞抵巴黎，马克龙在爱丽舍宫为他们接风。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260408-%E4%BC%8A%E6%9C%97%E4%BB%A5%E9%97%B4%E8%B0%8D%E7%BD%AA%E7%9B%91%E7%A6%81%E7%9A%84%E4%B8%A4%E5%90%8D%E6%B3%95%E5%9B%BD%E5%85%AC%E6%B0%91%E8%BF%94%E5%B7%B4%E9%BB%8E-%E9%A9%AC%E5%85%8B%E9%BE%99%E6%84%9F%E8%B0%A2%E5%AE%89%E6%9B%BC-%E4%BA%A4%E6%8D%A2%E6%9D%A1%E4%BB%B6%E7%A7%98%E8%80%8C%E4%B8%8D%E5%AE%A3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775659999000.webp","sourceId":"rfi"},{"id":1775659628000,"createdDate":"2026-04-08 14:47","name":"法国国际广播电台","title":"中国外交部：阿富汗和巴基斯坦同意避免双边冲突升级","content":"阿富汗和巴基斯坦围绕近期两国间的武装冲突的谈判似乎取得进展。中国外交部发言人毛宁8日在北京的例行记者会上表示，两国在新疆乌鲁木齐会谈一周后，同意不采取使事态升级或复杂化的行动。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260408-%E4%B8%AD%E5%9B%BD%E5%A4%96%E4%BA%A4%E9%83%A8-%E9%98%BF%E5%AF%8C%E6%B1%97%E5%92%8C%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%90%8C%E6%84%8F%E9%81%BF%E5%85%8D%E5%8F%8C%E8%BE%B9%E5%86%B2%E7%AA%81%E5%8D%87%E7%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775659628000.webp","sourceId":"rfi"},{"id":1775659000000,"createdDate":"2026-04-08 14:36","name":"法国国际广播电台","title":"美伊停火两周：油价大跌，股市大涨，但忧虑仍在","content":"自美国和以色列2月28日联手对伊朗展开大规模军事打击行动以来，国际能源市场以及股市几周来一再大起大落。7日晚间，美伊停火两周，以便重启谈判的消息传出立即引发市场效应，石油和天然气价格瞬时大跌，而亚洲股市立即强力反弹。但这种即时的振奋未必意味着市场将回归平稳，海湾能源供应链安全因这场战争引发的危机感并不会轻易随风散去，国际能源市场价格跌落何时能反应在消费者的钱包里尚难知晓。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E7%BB%8F%E6%B5%8E/20260408-%E7%BE%8E%E4%BC%8A%E5%81%9C%E7%81%AB%E4%B8%A4%E5%91%A8-%E6%B2%B9%E4%BB%B7%E5%A4%A7%E8%B7%8C%EF%BC%8C%E8%82%A1%E5%B8%82%E5%A4%A7%E6%B6%A8%EF%BC%8C%E4%BD%86%E5%BF%A7%E8%99%91%E4%BB%8D%E5%9C%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775659000000.webp","sourceId":"rfi"},{"id":1775655312000,"createdDate":"2026-04-08 13:35","name":"法国国际广播电台","title":"中国对中东停火表示欢迎 强调其在推动停火方面发挥了积极作用","content":"中国周三表示“欢迎”美国与伊朗达成的为期两周的停火协议，并强调其在推动停火方面发挥了积极作用。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260408-%E4%B8%AD%E5%9B%BD%E5%AF%B9%E4%B8%AD%E4%B8%9C%E5%81%9C%E7%81%AB%E8%A1%A8%E7%A4%BA%E6%AC%A2%E8%BF%8E-%E5%BC%BA%E8%B0%83%E5%85%B6%E5%9C%A8%E6%8E%A8%E5%8A%A8%E5%81%9C%E7%81%AB%E6%96%B9%E9%9D%A2%E5%8F%91%E6%8C%A5%E4%BA%86%E7%A7%AF%E6%9E%81%E4%BD%9C%E7%94%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775655312000.webp","sourceId":"rfi"},{"id":1775653503000,"createdDate":"2026-04-08 13:05","name":"法国国际广播电台","title":"台湾如何掌握全球半导体产业主导权 成为“小众超级大国”","content":"各位听众，，台湾在半导体领域的技术实力如今在全球地缘政治平衡中扮演着关键角色。在这层“硅盾”背后，是台湾历经五十余年精心构建的产业战略。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260408-%E5%8F%B0%E6%B9%BE%E5%A6%82%E4%BD%95%E6%8E%8C%E6%8F%A1%E5%85%A8%E7%90%83%E5%8D%8A%E5%AF%BC%E4%BD%93%E4%BA%A7%E4%B8%9A%E4%B8%BB%E5%AF%BC%E6%9D%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775653503000.webp","sourceId":"rfi"},{"id":1775650445000,"createdDate":"2026-04-08 12:14","name":"法国国际广播电台","title":"霍尔木兹海峡重开的消息令油价大跌 股市飙涨","content":"随着霍尔木兹海峡重开的消息公布，周三早晨国际油价大跌，股市飙涨。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260408-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E9%87%8D%E5%BC%80%E7%9A%84%E6%B6%88%E6%81%AF%E4%BB%A4%E6%B2%B9%E4%BB%B7%E5%A4%A7%E8%B7%8C-%E8%82%A1%E5%B8%82%E9%A3%99%E6%B6%A8","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775650445000.webp","sourceId":"rfi"},{"id":1775649079000,"createdDate":"2026-04-08 11:51","name":"法国国际广播电台","title":"美国与伊朗达成协议停火两周 换取重开霍尔木兹海峡 协议英文和波斯语版有别","content":"在美国总统特朗普威胁要摧毁伊朗伊斯兰共和国的最后通牒到期前一个多小时，美国和伊朗达成协议，同意停火两周，换取重开霍尔木兹海峡。预计双方周五将在巴基斯坦重开谈判。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260408-%E7%BE%8E%E5%9B%BD%E4%B8%8E%E4%BC%8A%E6%9C%97%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE%E5%81%9C%E7%81%AB%E4%B8%A4%E5%91%A8-%E6%8D%A2%E5%8F%96%E9%87%8D%E5%BC%80%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E5%8D%8F%E8%AE%AE%E8%8B%B1%E6%96%87%E5%92%8C%E6%B3%A2%E6%96%AF%E8%AF%AD%E7%89%88%E6%9C%89%E5%8C%BA%E5%88%AB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775649079000.webp","sourceId":"rfi"},{"id":1775645899000,"createdDate":"2026-04-08 10:58","name":"法国国际广播电台","title":"解放报：争议不断的台湾反对派党魁郑丽文——出征习近平治下的中国","content":"继《费加罗报》与《世界报》后，《解放报》周三8日登出由ArnaudVaulerin撰写的文章点评在高度争议声浪中出访中国的台湾最大反对党国民党主席郑丽文。文章导言写道，去年十月当选国民党主席后，郑丽文此番赴大陆进行为期六天的正式访问，旨在倡导恢复与北京的“建设性对话”。邀请她成行的习近平，对这一时机可谓志得意满。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260408-%E8%A7%A3%E6%94%BE%E6%8A%A5-%E4%BA%89%E8%AE%AE%E4%B8%8D%E6%96%AD%E7%9A%84%E5%8F%B0%E6%B9%BE%E5%8F%8D%E5%AF%B9%E6%B4%BE%E5%85%9A%E9%AD%81%E9%83%91%E4%B8%BD%E6%96%87-%E5%89%8D%E8%BF%9B%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%B2%BB%E4%B8%8B%E7%9A%84%E4%B8%AD%E5%9B%BD","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775645899000.webp","sourceId":"rfi"},{"id":1775645691000,"createdDate":"2026-04-08 10:54","name":"法国国际广播电台","title":"睽违十年国共领袖将再次会面 郑习会究竟是两岸破冰还是分化台湾？","content":"国民党主席郑丽文于7日到12日率团出访中国，她表示，此行要让民进党知道两岸和平没那么难，且第一件事情就是要得到北京的善意回应。但郑习会也引部分政党人士担忧。民进党表示，欢迎交流，但绝不能以台湾主权交换。台湾国安局长则担心中共借郑习会达到分化台湾目的。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E5%8F%B0%E6%B5%B7/20260408-%E7%9D%BD%E8%BF%9D%E5%8D%81%E5%B9%B4%E5%9B%BD%E5%85%B1%E9%A2%86%E8%A2%96%E5%B0%86%E5%86%8D%E6%AC%A1%E4%BC%9A%E9%9D%A2-%E9%83%91%E4%B9%A0%E4%BC%9A%E7%A9%B6%E7%AB%9F%E6%98%AF%E4%B8%A4%E5%B2%B8%E7%A0%B4%E5%86%B0%E8%BF%98%E6%98%AF%E5%88%86%E5%8C%96%E5%8F%B0%E6%B9%BE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775645691000.webp","sourceId":"rfi"},{"id":1775641557000,"createdDate":"2026-04-08 09:45","name":"法国国际广播电台","title":"中俄联手否决霍尔木兹海峡“温和版”决议案 法国的努力付诸东流","content":"美国总统特朗普7日晚在最后通牒到期前发文称，他“同意”停止空袭伊朗两周，并指伊朗已向华盛顿提交了一份“可行的”十点计划，该计划可作为谈判的基础。他还写道，如果伊朗“完全”重新开放霍尔木兹海峡，美国也准备停火。这项国际社会盼望已久的伊战停火消息，成为周四4月8日法国各大报纸的头版重点。与此同时，就在特朗普回应他听说中国应也参与了停火谈判之际，中国与俄罗斯联手否决了联合国安理会关于霍尔木兹海峡的决议案。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260408-%E4%B8%AD%E4%BF%84%E8%81%94%E6%89%8B%E5%90%A6%E5%86%B3%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E6%B8%A9%E5%92%8C%E7%89%88-%E5%86%B3%E8%AE%AE%E6%A1%88-%E6%B3%95%E5%9B%BD%E7%9A%84%E5%8A%AA%E5%8A%9B%E4%BB%98%E8%AF%B8%E4%B8%9C%E6%B5%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775641557000.webp","sourceId":"rfi"},{"id":1775640206000,"createdDate":"2026-04-08 09:23","name":"法国国际广播电台","title":"日本计划显著提升女性军人比例以缓解征兵压力","content":"日本正计划在未来十余年内显著提升女性在军队中的比例。根据今年设定的一项目标，日本希望到2036年3月，将女性在自卫队人员中的占比从目前的9%提高至13%。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260408-%E6%97%A5%E6%9C%AC%E8%AE%A1%E5%88%92%E6%98%BE%E8%91%97%E6%8F%90%E5%8D%87%E5%A5%B3%E6%80%A7%E5%86%9B%E4%BA%BA%E6%AF%94%E4%BE%8B%E4%BB%A5%E7%BC%93%E8%A7%A3%E5%BE%81%E5%85%B5%E5%8E%8B%E5%8A%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775640206000.webp","sourceId":"rfi"},{"id":1775638924000,"createdDate":"2026-04-08 09:02","name":"法国国际广播电台","title":"朝鲜一天两次发射导弹让缓和局势希望渺茫  王毅将到访平壤","content":"韩国军方表示，朝鲜周三（4月8日）发射了多枚弹道导弹，此前一天朝鲜也进行了一次发射。这一系列试验使首尔方面对缓和紧张局势的希望变得渺茫。这些发射也是在朝方宣布中国外交部长王毅将于4月9日至10日访问朝鲜之前进行的。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260408-%E6%9C%9D%E9%B2%9C%E4%B8%80%E5%A4%A9%E4%B8%A4%E6%AC%A1%E5%8F%91%E5%B0%84%E5%AF%BC%E5%BC%B9%E8%AE%A9%E7%BC%93%E5%92%8C%E5%B1%80%E5%8A%BF%E5%B8%8C%E6%9C%9B%E6%B8%BA%E8%8C%AB-%E7%8E%8B%E6%AF%85%E5%B0%86%E5%88%B0%E8%AE%BF%E5%B9%B3%E5%A3%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/08/1775638924000.webp","sourceId":"rfi"}]