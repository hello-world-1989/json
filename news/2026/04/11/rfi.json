[{"id":1775896298000,"createdDate":"2026-04-11 08:31","name":"法国国际广播电台","title":"霍尔木兹海峡紧张 日本澳大利亚加紧战略合作","content":"在霍尔木兹海峡遭封锁，原油和物资运输中断的背景下，日本和澳大利亚正加紧推进安保与产业供应链的合作，力图通过中等发达国家等的连携对应大国的独断专行及所造成的世界性的影响等，最近几天连续举行各层级的高官会谈。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260411-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%B4%A7%E5%BC%A0-%E6%97%A5%E6%9C%AC%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E5%8A%A0%E7%B4%A7%E6%88%98%E7%95%A5%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775896298000.webp","sourceId":"rfi"},{"id":1775896217000,"createdDate":"2026-04-11 08:30","name":"法国国际广播电台","title":"俄乌东正教复活节短期停火将于周六下午16时生效，共计32小时直至周日，停火前俄罗斯空袭造成至少2人死亡","content":"法新社消息称，俄罗斯总统普京周四（4月11日）宣布的且乌方也表示同意的东正教复活节短期停火将于周六（4月11日）下午16时开始生效，并持续至周日结束，共计32小时。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260411-%E4%BF%84%E4%B9%8C%E4%B8%9C%E6%AD%A3%E6%95%99%E5%A4%8D%E6%B4%BB%E8%8A%82%E7%9F%AD%E6%9C%9F%E5%81%9C%E7%81%AB%E5%B0%86%E4%BA%8E%E5%91%A8%E5%85%AD%E4%B8%8B%E5%8D%8816%E6%97%B6%E7%94%9F%E6%95%88%EF%BC%8C%E5%85%B1%E8%AE%A132%E5%B0%8F%E6%97%B6%E7%9B%B4%E8%87%B3%E5%91%A8%E6%97%A5%EF%BC%8C%E5%81%9C%E7%81%AB%E5%89%8D%E4%BF%84%E7%BD%97%E6%96%AF%E7%A9%BA%E8%A2%AD%E9%80%A0%E6%88%90%E8%87%B3%E5%B0%912%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775896217000.webp","sourceId":"rfi"},{"id":1775892635000,"createdDate":"2026-04-11 07:30","name":"法国国际广播电台","title":"历史性绕月之旅落幕：阿耳忒弥斯2号“正中靶心”式降落地球，下一步火星！","content":"路透社休斯敦电稿称，阿耳忒弥斯2号（ArtemisII）太空舱及其四名机组人员在太空度过近10天后，于美东时间周五10日穿过地球大气层，安全降落在太平洋海面，为半个多世纪以来人类首次月球近域之旅画上了圆满句号。NASA计划在2030年左右中国实现登月前完成载人登月。该机构更宏大的目标是建立长期的月球存在，作为最终人类探索火星的踏脚石。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260411-%E5%8E%86%E5%8F%B2%E6%80%A7%E7%BB%95%E6%9C%88%E4%B9%8B%E6%97%85%E8%90%BD%E5%B9%95-%E9%98%BF%E8%80%B3%E5%BF%92%E5%BC%A5%E6%96%AF2%E5%8F%B7-%E6%AD%A3%E4%B8%AD%E9%9D%B6%E5%BF%83-%E5%BC%8F%E9%99%8D%E8%90%BD%E5%9C%B0%E7%90%83%EF%BC%8C%E4%B8%8B%E4%B8%80%E6%AD%A5%E7%81%AB%E6%98%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775892635000.webp","sourceId":"rfi"},{"id":1775919898000,"createdDate":"2026-04-11 15:04","name":"法国国际广播电台","title":"秘鲁大选热门藤森惠子承诺驱逐非法移民 与华盛顿加强关系","content":"最新民调显示，秘鲁前总统藤森谦也的女儿藤森惠子位居榜首，预计周日投票后，她将与一位喜剧演员和一位“川粉”商人从35位候选人中脱颖而出，前两名将进入第二轮决赛。秘鲁是一个长期深陷政治动荡，且犯罪率飙升的国家。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260411-%E7%A7%98%E9%B2%81%E5%A4%A7%E9%80%89%E7%83%AD%E9%97%A8%E8%97%A4%E6%A3%AE%E6%83%A0%E5%AD%90%E6%89%BF%E8%AF%BA%E9%A9%B1%E9%80%90%E9%9D%9E%E6%B3%95%E7%A7%BB%E6%B0%91-%E4%B8%8E%E5%8D%8E%E7%9B%9B%E9%A1%BF%E5%8A%A0%E5%BC%BA%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775919898000.webp","sourceId":"rfi"},{"id":1775917628000,"createdDate":"2026-04-11 14:27","name":"法国国际广播电台","title":"匈牙利选举：特朗普承诺奥尔班当选将挺匈牙利经济 数百亲俄假账号开始“发功”","content":"匈牙利4月12日将举行立法大选。自2010年执政的亲俄总理奥尔班寻求在此次选举中赢得第五个任期。他已获得其盟友美国总统特朗普的支持，并有数百亲俄虚假账号“发功”为他助选。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260411-%E5%8C%88%E7%89%99%E5%88%A9%E9%80%89%E4%B8%BE-%E7%89%B9%E6%9C%97%E6%99%AE%E6%89%BF%E8%AF%BA%E5%A5%A5%E5%B0%94%E7%8F%AD%E5%BD%93%E9%80%89%E5%B0%86%E6%8C%BA%E5%8C%88%E7%89%99%E5%88%A9%E7%BB%8F%E6%B5%8E-%E6%95%B0%E7%99%BE%E4%BA%B2%E4%BF%84%E5%81%87%E8%B4%A6%E5%8F%B7%E5%BC%80%E5%A7%8B-%E5%8F%91%E5%8A%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775917628000.webp","sourceId":"rfi"},{"id":1775915880000,"createdDate":"2026-04-11 13:58","name":"法国国际广播电台","title":"中国援建柬埔寨大运河 湄公河直通泰国湾 避开越南","content":"中国在柬埔寨资助修建大型运河，连接湄公河与泰国湾，避开越南出海口。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260411-%E4%B8%AD%E5%9B%BD%E6%8F%B4%E5%BB%BA%E6%9F%AC%E5%9F%94%E5%AF%A8%E5%A4%A7%E8%BF%90%E6%B2%B3-%E6%B9%84%E5%85%AC%E6%B2%B3%E7%9B%B4%E9%80%9A%E6%B3%B0%E5%9B%BD%E6%B9%BE-%E9%81%BF%E5%BC%80%E8%B6%8A%E5%8D%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775915880000.webp","sourceId":"rfi"},{"id":1775910006000,"createdDate":"2026-04-11 12:20","name":"法国国际广播电台","title":"英国宣布因美国不“支持”暂停向毛里求斯移交查戈斯群岛计划","content":"英国首相府唐宁街周六表示，由于未获得美国总统的“支持”，将暂停向毛里求斯移交印度洋上的查戈斯群岛计划。该群岛的主岛迪戈-加西亚岛上有美英联合军事基地。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260411-%E8%8B%B1%E5%9B%BD%E5%AE%A3%E5%B8%83%E5%9B%A0%E7%BE%8E%E5%9B%BD%E4%B8%8D-%E6%94%AF%E6%8C%81-%E6%9A%82%E5%81%9C%E5%90%91%E6%AF%9B%E9%87%8C%E6%B1%82%E6%96%AF%E7%A7%BB%E4%BA%A4%E6%9F%A5%E6%88%88%E6%96%AF%E7%BE%A4%E5%B2%9B%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775910006000.webp","sourceId":"rfi"},{"id":1775909457000,"createdDate":"2026-04-11 12:10","name":"法国国际广播电台","title":"阿耳忒弥斯2号后谁将率先重返月球，中国、美国、印度、欧洲？","content":"4月11日星期六，法国各大传媒除了实时报道万众瞩目的美伊两国代表团在伊斯兰堡举行旨在结束中东战争的谈判外，为您选播两篇与中国有关的报道，首先是《解放报》提问道：阿耳忒弥斯2号（ArtemisII）成功返航后，谁将率先重返月球，中国、美国、印度还是欧洲？再来是《费加罗报》对于在台海局势高度复杂的背景下，台湾最大反对党国民党主席郑丽文访问北京，并与中国国家主席习近平进行了会谈的观察。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260411-%E9%98%BF%E8%80%B3%E5%BF%92%E5%BC%A5%E6%96%AF2%E5%8F%B7%E5%90%8E%E8%B0%81%E5%B0%86%E7%8E%87%E5%85%88%E9%87%8D%E8%BF%94%E6%9C%88%E7%90%83%EF%BC%8C%E4%B8%AD%E5%9B%BD-%E7%BE%8E%E5%9B%BD-%E5%8D%B0%E5%BA%A6-%E6%AC%A7%E6%B4%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775909457000.webp","sourceId":"rfi"},{"id":1775908988000,"createdDate":"2026-04-11 12:03","name":"法国国际广播电台","title":"美国和伊朗在巴基斯坦展开“孤注一掷”的谈判","content":"美国和伊朗今天周六开始在巴基斯坦展开“孤注一掷”的谈判，旨在结束已持续六周的冲突。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260411-%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%BC%8A%E6%9C%97%E5%9C%A8%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%B1%95%E5%BC%80-%E5%AD%A4%E6%B3%A8%E4%B8%80%E6%8E%B7-%E7%9A%84%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775908988000.webp","sourceId":"rfi"},{"id":1775908305000,"createdDate":"2026-04-11 11:51","name":"法国国际广播电台","title":"旅法艺术家张漠予：“真的拯救我的不是艺术，而是对生活本身的热爱”","content":"在上一次节目中，我们带您一起逛了逛旅法艺术家张漠予（ZhangMoyu）的画展“沿着阴影的边缘”。张漠予说每个人在某种程度上都是自己童年的受害者。她说她想表达的是一种被忽视的处境，以及我们往往不会去谈论这些伤害、这些暴力，但它们实际上是真实存在的。随后，她谈到了在法国的生活就像一场修行。法语和法国文化又如何帮助她重新理解自己，帮她厘清了关于我是谁以及我从哪里来这些非常本质的问题。最后，她还讲述了自己放弃医学转向艺术的选择和经历。她认为自己做出的所有选择都是一种对真实的追求，是对自我的探索，也是对自由的一种向往。本期节目，我们将继续和张漠予展开一场深度对话，去观察和理解这位艺术家的所思所想。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%AD%E5%8D%8E%E4%B8%96%E7%95%8C/20260411-%E6%97%85%E6%B3%95%E8%89%BA%E6%9C%AF%E5%AE%B6%E5%BC%A0%E6%BC%A0%E4%BA%88-%E7%9C%9F%E7%9A%84%E6%8B%AF%E6%95%91%E6%88%91%E7%9A%84%E4%B8%8D%E6%98%AF%E8%89%BA%E6%9C%AF%EF%BC%8C%E8%80%8C%E6%98%AF%E5%AF%B9%E7%94%9F%E6%B4%BB%E6%9C%AC%E8%BA%AB%E7%9A%84%E7%83%AD%E7%88%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775908305000.webp","sourceId":"rfi"},{"id":1775907456000,"createdDate":"2026-04-11 11:37","name":"法国国际广播电台","title":"美伊在巴基斯坦开启停火谈判  伊朗消息人士透露美国已同意解冻伊朗资产，但遭否认","content":"美国副总统JD·万斯周六（4月11日）抵达巴基斯坦。目前，中东冲突已持续六周，美国与伊朗将在相互不信任的氛围中举行谈判，试图结束中东战争。本次谈判将检验双方能否巩固目前脆弱的停火协议，并为可能到来的和平铺平道路。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260411-%E7%BE%8E%E4%BC%8A%E5%9C%A8%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%BC%80%E5%90%AF%E5%81%9C%E7%81%AB%E8%B0%88%E5%88%A4-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB%E9%80%8F%E9%9C%B2%EF%BC%8C%E7%BE%8E%E5%9B%BD%E5%B7%B2%E5%90%8C%E6%84%8F%E8%A7%A3%E5%86%BB%E4%BC%8A%E6%9C%97%E8%B5%84%E4%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775907456000.webp","sourceId":"rfi"},{"id":1775906418000,"createdDate":"2026-04-11 11:20","name":"法国国际广播电台","title":"解放报评析“和平之旅”：郑丽文上京，习近平满意","content":"在“习郑会”举行翌日，《解放报》资深记者ArnaudVaulerin周六11日发表分析文章称，解读一向沉稳寡言的中国国家主席习近平的真实想法，从来都不是一件容易的事。但无需高深洞察，也能判断出：在邀请并于北京会见台湾主要反对党——国民党主席郑丽文之后，他很可能颇为满意。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260411-%E8%A7%A3%E6%94%BE%E6%8A%A5%E6%B4%9E%E5%AF%9F-%E5%92%8C%E5%B9%B3%E4%B9%8B%E6%97%85-%E9%83%91%E4%B8%BD%E6%96%87%E8%B5%B4%E4%BA%AC%EF%BC%8C%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%BB%A1%E6%84%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775906418000.webp","sourceId":"rfi"},{"id":1775948203000,"createdDate":"2026-04-11 22:56","name":"法国国际广播电台","title":"霍尔木兹海峡：阻碍美伊谈判的绊脚石","content":"无论结果如何，美国与伊朗终于在巴基斯坦首都伊斯兰堡展开直接谈判，以终结2月28日美以联合发动的对伊战争，谈判官员的级别是1979年以来伊朗爆发伊斯兰革命美伊断交以来最高级别。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260411-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E9%98%BB%E7%A2%8D%E7%BE%8E%E4%BC%8A%E8%B0%88%E5%88%A4%E7%9A%84%E7%BB%8A%E8%84%9A%E7%9F%B3","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775948203000.webp","sourceId":"rfi"},{"id":1775946828000,"createdDate":"2026-04-11 22:33","name":"法国国际广播电台","title":"内塔尼亚胡：伊朗的核计划和弹道导弹计划已经被粉碎， 同意黎巴嫩提出的和平谈判请求","content":"以色列总理内塔尼亚胡表示，美以联合打击伊朗的行动已成功“粉碎”了伊朗的核计划和弹道导弹计划。他说，这场针对德黑兰的战争也削弱了伊朗的领导层及其地区盟友。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260411-%E5%86%85%E5%A1%94%E5%B0%BC%E4%BA%9A%E8%83%A1-%E4%BC%8A%E6%9C%97%E7%9A%84%E6%A0%B8%E8%AE%A1%E5%88%92%E5%92%8C%E5%BC%B9%E9%81%93%E5%AF%BC%E5%BC%B9%E8%AE%A1%E5%88%92%E5%B7%B2%E7%BB%8F%E8%A2%AB%E7%B2%89%E7%A2%8E%EF%BC%8C-%E5%90%8C%E6%84%8F%E9%BB%8E%E5%B7%B4%E5%AB%A9%E6%8F%90%E5%87%BA%E7%9A%84%E5%92%8C%E5%B9%B3%E8%B0%88%E5%88%A4%E8%AF%B7%E6%B1%82","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775946828000.webp","sourceId":"rfi"},{"id":1775946636000,"createdDate":"2026-04-11 22:30","name":"法国国际广播电台","title":"特朗普: 美国已开始“清理”霍尔木兹海峡，这是在“帮”中国、日本和法国等国家的忙","content":"美国中央司令部周六表示，两艘美国海军军舰已通过霍尔木兹海峡，开始清除伊朗在霍尔木兹海峡部署的水雷。中央司令部司令布拉德·库珀海军上将表示：“今天，我们启动了开辟新航道的进程，并将很快与海运业分享这条安全通道，以促进贸易自由流通”。伊朗军官否认美国军舰穿越霍尔木兹海峡这条关键水道。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260411-%E7%89%B9%E6%9C%97%E6%99%AE-%E7%BE%8E%E5%9B%BD%E5%B7%B2%E5%BC%80%E5%A7%8B-%E6%B8%85%E7%90%86-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%EF%BC%8C%E8%BF%99%E6%98%AF%E5%9C%A8-%E5%B8%AE-%E4%B8%AD%E5%9B%BD-%E6%97%A5%E6%9C%AC%E5%92%8C%E6%B3%95%E5%9B%BD%E7%AD%89%E5%9B%BD%E5%AE%B6%E7%9A%84%E5%BF%99","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775946636000.webp","sourceId":"rfi"},{"id":1775946320000,"createdDate":"2026-04-11 22:25","name":"法国国际广播电台","title":"美国和伊朗官员在巴基斯坦举行面对面会谈，巴基斯坦与参与斡旋的中国、埃及、土耳其保持密切协调","content":"周六，美伊官员在巴基斯坦举行面对面会谈，会谈持续到深夜。一位熟悉此事的外交消息人士告诉法新社，东道国巴基斯坦已组建一个专家组，协助双方就航行、核问题和其他关键事项谈判。埃及、土耳其和中国都曾参与斡旋，巴基斯坦仍在与这些国家保持密切协调。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260411-%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%BC%8A%E6%9C%97%E5%AE%98%E5%91%98%E5%9C%A8%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E4%B8%BE%E8%A1%8C%E9%9D%A2%E5%AF%B9%E9%9D%A2%E4%BC%9A%E8%B0%88%EF%BC%8C%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E4%B8%8E%E5%8F%82%E4%B8%8E%E6%96%A1%E6%97%8B%E7%9A%84%E4%B8%AD%E5%9B%BD-%E5%9F%83%E5%8F%8A-%E5%9C%9F%E8%80%B3%E5%85%B6%E4%BF%9D%E6%8C%81%E5%AF%86%E5%88%87%E5%8D%8F%E8%B0%83","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775946320000.webp","sourceId":"rfi"},{"id":1775945056000,"createdDate":"2026-04-11 22:04","name":"法国国际广播电台","title":"美媒报道中国准备向伊朗提供便携式防空导弹系统","content":"美国有线新闻电视网CNN独家报道援引消息人士称，美国情报显示，中国正准备向伊朗运送武器。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260411-%E7%BE%8E%E5%AA%92%E6%8A%A5%E9%81%93%E4%B8%AD%E5%9B%BD%E5%87%86%E5%A4%87%E5%90%91%E4%BC%8A%E6%9C%97%E6%8F%90%E4%BE%9B%E4%BE%BF%E6%90%BA%E5%BC%8F%E9%98%B2%E7%A9%BA%E5%AF%BC%E5%BC%B9%E7%B3%BB%E7%BB%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775945056000.webp","sourceId":"rfi"},{"id":1775944254000,"createdDate":"2026-04-11 21:50","name":"法国国际广播电台","title":"非洲:贝宁2026总统大选投票前夜","content":"西非国家贝宁2026年总统选举即将于2026年04月12日星期天举行投票。在此之前的最后竞选时刻，本台法广非洲组（RFIAfrique）在现场开展实地报道的不仅有科托努（Cotonou）的法语通讯员（Correspondant）。另外，还派出了一位特派女记者（EnvoyéeSpéciale）。04月11日周六下午的最新消息说，贝宁全国自治选举委员会（CENA-Commissionélectoralenationaleautonome）正在努力避免三个月前2026年01月11日该国市政与立法选举中出现的错漏。贝宁全国的选民人数近800万（确切地说是7,897,287人）。依照贝宁宪法，现总统帕特里斯·塔隆（PrésidentbéninoisPatriceTalon）已经连续执政两届共10年，他不寻求继续连任。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20260411-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E8%B4%9D%E5%AE%812026%E6%80%BB%E7%BB%9F%E5%A4%A7%E9%80%89%E6%8A%95%E7%A5%A8%E5%89%8D%E5%A4%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775944254000.webp","sourceId":"rfi"},{"id":1775944057000,"createdDate":"2026-04-11 21:47","name":"法国国际广播电台","title":"新民调：多数欧洲人认为美国比中国构成更大威胁","content":"据《柏林日报》报道：欧洲政治杂志Politico发布的一项新调查显示：美国总统特朗普（DonaldTrump）的政策正在欧洲引发对华盛顿的历史性不信任。在多个欧盟大国中，美国如今被视为对欧洲的威胁已超过中国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260411-%E6%96%B0%E6%B0%91%E8%B0%83-%E5%A4%9A%E6%95%B0%E6%AC%A7%E6%B4%B2%E4%BA%BA%E8%AE%A4%E4%B8%BA%E7%BE%8E%E5%9B%BD%E6%AF%94%E4%B8%AD%E5%9B%BD%E6%9E%84%E6%88%90%E6%9B%B4%E5%A4%A7%E5%A8%81%E8%83%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775944057000.webp","sourceId":"rfi"},{"id":1775943675000,"createdDate":"2026-04-11 21:41","name":"法国国际广播电台","title":"梅兰妮亚突发声切割爱泼斯坦　白宫再陷舆论风暴","content":"在中东战事持续升温、美国期中选举逼近之际，白宫原本已逐渐摆脱围绕已故性犯罪者杰佛瑞·爱泼斯坦（JeffreyEpstein）的政治阴影。然而，美国第一夫人梅兰妮亚·特朗普（MelaniaTrump）10日一场突如其来的公开声明，却再度将此案推回政治风暴中心，也让特朗普政府面临新的舆论压力。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260411-%E6%A2%85%E5%85%B0%E5%A6%AE%E4%BA%9A%E7%AA%81%E5%8F%91%E5%A3%B0%E5%88%87%E5%89%B2%E7%88%B1%E6%B3%BC%E6%96%AF%E5%9D%A6-%E7%99%BD%E5%AE%AB%E5%86%8D%E9%99%B7%E8%88%86%E8%AE%BA%E9%A3%8E%E6%9A%B4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775943675000.webp","sourceId":"rfi"},{"id":1775932723000,"createdDate":"2026-04-11 18:38","name":"法国国际广播电台","title":"华盛顿称开始在霍尔木兹海峡扫雷","content":"美国军方周六表示，两艘美国驱逐舰已于周六穿越霍尔木兹海峡，旨在为清除这条由伊朗控制的战略水道上布设的水雷“创造条件”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260411-%E5%8D%8E%E7%9B%9B%E9%A1%BF%E7%A7%B0%E5%BC%80%E5%A7%8B%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E6%89%AB%E9%9B%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775932723000.webp","sourceId":"rfi"},{"id":1775929932000,"createdDate":"2026-04-11 17:52","name":"法国国际广播电台","title":"特朗普干预伊朗和委内瑞拉打乱了中国利润丰厚的进口受制裁石油的计划","content":"美媒JustTheNews4月6日刊文指出，中国多年来利用美国对俄罗斯、委内瑞拉和伊朗等产油国实施的制裁，以大幅折扣价为自身经济发展提供动力并补充战略储备。但特朗普干预委内瑞拉和伊朗，可能会终结习近平的意外之财。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260411-%E7%89%B9%E6%9C%97%E6%99%AE%E5%B9%B2%E9%A2%84%E4%BC%8A%E6%9C%97%E5%92%8C%E5%A7%94%E5%86%85%E7%91%9E%E6%8B%89%E6%89%93%E4%B9%B1%E4%BA%86%E4%B8%AD%E5%9B%BD%E5%88%A9%E6%B6%A6%E4%B8%B0%E5%8E%9A%E7%9A%84%E8%BF%9B%E5%8F%A3%E5%8F%97%E5%88%B6%E8%A3%81%E7%9F%B3%E6%B2%B9%E7%9A%84%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775929932000.webp","sourceId":"rfi"}]