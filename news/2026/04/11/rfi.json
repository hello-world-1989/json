[{"id":1775896298000,"createdDate":"2026-04-11 08:31","name":"法国国际广播电台","title":"霍尔木兹海峡紧张 日本澳大利亚加紧战略合作","content":"在霍尔木兹海峡遭封锁，原油和物资运输中断的背景下，日本和澳大利亚正加紧推进安保与产业供应链的合作，力图通过中等发达国家等的连携对应大国的独断专行及所造成的世界性的影响等，最近几天连续举行各层级的高官会谈。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260411-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%B4%A7%E5%BC%A0-%E6%97%A5%E6%9C%AC%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E5%8A%A0%E7%B4%A7%E6%88%98%E7%95%A5%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775896298000.webp","sourceId":"rfi"},{"id":1775896217000,"createdDate":"2026-04-11 08:30","name":"法国国际广播电台","title":"俄乌东正教复活节短期停火将于周六下午16时生效，共计32小时直至周日，停火前俄罗斯空袭造成至少2人死亡","content":"法新社消息称，俄罗斯总统普京周四（4月11日）宣布的且乌方也表示同意的东正教复活节短期停火将于周六（4月11日）下午16时开始生效，并持续至周日结束，共计32小时。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260411-%E4%BF%84%E4%B9%8C%E4%B8%9C%E6%AD%A3%E6%95%99%E5%A4%8D%E6%B4%BB%E8%8A%82%E7%9F%AD%E6%9C%9F%E5%81%9C%E7%81%AB%E5%B0%86%E4%BA%8E%E5%91%A8%E5%85%AD%E4%B8%8B%E5%8D%8816%E6%97%B6%E7%94%9F%E6%95%88%EF%BC%8C%E5%85%B1%E8%AE%A132%E5%B0%8F%E6%97%B6%E7%9B%B4%E8%87%B3%E5%91%A8%E6%97%A5%EF%BC%8C%E5%81%9C%E7%81%AB%E5%89%8D%E4%BF%84%E7%BD%97%E6%96%AF%E7%A9%BA%E8%A2%AD%E9%80%A0%E6%88%90%E8%87%B3%E5%B0%912%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775896217000.webp","sourceId":"rfi"},{"id":1775892635000,"createdDate":"2026-04-11 07:30","name":"法国国际广播电台","title":"历史性绕月之旅落幕：阿耳忒弥斯2号“正中靶心”式降落地球，下一步火星！","content":"路透社休斯敦电稿称，阿耳忒弥斯2号（ArtemisII）太空舱及其四名机组人员在太空度过近10天后，于美东时间周五10日穿过地球大气层，安全降落在太平洋海面，为半个多世纪以来人类首次月球近域之旅画上了圆满句号。NASA计划在2030年左右中国实现登月前完成载人登月。该机构更宏大的目标是建立长期的月球存在，作为最终人类探索火星的踏脚石。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260411-%E5%8E%86%E5%8F%B2%E6%80%A7%E7%BB%95%E6%9C%88%E4%B9%8B%E6%97%85%E8%90%BD%E5%B9%95-%E9%98%BF%E8%80%B3%E5%BF%92%E5%BC%A5%E6%96%AF2%E5%8F%B7-%E6%AD%A3%E4%B8%AD%E9%9D%B6%E5%BF%83-%E5%BC%8F%E9%99%8D%E8%90%BD%E5%9C%B0%E7%90%83%EF%BC%8C%E4%B8%8B%E4%B8%80%