[{"id":1775896298000,"createdDate":"2026-04-11 08:31","name":"法国国际广播电台","title":"霍尔木兹海峡紧张 日本澳大利亚加紧战略合作","content":"在霍尔木兹海峡遭封锁，原油和物资运输中断的背景下，日本和澳大利亚正加紧推进安保与产业供应链的合作，力图通过中等发达国家等的连携对应大国的独断专行及所造成的世界性的影响等，最近几天连续举行各层级的高官会谈。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260411-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E7%B4%A7%E5%BC%A0-%E6%97%A5%E6%9C%AC%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E5%8A%A0%E7%B4%A7%E6%88%98%E7%95%A5%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775896298000.webp","sourceId":"rfi"},{"id":1775896217000,"createdDate":"2026-04-11 08:30","name":"法国国际广播电台","title":"俄乌东正教复活节短期停火将于周六下午16时生效，共计32小时直至周日，停火前俄罗斯空袭造成至少2人死亡","content":"法新社消息称，俄罗斯总统普京周四（4月11日）宣布的且乌方也表示同意的东正教复活节短期停火将于周六（4月11日）下午16时开始生效，并持续至周日结束，共计32小时。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260411-%E4%BF%84%E4%B9%8C%E4%B8%9C%E6%AD%A3%E6%95%99%E5%A4%8D%E6%B4%BB%E8%8A%82%E7%9F%AD%E6%9C%9F%E5%81%9C%E7%81%AB%E5%B0%86%E4%BA%8E%E5%91%A8%E5%85%AD%E4%B8%8B%E5%8D%8816%E6%97%B6%E7%94%9F%E6%95%88%EF%BC%8C%E5%85%B1%E8%AE%A132%E5%B0%8F%E6%97%B6%E7%9B%B4%E8%87%B3%E5%91%A8%E6%97%A5%EF%BC%8C%E5%81%9C%E7%81%AB%E5%89%8D%E4%BF%84%E7%BD%97%E6%96%AF%E7%A9%BA%E8%A2%AD%E9%80%A0%E6%88%90%E8%87%B3%E5%B0%912%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775896217000.webp","sourceId":"rfi"},{"id":1775892635000,"createdDate":"2026-04-11 07:30","name":"法国国际广播电台","title":"历史性绕月之旅落幕：阿耳忒弥斯2号“正中靶心”式降落地球，下一步火星！","content":"路透社休斯敦电稿称，阿耳忒弥斯2号（ArtemisII）太空舱及其四名机组人员在太空度过近10天后，于美东时间周五10日穿过地球大气层，安全降落在太平洋海面，为半个多世纪以来人类首次月球近域之旅画上了圆满句号。NASA计划在2030年左右中国实现登月前完成载人登月。该机构更宏大的目标是建立长期的月球存在，作为最终人类探索火星的踏脚石。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260411-%E5%8E%86%E5%8F%B2%E6%80%A7%E7%BB%95%E6%9C%88%E4%B9%8B%E6%97%85%E8%90%BD%E5%B9%95-%E9%98%BF%E8%80%B3%E5%BF%92%E5%BC%A5%E6%96%AF2%E5%8F%B7-%E6%AD%A3%E4%B8%AD%E9%9D%B6%E5%BF%83-%E5%BC%8F%E9%99%8D%E8%90%BD%E5%9C%B0%E7%90%83%EF%BC%8C%E4%B8%8B%E4%B8%80%E6%AD%A5%E7%81%AB%E6%98%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775892635000.webp","sourceId":"rfi"},{"id":1775919898000,"createdDate":"2026-04-11 15:04","name":"法国国际广播电台","title":"秘鲁大选热门藤森惠子承诺驱逐非法移民 与华盛顿加强关系","content":"最新民调显示，秘鲁前总统藤森谦也的女儿藤森惠子位居榜首，预计周日投票后，她将与一位喜剧演员和一位“川粉”商人从35位候选人中脱颖而出，前两名将进入第二轮决赛。秘鲁是一个长期深陷政治动荡，且犯罪率飙升的国家。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260411-%E7%A7%98%E9%B2%81%E5%A4%A7%E9%80%89%E7%83%AD%E9%97%A8%E8%97%A4%E6%A3%AE%E6%83%A0%E5%AD%90%E6%89%BF%E8%AF%BA%E9%A9%B1%E9%80%90%E9%9D%9E%E6%B3%95%E7%A7%BB%E6%B0%91-%E4%B8%8E%E5%8D%8E%E7%9B%9B%E9%A1%BF%E5%8A%A0%E5%BC%BA%E5%85%B3%E7%B3%BB","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775919898000.webp","sourceId":"rfi"},{"id":1775917628000,"createdDate":"2026-04-11 14:27","name":"法国国际广播电台","title":"匈牙利选举：特朗普承诺奥尔班当选将挺匈牙利经济 数百亲俄假账号开始“发功”","content":"匈牙利4月12日将举行立法大选。自2010年执政的亲俄总理奥尔班寻求在此次选举中赢得第五个任期。他已获得其盟友美国总统特朗普的支持，并有数百亲俄虚假账号“发功”为他助选。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260411-%E5%8C%88%E7%89%99%E5%88%A9%E9%80%89%E4%B8%BE-%E7%89%B9%E6%9C%97%E6%99%AE%E6%89%BF%E8%AF%BA%E5%A5%A5%E5%B0%94%E7%8F%AD%E5%BD%93%E9%80%89%E5%B0%86%E6%8C%BA%E5%8C%88%E7%89%99%E5%88%A9%E7%BB%8F%E6%B5%8E-%E6%95%B0%E7%99%BE%E4%BA%B2%E4%BF%84%E5%81%87%E8%B4%A6%E5%8F%B7%E5%BC%80%E5%A7%8B-%E5%8F%91%E5%8A%9F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775917628000.webp","sourceId":"rfi"},{"id":1775915880000,"createdDate":"2026-04-11 13:58","name":"法国国际广播电台","title":"中国援建柬埔寨大运河 湄公河直通泰国湾 避开越南","content":"中国在柬埔寨资助修建大型运河，连接湄公河与泰国湾，避开越南出海口。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260411-%E4%B8%AD%E5%9B%BD%E6%8F%B4%E5%BB%BA%E6%9F%AC%E5%9F%94%E5%AF%A8%E5%A4%A7%E8%BF%90%E6%B2%B3-%E6%B9%84%E5%85%AC%E6%B2%B3%E7%9B%B4%E9%80%9A%E6%B3%B0%E5%9B%BD%E6%B9%BE-%E9%81%BF%E5%BC%80%E8%B6%8A%E5%8D%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775915880000.webp","sourceId":"rfi"},{"id":1775910006000,"createdDate":"2026-04-11 12:20","name":"法国国际广播电台","title":"英国宣布因美国不“支持”暂停向毛里求斯移交查戈斯群岛计划","content":"英国首相府唐宁街周六表示，由于未获得美国总统的“支持”，将暂停向毛里求斯移交印度洋上的查戈斯群岛计划。该群岛的主岛迪戈-加西亚岛上有美英联合军事基地。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260411-%E8%8B%B1%E5%9B%BD%E5%AE%A3%E5%B8%83%E5%9B%A0%E7%BE%8E%E5%9B%BD%E4%B8%8D-%E6%94%AF%E6%8C%81-%E6%9A%82%E5%81%9C%E5%90%91%E6%AF%9B%E9%87%8C%E6%B1%82%E6%96%AF%E7%A7%BB%E4%BA%A4%E6%9F%A5%E6%88%88%E6%96%AF%E7%BE%A4%E5%B2%9B%E8%AE%A1%E5%88%92","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775910006000.webp","sourceId":"rfi"},{"id":1775909457000,"createdDate":"2026-04-11 12:10","name":"法国国际广播电台","title":"阿耳忒弥斯2号后谁将率先重返月球，中国、美国、印度、欧洲？","content":"4月11日星期六，法国各大传媒除了实时报道万众瞩目的美伊两国代表团在伊斯兰堡举行旨在结束中东战争的谈判外，为您选播两篇与中国有关的报道，首先是《解放报》提问道：阿耳忒弥斯2号（ArtemisII）成功返航后，谁将率先重返月球，中国、美国、印度还是欧洲？再来是《费加罗报》对于在台海局势高度复杂的背景下，台湾最大反对党国民党主席郑丽文访问北京，并与中国国家主席习近平进行了会谈的观察。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260411-%E9%98%BF%E8%80%B3%E5%BF%92%E5%BC%A5%E6%96%AF2%E5%8F%B7%E5%90%8E%E8%B0%81%E5%B0%86%E7%8E%87%E5%85%88%E9%87%8D%E8%BF%94%E6%9C%88%E7%90%83%EF%BC%8C%E4%B8%AD%E5%9B%BD-%E7%BE%8E%E5%9B%BD-%E5%8D%B0%E5%BA%A6-%E6%AC%A7%E6%B4%B2","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775909457000.webp","sourceId":"rfi"},{"id":1775908988000,"createdDate":"2026-04-11 12:03","name":"法国国际广播电台","title":"美国和伊朗在巴基斯坦展开“孤注一掷”的谈判","content":"美国和伊朗今天周六开始在巴基斯坦展开“孤注一掷”的谈判，旨在结束已持续六周的冲突。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260411-%E7%BE%8E%E5%9B%BD%E5%92%8C%E4%BC%8A%E6%9C%97%E5%9C%A8%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%B1%95%E5%BC%80-%E5%AD%A4%E6%B3%A8%E4%B8%80%E6%8E%B7-%E7%9A%84%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775908988000.webp","sourceId":"rfi"},{"id":1775908305000,"createdDate":"2026-04-11 11:51","name":"法国国际广播电台","title":"旅法艺术家张漠予：“真的拯救我的不是艺术，而是对生活本身的热爱”","content":"在上一次节目中，我们带您一起逛了逛旅法艺术家张漠予（ZhangMoyu）的画展“沿着阴影的边缘”。张漠予说每个人在某种程度上都是自己童年的受害者。她说她想表达的是一种被忽视的处境，以及我们往往不会去谈论这些伤害、这些暴力，但它们实际上是真实存在的。随后，她谈到了在法国的生活就像一场修行。法语和法国文化又如何帮助她重新理解自己，帮她厘清了关于我是谁以及我从哪里来这些非常本质的问题。最后，她还讲述了自己放弃医学转向艺术的选择和经历。她认为自己做出的所有选择都是一种对真实的追求，是对自我的探索，也是对自由的一种向往。本期节目，我们将继续和张漠予展开一场深度对话，去观察和理解这位艺术家的所思所想。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%AD%E5%8D%8E%E4%B8%96%E7%95%8C/20260411-%E6%97%85%E6%B3%95%E8%89%BA%E6%9C%AF%E5%AE%B6%E5%BC%A0%E6%BC%A0%E4%BA%88-%E7%9C%9F%E7%9A%84%E6%8B%AF%E6%95%91%E6%88%91%E7%9A%84%E4%B8%8D%E6%98%AF%E8%89%BA%E6%9C%AF%EF%BC%8C%E8%80%8C%E6%98%AF%E5%AF%B9%E7%94%9F%E6%B4%BB%E6%9C%AC%E8%BA%AB%E7%9A%84%E7%83%AD%E7%88%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775908305000.webp","sourceId":"rfi"},{"id":1775907456000,"createdDate":"2026-04-11 11:37","name":"法国国际广播电台","title":"美伊在巴基斯坦开启停火谈判  伊朗消息人士透露美国已同意解冻伊朗资产，但遭否认","content":"美国副总统JD·万斯周六（4月11日）抵达巴基斯坦。目前，中东冲突已持续六周，美国与伊朗将在相互不信任的氛围中举行谈判，试图结束中东战争。本次谈判将检验双方能否巩固目前脆弱的停火协议，并为可能到来的和平铺平道路。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260411-%E7%BE%8E%E4%BC%8A%E5%9C%A8%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E5%BC%80%E5%90%AF%E5%81%9C%E7%81%AB%E8%B0%88%E5%88%A4-%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB%E9%80%8F%E9%9C%B2%EF%BC%8C%E7%BE%8E%E5%9B%BD%E5%B7%B2%E5%90%8C%E6%84%8F%E8%A7%A3%E5%86%BB%E4%BC%8A%E6%9C%97%E8%B5%84%E4%BA%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775907456000.webp","sourceId":"rfi"},{"id":1775906418000,"createdDate":"2026-04-11 11:20","name":"法国国际广播电台","title":"解放报评析“和平之旅”：郑丽文上京，习近平满意","content":"在“习郑会”举行翌日，《解放报》资深记者ArnaudVaulerin周六11日发表分析文章称，解读一向沉稳寡言的中国国家主席习近平的真实想法，从来都不是一件容易的事。但无需高深洞察，也能判断出：在邀请并于北京会见台湾主要反对党——国民党主席郑丽文之后，他很可能颇为满意。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260411-%E8%A7%A3%E6%94%BE%E6%8A%A5%E6%B4%9E%E5%AF%9F-%E5%92%8C%E5%B9%B3%E4%B9%8B%E6%97%85-%E9%83%91%E4%B8%BD%E6%96%87%E8%B5%B4%E4%BA%AC%EF%BC%8C%E4%B9%A0%E8%BF%91%E5%B9%B3%E6%BB%A1%E6%84%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/11/1775906418000.webp","sourceId":"rfi"}]