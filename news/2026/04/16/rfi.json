[{"id":1776329726000,"createdDate":"2026-04-16 08:55","name":"法国国际广播电台","title":"出于对国际局势和中国海军实力增强的担忧，澳大利亚大幅提高国防开支，计划增至GDP的3%","content":"在全球冲突不断增多、以及美国持续施压盟友增加军费的背景下，澳大利亚宣布将把国防开支提升至国内生产总值（GDP）的3%，目标是在2033年实现，此前这一比例约为2%。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260416-%E5%87%BA%E4%BA%8E%E5%AF%B9%E5%9B%BD%E9%99%85%E5%B1%80%E5%8A%BF%E5%92%8C%E4%B8%AD%E5%9B%BD%E6%B5%B7%E5%86%9B%E5%AE%9E%E5%8A%9B%E5%A2%9E%E5%BC%BA%E7%9A%84%E6%8B%85%E5%BF%A7%EF%BC%8C%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E5%A4%A7%E5%B9%85%E6%8F%90%E9%AB%98%E5%9B%BD%E9%98%B2%E5%BC%80%E6%94%AF%EF%BC%8C%E8%AE%A1%E5%88%92%E5%A2%9E%E8%87%B3gdp%E7%9A%843","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776329726000.webp","sourceId":"rfi"},{"id":1776329113000,"createdDate":"2026-04-16 08:45","name":"法国国际广播电台","title":"暑期出行旺季即将到来，但若战争持续，欧洲最早从6月起就可能出现航空燃油短缺","content":"路透社星期四（4月16日）的消息称，多名欧洲官员表示，随着霍尔木兹海峡运输受阻导致供应紧张不断加剧，欧盟正努力寻找解决方案，以应对即将出现的航空燃油短缺，并尽可能提高炼油厂的产量。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260416-%E6%9A%91%E6%9C%9F%E5%87%BA%E8%A1%8C%E6%97%BA%E5%AD%A3%E5%8D%B3%E5%B0%86%E5%88%B0%E6%9D%A5%EF%BC%8C%E4%BD%86%E8%8B%A5%E6%88%98%E4%BA%89%E6%8C%81%E7%BB%AD%EF%BC%8C%E6%AC%A7%E6%B4%B2%E6%9C%80%E6%97%A9%E4%BB%8E6%E6%9C%88%E8%B5%B7%E5%B0%B1%E5%8F%AF%E8%83%BD%E5%87%BA%E7%8E%B0%E8%88%AA%E7%A9%BA%E7%87%83%E6%B2%B9%E7%9F%AD%E7%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776329113000.webp","sourceId":"rfi"},{"id":1776328023000,"createdDate":"2026-04-16 08:27","name":"法国国际广播电台","title":"美国正在讨论是否与伊朗举行第二轮谈判，伊朗也重申了谈判意愿","content":"法新社消息称，美国星期三（4月16日）宣布，正在讨论与德黑兰举行第二轮谈判的可能性，并表示对达成协议“持乐观态度”。此前，伊朗曾威胁称，如果美国封锁伊朗的港口，将阻断红海航运。伊朗方面也重申了谈判意愿。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260416-%E7%BE%8E%E5%9B%BD%E6%AD%A3%E5%9C%A8%E8%AE%A8%E8%AE%BA%E6%98%AF%E5%90%A6%E4%B8%8E%E4%BC%8A%E6%9C%97%E4%B8%BE%E8%A1%8C%E7%AC%AC%E4%BA%8C%E8%BD%AE%E8%B0%88%E5%88%A4%EF%BC%8C%E4%BC%8A%E6%9C%97%E4%B9%9F%E9%87%8D%E7%94%B3%E4%BA%86%E8%B0%88%E5%88%A4%E6%84%8F%E6%84%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776328023000.webp","sourceId":"rfi"},{"id":1776326486000,"createdDate":"2026-04-16 08:01","name":"法国国际广播电台","title":"哈梅内伊军事顾问、革命卫队内部强硬派代表雷扎伊：若美国在霍尔木兹海峡“执法”，将击沉美方船只","content":"已故的伊朗最高领袖之子穆杰塔巴·哈梅内伊的军事顾问星期三（4月16日）威胁称，如果美国试图在霍尔木兹海峡“执法”，伊朗将击沉美方船只。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260416-%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E5%86%9B%E4%BA%8B%E9%A1%BE%E9%97%AE-%E9%9D%A9%E5%91%BD%E5%8D%AB%E9%98%9F%E5%86%85%E9%83%A8%E5%BC%BA%E7%A1%AC%E6%B4%BE%E4%BB%A3%E8%A1%A8%E9%9B%B7%E6%89%8E%E4%BC%8A-%E8%8B%A5%E7%BE%8E%E5%9B%BD%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E6%89%A7%E6%B3%95-%EF%BC%8C%E5%B0%86%E5%87%BB%E6%B2%89%E7%BE%8E%E6%96%B9%E8%88%B9%E5%8F%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776326486000.webp","sourceId":"rfi"},{"id":1776322962000,"createdDate":"2026-04-16 07:02","name":"法国国际广播电台","title":"澳门财爷上任16个月突以「个人原因」离职 属港澳政府季内第二名离职主要官员","content":"澳门经济财政司司长戴建业上任不足一年半，便以「个人原因」请辞，中国政府今(16日)早公布，免去其职务，但未有接任人选，其工作将由行政长官岑浩辉兼掌，而澳门政府则着手跟进接任人手的提名工作。这是中国两个特别行政区三个月内第二宗问责局长突然辞职事件，在此之前，香港特区的时任政制及内地事务局局长曾国卫於1月下旬获北京的中央政府接纳他以「健康理由」请辞，继任人选在两个月後才公布。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260416-%E6%BE%B3%E9%97%A8%E8%B4%A2%E7%88%B7%E4%B8%8A%E4%BB%BB16%E4%B8%AA%E6%9C%88%E7%AA%81%E4%BB%A5-%E4%B8%AA%E4%BA%BA%E5%8E%9F%E5%9B%A0-%E7%A6%BB%E8%81%8C-%E5%B1%9E%E6%B8%AF%E6%BE%B3%E6%94%BF%E5%BA%9C%E5%AD%A3%E5%86%85%E7%AC%AC%E4%BA%8C%E5%90%8D%E7%A6%BB%E8%81%8C%E4%B8%BB%E8%A6%81%E5%AE%98%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776322962000.webp","sourceId":"rfi"},{"id":1776322342000,"createdDate":"2026-04-16 06:52","name":"法国国际广播电台","title":"中国首季经济增长5% 高於预期 官认伊朗战事有影响但料可控","content":"尽管全球经济均受到美伊战事影响，但中国首季国内生产总值(GDP)录得5%的增长，较上季加快0.5个百分点，亦高於市场预期的4.8%增幅。不过，同期作为拉动经济的「三头马车」，其增幅均逊於预期，而国家统计局副局长毛盛勇亦表示，中东局势肯定会影响中国的出口和经济，但总的来说，影响将是有限和可控的。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260416-%E4%B8%AD%E5%9B%BD%E9%A6%96%E5%AD%A3%E7%BB%8F%E6%B5%8E%E5%A2%9E%E9%95%BF5-%E9%AB%98%E6%96%BC%E9%A2%84%E6%9C%9F-%E5%AE%98%E8%AE%A4%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%8B%E6%9C%89%E5%BD%B1%E5%93%8D%E4%BD%86%E6%96%99%E5%8F%AF%E6%8E%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776322342000.webp","sourceId":"rfi"}]