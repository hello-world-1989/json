[{"id":1776329726000,"createdDate":"2026-04-16 08:55","name":"法国国际广播电台","title":"出于对国际局势和中国海军实力增强的担忧，澳大利亚大幅提高国防开支，计划增至GDP的3%","content":"在全球冲突不断增多、以及美国持续施压盟友增加军费的背景下，澳大利亚宣布将把国防开支提升至国内生产总值（GDP）的3%，目标是在2033年实现，此前这一比例约为2%。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260416-%E5%87%BA%E4%BA%8E%E5%AF%B9%E5%9B%BD%E9%99%85%E5%B1%80%E5%8A%BF%E5%92%8C%E4%B8%AD%E5%9B%BD%E6%B5%B7%E5%86%9B%E5%AE%9E%E5%8A%9B%E5%A2%9E%E5%BC%BA%E7%9A%84%E6%8B%85%E5%BF%A7%EF%BC%8C%E6%BE%B3%E5%A4%A7%E5%88%A9%E4%BA%9A%E5%A4%A7%E5%B9%85%E6%8F%90%E9%AB%98%E5%9B%BD%E9%98%B2%E5%BC%80%E6%94%AF%EF%BC%8C%E8%AE%A1%E5%88%92%E5%A2%9E%E8%87%B3gdp%E7%9A%843","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776329726000.webp","sourceId":"rfi"},{"id":1776329113000,"createdDate":"2026-04-16 08:45","name":"法国国际广播电台","title":"暑期出行旺季即将到来，但若战争持续，欧洲最早从6月起就可能出现航空燃油短缺","content":"路透社星期四（4月16日）的消息称，多名欧洲官员表示，随着霍尔木兹海峡运输受阻导致供应紧张不断加剧，欧盟正努力寻找解决方案，以应对即将出现的航空燃油短缺，并尽可能提高炼油厂的产量。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20260416-%E6%9A%91%E6%9C%9F%E5%87%BA%E8%A1%8C%E6%97%BA%E5%AD%A3%E5%8D%B3%E5%B0%86%E5%88%B0%E6%9D%A5%EF%BC%8C%E4%BD%86%E8%8B%A5%E6%88%98%E4%BA%89%E6%8C%81%E7%BB%AD%EF%BC%8C%E6%AC%A7%E6%B4%B2%E6%9C%80%E6%97%A9%E4%BB%8E6%E6%9C%88%E8%B5%B7%E5%B0%B1%E5%8F%AF%E8%83%BD%E5%87%BA%E7%8E%B0%E8%88%AA%E7%A9%BA%E7%87%83%E6%B2%B9%E7%9F%AD%E7%BC%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776329113000.webp","sourceId":"rfi"},{"id":1776328023000,"createdDate":"2026-04-16 08:27","name":"法国国际广播电台","title":"美国正在讨论是否与伊朗举行第二轮谈判，伊朗也重申了谈判意愿","content":"法新社消息称，美国星期三（4月16日）宣布，正在讨论与德黑兰举行第二轮谈判的可能性，并表示对达成协议“持乐观态度”。此前，伊朗曾威胁称，如果美国封锁伊朗的港口，将阻断红海航运。伊朗方面也重申了谈判意愿。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260416-%E7%BE%8E%E5%9B%BD%E6%AD%A3%E5%9C%A8%E8%AE%A8%E8%AE%BA%E6%98%AF%E5%90%A6%E4%B8%8E%E4%BC%8A%E6%9C%97%E4%B8%BE%E8%A1%8C%E7%AC%AC%E4%BA%8C%E8%BD%AE%E8%B0%88%E5%88%A4%EF%BC%8C%E4%BC%8A%E6%9C%97%E4%B9%9F%E9%87%8D%E7%94%B3%E4%BA%86%E8%B0%88%E5%88%A4%E6%84%8F%E6%84%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776328023000.webp","sourceId":"rfi"},{"id":1776326486000,"createdDate":"2026-04-16 08:01","name":"法国国际广播电台","title":"哈梅内伊军事顾问、革命卫队内部强硬派代表雷扎伊：若美国在霍尔木兹海峡“执法”，将击沉美方船只","content":"已故的伊朗最高领袖之子穆杰塔巴·哈梅内伊的军事顾问星期三（4月16日）威胁称，如果美国试图在霍尔木兹海峡“执法”，伊朗将击沉美方船只。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260416-%E5%93%88%E6%A2%85%E5%86%85%E4%BC%8A%E5%86%9B%E4%BA%8B%E9%A1%BE%E9%97%AE-%E9%9D%A9%E5%91%BD%E5%8D%AB%E9%98%9F%E5%86%85%E9%83%A8%E5%BC%BA%E7%A1%AC%E6%B4%BE%E4%BB%A3%E8%A1%A8%E9%9B%B7%E6%89%8E%E4%BC%8A-%E8%8B%A5%E7%BE%8E%E5%9B%BD%E5%9C%A8%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E6%89%A7%E6%B3%95-%EF%BC%8C%E5%B0%86%E5%87%BB%E6%B2%89%E7%BE%8E%E6%96%B9%E8%88%B9%E5%8F%AA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776326486000.webp","sourceId":"rfi"},{"id":1776322962000,"createdDate":"2026-04-16 07:02","name":"法国国际广播电台","title":"澳门财爷上任16个月突以「个人原因」离职 属港澳政府季内第二名离职主要官员","content":"澳门经济财政司司长戴建业上任不足一年半，便以「个人原因」请辞，中国政府今(16日)早公布，免去其职务，但未有接任人选，其工作将由行政长官岑浩辉兼掌，而澳门政府则着手跟进接任人手的提名工作。这是中国两个特别行政区三个月内第二宗问责局长突然辞职事件，在此之前，香港特区的时任政制及内地事务局局长曾国卫於1月下旬获北京的中央政府接纳他以「健康理由」请辞，继任人选在两个月後才公布。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260416-%E6%BE%B3%E9%97%A8%E8%B4%A2%E7%88%B7%E4%B8%8A%E4%BB%BB16%E4%B8%AA%E6%9C%88%E7%AA%81%E4%BB%A5-%E4%B8%AA%E4%BA%BA%E5%8E%9F%E5%9B%A0-%E7%A6%BB%E8%81%8C-%E5%B1%9E%E6%B8%AF%E6%BE%B3%E6%94%BF%E5%BA%9C%E5%AD%A3%E5%86%85%E7%AC%AC%E4%BA%8C%E5%90%8D%E7%A6%BB%E8%81%8C%E4%B8%BB%E8%A6%81%E5%AE%98%E5%91%98","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776322962000.webp","sourceId":"rfi"},{"id":1776322342000,"createdDate":"2026-04-16 06:52","name":"法国国际广播电台","title":"中国首季经济增长5% 高於预期 官认伊朗战事有影响但料可控","content":"尽管全球经济均受到美伊战事影响，但中国首季国内生产总值(GDP)录得5%的增长，较上季加快0.5个百分点，亦高於市场预期的4.8%增幅。不过，同期作为拉动经济的「三头马车」，其增幅均逊於预期，而国家统计局副局长毛盛勇亦表示，中东局势肯定会影响中国的出口和经济，但总的来说，影响将是有限和可控的。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260416-%E4%B8%AD%E5%9B%BD%E9%A6%96%E5%AD%A3%E7%BB%8F%E6%B5%8E%E5%A2%9E%E9%95%BF5-%E9%AB%98%E6%96%BC%E9%A2%84%E6%9C%9F-%E5%AE%98%E8%AE%A4%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%8B%E6%9C%89%E5%BD%B1%E5%93%8D%E4%BD%86%E6%96%99%E5%8F%AF%E6%8E%A7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776322342000.webp","sourceId":"rfi"},{"id":1776354173000,"createdDate":"2026-04-16 15:42","name":"法国国际广播电台","title":"喀麦隆：教宗良十四世到访巴门达“英语区危机紧绷”中心地带","content":"各位听众，梵蒂冈教宗良十四世教宗于4月16日星期四前往该国重要城市巴门达访问；巴门达也是“英语区危机”的冲突中心地带。此前，教宗已于4月15日周三离开阿尔及利亚前往喀麦隆首都雅温得，开启首次非洲之旅。在喀麦隆，为期11天的教宗非洲之行，进入第二阶段。喀麦隆现今的政治和安全局势十分紧张。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%81%9A%E7%84%A6%E9%9D%9E%E6%B4%B2/20260416-%E5%96%80%E9%BA%A6%E9%9A%86-%E6%95%99%E5%AE%97%E8%89%AF%E5%8D%81%E5%9B%9B%E4%B8%96%E5%88%B0%E8%AE%BF%E5%B7%B4%E9%97%A8%E8%BE%BE-%E8%8B%B1%E8%AF%AD%E5%8C%BA%E5%8D%B1%E6%9C%BA-%E7%B4%A7%E7%BB%B7%E4%B8%AD%E5%BF%83%E5%9C%B0%E5%B8%A6","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776354173000.webp","sourceId":"rfi"},{"id":1776353493000,"createdDate":"2026-04-16 15:31","name":"法国国际广播电台","title":"中国：学者遭拒入境美国  提醒公民增强安全防范意识","content":"中国外交部在周四（4月16号）发布通知，提醒赴美国中国公民在入境美国时保持警惕，注意入境安全风险。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260416-%E7%A7%B0%E5%AD%A6%E8%80%85%E9%81%AD%E6%8B%92%E5%85%A5%E5%A2%83-%E4%B8%AD%E5%9B%BD%E6%8F%90%E9%86%92%E5%85%AC%E6%B0%91%E5%85%A5%E5%A2%83%E7%BE%8E%E5%9B%BD%E6%97%B6%E4%BF%9D%E6%8C%81%E8%AD%A6%E6%83%95","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776353493000.webp","sourceId":"rfi"},{"id":1776350255000,"createdDate":"2026-04-16 14:37","name":"法国国际广播电台","title":"美国防部长：如果近期无法达成协议，将对伊朗采取更强硬措施，并透露美国正利用停火期提升实力进行“再武装”","content":"美国国防部长赫格塞斯周四（4月16日）表示，美国将“在必要时持续”对伊朗港口实施封锁（已自本周一开始执行），并警告称，如果近期无法达成协议，将对德黑兰采取更强硬措施。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260416-%E7%BE%8E%E5%9B%BD%E9%98%B2%E9%83%A8%E9%95%BF-%E5%A6%82%E6%9E%9C%E8%BF%91%E6%9C%9F%E6%97%A0%E6%B3%95%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE%EF%BC%8C%E5%B0%86%E5%AF%B9%E4%BC%8A%E6%9C%97%E9%87%87%E5%8F%96%E6%9B%B4%E5%BC%BA%E7%A1%AC%E6%8E%AA%E6%96%BD%EF%BC%8C%E5%B9%B6%E9%80%8F%E9%9C%B2%E7%BE%8E%E5%9B%BD%E6%AD%A3%E5%88%A9%E7%94%A8%E5%81%9C%E7%81%AB%E6%9C%9F%E6%8F%90%E5%8D%87%E5%AE%9E%E5%8A%9B%E8%BF%9B%E8%A1%8C-%E5%86%8D%E6%AD%A6%E8%A3%85","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776350255000.webp","sourceId":"rfi"},{"id":1776349132000,"createdDate":"2026-04-16 14:18","name":"法国国际广播电台","title":"台积电一季度利润同比大增58%，创下季度历史新高，但同时警告伊朗战争正在推高成本","content":"台湾芯片制造商台积电（TSMC）周四（4月16日）公布，今年第一季度利润同比大幅增长58%，这得益于人工智能热潮带来的强劲需求。不过，公司同时警告称，伊朗战争正在推高成本。","newsLink":"https://www.rfi.fr/cn/%E7%A7%91%E6%8A%80%E4%B8%8E%E6%96%87%E5%8C%96/20260416-%E5%8F%B0%E7%A7%AF%E7%94%B5%E4%B8%80%E5%AD%A3%E5%BA%A6%E5%88%A9%E6%B6%A6%E5%90%8C%E6%AF%94%E5%A4%A7%E5%A2%9E58-%EF%BC%8C%E5%88%9B%E4%B8%8B%E5%AD%A3%E5%BA%A6%E5%8E%86%E5%8F%B2%E6%96%B0%E9%AB%98%EF%BC%8C%E4%BD%86%E5%90%8C%E6%97%B6%E8%AD%A6%E5%91%8A%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%AD%A3%E5%9C%A8%E6%8E%A8%E9%AB%98%E6%88%90%E6%9C%AC","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776349132000.webp","sourceId":"rfi"},{"id":1776348727000,"createdDate":"2026-04-16 14:12","name":"法国国际广播电台","title":"消除“月经贫困”：法国将100%报销可重复使用的经期用品，主要针对26岁以下女性和经济困难群体，预计惠及670万人","content":"法国政府周四（4月16日）宣布，新学年开始（今年9月），26岁以下女性以及经济困难群体在购买可重复使用经期用品（如经期内裤和月经杯），可实现全部报销。这项措施其实早在三年前就已通过，如今终于彻底落地开始实施。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260416-%E6%B6%88%E9%99%A4-%E6%9C%88%E7%BB%8F%E8%B4%AB%E5%9B%B0-%E6%B3%95%E5%9B%BD%E5%B0%86100-%E6%8A%A5%E9%94%80%E5%8F%AF%E9%87%8D%E5%A4%8D%E4%BD%BF%E7%94%A8%E7%9A%84%E7%BB%8F%E6%9C%9F%E7%94%A8%E5%93%81%EF%BC%8C%E4%B8%BB%E8%A6%81%E9%92%88%E5%AF%B926%E5%B2%81%E4%BB%A5%E4%B8%8B%E5%A5%B3%E6%80%A7%E5%92%8C%E7%BB%8F%E6%B5%8E%E5%9B%B0%E9%9A%BE%E7%BE%A4%E4%BD%93%EF%BC%8C%E9%A2%84%E8%AE%A1%E6%83%A0%E5%8F%8A670%E4%B8%87%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776348727000.webp","sourceId":"rfi"},{"id":1776348535000,"createdDate":"2026-04-16 14:08","name":"法国国际广播电台","title":"以色列与黎巴嫩令人期盼却难以启动的谈判","content":"美国和伊朗之间为期两周的停火已经接近尾声而霍尔木兹海峡仍持续通行受阻之际，以色列与黎巴嫩可能就两国战事再度对话的消息似乎又让这场已经持续了六周而且搅动全球的中东危机萌现几许希望。美国总统特朗普周三晚间在其社交媒体“真相社交”平台上语气肯定地表示，以色列和黎巴嫩16日将展开对话。不过，法新社16日引述未具姓名的黎巴嫩官方途径消息，称黎巴嫩对以色列与黎巴嫩将展开对话毫不知情。这种似是而非的情景在很大程度上折射着谋求以色列与黎巴嫩两国之间停止战火努力之艰难。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260416-%E4%BB%A5%E8%89%B2%E5%88%97%E4%B8%8E%E9%BB%8E%E5%B7%B4%E5%AB%A9%E4%BB%A4%E4%BA%BA%E6%9C%9F%E7%9B%BC%E5%8D%B4%E9%9A%BE%E4%BB%A5%E5%90%AF%E5%8A%A8%E7%9A%84%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776348535000.webp","sourceId":"rfi"},{"id":1776340633000,"createdDate":"2026-04-16 11:57","name":"法国国际广播电台","title":"报告显示：2025年全球跨境镇压案例增加，中国仍居榜首","content":"总部设在华盛顿的人权组织“自由之家”近日发表的年度报告显示，2025年，全球专制政府对持不同政见人士的镇压行为新增126例，有跨国镇压行为的政府也增加至54个。中国仍然是跨国镇压案例最多的国家。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260416-%E6%8A%A5%E5%91%8A%E6%98%BE%E7%A4%BA-2025%E5%B9%B4%E5%85%A8%E7%90%83%E8%B7%A8%E5%A2%83%E9%95%87%E5%8E%8B%E6%A1%88%E4%BE%8B%E5%A2%9E%E5%8A%A0%EF%BC%8C%E4%B8%AD%E5%9B%BD%E4%BB%8D%E5%B1%85%E6%A6%9C%E9%A6%96","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776340633000.webp","sourceId":"rfi"},{"id":1776339922000,"createdDate":"2026-04-16 11:45","name":"法国国际广播电台","title":"回声报：中东战争影响初显，中国首季增长却超预期支撑了2026设定目标","content":"大家好，欢迎收听法国报纸摘要，今天是4月16日星期四，法国各主要日报头版各有侧重。就在美国总统特朗普自称以黎领导人“将在周四对话”之际《解放报》推出饱受战火摧残的黎巴嫩专题。《费加罗报》头版关注：特朗普希望通过封锁霍尔木兹海峡迫使伊朗政权屈服，以及距离法国总统选举首轮投票还有一年时间，企业领导人决心发出自己的声音。《十字架报》探讨当学校关门的话题。此外，尽管中东战争阴云笼罩，中国经济增长仍然保持韧性，首季国内生产总值录得5%的增长超出预期，则成为《回声报》国际版报道的重点。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260416-%E5%9B%9E%E5%A3%B0%E6%8A%A5-%E4%B8%AD%E4%B8%9C%E6%88%98%E4%BA%89%E5%BD%B1%E5%93%8D%E5%88%9D%E6%98%BE%EF%BC%8C%E4%B8%AD%E5%9B%BD%E9%A6%96%E5%AD%A3%E5%A2%9E%E9%95%BF%E5%8D%B4%E8%B6%85%E9%A2%84%E6%9C%9F%E6%94%AF%E6%92%91%E4%BA%862026%E8%AE%BE%E5%AE%9A%E7%9B%AE%E6%A0%87","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776339922000.webp","sourceId":"rfi"},{"id":1776339052000,"createdDate":"2026-04-16 11:30","name":"法国国际广播电台","title":"意大利外长访华会谈贸易及伊朗问题","content":"为加强两国间的经济联系，同时呼吁北京为伊朗和乌克兰的和平进程做出贡献，意大利外长安东尼奥·塔亚尼周四访华。外长办公室表示，他将在周四晚些时候在北京会见中国商务部长王文涛和外长王毅。塔亚尼同时也是意大利总理乔治亚·梅洛尼领导的极右翼政府的副总理。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260416-%E6%84%8F%E5%A4%A7%E5%88%A9%E5%A4%96%E9%95%BF%E8%AE%BF%E5%8D%8E%E4%BC%9A%E8%B0%88%E8%B4%B8%E6%98%93%E5%8F%8A%E4%BC%8A%E6%9C%97%E9%97%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776339052000.webp","sourceId":"rfi"},{"id":1776337031000,"createdDate":"2026-04-16 10:57","name":"法国国际广播电台","title":"观众变主角：中国从伊朗战争所得红利中重塑自身全球地位","content":"据法国周刊《观点》电子版15日晚登出NicolasBaverez撰写的社评指出，通过保障能源主权、掌控军事力量、管控对外贸易等手段，中国面对美国的不可预测性，正将自身塑造为稳定的一级大国。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260416-%E8%A7%82%E4%BC%97%E5%8F%98%E4%B8%BB%E8%A7%92-%E4%B8%AD%E5%9B%BD%E4%BB%8E%E4%BC%8A%E6%9C%97%E6%88%98%E4%BA%89%E6%89%80%E5%BE%97%E7%BA%A2%E5%88%A9%E4%B8%AD%E9%87%8D%E5%A1%91%E8%87%AA%E8%BA%AB%E5%85%A8%E7%90%83%E5%9C%B0%E4%BD%8D","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776337031000.webp","sourceId":"rfi"},{"id":1776333095000,"createdDate":"2026-04-16 09:51","name":"法国国际广播电台","title":"乌克兰遭遇今年以来俄罗斯最致命的袭击，至少16人死亡","content":"乌克兰当局星期四（4月16日）表示，俄罗斯在夜间对基辅及乌克兰多座城市发动了今年以来最致命的一次空袭，已造成至少16人死亡，其中包括一名12岁儿童，另有数十人受伤。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260416-%E4%B9%8C%E5%85%8B%E5%85%B0%E9%81%AD%E9%81%87%E4%BB%8A%E5%B9%B4%E4%BB%A5%E6%9D%A5%E4%BF%84%E7%BD%97%E6%96%AF%E6%9C%80%E8%87%B4%E5%91%BD%E7%9A%84%E8%A2%AD%E5%87%BB%EF%BC%8C%E8%87%B3%E5%B0%9116%E4%BA%BA%E6%AD%BB%E4%BA%A1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776333095000.webp","sourceId":"rfi"},{"id":1776332036000,"createdDate":"2026-04-16 09:33","name":"法国国际广播电台","title":"哈萨克斯坦牺牲本国民众自由讨好北京？19位公民因抗议中国新疆政策被判监禁或限制行动自由","content":"美联社4月16日消息称，哈萨克斯坦一家法院近日判处19名活动人士有罪。这些人曾在去年就中国西部新疆地区的打压政策举行抗议。专家和人权倡导者表示，这是哈萨克斯坦政府迄今为止规模最大的一次行动，旨在应北京方面要求压制批评声音。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260416-%E5%93%88%E8%90%A8%E5%85%8B%E6%96%AF%E5%9D%A6%E7%89%BA%E7%89%B2%E6%9C%AC%E5%9B%BD%E6%B0%91%E4%BC%97%E8%87%AA%E7%94%B1%E8%AE%A8%E5%A5%BD%E5%8C%97%E4%BA%AC-%E5%9B%A0%E6%8A%97%E8%AE%AE%E4%B8%AD%E5%9B%BD%E5%9C%A8%E6%96%B0%E7%96%86%E7%9A%84%E6%94%BF%E7%AD%96-19%E4%BD%8D%E5%85%AC%E6%B0%91%E8%A2%AB%E5%88%A4%E7%9B%91%E7%A6%81%E6%88%96%E9%99%90%E5%88%B6%E8%A1%8C%E5%8A%A8%E8%87%AA%E7%94%B1","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776332036000.webp","sourceId":"rfi"},{"id":1776331928000,"createdDate":"2026-04-16 09:32","name":"法国国际广播电台","title":"从亲密到疏远：特朗普抨击意大利总理梅洛尼","content":"原本被视为欧洲与美国总统特朗普之间“桥梁”的意大利总理梅洛尼，如今这座桥似乎看起来并不“稳固”。","newsLink":"https://www.rfi.fr/cn/%E6%94%BF%E6%B2%BB/20260416-%E4%BB%8E%E4%BA%B2%E5%AF%86%E5%88%B0%E7%96%8F%E8%BF%9C-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8A%A8%E5%87%BB%E6%84%8F%E5%A4%A7%E5%88%A9%E6%80%BB%E7%90%86%E6%A2%85%E6%B4%9B%E5%B0%BC","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776331928000.webp","sourceId":"rfi"},{"id":1776331787000,"createdDate":"2026-04-16 09:29","name":"法国国际广播电台","title":"高市早苗荣登“全球最具影响力百人”榜","content":"美国《时代》杂志每年例行评选的“全球最具影响力的百人”中，日本首相高市早苗入榜。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260416-%E9%AB%98%E5%B8%82%E6%97%A9%E8%8B%97%E8%8D%A3%E7%99%BB-%E5%85%A8%E7%90%83%E6%9C%80%E5%85%B7%E5%BD%B1%E5%93%8D%E5%8A%9B%E7%99%BE%E4%BA%BA-%E6%A6%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776331787000.webp","sourceId":"rfi"},{"id":1776330357000,"createdDate":"2026-04-16 09:05","name":"法国国际广播电台","title":"斯里兰卡：9名涉嫌参与网络诈骗的中国人被捕，海关查获近400部二手手机","content":"斯里兰卡海关消息称，9名中国公民周四（4月16日）在科伦坡机场被逮捕，他们试图非法将一批通信设备带入该国，当局怀疑这些设备将用于网络诈骗活动。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260416-%E6%96%AF%E9%87%8C%E5%85%B0%E5%8D%A1-9%E5%90%8D%E6%B6%89%E5%AB%8C%E5%8F%82%E4%B8%8E%E7%BD%91%E7%BB%9C%E8%AF%88%E9%AA%97%E7%9A%84%E4%B8%AD%E5%9B%BD%E4%BA%BA%E8%A2%AB%E6%8D%95%EF%BC%8C%E6%B5%B7%E5%85%B3%E6%9F%A5%E8%8E%B7%E8%BF%91400%E9%83%A8%E4%BA%8C%E6%89%8B%E6%89%8B%E6%9C%BA%E5%92%8C%E7%BA%A6100%E5%8F%B0%E7%94%B5%E8%84%91","thumbnail":"","detailImage":"news/detail/rfi/2026/04/16/1776330357000.webp","sourceId":"rfi"}]