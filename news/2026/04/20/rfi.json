[{"id":1776674772000,"createdDate":"2026-04-20 08:46","name":"法国国际广播电台","title":"美菲“肩并肩”年度军演登场 日本首度大规模参加 中国警告勿“玩火自焚”","content":"美国与菲律宾名为“肩并肩”的年度军演周一（4月20日）在菲律宾登场，今年日本首次派大规模部队参加，中国对此回应表示，各国军事合作不应破坏区域国家间的相互理解和信任，警告有关国家在安全领域盲目结盟无异于“玩火自焚”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260420-%E7%BE%8E%E8%8F%B2-%E8%82%A9%E5%B9%B6%E8%82%A9-%E5%B9%B4%E5%BA%A6%E5%86%9B%E6%BC%94%E7%99%BB%E5%9C%BA-%E6%97%A5%E6%9C%AC%E9%A6%96%E5%BA%A6%E5%A4%A7%E8%A7%84%E6%A8%A1%E5%8F%82%E5%8A%A0-%E4%B8%AD%E5%9B%BD%E8%AD%A6%E5%91%8A%E5%8B%BF-%E7%8E%A9%E7%81%AB%E8%87%AA%E7%84%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776674772000.webp","sourceId":"rfi"},{"id":1776672169000,"createdDate":"2026-04-20 08:02","name":"法国国际广播电台","title":"赖清德将出访非洲展现台湾战略主体性  「非洲之角」索马里兰不向北京低头秀台湾国旗","content":"台湾总统赖清德将在22日出访非洲友邦斯威士兰王国，非洲11国40余名政要表达热烈欢迎。准邦交国索马里兰不向北京低头秀出台湾国旗，展现挺台立场","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260420-%E8%B5%96%E6%B8%85%E5%BE%B7%E5%B0%86%E5%87%BA%E8%AE%BF%E9%9D%9E%E6%B4%B2%E5%B1%95%E7%8E%B0%E5%8F%B0%E6%B9%BE%E6%88%98%E7%95%A5%E4%B8%BB%E4%BD%93%E6%80%A7-%E9%9D%9E%E6%B4%B2%E4%B9%8B%E8%A7%92-%E7%B4%A2%E9%A9%AC%E9%87%8C%E5%85%B0%E4%B8%8D%E5%90%91%E5%8C%97%E4%BA%AC%E4%BD%8E%E5%A4%B4%E7%A7%80%E5%8F%B0%E6%B9%BE%E5%9B%BD%E6%97%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776672169000.webp","sourceId":"rfi"},{"id":1776670824000,"createdDate":"2026-04-20 07:40","name":"法国国际广播电台","title":"港府将推「部门首长责任制」疑货不对版 责不上政策局最高公务员遭诟病","content":"港府计划于10月推出「部门首长责任制」，近日公布细节，拟以两级调查机制处分表现不佳的公务员。但新机制列明，调查范围不涵盖作为政策局内最高级公务员的常任秘书长，亦不适用于追究导致168人死亡的宏福苑大火责任，责不上部门最高层引发讨论。即使主事官员急于解画，外界仍质疑新机制未能建立公务员须问责的态度。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260420-%E6%B8%AF%E5%BA%9C%E5%B0%86%E6%8E%A8-%E9%83%A8%E9%97%A8%E9%A6%96%E9%95%BF%E8%B4%A3%E4%BB%BB%E5%88%B6-%E7%96%91%E8%B4%A7%E4%B8%8D%E5%AF%B9%E7%89%88-%E8%B4%A3%E4%B8%8D%E4%B8%8A%E6%94%BF%E7%AD%96%E5%B1%80%E6%9C%80%E9%AB%98%E5%85%AC%E5%8A%A1%E5%91%98%E9%81%AD%E8%AF%9F%E7%97%85","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776670824000.webp","sourceId":"rfi"},{"id":1776669517000,"createdDate":"2026-04-20 07:18","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第24：浪漫主义群星之三：荷尔德林：第八节：人“诗意地栖居”","content":"海德格尔阐释荷尔德林的诗当然不是一种文学批评，而是构建一条经由诗而达于思的通道。他体验到的正是荷尔德林用诗行所揭示，描绘的时代状况：众神远去，精神贫乏，利害算计，社会一切以实用与否为价值标准。但人这样的居于大地是正确而适宜的吗？显然不是。荷尔德林已然给出了另一种可能性。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260420-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%89-%E8%8D%B7%E5%B0%94%E5%BE%B7%E6%9E%97-%E7%AC%AC%E5%85%AB%E8%8A%82-%E4%BA%BA-%E8%AF%97%E6%84%8F%E5%9C%B0%E6%A0%96%E5%B1%85","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776669517000.webp","sourceId":"rfi"}]