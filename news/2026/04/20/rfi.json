[{"id":1776674772000,"createdDate":"2026-04-20 08:46","name":"法国国际广播电台","title":"美菲“肩并肩”年度军演登场 日本首度大规模参加 中国警告勿“玩火自焚”","content":"美国与菲律宾名为“肩并肩”的年度军演周一（4月20日）在菲律宾登场，今年日本首次派大规模部队参加，中国对此回应表示，各国军事合作不应破坏区域国家间的相互理解和信任，警告有关国家在安全领域盲目结盟无异于“玩火自焚”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260420-%E7%BE%8E%E8%8F%B2-%E8%82%A9%E5%B9%B6%E8%82%A9-%E5%B9%B4%E5%BA%A6%E5%86%9B%E6%BC%94%E7%99%BB%E5%9C%BA-%E6%97%A5%E6%9C%AC%E9%A6%96%E5%BA%A6%E5%A4%A7%E8%A7%84%E6%A8%A1%E5%8F%82%E5%8A%A0-%E4%B8%AD%E5%9B%BD%E8%AD%A6%E5%91%8A%E5%8B%BF-%E7%8E%A9%E7%81%AB%E8%87%AA%E7%84%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776674772000.webp","sourceId":"rfi"},{"id":1776672169000,"createdDate":"2026-04-20 08:02","name":"法国国际广播电台","title":"赖清德将出访非洲展现台湾战略主体性  「非洲之角」索马里兰不向北京低头秀台湾国旗","content":"台湾总统赖清德将在22日出访非洲友邦斯威士兰王国，非洲11国40余名政要表达热烈欢迎。准邦交国索马里兰不向北京低头秀出台湾国旗，展现挺台立场","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260420-%E8%B5%96%E6%B8%85%E5%BE%B7%E5%B0%86%E5%87%BA%E8%AE%BF%E9%9D%9E%E6%B4%B2%E5%B1%95%E7%8E%B0%E5%8F%B0%E6%B9%BE%E6%88%98%E7%95%A5%E4%B8%BB%E4%BD%93%E6%80%A7-%E9%9D%9E%E6%B4%B2%E4%B9%8B%E8%A7%92-%E7%B4%A2%E9%A9%AC%E9%87%8C%E5%85%B0%E4%B8%8D%E5%90%91%E5%8C%97%E4%BA%AC%E4%BD%8E%E5%A4%B4%E7%A7%80%E5%8F%B0%E6%B9%BE%E5%9B%BD%E6%97%97","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776672169000.webp","sourceId":"rfi"},{"id":1776670824000,"createdDate":"2026-04-20 07:40","name":"法国国际广播电台","title":"港府将推「部门首长责任制」疑货不对版 责不上政策局最高公务员遭诟病","content":"港府计划于10月推出「部门首长责任制」，近日公布细节，拟以两级调查机制处分表现不佳的公务员。但新机制列明，调查范围不涵盖作为政策局内最高级公务员的常任秘书长，亦不适用于追究导致168人死亡的宏福苑大火责任，责不上部门最高层引发讨论。即使主事官员急于解画，外界仍质疑新机制未能建立公务员须问责的态度。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20260420-%E6%B8%AF%E5%BA%9C%E5%B0%86%E6%8E%A8-%E9%83%A8%E9%97%A8%E9%A6%96%E9%95%BF%E8%B4%A3%E4%BB%BB%E5%88%B6-%E7%96%91%E8%B4%A7%E4%B8%8D%E5%AF%B9%E7%89%88-%E8%B4%A3%E4%B8%8D%E4%B8%8A%E6%94%BF%E7%AD%96%E5%B1%80%E6%9C%80%E9%AB%98%E5%85%AC%E5%8A%A1%E5%91%98%E9%81%AD%E8%AF%9F%E7%97%85","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776670824000.webp","sourceId":"rfi"},{"id":1776669517000,"createdDate":"2026-04-20 07:18","name":"法国国际广播电台","title":"欧洲思想文化长廊：德国浪漫主义第24：浪漫主义群星之三：荷尔德林：第八节：人“诗意地栖居”","content":"海德格尔阐释荷尔德林的诗当然不是一种文学批评，而是构建一条经由诗而达于思的通道。他体验到的正是荷尔德林用诗行所揭示，描绘的时代状况：众神远去，精神贫乏，利害算计，社会一切以实用与否为价值标准。但人这样的居于大地是正确而适宜的吗？显然不是。荷尔德林已然给出了另一种可能性。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A/20260420-%E6%AC%A7%E6%B4%B2%E6%80%9D%E6%83%B3%E6%96%87%E5%8C%96%E9%95%BF%E5%BB%8A-%E5%BE%B7%E5%9B%BD%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%AC%AC24-%E6%B5%AA%E6%BC%AB%E4%B8%BB%E4%B9%89%E7%BE%A4%E6%98%9F%E4%B9%8B%E4%B8%89-%E8%8D%B7%E5%B0%94%E5%BE%B7%E6%9E%97-%E7%AC%AC%E5%85%AB%E8%8A%82-%E4%BA%BA-%E8%AF%97%E6%84%8F%E5%9C%B0%E6%A0%96%E5%B1%85","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776669517000.webp","sourceId":"rfi"},{"id":1776704019000,"createdDate":"2026-04-20 16:53","name":"法国国际广播电台","title":"亲俄前总统压倒性赢得保加利亚立法选举，欧盟与俄均表态","content":"路透社索菲亚站4月20日消息，立场被认为亲俄的保加利亚前总统鲁门·拉德夫在该国议会选举中取得了压倒性胜利。他击败了长期主导政坛的传统政治力量，也可能使这个保加利亚这个欧盟和北约成员国在政治取向上更接近莫斯科。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260420-%E4%BA%B2%E4%BF%84%E5%89%8D%E6%80%BB%E7%BB%9F%E5%8E%8B%E5%80%92%E6%80%A7%E8%B5%A2%E5%BE%97%E4%BF%9D%E5%8A%A0%E5%88%A9%E4%BA%9A%E7%AB%8B%E6%B3%95%E9%80%89%E4%B8%BE%EF%BC%8C%E6%AC%A7%E7%9B%9F%E4%B8%8E%E4%BF%84%E5%9D%87%E8%A1%A8%E6%80%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776704019000.webp","sourceId":"rfi"},{"id":1776700854000,"createdDate":"2026-04-20 16:00","name":"法国国际广播电台","title":"香港火灾造成168人死亡后，居民首次获准重返现场试图找回个人物品","content":"去年在一场特大火灾中失去家园的数千名香港居民，自周一起被允许首次重返现场，试图找回他们仅存的个人物品。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260420-%E9%A6%99%E6%B8%AF%E7%81%AB%E7%81%BE%E9%80%A0%E6%88%90168%E4%BA%BA%E6%AD%BB%E4%BA%A1%E5%90%8E%EF%BC%8C%E5%B1%85%E6%B0%91%E9%A6%96%E6%AC%A1%E8%8E%B7%E5%87%86%E9%87%8D%E8%BF%94%E7%8E%B0%E5%9C%BA%E8%AF%95%E5%9B%BE%E6%89%BE%E5%9B%9E%E4%B8%AA%E4%BA%BA%E7%89%A9%E5%93%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776700854000.webp","sourceId":"rfi"},{"id":1776696959000,"createdDate":"2026-04-20 14:55","name":"法国国际广播电台","title":"菲律宾军队击毙至少十名共产毛主义叛乱分子","content":"菲律宾军方周一宣布，政府军击毙了“至少十名”与历史最悠久的共产主义叛乱活动有关的毛主义叛乱分子。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260420-%E8%8F%B2%E5%BE%8B%E5%AE%BE%E5%86%9B%E9%98%9F%E5%87%BB%E6%AF%99%E8%87%B3%E5%B0%91%E5%8D%81%E5%90%8D%E5%85%B1%E4%BA%A7%E6%AF%9B%E4%B8%BB%E4%B9%89%E5%8F%9B%E4%B9%B1%E5%88%86%E5%AD%90","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776696959000.webp","sourceId":"rfi"},{"id":1776695003000,"createdDate":"2026-04-20 14:23","name":"法国国际广播电台","title":"韩国总统到访印度大力加强两国经贸合作","content":"韩国总统李在明到访印度周一在新德里与印度总理莫迪举行会谈，旨在显著提升两国经贸合作，尤其是在造船等领域。印度外交部在一份声明中表示两国领导人重点讨论深化在造船、贸易、投资和人工智能等领域的双边合作。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%BB%8A%E6%97%A5%E7%BB%8F%E6%B5%8E/20260420-%E9%9F%A9%E5%9B%BD%E6%80%BB%E7%BB%9F%E5%88%B0%E8%AE%BF%E5%8D%B0%E5%BA%A6%E5%A4%A7%E5%8A%9B%E5%8A%A0%E5%BC%BA%E4%B8%A4%E5%9B%BD%E7%BB%8F%E8%B4%B8%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776695003000.webp","sourceId":"rfi"},{"id":1776694743000,"createdDate":"2026-04-20 14:19","name":"法国国际广播电台","title":"日本：7.7级地震后引发海啸预警  “大”地震风险增加","content":"日本周一（4月20号）发出警告，称发生8.0级或以上“大”地震的风险增加。此前，该国北部发生强烈地震，并引发海啸预警。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260420-%E6%97%A5%E6%9C%AC-7-7%E7%BA%A7%E5%9C%B0%E9%9C%87%E5%90%8E%E5%BC%95%E5%8F%91%E6%B5%B7%E5%95%B8%E9%A2%84%E8%AD%A6-%E5%A4%A7-%E5%9C%B0%E9%9C%87%E9%A3%8E%E9%99%A9%E5%A2%9E%E5%8A%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776694743000.webp","sourceId":"rfi"},{"id":1776694683000,"createdDate":"2026-04-20 14:18","name":"法国国际广播电台","title":"首尔将大幅削减朝韩边境驻军","content":"韩国国防部宣布将驻扎在三八线非军事区的人员减少75%，韩国与朝鲜之间的边界是世界上戒备最森严、监控最严密的边界，韩国减少驻军主要是受该国人口下降的影响。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260420-%E9%A6%96%E5%B0%94%E5%B0%86%E5%A4%A7%E5%B9%85%E5%89%8A%E5%87%8F%E6%9C%9D%E9%9F%A9%E8%BE%B9%E5%A2%83%E9%A9%BB%E5%86%9B","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776694683000.webp","sourceId":"rfi"},{"id":1776692462000,"createdDate":"2026-04-20 13:41","name":"法国国际广播电台","title":"巴黎法院等待马斯克就X平台接受问询 美国司法部谴责巴黎“不当”利用司法干涉美企","content":"社交媒体平台X的所有者埃隆·马斯克被要求今天周一在巴黎接受“非强制性”问询。传唤的具体地点和时间尚未有任何消息泄露。马斯克本人则谴责此举是“政治攻击”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260420-%E5%B7%B4%E9%BB%8E%E6%B3%95%E9%99%A2%E7%AD%89%E5%BE%85%E9%A9%AC%E6%96%AF%E5%85%8B%E5%B0%B1x%E5%B9%B3%E5%8F%B0%E6%8E%A5%E5%8F%97%E9%97%AE%E8%AF%A2-%E7%BE%8E%E5%9B%BD%E5%8F%B8%E6%B3%95%E9%83%A8%E8%B0%B4%E8%B4%A3%E5%B7%B4%E9%BB%8E-%E4%B8%8D%E5%BD%93-%E5%88%A9%E7%94%A8%E5%8F%B8%E6%B3%95%E5%B9%B2%E6%B6%89%E7%BE%8E%E4%BC%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776692462000.webp","sourceId":"rfi"},{"id":1776686447000,"createdDate":"2026-04-20 12:00","name":"法国国际广播电台","title":"“法波友好日”马克龙访波兰 与图斯克会谈聚焦核威慑议题","content":"法国总统马克龙周一（4月20日）访问东欧国家波兰，在充满象征意义的波兰北部城市格但斯克与波兰总理图斯克举行峰会。核威慑、军事卫星及国防工业合作等关键议题将是两位领导人讨论的焦点。在复杂动荡的国际局势下，马克龙此次在“法波友好日”的访问，旨在推动强化双方关系，建设一个面对美、俄更加“强大”和“自主”的欧洲。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E8%A7%A3%E8%AF%B4/20260420-%E6%B3%95%E6%B3%A2%E5%8F%8B%E5%A5%BD%E6%97%A5-%E9%A9%AC%E5%85%8B%E9%BE%99%E8%AE%BF%E6%B3%A2%E5%85%B0-%E4%B8%8E%E5%9B%BE%E6%96%AF%E5%85%8B%E4%BC%9A%E8%B0%88%E8%81%9A%E7%84%A6%E6%A0%B8%E5%A8%81%E6%85%91%E8%AE%AE%E9%A2%98","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776686447000.webp","sourceId":"rfi"},{"id":1776686367000,"createdDate":"2026-04-20 11:59","name":"法国国际广播电台","title":"习近平：霍尔木兹海峡“必须保持畅通”","content":"据中国官方媒体报道，中国国家主席习近平周一在与沙特王储穆罕默德·本·萨勒曼通电话时表示，霍尔木兹海峡必须“保持开放”。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260420-%E4%B9%A0%E8%BF%91%E5%B9%B3-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1-%E5%BF%85%E9%A1%BB%E4%BF%9D%E6%8C%81%E7%95%85%E9%80%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776686367000.webp","sourceId":"rfi"},{"id":1776685654000,"createdDate":"2026-04-20 11:47","name":"法国国际广播电台","title":"距离停火期限到期仅剩两天，美伊谈判前景不明","content":"周一，德黑兰与华盛顿在巴基斯坦举行新一轮谈判的前景依然充满不确定性，双方互不信任，且霍尔木兹海峡的冲突事件频发。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260420-%E8%B7%9D%E7%A6%BB%E5%81%9C%E7%81%AB%E6%9C%9F%E9%99%90%E5%88%B0%E6%9C%9F%E4%BB%85%E5%89%A9%E4%B8%A4%E5%A4%A9%EF%BC%8C%E7%BE%8E%E4%BC%8A%E8%B0%88%E5%88%A4%E5%89%8D%E6%99%AF%E4%B8%8D%E6%98%8E","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776685654000.webp","sourceId":"rfi"},{"id":1776685224000,"createdDate":"2026-04-20 11:40","name":"法国国际广播电台","title":"油价飙升带来的意外之财难掩俄罗斯经济的整体颓势","content":"中东危机依然是20日出版的法国全国性大报但各报重点关注的国际话题。财经报刊《回声报》凸出伊朗与美国围绕此前达成的两周停火接近到期之际的较量。《十字架报》聚焦黎巴嫩与以色列达成的脆弱停火并没能让当地居民的日常生活摆脱战争。法共《人道报》也在头版以醒目标题凸出黎巴嫩南部被战火摧毁的景象。一名法国蓝盔军士兵在黎巴嫩南部身亡是《解放报》关于中东危机报道的主题。《费加罗报》在国际版以一整版篇幅报道黎巴嫩局势，特别是法国在这场并未参战的冲突中遭遇的伤亡。该报也在经济副刊，梳理这场中东冲突给旅游业带来的冲击。该报特别注意到伊朗战争令巴西对中国的石油出口成倍增长，认为中东危机让巴西得以成为中国可靠并且稳定的石油供应者。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20260420-%E6%B2%B9%E4%BB%B7%E9%A3%99%E5%8D%87%E5%B8%A6%E6%9D%A5%E7%9A%84%E6%84%8F%E5%A4%96%E4%B9%8B%E8%B4%A2%E9%9A%BE%E6%8E%A9%E4%BF%84%E7%BD%97%E6%96%AF%E7%BB%8F%E6%B5%8E%E7%9A%84%E6%95%B4%E4%BD%93%E9%A2%93%E5%8A%BF","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776685224000.webp","sourceId":"rfi"},{"id":1776682635000,"createdDate":"2026-04-20 10:57","name":"法国国际广播电台","title":"朝鲜进行改良版短程地对地弹道导弹“火星炮-11丁”威力评估试验","content":"韩联社引述朝中社报道，朝鲜导弹总局19日进行改良版短程地对地弹道导弹“火星炮-11丁”型战斗部威力评估试验，报道称，此次试射旨在确认被搭载于战术弹道导弹的集束战斗部和破片地雷战斗部的特点和威力。5枚导弹朝136公里处的目标岛屿飞行，精准打击12.5～13公顷面积。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260420-%E6%9C%9D%E9%B2%9C%E8%BF%9B%E8%A1%8C%E6%94%B9%E8%89%AF%E7%89%88%E7%9F%AD%E7%A8%8B%E5%9C%B0%E5%AF%B9%E5%9C%B0%E5%BC%B9%E9%81%93%E5%AF%BC%E5%BC%B9-%E7%81%AB%E6%98%9F%E7%82%AE-11%E4%B8%81-%E5%A8%81%E5%8A%9B%E8%AF%84%E4%BC%B0%E8%AF%95%E9%AA%8C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776682635000.webp","sourceId":"rfi"},{"id":1776682138000,"createdDate":"2026-04-20 10:48","name":"法国国际广播电台","title":"日本继父涉嫌杀害男童事件震惊日本 疯传涉嫌者为中国人","content":"在日本，一名失踪的小学生安达结希（11岁），4月13日在京都府南丹市内的山林中发现了其遗体。4月16日凌晨，结希的继父安达优季（37岁）因涉嫌遗弃尸体被逮捕。据称他供述说：“是我做的没错。”此外，他还承认了杀害行为，并说“是一时冲动掐住了他的脖子”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E4%B8%9C%E4%BA%AC%E4%B8%93%E6%A0%8F/20260420-%E6%97%A5%E6%9C%AC%E7%BB%A7%E7%88%B6%E6%B6%89%E5%AB%8C%E6%9D%80%E5%AE%B3%E7%94%B7%E7%AB%A5%E4%BA%8B%E4%BB%B6%E9%9C%87%E6%83%8A%E6%97%A5%E6%9C%AC-%E7%96%AF%E4%BC%A0%E6%B6%89%E5%AB%8C%E8%80%85%E4%B8%BA%E4%B8%AD%E5%9B%BD%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776682138000.webp","sourceId":"rfi"},{"id":1776728672000,"createdDate":"2026-04-20 23:44","name":"法国国际广播电台","title":"刚果民主共和国为淘金热付出沉重代价：污染、腐败与中国企业对土地的掠夺","content":"法国世界报周一刊出长篇文章，报道刚果民主共和国东部的上韦莱省（Haut-Uele），在国际金价持续飙升的背景下，从传统的手工采金区，逐步演变为全球资本、地方权力与外国企业激烈角逐的“黄金前线”。这一切给当地带来的是环境破坏、社会失序，以及制度失灵。而这一切又和中国企业的大规模进入与半机械化开采模式紧密相连，中国企业是当地生态与社会结构剧烈变化的重要推动力量。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E4%B8%96%E7%95%8C%E6%8A%A5/20260420-%E5%88%9A%E6%9E%9C%E6%B0%91%E4%B8%BB%E5%85%B1%E5%92%8C%E5%9B%BD%E4%B8%BA%E6%B7%98%E9%87%91%E7%83%AD%E4%BB%98%E5%87%BA%E6%B2%89%E9%87%8D%E4%BB%A3%E4%BB%B7-%E6%B1%A1%E6%9F%93-%E8%85%90%E8%B4%A5%E4%B8%8E%E4%B8%AD%E5%9B%BD%E4%BC%81%E4%B8%9A%E5%AF%B9%E5%9C%9F%E5%9C%B0%E7%9A%84%E6%8E%A0%E5%A4%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776728672000.webp","sourceId":"rfi"},{"id":1776720334000,"createdDate":"2026-04-20 21:25","name":"法国国际广播电台","title":"核威慑、军事卫星：马克龙与图斯克推进法波防务合作","content":"在欧洲安全局势持续紧张的背景下，法国总统马克龙与波兰总理图斯克周一在波兰北部城市格但斯克（Gdańsk）会晤，重点涉及核威慑、军事卫星及国防工业等关键领域，为法国和波兰的防务合作注入新的动力。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260420-%E6%A0%B8%E5%A8%81%E6%85%91-%E5%86%9B%E4%BA%8B%E5%8D%AB%E6%98%9F-%E9%A9%AC%E5%85%8B%E9%BE%99%E4%B8%8E%E5%9B%BE%E6%96%AF%E5%85%8B%E6%8E%A8%E8%BF%9B%E6%B3%95%E6%B3%A2%E9%98%B2%E5%8A%A1%E5%90%88%E4%BD%9C","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776720334000.webp","sourceId":"rfi"},{"id":1776719831000,"createdDate":"2026-04-20 21:17","name":"法国国际广播电台","title":"爱奇艺推出“演员影像数据库”引发争议","content":"中国在线视频平台爱奇艺（iQiyi）周一(4月20日）推出一项面向人工智能（AI）内容创作的新工具，引发广泛争议。该工具旨在简化影视作品中对演员形象的AI生成与调用，被外界解读为“演员影像数据库”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260420-%E7%88%B1%E5%A5%87%E8%89%BA%E6%8E%A8%E5%87%BA-%E6%BC%94%E5%91%98%E5%BD%B1%E5%83%8F%E6%95%B0%E6%8D%AE%E5%BA%93-%E5%BC%95%E5%8F%91%E4%BA%89%E8%AE%AE","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776719831000.webp","sourceId":"rfi"},{"id":1776719534000,"createdDate":"2026-04-20 21:12","name":"法国国际广播电台","title":"霍尔木兹海峡航运再度全面瘫痪 伊朗与美国互施封锁","content":"霍尔木兹海峡海上交通周一(4月20日）再次陷入完全停滞状态，德黑兰与华盛顿各自实施独立封锁，而伊朗船只继续试图突破美国的阻拦。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260420-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E6%B5%B7%E5%B3%A1%E8%88%AA%E8%BF%90%E5%86%8D%E5%BA%A6%E5%85%A8%E9%9D%A2%E7%98%AB%E7%97%AA-%E4%BC%8A%E6%9C%97%E4%B8%8E%E7%BE%8E%E5%9B%BD%E4%BA%92%E6%96%BD%E5%B0%81%E9%94%81","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776719534000.webp","sourceId":"rfi"},{"id":1776719347000,"createdDate":"2026-04-20 21:09","name":"法国国际广播电台","title":"霍尔木兹封锁：马克龙指美伊双方均有过失 呼吁恢复冷静","content":"正在波兰访问的法国总统马克龙周一(4月20日）指责美国和伊朗在霍尔木兹海峡问题上均犯下“错误”，马克龙指出，封锁海峡推高了石油价格并影响全球经济，他同时呼吁“各方立即恢复冷静”。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260420-%E9%9C%8D%E5%B0%94%E6%9C%A8%E5%85%B9%E5%B0%81%E9%94%81-%E9%A9%AC%E5%85%8B%E9%BE%99%E6%8C%87%E7%BE%8E%E4%BC%8A%E5%8F%8C%E6%96%B9%E5%9D%87%E6%9C%89%E8%BF%87%E5%A4%B1-%E5%91%BC%E5%90%81%E6%81%A2%E5%A4%8D%E5%86%B7%E9%9D%99","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776719347000.webp","sourceId":"rfi"},{"id":1776719129000,"createdDate":"2026-04-20 21:05","name":"法国国际广播电台","title":"特朗普：达成协议才可解除伊朗港口封锁 美代表团即将赴巴基斯坦与伊朗谈判","content":"在霍尔木兹海峡紧张局势持续升级之际，美国代表团“即将”启程前往巴基斯坦，与伊朗举行新一轮会谈；而德黑兰方面则对是否参与谈判保持模糊态度。霍尔木兹海峡成为当前冲突的核心焦点。美国总统特朗普表示：只有达成协议才会解除对伊朗港口封锁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20260420-%E7%89%B9%E6%9C%97%E6%99%AE-%E8%BE%BE%E6%88%90%E5%8D%8F%E8%AE%AE%E6%89%8D%E5%8F%AF%E8%A7%A3%E9%99%A4%E4%BC%8A%E6%9C%97%E6%B8%AF%E5%8F%A3%E5%B0%81%E9%94%81-%E7%BE%8E%E4%BB%A3%E8%A1%A8%E5%9B%A2%E5%8D%B3%E5%B0%86%E8%B5%B4%E5%B7%B4%E5%9F%BA%E6%96%AF%E5%9D%A6%E4%B8%8E%E4%BC%8A%E6%9C%97%E8%B0%88%E5%88%A4","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776719129000.webp","sourceId":"rfi"},{"id":1776717986000,"createdDate":"2026-04-20 20:46","name":"法国国际广播电台","title":"美伊第二轮会谈存变数，德黑兰是否参与不确定","content":"美伊脆弱的停火协议即将到期。巴基斯坦正持续推动战争双方之间新一轮谈判的筹备工作。不过，谈判能否如期举行，仍存在不确定性。特朗普指出，在未达成协议之前，不会解除对伊朗港口的封锁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E8%A6%81%E9%97%BB%E5%88%86%E6%9E%90/20260420-%E7%BE%8E%E4%BC%8A%E7%AC%AC%E4%BA%8C%E8%BD%AE%E4%BC%9A%E8%B0%88%E5%AD%98%E5%8F%98%E6%95%B0%EF%BC%8C%E5%BE%B7%E9%BB%91%E5%85%B0%E6%98%AF%E5%90%A6%E5%8F%82%E4%B8%8E%E4%B8%8D%E7%A1%AE%E5%AE%9A","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776717986000.webp","sourceId":"rfi"},{"id":1776712025000,"createdDate":"2026-04-20 19:07","name":"法国国际广播电台","title":"关税裁定无效 特朗普政府开始接受企业退税申请","content":"美国政府在4月20日正式启动关税退款申请机制，针对先前由美国总统特朗普（DonaldTrump）依紧急权力法课征、但遭法院裁定违法的进口关税，开始受理企业申请退还，总金额预估超过1660亿美元，成为美国史上规模最大的关税退款行动之一。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260420-%E5%85%B3%E7%A8%8E%E8%A3%81%E5%AE%9A%E6%97%A0%E6%95%88-%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E5%BC%80%E5%A7%8B%E6%8E%A5%E5%8F%97%E4%BC%81%E4%B8%9A%E9%80%80%E7%A8%8E%E7%94%B3%E8%AF%B7","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776712025000.webp","sourceId":"rfi"},{"id":1776708447000,"createdDate":"2026-04-20 18:07","name":"法国国际广播电台","title":"习近平在郑习会讲话结束 郑丽文话未毕麦克风消音乌龙 掀议论","content":"各位听众，台湾中国国民党主席郑丽文与中共总书记习近平4月10日周五在北京历史性的会晤可说全球瞩目。而郑习会当中，习近平讲话完毕后，郑丽文的讲话尚未结束，其麦克风被消音的直播画面引发网友关注，尤其台湾网友议论纷纷。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E5%BE%AE%E8%A8%80%E5%BE%AE%E8%AF%AD/20260420-%E4%B9%A0%E8%BF%91%E5%B9%B3%E5%9C%A8%E9%83%91%E4%B9%A0%E4%BC%9A%E8%AE%B2%E8%AF%9D%E7%BB%93%E6%9D%9F-%E9%83%91%E4%B8%BD%E6%96%87%E8%AF%9D%E6%9C%AA%E6%AF%95%E9%BA%A6%E5%85%8B%E9%A3%8E%E6%B6%88%E9%9F%B3%E4%B9%8C%E9%BE%99-%E6%8E%80%E8%AE%AE%E8%AE%BA","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776708447000.webp","sourceId":"rfi"},{"id":1776706724000,"createdDate":"2026-04-20 17:38","name":"法国国际广播电台","title":"非洲:科特迪瓦采纳设立主权基金","content":"在西非国家科特迪瓦，政府已通过了一项法令，旨在设立主权基金，用于给发展项目提供金融支持，并在发生国际危机时用于给予某些行业提供补贴。科特迪瓦的中文国名，也有译作象牙海岸（Côted'Ivoire）。","newsLink":"https://www.rfi.fr/cn/rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2-%E7%A7%91%E7%89%B9%E8%BF%AA%E7%93%A6%E9%87%87%E7%BA%B3%E8%AE%BE%E7%AB%8B%E4%B8%BB%E6%9D%83%E5%9F%BA%E9%87%91","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776706724000.webp","sourceId":"rfi"},{"id":1776706180000,"createdDate":"2026-04-20 17:29","name":"法国国际广播电台","title":"日本内阁官房长官避谈高市首相未参加首脑线上会议原因","content":"4月17日，围绕霍尔木兹海峡问题，志同道合国家举行了“关于霍尔木兹海峡航行自由的首脑线上会议”，有50多个国家和机构参加，并就清除霍尔木兹海峡的水雷等问题进行了讨论,目前没有迹象表明日本首相高市早苗参加了这次线上会议，日本官房长官木原稔在20日上午的记者会上证实了高市早苗首相没有参加17日的首脑线上会议，日本方面由国家安全保障局长市川惠一出席，高市首相发表了书面致辞，但是他回避了回答高市早苗首相没有参加首脑线上会议的具体原因。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20260420-%E6%97%A5%E6%9C%AC%E5%86%85%E9%98%81%E5%AE%98%E6%88%BF%E9%95%BF%E5%AE%98%E9%81%BF%E8%B0%88%E9%AB%98%E5%B8%82%E9%A6%96%E7%9B%B8%E6%9C%AA%E5%8F%82%E5%8A%A0%E9%A6%96%E8%84%91%E7%BA%BF%E4%B8%8A%E4%BC%9A%E8%AE%AE%E5%8E%9F%E5%9B%A0","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776706180000.webp","sourceId":"rfi"},{"id":1776704438000,"createdDate":"2026-04-20 17:00","name":"法国国际广播电台","title":"保加利亚前总统赢选举 兼收亲俄亲西方票仓 或终结政治动荡","content":"据周一公布的近乎最终的选举结果显示，主张恢复与莫斯科对话的保加利亚前总统鲁门·拉德夫在议会选举中赢得多数席位，这可能结束该国五年内经历八次议会选举后持续的政治动荡。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20260420-%E4%BF%9D%E5%8A%A0%E5%88%A9%E4%BA%9A%E5%89%8D%E6%80%BB%E7%BB%9F%E8%B5%A2%E8%AE%AE%E4%BC%9A%E9%80%89%E4%B8%BE-%E4%B8%BB%E5%BC%A0%E4%B8%8E%E4%BF%84%E5%AF%B9%E8%AF%9D-%E8%8E%AB%E6%96%AF%E7%A7%91%E8%A1%A8%E7%A4%BA%E8%B5%9E%E8%B5%8F","thumbnail":"","detailImage":"news/detail/rfi/2026/04/20/1776704438000.webp","sourceId":"rfi"}]