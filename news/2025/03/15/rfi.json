[{"id":1741996951000,"createdDate":"2025-03-15 00:02","name":"法国国际广播电台","title":"调查显示 法国年轻人对时事焦虑程度创历史新高","content":"周五公布的一项青少年心理健康年度调查显示，针对儿童的暴力、世界状况、全球变暖等多种问题，法国青少年2024年对时事的焦虑达到最高水平。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20250315-%E8%B0%83%E6%9F%A5%E6%98%BE%E7%A4%BA-%E6%B3%95%E5%9B%BD%E5%B9%B4%E8%BD%BB%E4%BA%BA%E5%AF%B9%E6%97%B6%E4%BA%8B%E7%84%A6%E8%99%91%E7%A8%8B%E5%BA%A6%E5%88%9B%E5%8E%86%E5%8F%B2%E6%96%B0%E9%AB%98","thumbnail":"","detailImage":"news/detail/rfi/2025/03/15/1741996951000.webp","sourceId":"rfi"},{"id":1742039632000,"createdDate":"2025-03-15 11:53","name":"法国国际广播电台","title":"美国宣布驱逐南非大使，南非总统对此表示遗憾","content":"自特朗普重返白宫以来迅速恶化的美国与南非关系出现紧张升级。14日晚间，美国国务卿卢比奥宣布驱逐南非驻美大使易卜拉欣-拉苏尔，称拉苏尔是“仇恨美国和仇恨特朗普总统“的”种族歧视政客\"。南非总统拉马福萨对这项驱逐决定表示遗憾，但也表示南非不会被特朗普的压力吓倒。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20250315-%E7%BE%8E%E5%9B%BD%E5%AE%A3%E5%B8%83%E9%A9%B1%E9%80%90%E5%8D%97%E9%9D%9E%E5%A4%A7%E4%BD%BF%EF%BC%8C%E5%8D%97%E9%9D%9E%E6%80%BB%E7%BB%9F%E5%AF%B9%E6%AD%A4%E8%A1%A8%E7%A4%BA%E9%81%97%E6%86%BE","thumbnail":"","detailImage":"news/detail/rfi/2025/03/15/1742039632000.webp","sourceId":"rfi"},{"id":1742038776000,"createdDate":"2025-03-15 11:39","name":"法国国际广播电台","title":"费加罗报：中国入侵台湾的两栖登陆巨舰 开始测试","content":"据《费加罗报》国际版由AlexisFeertchak所撰文章指出，中国刚测试了入侵台湾所需的两栖登陆艇。它们的建造今年1月在中国南部的一家造船厂被卫星影像所揭露，在南中国海一片灰暗的海滩上，它们在水面上延伸，一直延伸到广东省湛江市的大陆，距离台湾要塞有一千公里之遥。让人想起盟军在诺曼底登陆时使用的代号“桑葚”的人工港。","newsLink":"https://www.rfi.fr/cn/%E4%B8%93%E6%A0%8F%E6%A3%80%E7%B4%A2/%E6%B3%95%E5%9B%BD%E6%8A%A5%E7%BA%B8%E6%91%98%E8%A6%81/20250315-%E8%B4%B9%E5%8A%A0%E7%BD%97%E6%8A%A5-%E4%B8%AD%E5%9B%BD%E5%85%A5%E4%BE%B5%E5%8F%B0%E6%B9%BE%E7%9A%84%E4%B8%A4%E6%A0%96%E7%99%BB%E9%99%86%E5%B7%A8%E8%88%B0-%E5%BC%80%E5%A7%8B%E6%B5%8B%E8%AF%95","thumbnail":"","detailImage":"news/detail/rfi/2025/03/15/1742038776000.webp","sourceId":"rfi"},{"id":1742035905000,"createdDate":"2025-03-15 10:51","name":"法国国际广播电台","title":"日本首相向手下议员发放商品劵曝光 面临重大政治危机","content":"最近，日本首相石破茂向手下议员发放商品劵曝光，在政坛掀起轩然大波，遭到在野党甚至执政党的严厉批判，面临重大政治危机。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20250315-%E6%97%A5%E6%9C%AC%E9%A6%96%E7%9B%B8%E5%90%91%E6%89%8B%E4%B8%8B%E8%AE%AE%E5%91%98%E5%8F%91%E6%94%BE%E5%95%86%E5%93%81%E5%8A%B5%E6%9B%9D%E5%85%89-%E9%9D%A2%E4%B8%B4%E9%87%8D%E5%A4%A7%E6%94%BF%E6%B2%BB%E5%8D%B1%E6%9C%BA","thumbnail":"","detailImage":"news/detail/rfi/2025/03/15/1742035905000.webp","sourceId":"rfi"},{"id":1742027367000,"createdDate":"2025-03-15 08:29","name":"法国国际广播电台","title":"特朗普拟推新禁令：对40多国实施旅游签证限制","content":"根据熟知内情的消息人士与路透社看到的内部备忘录，美国特朗普政府正在考虑推出新的禁令，将对40多个国家的公民实施广泛的旅行限制。","newsLink":"https://www.rfi.fr/cn/%E7%BE%8E%E6%B4%B2/20250315-%E7%89%B9%E6%9C%97%E6%99%AE%E6%8B%9F%E6%8E%A8%E6%96%B0%E7%A6%81%E4%BB%A4-%E5%AF%B940%E5%A4%9A%E5%9B%BD%E5%AE%9E%E6%96%BD%E6%97%85%E6%B8%B8%E7%AD%BE%E8%AF%81%E9%99%90%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2025/03/15/1742027367000.webp","sourceId":"rfi"}]