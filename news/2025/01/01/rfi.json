[{"id":1735735061000,"createdDate":"2025-01-01 12:37","name":"法国国际广播电台","title":"俄罗斯新年发射111无人机袭击基辅市中心","content":"周三元旦日，莫斯科军队向基辅发动袭击，在乌克兰新年期间向基辅发射了111架无人机，造成1人死亡、7人受伤。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20250101-%E4%BF%84%E7%BD%97%E6%96%AF%E6%96%B0%E5%B9%B4%E5%8F%91%E5%B0%84111%E6%97%A0%E4%BA%BA%E6%9C%BA%E8%A2%AD%E5%87%BB%E5%9F%BA%E8%BE%85%E5%B8%82%E4%B8%AD%E5%BF%83","thumbnail":"","detailImage":"news/detail/rfi/2025/01/01/1735735061000.webp","sourceId":"rfi"},{"id":1735727705000,"createdDate":"2025-01-01 10:35","name":"法国国际广播电台","title":"中国C919首班飞港定航客机今抵香港","content":"由中国国产C919飞机执飞的首班往来上海和香港之间的客机，今早10时40分顺利降落香港国际机场，比原定时间早约5分钟。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20250101-%E4%B8%AD%E5%9B%BDc919%E9%A6%96%E7%8F%AD%E9%A3%9E%E6%B8%AF%E5%AE%9A%E8%88%AA%E5%AE%A2%E6%9C%BA%E4%BB%8A%E6%8A%B5%E9%A6%99%E6%B8%AF","thumbnail":"","detailImage":"news/detail/rfi/2025/01/01/1735727705000.webp","sourceId":"rfi"},{"id":1735727315000,"createdDate":"2025-01-01 10:28","name":"法国国际广播电台","title":"中国哈尔滨：庆新年热闹之地","content":"中国东北哈尔滨成为阳历新年旅游地新宠。在哈尔滨寒冷的街道上，仍然有一群群戴着饰有绒球和兽耳帽子的游客漫步，他们被社交网络上同样流行的旅游趋势指点所吸引。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20250101-%E4%B8%AD%E5%9B%BD%E5%93%88%E5%B0%94%E6%BB%A8-%E5%BA%86%E6%96%B0%E5%B9%B4%E7%83%AD%E9%97%B9%E4%B9%8B%E5%9C%B0","thumbnail":"","detailImage":"news/detail/rfi/2025/01/01/1735727315000.webp","sourceId":"rfi"},{"id":1735726505000,"createdDate":"2025-01-01 10:15","name":"法国国际广播电台","title":"世界辞旧迎新又一瞥","content":"从最早进入2025年的澳大利亚悉尼开始，再经卡拉奇旋转到巴黎，昨夜今晨，全世界在烟花燃放中庆祝2025年到来，而在2024年结束之际，乌克兰战争，奥运金牌、特朗普的强势回归白宫以及中东的新剧变话题仍然充斥着2024年的结束时的最后时刻。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20250101-%E4%B8%96%E7%95%8C%E8%BE%9E%E6%97%A7%E8%BF%8E%E6%96%B0%E5%8F%88%E4%B8%80%E7%9E%A5","thumbnail":"","detailImage":"news/detail/rfi/2025/01/01/1735726505000.webp","sourceId":"rfi"},{"id":1735725334000,"createdDate":"2025-01-01 09:55","name":"法国国际广播电台","title":"中国今天开始实行新退休制","content":"中国今天发布“实施弹性退休制度暂行办法”，延后退休正式上路。目前职工达到按月领取基本养老金最低缴费年限者，可申请提前或延后退休，均不得超过3年。接下来将用15年时间，逐步将退休年龄分情况调高3至5岁。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20250101-%E4%B8%AD%E5%9B%BD%E4%BB%8A%E5%A4%A9%E5%BC%80%E5%A7%8B%E5%AE%9E%E8%A1%8C%E6%96%B0%E9%80%80%E4%BC%91%E5%88%B6","thumbnail":"","detailImage":"news/detail/rfi/2025/01/01/1735725334000.webp","sourceId":"rfi"},{"id":1735724868000,"createdDate":"2025-01-01 09:47","name":"法国国际广播电台","title":"俄罗斯今切断经乌克兰输欧天然气","content":"乌克兰与俄罗斯今天分别宣布，切断了通过乌克兰的俄罗斯输往欧洲的天然气供应。此前2019年，俄罗斯与乌克兰签署为期五年合同，该合同今天到期。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20250101-%E4%BF%84%E7%BD%97%E6%96%AF%E4%BB%8A%E5%88%87%E6%96%AD%E7%BB%8F%E4%B9%8C%E5%85%8B%E5%85%B0%E8%BE%93%E6%AC%A7%E5%A4%A9%E7%84%B6%E6%B0%94","thumbnail":"","detailImage":"news/detail/rfi/2025/01/01/1735724868000.webp","sourceId":"rfi"},{"id":1735723981000,"createdDate":"2025-01-01 09:33","name":"法国国际广播电台","title":"叙利亚：以“自由喜悦”和“安全希望”迎新年","content":"经过十多年毁灭性的战争，独裁政权阿萨德倒台标志着叙利亚进入历史的转折点，罕见让叙利亚人找到自由的欢乐的时刻。今年除夕夜，数百万叙利亚人聚集在大马士革以及其它城市街头，庆祝这2024年结束，同时也庆祝一个以镇压和战争为标志的时代的结束。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20250101-%E5%8F%99%E5%88%A9%E4%BA%9A-%E4%BB%A5-%E8%87%AA%E7%94%B1%E5%96%9C%E6%82%A6-%E5%92%8C-%E5%AE%89%E5%85%A8%E5%B8%8C%E6%9C%9B-%E8%BF%8E%E6%96%B0%E5%B9%B4","thumbnail":"","detailImage":"news/detail/rfi/2025/01/01/1735723981000.webp","sourceId":"rfi"},{"id":1735721523000,"createdDate":"2025-01-01 08:52","name":"法国国际广播电台","title":"法国在西非又一“重挫”：科特迪瓦总统宣布法国即将从该国撤军","content":"科特迪瓦在12月31日宣布，法国军队将在科特迪瓦驻扎数十年后撤离。这是非洲国家中最新一个减少与法国这一前殖民大国军事关系的国家。","newsLink":"https://www.rfi.fr/cn/%E9%9D%9E%E6%B4%B2/20250101-%E6%B3%95%E5%9B%BD%E5%9C%A8%E8%A5%BF%E9%9D%9E%E5%8F%88%E4%B8%80-%E9%87%8D%E6%8C%AB-%E7%A7%91%E7%89%B9%E8%BF%AA%E7%93%A6%E6%80%BB%E7%BB%9F%E5%AE%A3%E5%B8%83%E6%B3%95%E5%9B%BD%E5%8D%B3%E5%B0%86%E4%BB%8E%E8%AF%A5%E5%9B%BD%E6%92%A4%E5%86%9B","thumbnail":"","detailImage":"news/detail/rfi/2025/01/01/1735721523000.webp","sourceId":"rfi"},{"id":1735718876000,"createdDate":"2025-01-01 08:07","name":"法国国际广播电台","title":"中港股市去年齐升 香港升近17.7% 七年最强 专家对後市审慎","content":"香港股市在连跌四年之後，2024年全年升逾三千点，升幅达17.67%，论点数或升幅均是2017年後最高；反映在香上市中国内地企业表现之恒生中国企业指数（「国指」）亦上升1521点，升幅更高达26.4%，是2009年以来表现最佳的一年，成为继台湾加权指数後，亚太区股市中表现第二佳的指数。不过，市场对中国内地经济转趋观望，加上美国联储局减息预期降温，中美贸易战亦可能加剧，令专家对短期後市持审慎态度。","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20250101-%E4%B8%AD%E6%B8%AF%E8%82%A1%E5%B8%82%E5%8E%BB%E5%B9%B4%E9%BD%90%E5%8D%87-%E9%A6%99%E6%B8%AF%E5%8D%87%E8%BF%9117-7-%E4%B8%83%E5%B9%B4%E6%9C%80%E5%BC%BA-%E4%B8%93%E5%AE%B6%E5%AF%B9%E5%BE%8C%E5%B8%82%E5%AE%A1%E6%85%8E","thumbnail":"","detailImage":"news/detail/rfi/2025/01/01/1735718876000.webp","sourceId":"rfi"},{"id":1735718393000,"createdDate":"2025-01-01 07:59","name":"法国国际广播电台","title":"刘锐绍被停所有电台节目 黄国才发片声援留港被打压的艺文人","content":"新年前夕的两则帖文，预示了香港今年的文艺自由：一是熟悉中国时事丶言论温和的评论员刘锐绍在商业电台(商台)的节目嘉宾主持身份被停，他在脸书上自嘲地说，由今天开始，「我的所有电台节目全部正式被『与时俱退』」，反映香港评论空间进一步收窄；二是移居台湾的香港艺术家黄国才在个人脸书上载在「海牙国际法院」前演奏的《愿荣光归香港》影片，「献给一众仍在香港努力，但每天被威权暴政打压的艺文创作人。」","newsLink":"https://www.rfi.fr/cn/%E6%B8%AF%E6%BE%B3%E5%8F%B0/20250101-%E5%88%98%E9%94%90%E7%BB%8D%E8%A2%AB%E5%81%9C%E6%89%80%E6%9C%89%E7%94%B5%E5%8F%B0%E8%8A%82%E7%9B%AE-%E9%BB%84%E5%9B%BD%E6%89%8D%E5%8F%91%E7%89%87%E5%A3%B0%E6%8F%B4%E7%95%99%E6%B8%AF%E8%A2%AB%E6%89%93%E5%8E%8B%E7%9A%84%E8%89%BA%E6%96%87%E4%BA%BA","thumbnail":"","detailImage":"news/detail/rfi/2025/01/01/1735718393000.webp","sourceId":"rfi"}]