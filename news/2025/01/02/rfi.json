[{"id":1735821330000,"createdDate":"2025-01-02 12:35","name":"法国国际广播电台","title":"贝鲁继续咨询 试图避免遭弹劾","content":"法国新政府继续陷于千头万绪的麻烦与压力，其中首要是寻求各党派协议，在2025年预算案议题上，避免被弹劾。极左翼领袖威胁不让贝鲁总理的政府寿长长过这个冬天。","newsLink":"https://www.rfi.fr/cn/%E6%B3%95%E5%9B%BD/20250102-%E8%B4%9D%E9%B2%81%E7%BB%A7%E7%BB%AD%E5%92%A8%E8%AF%A2-%E8%AF%95%E5%9B%BE%E9%81%BF%E5%85%8D%E9%81%AD%E5%BC%B9%E5%8A%BE","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735821330000.webp","sourceId":"rfi"},{"id":1735818851000,"createdDate":"2025-01-02 11:54","name":"法国国际广播电台","title":"黑山新年枪击案引震惊","content":"黑山检察官周四今天表示，一名武装男子在黑山南部一家餐馆开枪，造成十二人死亡，其中包括两名儿童。黑山政府宣布从周四开始进行为期三天的全国哀悼。","newsLink":"https://www.rfi.fr/cn/%E6%AC%A7%E6%B4%B2/20250102-%E9%BB%91%E5%B1%B1%E6%96%B0%E5%B9%B4%E6%9E%AA%E5%87%BB%E6%A1%88%E5%BC%95%E9%9C%87%E6%83%8A","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735818851000.webp","sourceId":"rfi"},{"id":1735818198000,"createdDate":"2025-01-02 11:43","name":"法国国际广播电台","title":"人民币国际化：专家问真的都准备好了？包括逆差与高失业","content":"中国政府提出要推进人民币国际化，前中国银行首席经济学家曹远征表示，人民币要成为国际货币有3个条件，包括要有稳定逆差形成机制，这会将中国的高额顺差变成逆差，意味着失业问题会非常严峻。根据环球银行金融电信协会（Swift）去年12月公布，去年11月人民币在全球支付货币中占比升至3.89%，是全球第4大最活跃货币。在全球支付市场中，美元仍占据主导地位。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20250102-%E4%BA%BA%E6%B0%91%E5%B8%81%E5%9B%BD%E9%99%85%E5%8C%96-%E4%B8%93%E5%AE%B6%E9%97%AE%E7%9C%9F%E7%9A%84%E9%83%BD%E5%87%86%E5%A4%87%E5%A5%BD%E4%BA%86-%E5%8C%85%E6%8B%AC%E9%80%86%E5%B7%AE%E4%B8%8E%E9%AB%98%E5%A4%B1%E4%B8%9A","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735818198000.webp","sourceId":"rfi"},{"id":1735813905000,"createdDate":"2025-01-02 10:31","name":"法国国际广播电台","title":"中国呼吸道疾病大流行 各地医院门诊爆满","content":"自去年12月，中国出现大规模呼吸道疾病传染态势，包括流感、“人类间质肺炎病毒”、COVID-19、肺炎徽浆菌、腺病毒等疾病齐发，导致中国各地特别是北方省区医院人满为患。其中，北京传播最广的流感将于1月上旬达到高峰。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20250102-%E4%B8%AD%E5%9B%BD%E5%91%BC%E5%90%B8%E9%81%93%E7%96%BE%E7%97%85%E5%A4%A7%E6%B5%81%E8%A1%8C-%E5%90%84%E5%9C%B0%E5%8C%BB%E9%99%A2%E9%97%A8%E8%AF%8A%E7%88%86%E6%BB%A1","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735813905000.webp","sourceId":"rfi"},{"id":1735813362000,"createdDate":"2025-01-02 10:22","name":"法国国际广播电台","title":"韩国法警今要动强逮捕总统 尹锡悦如何拒捕引聚焦","content":"韩国反对派推动对总统尹锡悦发布戒严令涉动乱罪弹劾，调查并逮捕。尹锡悦至此拒绝已经由国家警方与司法机构对他的所有传票。尹锡悦今天能否继续顽抗，成为聚焦。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20250102-%E9%9F%A9%E5%9B%BD%E6%B3%95%E8%AD%A6%E4%BB%8A%E8%A6%81%E5%8A%A8%E5%BC%BA%E9%80%AE%E6%8D%95%E6%80%BB%E7%BB%9F-%E5%B0%B9%E9%94%A1%E6%82%A6%E5%A6%82%E4%BD%95%E6%8B%92%E6%8D%95%E5%BC%95%E8%81%9A%E7%84%A6","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735813362000.webp","sourceId":"rfi"},{"id":1735812975000,"createdDate":"2025-01-02 10:16","name":"法国国际广播电台","title":"德国总理舒尔茨新年致辞谴责马斯克干政","content":"德国总理奥拉夫·舒尔茨本次的新年电视演讲也许是最后一次。在政治动荡和欧洲加剧分化的背景下，舒尔茨不仅提到了经济、团结等问题，还尤其提到了即将执掌未来特朗普政府的“政府效能部”的亿万富翁埃隆·马斯克。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20250102-%E5%BE%B7%E5%9B%BD%E6%80%BB%E7%90%86%E8%88%92%E5%B0%94%E8%8C%A8%E6%96%B0%E5%B9%B4%E8%87%B4%E8%BE%9E%E8%B0%B4%E8%B4%A3%E9%A9%AC%E6%96%AF%E5%85%8B%E5%B9%B2%E6%94%BF","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735812975000.webp","sourceId":"rfi"},{"id":1735811898000,"createdDate":"2025-01-02 09:58","name":"法国国际广播电台","title":"日中韩三国合作选“未来”为今年代表词","content":"日中韩合作秘书处宣布，“未来”当选2025年三国合作关系代表性汉字词语。词语由日中韩民众投票选定。设址在韩国首尔的该3国合作秘书处1日称，该词“体现了对建立更紧密联系的乐观和决心”，期待交流进一步深化。","newsLink":"https://www.rfi.fr/cn/%E4%BA%9A%E6%B4%B2/20250102-%E6%97%A5%E4%B8%AD%E9%9F%A9%E4%B8%89%E5%9B%BD%E5%90%88%E4%BD%9C%E9%80%89-%E6%9C%AA%E6%9D%A5-%E4%B8%BA%E4%BB%8A%E5%B9%B4%E4%BB%A3%E8%A1%A8%E8%AF%8D","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735811898000.webp","sourceId":"rfi"},{"id":1735811219000,"createdDate":"2025-01-02 09:46","name":"法国国际广播电台","title":"2025全球股市第一天：有涨有跌","content":"一月2日星期四是2025年的第一个交易日，全球股市涨跌互现，中国基准指数下跌超过2%。","newsLink":"https://www.rfi.fr/cn/%E5%9B%BD%E9%99%85/20250102-2025%E5%85%A8%E7%90%83%E8%82%A1%E5%B8%82%E7%AC%AC%E4%B8%80%E5%A4%A9-%E6%9C%89%E6%B6%A8%E6%9C%89%E8%B7%8C","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735811219000.webp","sourceId":"rfi"},{"id":1735810387000,"createdDate":"2025-01-02 09:33","name":"法国国际广播电台","title":"2024：中国官称最热年份","content":"中国当局宣布，2024年是中国有记录以来最热的一年。据法新社称，气候变化导致的极端天气现象在世界各地不断增加。世界气象组织（WMO）周一警告称，去年气候变化引发了极端天气和创纪录的高温。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20250102-2024-%E4%B8%AD%E5%9B%BD%E5%AE%98%E7%A7%B0%E6%9C%80%E7%83%AD%E5%B9%B4%E4%BB%BD","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735810387000.webp","sourceId":"rfi"},{"id":1735809646000,"createdDate":"2025-01-02 09:20","name":"法国国际广播电台","title":"俄罗斯早已做好攻击日韩160个目标清单","content":"英国经济媒体《金融时报》报道，俄罗斯军队曾假设与日本和韩国之间发生战争的事态，制定了一份包含两国防御设施、核电站等总计160个目标的攻击清单。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20250102-%E4%BF%84%E7%BD%97%E6%96%AF%E6%97%A9%E5%B7%B2%E5%81%9A%E5%A5%BD%E6%94%BB%E5%87%BB%E6%97%A5%E9%9F%A9160%E4%B8%AA%E7%9B%AE%E6%A0%87%E6%B8%85%E5%8D%95","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735809646000.webp","sourceId":"rfi"},{"id":1735809427000,"createdDate":"2025-01-02 09:17","name":"法国国际广播电台","title":"中国对美国新奥尔良汽车撞人案称“震惊”","content":"中国今天对美国新奥尔良发生的致命袭击事件称感到“震惊”，并向遇难者家属表示慰问。美国新奥尔良汽车撞人案死亡人数暂定升至15人。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20250102-%E4%B8%AD%E5%9B%BD%E5%AF%B9%E7%BE%8E%E5%9B%BD%E6%96%B0%E5%A5%A5%E5%B0%94%E8%89%AF%E6%B1%BD%E8%BD%A6%E6%92%9E%E4%BA%BA%E6%A1%88%E7%A7%B0-%E9%9C%87%E6%83%8A","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735809427000.webp","sourceId":"rfi"},{"id":1735808435000,"createdDate":"2025-01-02 09:00","name":"法国国际广播电台","title":"财新PMI显示中国制造业12月增长放缓","content":"周四（1月2日）公布的一项独立指数显示，12月份中国制造业活动继续增长，但增速低于上月。财新分析援引专家指，由于国内需求不振和外部不利因素增多，中国经济下行压力依然很大。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20250102-%E8%B4%A2%E6%96%B0pmi%E6%98%BE%E7%A4%BA%E4%B8%AD%E5%9B%BD%E5%88%B6%E9%80%A0%E4%B8%9A12%E6%9C%88%E5%A2%9E%E9%95%BF%E6%94%BE%E7%BC%93","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735808435000.webp","sourceId":"rfi"},{"id":1735807663000,"createdDate":"2025-01-02 08:47","name":"法国国际广播电台","title":"香港助力国产C919飞入国际舞台 舆论称面对认证和美国阻挠 料路漫漫","content":"中国国产大型民航客机C919在元旦日由上海首航香港，成为国产机首次飞出大陆的首条定期商业航线，运输及物流局局长陈美宝透露，香港国际航空学院正考虑把培训课程扩展至包含C919，支持该客机的维修工作，相信作为国际航空枢纽的香港，可以帮助C919「踏出世界的舞台」。不少报章社论均肯定香港在这方面可以作出的贡献，但《信报》指出，要打入国际市场，仍有较长的路要走，不可能一蹴即就。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20250102-%E9%A6%99%E6%B8%AF%E5%8A%A9%E5%8A%9B%E5%9B%BD%E4%BA%A7c919%E9%A3%9E%E5%85%A5%E5%9B%BD%E9%99%85%E8%88%9E%E5%8F%B0-%E8%88%86%E8%AE%BA%E7%A7%B0%E9%9D%A2%E5%AF%B9%E8%AE%A4%E8%AF%81%E5%92%8C%E7%BE%8E%E5%9B%BD%E9%98%BB%E6%8C%A0-%E6%96%99%E8%B7%AF%E6%BC%AB%E6%BC%AB","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735807663000.webp","sourceId":"rfi"},{"id":1735805935000,"createdDate":"2025-01-02 08:18","name":"法国国际广播电台","title":"澳门去年博彩收入2268亿 升24% 惟上月赌收两年来首降 疑因习近平访澳","content":"有东方蒙地卡罗之称的澳门，2024年全年的赌博收入达2267.8亿澳门元(下同，折算约273.6亿欧元)，超出政府预期，按年升幅亦达23.9%，但只及疫情前的77.5%；而教人诧异的是，上月的赌收是中国通关两年来首次出现下跌，美媒彭博引述业界称，可能是因为中国国家主席习近平当月来澳出席回归25同年庆典而加强保安，导致旅客减少。","newsLink":"https://www.rfi.fr/cn/%E4%B8%AD%E5%9B%BD/20250102-%E6%BE%B3%E9%97%A8%E5%8E%BB%E5%B9%B4%E5%8D%9A%E5%BD%A9%E6%94%B6%E5%85%A52268%E4%BA%BF-%E5%8D%8724-%E6%83%9F%E4%B8%8A%E6%9C%88%E8%B5%8C%E6%94%B6%E4%B8%A4%E5%B9%B4%E6%9D%A5%E9%A6%96%E9%99%8D-%E7%96%91%E5%9B%A0%E4%B9%A0%E8%BF%91%E5%B9%B3%E8%AE%BF%E6%BE%B3","thumbnail":"","detailImage":"news/detail/rfi/2025/01/02/1735805935000.webp","sourceId":"rfi"}]